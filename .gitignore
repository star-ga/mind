# Rust
/target/
**/*.rs.bk
*.pdb
Cargo.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# LLVM
*.bc
*.ll

# Build artifacts
/build/
/dist/
*.o
*.so
*.dylib
*.dll

# Exception: the RFC 0008 Phase G keystone oracle is a committed, blessed
# real-ELF artifact (examples/mindc_mind/libmindc_mind.so) that the
# mindcraft_self_host gate compares its fresh build against under
# MIND_BENCH_REQUIRE=1. It is produced deterministically by
#   mindc --emit-shared examples/mindc_mind/libmindc_mind.so \
#         examples/mindc_mind/main.mind
# (LLVM 18 toolchain). Re-bless from a verified real-ELF build only.
!examples/mindc_mind/libmindc_mind.so

# Testing
/coverage/
*.profraw
*.profdata

# Documentation
/book/
/target/doc/

# Environment
.env
.env.local

# Benchmarks
/bench_results/

# Examples output
/examples/output/

# Never commit patent/IP documents to public repos
*PATENT*
*patent*
*.patent.*
*_PATENT_*

# arch-mind transient state (Tranche 5). Includes last_summary.json,
# key.local, and store.lock because they embed absolute repo paths.
.arch-mind/store/
.arch-mind/_log_*
.arch-mind/scan_before.json
.arch-mind/last_summary.json
.arch-mind/key.local
.arch-mind/store.lock

# Private audit reports (Copilot CLI, internal review). The JSON baseline
# arch-mind-v*.json files ARE public-safe (raw metrics, no leak quotes) and
# are tracked individually below the wildcard.
audits/*-audit.md
audits/*-review.md

# mindc doc smoke-test artifacts (canonical output is target/doc/)
std/**/*.html
examples/**/*.html

# Agent worktree isolation (local sub-agent infrastructure, never tracked)
.claude/
