# Rust
/target/
**/*.rs.bk
*.pdb
Cargo.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# LLVM
*.bc
*.ll

# Build artifacts
/build/
/dist/
*.o
*.so
*.dylib
*.dll

# Testing
/coverage/
*.profraw
*.profdata

# Documentation
/book/
/target/doc/

# Environment
.env
.env.local

# Benchmarks
/bench_results/

# Examples output
/examples/output/

# Never commit patent/IP documents to public repos
*PATENT*
*patent*
*.patent.*
*_PATENT_*

# arch-mind transient state (Tranche 5). Includes last_summary.json,
# key.local, and store.lock because they embed absolute repo paths.
.arch-mind/store/
.arch-mind/store.pre-rotation-*/
.arch-mind/keys.json
.arch-mind/_log_*
.arch-mind/scan_before.json
.arch-mind/last_summary.json
.arch-mind/key.local
.arch-mind/store.lock

# Private audit reports (Copilot CLI, internal review). The JSON baseline
# arch-mind-v*.json files ARE public-safe (raw metrics, no leak quotes) and
# are tracked individually below the wildcard.
audits/*-audit.md
audits/*-review.md

# mindc doc smoke-test artifacts (canonical output is target/doc/)
std/**/*.html
examples/**/*.html

# Agent worktree isolation (local sub-agent infrastructure, never tracked)
.claude/

# Aspirational examples — use MIND language features not yet implemented in the
# parser (tensor type syntax, for/in loops, tuple destructuring, hex literals,
# compound assignment, &[u8] slices).  These files are git-tracked design
# references; this gitignore entry only excludes them from `mindc check` via the
# VCS integration (vcs.use_ignore_file = true in Mind.toml mindcraft config).
# Remove an entry once the corresponding parser feature ships.
/examples/remizov_benchmark.mind
/examples/remizov_feynman.mind
/examples/remizov_gpu.mind
/examples/remizov_inverse.mind
/examples/remizov_solver.mind
/examples/remizov_verify.mind
/examples/fft_signal.mind
/examples/policy.mind
/examples/compliance/auditable_model.mind
/examples/zoo/

# build artifacts must not be committed (unprotected .so)
examples/**/*.so

# Iteration-operator research + prior-art papers name a design-partner — keep in mind-internal, never public
docs/research/
