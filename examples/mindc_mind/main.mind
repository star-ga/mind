    8
}
pub fn tk_colon() -> i64 {
    9
}
pub fn tk_arrow() -> i64 {
    10
}
pub fn tk_eq() -> i64 {
    11
}
pub fn tk_plus() -> i64 {
    12
}
pub fn tk_minus() -> i64 {
    13
}
pub fn tk_star() -> i64 {
    14
}
pub fn tk_slash() -> i64 {
    15
}
pub fn tk_lt() -> i64 {
    16
}
pub fn tk_gt() -> i64 {
    17
}
