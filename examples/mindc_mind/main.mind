    1541459225
}
// W schedule helpers — 64 words stored stride-8 (like a Vec element).
pub fn nb_w_get(w_addr: i64, i: i64) -> i64 {
    __mind_load_i64(w_addr + i * 8)
}
pub fn nb_w_set(w_addr: i64, i: i64, v: i64) -> i64 {
    __mind_store_i64(w_addr + i * 8, v)
}

// compress_block — process one 64-byte block at `block_addr` (stride-1 bytes)
// into the 8-word H state at `h_addr` (stride-8). Mirrors sha256_compress.
// One round of compression. Working vars a..h live in the stride-8 scratch `v`
// (v[0]=a..v[7]=h); state stays in MEMORY so the 64-round driver carries ONLY its
// loop counter (single-carry while — the nfn-emittable subset; an 8-`let mut`
// loop-carry is out of subset and fails the flip). Pure i64 + &0xffffffff masks.
pub fn nb_sha256_round(v: i64, w_addr: i64, rnd: i64) -> i64 {
    let va: i64 = __mind_load_i64(v + 0 * 8);
    let vb: i64 = __mind_load_i64(v + 1 * 8);
    let vc: i64 = __mind_load_i64(v + 2 * 8);
    let vd: i64 = __mind_load_i64(v + 3 * 8);
    let ve: i64 = __mind_load_i64(v + 4 * 8);
    let vf: i64 = __mind_load_i64(v + 5 * 8);
    let vg: i64 = __mind_load_i64(v + 6 * 8);
    let vh: i64 = __mind_load_i64(v + 7 * 8);
    let t1: i64 = nb_mask32(vh + nb_bsig1(ve) + nb_ch(ve, vf, vg) + nb_k_word(rnd) + nb_w_get(w_addr, rnd));
    let t2: i64 = nb_mask32(nb_bsig0(va) + nb_maj(va, vb, vc));
    __mind_store_i64(v + 7 * 8, vg);
    __mind_store_i64(v + 6 * 8, vf);
    __mind_store_i64(v + 5 * 8, ve);
    __mind_store_i64(v + 4 * 8, nb_mask32(vd + t1));
    __mind_store_i64(v + 3 * 8, vc);
    __mind_store_i64(v + 2 * 8, vb);
    __mind_store_i64(v + 1 * 8, va);
    __mind_store_i64(v + 0 * 8, nb_mask32(t1 + t2));
    0
}

// Pack one big-endian message word W[wi] from 4 stride-1 bytes at block_addr.
pub fn nb_sha256_w0(block_addr: i64, w_addr: i64, wi: i64) -> i64 {
    let base: i64 = wi * 4;
    let b0: i64 = __mind_load_i8(block_addr + base + 0);
    let b1: i64 = __mind_load_i8(block_addr + base + 1);
    let b2: i64 = __mind_load_i8(block_addr + base + 2);
    let b3: i64 = __mind_load_i8(block_addr + base + 3);
    let word: i64 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
    nb_w_set(w_addr, wi, word)
}

// ---- recursion-form loops (the nfn mic@3 emitter has NO `while` arm; main.mind
// is written recursion-only, so each sha256 "loop" is a tail-recursive helper). ----

// W[0..15]: big-endian pack, indices wi..15.
pub fn nb_sha256_w0_loop(block_addr: i64, w_addr: i64, wi: i64) -> i64 {
    if wi >= 16 {
        return 0;
    }
    let _s: i64 = nb_sha256_w0(block_addr, w_addr, wi);
    nb_sha256_w0_loop(block_addr, w_addr, wi + 1)
}
// W[16..63]: schedule extension, indices wj..63.
pub fn nb_sha256_wsched_loop(w_addr: i64, wj: i64) -> i64 {
    if wj >= 64 {
        return 0;
    }
    let s0: i64 = nb_ssig0(nb_w_get(w_addr, wj - 15));
    let s1: i64 = nb_ssig1(nb_w_get(w_addr, wj - 2));
    let val: i64 = nb_mask32(nb_w_get(w_addr, wj - 16) + s0 + nb_w_get(w_addr, wj - 7) + s1);
    let _s2: i64 = nb_w_set(w_addr, wj, val);
    nb_sha256_wsched_loop(w_addr, wj + 1)
}
// Copy 8 H words into the working-var scratch `v`, indices vi..7.
pub fn nb_sha256_vinit_loop(v: i64, h_addr: i64, vi: i64) -> i64 {
    if vi >= 8 {
        return 0;
    }
    __mind_store_i64(v + vi * 8, __mind_load_i64(h_addr + vi * 8));
    nb_sha256_vinit_loop(v, h_addr, vi + 1)
}
// 64 rounds, indices rnd..63 (state is memory-backed so this carries only rnd).
pub fn nb_sha256_round_loop(v: i64, w_addr: i64, rnd: i64) -> i64 {
    if rnd >= 64 {
        return 0;
    }
    let _r: i64 = nb_sha256_round(v, w_addr, rnd);
    nb_sha256_round_loop(v, w_addr, rnd + 1)
}
// Fold the working vars back into H, indices fi..7.
pub fn nb_sha256_fold_loop(h_addr: i64, v: i64, fi: i64) -> i64 {
    if fi >= 8 {
        return 0;
    }
    __mind_store_i64(h_addr + fi * 8, nb_mask32(__mind_load_i64(h_addr + fi * 8) + __mind_load_i64(v + fi * 8)));
    nb_sha256_fold_loop(h_addr, v, fi + 1)
}

pub fn nb_sha256_compress(block_addr: i64, h_addr: i64) -> i64 {
    let w_addr: i64 = __mind_alloc(512);
    let _w0: i64 = nb_sha256_w0_loop(block_addr, w_addr, 0);
    let _ws: i64 = nb_sha256_wsched_loop(w_addr, 16);
    // Working vars a..h in a stride-8 scratch (memory-backed, single-carry round).
    let v: i64 = __mind_alloc(64);
    let _vi: i64 = nb_sha256_vinit_loop(v, h_addr, 0);
    let _rl: i64 = nb_sha256_round_loop(v, w_addr, 0);
    nb_sha256_fold_loop(h_addr, v, 0)
}

// Copy in_len input bytes into the pad buffer, indices ci..in_len-1.
pub fn nb_sha256_copyin_loop(buf: i64, in_addr: i64, in_len: i64, ci: i64) -> i64 {
    if ci >= in_len {
        return 0;
    }
    __mind_store_i8(buf + ci, __mind_load_i8(in_addr + ci));
    nb_sha256_copyin_loop(buf, in_addr, in_len, ci + 1)
}
// Zero-fill the padding region [zi, end).
pub fn nb_sha256_zero_loop(buf: i64, zi: i64, end: i64) -> i64 {
    if zi >= end {
        return 0;
    }
    __mind_store_i8(buf + zi, 0);
    nb_sha256_zero_loop(buf, zi + 1, end)
}
// Init the 8 H words from nb_h_init, indices hi..7.
pub fn nb_sha256_hinit_loop(h_addr: i64, hi: i64) -> i64 {
    if hi >= 8 {
        return 0;
    }
    __mind_store_i64(h_addr + hi * 8, nb_h_init(hi));
    nb_sha256_hinit_loop(h_addr, hi + 1)
}
// Process each 64-byte block, indices blk..num_blocks-1.
pub fn nb_sha256_blocks_loop(buf: i64, h_addr: i64, blk: i64, num_blocks: i64) -> i64 {
    if blk >= num_blocks {
        return 0;
    }
    let _c: i64 = nb_sha256_compress(buf + blk * 64, h_addr);
    nb_sha256_blocks_loop(buf, h_addr, blk + 1, num_blocks)
}
// Serialise the 8-word digest big-endian, indices di..7.
pub fn nb_sha256_out_loop(h_addr: i64, out_addr: i64, di: i64) -> i64 {
    if di >= 8 {
        return 0;
    }
    let word: i64 = __mind_load_i64(h_addr + di * 8);
    __mind_store_i8(out_addr + di * 4 + 0, (word >> 24) & 255);
    __mind_store_i8(out_addr + di * 4 + 1, (word >> 16) & 255);
    __mind_store_i8(out_addr + di * 4 + 2, (word >> 8) & 255);
    __mind_store_i8(out_addr + di * 4 + 3, word & 255);
    nb_sha256_out_loop(h_addr, out_addr, di + 1)
}

// nb_sha256 — FIPS 180-4 SHA-256 over `in_len` stride-1 bytes at `in_addr`,
// writing the 32-byte big-endian digest to `out_addr` (stride-1, H0 high byte
// first). Mirrors `mini_sha256` / std/sha256.mind's `sha256` byte-for-byte.
pub fn nb_sha256(in_addr: i64, in_len: i64, out_addr: i64) -> i64 {
    // Padding length (FIPS §5.1.1): 0x80, zeros to ≡56 (mod 64), 8-byte BE bitlen.
    // `in_len % 64` == `in_len & 63` for in_len >= 0 (mind_sha256/std.sha256 use
    // `% 64`; the nfn mic@3 emitter has no `%` arm, and the bitmask is the exact
    // same value for a non-negative length — and stays self-flip-clean i64-only).
    let tail: i64 = in_len & 63;
    let pad_zeros: i64 = if tail < 56 {
        55 - tail
    } else {
        119 - tail
    };
    let padded_len: i64 = in_len + 1 + pad_zeros + 8;
    let buf: i64 = __mind_alloc(padded_len);
    let _ci: i64 = nb_sha256_copyin_loop(buf, in_addr, in_len, 0);
    __mind_store_i8(buf + in_len, 128);
    let _zi: i64 = nb_sha256_zero_loop(buf, in_len + 1, in_len + 1 + pad_zeros);
    // 64-bit big-endian bit-length.
    let bit_len: i64 = in_len * 8;
    let len_off: i64 = padded_len - 8;
    let blen_hi: i64 = (bit_len >> 32) & 4294967295;
    let blen_lo: i64 = bit_len & 4294967295;
    __mind_store_i8(buf + len_off + 0, (blen_hi >> 24) & 255);
    __mind_store_i8(buf + len_off + 1, (blen_hi >> 16) & 255);
    __mind_store_i8(buf + len_off + 2, (blen_hi >> 8) & 255);
    __mind_store_i8(buf + len_off + 3, blen_hi & 255);
    __mind_store_i8(buf + len_off + 4, (blen_lo >> 24) & 255);
    __mind_store_i8(buf + len_off + 5, (blen_lo >> 16) & 255);
    __mind_store_i8(buf + len_off + 6, (blen_lo >> 8) & 255);
    __mind_store_i8(buf + len_off + 7, blen_lo & 255);
    // H state, stride-8.
    let h_addr: i64 = __mind_alloc(64);
    let _hi: i64 = nb_sha256_hinit_loop(h_addr, 0);
    // Process each 64-byte block, then serialise the digest big-endian.
    let num_blocks: i64 = padded_len / 64;
    let _bl: i64 = nb_sha256_blocks_loop(buf, h_addr, 0, num_blocks);
    nb_sha256_out_loop(h_addr, out_addr, 0)
}

// nb_sha256_note(mic3_addr, mic3_len) — sha256 the pure-MIND mic@3 EmitState.buf
// bytes (stride-1 String storage == the stride-1 byte view nb_sha256 reads) into
// a fresh 32-byte out buffer; returns its address, or 0 on a degenerate empty
// input so the caller FAILS CLOSED (refuses to emit a wrong note) rather than
// hashing nothing. The mic@3 bytes for the SEEDED+PRUNED combined IR are the one
// open port-feasibility item; see nb_trace_hash + the deferred marker below.
pub fn nb_sha256_note(mic3_addr: i64, mic3_len: i64) -> i64 {
    if mic3_len <= 0 {
        return 0;
    }
    let out32: i64 = __mind_alloc(32);
    let _r: i64 = nb_sha256(mic3_addr, mic3_len, out32);
    out32
}

// Verification export: nb_sha256(in_addr, in_len) -> 32-byte digest buffer addr.
// Lets the smoke prove the pure-MIND SHA-256 is byte-identical to the Rust
// mini_sha256 by hashing the SAME oracle mic@3 bytes and comparing the digest
// against the oracle ELF note's 32 bytes (the load-bearing sha256 round-trip).
pub fn selftest_sha256(in_addr: i64, in_len: i64) -> i64 {
    nb_sha256_note(in_addr, in_len)
}

// build_note: n_namesz=5 ; n_descsz=32 ; n_type=1 ; "MIND\0\0\0\0" ; <32-byte hash>.
// The Rust note uses ir_trace_hash(ir). For the scalar fixture the hash is a pure
// function of the IR; we read the 32 bytes from the hash buffer `hash_addr`.
pub fn nb_build_note(note0: String, hash_addr: i64) -> String {
    let a1: String = nb_u32(note0, 5);
    let a2: String = nb_u32(a1, 32);
    let a3: String = nb_u32(a2, 1);
    // "MIND\0\0\0\0"
    let a4: String = nb_push(a3, 77);
    let a5: String = nb_push(a4, 73);
    let a6: String = nb_push(a5, 78);
    let a7: String = nb_push(a6, 68);
    let a8: String = nb_push(a7, 0);
    let a9: String = nb_push(a8, 0);
    let a10: String = nb_push(a9, 0);
    let a11: String = nb_push(a10, 0);
    nb_note_hash_bytes(a11, hash_addr, 0)
}
pub fn nb_note_hash_bytes(note: String, hash_addr: i64, i: i64) -> String {
    if i >= 32 {
        return note;
    }
    let b: i64 = __mind_load_i8(hash_addr + i);
    let n1: String = nb_push(note, b);
    nb_note_hash_bytes(n1, hash_addr, i + 1)
}

// ---- write_elf: ehdr + 4 phdrs + code + note (mirror src/native write_elf) ----
pub fn nb_write_elf(code: String, entry_off: i64, note: String) -> String {
    let code_len: i64 = string_len(code);
    let note_len: i64 = string_len(note);
    let load_addr: i64 = nb_load_addr();
    let hdrs: i64 = nb_hdrs();
    let entry: i64 = load_addr + hdrs + entry_off;
    let load_sz: i64 = hdrs + code_len;
    let note_off: i64 = hdrs + code_len;

    // --- Elf64_Ehdr ---
    let e0: String = string_new();
    // e_ident: 7F 'E' 'L' 'F' 2 1 1 0 then 8 zero bytes
    let e1: String = nb_push(e0, 127);
    let e2: String = nb_push(e1, 69);
    let e3: String = nb_push(e2, 76);
    let e4: String = nb_push(e3, 70);
    let e5: String = nb_push(e4, 2);
    let e6: String = nb_push(e5, 1);
    let e7: String = nb_push(e6, 1);
    let e8: String = nb_push(e7, 0);
    let e9: String = nb_zeros(e8, 8);
    let e10: String = nb_u16(e9, 2);
    // ET_EXEC
    let e11: String = nb_u16(e10, 62);
    // EM_X86_64
    let e12: String = nb_u32(e11, 1);
    // e_version
    let e13: String = nb_i64le(e12, entry);
    // e_entry
    let e14: String = nb_i64le(e13, 64);
    // e_phoff
    let e15: String = nb_i64le(e14, 0);
    // e_shoff
    let e16: String = nb_u32(e15, 0);
    // e_flags
    let e17: String = nb_u16(e16, 64);
    // e_ehsize
    let e18: String = nb_u16(e17, 56);
    // e_phentsize
    let e19: String = nb_u16(e18, 4);
    // e_phnum = 4
    let e20: String = nb_u16(e19, 0);
    // e_shentsize
    let e21: String = nb_u16(e20, 0);
    // e_shnum
    let e22: String = nb_u16(e21, 0);
    // e_shstrndx

    // --- phdr 1: PT_LOAD (R+X) over headers + code ---
    let f1: String = nb_u32(e22, 1);
    // PT_LOAD
    let f2: String = nb_u32(f1, 5);
    // R+X
    let f3: String = nb_i64le(f2, 0);
    // p_offset
    let f4: String = nb_i64le(f3, load_addr);
    // p_vaddr
    let f5: String = nb_i64le(f4, load_addr);
    // p_paddr
    let f6: String = nb_i64le(f5, load_sz);
    // p_filesz
    let f7: String = nb_i64le(f6, load_sz);
    // p_memsz
    let f8: String = nb_i64le(f7, 4096);
    // p_align

    // --- phdr 2: PT_NOTE (trace-hash provenance) ---
    let g1: String = nb_u32(f8, 4);
    // PT_NOTE
    let g2: String = nb_u32(g1, 4);
    // R
    let g3: String = nb_i64le(g2, note_off);
    // p_offset
    let g4: String = nb_i64le(g3, load_addr + note_off);
    // p_vaddr
    let g5: String = nb_i64le(g4, load_addr + note_off);
    // p_paddr
    let g6: String = nb_i64le(g5, note_len);
    // p_filesz
    let g7: String = nb_i64le(g6, note_len);
    // p_memsz
    let g8: String = nb_i64le(g7, 4);
    // p_align

    // --- phdr 3: PT_LOAD (RW) — BSS bump-allocator arena ---
    let h1: String = nb_u32(g8, 1);
    // PT_LOAD
    let h2: String = nb_u32(h1, 6);
    // RW
    let h3: String = nb_i64le(h2, 0);
    // p_offset
    let h4: String = nb_i64le(h3, nb_arena_addr());
    // p_vaddr
    let h5: String = nb_i64le(h4, nb_arena_addr());
    // p_paddr
    let h6: String = nb_i64le(h5, 0);
    // p_filesz = 0 (BSS)
    let h7: String = nb_i64le(h6, nb_arena_bytes());
    // p_memsz
    let h8: String = nb_i64le(h7, 4096);
    // p_align

    // --- phdr 4: PT_LOAD (RW) — dedicated call-stack region (BSS) ---
    let i1: String = nb_u32(h8, 1);
    // PT_LOAD
    let i2: String = nb_u32(i1, 6);
    // RW
    let i3: String = nb_i64le(i2, 0);
    // p_offset
    let i4: String = nb_i64le(i3, nb_stack_addr());
    // p_vaddr
    let i5: String = nb_i64le(i4, nb_stack_addr());
    // p_paddr
    let i6: String = nb_i64le(i5, 0);
    // p_filesz = 0 (BSS)
    let i7: String = nb_i64le(i6, nb_stack_bytes());
    // p_memsz
    let i8: String = nb_i64le(i7, 4096);
    // p_align

    // --- code, then the (unmapped) note ---
    let j1: String = string_push_str(i8, code);
    string_push_str(j1, note)
}

// Append `n` zero bytes.
pub fn nb_zeros(code: String, n: i64) -> String {
    if n <= 0 {
        return code;
    }
    let c1: String = string_push_byte(code, 0);
    nb_zeros(c1, n - 1)
}

// ---- stdlib-bundling reachability prune (mirrors bin/mind-native.rs) ----
//
// The Rust mind-native driver PREPENDS all ~21 bundled std/*.mind modules ahead
// of the user file, lowers the union, then dead-code-prunes to the user file's
// call graph (prune_unreachable_fns) and finally keeps only the LAST FnDef per
// name (compile_to_elf's last-write-wins dedup). To stay byte-identical the pure
// front-end does the same over `fns` (collected in combined source order):
//
//   * roots  = every fn whose NAME starts at/after `user_lo` (the offset where
//              the user file begins in the combined buffer). With user_lo==0 all
//              fns are roots, so a single-file fixture prunes to a no-op — the
//              5-fixture native ladder stays byte-identical.
//   * BFS    = mark every fn transitively reachable from a root via call edges
//              (callee name -> LAST defining fn index, the last-write-wins ABI).
//   * dedup  = keep fn k only if it is the LAST def of its own name (drops the
//              shadowed bundled brick when the user redefines a std name).
//
// All of this is a pure function of the parsed AST (name-set reachability), so
// byte-identity holds. Reachability is computed over the `fns` array of fn_def
// nodes; `reach[k]` is a 1/0 byte-per-i64 marker array parallel to `fns`.

// Return the LAST index in fns[0..n_fns) whose fn-name span equals buf[lo..hi),
// or -1. `best` threads the best-so-far so the final (largest) match wins —
// matching compile_to_elf's "keep the LAST FnDef per name" contract.
pub fn nb_last_def_idx(buf: i64, fns: i64, n_fns: i64, lo: i64, hi: i64, k: i64, best: i64) -> i64 {
    if k >= n_fns {
        return best;
    }
    let node: i64 = __mind_load_i64(fns + k * 8);
    let name_node: i64 = ast_child0(node);
    let best2: i64 = if span_bytes_equal(buf, lo, hi, ast_span_lo(name_node), ast_span_hi(name_node)) == 1 {
        k
    } else {
        best
    };
    nb_last_def_idx(buf, fns, n_fns, lo, hi, k + 1, best2)
}

// Seed reach[k]=1 for every fn whose NAME begins at/after `user_lo` (the user
// roots). user_lo==0 makes every fn a root (single-file no-op prune).
pub fn nb_mark_roots(buf: i64, fns: i64, n_fns: i64, user_lo: i64, reach: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    let node: i64 = __mind_load_i64(fns + k * 8);
    let name_node: i64 = ast_child0(node);
    let r: i64 = if ast_span_lo(name_node) >= user_lo {
        1
    } else {
        0
    };
    __mind_store_i64(reach + k * 8, r);
    nb_mark_roots(buf, fns, n_fns, user_lo, reach, k + 1)
}

// Mark the callee of one call node reachable (resolve its name to the LAST
// defining fn index). `changed` is bumped if a previously-unreached fn flips on.
pub fn nb_reach_callee(buf: i64, fns: i64, n_fns: i64, reach: i64, callee: i64, changed: i64) -> i64 {
    let idx: i64 = nb_last_def_idx(buf, fns, n_fns, ast_span_lo(callee), ast_span_hi(callee), 0, 0 - 1);
    if idx < 0 {
        return 0;
    }
    if __mind_load_i64(reach + idx * 8) == 1 {
        return 0;
    }
    __mind_store_i64(reach + idx * 8, 1);
    __mind_store_i64(changed, __mind_load_i64(changed) + 1);
    0
}

// Walk one expression marking every call's callee reachable.
pub fn nb_reach_expr(buf: i64, fns: i64, n_fns: i64, reach: i64, node: i64, changed: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return 0;
    }
    // A float literal is a call-free LEAF (like an int literal) — it references no fn.
    // Pre-fix nb_reach_expr had no float-lit arm, so a float literal (e.g. under a
    // `-1.0` unary-minus) fell to the binop tail and recursed into the leaf's absent
    // children -> null-deref SIGSEGV in the whole-module reachability pass (the fp-call
    // selftest does not run reachability, which is why only the whole-module native path
    // faulted). main.mind is float-free, so this arm never fires during self-compile.
    if k == ast_float_lit() {
        return 0;
    }
    if k == ast_ident() {
        return 0;
    }
    if k == ast_paren() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    if k == ast_struct_lit() {
        let fields_addr: i64 = ast_child1(node);
        let nfields: i64 = ast_aux(node);
        return nb_reach_struct_fields(buf, fns, n_fns, reach, fields_addr, nfields, 0, changed);
    }
    if k == ast_field() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let _a: i64 = nb_reach_args(buf, fns, n_fns, reach, args_addr, args_len, 0, changed);
        let _c: i64 = nb_reach_callee(buf, fns, n_fns, reach, callee, changed);
        return 0;
    }
    // FIX #170/#171: unary minus and expression-position value-if — walk the operand /
    // the cond+both branches to mark callees, mirroring nb_reach_stmt's ast_if. Pre-fix
    // these fell to the binop tail and null-deref'd on absent children when the call-graph
    // reachability pass walked a `-EXPR` or a nested value-if. Inert for main.mind's
    // float-free source (no such nodes reach here during self-compile).
    if k == ast_neg() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    // FIX #172: `!x` — walk the operand to mark reachable callees. Pre-fix this fell to the
    // binop tail and null-deref'd on ast_child1 == 0 when the call-graph reachability pass
    // walked a `!EXPR`. Inert for main.mind's `!`-free natively-emitted source.
    if k == ast_not() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    if k == ast_if() {
        let rc_cond: i64 = ast_child0(node);
        let _rc: i64 = nb_reach_expr(buf, fns, n_fns, reach, rc_cond, changed);
        let rt_blk: i64 = ast_child1(node);
        let _rt: i64 = nb_reach_stmts(buf, fns, n_fns, reach, ast_child0(rt_blk), ast_aux(rt_blk), 0, changed);
        let re_blk: i64 = ast_child2(node);
        let re_sa: i64 = if re_blk == 0 {
            0
        } else {
            ast_child0(re_blk)
        };
        let re_sl: i64 = if re_blk == 0 {
            0
        } else {
            ast_aux(re_blk)
        };
        return nb_reach_stmts(buf, fns, n_fns, reach, re_sa, re_sl, 0, changed);
    }
    // NARROWING cast `EXPR as iN` — walk the operand only (child1 == 0) to mark reachable
    // callees. Pre-arm this fell to the binop tail and null-deref'd on ast_child1 == 0
    // when the call-graph reachability pass walked a cast node. Never fires during
    // self-compile (main.mind produces no cast node).
    if k == ast_cast() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    let _l: i64 = nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    nb_reach_expr(buf, fns, n_fns, reach, ast_child1(node), changed)
}
pub fn nb_reach_struct_fields(buf: i64, fns: i64, n_fns: i64, reach: i64, fields_addr: i64, nfields: i64, i: i64, changed: i64) -> i64 {
    if i >= nfields {
        return 0;
    }
    let value_node: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    let _v: i64 = nb_reach_expr(buf, fns, n_fns, reach, value_node, changed);
    nb_reach_struct_fields(buf, fns, n_fns, reach, fields_addr, nfields, i + 1, changed)
}
pub fn nb_reach_args(buf: i64, fns: i64, n_fns: i64, reach: i64, args_addr: i64, args_len: i64, i: i64, changed: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let _a: i64 = nb_reach_expr(buf, fns, n_fns, reach, arg_node, changed);
    nb_reach_args(buf, fns, n_fns, reach, args_addr, args_len, i + 1, changed)
}
pub fn nb_reach_stmt(buf: i64, fns: i64, n_fns: i64, reach: i64, node: i64, changed: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_return() {
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child0(node), changed);
    }
    if k == ast_let() {
        return nb_reach_stmt(buf, fns, n_fns, reach, ast_child2(node), changed);
    }
    if k == ast_if() {
        let cond: i64 = ast_child0(node);
        let _c: i64 = nb_reach_expr(buf, fns, n_fns, reach, cond, changed);
        let then_blk: i64 = ast_child1(node);
        let _t: i64 = nb_reach_stmts(buf, fns, n_fns, reach, ast_child0(then_blk), ast_aux(then_blk), 0, changed);
        let else_blk: i64 = ast_child2(node);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        return nb_reach_stmts(buf, fns, n_fns, reach, else_sa, else_sl, 0, changed);
    }
    if k == ast_while() {
        // `while COND { BODY }`: mark callees in cond + body.
        let cond: i64 = ast_child0(node);
        let _c: i64 = nb_reach_expr(buf, fns, n_fns, reach, cond, changed);
        let body_blk: i64 = ast_child1(node);
        return nb_reach_stmts(buf, fns, n_fns, reach, ast_child0(body_blk), ast_aux(body_blk), 0, changed);
    }
    if k == ast_assign() {
        // `NAME = VALUE`: mark callees in the value expr (child2).
        return nb_reach_expr(buf, fns, n_fns, reach, ast_child2(node), changed);
    }
    if k == ast_break() {
        return 0;
    }
    if k == ast_continue() {
        return 0;
    }
    nb_reach_expr(buf, fns, n_fns, reach, node, changed)
}
pub fn nb_reach_stmts(buf: i64, fns: i64, n_fns: i64, reach: i64, stmts_addr: i64, stmts_len: i64, i: i64, changed: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let _s: i64 = nb_reach_stmt(buf, fns, n_fns, reach, stmt_node, changed);
    nb_reach_stmts(buf, fns, n_fns, reach, stmts_addr, stmts_len, i + 1, changed)
}
// Expand the call edges of EVERY currently-reachable fn once; bumps `changed`
// for each newly-marked fn so the caller can iterate to a fixpoint.
pub fn nb_reach_pass(buf: i64, fns: i64, n_fns: i64, reach: i64, k: i64, changed: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    let do_it: i64 = if __mind_load_i64(reach + k * 8) == 1 {
        let node: i64 = __mind_load_i64(fns + k * 8);
        let body: i64 = ast_child2(node);
        let stmts_addr: i64 = ast_child0(body);
        let stmts_len: i64 = ast_aux(body);
        nb_reach_stmts(buf, fns, n_fns, reach, stmts_addr, stmts_len, 0, changed)
    } else {
        0
    };
    nb_reach_pass(buf, fns, n_fns, reach, k + 1, changed)
}
// Iterate nb_reach_pass to a fixpoint (no new fn marked). Bounded by n_fns
// rounds (each round marks >=1 new fn or terminates), so it always converges.
pub fn nb_reach_fixpoint(buf: i64, fns: i64, n_fns: i64, reach: i64, rounds: i64) -> i64 {
    if rounds <= 0 {
        return 0;
    }
    let changed: i64 = __mind_alloc(8);
    __mind_store_i64(changed, 0);
    let _p: i64 = nb_reach_pass(buf, fns, n_fns, reach, 0, changed);
    if __mind_load_i64(changed) == 0 {
        return 0;
    }
    nb_reach_fixpoint(buf, fns, n_fns, reach, rounds - 1)
}
// Build kept[] = the fn nodes to emit: reachable AND the LAST def of their name
// (last-write-wins dedup). Returns the kept count.
pub fn nb_build_kept(buf: i64, fns: i64, n_fns: i64, reach: i64, kept: i64, k: i64, m: i64) -> i64 {
    if k >= n_fns {
        return m;
    }
    let node: i64 = __mind_load_i64(fns + k * 8);
    let name_node: i64 = ast_child0(node);
    let last_idx: i64 = nb_last_def_idx(buf, fns, n_fns, ast_span_lo(name_node), ast_span_hi(name_node), 0, 0 - 1);
    let keep: i64 = if __mind_load_i64(reach + k * 8) == 1 {
        if last_idx == k {
            1
        } else {
            0
        }
    } else {
        0
    };
    let m2: i64 = if keep == 1 {
        __mind_store_i64(kept + m * 8, node);
        m + 1
    } else {
        m
    };
    nb_build_kept(buf, fns, n_fns, reach, kept, k + 1, m2)
}

// Build kept[] with RETAIN-ALL-REACHABLE-NAME semantics (mirror the Rust emit_mic3
// prune, bin/mind-native.rs prune_unreachable_fns: `retain(FnDef{name} =>
// reachable.contains(name))`). Unlike nb_build_kept (last-write-wins, correct for the
// NATIVE backend which shadows a duplicate name), emit_mic3 keeps EVERY FnDef whose
// NAME is reachable — including earlier duplicate-named defs (e.g. std/toml.mind's
// bytes_eq alongside main.mind's bytes_eq). Reachability marks only a name's LAST-def
// index (nb_reach_callee), so a fn is name-reachable iff reach[last_def_idx]==1. Used
// by the mic@3 trace-hash path (nb_build_mic3); the native ELF path keeps nb_build_kept.
pub fn nb_build_kept_all(buf: i64, fns: i64, n_fns: i64, reach: i64, kept: i64, k: i64, m: i64) -> i64 {
    if k >= n_fns {
        return m;
    }
    let node: i64 = __mind_load_i64(fns + k * 8);
    let name_node: i64 = ast_child0(node);
    let last_idx: i64 = nb_last_def_idx(buf, fns, n_fns, ast_span_lo(name_node), ast_span_hi(name_node), 0, 0 - 1);
    let keep: i64 = if last_idx >= 0 {
        __mind_load_i64(reach + last_idx * 8)
    } else {
        0
    };
    let m2: i64 = if keep == 1 {
        __mind_store_i64(kept + m * 8, node);
        m + 1
    } else {
        m
    };
    nb_build_kept_all(buf, fns, n_fns, reach, kept, k + 1, m2)
}

// ---- linker: patch each call's rel32 into the assembled code buffer ----
// `funcs` describes the laid-out functions: starts[k] = function k's code start
// in the combined image, and (lo,hi) name spans to resolve callees. Each call
// record (in `calls`) is (rel_off_within_fn, callee_lo, callee_hi) — but rel_off
// is relative to its OWN function start. We track which function each call
// belongs to via the function-boundary offsets. To keep it simple for the scalar
// slice, nb_lower_fn records rel32 offsets RELATIVE TO THE FN; we convert to
// absolute by adding the fn's start when patching.

// Resolve a callee name span to its function index (by matching the fn-name span
// stored in fn_names: fn_names[k] = (name_lo, name_hi)). Returns -1 if undefined.
pub fn nb_resolve_callee(buf: i64, fn_names: i64, n_fns: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(fn_names + (k * 2 + 0) * 8);
    let nhi: i64 = __mind_load_i64(fn_names + (k * 2 + 1) * 8);
    if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        return k;
    }
    nb_resolve_callee(buf, fn_names, n_fns, lo, hi, k + 1)
}

// Patch a single rel32 at absolute code offset `abs_off` to value `rel`.
// Writes 4 little-endian bytes (two's-complement) directly into the code buffer.
pub fn nb_patch_rel32(code_addr: i64, abs_off: i64, rel: i64) -> i64 {
    let u: i64 = if rel < 0 {
        rel + 4294967296
    } else {
        rel
    };
    __mind_store_i8(code_addr + abs_off + 0, u & 255);
    __mind_store_i8(code_addr + abs_off + 1, (u / 256) & 255);
    __mind_store_i8(code_addr + abs_off + 2, (u / 65536) & 255);
    __mind_store_i8(code_addr + abs_off + 3, (u / 16777216) & 255);
    0
}

// ---- selftest export: full IR -> x86-64 -> ELF for the scalar slice ----
//
// Returns the i64 heap-record address of an EmitState whose .buf is the ELF
// bytes (so the Python gate reads it via the same ctypes handle path as
// selftest_emit_mlir). The EmitState's next_id/last_id are unused (0).
//
// Strategy (mirrors compile_to_elf):
//   1. Walk program items; collect fn_defs, entry (`main`) FIRST, rest after.
//   2. Lower each fn to its code String + call records (rel32 offsets recorded
//      relative to each fn).
//   3. Concatenate the per-fn code into one image, tracking each fn's start.
//   4. Patch each call's rel32 = callee_start - (caller_start + rel_off + 4).
//   5. build_note(trace_hash) ; write_elf(code, entry_off=0, note).
//
// The trace hash is `ir_trace_hash(ir) = mini_sha256(emit_mic3(ir))` over the
// SEEDED+PRUNED combined IR (src/ir/evidence.rs:72). The SHA-256 leg is now ported
// in pure MIND (nb_sha256 above, proven byte-identical to the oracle on the real
// mic@3 bytes). The remaining leg is reproducing emit_mic3(pruned-combined IR) in
// pure MIND (nb_trace_hash below) — the one open port-feasibility item:
//   deferred: nb_trace_hash's pruned-combined mic@3 emitter is not yet byte-exact,
//   so it fails closed (returns 0) and the _h/_hb shims still take the oracle's
//   32-byte hash via hash_addr to keep the ladder byte-identical. The sha256 half
//   is DONE (nb_sha256_note). upgrade path: drive emit_mic3_header/strtab/items-
//   loop over the pruned kept item set with the combined-lowering numbering, hand
//   its .buf addr/len to nb_sha256_note, then reimplement these _h/_hb shims to
//   call the no-hash selftest_native_elf(_u) and drop the hash_addr arg.
// 3-arg entry: single-file form (no bundled stdlib). user_lo=0 -> every fn is a
// reachability root, so the prune is a no-op and the native ladder fixtures stay
// byte-identical. The stdlib-bundling path uses the 4-arg variant below.
pub fn selftest_native_elf_h(src_addr: i64, src_len: i64, hash_addr: i64) -> EmitState {
    selftest_native_elf_hb(src_addr, src_len, hash_addr, 0)
}

// ---- SELF-COMPUTED trace hash (no oracle feed) ----
//
// nb_trace_hash builds the pruned-combined mic@3 bytes in pure MIND and runs
// nb_sha256 over them, returning the 32-byte digest buffer address — or 0 (FAIL
// CLOSED) so the caller refuses rather than emit a wrong note. The mic@3 emit over
// the seeded+pruned combined IR is the open port item; until it is byte-exact this
// returns 0 (never a fake hash). The sha256 leg it depends on is proven correct.
// deferred: emit_mic3 over the seeded+pruned combined IR is not yet reproduced in
//   pure MIND — lower_to_ir's whole-module top-level instr stream (~1305 instrs for
//   the `add` fixture, ~4358 for main.mind: every std OP_OUTPUT / OP_EXTERN_FN_DECL
//   placeholder the prune RETAINS, plus the combined next_id/strtab numbering) is
//   not yet driven by the nfn machinery (which fails closed over the full std
//   surface). Once it is, feed mic3.buf addr/len to nb_sha256_note here.
//   GATE/DECODE (2026-06-30): the authoritative target bytes are dumpable via the
//   `MIND_DUMP_MIC3=<path> mind-native <fixture> <elf>` debug hook (src/bin/mind-native.rs)
//   — sha256(that file) == the ELF PT_NOTE (verified: `add` fixture → 5447 B, sha
//   e912443707c23b57…). DECODED add target: MIC3 v2 | string_table 84 entries (extern
//   names open/close/read/write/lseek/unlink/… + type strings i64/!llvm.ptr + fn names,
//   in combined-lowering first-seen order) | next_id 618 | exports 0 | instr_count 1305
//   (~618 ConstI64+Output per-top-level-item placeholders + 67 ExternFnDecl + the 2 real
//   add/main bodies) | then struct_defs/const_array/repr_c registries. INCREMENTAL PORT
//   PLAN, gate each prefix byte-for-byte against the dump: (1) header MIC3+ver; (2) the
//   84-entry string table in combined first-seen interning order; (3) next_id+exports;
//   (4) the 1305-instr top-level stream (placeholder per non-main item + ExternFnDecl per
//   extern + kept fn bodies — mirror src/eval/lower.rs lower_to_ir top-level item lowering
//   @lower.rs:846-921); (5) struct_defs registry. The emit_instr/strtab machinery already
//   exists in the nfn path (emit_mic3_module_fndef etc.); the missing piece is driving it
//   over the COMBINED+PRUNED item set with lower_to_ir's numbering, NOT a single file.
//   MECHANISM (decoded from src/eval/lower.rs 780-925, 2026-06-30): lower_to_ir walks
//   EVERY top-level item in order; each allocates a fresh id and pushes {value-instr +
//   Output(id)}: StructDef/EnumDef → ConstI64(id,0)+Output (metadata to registries);
//   Const[array] → ConstArray+Output; FnDef → the real FnDef body+Output; extern → an
//   ExternFnDecl; Export → exports set (no instr). So next_id ≈ item-count (618) and the
//   1305-instr stream ≈ one {value,Output} pair per item. prune_unreachable_fns RETAINS
//   every placeholder + ExternFnDecl, only dropping unreachable FnDef bodies. KEY
//   STRATEGY NOTE: the string table is collected FROM the built instr stream
//   (collect_strings over module.instrs), so this port is NOT prefix-gatable — nb_trace_hash
//   must build the WHOLE pruned-combined IR (all instrs + registries) FIRST, then run the
//   existing emit_mic3 header/strtab/instr machinery over it. The nfn already lowers
//   struct/enum/const/fn top-level items (the main.mind flip proves it); the remaining gaps
//   are: extern-decl items, the seeded stdlib items, the prune, and matching next_id/order.
//   This is a build-whole-module port (multi-session), fully de-risked: target dumpable +
//   sha-confirmed, mechanism known, machinery mostly present.
pub fn nb_trace_hash(tokens: Vec, src_addr: i64, src_len: i64, user_lo: i64) -> i64 {
    // SELF-COMPUTE the note (#17 sub-milestone 3): build the SEEDED+PRUNED combined
    // mic@3 in pure MIND (nb_build_mic3 — byte-exact vs emit_mic3, gated to
    // /tmp/add_combined.mic3 at 5447 B / sha e912443707c23b57) and run the ported
    // SHA-256 over its .buf bytes. The prune/kept set is recomputed inside
    // nb_build_mic3_from_tokens from (src, user_lo), so the caller passes only the
    // ALREADY-lexed token stream (ARENA dedup — no re-lex of the full source here).
    // nb_build_mic3 fails closed (empty .buf) on any unmatched fn shape => len 0 =>
    // nb_sha256_note returns 0 => the no-hash entries refuse to emit a wrong note.
    let mic3: EmitState = nb_build_mic3_from_tokens(tokens, src_addr, src_len, user_lo);
    let bufstr: String = mic3.buf;
    let addr: i64 = string_addr(bufstr);
    let ln: i64 = string_len(bufstr);
    nb_sha256_note(addr, ln)
}

// ---- #17 sub-milestone 1: MATERIALIZE + PRUNE COUNTS (next_id + instr_count) ----
//
// Reproduce the two anchor numbers of emit_mic3(pruned-combined IR) WITHOUT yet
// building the byte stream: `next_id` and `instr_count`. Decoded from
// /tmp/add_combined.mic3 (the authoritative `add`-fixture target, 5447 B) the
// pruned-combined instr stream is EXACTLY:
//   618 ConstI64 + 618 Output + 2 FnDef + 67 ExternFnDecl = 1305 ; next_id = 618.
// Model (mirrors src/eval/lower.rs:676-925 + the extern arm @5420 + the FnDef
// module-level placeholder @ir/print + prune_unreachable_fns @bin/mind-native.rs):
//   * EVERY top-level item pushes a value-placeholder `ConstI64(id,0)` + `Output(id)`
//     and allocates ONE fresh id  =>  next_id == item-count, and 1 ConstI64 + 1
//     Output per item survive the prune (both are non-FnDef, always RETAINED).
//   * a FnDef item ADDITIONALLY pushes its real `FnDef` instr BEFORE the placeholder;
//     the prune drops that FnDef instr for every UNREACHABLE fn (the placeholder pair
//     stays) — so only the KEPT fns contribute a FnDef instr.
//   * an `extern "C" { .. }` block ADDITIONALLY pushes one `ExternFnDecl` per declared
//     fn (never pruned) BEFORE its placeholder.
// Hence:  next_id      = items_len
//         instr_count  = 2*items_len + kept_fns + total_extern_fn_decls
// The pure-MIND parser collapses each extern block to a single ast_struct_def stub,
// so the per-block fn-decl count is recovered by scanning the block's source span for
// standalone `fn` words (nb_count_fn_words). kept_fns is the reachable+last-def set
// already computed by nb_build_kept.

// 1 iff byte `b` is an identifier char (alnum or `_`) — the word-boundary test for
// isolating a standalone `fn` keyword inside an extern block's source span.
pub fn nb_is_word_byte(b: i64) -> i64 {
    if is_alnum(b) == 1 {
        return 1;
    }
    if b == 95 {
        return 1;
    }
    0
}

// Count standalone `fn` word occurrences in buf[lo..hi] — one per extern fn-decl.
// A match is bytes `f`,`n` with a non-word char (or start-of-span) before and a
// non-word char after, so identifiers that merely contain `fn` do not miscount.
pub fn nb_count_fn_words(buf: i64, lo: i64, hi: i64, span_lo: i64, acc: i64) -> i64 {
    if lo + 2 > hi {
        return acc;
    }
    let hit: i64 = if load_byte(buf, lo) == 102 {
        if load_byte(buf, lo + 1) == 110 {
            let pre_ok: i64 = if lo <= span_lo {
                1
            } else {
                if nb_is_word_byte(load_byte(buf, lo - 1)) == 1 {
                    0
                } else {
                    1
                }
            };
            let post_ok: i64 = if nb_is_word_byte(load_byte(buf, lo + 2)) == 1 {
                0
            } else {
                1
            };
            if pre_ok == 1 {
                post_ok
            } else {
                0
            }
        } else {
            0
        }
    } else {
        0
    };
    nb_count_fn_words(buf, lo + 1, hi, span_lo, acc + hit)
}

// 1 iff the item's source span begins with the `extern` keyword (an extern block
// stub — the pure-MIND parser lowers struct/enum/const/module/extern all to an
// ast_struct_def leaf, distinguished here by the first 6 span bytes).
pub fn nb_item_is_extern(buf: i64, node: i64) -> i64 {
    let lo: i64 = ast_span_lo(node);
    is_extern_kw(buf, lo, lo + 6)
}

// Sum the extern fn-decls over EVERY top-level item (0 for non-extern items).
pub fn nb_sum_extern_fns(buf: i64, items_addr: i64, items_len: i64, i: i64, acc: i64) -> i64 {
    if i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let add: i64 = if nb_item_is_extern(buf, item) == 1 {
        nb_count_fn_words(buf, ast_span_lo(item), ast_span_hi(item), ast_span_lo(item), 0)
    } else {
        0
    };
    nb_sum_extern_fns(buf, items_addr, items_len, i + 1, acc + add)
}

// Debug/count export (sub-milestone 1 verification): lex+parse the combined src,
// build the reachable+last-def kept-fn set (reusing the native-ELF prune machinery),
// then compute next_id + instr_count per the materialize+prune model above. Writes
// diagnostics to out[0..5] and returns next_id. No mic@3 bytes are built.
//   out[0] = items_len (== next_id)   out[1] = total fn_defs (pre-prune)
//   out[2] = kept fns                 out[3] = total extern fn-decls
//   out[4] = instr_count
// deferred: temporary counting harness for #17 sub-milestone 1 (materialize+prune
//   COUNT only). upgrade path: sub-milestone 2 drives emit_mic3 header/strtab/instr
//   machinery over this same materialized+pruned stream and feeds .buf to nb_sha256_note.
pub fn selftest_nb_trace_counts(src_addr: i64, src_len: i64, user_lo: i64, out: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Kept fn set (reachable from user_lo roots, last-def-per-name), reusing the
    // exact prune machinery selftest_native_elf_hb lays the fn set with.
    let all_fns: i64 = __mind_alloc((items_len + 1) * 8);
    let nb_all: i64 = nb_collect_fns(items_addr, items_len, 0, all_fns, 0);
    let reach: i64 = __mind_alloc((nb_all + 1) * 8);
    let _r0: i64 = nb_mark_roots(src_addr, all_fns, nb_all, user_lo, reach, 0);
    let _rf: i64 = nb_reach_fixpoint(src_addr, all_fns, nb_all, reach, nb_all + 1);
    let fns: i64 = __mind_alloc((nb_all + 1) * 8);
    let n_fns: i64 = nb_build_kept(src_addr, all_fns, nb_all, reach, fns, 0, 0);
    let total_externs: i64 = nb_sum_extern_fns(src_addr, items_addr, items_len, 0, 0);
    let next_id: i64 = items_len;
    let instr_count: i64 = items_len + items_len + n_fns + total_externs;
    __mind_store_i64(out + 0, items_len);
    __mind_store_i64(out + 8, nb_all);
    __mind_store_i64(out + 16, n_fns);
    __mind_store_i64(out + 24, total_externs);
    __mind_store_i64(out + 32, instr_count);
    next_id
}

// ---- #17 sub-milestone 2: STRING TABLE for the pruned-combined item stream ----
//
// Reproduce emit_mic3's string table (src/ir/compact/v3/emit.rs:717-742) for the
// pruned-combined IR, byte-exact vs /tmp/add_combined.mic3's 84 entries. The oracle
// interns strings first-seen across three passes, in this exact order:
//   1. collect_strings over the RETAINED instrs (source/item order): each retained
//      ExternFnDecl -> name, then each param type spelling, then the ret type; each
//      KEPT FnDef -> name, params, then body CALL callee names. Pruned FnDefs are
//      gone (contribute nothing); Const/Output placeholders carry no strings.
//   2. exports (sorted) — 0 for the add fixture.
//   3. struct_defs (BTreeMap-sorted by name) -> type name + field names.
// Extern param/return TYPE spellings lower to mic@3 strings via extern_type_to_mlir
// (lower.rs 7171): raw pointer / fn-ptr -> "!llvm.ptr"; f32/f64 -> "f32"/"f64";
// every integer/bool -> "i64". The pure-MIND parser collapses each extern block to a
// span-only ast_struct_def stub, so this SPAN-SCANS the block (re-lexing its source
// span) to recover per-decl names + param/return categories rather than walking a
// real ExternFnDecl AST (which does not exist here).

// Synthetic mic@3 type-string constants buffer: bytes "!llvm.ptr" [0,9) || "i64"
// [9,12) || "f32" [12,15) || "f64" [15,18). "!llvm.ptr" never appears verbatim in
// source, so type strings are interned from this buffer (dedup is by byte value, so
// an "i64" that also appears in source shares the one slot).
pub fn nb_type_consts() -> i64 {
    let b: i64 = __mind_alloc(24);
    __mind_store_i8(b + 0, 33);
    __mind_store_i8(b + 1, 108);
    __mind_store_i8(b + 2, 108);
    __mind_store_i8(b + 3, 118);
    __mind_store_i8(b + 4, 109);
    __mind_store_i8(b + 5, 46);
    __mind_store_i8(b + 6, 112);
    __mind_store_i8(b + 7, 116);
    __mind_store_i8(b + 8, 114);
    __mind_store_i8(b + 9, 105);
    __mind_store_i8(b + 10, 54);
    __mind_store_i8(b + 11, 52);
    __mind_store_i8(b + 12, 102);
    __mind_store_i8(b + 13, 51);
    __mind_store_i8(b + 14, 50);
    __mind_store_i8(b + 15, 102);
    __mind_store_i8(b + 16, 54);
    __mind_store_i8(b + 17, 52);
    b
}

// Categorize an extern param/return type from its leading token: 0="!llvm.ptr"
// (raw pointer `*..`/reference `&..`), 2="f32", 3="f64", 1="i64" (every integer/bool
// and anything else — mirrors extern_type_to_mlir's default). `subbase` is the base
// address the block's tokens are offset from; `tpos` is the token index of the type's
// first token (the one right after the `:` or `->`).
pub fn nb_type_cat(subbase: i64, toks: Vec, tpos: i64) -> i64 {
    let k: i64 = tok_kind(toks, tpos);
    if k == tk_star() {
        return 0;
    }
    if k == tk_amp() {
        return 0;
    }
    if k == tk_ident() {
        let lo: i64 = tok_lo(toks, tpos);
        let hi: i64 = tok_hi(toks, tpos);
        if hi - lo == 3 {
            if load_byte(subbase, lo) == 102 {
                let c1: i64 = load_byte(subbase, lo + 1);
                let c2: i64 = load_byte(subbase, lo + 2);
                if c1 == 51 {
                    if c2 == 50 {
                        return 2;
                    }
                }
                if c1 == 54 {
                    if c2 == 52 {
                        return 3;
                    }
                }
            }
        }
        return 1;
    }
    1
}

// Intern the mic@3 type string for category `cat` from the constants buffer.
pub fn nb_intern_tcat(strbuf: i64, offs: i64, ccell: i64, tconst: i64, cat: i64) -> i64 {
    if cat == 0 {
        return intern_span(strbuf, offs, ccell, tconst, 0, 9);
    }
    if cat == 2 {
        return intern_span(strbuf, offs, ccell, tconst, 12, 15);
    }
    if cat == 3 {
        return intern_span(strbuf, offs, ccell, tconst, 15, 18);
    }
    intern_span(strbuf, offs, ccell, tconst, 9, 12)
}

// Walk an extern block's param-list tokens from `pos`, interning one type string per
// param (at each top-level `:`) in left-to-right order. Returns the token index of the
// closing `)`. Param types have no inner `:`, so one colon == one param type.
pub fn nb_extern_params(strbuf: i64, offs: i64, ccell: i64, subbase: i64, toks: Vec, tconst: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return pos;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_rparen() {
        return pos;
    }
    if k == tk_colon() {
        let cat: i64 = nb_type_cat(subbase, toks, pos + 1);
        let _t: i64 = nb_intern_tcat(strbuf, offs, ccell, tconst, cat);
        return nb_extern_params(strbuf, offs, ccell, subbase, toks, tconst, pos + 1);
    }
    nb_extern_params(strbuf, offs, ccell, subbase, toks, tconst, pos + 1)
}

// Advance past the next `;` token; returns the index just after it (or eof position).
pub fn nb_skip_to_semi(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return pos;
    }
    if tok_kind(toks, pos) == tk_semi() {
        return pos + 1;
    }
    nb_skip_to_semi(toks, pos + 1)
}

// Scan an extern block's tokens: for each `fn NAME(params) -> ret;` decl, intern the
// name, then each param type, then the return type — mirroring collect_instr_strings'
// ExternFnDecl arm (name, param_types.., ret_type). Non-`fn` tokens (extern/"C"/{/}/
// unsafe/pub) are skipped. `subbase` is the block-span base the tokens offset from.
pub fn nb_extern_scan(strbuf: i64, offs: i64, ccell: i64, subbase: i64, toks: Vec, tconst: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0;
    }
    if tok_kind(toks, pos) == tk_kw_fn() {
        let _n: i64 = intern_span(strbuf, offs, ccell, subbase, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1));
        // params start after `NAME (` (pos+1 = name, pos+2 = `(`, pos+3 = first tok).
        let rp: i64 = nb_extern_params(strbuf, offs, ccell, subbase, toks, tconst, pos + 3);
        let nafter: i64 = if tok_kind(toks, rp + 1) == tk_arrow() {
            let cat: i64 = nb_type_cat(subbase, toks, rp + 2);
            let _r: i64 = nb_intern_tcat(strbuf, offs, ccell, tconst, cat);
            nb_skip_to_semi(toks, rp + 2)
        } else {
            nb_skip_to_semi(toks, rp + 1)
        };
        return nb_extern_scan(strbuf, offs, ccell, subbase, toks, tconst, nafter);
    }
    nb_extern_scan(strbuf, offs, ccell, subbase, toks, tconst, pos + 1)
}

// Re-lex an extern block's source span [lo,hi) and intern its decls' strings.
pub fn nb_extern_intern_block(strbuf: i64, offs: i64, ccell: i64, src: i64, tconst: i64, lo: i64, hi: i64) -> i64 {
    let toks: Vec = lex(src + lo, hi - lo);
    nb_extern_scan(strbuf, offs, ccell, src + lo, toks, tconst, 0)
}

// 1 iff `node` is in the kept-fn array kept[0..n_kept).
pub fn nb_is_kept(node: i64, kept: i64, n_kept: i64, k: i64) -> i64 {
    if k >= n_kept {
        return 0;
    }
    if __mind_load_i64(kept + k * 8) == node {
        return 1;
    }
    nb_is_kept(node, kept, n_kept, k + 1)
}

// Build the instruction-string half of the strtab in item order: extern blocks scan
// their decls; KEPT fn defs intern name+params+body-call-names via collect_fn_strings;
// pruned fns and struct/enum/const/use items contribute nothing here (struct names come
// later via the sorted registry pass).
pub fn nb_strtab_build(strbuf: i64, offs: i64, ccell: i64, src: i64, tconst: i64, items_addr: i64, items_len: i64, kept: i64, n_kept: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        if nb_is_kept(item, kept, n_kept, 0) == 1 {
            let _f: i64 = collect_fn_strings(strbuf, offs, ccell, src, item);
        }
    } else {
        if nb_item_is_extern(src, item) == 1 {
            let _e: i64 = nb_extern_intern_block(strbuf, offs, ccell, src, tconst, ast_span_lo(item), ast_span_hi(item));
        }
    }
    nb_strtab_build(strbuf, offs, ccell, src, tconst, items_addr, items_len, kept, n_kept, i + 1)
}

// Debug/verify export (sub-milestone 2): build the pruned-combined string table and
// expose it so a harness can diff every entry against the authoritative target. Writes
//   out[0] = ncount (number of interned strings)
//   out[1] = strbuf address     out[2] = offs address (ncount+1 cumulative offsets)
// and returns ncount. No mic@3 header/instr bytes are emitted.
// deferred: temporary strtab-verify harness for #17 sub-milestone 2 (string table only).
//   upgrade path: sub-milestone 3 materializes the pruned instr stream + registries and
//   drives emit_mic3_header/strtab/instr/registry over it, feeding .buf to nb_sha256_note.
pub fn selftest_nb_strtab(src_addr: i64, src_len: i64, user_lo: i64, out: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let all_fns: i64 = __mind_alloc((items_len + 1) * 8);
    let nb_all: i64 = nb_collect_fns(items_addr, items_len, 0, all_fns, 0);
    let reach: i64 = __mind_alloc((nb_all + 1) * 8);
    let _r0: i64 = nb_mark_roots(src_addr, all_fns, nb_all, user_lo, reach, 0);
    let _rf: i64 = nb_reach_fixpoint(src_addr, all_fns, nb_all, reach, nb_all + 1);
    let kept: i64 = __mind_alloc((nb_all + 1) * 8);
    let n_kept: i64 = nb_build_kept_all(src_addr, all_fns, nb_all, reach, kept, 0, 0);
    let tconst: i64 = nb_type_consts();
    let srt: i64 = srt_build(src_addr, src_len);
    let strbuf: i64 = __mind_alloc(262144);
    let offs: i64 = __mind_alloc(8192 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let _b: i64 = nb_strtab_build(strbuf, offs, ccell, src_addr, tconst, items_addr, items_len, kept, n_kept, 0);
    let _s: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    __mind_store_i64(out + 0, ncount);
    __mind_store_i64(out + 8, strbuf);
    __mind_store_i64(out + 16, offs);
    ncount
}

// ---- #17 sub-milestone 3: MATERIALIZE the pruned-combined instr stream + ----
// registries and drive the FULL mic@3 emit, byte-exact vs /tmp/add_combined.mic3.
//
// Model (decoded from /tmp/add_combined.mic3, gate-proven): each of the 618 combined
// items emits ConstI64(i,0)+Output(i) at its own fresh id i (== item index), EXCEPT a
// KEPT FnDef item PREPENDS its real FnDef body and an EXTERN block item PREPENDS one
// ExternFnDecl per declared symbol (a PRUNED FnDef item drops its FnDef instr, leaving
// only the placeholder pair). next_id == items_len; instr_count == 2*items_len +
// n_kept + total_extern_decls. Registries: struct_defs (BTreeMap-sorted, reused
// srt_emit_registry_sorted_interned), then const_array_defs (0) and repr_c_structs (0).

// Strtab index for an extern type category (parallel to nb_intern_tcat but READ-ONLY):
// 0=!llvm.ptr [0,9), 2=f32 [12,15), 3=f64 [15,18), else i64 [9,12) — indices INTO the
// already-built 84-entry strtab (intern_find over the tconst constants buffer).
pub fn nb_tcat_index(strbuf: i64, offs: i64, ncount: i64, tconst: i64, cat: i64) -> i64 {
    if cat == 0 {
        return intern_find(strbuf, offs, ncount, tconst, 0, 9, 0);
    }
    if cat == 2 {
        return intern_find(strbuf, offs, ncount, tconst, 12, 15, 0);
    }
    if cat == 3 {
        return intern_find(strbuf, offs, ncount, tconst, 15, 18, 0);
    }
    intern_find(strbuf, offs, ncount, tconst, 9, 12, 0)
}

// Collect an extern decl's param-type categories into catbuf[0..], one per top-level
// `:`; write the count to ncell and return the token index of the closing `)`. Mirrors
// nb_extern_params' walk (one colon == one param type; no inner colons).
pub fn nb_ecoll_params(subbase: i64, toks: Vec, pos: i64, catbuf: i64, ncell: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return pos;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_rparen() {
        return pos;
    }
    if k == tk_colon() {
        let cat: i64 = nb_type_cat(subbase, toks, pos + 1);
        let n: i64 = __mind_load_i64(ncell);
        __mind_store_i64(catbuf + n * 8, cat);
        __mind_store_i64(ncell, n + 1);
        return nb_ecoll_params(subbase, toks, pos + 1, catbuf, ncell);
    }
    nb_ecoll_params(subbase, toks, pos + 1, catbuf, ncell)
}

// Emit the param-type string indices for catbuf[0..ncat) as uleb strtab-idxs.
pub fn nb_emit_cat_idxs(s: EmitState, strbuf: i64, offs: i64, ncount: i64, tconst: i64, catbuf: i64, ncat: i64, i: i64) -> EmitState {
    if i >= ncat {
        return s;
    }
    let cat: i64 = __mind_load_i64(catbuf + i * 8);
    let idx: i64 = nb_tcat_index(strbuf, offs, ncount, tconst, cat);
    let s1: EmitState = emit_uleb128(s, idx);
    nb_emit_cat_idxs(s1, strbuf, offs, ncount, tconst, catbuf, ncat, i + 1)
}

// Emit OP_EXTERN_FN_DECL (0x25) for each `fn NAME(params) -> ret;` in an extern block's
// tokens, mirroring nb_extern_scan's structure but WRITING bytes: uleb(name_idx),
// uleb(nparams), each param type idx, opt ret (0 | 1+idx), varargs=0, uleb(hints=0),
// callconv=1 (SysV — resolve_callconv(C) on Linux). Threads EmitState.
pub fn nb_emit_extern_scan(s: EmitState, strbuf: i64, offs: i64, ncount: i64, subbase: i64, toks: Vec, tconst: i64, pos: i64) -> EmitState {
    if at_eof(toks, pos) == 1 {
        return s;
    }
    if tok_kind(toks, pos) == tk_kw_fn() {
        let nidx: i64 = intern_find(strbuf, offs, ncount, subbase, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1), 0);
        let s0: EmitState = es_push(s, 37);
        let s1: EmitState = emit_uleb128(s0, nidx);
        let catbuf: i64 = __mind_alloc(64 * 8);
        let ncell: i64 = __mind_alloc(8);
        __mind_store_i64(ncell, 0);
        let rp: i64 = nb_ecoll_params(subbase, toks, pos + 3, catbuf, ncell);
        let ncat: i64 = __mind_load_i64(ncell);
        let s2: EmitState = emit_uleb128(s1, ncat);
        let s3: EmitState = nb_emit_cat_idxs(s2, strbuf, offs, ncount, tconst, catbuf, ncat, 0);
        if tok_kind(toks, rp + 1) == tk_arrow() {
            let rcat: i64 = nb_type_cat(subbase, toks, rp + 2);
            let ridx: i64 = nb_tcat_index(strbuf, offs, ncount, tconst, rcat);
            let s4: EmitState = es_push(s3, 1);
            let s5: EmitState = emit_uleb128(s4, ridx);
            let s6: EmitState = es_push(s5, 0);
            let s7: EmitState = emit_uleb128(s6, 0);
            let s8: EmitState = es_push(s7, 1);
            let nafter: i64 = nb_skip_to_semi(toks, rp + 2);
            return nb_emit_extern_scan(s8, strbuf, offs, ncount, subbase, toks, tconst, nafter);
        }
        let s4b: EmitState = es_push(s3, 0);
        let s5b: EmitState = es_push(s4b, 0);
        let s6b: EmitState = emit_uleb128(s5b, 0);
        let s7b: EmitState = es_push(s6b, 1);
        let nafter2: i64 = nb_skip_to_semi(toks, rp + 1);
        return nb_emit_extern_scan(s7b, strbuf, offs, ncount, subbase, toks, tconst, nafter2);
    }
    nb_emit_extern_scan(s, strbuf, offs, ncount, subbase, toks, tconst, pos + 1)
}

// Re-lex an extern block's source span [lo,hi) and emit its ExternFnDecls.
pub fn nb_emit_extern_block(s: EmitState, strbuf: i64, offs: i64, ncount: i64, src: i64, tconst: i64, lo: i64, hi: i64) -> EmitState {
    let toks: Vec = lex(src + lo, hi - lo);
    nb_emit_extern_scan(s, strbuf, offs, ncount, src + lo, toks, tconst, 0)
}

// Emit one combined item's instrs: KEPT FnDef -> real body + placeholder pair; extern
// block -> ExternFnDecl(s) + placeholder pair; everything else (pruned fn, struct/enum/
// const/other) -> placeholder pair only. `i` is BOTH the item index and its fresh id.
pub fn nb_emit_one_item(s: EmitState, src: i64, item: i64, i: i64, strbuf: i64, offs: i64, ncount: i64, tconst: i64, kept: i64, n_kept: i64, ok_cell: i64) -> EmitState {
    if ast_kind(item) == ast_fn_def() {
        if nb_is_kept(item, kept, n_kept, 0) == 1 {
            let s1: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
            let s2: EmitState = emit_mic3_const_i64(s1, i, 0);
            return emit_mic3_output(s2, i);
        }
        let s1b: EmitState = emit_mic3_const_i64(s, i, 0);
        return emit_mic3_output(s1b, i);
    }
    if nb_item_is_extern(src, item) == 1 {
        let s1c: EmitState = nb_emit_extern_block(s, strbuf, offs, ncount, src, tconst, ast_span_lo(item), ast_span_hi(item));
        let s2c: EmitState = emit_mic3_const_i64(s1c, i, 0);
        return emit_mic3_output(s2c, i);
    }
    let s1d: EmitState = emit_mic3_const_i64(s, i, 0);
    emit_mic3_output(s1d, i)
}

// Walk items in declaration order, emitting each item's instrs; fail closed via ok_cell.
pub fn nb_emit_items(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, tconst: i64, kept: i64, n_kept: i64, ok_cell: i64, i: i64) -> EmitState {
    if i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let s1: EmitState = nb_emit_one_item(s, src, item, i, strbuf, offs, ncount, tconst, kept, n_kept, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return s1;
    }
    nb_emit_items(s1, src, items_addr, items_len, strbuf, offs, ncount, tconst, kept, n_kept, ok_cell, i + 1)
}

// FULL pruned-combined mic@3 build. Returns the EmitState whose .buf is the byte-exact
// mic@3 stream (== /tmp/add_combined.mic3 for the seeded add fixture), or es_new()
// (empty) on any unmatched fn shape (fail closed). Reuses sub-milestone 2's strtab
// machinery verbatim, then materializes the instr stream + struct registry.
pub fn nb_build_mic3(src_addr: i64, src_len: i64, user_lo: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    nb_build_mic3_from_tokens(tokens, src_addr, src_len, user_lo)
}

// ARENA (Rule-2c dedup): build the pruned-combined mic@3 from an ALREADY-lexed token
// stream, so the self-compile trace-hash path (selftest_native_elf_u -> nb_trace_hash)
// reuses the tokens it already lexed instead of re-lexing the full ~1.9 MB source TWICE
// (once here, once inside srt_build) into the fixed 1 GiB native bump arena. Each such
// full-source lex permanently occupies ~46 MB (Vec doubling, no free); on the whole-
// compiler self-compile the two redundant lexes here cost ~92 MB of arena that the
// nb_trace_hash mic@3 build (~600 MB, half the arena) did not need. Byte-identical to
// nb_build_mic3: the same (src_addr, src_len) tokens yield an identical parse/registry/
// emit, so the mic@3 bytes (and thus the SHA-256 note) are unchanged. Mirrors
// selftest_native_elf_hb_from_tokens' proven parse(tokens)+srt_build_from_tokens reuse.
pub fn nb_build_mic3_from_tokens(tokens: Vec, src_addr: i64, src_len: i64, user_lo: i64) -> EmitState {
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build_from_tokens(tokens, src_addr);
    let n_structs: i64 = srt_count(srt);
    // STRUCT-LIT preprocessing (mirror selftest_mic3_module_nfn ~L12026): desugar
    // struct-literal ctors -> __mind_alloc + ordered __mind_store_i64 + ptr-result,
    // pre-fold resolvable field reads -> __mind_load_i64, then annotate — in THIS
    // order, over the SAME combined items, BEFORE the kept-set / strtab / emit passes.
    // No-op for a fn with no struct lit: the 4 struct-less fixtures are unaffected
    // because their kept mains carry no literal and every pruned stdlib body is
    // dropped to a placeholder pair (strtab collects + emit lowers KEPT fns only).
    // The combined buffer always contains __mind_alloc/__mind_store_i64 (stdlib uses
    // both), so have_spans==1, src_use==src_addr, and the real found spans are used.
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    let alloc_found: i64 = find_alloc_name_span(src_addr, src_len, 0, slit_acell);
    let store_found: i64 = find_store_name_span(src_addr, src_len, 0, slit_scell);
    let have_spans: i64 = if alloc_found == 1 {
        store_found
    } else {
        0
    };
    let src_use: i64 = if have_spans == 1 {
        src_addr
    } else {
        build_src_intrinsics(src_addr, src_len)
    };
    let alo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 0)
    } else {
        src_len
    };
    let ahi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 8)
    } else {
        src_len + 12
    };
    let slo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 0)
    } else {
        src_len + 12
    };
    let shi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 8)
    } else {
        src_len + 28
    };
    let _sl: i64 = slit_desugar_module(src_use, src_len, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    let prefold_len: i64 = if have_spans == 1 {
        src_len
    } else {
        src_len + 43
    };
    let _pf: i64 = field_prefold_module(src_use, prefold_len, items_addr, items_len, 0, srt);
    let _an: i64 = slit_annotate_module(src_use, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    let all_fns: i64 = __mind_alloc((items_len + 1) * 8);
    let nb_all: i64 = nb_collect_fns(items_addr, items_len, 0, all_fns, 0);
    let reach: i64 = __mind_alloc((nb_all + 1) * 8);
    let _r0: i64 = nb_mark_roots(src_addr, all_fns, nb_all, user_lo, reach, 0);
    let _rf: i64 = nb_reach_fixpoint(src_addr, all_fns, nb_all, reach, nb_all + 1);
    let kept: i64 = __mind_alloc((nb_all + 1) * 8);
    let n_kept: i64 = nb_build_kept_all(src_addr, all_fns, nb_all, reach, kept, 0, 0);
    let tconst: i64 = nb_type_consts();
    // Buffers sized for FULL main.mind scale (oracle strtab = 2460 entries / 25289 B),
    // not the 84-string add fixture — a 1024-entry offs overflowed the heap at scale.
    let strbuf: i64 = __mind_alloc(262144);
    let offs: i64 = __mind_alloc(8192 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let _sb: i64 = nb_strtab_build(strbuf, offs, ccell, src_addr, tconst, items_addr, items_len, kept, n_kept, 0);
    let _si: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let total_externs: i64 = nb_sum_extern_fns(src_addr, items_addr, items_len, 0, 0);
    let s1: EmitState = emit_mic3_header(es_new());
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, ncount);
    let s3: EmitState = emit_uleb128(s2, items_len);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, items_len + items_len + n_kept + total_externs);
    let ok_cell: i64 = __mind_alloc(8);
    __mind_store_i64(ok_cell, 1);
    let s6: EmitState = nb_emit_items(s5, src_addr, items_addr, items_len, strbuf, offs, ncount, tconst, kept, n_kept, ok_cell, 0);
    if __mind_load_i64(ok_cell) == 0 {
        return es_new();
    }
    if n_structs == 0 {
        return emit_mic3_empty_registries(s6);
    }
    let s7: EmitState = emit_uleb128(s6, n_structs);
    let s8: EmitState = srt_emit_registry_sorted_interned(s7, strbuf, offs, ccell, src_addr, srt, 0);
    let s9: EmitState = emit_uleb128(s8, 0);
    emit_uleb128(s9, 0)
}

// Verify export (sub-milestone 3): build the full pruned-combined mic@3 and return its
// EmitState so a harness can diff .buf against /tmp/add_combined.mic3 (5447 B).
pub fn selftest_nb_mic3(src_addr: i64, src_len: i64, user_lo: i64) -> EmitState {
    nb_build_mic3(src_addr, src_len, user_lo)
}

// DIAGNOSTIC (#17 full-scale cutover): walk the pruned-combined item stream exactly as
// nb_emit_items does, emit each via nb_emit_one_item, and record the FIRST item whose
// emit fails closed (KEPT fn with an unsupported body shape). Writes out[0]=item index,
// out[1]=fn-name span_lo, out[2]=ast_kind; returns the item index (or -1 if none fail).
// Respects the kept set (a PRUNED fn only emits a placeholder pair, never its body).
// deferred: temporary full-scale fail locator; upgrade path: close each surfaced shape
//   gap in emit_mic3_module_fndef / nb_emit_one_item until nb_build_mic3 is byte-exact.
pub fn nb_emit_items_faildiag(src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, tconst: i64, kept: i64, n_kept: i64, i: i64, out: i64) -> i64 {
    if i >= items_len {
        return 0 - 1;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let ok: i64 = __mind_alloc(8);
    __mind_store_i64(ok, 1);
    let _s: EmitState = nb_emit_one_item(es_new(), src, item, i, strbuf, offs, ncount, tconst, kept, n_kept, ok);
    if __mind_load_i64(ok) == 0 {
        // Collect EVERY failing item's fn-name span_lo into out[40 + fails*8]; out[0]
        // holds the running fail count so a harness can list the full punch-list.
        let fails: i64 = __mind_load_i64(out + 0);
        if fails < 128 {
            let nm: i64 = ast_child0(item);
            __mind_store_i64(out + 40 + fails * 8, ast_span_lo(nm))
        }
        __mind_store_i64(out + 0, fails + 1)
    }
    nb_emit_items_faildiag(src, items_addr, items_len, strbuf, offs, ncount, tconst, kept, n_kept, i + 1, out)
}

pub fn selftest_nb_mic3_faildiag(src_addr: i64, src_len: i64, user_lo: i64, out: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build(src_addr, src_len);
    let n_structs: i64 = srt_count(srt);
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    let alloc_found: i64 = find_alloc_name_span(src_addr, src_len, 0, slit_acell);
    let store_found: i64 = find_store_name_span(src_addr, src_len, 0, slit_scell);
    let have_spans: i64 = if alloc_found == 1 {
        store_found
    } else {
        0
    };
    let src_use: i64 = if have_spans == 1 {
        src_addr
    } else {
        build_src_intrinsics(src_addr, src_len)
    };
    let alo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 0)
    } else {
        src_len
    };
    let ahi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 8)
    } else {
        src_len + 12
    };
    let slo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 0)
    } else {
        src_len + 12
    };
    let shi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 8)
    } else {
        src_len + 28
    };
    let _sl: i64 = slit_desugar_module(src_use, src_len, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    let prefold_len: i64 = if have_spans == 1 {
        src_len
    } else {
        src_len + 43
    };
    let _pf: i64 = field_prefold_module(src_use, prefold_len, items_addr, items_len, 0, srt);
    let _an: i64 = slit_annotate_module(src_use, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    let all_fns: i64 = __mind_alloc((items_len + 1) * 8);
    let nb_all: i64 = nb_collect_fns(items_addr, items_len, 0, all_fns, 0);
    let reach: i64 = __mind_alloc((nb_all + 1) * 8);
    let _r0: i64 = nb_mark_roots(src_addr, all_fns, nb_all, user_lo, reach, 0);
    let _rf: i64 = nb_reach_fixpoint(src_addr, all_fns, nb_all, reach, nb_all + 1);
    let kept: i64 = __mind_alloc((nb_all + 1) * 8);
    let n_kept: i64 = nb_build_kept_all(src_addr, all_fns, nb_all, reach, kept, 0, 0);
    let tconst: i64 = nb_type_consts();
    // Buffers sized for FULL main.mind scale (oracle strtab = 2460 entries / 25289 B),
    // not the 84-string add fixture — a 1024-entry offs overflowed the heap at scale.
    let strbuf: i64 = __mind_alloc(262144);
    let offs: i64 = __mind_alloc(8192 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let _sb: i64 = nb_strtab_build(strbuf, offs, ccell, src_addr, tconst, items_addr, items_len, kept, n_kept, 0);
    let _si: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    __mind_store_i64(out + 24, n_kept);
    __mind_store_i64(out + 32, items_len);
    nb_emit_items_faildiag(src_addr, items_addr, items_len, strbuf, offs, ncount, tconst, kept, n_kept, 0, out)
}

// No-hash native-ELF entries (Rust-independence #14, PHASE 1.3 — TRACE-HASH). These
// mirror selftest_native_elf_h / selftest_native_elf_hb EXACTLY except the note is
// SELF-COMPUTED via nb_trace_hash (no hash_addr fed). When nb_trace_hash fails
// closed (the open mic@3 port), nb_build_note copies from address 0 — which would
// be a wrong note — so the entry instead returns the empty es_new() to FAIL LOUD;
// the smoke's no-feed rung then sees a zero-length ELF and reports the gap rather
// than a fake pass. Once nb_trace_hash is byte-exact, these become the canonical
// path and the _h/_hb shims call them.
// ---- ROUND 2 arena reclaim: mic@3 scratch checkpoint/reset (byte-exact) ----
//
// Copy the 32-byte trace-hash digest src->dst so it survives an arena reclaim.
// Byte-wise (matches nb_note_hash_bytes); dst is a stable slot allocated BELOW
// the reclaim checkpoint, src is the (about-to-be-reclaimed) sha256 buffer.
pub fn nb_copy32(dst: i64, src: i64, i: i64) -> i64 {
    if i >= 32 {
        return 0;
    }
    let _s: i64 = __mind_store_i8(dst + i, __mind_load_i8(src + i));
    nb_copy32(dst, src, i + 1)
}

// Reset the native bump-arena cursor to reclaim everything allocated after the
// checkpoint (the dead mic@3 scratch that nb_trace_hash built only to SHA-256).
// `ckpt` is the pointer that `__mind_alloc(0)` returned at the checkpoint. In the
// EMITTED native ELF the bump arena is a fixed 1 GiB BSS window at ARENA_ADDR and
// __mind_alloc(n) returns ARENA_ADDR+cursor+16 while advancing the cursor by n+8
// (nb_emit_alloc/_core, NO zero-guard) — so alloc(0) returns ARENA_ADDR+C0+16 and
// leaves the cursor at C0+8; restoring the cursor to (ckpt - ARENA_ADDR - 8) == C0+8
// frees the whole post-checkpoint region for the ELF emit to REUSE. The range guard
// makes this a SAFE NO-OP in the malloc-backed .so: there __mind_alloc(0) returns 0
// (`if (bytes<=0) return 0`), which is < ARENA_ADDR, so we never poke a fixed address
// the .so does not own. The reset changes only WHERE the running compiler allocates,
// never an emitted byte (output is a String built from the IR, address-independent),
// so the native-ELF and .so emitters stay byte-identical.
pub fn nb_arena_reclaim(ckpt: i64) -> i64 {
    if ckpt < nb_arena_addr() + 16 {
        return 0;
    }
    if ckpt >= nb_arena_addr() + nb_arena_bytes() {
        return 0;
    }
    let _r: i64 = __mind_store_i64(nb_arena_addr(), ckpt - nb_arena_addr() - 8);
    0
}

pub fn selftest_native_elf(src_addr: i64, src_len: i64) -> EmitState {
    selftest_native_elf_u(src_addr, src_len, 0)
}
pub fn selftest_native_elf_u(src_addr: i64, src_len: i64, user_lo: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    // ARENA (Round-2 mic@3 reclaim, 2026-07-21): nb_trace_hash builds the canonical
    // seeded+pruned mic@3 bytes (~476 MB for the whole self-host source) ONLY to
    // SHA-256 them into the 32-byte trace_hash note; that buffer is DEAD the instant
    // the digest exists, yet the fixed 1 GiB bump arena never frees, so the ~268 MB
    // native-ELF emit used to stack ON TOP of it. We CHECKPOINT the bump cursor before
    // the mic@3 build, COPY the finished digest out to a stable slot below the
    // checkpoint, then RESET the cursor so the ELF emit REUSES the reclaimed mic@3
    // region instead of extending past it — reclaiming ~268 MB of peak arena (the ELF
    // emit no longer stacks), which is what lets the self-compile keep growing without
    // tripping the nb_arena ud2 cap. Byte-exact: nothing live points into the reclaimed
    // region (tokens + src predate the checkpoint; the digest is copied out first), and
    // no emitted byte depends on the arena layout.
    let hslot: i64 = __mind_alloc(32);
    let ckpt: i64 = __mind_alloc(0);
    // Self-compute the note hash (no oracle feed). 0 => fail closed. nb_trace_hash
    // recomputes its own prune/kept set inside nb_build_mic3_from_tokens, so the ONLY
    // input it needs is the already-lexed `tokens` (ARENA dedup — no re-lex here).
    let h32: i64 = nb_trace_hash(tokens, src_addr, src_len, user_lo);
    if h32 == 0 {
        // Open mic@3 port: refuse to emit a note we cannot self-compute. Return the
        // empty EmitState so the smoke's no-feed rung fails LOUD (no fake win).
        return es_new();
    }
    // Preserve the digest into the stable slot BEFORE reclaiming the mic@3 region it
    // lives in, then reset the bump cursor (native-ELF only; no-op in the .so).
    let _cp: i64 = nb_copy32(hslot, h32, 0);
    let _rs: i64 = nb_arena_reclaim(ckpt);
    // Thread the ALREADY-lexed tokens into the _hb body instead of re-lexing (each
    // full-source lex() permanently occupies ~46 MB of the no-free arena). Token reuse
    // is byte-exact: same (src_addr, src_len) => identical token stream => identical
    // note + emitted ELF. The note is read from `hslot` (the stable digest copy).
    selftest_native_elf_hb_from_tokens(tokens, src_addr, hslot, user_lo)
}

// 4-arg form: `user_lo` is the offset in `src_addr` where the USER file begins
// (the bundled std/*.mind sources are concatenated ahead of it). Fns whose name
// starts at/after user_lo are the prune roots; reachable+last-def-per-name fns
// are emitted. Mirrors bin/mind-native.rs (seed stdlib, lower union, prune to the
// user call graph, last-write-wins dedup) so the two emitters lay the SAME fn set.
pub fn selftest_native_elf_hb(src_addr: i64, src_len: i64, hash_addr: i64, user_lo: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    selftest_native_elf_hb_from_tokens(tokens, src_addr, hash_addr, user_lo)
}

// Token-reuse variant of selftest_native_elf_hb (Rule-2c arena dedup): identical
// body except the full-source lex is hoisted to the caller, so the u -> hb chain
// lexes the whole source once instead of twice. Byte-exact: the token stream for
// (src_addr, src_len) is deterministic, so every downstream registry/lowering/
// patch step sees identical inputs and the emitted ELF is unchanged.
pub fn selftest_native_elf_hb_from_tokens(tokens: Vec, src_addr: i64, hash_addr: i64, user_lo: i64) -> EmitState {
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);

    // Collect ALL fn_def items in combined source order (std bricks first, then
    // the user file). nb_all = the pre-prune set.
    let all_fns: i64 = __mind_alloc((items_len + 1) * 8);
    let nb_all: i64 = nb_collect_fns(items_addr, items_len, 0, all_fns, 0);

    // Reachability prune to the user call graph, then last-write-wins dedup. For
    // a single file (user_lo==0) every fn is a root => kept == all (no-op).
    let reach: i64 = __mind_alloc((nb_all + 1) * 8);
    let _r0: i64 = nb_mark_roots(src_addr, all_fns, nb_all, user_lo, reach, 0);
    let _rf: i64 = nb_reach_fixpoint(src_addr, all_fns, nb_all, reach, nb_all + 1);
    let fns: i64 = __mind_alloc((nb_all + 1) * 8);
    let n_fns: i64 = nb_build_kept(src_addr, all_fns, nb_all, reach, fns, 0, 0);
    let entry_idx: i64 = nb_find_main(src_addr, fns, n_fns, 0);

    // Lay out: entry (main) FIRST, then the rest in source order.
    // ordered[] = the fn nodes in emission order.
    let ordered: i64 = __mind_alloc((n_fns + 1) * 8);
    let _ord: i64 = nb_order_fns(fns, n_fns, entry_idx, ordered);

    // fn_names[k] = (name_lo, name_hi) for ordered fn k; starts[k] filled below.
    let fn_names: i64 = __mind_alloc((n_fns + 1) * 2 * 8);
    let _fn: i64 = nb_fill_names(ordered, n_fns, 0, fn_names);

    // calls scratch table: ONE record (3 i64 words) per call site in the module.
    // Size it from the actual call count (nb_count_all_calls walks every ordered
    // fn body, bumping ccell at each ast_call); the old fixed 256-record cap
    // overflowed the bump arena on real modules (main.mind has ~10.7k call sites),
    // corrupting nb_patch_all. `+1` keeps a call-free module's alloc non-zero.
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    let n_calls: i64 = nb_count_all_calls(src_addr, ordered, n_fns, 0, ccell);
    let calls: i64 = __mind_alloc((n_calls + 1) * 3 * 8);
    // per-fn: start offset; call k belongs to fn call_owner[k].
    let starts: i64 = __mind_alloc((n_fns + 1) * 8);
    let call_owner: i64 = __mind_alloc((n_calls + 1) * 8);

    // Lower each ordered fn; concatenate into `image` (threaded as acc.code; the
    // running call count is threaded as acc.ncalls).
    // Whole-module struct registry (type-name -> field-name list), built once and
    // threaded through nb_lower_all so each fn's struct-typed params resolve their
    // field offsets (the Step-2 FieldAccess path) without re-lexing per fn.
    // RI-D2 S-C1 fix: build BOTH whole-module registries from the `tokens` already lexed
    // above (line ~24984), NOT via two more full-source lexes. Each extra full-source lex
    // permanently occupies the fixed 1 GiB native bump arena (no free); the redundant srt+
    // frt lexes overflowed it on the whole-compiler source (native stage1 segfault while
    // the unlimited-heap .so passed). Reusing `tokens` yields byte-identical registries.
    let srt: i64 = srt_build_from_tokens(tokens, src_addr);
    // RI-D2 S-C1: whole-module return-type registry (fn name -> declared-return-dtype),
    // built once and threaded through nb_lower_all like srt, so a call is spilled from the
    // right register file (xmm0 for a float-returning callee) and classified by its
    // callee's return dtype. Every fn in main.mind's float-free source registers INT.
    let frt: i64 = frt_build_from_tokens(tokens, src_addr);
    // RI-C: does any REACHABLE (pruned) fn reference argv? Gates the entry argc/argv
    // capture so an argv-free program is byte-identical EVEN when std.cli (whose
    // args_from_os mentions the intrinsic) is seeded ahead of it — the scan is scoped
    // to the emitted `ordered` set, not the raw combined token buffer.
    let uses_argv: i64 = nb_fns_use_argv(src_addr, ordered, n_fns, 0);
    // FAIL CLOSED when a narrow-width (i8/i16/i32) param is REASSIGNED in the fn
    // body: the loop-carry + width interaction desyncs the frame/slot count so the
    // carried loop var never updates -> the emitted ELF HANGS (infinite loop). A
    // narrow param that is only READ/RETURNED lowers correctly (the entry width-
    // wrap driver handles it — see self_host_native_autowrap_smoke.py), so ONLY the
    // reassigned shape is refused. Refuse loudly rather than emit a hanging ELF
    // (roadmap C2 narrow-param-carry support is the real fix). Never fires during
    // self-compile (no body-having self-host fn reassigns a narrow param), so the
    // loop stays byte-identical.
    if nb_fns_reassign_narrow_param(src_addr, ordered, n_fns, 0) == 1 {
        return es_new();
    }
    let acc0: NbState = NbState { code: string_new(), next_id: 0, last_id: 0, ncalls: 0 };
    let lr: NbState = nb_lower_all(acc0, src_addr, ordered, n_fns, 0, calls, starts, call_owner, entry_idx, srt, frt, uses_argv);
    let image0: String = lr.code;
    let total_calls: i64 = lr.ncalls;

    // No-`main` (library) module: prepend the 9-byte synth entry stub at offset 0
    // (mirrors src/native/mod.rs pushing synth_lib_entry() as funcs[0]) and shift
    // every recorded fn start by 9 so the inter-fn rel32 patches stay exact. With
    // a real `main` (entry_idx>=0) the stub is omitted and starts are unchanged.
    let stub_len: i64 = if entry_idx < 0 {
        9
    } else {
        0
    };
    let _ss: i64 = nb_shift_starts(starts, n_fns, stub_len, 0);
    let image: String = if entry_idx < 0 {
        string_push_str(nb_synth_entry(), image0)
    } else {
        image0
    };

    // Patch each call's rel32. call k: owner fn = call_owner[k]; rel_off recorded
    // relative to that fn => abs_off = starts[owner] + rel_off. Resolve callee.
    let code_addr: i64 = string_addr(image);
    let _p: i64 = nb_patch_all(code_addr, calls, total_calls, call_owner, starts, fn_names, n_fns, src_addr, 0);

    // entry_off = 0 (entry is laid first).
    let note0: String = string_new();
    let note: String = nb_build_note(note0, hash_addr);
    let elf: String = nb_write_elf(image, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// Collect fn_def nodes into fns[]; returns the count.
pub fn nb_collect_fns(items_addr: i64, items_len: i64, i: i64, fns: i64, n: i64) -> i64 {
    if i >= items_len {
        return n;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let n2: i64 = if ast_kind(item) == ast_fn_def() {
        __mind_store_i64(fns + n * 8, item);
        n + 1
    } else {
        n
    };
    nb_collect_fns(items_addr, items_len, i + 1, fns, n2)
}

// Find the index of the fn named `main`, or -1.
pub fn nb_find_main(buf: i64, fns: i64, n_fns: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0 - 1;
    }
    let node: i64 = __mind_load_i64(fns + k * 8);
    let name_node: i64 = ast_child0(node);
    if nb_name_is_main(buf, ast_span_lo(name_node), ast_span_hi(name_node)) == 1 {
        return k;
    }
    nb_find_main(buf, fns, n_fns, k + 1)
}

// 1 if buf[lo..hi] spells "main".
pub fn nb_name_is_main(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo != 4 {
        return 0;
    }
    if load_byte(buf, lo + 0) != 109 {
        return 0;
    }
    if load_byte(buf, lo + 1) != 97 {
        return 0;
    }
    if load_byte(buf, lo + 2) != 105 {
        return 0;
    }
    if load_byte(buf, lo + 3) != 110 {
        return 0;
    }
    1
}

// Build the emission order: entry (main) first, then the rest in source order.
pub fn nb_order_fns(fns: i64, n_fns: i64, entry_idx: i64, ordered: i64) -> i64 {
    // ordered[0] = entry (if present), then the rest skipping entry_idx.
    let pos0: i64 = if entry_idx >= 0 {
        __mind_store_i64(ordered + 0, __mind_load_i64(fns + entry_idx * 8));
        1
    } else {
        0
    };
    nb_order_rest(fns, n_fns, entry_idx, ordered, 0, pos0)
}
pub fn nb_order_rest(fns: i64, n_fns: i64, entry_idx: i64, ordered: i64, i: i64, pos: i64) -> i64 {
    if i >= n_fns {
        return pos;
    }
    let pos2: i64 = if i == entry_idx {
        pos
    } else {
        __mind_store_i64(ordered + pos * 8, __mind_load_i64(fns + i * 8));
        pos + 1
    };
    nb_order_rest(fns, n_fns, entry_idx, ordered, i + 1, pos2)
}

// fn_names[k] = (name_lo, name_hi) for ordered[k].
pub fn nb_fill_names(ordered: i64, n_fns: i64, k: i64, fn_names: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    let node: i64 = __mind_load_i64(ordered + k * 8);
    let name_node: i64 = ast_child0(node);
    __mind_store_i64(fn_names + (k * 2 + 0) * 8, ast_span_lo(name_node));
    __mind_store_i64(fn_names + (k * 2 + 1) * 8, ast_span_hi(name_node));
    nb_fill_names(ordered, n_fns, k + 1, fn_names)
}

// Lower every ordered fn, concatenating their code into `image`. Records each
// fn's start offset (starts[k]) and which fn owns each new call (call_owner[c]).
// Threads the running ncalls. `entry_idx` is the index in `fns` of main; an
// ordered fn is the entry iff it is ordered position 0 AND a main existed.
// is_entry for ordered fn k: true iff k is ordered-position 0 AND a main existed.
// Plain-return form (the nested value-if is outside the self-host nfn subset).
pub fn nb_is_entry(k: i64, entry_idx: i64) -> i64 {
    if k != 0 {
        return 0;
    }
    if entry_idx < 0 {
        return 0;
    }
    1
}

// Thread the running image + call-count as ONE NbState accumulator `acc`
// (acc.code = the laid-out image so far, acc.ncalls = the running call count).
// The guard returns the param `acc` (NOT a struct literal) so the body stays
// inside the self-host nfn-emittable seq subset (a struct-literal guard-return in
// a multi-statement recursive struct fn is outside it — verified empirically).
pub fn nb_lower_all(acc: NbState, buf: i64, ordered: i64, n_fns: i64, k: i64, calls: i64, starts: i64, call_owner: i64, entry_idx: i64, srt: i64, frt: i64, uses_argv: i64) -> NbState {
    if k >= n_fns {
        return acc;
    }
    let node: i64 = __mind_load_i64(ordered + k * 8);
    let is_entry: i64 = nb_is_entry(k, entry_idx);
    let ncalls0: i64 = acc.ncalls;
    let image: String = acc.code;
    __mind_store_i64(starts + k * 8, string_len(image));
    let fr: NbState = nb_lower_fn(buf, node, is_entry, calls, ncalls0, srt, frt, uses_argv);
    // Record owner for each newly-added call.
    let _o: i64 = nb_set_owners(call_owner, ncalls0, fr.ncalls, k);
    let image2: String = string_push_str(image, fr.code);
    let acc2: NbState = NbState { code: image2, next_id: 0, last_id: 0, ncalls: fr.ncalls };
    nb_lower_all(acc2, buf, ordered, n_fns, k + 1, calls, starts, call_owner, entry_idx, srt, frt, uses_argv)
}
pub fn nb_set_owners(call_owner: i64, c0: i64, c1: i64, k: i64) -> i64 {
    if c0 >= c1 {
        return 0;
    }
    __mind_store_i64(call_owner + c0 * 8, k);
    nb_set_owners(call_owner, c0 + 1, c1, k)
}

// Patch every call's rel32.
pub fn nb_patch_all(code_addr: i64, calls: i64, total_calls: i64, call_owner: i64, starts: i64, fn_names: i64, n_fns: i64, buf: i64, c: i64) -> i64 {
    if c >= total_calls {
        return 0;
    }
    let rel_off: i64 = __mind_load_i64(calls + (c * 3 + 0) * 8);
    let lo: i64 = __mind_load_i64(calls + (c * 3 + 1) * 8);
    let hi: i64 = __mind_load_i64(calls + (c * 3 + 2) * 8);
    let owner: i64 = __mind_load_i64(call_owner + c * 8);
    let caller_start: i64 = __mind_load_i64(starts + owner * 8);
    let abs_off: i64 = caller_start + rel_off;
    let callee_idx: i64 = nb_resolve_callee(buf, fn_names, n_fns, lo, hi, 0);
    let callee_start: i64 = __mind_load_i64(starts + callee_idx * 8);
    let next: i64 = abs_off + 4;
    let rel: i64 = callee_start - next;
    let _p: i64 = nb_patch_rel32(code_addr, abs_off, rel);
    nb_patch_all(code_addr, calls, total_calls, call_owner, starts, fn_names, n_fns, buf, c + 1)
}

// ---- RI-B1: scalar-f64 SSE2 emitters (zero MLIR/LLVM) ----------------------
// The native-ELF path is otherwise i64-only. These emit x86-64 SSE2 scalar-double
// machine code directly. This first slice covers the register-form arithmetic and
// convert (the value-in-xmm forms), which need no rbp frame — sufficient to prove
// MIND emits correct scalar-f64 float code natively. Defined at the END of the file
// so the whole-compiler emission layout (source-order fn placement + inter-fn rel32
// patches) of every existing fn is unperturbed and stays byte-identical to the frozen
// oracle. The memory-operand spill forms (movsd [rbp+d],xmm0 = F2 0F 11 85 <d32> /
// movsd xmm0,[rbp+d] = F2 0F 10 85 <d32> / addsd xmm0,[rbp+d] = F2 0F 58 85 <d32> /
// ucomisd = 66 0F 2E 85 <d32> / cvtsi2sd = F2 48 0F 2A 85 <d32>) plus a per-SSA dtype
// tag threaded through nb_expr are the upgrade path to fold floats into the existing
// spill model; f32 mirrors these with the F2->F3 prefix swap and 66 dropped on convert.

// Load a 64-bit double bit-pattern into xmm{which} (which: 0->xmm0, 1->xmm1) via a
// gpr bridge:  movabs rax, bits (48 B8 <imm64>) ; movq xmm{which}, rax (66 48 0F 6E /r).
pub fn nb_fp_const_xmm(code: String, bits: i64, which: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, bits);
    let c4: String = nb_push(c3, 102);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 110);
    let modrm: i64 = if which == 0 {
        192
    } else {
        200
    };
    nb_push(c7, modrm)
}

// Scalar-double arith:  xmm0 = xmm0 OP xmm1.  F2 0F <opc> C1.
//   op_sel 0->addsd(0x58) 1->subsd(0x5C) 2->mulsd(0x59) 3->divsd(0x5E).
pub fn nb_fp_binop_xmm01(code: String, op_sel: i64) -> String {
    let opc: i64 = if op_sel == 0 {
        88
    } else {
        if op_sel == 1 {
            92
        } else {
            if op_sel == 2 {
                89
            } else {
                94
            }
        }
    };
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, opc);
    nb_push(c3, 193)
}

// Truncating convert f64->i64:  cvttsd2si rax, xmm0 = F2 48 0F 2C C0.
pub fn nb_fp_trunc_rax_xmm0(code: String) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 44);
    nb_push(c4, 192)
}

// Standalone runnable-ELF entry that computes `trunc(a OP b)` in scalar f64 and
// exits with it, emitting ZERO MLIR/LLVM. `a_bits`/`b_bits` are the IEEE-754
// double bit-patterns; op_sel selects add/sub/mul/div. Wraps the code via the same
// nb_write_elf scaffold the integer path uses, so the produced bytes are a real,
// directly-executable x86-64 ELF. The gate runs it and checks the exit code — the
// CPU is the oracle (no frozen float oracle exists; Rust native never emitted f64).
pub fn selftest_native_elf_fp(a_bits: i64, b_bits: i64, op_sel: i64) -> EmitState {
    let c1: String = nb_fp_const_xmm(string_new(), a_bits, 0);
    let c2: String = nb_fp_const_xmm(c1, b_bits, 1);
    let c3: String = nb_fp_binop_xmm01(c2, op_sel);
    let c4: String = nb_fp_trunc_rax_xmm0(c3);
    let code: String = nb_emit_return(c4, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-B1: scalar-f64 SSE2 memory-operand (stack-slot) forms --------------
// These fold floats into the existing rbp-frame spill model the integer path
// uses: a scalar-double lives in an 8-byte stack slot [rbp+disp32] (disp via
// nb_slot_disp, two's-complement i32) and is loaded to xmm0 / stored from xmm0 /
// consumed directly as a binop memory operand. ModRM 0x85 = mod=10 (disp32),
// reg=000 (xmm0), rm=101 (rbp). Appended at the END of the file so the
// whole-compiler emission layout of every existing fn is unperturbed and the
// integer native-ELF oracle stays byte-identical. f32 mirrors these with the
// F2->F3 scalar-single prefix swap; a per-SSA dtype tag threaded through nb_expr
// is the remaining upgrade path to route these from real float expressions.

// movsd xmm0, [rbp+disp32]  =  F2 0F 10 85 <disp32>   (load slot -> xmm0)
pub fn nb_fp_movsd_load_xmm0(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 16);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// movsd xmm{k}, [rbp+disp32]  =  F2 0F 10 (0x80 | (k&7)<<3 | 0x05) <disp32>
// Load a stack slot into SSE arg register xmm{k}. This is nb_fp_movsd_load_xmm0 with
// k folded into the ModRM.reg field (mirror of nb_store_sse_argreg, but the store
// opcode 0x11 -> the load opcode 0x10). k in 0..7 (the 8 SysV SSE arg registers) needs
// no REX; k==0 is byte-identical to nb_fp_movsd_load_xmm0.
pub fn nb_fp_movsd_load_xmmk(code: String, k: i64, disp: i64) -> String {
    let modrm: i64 = 128 + (k & 7) * 8 + 5;
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 16);
    let c4: String = nb_push(c3, modrm);
    nb_i32le_signed(c4, disp)
}

// movsd xmm0, [rax]  =  F2 0F 10 00   (load the 8 bytes AT the address in rax into xmm0)
// The register-indirect movsd form (ModRM 00: mod=00 reg=xmm0 rm=rax) used by the FLOAT
// field READ: after `mov rax,[rbp+addr]` puts the field's byte address in rax, this loads
// its f64 value into the SSE register file. RI-D2 S-D.
pub fn nb_fp_movsd_load_xmm0_rax(code: String) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 16);
    nb_push(c3, 0)
}

// movsd [rbp+disp32], xmm0  =  F2 0F 11 85 <disp32>   (store xmm0 -> slot)
pub fn nb_fp_movsd_store_xmm0(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 17);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// <op>sd xmm0, [rbp+disp32]  =  F2 0F <opc> 85 <disp32>   (xmm0 = xmm0 OP slot)
//   op_sel 0->addsd(0x58) 1->subsd(0x5C) 2->mulsd(0x59) 3->divsd(0x5E).
pub fn nb_fp_binop_xmm0_mem(code: String, op_sel: i64, disp: i64) -> String {
    let opc: i64 = if op_sel == 0 {
        88
    } else {
        if op_sel == 1 {
            92
        } else {
            if op_sel == 2 {
                89
            } else {
                94
            }
        }
    };
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, opc);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// FIX #168 encoder: `ucomisd xmm0, [rbp+disp32] ; set<cc> al ; movzx eax, al` — lhs
// already in xmm0. Leaves the i64 0/1 boolean in rax (mirror of nb_cmp_rax_mem, but the
// unordered-compare SSE form + an UNSIGNED setcc since comisd/ucomisd set CF/ZF like an
// unsigned compare). Correct for all FINITE operands.
//   ucomisd = 66 0F 2E 85 <disp32> ; set<cc> al = 0F <setcc> C0 ; movzx eax,al = 0F B6 C0
pub fn nb_fp_cmp_xmm0_mem(code: String, setcc: i64, rhs_disp: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 46);
    let c4: String = nb_push(c3, 133);
    let c5: String = nb_i32le_signed(c4, rhs_disp);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, setcc);
    let c8: String = nb_push(c7, 192);
    let c9: String = nb_push(c8, 15);
    let c10: String = nb_push(c9, 182);
    nb_push(c10, 192)
}

// push rbp ; mov rbp,rsp ; sub rsp,frame(imm32)  =  55 48 89 E5 48 81 EC <imm32>
// Sets up the rbp frame so [rbp+disp32] stack slots are addressable. (movsd is
// scalar/unaligned, so no 16-byte alignment fixup is required.)
pub fn nb_fp_prologue_frame(code: String, frame: i64) -> String {
    let c1: String = nb_push(code, 85);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 137);
    let c4: String = nb_push(c3, 229);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 129);
    let c7: String = nb_push(c6, 236);
    nb_u32(c7, frame)
}

// Standalone runnable-ELF entry proving the memory-operand SSE2 forms: computes
// `trunc(a OP b)` in scalar f64 but ROUTES every value through a stack slot —
// each const is spilled to a slot with movsd-store, the binop consumes b as a
// [rbp+disp32] memory operand, and the result round-trips slot->store->load
// before cvttsd2si. Exercises F2 0F 10 85 / F2 0F 11 85 / F2 0F {58..} 85 end to
// end. Emits ZERO MLIR/LLVM; the CPU exit code is the oracle (no frozen float
// oracle exists — Rust native returned Unsupported(ConstF64)).
pub fn selftest_native_elf_fp_mem(a_bits: i64, b_bits: i64, op_sel: i64) -> EmitState {
    let p: String = nb_fp_prologue_frame(string_new(), 64);
    // a -> xmm0 -> slot0 [rbp-8]
    let c1: String = nb_fp_const_xmm(p, a_bits, 0);
    let c2: String = nb_fp_movsd_store_xmm0(c1, nb_slot_disp(0));
    // b -> xmm0 -> slot1 [rbp-16]
    let c3: String = nb_fp_const_xmm(c2, b_bits, 0);
    let c4: String = nb_fp_movsd_store_xmm0(c3, nb_slot_disp(1));
    // xmm0 = slot0 ; xmm0 = xmm0 OP [rbp-16]  (memory-operand binop)
    let c5: String = nb_fp_movsd_load_xmm0(c4, nb_slot_disp(0));
    let c6: String = nb_fp_binop_xmm0_mem(c5, op_sel, nb_slot_disp(1));
    // result -> slot2 -> back to xmm0 (store+load round-trip proves both forms)
    let c7: String = nb_fp_movsd_store_xmm0(c6, nb_slot_disp(2));
    let c8: String = nb_fp_movsd_load_xmm0(c7, nb_slot_disp(2));
    let c9: String = nb_fp_trunc_rax_xmm0(c8);
    let code: String = nb_emit_return(c9, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-B1: per-SSA dtype tag (int vs float) — the connecting construct ------
// The native-ELF backend is otherwise i64-only: every SSA value is spilled to a
// GP-integer stack slot and consumed with rax/imul/idiv. To lower real floats it
// must know, per SSA id, whether a value is a 64-bit integer or a scalar f64, so
// nb_expr can route an ast_float_lit's value (and later arithmetic over float SSA
// values) to the SSE2 f64 encoders (nb_fp_const_xmm / nb_fp_movsd_* /
// nb_fp_binop_xmm0_mem) with xmm registers instead of the integer path.
//
// This FIRST slice lands the TAG itself — the connecting construct between the
// parser's ast_float_lit (commit c72f645) and the nb_fp_* encoders (c914529):
// the two dtype constants, the AST-node -> dtype classifier nb_expr will consult,
// and the SSA-id-keyed dtype table (new/set/get). It is purely ADDITIVE and
// FLOAT-ONLY: main.mind's OWN source contains no float literals, so nb_node_dtype
// classifies every integer SSA value as INT (0) and nothing about the existing
// integer lowering changes — the integer self-host stays byte-identical.
//
// FOLLOW-UP (next construct, NOT this one): the nb_expr SSE-selection arm that
// allocates one nb_dtype_table per fn body, tags each ast_float_lit's dst slot
// FLOAT, propagates FLOAT through a binop whose operands are FLOAT, and reads
// nb_dtype_get(id) to pick the nb_fp_* xmm encoders vs the GP-integer ops.

// dtype tags: an SSA value is either a 64-bit integer or a scalar f64.
pub fn nb_dtype_int() -> i64 {
    0
}
pub fn nb_dtype_float() -> i64 {
    1
}

// Classify the dtype of the SSA value an AST expression node produces. In this
// first slice only a float LITERAL is float-typed; arithmetic-result inference
// (a float op over float operands stays float) lands with the nb_expr SSE arm.
// Every other node -> INT, so the integer path is entirely unperturbed.
pub fn nb_node_dtype(node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_float_lit() {
        return nb_dtype_float();
    }
    // A parenthesised expr has the dtype of its inner expr (nb_expr passes paren
    // straight through to child0, so the dtype must too).
    if k == ast_paren() {
        return nb_node_dtype(ast_child0(node));
    }
    // FIX #170: unary minus preserves the operand's dtype — `-1.0` is FLOAT, so a
    // downstream float op/compare over it routes the SSE2 path (a signed-bit compare of
    // negated IEEE-754 bits would be wrong, #168). main.mind is float-free so this is INT.
    if k == ast_neg() {
        return nb_node_dtype(ast_child0(node));
    }
    // FIX #172: `!x` (`x == 0`) yields an i64 boolean -> INT, regardless of operand dtype.
    if k == ast_not() {
        return nb_dtype_int();
    }
    // FIX #171: a value-if (`if C { A } else { B }`) has the dtype of its branch values,
    // classified off the then-branch's tail expression. This lets a `let r = if C {2.0}
    // else {3.0}; r + 1.0` binding tag r's slot FLOAT (nb_stmt's let arm reads this),
    // so the downstream float op routes the SSE2 path instead of the GP-integer path
    // (which returned a wrong value pre-fix). main.mind's value-ifs are all INT-branched,
    // so this classifies INT during self-compile — byte-identical.
    if k == ast_if() {
        let tt_blk: i64 = ast_child1(node);
        let tt_sl: i64 = ast_aux(tt_blk);
        if tt_sl >= 1 {
            return nb_node_dtype(__mind_load_i64(ast_child0(tt_blk) + (tt_sl - 1) * 8));
        }
        return nb_dtype_int();
    }
    // FLOAT-op-FLOAT propagation (the minimal rule): a scalar-arithmetic binop
    // (+ - * /) over two FLOAT operands is itself FLOAT, so a nested float
    // expression stays float-typed through its consumers. A comparison op
    // (nb_fp_opsel < 0) produces an i64 bool -> INT even over float operands, and
    // any operand that is not float bottoms the result out to INT. main.mind's own
    // source contains no float literals, so every binop here recurses to INT and
    // this branch never fires during self-compile.
    if k == ast_binop() {
        if nb_fp_opsel(ast_aux(node)) >= 0 {
            if nb_node_dtype(ast_child0(node)) == nb_dtype_float() {
                if nb_node_dtype(ast_child1(node)) == nb_dtype_float() {
                    return nb_dtype_float();
                }
            }
        }
        return nb_dtype_int();
    }
    nb_dtype_int()
}

// RI-B1 (#107) FOLLOW-UP: FLOAT dtype propagation across a LET binding. The pure-AST
// nb_node_dtype above cannot see through an ident (`let x = 1.5; x + 2.5` — `x` is an
// ast_ident, classified INT by the AST alone). This TABLE-aware classifier resolves an
// ident to its bound SSA slot (via the SAME let-env nb_expr consults) and reads the
// per-SSA dtype the `let` recorded, so a float-let-bound operand is seen as FLOAT and
// the nb_expr binop arm routes the SSE2 path. For every non-ident node it mirrors
// nb_node_dtype's AST rule but recurses through THIS classifier so nested idents
// resolve too. Guard: `tbl == 0` (no per-fn table on this path) falls back to the
// pure-AST nb_node_dtype, so any caller without a table is byte-for-byte unchanged.
// main.mind's OWN source is float-free, so the table stays all-INT during self-compile
// (no `let` ever tags a slot FLOAT), every ident resolves to INT, and the integer
// native-ELF emission is byte-identical.
pub fn nb_node_dtype_tbl(node: i64, tbl: i64, lets: i64, lcell: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    if tbl == 0 {
        return nb_node_dtype(node);
    }
    let k: i64 = ast_kind(node);
    if k == ast_ident() {
        // Resolve the name exactly as nb_expr's ident arm does: a PARAM first (its SSA
        // slot == its index), else a `let`-bound slot. Read the recorded dtype off the
        // resolved slot. RI-D2 S-B: a float param's slot was tagged FLOAT by
        // nb_tag_float_params in nb_lower_fn, so a param ident now classifies FLOAT
        // instead of falling through to INT. main.mind's params are all INT, so every
        // param ident here still reads INT (tag default) — classification unchanged, GP
        // path byte-identical.
        let pidx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if pidx >= 0 {
            return nb_dtype_get(tbl, pidx);
        }
        let lslot: i64 = nb_lets_lookup(lets, lcell, buf, ast_span_lo(node), ast_span_hi(node));
        if lslot >= 0 {
            return nb_dtype_get(tbl, lslot);
        }
        return nb_dtype_int();
    }
    if k == ast_float_lit() {
        return nb_dtype_float();
    }
    // RI-D2 S-C1: a CALL classifies as its callee's DECLARED return dtype, read from the
    // frt registry (stashed at lcell+16 by nb_lower_fn). This lets an immediate binop over
    // a call — `g() + 1.5` where `g` returns f64 — see the call operand as FLOAT and route
    // the SSE2 arm. frt_lookup_dtype returns INT for a null registry or an unregistered
    // callee, and every callee in main.mind's float-free source registers INT, so a call
    // node here classifies INT during self-compile exactly as the prior fall-through did.
    if k == ast_call() {
        return frt_lookup_dtype(__mind_load_i64(lcell + 16), buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node)));
    }
    if k == ast_field() {
        // RI-D2 S-D: a field READ `recv.field` classifies as its field's dtype (FLOAT for
        // an f64/f32 field), resolved off the receiver's struct binding — so an immediate
        // binop over a float field (`p.x + 1.0`) sees the field operand FLOAT and routes
        // the SSE2 arm. Every field in main.mind's float-free structs classifies INT, so
        // this is byte-identical during self-compile.
        return nb_field_dtype(ast_child0(node), node, buf, lets, lcell);
    }
    if k == ast_paren() {
        return nb_node_dtype_tbl(ast_child0(node), tbl, lets, lcell, buf, params_addr, n_params);
    }
    // FIX #170: unary minus preserves the operand's dtype (table-aware, so a `-x` over a
    // float-let-bound `x` classifies FLOAT). main.mind's source is float-free -> INT.
    if k == ast_neg() {
        return nb_node_dtype_tbl(ast_child0(node), tbl, lets, lcell, buf, params_addr, n_params);
    }
    // FIX #172: `!x` (`x == 0`) yields an i64 boolean -> INT, regardless of operand dtype.
    if k == ast_not() {
        return nb_dtype_int();
    }
    // FIX #171: a value-if classifies as its then-branch tail dtype (table-aware). Lets a
    // `let r = if C {float} else {float}` binding tag r FLOAT so a later `r + 1.0` routes
    // the SSE2 path. main.mind's value-ifs are INT-branched -> INT, byte-identical.
    if k == ast_if() {
        let tt_blk: i64 = ast_child1(node);
        let tt_sl: i64 = ast_aux(tt_blk);
        if tt_sl >= 1 {
            return nb_node_dtype_tbl(__mind_load_i64(ast_child0(tt_blk) + (tt_sl - 1) * 8), tbl, lets, lcell, buf, params_addr, n_params);
        }
        return nb_dtype_int();
    }
    if k == ast_binop() {
        if nb_fp_opsel(ast_aux(node)) >= 0 {
            if nb_node_dtype_tbl(ast_child0(node), tbl, lets, lcell, buf, params_addr, n_params) == nb_dtype_float() {
                if nb_node_dtype_tbl(ast_child1(node), tbl, lets, lcell, buf, params_addr, n_params) == nb_dtype_float() {
                    return nb_dtype_float();
                }
            }
        }
        return nb_dtype_int();
    }
    nb_dtype_int()
}

// Tag SSA slot `id` with dtype `dt` in the per-fn table, guarded: a null table (a
// caller with no dtype table threaded) or an unresolved slot (id < 0) is a no-op, so
// this is inert on every path that does not opt in. Returns 0.
pub fn nb_dtype_tag_slot(tbl: i64, id: i64, dt: i64) -> i64 {
    if tbl == 0 {
        return 0;
    }
    if id < 0 {
        return 0;
    }
    let _s: i64 = nb_dtype_set(tbl, id, dt);
    0
}

// Classify a param's declared type (its type-leaf span) as FLOAT or INT. A param node
// is (name_leaf at child0, type_leaf at child1); the type leaf's span is the type name
// text. Returns nb_dtype_float() for `f64`/`f32`, else nb_dtype_int(). Only these two
// scalar-float type names route the SSE ABI/encoder; every other type (i64, bool,
// String, a struct name, ...) stays INT and takes the GP-integer path unchanged. bytes
// f=102, 6=54, 4=52, 3=51, 2=50, so "f64"=[102,54,52] and "f32"=[102,51,50].
pub fn nb_param_is_float(buf: i64, type_leaf: i64) -> i64 {
    let lo: i64 = ast_span_lo(type_leaf);
    let hi: i64 = ast_span_hi(type_leaf);
    let f64_buf: i64 = make_byte_buf_3(102, 54, 52);
    if bytes_eq(buf, lo, hi, f64_buf, 0, 3) == 1 {
        return nb_dtype_float();
    }
    let f32_buf: i64 = make_byte_buf_3(102, 51, 50);
    if bytes_eq(buf, lo, hi, f32_buf, 0, 3) == 1 {
        return nb_dtype_float();
    }
    nb_dtype_int()
}

// Tag every FLOAT param's SSA slot (param i -> slot i) in the per-fn dtype table, so a
// float param ident classifies FLOAT at its consumers. Recursion (self-host subset, no
// while). nb_dtype_tag_slot is a no-op for a null table or id<0; tagging a non-float
// param writes INT (the table default), emitting no code — so this is inert for the
// all-integer param case (all of main.mind), preserving byte-identity.
pub fn nb_tag_float_params(tbl: i64, buf: i64, params_addr: i64, n_params: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let dt: i64 = nb_param_is_float(buf, ast_child1(pnode));
    let _s: i64 = nb_dtype_tag_slot(tbl, i, dt);
    nb_tag_float_params(tbl, buf, params_addr, n_params, i + 1)
}

// Map a binop operator tag to the SSE2 scalar-double op_sel used by
// nb_fp_binop_xmm0_mem: + -> addsd(0), - -> subsd(1), * -> mulsd(2), / -> divsd(3).
// Returns -1 for any non-ARITHMETIC operator (comparisons, bitwise, shifts) — these have
// no scalar-double ARITHMETIC form. A FLOAT-op-FLOAT COMPARISON is NOT routed to the
// GP-integer path (that would be a signed compare of raw IEEE-754 bits, inverted for
// negatives — #168): nb_expr routes it through nb_fp_setcc_opcode + the ucomisd SSE
// compare instead; only bitwise/shift operators over float operands (which the surface
// grammar does not admit) would fall through. The result of a float comparison is an i64
// 0/1 boolean, hence itself INT.
pub fn nb_fp_opsel(op: i64) -> i64 {
    if op == op_add() {
        return 0;
    }
    if op == op_sub() {
        return 1;
    }
    if op == op_mul() {
        return 2;
    }
    if op == op_div() {
        return 3;
    }
    0 - 1
}

// FIX #168: map a FLOAT-operand relational/equality operator to the UNSIGNED set<cc>
// opcode byte used after ucomisd (comisd/ucomisd set CF/ZF like an unsigned compare, so
// the GP SIGNED setcc of nb_setcc_opcode would be wrong). For xmm0 <op> mem:
//   >  -> seta  (0x97 = 151, CF=0 & ZF=0)   >= -> setae (0x93 = 147, CF=0)
//   <  -> setb  (0x92 = 146, CF=1)          <= -> setbe (0x96 = 150, CF=1 | ZF=1)
//   == -> sete  (0x94 = 148, ZF=1)          != -> setne (0x95 = 149, ZF=0)
// These are exact for FINITE operands. deferred: NaN edge cases — an unordered ucomisd
// sets CF=ZF=PF=1, so setb/setbe/sete read TRUE for a NaN operand; a fully NaN-aware
// predicate (parity-flag masking for ==/!=, swapped-operand seta/setae for </<=) is the
// upgrade path. main.mind is float-free so this arm never fires during self-compile.
pub fn nb_fp_setcc_opcode(op: i64) -> i64 {
    if op == op_gt() {
        return 151;
    }
    if op == op_ge() {
        return 147;
    }
    if op == op_lt() {
        return 146;
    }
    if op == op_le() {
        return 150;
    }
    if op == op_eq() {
        return 148;
    }
    if op == op_ne() {
        return 149;
    }
    0 - 1
}

// A per-SSA dtype table: `n` i64 slots indexed by SSA id, all initialised to INT
// (0). nb_expr will allocate one per function body and consult it when lowering
// each expression, exactly as it already consults the let-env for slot ids.
pub fn nb_dtype_table_new(n: i64) -> i64 {
    let tbl: i64 = __mind_alloc(n * 8);
    let _z: i64 = nb_dtype_table_init(tbl, n, 0);
    tbl
}

// Zero (= INT) every slot, so an un-tagged SSA id reads back INT by default.
// Recursion (mirrors nb_call_args) keeps this in the self-host subset — no while.
pub fn nb_dtype_table_init(tbl: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return tbl;
    }
    __mind_store_i64(tbl + i * 8, nb_dtype_int());
    nb_dtype_table_init(tbl, n, i + 1)
}

// Tag SSA id `id` with dtype `dt`; returns the table (immutable-threading style).
pub fn nb_dtype_set(tbl: i64, id: i64, dt: i64) -> i64 {
    __mind_store_i64(tbl + id * 8, dt);
    tbl
}

// Read the dtype tag of SSA id `id` (default INT for an un-tagged slot).
pub fn nb_dtype_get(tbl: i64, id: i64) -> i64 {
    __mind_load_i64(tbl + id * 8)
}

// Demonstrable slice: lex + parse ONE primary expression from `src`, classify its
// SSA value's dtype, round-trip that tag through the SSA dtype table, and return
// the tag. Proves the whole tiny chain end to end with a REAL parsed AST node:
//   `1.5` (an ast_float_lit from the parser) -> nb_dtype_float() (1)
//   `42`  (an ast_int_lit)                   -> nb_dtype_int()   (0)
// This is the parser<->encoder connecting construct's first observable behaviour;
// the nb_expr SSE-selection arm is the follow-up. Emits nothing — pure dtype
// threading — so it cannot perturb any byte-identity oracle.
pub fn selftest_dtype_tag(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let pr: ParseResult = parse_primary(toks, 0, src_addr);
    let node: i64 = pr_node(pr);
    let dt: i64 = nb_node_dtype(node);
    let tbl: i64 = nb_dtype_table_new(4);
    let _s: i64 = nb_dtype_set(tbl, 0, dt);
    nb_dtype_get(tbl, 0)
}

// ---- RI-B1: float-literal decimal span -> IEEE-754 f64 bits (integer-only) -----
// nb_expr's float arm needs the 64-bit double bit-pattern of a `<int>.<frac>`
// source literal, computed with INTEGER arithmetic only so main.mind stays
// float-free (a float op in main.mind's own source would break self-host
// byte-identity). value = num/den, den = 10^fdigits = 2^k * 5^k; strip the 5^k
// factor (exact for a dyadic / exactly-representable literal) to leave q * 2^(-k),
// then normalise q into a 53-bit mantissa. EXACT for the exactly-representable
// dyadic case (0.5, 1.5, 2.5, 3.0, ...).
// deferred: general correctly-rounded decimal->f64 (round-to-nearest-even over
// arbitrary precision) is a follow-up — stubbed to the exact dyadic case; upgrade
// path: a bignum long-division producing the guard/round/sticky bits.

// 10^n (n>=0) via recursion (self-host subset: no while).
pub fn nb_pow10(n: i64) -> i64 {
    if n <= 0 {
        return 1;
    }
    nb_pow10(n - 1) * 10
}

// Divide `q` by 5 exactly, `k` times (strips the 5^k factor of den = 10^k).
pub fn nb_strip_pow5(q: i64, k: i64) -> i64 {
    if k <= 0 {
        return q;
    }
    nb_strip_pow5(q / 5, k - 1)
}

// Index of the highest set bit of q>0 (q in [2^b, 2^(b+1)) -> returns b).
pub fn nb_msb_index(q: i64) -> i64 {
    if q <= 1 {
        return 0;
    }
    nb_msb_index(q / 2) + 1
}

// IEEE-754 f64 bits for q * 2^(-k), q>0, sign 0. q normalises to a 53-bit mantissa
// (implicit leading 1 at bit 52); biased exponent = 1023 + (b - k). Shifts are
// native-ELF-supported (nb_arith_rax_mem shl/shr), so this self-compiles.
pub fn nb_ratio_to_f64_bits(q: i64, k: i64) -> i64 {
    if q <= 0 {
        return 0;
    }
    let b: i64 = nb_msb_index(q);
    let mant: i64 = if b <= 52 {
        q << (52 - b)
    } else {
        q >> (b - 52)
    };
    let frac: i64 = mant - (1 << 52);
    let biased: i64 = 1023 + (b - k);
    (biased << 52) | frac
}

// Index of the '.' (byte 46) in [lo,hi); returns hi when absent (no fractional part).
pub fn nb_find_dot(buf: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return hi;
    }
    if load_byte(buf, lo) == 46 {
        return lo;
    }
    nb_find_dot(buf, lo + 1, hi)
}

// Parse a `<intdigits>.<fracdigits>` span into IEEE-754 f64 bits (see block header).
pub fn nb_float_lit_bits(buf: i64, lo: i64, hi: i64) -> i64 {
    let dot: i64 = nb_find_dot(buf, lo, hi);
    let ipart: i64 = parse_int_span(buf, lo, dot, 0);
    let fdigits: i64 = hi - (dot + 1);
    let fk: i64 = if fdigits < 0 {
        0
    } else {
        fdigits
    };
    let fpart: i64 = parse_int_span(buf, dot + 1, hi, 0);
    let den: i64 = nb_pow10(fk);
    let num: i64 = ipart * den + fpart;
    let q: i64 = nb_strip_pow5(num, fk);
    nb_ratio_to_f64_bits(q, fk)
}

// 1 iff 5^k divides `num` (num >= 0). Each step requires num divisible by 5; a
// single non-multiple means 5^k (k>=1) does not divide num. `num - (num/5)*5` is
// the integer remainder (no `%` dependency, matching nb_strip_pow5's `/` style).
pub fn nb_pow5_divides(num: i64, k: i64) -> i64 {
    if k <= 0 {
        return 1;
    }
    if num - (num / 5) * 5 != 0 {
        return 0;
    }
    nb_pow5_divides(num / 5, k - 1)
}

// 1 iff the decimal literal in [lo,hi) is EXACTLY a dyadic rational q * 2^-fk —
// i.e. 5^fk divides num = ipart*10^fk + fpart. nb_float_lit_bits is exact ONLY in
// that case; a non-dyadic literal (0.1, 3.14, 0.7 ...) truncates in
// nb_strip_pow5's integer /5 and yields SILENT wrong IEEE-754 bits (0.1 -> 0.0,
// 3.14 -> 3.0). Same parse as nb_float_lit_bits.
pub fn nb_float_lit_is_dyadic(buf: i64, lo: i64, hi: i64) -> i64 {
    let dot: i64 = nb_find_dot(buf, lo, hi);
    let ipart: i64 = parse_int_span(buf, lo, dot, 0);
    let fdigits: i64 = hi - (dot + 1);
    let fk: i64 = if fdigits < 0 {
        0
    } else {
        fdigits
    };
    let fpart: i64 = parse_int_span(buf, dot + 1, hi, 0);
    let den: i64 = nb_pow10(fk);
    let num: i64 = ipart * den + fpart;
    nb_pow5_divides(num, fk)
}

// C1 exactness guard, isolated selftest export: 1 iff the decimal literal (first 8
// bytes b0..b7, true byte length `len`) is exactly dyadic. Python oracle recomputes
// (ipart*10^fk + fpart) mod 5^fk == 0.
pub fn selftest_float_lit_dyadic(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64, b6: i64, b7: i64, len: i64) -> i64 {
    let buf: i64 = make_byte_buf_8(b0, b1, b2, b3, b4, b5, b6, b7);
    nb_float_lit_is_dyadic(buf, 0, len)
}

// End-to-end proof of the nb_expr float-selection arm: lex + parse a REAL float
// literal source, lower it through nb_expr (which now routes FLOAT through
// nb_fp_const_xmm + movsd-store to the value's stack slot), then load the slot back
// to xmm0 and cvttsd2si -> exit(trunc(value)). Driven through the REAL nb_expr path,
// not the fp encoders directly. Emits ZERO MLIR/LLVM; the CPU exit code is the
// oracle (no frozen float oracle can exist — the deleted Rust native rejected
// ConstF64). A bare float literal touches none of nb_expr's calls/lets/param
// scratch, so minimal empty allocations suffice.
pub fn selftest_native_elf_fp_expr(src_addr: i64, src_len: i64) -> EmitState {
    let toks: Vec = lex(src_addr, src_len);
    let pr: ParseResult = parse_primary(toks, 0, src_addr);
    let node: i64 = pr_node(pr);
    // rbp frame so [rbp+disp32] slots are addressable (the movsd store/load target).
    let p: String = nb_fp_prologue_frame(string_new(), 64);
    let params: i64 = __mind_alloc(8);
    let calls: i64 = __mind_alloc(8);
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // C2 return-width word (+72): full-width 64 on this hand-rolled driver path,
    // so nb_stmt's return arm reads a DEFINED no-op width, never adjacent-alloc
    // garbage (the lcell layout matches nb_lower_fn's 80-byte cell).
    __mind_store_i64(lcell + 72, 64);
    // RI-B1 FOLLOW-UP: no per-fn dtype table on the bare-expr path — store 0 at lcell+8
    // so nb_expr's binop arm falls back to the pure-AST classifier (behaviour unchanged).
    __mind_store_i64(lcell + 8, 0);
    let st0: NbState = NbState { code: p, next_id: 0, last_id: 0 - 1, ncalls: 0 };
    let s1: NbState = nb_expr(st0, src_addr, node, params, 0, calls, lets, lcell);
    // Read the float back out of its slot and truncate to i64 for exit(rax).
    let c1: String = nb_fp_movsd_load_xmm0(s1.code, nb_slot_disp(s1.last_id));
    let c2: String = nb_fp_trunc_rax_xmm0(c1);
    let code: String = nb_emit_return(c2, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// End-to-end proof of the nb_expr FLOAT-op-FLOAT arm: lex + parse a REAL float
// ARITHMETIC source (`1.5 + 2.5`) with parse_expr (pratt), then lower the WHOLE
// binop AST through nb_expr. Each float-literal operand routes the SSE2 const path
// into its own stack slot; the binop arm then loads lhs -> xmm0 (movsd), applies
// <op>sd xmm0,[rhs slot] (memory-operand binop, op selected by the arith operator),
// and spills the result -> the dst slot (movsd). The harness reads the dst slot back
// to xmm0 and cvttsd2si -> exit(trunc(a OP b)). Driven through the REAL nb_expr binop
// path, not the fp encoders directly. Emits ZERO MLIR/LLVM; the CPU exit code is the
// oracle (no frozen float oracle can exist — the deleted Rust native rejected
// ConstF64). A bare float arith expr touches none of nb_expr's calls/lets/param
// scratch, so minimal empty allocations suffice.
pub fn selftest_native_elf_fp_binop(src_addr: i64, src_len: i64) -> EmitState {
    let toks: Vec = lex(src_addr, src_len);
    let pr: ParseResult = parse_expr(toks, 0, src_addr);
    let node: i64 = pr_node(pr);
    // rbp frame so [rbp+disp32] slots are addressable (the movsd store/load target).
    let p: String = nb_fp_prologue_frame(string_new(), 64);
    let params: i64 = __mind_alloc(8);
    let calls: i64 = __mind_alloc(8);
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // C2 return-width word (+72): full-width 64 on this hand-rolled driver path,
    // so nb_stmt's return arm reads a DEFINED no-op width, never adjacent-alloc
    // garbage (the lcell layout matches nb_lower_fn's 80-byte cell).
    __mind_store_i64(lcell + 72, 64);
    // RI-B1 FOLLOW-UP: no per-fn dtype table on the bare-expr path — store 0 at lcell+8
    // so nb_expr's binop arm falls back to the pure-AST classifier (behaviour unchanged).
    __mind_store_i64(lcell + 8, 0);
    let st0: NbState = NbState { code: p, next_id: 0, last_id: 0 - 1, ncalls: 0 };
    let s1: NbState = nb_expr(st0, src_addr, node, params, 0, calls, lets, lcell);
    // Read the float result back out of its slot and truncate to i64 for exit(rax).
    let c1: String = nb_fp_movsd_load_xmm0(s1.code, nb_slot_disp(s1.last_id));
    let c2: String = nb_fp_trunc_rax_xmm0(c1);
    let code: String = nb_emit_return(c2, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// End-to-end proof of FLOAT dtype propagation ACROSS a LET binding (RI-B1 #107
// follow-up): lex + parse a REAL statement block (e.g. `{ let x = 1.5; x + 2.5 }`)
// with parse_block, then lower the WHOLE block through nb_block_stmts / nb_stmt /
// nb_expr with a REAL per-fn dtype table threaded at lcell+8 — exactly the plumbing
// nb_lower_fn uses. The `let` arm tags x's SSA slot FLOAT (its init `1.5` classifies
// FLOAT); the trailing `x + 2.5` binop then resolves `x` through the let-env, reads
// tbl[x_slot] = FLOAT, sees rhs `2.5` FLOAT, and routes the SSE2 f64 memory-operand
// encoders. The harness reads the result slot back to xmm0 and cvttsd2si ->
// exit(trunc(value)). Driven through the REAL statement-lowering path, not the fp
// encoders directly. Emits ZERO MLIR/LLVM; the CPU exit code is the oracle (no frozen
// float oracle can exist — the deleted Rust native rejected ConstF64). WITHOUT the
// dtype-table threading `x` would classify INT and the binop would take the GP-integer
// path, faulting or returning the wrong integer — so a correct exit is a non-fakeable
// proof the float dtype crossed the let.
pub fn selftest_native_elf_fp_let(src_addr: i64, src_len: i64) -> EmitState {
    let toks: Vec = lex(src_addr, src_len);
    let pr: ParseResult = parse_block(toks, 0, src_addr);
    let blk: i64 = pr_node(pr);
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    // rbp frame so [rbp+disp32] slots are addressable (the movsd store/load target).
    let p: String = nb_fp_prologue_frame(string_new(), 256);
    let params: i64 = __mind_alloc(8);
    let calls: i64 = __mind_alloc(8);
    let jmps: i64 = __mind_alloc(512 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // Per-fn let-env + real dtype table at lcell+8 (the nb_lower_fn plumbing).
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // C2 return-width word (+72): full-width 64 on this hand-rolled driver path,
    // so nb_stmt's return arm reads a DEFINED no-op width, never adjacent-alloc
    // garbage (the lcell layout matches nb_lower_fn's 80-byte cell).
    __mind_store_i64(lcell + 72, 64);
    __mind_store_i64(lcell + 8, nb_dtype_table_new(128));
    let srt: i64 = srt_build(src_addr, src_len);
    let loops: i64 = __mind_alloc(256 * 3 * 8);
    let lpcell: i64 = __mind_alloc(8);
    __mind_store_i64(lpcell, 0);
    let st0: NbState = NbState { code: p, next_id: 0, last_id: 0 - 1, ncalls: 0 };
    let sb: NbState = nb_block_stmts(st0, src_addr, stmts_addr, stmts_len, 0, params, 0, calls, 0, jmps, jcell, lets, lcell, srt, loops, lpcell);
    // Read the float result of the tail expr back out of its slot and truncate.
    let c1: String = nb_fp_movsd_load_xmm0(sb.code, nb_slot_disp(sb.last_id));
    let c2: String = nb_fp_trunc_rax_xmm0(c1);
    let code: String = nb_emit_return(c2, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// End-to-end proof of a FLOAT struct-FIELD READ through GENERAL lowering (RI-D2 S-D).
// Parse a REAL statement block that constructs a struct with an f64 field via a struct
// literal, binds it to a typed let, then reads the field into a float expression:
//   `{ let p: P = P { x: 3.5 }; p.x + 1.0 }` -> 4.5 -> exit(trunc)=4.
// Lower the WHOLE block through nb_block_stmts / nb_stmt / nb_expr (not a hand-emitted fp
// encoder): the `let` binds `p` to its struct-literal descriptor (nb_slit path), and the
// `p.x` field read hits nb_expr's ast_field arm where nb_field_dtype classifies the field
// FLOAT (its literal value `3.5`), so nb_field_read_fp loads it via movsd and tags the
// result slot FLOAT — nb_node_dtype_tbl's ast_field arm then sees `p.x` FLOAT and the
// binop `p.x + 1.0` routes the SSE2 f64 encoders. Read the tail result slot back to xmm0
// and cvttsd2si -> exit(trunc). Emits ZERO MLIR/LLVM; the CPU exit code is the oracle (no
// frozen float oracle exists — Rust native rejected ConstF64). Without the S-D field-dtype
// classification `p.x` would classify INT, take the GP-integer field load, and the trunc
// of the mis-interpreted bits would fault or return the wrong exit — so a correct exit is
// non-fakeable. A MIXED struct (int + float fields) reading its float field proves the
// per-field dtype + offset. Same nb_block_stmts / lcell+8 dtype-table plumbing as fp_let.
pub fn selftest_native_elf_fp_field(src_addr: i64, src_len: i64) -> EmitState {
    let toks: Vec = lex(src_addr, src_len);
    let pr: ParseResult = parse_block(toks, 0, src_addr);
    let blk: i64 = pr_node(pr);
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    let p: String = nb_fp_prologue_frame(string_new(), 256);
    let params: i64 = __mind_alloc(8);
    let calls: i64 = __mind_alloc(8);
    let jmps: i64 = __mind_alloc(512 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // C2 return-width word (+72): full-width 64 on this hand-rolled driver path,
    // so nb_stmt's return arm reads a DEFINED no-op width, never adjacent-alloc
    // garbage (the lcell layout matches nb_lower_fn's 80-byte cell).
    __mind_store_i64(lcell + 72, 64);
    __mind_store_i64(lcell + 8, nb_dtype_table_new(128));
    let srt: i64 = srt_build(src_addr, src_len);
    let loops: i64 = __mind_alloc(256 * 3 * 8);
    let lpcell: i64 = __mind_alloc(8);
    __mind_store_i64(lpcell, 0);
    let st0: NbState = NbState { code: p, next_id: 0, last_id: 0 - 1, ncalls: 0 };
    let sb: NbState = nb_block_stmts(st0, src_addr, stmts_addr, stmts_len, 0, params, 0, calls, 0, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let c1: String = nb_fp_movsd_load_xmm0(sb.code, nb_slot_disp(sb.last_id));
    let c2: String = nb_fp_trunc_rax_xmm0(c1);
    let code: String = nb_emit_return(c2, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-D2 S-B harness: FLOAT fn-param dtype + SysV SSE-spill ABI ----------
// These prove a FLOAT parameter flows through general nb_expr lowering (not a
// hand-emitted fp selftest): a real parsed `fn f(x: f64) -> f64 { x + 2.5 }` is
// lowered through nb_emit_params (the two-pool SSE/GP spill ABI) + nb_block_stmts
// / nb_expr (the classifier resolves the param ident FLOAT and routes the SSE2
// encoders). All NEW exports, never reached during self-compile.

// movabs into the gp_k-th SysV GP arg register (rdi/rsi/rdx/rcx/r8/r9): a known
// int, staging the caller side of an integer param so nb_emit_params has a defined
// value to spill. (0x48 | REX.B) (0xB8 + reg&7) <imm64>.
pub fn nb_fp_stage_gp(code: String, gp_k: i64, val: i64) -> String {
    let reg: i64 = nb_argreg_field(gp_k);
    let ext: i64 = nb_argreg_ext(gp_k);
    let rex: i64 = 72 + ext;
    let op: i64 = 184 + (reg & 7);
    let c1: String = nb_push(code, rex);
    let c2: String = nb_push(c1, op);
    nb_i64le(c2, val)
}

// Known IEEE-754 double bit-patterns staged into the SSE arg registers, keyed by SSE
// index: sse0 -> 3.5 (0x400C000000000000), sse1 -> 2.0 (0x4000000000000000). Chosen so
// every fixture's result is an exactly-representable dyadic whose trunc fits a byte.
pub fn nb_fp_known_double(sse_k: i64) -> i64 {
    if sse_k == 0 {
        return 4615063718147915776;
    }
    4611686018427387904
}

// Stage the SysV arg registers with KNOWN fixture values (the caller side): float
// params -> xmm{sse_k} (known double), int params -> the gp_k-th GP arg reg (known
// int). Walks the SAME gp_k/sse_k progression nb_emit_params uses, so the two agree on
// which register each param arrives in — a wrong-pool ABI split then reads a garbage
// register and the run faults / returns a wrong exit (non-fakeable).
pub fn nb_fp_param_stage(code: String, buf: i64, params_addr: i64, n_params: i64, i: i64, gp_k: i64, sse_k: i64) -> String {
    if i >= n_params {
        return code;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    if nb_param_is_float(buf, ast_child1(pnode)) == nb_dtype_float() {
        let cf: String = nb_fp_const_xmm(code, nb_fp_known_double(sse_k), sse_k);
        return nb_fp_param_stage(cf, buf, params_addr, n_params, i + 1, gp_k, sse_k + 1);
    }
    let ci: String = nb_fp_stage_gp(code, gp_k, 42);
    nb_fp_param_stage(ci, buf, params_addr, n_params, i + 1, gp_k + 1, sse_k)
}

// End-to-end proof of a FLOAT fn-param through GENERAL lowering (RI-D2 S-B). Parse a
// real `fn f(x: f64) -> f64 { x + 2.5 }` (first item), stage its args into the SysV
// registers, spill them via nb_emit_params (the two-pool SSE/GP ABI half), tag the
// float param slots FLOAT via nb_tag_float_params (the classifier half), then lower the
// body through nb_block_stmts / nb_expr — where the binop arm consults the dtype table,
// sees the param FLOAT (nb_node_dtype_tbl's resolve_param branch), and routes the SSE2
// encoders. Read the result slot back to xmm0 and cvttsd2si -> exit(trunc). Emits ZERO
// MLIR/LLVM; the CPU exit code is the oracle (no frozen float oracle exists — Rust
// native rejected ConstF64). A wrong register-file/pool choice or a mis-classified param
// faults or returns the wrong integer, so a correct exit is non-fakeable.
pub fn selftest_native_elf_fp_param(src_addr: i64, src_len: i64) -> EmitState {
    let toks: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(toks, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let fndef: i64 = __mind_load_i64(items_addr);
    let params_addr: i64 = ast_child1(fndef);
    let n_params: i64 = ast_aux(fndef) / 2;
    let body: i64 = ast_child2(fndef);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);

    // rbp frame so [rbp+disp32] slots are addressable (movsd store/load target).
    let p: String = nb_fp_prologue_frame(string_new(), 256);
    // Caller side: place the known arg values into the SysV registers ...
    let staged: String = nb_fp_param_stage(p, src_addr, params_addr, n_params, 0, 0, 0);
    // ... ABI half: spill each arg register into its param slot (two-pool split).
    let st_params: NbState = NbState { code: staged, next_id: n_params, last_id: 0 - 1, ncalls: 0 };
    let st_p: NbState = nb_emit_params(st_params, src_addr, params_addr, n_params, 0, 0, 0);

    // Per-fn let-env + dtype table (the nb_lower_fn plumbing). Classifier half: tag
    // each float param slot FLOAT so a param ident routes the SSE2 path.
    let calls: i64 = __mind_alloc(8);
    let jmps: i64 = __mind_alloc(512 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // C2 return-width word (+72): full-width 64 on this hand-rolled driver path,
    // so nb_stmt's return arm reads a DEFINED no-op width, never adjacent-alloc
    // garbage (the lcell layout matches nb_lower_fn's 80-byte cell).
    __mind_store_i64(lcell + 72, 64);
    let dtbl: i64 = nb_dtype_table_new(128);
    __mind_store_i64(lcell + 8, dtbl);
    let _tfp: i64 = nb_tag_float_params(dtbl, src_addr, params_addr, n_params, 0);
    let srt: i64 = srt_build(src_addr, src_len);
    let loops: i64 = __mind_alloc(256 * 3 * 8);
    let lpcell: i64 = __mind_alloc(8);
    __mind_store_i64(lpcell, 0);

    // Lower the body through the REAL statement-lowering path.
    let sb: NbState = nb_block_stmts(st_p, src_addr, stmts_addr, stmts_len, 0, params_addr, n_params, calls, 0, jmps, jcell, lets, lcell, srt, loops, lpcell);
    // Read the float result of the tail expr back out of its slot and truncate.
    let c1: String = nb_fp_movsd_load_xmm0(sb.code, nb_slot_disp(sb.last_id));
    let c2: String = nb_fp_trunc_rax_xmm0(c1);
    let code: String = nb_emit_return(c2, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-D2 S-C1: fn return-type registry (frt) ----------------------------------
// A whole-module registry mapping each `fn NAME ( ... ) -> RETTYPE {` to its declared
// return dtype (FLOAT for f64/f32, else INT), built by re-lexing the source exactly
// like srt_build builds the struct registry. It answers ONE question at a call site:
// "does the callee return a float?" — so a call's result is spilled from the correct
// SysV register file (xmm0 for float, rax otherwise) and classified for downstream
// float propagation. Requiring the trailing body `{` after RETTYPE means `;`-terminated
// extern declarations (e.g. std's `unsafe fn ...-> f64;`) are NOT recorded as float —
// they have no body and are never lowered on the native path. main.mind's own source
// has zero float-returning fns (its `-> f64` matches are all in `//` comments the lexer
// strips), so every fn registers INT and this registry is inert for self-compile.

pub fn frt_cap() -> i64 {
    4096
}

// Words per fn slot: name_lo + name_hi + ret_is_float + ret_width (C2 driver;
// 64 default, 8/16/32 only for a declared `-> i8/i16/i32 {` return).
pub fn frt_slot_words() -> i64 {
    4
}

pub fn frt_alloc() -> i64 {
    let t: i64 = __mind_alloc((1 + frt_cap() * frt_slot_words()) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn frt_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

pub fn frt_slot_base(k: i64) -> i64 {
    1 + k * frt_slot_words()
}

pub fn frt_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (frt_slot_base(k) + 0) * 8)
}

pub fn frt_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (frt_slot_base(k) + 1) * 8)
}

pub fn frt_ret(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (frt_slot_base(k) + 2) * 8)
}

// The fn's declared return WIDTH (C2 driver): 64 for i64/unit/float/anything
// else, 8/16/32 only for an explicit narrow-int return annotation.
pub fn frt_retw(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (frt_slot_base(k) + 3) * 8)
}

// Append a fn with name span (nlo, nhi), return-dtype `ret_dt`, and declared
// return width `retw`. Overflow no-ops.
pub fn frt_push(t: i64, nlo: i64, nhi: i64, ret_dt: i64, retw: i64) -> i64 {
    let n: i64 = frt_count(t);
    if n >= frt_cap() {
        return n;
    }
    __mind_store_i64(t + (frt_slot_base(n) + 0) * 8, nlo);
    __mind_store_i64(t + (frt_slot_base(n) + 1) * 8, nhi);
    __mind_store_i64(t + (frt_slot_base(n) + 2) * 8, ret_dt);
    __mind_store_i64(t + (frt_slot_base(n) + 3) * 8, retw);
    __mind_store_i64(t + 0, n + 1);
    n
}

// Classify a return-type span (lo, hi) as FLOAT (f64/f32) or INT, span-keyed (the
// value-side twin of nb_param_is_float, which takes a type-leaf AST node). bytes
// f=102, 6=54, 4=52, 3=51, 2=50, so "f64"=[102,54,52] and "f32"=[102,51,50].
pub fn frt_ret_is_float(buf: i64, lo: i64, hi: i64) -> i64 {
    let f64_buf: i64 = make_byte_buf_3(102, 54, 52);
    if bytes_eq(buf, lo, hi, f64_buf, 0, 3) == 1 {
        return nb_dtype_float();
    }
    let f32_buf: i64 = make_byte_buf_3(102, 51, 50);
    if bytes_eq(buf, lo, hi, f32_buf, 0, 3) == 1 {
        return nb_dtype_float();
    }
    nb_dtype_int()
}

// From the token AFTER a fn's name, scan forward to the signature's return-type. Stops
// at the first `{` (a body brace with no preceding `->` = a unit return -> INT) or the
// first `->` (arrow). At the arrow: RETTYPE is the next token and the body `{` must
// follow it — `-> f64 {` records FLOAT; `-> TYPE ;` (extern, no body) or a multi-token
// type (RETTYPE not immediately followed by `{`) records INT. Params in this subset are
// `name: type` pairs with no braces/arrows, so the first arrow/brace found is the
// signature's. Tail-recursive (self-host subset, no while).
pub fn frt_scan_ret(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return nb_dtype_int();
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return nb_dtype_int();
    }
    if k == tk_arrow() {
        if tok_kind(toks, pos + 2) == tk_lbrace() {
            return frt_ret_is_float(buf, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1));
        }
        return nb_dtype_int();
    }
    frt_scan_ret(toks, buf, pos + 1)
}

// Classify a return-type span (lo, hi) as a declared int bit-width: "i8" -> 8,
// "i16" -> 16, "i32" -> 32, anything else -> 64 (the full-width default) — the
// span-keyed twin of nb_width_of_ann (which takes a type-leaf AST node). bytes:
// i=105, 8=56, 1=49, 6=54, 3=51, 2=50.
pub fn frt_ret_width(buf: i64, lo: i64, hi: i64) -> i64 {
    let i8_buf: i64 = make_byte_buf_3(105, 56, 0);
    if bytes_eq(buf, lo, hi, i8_buf, 0, 2) == 1 {
        return 8;
    }
    let i16_buf: i64 = make_byte_buf_3(105, 49, 54);
    if bytes_eq(buf, lo, hi, i16_buf, 0, 3) == 1 {
        return 16;
    }
    let i32_buf: i64 = make_byte_buf_3(105, 51, 50);
    if bytes_eq(buf, lo, hi, i32_buf, 0, 3) == 1 {
        return 32;
    }
    64
}

// The width twin of frt_scan_ret: from the token AFTER a fn's name, scan to the
// signature's return type and classify its declared int WIDTH. Same stop rules —
// a body `{` with no `->` (unit return), an extern `;`, or a multi-token type all
// record 64, the full-width default that emits nothing. Tail-recursive.
pub fn frt_scan_retw(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 64;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return 64;
    }
    if k == tk_arrow() {
        if tok_kind(toks, pos + 2) == tk_lbrace() {
            return frt_ret_width(buf, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1));
        }
        return 64;
    }
    frt_scan_retw(toks, buf, pos + 1)
}

// Scan the token stream, recording every `fn NAME (...) -> RETTYPE {` def and its
// return dtype. `fn` is a dedicated keyword token (tk_kw_fn), and the name is always the
// next token (`pub fn NAME` yields kw_pub, kw_fn, NAME, so pos+1 is the name in both the
// `fn` and `pub fn` forms). Advancing one token at a time is safe — a fn keyword only
// appears at a def. Tail-recursive.
pub fn frt_collect(toks: Vec, buf: i64, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_kw_fn() {
        let ret_dt: i64 = frt_scan_ret(toks, buf, pos + 2);
        let retw: i64 = frt_scan_retw(toks, buf, pos + 2);
        let _p: i64 = frt_push(t, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1), ret_dt, retw);
        return frt_collect(toks, buf, pos + 1, t);
    }
    frt_collect(toks, buf, pos + 1, t)
}

// Build (and return) a fresh return-type registry covering every fn def in `src`.
pub fn frt_build(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = frt_alloc();
    frt_collect(tokens, src_addr, 0, t)
}

// RI-D2 S-C1 fix: build the registry from an ALREADY-lexed token stream, avoiding a
// redundant full-source lex. The native-ELF program's heap is a FIXED 1 GiB bump arena
// with no free (nb_arena_bytes), so each full-source lex of the ~1.75 MB self-host source
// permanently retains its (doubling-reallocated) token Vec. Re-lexing in frt_build was the
// 4th such lex on the whole-compiler path and tipped the arena past 1 GiB, so the native
// stage1 segfaulted while compiling the full source (the .so, on the unlimited system
// allocator, never hits the cap — which is why the LLVM gates stayed green). Reusing the
// caller's tokens yields the byte-identical registry (same struct/return content) with one
// fewer arena-resident lex. src_addr is still the byte source the spans key into.
pub fn frt_build_from_tokens(tokens: Vec, src_addr: i64) -> i64 {
    let t: i64 = frt_alloc();
    frt_collect(tokens, src_addr, 0, t)
}

// Find the fn whose NAME span equals src[lo..hi), or -1. Tail-recursive.
pub fn frt_find(t: i64, src: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= frt_count(t) {
        return 0 - 1;
    }
    if span_bytes_equal(src, lo, hi, frt_name_lo(t, k), frt_name_hi(t, k)) == 1 {
        return k;
    }
    frt_find(t, src, lo, hi, k + 1)
}

// The callee's declared return dtype for the name span src[lo..hi): FLOAT iff the fn is
// registered f64/f32-returning, else INT. A null registry (t == 0) or an unregistered
// callee (e.g. an intrinsic, or a fn defined outside the scanned buffer) resolves to
// INT — the safe default that keeps the integer/pointer call path unchanged.
pub fn frt_lookup_dtype(t: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if t == 0 {
        return nb_dtype_int();
    }
    let k: i64 = frt_find(t, src, lo, hi, 0);
    if k < 0 {
        return nb_dtype_int();
    }
    frt_ret(t, k)
}

// The fn's declared return WIDTH for the name span src[lo..hi): 8/16/32 for a
// narrow-int-returning fn, else 64. A null registry or an unregistered name
// resolves to 64 — the safe full-width default that emits nothing.
pub fn frt_lookup_width(t: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if t == 0 {
        return 64;
    }
    let k: i64 = frt_find(t, src, lo, hi, 0);
    if k < 0 {
        return 64;
    }
    frt_retw(t, k)
}

// ---- RI-D2 S-C1 selftest: FLOAT call-RETURN dtype through native-ELF -------------
// Proves a call to an f64-returning fn spills its result from xmm0 (SysV) and tags it
// FLOAT so a downstream expr routes the SSE2 path — end to end through the GENERAL
// nb_expr call arm + nb_lower_all + inter-fn rel32 patching (not a hand-emitted fp
// stub). The fixture source declares >=2 fns (a float-returning callee `g` plus a
// caller that consumes `g()` in a float expr); the LAST fn is the caller. A synthesized
// entry stub sets rsp, calls the caller (rel32), truncates its xmm0 result to rax, and
// exits — so the process exit code == trunc(value), the non-fakeable execution oracle
// (a wrong rax-vs-xmm0 spill, a missing tag, or a wrong callee-return register faults or
// returns the wrong integer). No frozen byte oracle exists for native-ELF float — the
// deleted Rust native backend rejected ConstF64 — so the CPU exit code is the oracle.
pub fn selftest_native_elf_fp_call(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);

    // Collect every fn in source order (single file -> every fn is a root, no prune).
    let ordered: i64 = __mind_alloc((items_len + 1) * 8);
    let n_fns: i64 = nb_collect_fns(items_addr, items_len, 0, ordered, 0);

    // Whole-module registries (struct-field + return-type).
    let srt: i64 = srt_build(src_addr, src_len);
    let frt: i64 = frt_build(src_addr, src_len);

    // calls scratch table (one 3-i64 record per call site; +2 slack for our entry call).
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    let n_calls: i64 = nb_count_all_calls(src_addr, ordered, n_fns, 0, ccell);
    let calls: i64 = __mind_alloc((n_calls + 2) * 3 * 8);
    let starts: i64 = __mind_alloc((n_fns + 1) * 8);
    let call_owner: i64 = __mind_alloc((n_calls + 2) * 8);

    // Lower every fn as NON-entry (entry_idx = -1) into one image; f -> g calls recorded.
    let acc0: NbState = NbState { code: string_new(), next_id: 0, last_id: 0, ncalls: 0 };
    let lr: NbState = nb_lower_all(acc0, src_addr, ordered, n_fns, 0, calls, starts, call_owner, 0 - 1, srt, frt, 0);
    let body_image: String = lr.code;
    let total_calls: i64 = lr.ncalls;

    // Synthesized runnable entry at image offset 0:
    //   movabs rsp, STACK_TOP ; call <caller> (rel32 placeholder) ; cvttsd2si rax,xmm0 ;
    //   mov rdi,rax ; mov rax,60 ; syscall  (exit(trunc(caller's float result))).
    let e0: String = string_new();
    let e1: String = nb_push(e0, 72);
    let e2: String = nb_push(e1, 188);
    let e3: String = nb_i64le(e2, nb_stack_top());
    let e4: String = nb_push(e3, 232);
    let entry_call_site: i64 = string_len(e4);
    let e5: String = nb_u32(e4, 0);
    let e6: String = nb_fp_trunc_rax_xmm0(e5);
    let entry: String = nb_emit_return(e6, 1);
    let entry_len: i64 = string_len(entry);

    // image = [entry][fn0..fnN]; shift each fn start past the entry stub, then link.
    let _sh: i64 = nb_shift_starts(starts, n_fns, entry_len, 0);
    let image: String = string_push_str(entry, body_image);
    let code_addr: i64 = string_addr(image);

    // fn_names for callee resolution, then patch every inter-fn rel32 (f -> g).
    let fn_names: i64 = __mind_alloc((n_fns + 1) * 2 * 8);
    let _fn: i64 = nb_fill_names(ordered, n_fns, 0, fn_names);
    let _p: i64 = nb_patch_all(code_addr, calls, total_calls, call_owner, starts, fn_names, n_fns, src_addr, 0);

    // Patch the entry's `call <caller>` rel32: the caller is the LAST fn (it consumes g()).
    let caller_idx: i64 = n_fns - 1;
    let caller_start: i64 = __mind_load_i64(starts + caller_idx * 8);
    let rel: i64 = caller_start - (entry_call_site + 4);
    let _pe: i64 = nb_patch_rel32(code_addr, entry_call_site, rel);

    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(image, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-B2-S1 (#108): scalar i64 dot-product reduction native-ELF ----
// The first rung of the tensor/BLAS native-ELF ladder — the RI-B2 analogue of
// RI-B1's "float literal before a float binop": it proves the streaming-
// reduction-OVER-MEMORY path end to end (a counted `while i < n` loop that
// indexes two in-memory i64 arrays, multiplies element-wise, and accumulates)
// with PURE REUSE — it COMPOSES the existing nb_* emitters and adds NO new
// encoder. The two length-`n` arrays are baked into the entry stack frame as
// movabs immediates (the fixtures are known at emit time); the loop then
// re-derives each element ADDRESS at runtime (`base + i*8`) so the actual
// per-element memory load/index/reduce is exercised, not folded away. The final
// accumulator is returned as the process exit code (fixtures are chosen so the
// dot fits in a byte, 0..255).
//
// ADDITIVITY: this is a NEW export, NEVER reached during self-compile (main.mind
// does not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. There is NO frozen byte oracle
// for this path yet — the deleted Rust native backend never emitted a dot-product
// entry, and byte-identity vs the MLIR canary is a LATER slice (RI-B2-S3). The
// gate here is EXECUTION CORRECTNESS: emit the ELF, run it, assert exit == the
// exact Sum a[i]*b[i]. A wrong index/mul/accumulate/loop-bound faults or returns a
// wrong exit, so a correct exit is a non-fakeable proof the reduction lowered.

// movabs rax, val ; mov [rbp+disp], rax  (materialize an i64 immediate into a slot).
pub fn nb_intdot_movimm(code: String, val: i64, disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, val);
    nb_store_rax(c3, disp)
}

// Bake array `vals_addr[0..n]` into the frame ascending from `base_disp`
// (element i at [rbp + base_disp + 8*i]). Recursive (self-host subset), one
// movabs+store per element. Values are read at EMIT time from the caller's
// in-memory fixture array.
pub fn nb_intdot_store_arr(code: String, vals_addr: i64, base_disp: i64, i: i64, n: i64) -> String {
    if i >= n {
        return code;
    }
    let v: i64 = __mind_load_i64(vals_addr + i * 8);
    let c1: String = nb_intdot_movimm(code, v, base_disp + 8 * i);
    nb_intdot_store_arr(c1, vals_addr, base_disp, i + 1, n)
}

// lea rax, [rbp+src_disp] ; mov [rbp+dst_disp], rax  (materialize the RUNTIME
// absolute base address of an in-frame array into a pointer slot, so the loop can
// form `base + i*8`).
pub fn nb_intdot_lea(code: String, src_disp: i64, dst_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 141);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, src_disp);
    nb_store_rax(c4, dst_disp)
}

// One element load: addr = i*8 + base ; ptr_slot = addr ; out_slot = *addr.
// EXPLICIT per-element addressing — nb_emit_load_i64 is register-indirect [rax]
// only (it does NOT index), so the element address is computed first with the
// existing integer mul+add memory-operand ops into `ptr_disp`, loaded back as the
// pointer, then dereferenced.
pub fn nb_intdot_load_elem(code: String, base_disp: i64, ptr_disp: i64, out_disp: i64, i_disp: i64, eight_disp: i64) -> String {
    let c1: String = nb_load_rax(code, i_disp);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), eight_disp);
    let c3: String = nb_arith_rax_mem(c2, op_add(), base_disp);
    let c4: String = nb_store_rax(c3, ptr_disp);
    let c5: String = nb_emit_load_i64(c4, ptr_disp);
    nb_store_rax(c5, out_disp)
}

// selftest_native_elf_intdot(a_addr, b_addr, n): emit a runnable ET_EXEC that
// computes acc = Sum a[i]*b[i] over the two length-`n` i64 fixture arrays (baked
// in from a_addr/b_addr) and exit(acc). a_addr/b_addr point at the caller's
// in-memory i64 arrays; n is the shared length.
pub fn selftest_native_elf_intdot(a_addr: i64, b_addr: i64, n: i64) -> EmitState {
    // Frame slot map (all rbp-relative, within a 4096-byte frame):
    //   i=-8  eight=-16  n=-24  acc=-32  ptr=-40  aval=-48  bval=-56
    //   prod=-64  one=-72  cond=-80  baseA=-88  baseB=-96
    //   array A region base = -1024 (A[i] at -1024+8i), array B base = -512.
    let p0: String = nb_fp_prologue_frame(string_new(), 4096);
    // Bake both fixture arrays into the frame (ascending, so base + i*8 indexes them).
    let p1: String = nb_intdot_store_arr(p0, a_addr, 0 - 1024, 0, n);
    let p2: String = nb_intdot_store_arr(p1, b_addr, 0 - 512, 0, n);
    // Constants: eight=8, n, i=0, acc=0, one=1.
    let k1: String = nb_intdot_movimm(p2, 8, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, n, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 0, 0 - 8);
    let k4: String = nb_intdot_movimm(k3, 0, 0 - 32);
    let k5: String = nb_intdot_movimm(k4, 1, 0 - 72);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k5, 0 - 1024, 0 - 88);
    let bb: String = nb_intdot_lea(ba, 0 - 512, 0 - 96);
    // Loop scaffold (mirror nb_emit_while's byte-level structure).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // header = back-edge target.
    let header: i64 = string_len(bb);
    // cond: rax=i ; (i < n) -> 0/1 ; store cond.
    let cc1: String = nb_load_rax(bb, 0 - 8);
    let cc2: String = nb_cmp_rax_mem(cc1, nb_setcc_opcode(op_lt()), 0 - 24);
    let cc3: String = nb_store_rax(cc2, 0 - 80);
    // cmp qword [cond],0 ; je exit(rel32 patched).
    let cj: String = nb_emit_cmp_je_zero(cc3, 0 - 80, jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    // body: aval = a[i] ; bval = b[i] ; prod = aval*bval ; acc += prod ; i += 1.
    let bd1: String = nb_intdot_load_elem(cj, 0 - 88, 0 - 40, 0 - 48, 0 - 8, 0 - 16);
    let bd2: String = nb_intdot_load_elem(bd1, 0 - 96, 0 - 40, 0 - 56, 0 - 8, 0 - 16);
    let bd3: String = nb_load_rax(bd2, 0 - 48);
    let bd4: String = nb_arith_rax_mem(bd3, op_mul(), 0 - 56);
    let bd5: String = nb_store_rax(bd4, 0 - 64);
    let bd6: String = nb_load_rax(bd5, 0 - 32);
    let bd7: String = nb_arith_rax_mem(bd6, op_add(), 0 - 64);
    let bd8: String = nb_store_rax(bd7, 0 - 32);
    let bd9: String = nb_load_rax(bd8, 0 - 8);
    let bd10: String = nb_arith_rax_mem(bd9, op_add(), 0 - 72);
    let bd11: String = nb_store_rax(bd10, 0 - 8);
    // back-edge: jmp header (target known now, patched below).
    let jb: String = nb_emit_jmp(bd11, jmps, jcell);
    let back_which: i64 = __mind_load_i64(jcell) - 1;
    let _pb: i64 = nb_jmp_set_target(jmps, jcell, back_which, header);
    // end: patch the je-exit here.
    let end_at: i64 = string_len(jb);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, end_at);
    // load acc into rax ; exit(acc).
    let r1: String = nb_load_rax(jb, 0 - 32);
    let code: String = nb_emit_return(r1, 1);
    // Patch every recorded intra-fn jump in place before wrapping (entry_off = 0,
    // so fn-relative sites == code-relative).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S2 (#108) — native-ELF scalar int16 DOT-PRODUCT, the FIRST byte-identity
// gated tensor rung. Two exports:
//   selftest_native_elf_write8   — Step A: proves the __mind_write "emit 8 LE
//                                  bytes to stdout" harness on a KNOWN i64.
//   selftest_native_elf_intdot_i16 — Step B: the int16 dot, gated byte-for-byte
//                                  against the MLIR canary dot-i16-4096.
// Both are NEW exports never reached during self-compile, so the integer native-
// ELF oracle stays byte-identical (additivity).
// ============================================================================

// STEP A: emit an ET_EXEC that writes the 8 LITTLE-ENDIAN bytes of `val` to
// stdout (fd 1) via the raw write(2) syscall, then exit(0). De-risks the C1
// gate: a Python smoke captures stdout and asserts sha256 over those 8 bytes is
// stable and equals sha256(struct.pack('<q', val)). Proves (a) __mind_write
// emits a buffer to fd 1, (b) the byte order is LE, (c) sha256-over-stdout is
// deterministic — the exact mechanism Step B's canary gate relies on.
//   Frame slots: result=-16 (the 8-byte buffer), bufaddr=-24 (&result),
//   fd=-32, count=-40, zero=-48.
pub fn selftest_native_elf_write8(val: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 256);
    let k1: String = nb_intdot_movimm(p0, val, 0 - 16);
    let la: String = nb_intdot_lea(k1, 0 - 16, 0 - 24);
    let k2: String = nb_intdot_movimm(la, 1, 0 - 32);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 40);
    let w1: String = nb_emit_write(k3, 0 - 32, 0 - 24, 0 - 40);
    let z1: String = nb_intdot_movimm(w1, 0, 0 - 48);
    let r1: String = nb_load_rax(z1, 0 - 48);
    let code: String = nb_emit_return(r1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// One generation-loop body iteration: advance the LCG one draw and store the
// int16 element to memory[base + i*8] (stored as 8 bytes; only the low 2 hold
// the element — the int16 packing is realised by the movsx WORD load in the dot
// loop). base_d is a slot holding the runtime base address of the target array.
//   state = state*1664525 + 1013904223 ; val = state >> 32 (low 16 = element) ;
//   ptr = base + i*8 ; *ptr = val ; i += 1.
// Slot map (rbp-relative): state=-65544 mul=-65552 addc=-65560 i=-65568
//   eight=-65584 sh32=-65600 ptr=-65616 val=-65624 one=-65680.
pub fn nb_i16gen_body(code: String, base_d: i64) -> String {
    let a1: String = nb_load_rax(code, 0 - 65544);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 65552);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 65560);
    let a4: String = nb_store_rax(a3, 0 - 65544);
    let b1: String = nb_load_rax(a4, 0 - 65544);
    let b2: String = nb_arith_rax_mem(b1, op_shr(), 0 - 65600);
    let b3: String = nb_store_rax(b2, 0 - 65624);
    let c1: String = nb_load_rax(b3, 0 - 65568);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 65584);
    let c3: String = nb_arith_rax_mem(c2, op_add(), base_d);
    let c4: String = nb_store_rax(c3, 0 - 65616);
    let d1: String = nb_emit_store_i64(c4, 0 - 65616, 0 - 65624);
    let e1: String = nb_load_rax(d1, 0 - 65568);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 65680);
    nb_store_rax(e2, 0 - 65568)
}

// One dot-loop body iteration: aval = movsx word a[i] ; bval = movsx word b[i] ;
// prod = aval*bval (i64) ; acc += prod ; i += 1. THE int16 rung: each element is
// sign-extended from memory via nb_emit_load_i16_sx before the exact i64 MAC.
//   baseA=-65664 baseB=-65672 aval=-65632 bval=-65640 prod=-65648 acc=-65608.
pub fn nb_i16dot_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 65568);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 65584);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 65664);
    let a4: String = nb_store_rax(a3, 0 - 65616);
    let a5: String = nb_emit_load_i16_sx(a4, 0 - 65616);
    let a6: String = nb_store_rax(a5, 0 - 65632);
    let b1: String = nb_load_rax(a6, 0 - 65568);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 65584);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 65672);
    let b4: String = nb_store_rax(b3, 0 - 65616);
    let b5: String = nb_emit_load_i16_sx(b4, 0 - 65616);
    let b6: String = nb_store_rax(b5, 0 - 65640);
    let c1: String = nb_load_rax(b6, 0 - 65632);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 65640);
    let c3: String = nb_store_rax(c2, 0 - 65648);
    let d1: String = nb_load_rax(c3, 0 - 65608);
    let d2: String = nb_arith_rax_mem(d1, op_add(), 0 - 65648);
    let d3: String = nb_store_rax(d2, 0 - 65608);
    let e1: String = nb_load_rax(d3, 0 - 65568);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 65680);
    nb_store_rax(e2, 0 - 65568)
}

// STEP B: emit an ET_EXEC that (1) generates a[0..n] then b[0..n] via the EXACT
// LCG (seed 0xDEADBEEF, state=state*1664525+1013904223, element=(state>>32) low
// 16 as i16) into two in-frame int16 arrays, (2) computes acc = Sum sext(a[i]) *
// sext(b[i]) with a full i64 accumulator, (3) narrows ONCE to i32 (movsxd — the
// MLIR canary's `acc as i32`), (4) writes the 8 LE bytes of the result to stdout.
// The reduction model was resolved empirically: the dot-i16-4096 gate hashes the
// i64 sign-extension of the i32-narrowed sum (NOT the full i64 sum, NOT an i32
// pairwise-wrap). n is baked at emit time (the canary uses 4096).
//   A array base = -65536 (A[i] at -65536+8i), B base = -32768. Scratch below
//   -65536. Frame 73728 holds both 4096-element arrays plus scratch.
pub fn selftest_native_elf_intdot_i16(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 73728);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 65552);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 65560);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 65584);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 65680);
    let k5: String = nb_intdot_movimm(k4, 32, 0 - 65600);
    let k6: String = nb_intdot_movimm(k5, 3735928559, 0 - 65544);
    let k7: String = nb_intdot_movimm(k6, 0, 0 - 65608);
    let k8: String = nb_intdot_movimm(k7, n, 0 - 65576);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 65536, 0 - 65664);
    let bb: String = nb_intdot_lea(ba, 0 - 32768, 0 - 65672);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- generate A[0..n] (base slot -65664) ---
    let ga0: String = nb_intdot_movimm(bb, 0, 0 - 65568);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 65568);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let gac3: String = nb_store_rax(gac2, 0 - 65656);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 65656, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_i16gen_body(gacj, 0 - 65664);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..n] (base slot -65672), LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 65568);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 65568);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let gbc3: String = nb_store_rax(gbc2, 0 - 65656);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 65656, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_i16gen_body(gbcj, 0 - 65672);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    // --- dot loop: acc = Sum sext(a[i]) * sext(b[i]) ---
    let d0: String = nb_intdot_movimm(gbjb, 0, 0 - 65568);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 65568);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let dc3: String = nb_store_rax(dc2, 0 - 65656);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 65656, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_i16dot_body(dcj);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Narrow ONCE to i32 and sign-extend to i64 (the canary's `acc as i32`).
    let t1: String = nb_load_rax(djb, 0 - 65608);
    let t2: String = nb_movsxd_rax_eax(t1);
    let t3: String = nb_store_rax(t2, 0 - 65688);
    // write(1, &result, 8).
    let t4: String = nb_intdot_lea(t3, 0 - 65688, 0 - 65704);
    let t5: String = nb_intdot_movimm(t4, 1, 0 - 65696);
    let t6: String = nb_intdot_movimm(t5, 8, 0 - 65712);
    let t7: String = nb_emit_write(t6, 0 - 65696, 0 - 65704, 0 - 65712);
    // exit(0).
    let t8: String = nb_intdot_movimm(t7, 0, 0 - 65720);
    let t9: String = nb_load_rax(t8, 0 - 65720);
    let code: String = nb_emit_return(t9, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S4 (#108) — native-ELF scalar Q16.16 fixed-point DOT-PRODUCT, byte-
// identical to the MLIR canary dot-l2-q16 (len 65536, seed 0xDEADBEEF). Reuses
// the S2 harness (LCG runtime-gen + i64 MAC-loop + write-8-LE-bytes). Deltas vs
// the int16 rung: (1) elements are i32 Q16.16 (movsxd DWORD load, not movsx WORD);
// (2) the LCG narrows differently — next_q16 = ((state>>16) as u32 as i32) >> 12,
// realised in i64 as (state << 16) SAR 44 (== state bits [28:48) sign-extended
// from bit 47); (3) a per-product `>> 16` (SAR) applies the Q16.16 rescale before
// the accumulate. Final narrow is the SAME `acc as i32` (movsxd rax,eax). NEW
// export never reached during self-compile, so the integer native-ELF oracle
// stays byte-identical (additivity).
//
// Frame: two 65536-element i64 arrays (524288 bytes each) plus scratch below.
//   A base = -1048576, B base = -524288, scratch at -1048584 .. -1048752.
// Slot map (rbp-relative):
//   state=-1048584 mul=-1048592 addc=-1048600 i=-1048608 eight=-1048616
//   n=-1048624 acc=-1048632 cmpflag=-1048640 one=-1048648 baseA=-1048656
//   baseB=-1048664 ptr=-1048672 aval=-1048680 bval=-1048688 prod=-1048696
//   sixteen=-1048704 fortyfour=-1048712 result=-1048720 fd=-1048728
//   bufaddr=-1048736 count=-1048744 exitcode=-1048752.
// ============================================================================

// One generation-loop body: advance the LCG one draw and store the Q16.16 i32
// element to memory[base + i*8]. base_d is a slot holding the array's runtime base.
//   state = state*1664525 + 1013904223 ; q16 = (state << 16) SAR 44 (the exact
//   i64 form of ((state>>16) as u32 as i32) >> 12) ; ptr = base + i*8 ; *ptr = q16.
pub fn nb_q16gen_body(code: String, base_d: i64) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048584);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048592);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048600);
    let a4: String = nb_store_rax(a3, 0 - 1048584);
    let b1: String = nb_load_rax(a4, 0 - 1048584);
    let b2: String = nb_arith_rax_mem(b1, op_shl(), 0 - 1048704);
    let b3: String = nb_arith_rax_mem(b2, op_shr(), 0 - 1048712);
    let b4: String = nb_store_rax(b3, 0 - 1048680);
    let c1: String = nb_load_rax(b4, 0 - 1048608);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 1048616);
    let c3: String = nb_arith_rax_mem(c2, op_add(), base_d);
    let c4: String = nb_store_rax(c3, 0 - 1048672);
    let d1: String = nb_emit_store_i64(c4, 0 - 1048672, 0 - 1048680);
    let e1: String = nb_load_rax(d1, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// One dot-loop body: aval = movsxd dword a[i] ; bval = movsxd dword b[i] ;
// prod = (aval*bval) SAR 16 (Q16.16 rescale) ; acc += prod ; i += 1. Each i32
// element is sign-extended from memory via nb_emit_load_i32_sx before the i64
// product and the per-product >>16.
pub fn nb_q16dot_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048608);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048616);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048656);
    let a4: String = nb_store_rax(a3, 0 - 1048672);
    let a5: String = nb_emit_load_i32_sx(a4, 0 - 1048672);
    let a6: String = nb_store_rax(a5, 0 - 1048680);
    let b1: String = nb_load_rax(a6, 0 - 1048608);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 1048616);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 1048664);
    let b4: String = nb_store_rax(b3, 0 - 1048672);
    let b5: String = nb_emit_load_i32_sx(b4, 0 - 1048672);
    let b6: String = nb_store_rax(b5, 0 - 1048688);
    let c1: String = nb_load_rax(b6, 0 - 1048680);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 1048688);
    let c3: String = nb_arith_rax_mem(c2, op_shr(), 0 - 1048704);
    let c4: String = nb_store_rax(c3, 0 - 1048696);
    let d1: String = nb_load_rax(c4, 0 - 1048632);
    let d2: String = nb_arith_rax_mem(d1, op_add(), 0 - 1048696);
    let d3: String = nb_store_rax(d2, 0 - 1048632);
    let e1: String = nb_load_rax(d3, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// Emit an ET_EXEC that (1) generates a[0..n] then b[0..n] via the EXACT Q16.16
// LCG into two in-frame i32 arrays, (2) computes acc = Sum (sext(a[i]) *
// sext(b[i])) >> 16 with a full i64 accumulator, (3) narrows ONCE to i32 (movsxd
// — the canary's `acc as i32`), (4) writes the 8 LE bytes of the result to stdout.
// n is baked at emit time (the canary uses 65536).
pub fn selftest_native_elf_intdot_q16(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 1048592);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 1048600);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 1048616);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 1048648);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 1048704);
    let k5b: String = nb_intdot_movimm(k5, 44, 0 - 1048712);
    let k6: String = nb_intdot_movimm(k5b, 3735928559, 0 - 1048584);
    let k7: String = nb_intdot_movimm(k6, 0, 0 - 1048632);
    let k8: String = nb_intdot_movimm(k7, n, 0 - 1048624);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 1048576, 0 - 1048656);
    let bb: String = nb_intdot_lea(ba, 0 - 524288, 0 - 1048664);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- generate A[0..n] (base slot -1048656) ---
    let ga0: String = nb_intdot_movimm(bb, 0, 0 - 1048608);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 1048608);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gac3: String = nb_store_rax(gac2, 0 - 1048640);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 1048640, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_q16gen_body(gacj, 0 - 1048656);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..n] (base slot -1048664), LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 1048608);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 1048608);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gbc3: String = nb_store_rax(gbc2, 0 - 1048640);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 1048640, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_q16gen_body(gbcj, 0 - 1048664);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    // --- dot loop: acc = Sum (sext(a[i]) * sext(b[i])) >> 16 ---
    let d0: String = nb_intdot_movimm(gbjb, 0, 0 - 1048608);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 1048608);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let dc3: String = nb_store_rax(dc2, 0 - 1048640);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 1048640, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_q16dot_body(dcj);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Narrow ONCE to i32 and sign-extend to i64 (the canary's `acc as i32`).
    let t1: String = nb_load_rax(djb, 0 - 1048632);
    let t2: String = nb_movsxd_rax_eax(t1);
    let t3: String = nb_store_rax(t2, 0 - 1048720);
    // write(1, &result, 8).
    let t4: String = nb_intdot_lea(t3, 0 - 1048720, 0 - 1048736);
    let t5: String = nb_intdot_movimm(t4, 1, 0 - 1048728);
    let t6: String = nb_intdot_movimm(t5, 8, 0 - 1048744);
    let t7: String = nb_emit_write(t6, 0 - 1048728, 0 - 1048736, 0 - 1048744);
    // exit(0).
    let t8: String = nb_intdot_movimm(t7, 0, 0 - 1048752);
    let t9: String = nb_load_rax(t8, 0 - 1048752);
    let code: String = nb_emit_return(t9, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S6 (#108) — native-ELF scalar GEMV (matrix x vector), byte-identical to
// the MLIR canaries gemv-i16 AND gemv-q16 (both 256x256, seed 0xDEADBEEF). GEMV
// composes the PROVEN S2/S4 inner dot bodies under a NEW outer row-loop that
// writes a VECTOR output: y[r] = dot(W row r, x) for each row r, each y[r] a raw
// i32 emitted LITTLE-ENDIAN to stdout in ROW-MAJOR order. The gate sha256's the
// M*4-byte stdout stream (canonical_hash_i32s), so 256 per-row write(1,&y_r,4)
// calls produce the identical byte stream as one write of a contiguous buffer —
// no 32-bit-store encoder needed (reuses the i64 result slot + 4-byte write).
//
// Big frame shared by both kernels (mirror the S4 Q16 slot map, W reuses the S4
// A-array region and x the B-array region):
//   W base = -1048576 (65536 i64 cells, spans ..-524296), x base = -524288 (256
//   cells, spans ..-522248). Scratch below -1048576.
// Slot map (rbp-relative):
//   state=-1048584 mul=-1048592 addc=-1048600 i=-1048608 (inner col idx)
//   eight=-1048616 n=-1048624 (=N cols) acc=-1048632 cmpflag=-1048640
//   one=-1048648 baseA=-1048656 (current row base ptr, mutable each outer iter)
//   baseB=-1048664 (x base, const) ptr=-1048672 aval=-1048680 bval=-1048688
//   prod=-1048696 sixteen=-1048704 fortyfour=-1048712 result=-1048720
//   fd=-1048728 bufaddr=-1048736 count=-1048744 exitcode=-1048752
//   r=-1048760 (outer row idx) nrows=-1048768 (=M) rowstride=-1048776 (=N*8)
//   baseW0=-1048784 (W base runtime addr, const) gentotal=-1048792 (=M*N)
//   thirtytwo=-1048800 (i16 gen shr-32).
// The Q16 gemv reuses nb_q16gen_body + nb_q16dot_body VERBATIM (their slots are
// exactly this map). The i16 gemv needs big-frame gen/dot bodies (the S2 bodies
// hardcode the small 73728-byte S2 frame, which cannot hold a 65536-cell W).
// ============================================================================

// One int16 generation-loop body in the big gemv frame (the S2 nb_i16gen_body
// ported onto the S4 slot map): advance the LCG one draw, val = state >> 32
// (low 16 = element), store 8 bytes to memory[base + i*8], i += 1. Only the low
// 16 bits matter (realised by the movsx WORD load in the dot loop), so SAR vs
// SHR on the >>32 is irrelevant to bits [32:48).
pub fn nb_gemv_i16gen_body(code: String, base_d: i64) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048584);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048592);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048600);
    let a4: String = nb_store_rax(a3, 0 - 1048584);
    let b1: String = nb_load_rax(a4, 0 - 1048584);
    let b2: String = nb_arith_rax_mem(b1, op_shr(), 0 - 1048800);
    let b3: String = nb_store_rax(b2, 0 - 1048680);
    let c1: String = nb_load_rax(b3, 0 - 1048608);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 1048616);
    let c3: String = nb_arith_rax_mem(c2, op_add(), base_d);
    let c4: String = nb_store_rax(c3, 0 - 1048672);
    let d1: String = nb_emit_store_i64(c4, 0 - 1048672, 0 - 1048680);
    let e1: String = nb_load_rax(d1, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// One int16 dot-loop body in the big gemv frame (the S2 nb_i16dot_body ported
// onto the S4 slot map): aval = movsx word W[baseA + i*8], bval = movsx word
// x[baseB + i*8], prod = aval*bval (i64, NO >>16), acc += prod, i += 1. baseA is
// the CURRENT row base (set each outer iter); baseB is the constant x base.
pub fn nb_gemv_i16dot_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048608);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048616);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048656);
    let a4: String = nb_store_rax(a3, 0 - 1048672);
    let a5: String = nb_emit_load_i16_sx(a4, 0 - 1048672);
    let a6: String = nb_store_rax(a5, 0 - 1048680);
    let b1: String = nb_load_rax(a6, 0 - 1048608);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 1048616);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 1048664);
    let b4: String = nb_store_rax(b3, 0 - 1048672);
    let b5: String = nb_emit_load_i16_sx(b4, 0 - 1048672);
    let b6: String = nb_store_rax(b5, 0 - 1048688);
    let c1: String = nb_load_rax(b6, 0 - 1048680);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 1048688);
    let c3: String = nb_store_rax(c2, 0 - 1048696);
    let d1: String = nb_load_rax(c3, 0 - 1048632);
    let d2: String = nb_arith_rax_mem(d1, op_add(), 0 - 1048696);
    let d3: String = nb_store_rax(d2, 0 - 1048632);
    let e1: String = nb_load_rax(d3, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// Emit the outer row-loop + inner dot-loop + per-row write shared by both gemv
// kernels. `code_in` already has the LCG constants and both gen loops emitted;
// `is_q16`=1 selects the Q16 dot body (movsxd DWORD + >>16), else the int16 body
// (movsx WORD, no >>16). jmps/jcell thread the shared jump scaffold. For each
// row r<M: baseA = baseW0 + r*rowstride ; acc = 0 ; inner dot over N cols ;
// narrow acc to i32 (movsxd) into result ; write(1,&result,4) ; r += 1.
pub fn nb_gemv_row_loop(code_in: String, is_q16: i64, jmps: i64, jcell: i64) -> String {
    // --- outer row loop header ---
    let o0: String = nb_intdot_movimm(code_in, 0, 0 - 1048760);
    let o_hdr: i64 = string_len(o0);
    let oc1: String = nb_load_rax(o0, 0 - 1048760);
    let oc2: String = nb_cmp_rax_mem(oc1, nb_setcc_opcode(op_lt()), 0 - 1048768);
    let oc3: String = nb_store_rax(oc2, 0 - 1048640);
    let ocj: String = nb_emit_cmp_je_zero(oc3, 0 - 1048640, jmps, jcell);
    let o_je: i64 = __mind_load_i64(jcell) - 1;
    // baseA = baseW0 + r*rowstride.
    let p1: String = nb_load_rax(ocj, 0 - 1048760);
    let p2: String = nb_arith_rax_mem(p1, op_mul(), 0 - 1048776);
    let p3: String = nb_arith_rax_mem(p2, op_add(), 0 - 1048784);
    let p4: String = nb_store_rax(p3, 0 - 1048656);
    // acc = 0.
    let q1: String = nb_intdot_movimm(p4, 0, 0 - 1048632);
    // --- inner dot loop over N cols ---
    let d0: String = nb_intdot_movimm(q1, 0, 0 - 1048608);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 1048608);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let dc3: String = nb_store_rax(dc2, 0 - 1048640);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 1048640, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_gemv_dot_body(dcj, is_q16);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Narrow acc ONCE to i32 (movsxd — the canary's `acc as i32`) into result.
    let t1: String = nb_load_rax(djb, 0 - 1048632);
    let t2: String = nb_movsxd_rax_eax(t1);
    let t3: String = nb_store_rax(t2, 0 - 1048720);
    // write(1, &result, 4) — fd/bufaddr/count were set before the outer loop.
    let w1: String = nb_emit_write(t3, 0 - 1048728, 0 - 1048736, 0 - 1048744);
    // r += 1.
    let u1: String = nb_load_rax(w1, 0 - 1048760);
    let u2: String = nb_arith_rax_mem(u1, op_add(), 0 - 1048648);
    let u3: String = nb_store_rax(u2, 0 - 1048760);
    // back edge to the outer header.
    let ojb: String = nb_emit_jmp(u3, jmps, jcell);
    let o_bk: i64 = __mind_load_i64(jcell) - 1;
    let _op1: i64 = nb_jmp_set_target(jmps, jcell, o_bk, o_hdr);
    let o_end: i64 = string_len(ojb);
    let _op2: i64 = nb_jmp_set_target(jmps, jcell, o_je, o_end);
    ojb
}

// Dispatch to the int16 or Q16 dot body (early-return statement form — avoids the
// struct-valued if-expr mis-lower trap in the bootstrap mindc).
pub fn nb_gemv_dot_body(code: String, is_q16: i64) -> String {
    if is_q16 == 1 {
        return nb_q16dot_body(code);
    }
    nb_gemv_i16dot_body(code)
}

// Emit the two gen loops (W[0..M*N] then x[0..N], LCG state continuing) shared by
// both gemv kernels. `is_q16`=1 uses the Q16 gen body, else the int16 gen body.
// W is generated into baseW0 (const W base slot), x into baseB (const x base slot).
pub fn nb_gemv_gen_loops(code_in: String, is_q16: i64, jmps: i64, jcell: i64) -> String {
    // --- generate W[0..M*N] (base slot -1048784), count = gentotal ---
    let ga0: String = nb_intdot_movimm(code_in, 0, 0 - 1048608);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 1048608);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 1048792);
    let gac3: String = nb_store_rax(gac2, 0 - 1048640);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 1048640, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_gemv_gen_body(gacj, is_q16, 0 - 1048784);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate x[0..N] (base slot -1048664), count = n, LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 1048608);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 1048608);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gbc3: String = nb_store_rax(gbc2, 0 - 1048640);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 1048640, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_gemv_gen_body(gbcj, is_q16, 0 - 1048664);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    gbjb
}

// Dispatch to the int16 or Q16 generation body (early-return statement form).
pub fn nb_gemv_gen_body(code: String, is_q16: i64, base_d: i64) -> String {
    if is_q16 == 1 {
        return nb_q16gen_body(code, base_d);
    }
    nb_gemv_i16gen_body(code, base_d)
}

// Set the shared LCG + shape + write constants for a gemv kernel (all slots that
// are constant for the whole run). Returns the code buffer with the runtime base
// addresses (W, x, &result) materialised via lea.
pub fn nb_gemv_consts(code: String, m: i64, n: i64) -> String {
    let k1: String = nb_intdot_movimm(code, 1664525, 0 - 1048592);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 1048600);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 1048616);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 1048648);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 1048704);
    let k5b: String = nb_intdot_movimm(k5, 44, 0 - 1048712);
    let k5c: String = nb_intdot_movimm(k5b, 32, 0 - 1048800);
    let k6: String = nb_intdot_movimm(k5c, 3735928559, 0 - 1048584);
    let k8: String = nb_intdot_movimm(k6, n, 0 - 1048624);
    let k9: String = nb_intdot_movimm(k8, m, 0 - 1048768);
    let k10: String = nb_intdot_movimm(k9, n * 8, 0 - 1048776);
    let k11: String = nb_intdot_movimm(k10, m * n, 0 - 1048792);
    let k12: String = nb_intdot_movimm(k11, 1, 0 - 1048728);
    let k13: String = nb_intdot_movimm(k12, 4, 0 - 1048744);
    // Runtime base addresses: W (const), x (const), &result (write buffer).
    let ba: String = nb_intdot_lea(k13, 0 - 1048576, 0 - 1048784);
    let bb: String = nb_intdot_lea(ba, 0 - 524288, 0 - 1048664);
    nb_intdot_lea(bb, 0 - 1048720, 0 - 1048736)
}

// Emit a runnable ET_EXEC that LCG-generates W[M*N] + x[N], then for each row r
// computes y[r] = Sum_c W[r,c]*x[c] (int16: exact i64 MAC, narrow once to i32) and
// writes the 4 LE bytes of y[r] to stdout in row-major order. Byte-identical to
// the MLIR canary gemv-i16 (256x256, seed 0xDEADBEEF). NEW export never reached
// during self-compile — integer native-ELF oracle stays byte-identical.
pub fn selftest_native_elf_gemv_i16(m: i64, n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    let kc: String = nb_gemv_consts(p0, m, n);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let gens: String = nb_gemv_gen_loops(kc, 0, jmps, jcell);
    let rows: String = nb_gemv_row_loop(gens, 0, jmps, jcell);
    // exit(0).
    let e1: String = nb_intdot_movimm(rows, 0, 0 - 1048752);
    let e2: String = nb_load_rax(e1, 0 - 1048752);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// Emit a runnable ET_EXEC that LCG-generates W[M*N] + x[N] as Q16.16, then for
// each row r computes y[r] = Sum_c (W[r,c]*x[c])>>16 (i64 MAC with per-product
// Q16 rescale, narrow once to i32) and writes the 4 LE bytes of y[r] to stdout in
// row-major order. Byte-identical to the MLIR canary gemv-q16 (256x256, seed
// 0xDEADBEEF). NEW export never reached during self-compile.
pub fn selftest_native_elf_gemv_q16(m: i64, n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    let kc: String = nb_gemv_consts(p0, m, n);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let gens: String = nb_gemv_gen_loops(kc, 1, jmps, jcell);
    let rows: String = nb_gemv_row_loop(gens, 1, jmps, jcell);
    // exit(0).
    let e1: String = nb_intdot_movimm(rows, 0, 0 - 1048752);
    let e2: String = nb_load_rax(e1, 0 - 1048752);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---- RI-B2-S7 (#108): scalar fused GEMM (matrix x matrix) ----
// C[M,N] = A[M,K] . B[K,N], byte-identical to the MLIR canaries gemm-q16 and
// gemm-i8. The triple loop composes the proven i64-MAC dot: for each (i,j),
// acc = Sum_k f(A[i*K+k] * B[k*N+j]) with a full i64 accumulator, narrowed ONCE
// to i32 (movsxd — the canary's `acc as i32`), then the 4 LE bytes are written to
// stdout in row-major (i,j) order (== canonical_hash_i32s of the M*N i32 matrix,
// M*N*4 bytes). A is generated before B via the SAME LCG the canary uses; the
// per-element narrowing (q16: next_q16; i8: (next_u32>>16) as i8) is realised by
// the shl/sar amounts in nb_gemm_consts. B is the UN-transposed K*N operand,
// indexed B[k*N+j] (column j, stride N*8) — mathematically identical to the
// canary's dot over B-transpose rows.

// Set the shared LCG + shape + write constants for a gemm kernel. shl_amt/sar_amt
// select the per-element narrowing in the shared gen body (q16: 16/44 realises
// ((state>>16 as u32 as i32)>>12); i8: 24/56 realises (next_u32>>16) as i8).
pub fn nb_gemm_consts(code: String, m: i64, n: i64, k: i64, shl_amt: i64, sar_amt: i64) -> String {
    let k1: String = nb_intdot_movimm(code, 1664525, 0 - 1048592);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 1048600);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 1048616);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 1048648);
    let k5: String = nb_intdot_movimm(k4, shl_amt, 0 - 1048704);
    let k6: String = nb_intdot_movimm(k5, sar_amt, 0 - 1048712);
    let k7: String = nb_intdot_movimm(k6, 3735928559, 0 - 1048584);
    let k8: String = nb_intdot_movimm(k7, m, 0 - 1048768);
    let k9: String = nb_intdot_movimm(k8, n, 0 - 1048624);
    let k10: String = nb_intdot_movimm(k9, k, 0 - 1048824);
    let k11: String = nb_intdot_movimm(k10, k * 8, 0 - 1048832);
    let k12: String = nb_intdot_movimm(k11, n * 8, 0 - 1048776);
    let k13: String = nb_intdot_movimm(k12, m * k, 0 - 1048848);
    let k14: String = nb_intdot_movimm(k13, k * n, 0 - 1048856);
    let k15: String = nb_intdot_movimm(k14, 1, 0 - 1048728);
    let k16: String = nb_intdot_movimm(k15, 4, 0 - 1048744);
    // Runtime base addresses: A (const region), B (const region), &result (write buf).
    let ba: String = nb_intdot_lea(k16, 0 - 1048576, 0 - 1048784);
    let bb: String = nb_intdot_lea(ba, 0 - 524288, 0 - 1048664);
    nb_intdot_lea(bb, 0 - 1048720, 0 - 1048736)
}

// Emit the two gen loops A[0..M*K] then B[0..K*N] (LCG state continues) into the
// two in-frame arrays. Reuses the proven Q16 gen body — the shl/sar const slots
// (set by nb_gemm_consts) select q16 vs i8 narrowing, so ONE body serves both.
pub fn nb_gemm_gen_loops(code_in: String, jmps: i64, jcell: i64) -> String {
    // --- generate A[0..M*K] (base slot -1048784), count = M*K (-1048848) ---
    let ga0: String = nb_intdot_movimm(code_in, 0, 0 - 1048608);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 1048608);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 1048848);
    let gac3: String = nb_store_rax(gac2, 0 - 1048640);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 1048640, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_q16gen_body(gacj, 0 - 1048784);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..K*N] (base slot -1048664), count = K*N (-1048856) ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 1048608);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 1048608);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 1048856);
    let gbc3: String = nb_store_rax(gbc2, 0 - 1048640);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 1048640, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_q16gen_body(gbcj, 0 - 1048664);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    gbjb
}

// The per-product step: prod = aval*bval, with an extra SAR (Q16 rescale) for q16.
// Early-return statement form (avoids the struct-valued if-expr mis-lower trap).
pub fn nb_gemm_prod(code: String, is_q16: i64) -> String {
    let c1: String = nb_load_rax(code, 0 - 1048680);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 1048688);
    if is_q16 == 1 {
        let c3: String = nb_arith_rax_mem(c2, op_shr(), 0 - 1048704);
        return nb_store_rax(c3, 0 - 1048696);
    }
    nb_store_rax(c2, 0 - 1048696)
}

// Sign-extending narrow load for one gemm element: movsxd DWORD for q16, movsx
// BYTE for i8. Early-return statement form.
pub fn nb_gemm_load_sx(code: String, is_q16: i64, addr_disp: i64) -> String {
    if is_q16 == 1 {
        return nb_emit_load_i32_sx(code, addr_disp);
    }
    nb_emit_load_i8_sx(code, addr_disp)
}

// One inner-K dot body: aval = A[baseA_row + k*8]; bval = B[baseB_col + k*(N*8)];
// prod = f(aval*bval); acc += prod; k += 1. A is contiguous (stride 8); B is the
// UN-transposed K*N operand read down column j (stride N*8, slot -1048776).
pub fn nb_gemm_dot_body(code: String, is_q16: i64) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048608);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048616);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048656);
    let a4: String = nb_store_rax(a3, 0 - 1048672);
    let a5: String = nb_gemm_load_sx(a4, is_q16, 0 - 1048672);
    let a6: String = nb_store_rax(a5, 0 - 1048680);
    let b1: String = nb_load_rax(a6, 0 - 1048608);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 1048776);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 1048816);
    let b4: String = nb_store_rax(b3, 0 - 1048672);
    let b5: String = nb_gemm_load_sx(b4, is_q16, 0 - 1048672);
    let b6: String = nb_store_rax(b5, 0 - 1048688);
    let cc: String = nb_gemm_prod(b6, is_q16);
    let d1: String = nb_load_rax(cc, 0 - 1048632);
    let d2: String = nb_arith_rax_mem(d1, op_add(), 0 - 1048696);
    let d3: String = nb_store_rax(d2, 0 - 1048632);
    let e1: String = nb_load_rax(d3, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// Emit the triple loop (i over M, j over N, k over K) + per-output narrow + write.
// baseA_row = baseA0 + i*(K*8); baseB_col = baseB0 + j*8; acc over K; result =
// acc as i32; write(1,&result,4). Row-major (i,j) output order.
pub fn nb_gemm_triple_loop(code_in: String, is_q16: i64, jmps: i64, jcell: i64) -> String {
    // --- outer i loop ---
    let o0: String = nb_intdot_movimm(code_in, 0, 0 - 1048760);
    let o_hdr: i64 = string_len(o0);
    let oc1: String = nb_load_rax(o0, 0 - 1048760);
    let oc2: String = nb_cmp_rax_mem(oc1, nb_setcc_opcode(op_lt()), 0 - 1048768);
    let oc3: String = nb_store_rax(oc2, 0 - 1048640);
    let ocj: String = nb_emit_cmp_je_zero(oc3, 0 - 1048640, jmps, jcell);
    let o_je: i64 = __mind_load_i64(jcell) - 1;
    // baseA_row = baseA0 + i*(K*8).
    let p1: String = nb_load_rax(ocj, 0 - 1048760);
    let p2: String = nb_arith_rax_mem(p1, op_mul(), 0 - 1048832);
    let p3: String = nb_arith_rax_mem(p2, op_add(), 0 - 1048784);
    let p4: String = nb_store_rax(p3, 0 - 1048656);
    // --- middle j loop ---
    let m0: String = nb_intdot_movimm(p4, 0, 0 - 1048808);
    let m_hdr: i64 = string_len(m0);
    let mc1: String = nb_load_rax(m0, 0 - 1048808);
    let mc2: String = nb_cmp_rax_mem(mc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let mc3: String = nb_store_rax(mc2, 0 - 1048640);
    let mcj: String = nb_emit_cmp_je_zero(mc3, 0 - 1048640, jmps, jcell);
    let m_je: i64 = __mind_load_i64(jcell) - 1;
    // baseB_col = baseB0 + j*8.
    let q1: String = nb_load_rax(mcj, 0 - 1048808);
    let q2: String = nb_arith_rax_mem(q1, op_mul(), 0 - 1048616);
    let q3: String = nb_arith_rax_mem(q2, op_add(), 0 - 1048664);
    let q4: String = nb_store_rax(q3, 0 - 1048816);
    // acc = 0.
    let q5: String = nb_intdot_movimm(q4, 0, 0 - 1048632);
    // --- inner k loop over K ---
    let d0: String = nb_intdot_movimm(q5, 0, 0 - 1048608);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 1048608);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 1048824);
    let dc3: String = nb_store_rax(dc2, 0 - 1048640);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 1048640, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_gemm_dot_body(dcj, is_q16);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Narrow acc ONCE to i32 (movsxd — the canary's `acc as i32`) into result.
    let t1: String = nb_load_rax(djb, 0 - 1048632);
    let t2: String = nb_movsxd_rax_eax(t1);
    let t3: String = nb_store_rax(t2, 0 - 1048720);
    // write(1, &result, 4).
    let w1: String = nb_emit_write(t3, 0 - 1048728, 0 - 1048736, 0 - 1048744);
    // j += 1.
    let u1: String = nb_load_rax(w1, 0 - 1048808);
    let u2: String = nb_arith_rax_mem(u1, op_add(), 0 - 1048648);
    let u3: String = nb_store_rax(u2, 0 - 1048808);
    // back edge to the middle header.
    let mjb: String = nb_emit_jmp(u3, jmps, jcell);
    let m_bk: i64 = __mind_load_i64(jcell) - 1;
    let _mp1: i64 = nb_jmp_set_target(jmps, jcell, m_bk, m_hdr);
    let m_end: i64 = string_len(mjb);
    let _mp2: i64 = nb_jmp_set_target(jmps, jcell, m_je, m_end);
    // i += 1.
    let v1: String = nb_load_rax(mjb, 0 - 1048760);
    let v2: String = nb_arith_rax_mem(v1, op_add(), 0 - 1048648);
    let v3: String = nb_store_rax(v2, 0 - 1048760);
    // back edge to the outer header.
    let ojb: String = nb_emit_jmp(v3, jmps, jcell);
    let o_bk: i64 = __mind_load_i64(jcell) - 1;
    let _op1: i64 = nb_jmp_set_target(jmps, jcell, o_bk, o_hdr);
    let o_end: i64 = string_len(ojb);
    let _op2: i64 = nb_jmp_set_target(jmps, jcell, o_je, o_end);
    ojb
}

// Emit a runnable ET_EXEC for scalar Q16.16 GEMM: LCG-generate A[M*K] then B[K*N]
// as Q16.16, then C[i,j] = (i32)( Sum_k (A[i,k]*B[k,j]) >> 16 ), i64 MAC with
// per-product Q16 rescale, narrowed once to i32, M*N i32 output row-major to
// stdout. Byte-identical to the MLIR canary gemm-q16 (64x64x64, seed 0xDEADBEEF).
// NEW export never reached during self-compile — integer native oracle stays
// byte-identical.
pub fn selftest_native_elf_gemm_q16(m: i64, n: i64, k: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    let kc: String = nb_gemm_consts(p0, m, n, k, 16, 44);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let gens: String = nb_gemm_gen_loops(kc, jmps, jcell);
    let loops: String = nb_gemm_triple_loop(gens, 1, jmps, jcell);
    // exit(0).
    let e1: String = nb_intdot_movimm(loops, 0, 0 - 1048752);
    let e2: String = nb_load_rax(e1, 0 - 1048752);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// Emit a runnable ET_EXEC for scalar int8 GEMM (the det.igemm tier): LCG-generate
// A[M*K] then B[K*N] as int8 ((next_u32>>16) as i8), then C[i,j] =
// (i32)( Sum_k A[i,k]*B[k,j] ), PURE INTEGER i64 MAC (movsx-byte loads, NO
// fixed-point shift), narrowed once to i32, M*N i32 output row-major to stdout.
// Byte-identical to the MLIR canary gemm-i8 (64x64x64, seed 0xDEADBEEF). NEW
// export never reached during self-compile.
pub fn selftest_native_elf_gemm_i8(m: i64, n: i64, k: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    let kc: String = nb_gemm_consts(p0, m, n, k, 24, 56);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let gens: String = nb_gemm_gen_loops(kc, jmps, jcell);
    let loops: String = nb_gemm_triple_loop(gens, 0, jmps, jcell);
    // exit(0).
    let e1: String = nb_intdot_movimm(loops, 0, 0 - 1048752);
    let e2: String = nb_load_rax(e1, 0 - 1048752);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S8 (#108) — native-ELF scalar STRICT-FP f32 DOT-PRODUCT, byte-identical
// to the MLIR canary dot-f32-v (len 4093, seed 0xDEADBEEF). The FLOAT tier
// opener. Because f32 add is NOT associative, byte-identity rests on an
// EXACTLY-pinned fold order + exact f32 rounding. The reference fold
// (tests/cross_substrate_identity.rs::ref_dot_f32_strict) is an 8-LANE
// accumulator, NOT a plain sequential sum:
//   ve = (n/8)*8 ; acc[0..8] = 0.0f
//   for i in (0,8,..,ve-8): for lane 0..8: acc[lane] += a[i+lane]*b[i+lane]
//   hs = acc[0]; hs += acc[1] .. += acc[7]   (fixed left-to-right fold)
//   s = hs; for j in ve..n: s += a[j]*b[j]    (scalar tail)
// mulss THEN addss, UNFUSED (no FMA), each lane strictly k=0,1,.. in order.
// IEEE add is commutative so `acc + prod` == `prod + acc` bitwise (we keep the
// running acc as the addss memory operand). f32 elements are stored one per
// 8-byte slot (movss touches the low 4); n baked at emit time.
// NEW exports, never reached during self-compile -> the integer + f64 native-ELF
// oracle stays byte-identical (additivity). The F3-prefix scalar-single family
// mirrors the RI-B1 f64 F2 encoders (nb_fp_movsd_* / nb_fp_binop_xmm0_mem).
// ============================================================================

// movss xmm0, [rbp+disp32]  =  F3 0F 10 85 <disp32>   (load slot low-4 -> xmm0)
pub fn nb_fp_movss_load_xmm0(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 16);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// movss [rbp+disp32], xmm0  =  F3 0F 11 85 <disp32>   (store xmm0 -> slot low-4)
pub fn nb_fp_movss_store_xmm0(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 17);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// <op>ss xmm0, [rbp+disp32]  =  F3 0F <opc> 85 <disp32>   (xmm0 = xmm0 OP slot).
//   op_sel 0->addss(0x58) 1->subss(0x5C) 2->mulss(0x59) 3->divss(0x5E).
pub fn nb_fp_ss_binop_mem(code: String, op_sel: i64, disp: i64) -> String {
    let opc: i64 = if op_sel == 0 {
        88
    } else {
        if op_sel == 1 {
            92
        } else {
            if op_sel == 2 {
                89
            } else {
                94
            }
        }
    };
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, opc);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}

// cvtsi2ss xmm0, qword [rbp+disp32] = F3 48 0F 2A 85 <disp32> (signed i64 -> f32;
// the u32 sample is masked to [0,2^32) so signed == unsigned conversion).
pub fn nb_fp_cvtsi2ss_mem(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 42);
    let c5: String = nb_push(c4, 133);
    nb_i32le_signed(c5, disp)
}

// movd eax, xmm0 = 66 0F 7E C0 (f32 bits -> eax; writing eax zeroes rax[63:32],
// so the subsequent 8-LE-byte store == `to_bits() as i64` zero-extension).
pub fn nb_fp_movd_eax_xmm0(code: String) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 126);
    nb_push(c3, 192)
}

// movss xmm0, [rax]  via a pointer slot:  mov rax,[rbp+ptr] ; F3 0F 10 00.
pub fn nb_fp_movss_load_ind(code: String, ptr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, ptr_disp);
    let c5: String = nb_push(c4, 243);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 16);
    nb_push(c7, 0)
}

// mulss xmm0, [rax]  via a pointer slot:  mov rax,[rbp+ptr] ; F3 0F 59 00.
pub fn nb_fp_mulss_ind(code: String, ptr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, ptr_disp);
    let c5: String = nb_push(c4, 243);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 89);
    nb_push(c7, 0)
}

// movss [rax], xmm0  via a pointer slot:  mov rax,[rbp+ptr] ; F3 0F 11 00.
pub fn nb_fp_movss_store_ind(code: String, ptr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, ptr_disp);
    let c5: String = nb_push(c4, 243);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 17);
    nb_push(c7, 0)
}

// add rax, imm32  =  48 05 <imm32>  (fold a compile-time lane byte-offset into an
// address; imm is a small non-negative multiple of 8).
pub fn nb_fp_add_rax_imm(code: String, imm: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 5);
    nb_u32(c2, imm)
}

// STEP A: emit an ET_EXEC that routes a KNOWN f32 (its IEEE bits) through xmm via
// movss-load + movd, then writes its 8 LE bit-bytes to stdout and exit(0). Proves
// movss-load + movd(eax<-xmm0) + the f32->bits->stdout path the dot gate relies
// on. Slots: bits=-16 result=-24 bufaddr=-32 fd=-40 count=-48 exit=-56.
pub fn selftest_native_elf_write_f32(bits: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 256);
    let k1: String = nb_intdot_movimm(p0, bits, 0 - 16);
    let m1: String = nb_fp_movss_load_xmm0(k1, 0 - 16);
    let m2: String = nb_fp_movd_eax_xmm0(m1);
    let m3: String = nb_store_rax(m2, 0 - 24);
    let w0: String = nb_intdot_lea(m3, 0 - 24, 0 - 32);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 40);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 48);
    let w3: String = nb_emit_write(w2, 0 - 40, 0 - 32, 0 - 48);
    let z1: String = nb_intdot_movimm(w3, 0, 0 - 56);
    let r1: String = nb_load_rax(z1, 0 - 56);
    let code: String = nb_emit_return(r1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// One LCG f32 draw, leaving the sample in xmm0 (does NOT store to an array):
//   state = state*1664525 + 1013904223 ; u32 = (state>>16) & 0xFFFFFFFF ;
//   xmm0 = ((f32)u32 / 4294967296.0f) * 2.0f - 1.0f.
// Shared scratch slots: state=-8 mul=-16 addc=-24 sh16=-56 mask32=-64 u32s=-72
//   divisor=-128 twof=-136 onef=-144.
pub fn nb_f32_draw_xmm0(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 8);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 16);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 24);
    let a4: String = nb_store_rax(a3, 0 - 8);
    let b1: String = nb_load_rax(a4, 0 - 8);
    let b2: String = nb_arith_rax_mem(b1, op_shr(), 0 - 56);
    let b3: String = nb_arith_rax_mem(b2, op_bitand(), 0 - 64);
    let b4: String = nb_store_rax(b3, 0 - 72);
    let c1: String = nb_fp_cvtsi2ss_mem(b4, 0 - 72);
    let c2: String = nb_fp_ss_binop_mem(c1, 3, 0 - 128);
    let c3: String = nb_fp_ss_binop_mem(c2, 2, 0 - 136);
    nb_fp_ss_binop_mem(c3, 1, 0 - 144)
}

// STEP B: emit an ET_EXEC that draws the first `n` LCG f32 samples (fresh seed
// 0xDEADBEEF, the `a`-vector prefix) and writes each sample's 8 LE bit-bytes to
// stdout, isolating the u32->f32 / div / mul / sub rounding BEFORE the dot. The
// Python oracle recomputes next_f32_unit for the same n draws and compares
// sha256(stdout). Slots add: i=-32 n=-48 one_i=-88 result=-224 fd=-232
// bufaddr=-240 count=-248.
pub fn selftest_native_elf_genf32(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 65536);
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 16, 0 - 56);
    let k4: String = nb_intdot_movimm(k3, 4294967295, 0 - 64);
    let k5: String = nb_intdot_movimm(k4, 1333788672, 0 - 128);
    let k6: String = nb_intdot_movimm(k5, 1073741824, 0 - 136);
    let k7: String = nb_intdot_movimm(k6, 1065353216, 0 - 144);
    let k8: String = nb_intdot_movimm(k7, 3735928559, 0 - 8);
    let k9: String = nb_intdot_movimm(k8, n, 0 - 48);
    let k10: String = nb_intdot_movimm(k9, 1, 0 - 88);
    let k11: String = nb_intdot_movimm(k10, 1, 0 - 232);
    let k12: String = nb_intdot_movimm(k11, 8, 0 - 248);
    let la: String = nb_intdot_lea(k12, 0 - 224, 0 - 240);
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let g0: String = nb_intdot_movimm(la, 0, 0 - 32);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 32);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 48);
    let gc3: String = nb_store_rax(gc2, 0 - 80);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 80, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    // body: draw -> xmm0 ; movd eax ; store result ; write(1,&result,8) ; i += 1.
    let d1: String = nb_f32_draw_xmm0(gcj);
    let d2: String = nb_fp_movd_eax_xmm0(d1);
    let d3: String = nb_store_rax(d2, 0 - 224);
    let d4: String = nb_emit_write(d3, 0 - 232, 0 - 240, 0 - 248);
    let d5: String = nb_load_rax(d4, 0 - 32);
    let d6: String = nb_arith_rax_mem(d5, op_add(), 0 - 88);
    let d7: String = nb_store_rax(d6, 0 - 32);
    let gjb: String = nb_emit_jmp(d7, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    let z1: String = nb_intdot_movimm(gjb, 0, 0 - 256);
    let r1: String = nb_load_rax(z1, 0 - 256);
    let code: String = nb_emit_return(r1, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// One generation-loop body: draw one LCG f32 into xmm0 and movss-store it to
// memory[base + i*8], then i += 1. base_d is a slot holding the array runtime base.
pub fn nb_f32gen_body(code: String, base_d: i64) -> String {
    let s1: String = nb_f32_draw_xmm0(code);
    let p1: String = nb_load_rax(s1, 0 - 32);
    let p2: String = nb_arith_rax_mem(p1, op_mul(), 0 - 40);
    let p3: String = nb_arith_rax_mem(p2, op_add(), base_d);
    let p4: String = nb_store_rax(p3, 0 - 112);
    let p5: String = nb_fp_movss_store_ind(p4, 0 - 112);
    let e1: String = nb_load_rax(p5, 0 - 32);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 88);
    nb_store_rax(e2, 0 - 32)
}

// One dot-loop LANE (compile-time unrolled j in 0..8): acc[j] += a[i+j]*b[i+j].
//   a addr = baseA + i*8 + j*8 -> ptr_a ; b addr = baseB + i*8 + j*8 -> ptr_b ;
//   xmm0 = a ; xmm0 = mulss xmm0,b ; xmm0 = addss xmm0,acc[j] ; acc[j] = xmm0.
// acc0=-152 acc1=-160 .. acc7=-208 ; ptr_a=-112 ptr_b=-120 baseA=-96 baseB=-104.
pub fn nb_f32dot_lane(code: String, lane: i64) -> String {
    let off: i64 = lane * 8;
    let accd: i64 = 0 - 152 - lane * 8;
    let a1: String = nb_load_rax(code, 0 - 32);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 40);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 96);
    let a4: String = nb_fp_add_rax_imm(a3, off);
    let a5: String = nb_store_rax(a4, 0 - 112);
    let b1: String = nb_load_rax(a5, 0 - 32);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 40);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 104);
    let b4: String = nb_fp_add_rax_imm(b3, off);
    let b5: String = nb_store_rax(b4, 0 - 120);
    let c1: String = nb_fp_movss_load_ind(b5, 0 - 112);
    let c2: String = nb_fp_mulss_ind(c1, 0 - 120);
    let c3: String = nb_fp_ss_binop_mem(c2, 0, accd);
    nb_fp_movss_store_xmm0(c3, accd)
}

// One main-loop iteration: 8 unrolled lanes then i += 8.
pub fn nb_f32dot_main_body(code: String) -> String {
    let l0: String = nb_f32dot_lane(code, 0);
    let l1: String = nb_f32dot_lane(l0, 1);
    let l2: String = nb_f32dot_lane(l1, 2);
    let l3: String = nb_f32dot_lane(l2, 3);
    let l4: String = nb_f32dot_lane(l3, 4);
    let l5: String = nb_f32dot_lane(l4, 5);
    let l6: String = nb_f32dot_lane(l5, 6);
    let l7: String = nb_f32dot_lane(l6, 7);
    let e1: String = nb_load_rax(l7, 0 - 32);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 40);
    nb_store_rax(e2, 0 - 32)
}

// One scalar-tail iteration: s += a[i]*b[i] ; i += 1.  s lives in sslot=-216.
pub fn nb_f32dot_tail_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 32);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 40);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 96);
    let a4: String = nb_store_rax(a3, 0 - 112);
    let b1: String = nb_load_rax(a4, 0 - 32);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 40);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 104);
    let b4: String = nb_store_rax(b3, 0 - 120);
    let c1: String = nb_fp_movss_load_ind(b4, 0 - 112);
    let c2: String = nb_fp_mulss_ind(c1, 0 - 120);
    let c3: String = nb_fp_ss_binop_mem(c2, 0, 0 - 216);
    let c4: String = nb_fp_movss_store_xmm0(c3, 0 - 216);
    let e1: String = nb_load_rax(c4, 0 - 32);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 88);
    nb_store_rax(e2, 0 - 32)
}

// The 8-lane horizontal fold: hs = acc0 ; hs += acc1 .. += acc7 ; store hs -> sslot.
pub fn nb_f32dot_fold(code: String) -> String {
    let h0: String = nb_fp_movss_load_xmm0(code, 0 - 152);
    let h1: String = nb_fp_ss_binop_mem(h0, 0, 0 - 160);
    let h2: String = nb_fp_ss_binop_mem(h1, 0, 0 - 168);
    let h3: String = nb_fp_ss_binop_mem(h2, 0, 0 - 176);
    let h4: String = nb_fp_ss_binop_mem(h3, 0, 0 - 184);
    let h5: String = nb_fp_ss_binop_mem(h4, 0, 0 - 192);
    let h6: String = nb_fp_ss_binop_mem(h5, 0, 0 - 200);
    let h7: String = nb_fp_ss_binop_mem(h6, 0, 0 - 208);
    nb_fp_movss_store_xmm0(h7, 0 - 216)
}

// Emit one LCG-gen loop over i in 0..n with `body(code, base_d)`, returning the
// grown code. Mirrors the i16/q16 loop scaffold (header/cond/je/body/jmp/patch).
pub fn nb_f32_gen_loop(code: String, base_d: i64, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 32);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 32);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 48);
    let gc3: String = nb_store_rax(gc2, 0 - 80);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 80, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let gb: String = nb_f32gen_body(gcj, base_d);
    let gjb: String = nb_emit_jmp(gb, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// STEP C: emit an ET_EXEC that (1) LCG-generates a[0..n] then b[0..n] as f32 into
// two in-frame arrays, (2) computes the strict-FP 8-lane dot with the pinned
// left-to-right horizontal fold + scalar tail, (3) writes the result's 8 LE
// bit-bytes to stdout. Byte-identical to the MLIR canary dot-f32-v (n=4093, seed
// 0xDEADBEEF). Frame 131072: A base -131072, B base -98304, scratch shallow.
pub fn selftest_native_elf_dot_f32(n: i64) -> EmitState {
    let ve: i64 = (n / 8) * 8;
    let p0: String = nb_fp_prologue_frame(string_new(), 131072);
    // Integer + f32-bit constants.
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 40);
    let k4: String = nb_intdot_movimm(k3, n, 0 - 48);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 56);
    let k6: String = nb_intdot_movimm(k5, 4294967295, 0 - 64);
    let k7: String = nb_intdot_movimm(k6, 1, 0 - 88);
    let k8: String = nb_intdot_movimm(k7, 1333788672, 0 - 128);
    let k9: String = nb_intdot_movimm(k8, 1073741824, 0 - 136);
    let k10: String = nb_intdot_movimm(k9, 1065353216, 0 - 144);
    let k11: String = nb_intdot_movimm(k10, 3735928559, 0 - 8);
    let k12: String = nb_intdot_movimm(k11, ve, 0 - 264);
    // acc[0..8] = 0.0f (bit pattern 0).
    let z0: String = nb_intdot_movimm(k12, 0, 0 - 152);
    let z1: String = nb_intdot_movimm(z0, 0, 0 - 160);
    let z2: String = nb_intdot_movimm(z1, 0, 0 - 168);
    let z3: String = nb_intdot_movimm(z2, 0, 0 - 176);
    let z4: String = nb_intdot_movimm(z3, 0, 0 - 184);
    let z5: String = nb_intdot_movimm(z4, 0, 0 - 192);
    let z6: String = nb_intdot_movimm(z5, 0, 0 - 200);
    let z7: String = nb_intdot_movimm(z6, 0, 0 - 208);
    // Runtime base addresses of the two in-frame f32 arrays.
    let ba: String = nb_intdot_lea(z7, 0 - 131072, 0 - 96);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 104);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // Generate a (base slot -96) then b (base slot -104); LCG state continues.
    let ga: String = nb_f32_gen_loop(bb, 0 - 96, jmps, jcell);
    let gb: String = nb_f32_gen_loop(ga, 0 - 104, jmps, jcell);
    // Main dot loop: i in 0..ve step 8, 8-lane accumulate.
    let m0: String = nb_intdot_movimm(gb, 0, 0 - 32);
    let m_hdr: i64 = string_len(m0);
    let mc1: String = nb_load_rax(m0, 0 - 32);
    let mc2: String = nb_cmp_rax_mem(mc1, nb_setcc_opcode(op_lt()), 0 - 264);
    let mc3: String = nb_store_rax(mc2, 0 - 80);
    let mcj: String = nb_emit_cmp_je_zero(mc3, 0 - 80, jmps, jcell);
    let m_je: i64 = __mind_load_i64(jcell) - 1;
    let mb: String = nb_f32dot_main_body(mcj);
    let mjb: String = nb_emit_jmp(mb, jmps, jcell);
    let m_bk: i64 = __mind_load_i64(jcell) - 1;
    let _mp1: i64 = nb_jmp_set_target(jmps, jcell, m_bk, m_hdr);
    let m_end: i64 = string_len(mjb);
    let _mp2: i64 = nb_jmp_set_target(jmps, jcell, m_je, m_end);
    // Horizontal fold -> sslot (i is left == ve, reused as the tail counter).
    let fld: String = nb_f32dot_fold(mjb);
    // Scalar tail: i in ve..n.
    let t_hdr: i64 = string_len(fld);
    let tc1: String = nb_load_rax(fld, 0 - 32);
    let tc2: String = nb_cmp_rax_mem(tc1, nb_setcc_opcode(op_lt()), 0 - 48);
    let tc3: String = nb_store_rax(tc2, 0 - 80);
    let tcj: String = nb_emit_cmp_je_zero(tc3, 0 - 80, jmps, jcell);
    let t_je: i64 = __mind_load_i64(jcell) - 1;
    let tb: String = nb_f32dot_tail_body(tcj);
    let tjb: String = nb_emit_jmp(tb, jmps, jcell);
    let t_bk: i64 = __mind_load_i64(jcell) - 1;
    let _tp1: i64 = nb_jmp_set_target(jmps, jcell, t_bk, t_hdr);
    let t_end: i64 = string_len(tjb);
    let _tp2: i64 = nb_jmp_set_target(jmps, jcell, t_je, t_end);
    // result bits: movss xmm0,[sslot] ; movd eax,xmm0 ; store rax -> result.
    let r0: String = nb_fp_movss_load_xmm0(tjb, 0 - 216);
    let r1: String = nb_fp_movd_eax_xmm0(r0);
    let r2: String = nb_store_rax(r1, 0 - 224);
    // write(1, &result, 8).
    let w0: String = nb_intdot_lea(r2, 0 - 224, 0 - 240);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 232);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 248);
    let w3: String = nb_emit_write(w2, 0 - 232, 0 - 240, 0 - 248);
    // exit(0).
    let e1: String = nb_intdot_movimm(w3, 0, 0 - 256);
    let e2: String = nb_load_rax(e1, 0 - 256);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ---------------------------------------------------------------------------
// RI-B2-S9 (#108) — native-ELF scalar STRICT-FP f32 GEMV (matmul-f32-v). The
// f32 analog of the integer gemv (S6): an OUTER row loop over the ALREADY-PROVEN
// S8 strict-FP f32 dot INNER (nb_f32dot_main_body + nb_f32dot_fold, reused
// VERBATIM), with a VECTOR output. Per row r: y[r] = strict-FP dot of
// W[r,:] . x, written as its 4 IEEE-754 bit-bytes to stdout in row-major order.
// Byte-identical to the MLIR canary matmul-f32-v (64x64, seed 0xDEADBEEF). No
// new encoder — reuses the S8 f32 SSE family + the S6 row-loop pattern.
//
// Frame reuses the S8 dot slot map (frame 131072): W array base -131072
// (m*n f32), x array base -98304 (n f32), the 8-lane accumulator -152..-208,
// sslot -216, result -224. cols=64 so ve=(64/8)*8=64 — NO scalar tail. New
// slots: Wbase -272 (const addr), rowstride -280 (n*8), r -288, m -296.

// Set the constant slots for the f32 gemv (LCG + f32-bit consts + shape +
// write). W gen count -48 = m*n; ve -264 = (n/8)*8; rowstride -280 = n*8; rows
// -296 = m; write is 4 bytes/element (count -248 = 4). lea the two array bases
// (-96 = W for gen, -272 = W for the per-row address calc, -104 = x) and the
// result buffer (-240 = &result).
pub fn nb_f32matmul_consts(code: String, m: i64, n: i64) -> String {
    let k1: String = nb_intdot_movimm(code, 1664525, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 40);
    let k4: String = nb_intdot_movimm(k3, m * n, 0 - 48);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 56);
    let k6: String = nb_intdot_movimm(k5, 4294967295, 0 - 64);
    let k7: String = nb_intdot_movimm(k6, 1, 0 - 88);
    let k8: String = nb_intdot_movimm(k7, 1333788672, 0 - 128);
    let k9: String = nb_intdot_movimm(k8, 1073741824, 0 - 136);
    let k10: String = nb_intdot_movimm(k9, 1065353216, 0 - 144);
    let k11: String = nb_intdot_movimm(k10, 3735928559, 0 - 8);
    let k12: String = nb_intdot_movimm(k11, (n / 8) * 8, 0 - 264);
    let k13: String = nb_intdot_movimm(k12, n * 8, 0 - 280);
    let k14: String = nb_intdot_movimm(k13, m, 0 - 296);
    let k15: String = nb_intdot_movimm(k14, 1, 0 - 232);
    let k16: String = nb_intdot_movimm(k15, 4, 0 - 248);
    // Runtime base addresses: W (into -96 for gen AND -272 for row calc), x
    // (into -104, kept as baseB for the dot), &result (into -240 = bufaddr).
    let ba: String = nb_intdot_lea(k16, 0 - 131072, 0 - 96);
    let bb: String = nb_intdot_lea(ba, 0 - 131072, 0 - 272);
    let bc: String = nb_intdot_lea(bb, 0 - 98304, 0 - 104);
    nb_intdot_lea(bc, 0 - 224, 0 - 240)
}

// Emit the two f32 gen loops: W[0..m*n] into base slot -96 (count -48 = m*n set
// in consts), then x[0..n] into base slot -104 (count reset to n between). LCG
// state continues across both — the SAME make_matvec_f32 order (W before x).
pub fn nb_f32matmul_gen_loops(code_in: String, n: i64, jmps: i64, jcell: i64) -> String {
    let ga: String = nb_f32_gen_loop(code_in, 0 - 96, jmps, jcell);
    let sc: String = nb_intdot_movimm(ga, n, 0 - 48);
    nb_f32_gen_loop(sc, 0 - 104, jmps, jcell)
}

// Emit the outer row loop over r<m. For each row: baseA(-96) = Wbase(-272) +
// r*rowstride(-280) ; zero the 8-lane accumulator ; run the S8 f32 dot main loop
// over ve(-264) cols (no tail, cols is a multiple of 8) ; pinned horizontal fold
// -> sslot(-216) ; movss/movd the result f32 bits -> result(-224) ; write 4 LE
// bytes ; r += 1.
pub fn nb_f32matmul_row_loop(code_in: String, jmps: i64, jcell: i64) -> String {
    // --- outer row loop header (r=-288, m=-296) ---
    let o0: String = nb_intdot_movimm(code_in, 0, 0 - 288);
    let o_hdr: i64 = string_len(o0);
    let oc1: String = nb_load_rax(o0, 0 - 288);
    let oc2: String = nb_cmp_rax_mem(oc1, nb_setcc_opcode(op_lt()), 0 - 296);
    let oc3: String = nb_store_rax(oc2, 0 - 80);
    let ocj: String = nb_emit_cmp_je_zero(oc3, 0 - 80, jmps, jcell);
    let o_je: i64 = __mind_load_i64(jcell) - 1;
    // baseA(-96) = Wbase(-272) + r*rowstride(-280).
    let p1: String = nb_load_rax(ocj, 0 - 288);
    let p2: String = nb_arith_rax_mem(p1, op_mul(), 0 - 280);
    let p3: String = nb_arith_rax_mem(p2, op_add(), 0 - 272);
    let p4: String = nb_store_rax(p3, 0 - 96);
    // acc[0..8] = 0.0f (bit pattern 0).
    let z0: String = nb_intdot_movimm(p4, 0, 0 - 152);
    let z1: String = nb_intdot_movimm(z0, 0, 0 - 160);
    let z2: String = nb_intdot_movimm(z1, 0, 0 - 168);
    let z3: String = nb_intdot_movimm(z2, 0, 0 - 176);
    let z4: String = nb_intdot_movimm(z3, 0, 0 - 184);
    let z5: String = nb_intdot_movimm(z4, 0, 0 - 192);
    let z6: String = nb_intdot_movimm(z5, 0, 0 - 200);
    let z7: String = nb_intdot_movimm(z6, 0, 0 - 208);
    // --- inner main dot loop over i in 0..ve(-264) step 8 ---
    let m0: String = nb_intdot_movimm(z7, 0, 0 - 32);
    let m_hdr: i64 = string_len(m0);
    let mc1: String = nb_load_rax(m0, 0 - 32);
    let mc2: String = nb_cmp_rax_mem(mc1, nb_setcc_opcode(op_lt()), 0 - 264);
    let mc3: String = nb_store_rax(mc2, 0 - 80);
    let mcj: String = nb_emit_cmp_je_zero(mc3, 0 - 80, jmps, jcell);
    let m_je: i64 = __mind_load_i64(jcell) - 1;
    let mb: String = nb_f32dot_main_body(mcj);
    let mjb: String = nb_emit_jmp(mb, jmps, jcell);
    let m_bk: i64 = __mind_load_i64(jcell) - 1;
    let _mp1: i64 = nb_jmp_set_target(jmps, jcell, m_bk, m_hdr);
    let m_end: i64 = string_len(mjb);
    let _mp2: i64 = nb_jmp_set_target(jmps, jcell, m_je, m_end);
    // Pinned left-to-right horizontal fold -> sslot(-216).
    let fld: String = nb_f32dot_fold(mjb);
    // result bits: movss xmm0,[sslot] ; movd eax,xmm0 ; store rax -> result.
    let r0: String = nb_fp_movss_load_xmm0(fld, 0 - 216);
    let r1: String = nb_fp_movd_eax_xmm0(r0);
    let r2: String = nb_store_rax(r1, 0 - 224);
    // write(1, &result, 4) — fd/bufaddr/count set in consts.
    let w1: String = nb_emit_write(r2, 0 - 232, 0 - 240, 0 - 248);
    // r += 1.
    let u1: String = nb_load_rax(w1, 0 - 288);
    let u2: String = nb_arith_rax_mem(u1, op_add(), 0 - 88);
    let u3: String = nb_store_rax(u2, 0 - 288);
    // back edge to the outer header.
    let ojb: String = nb_emit_jmp(u3, jmps, jcell);
    let o_bk: i64 = __mind_load_i64(jcell) - 1;
    let _op1: i64 = nb_jmp_set_target(jmps, jcell, o_bk, o_hdr);
    let o_end: i64 = string_len(ojb);
    let _op2: i64 = nb_jmp_set_target(jmps, jcell, o_je, o_end);
    ojb
}

// STEP: emit an ET_EXEC that (1) LCG-generates W[m*n] then x[n] as f32 (fresh
// seed 0xDEADBEEF, the SAME make_matvec_f32 the canary uses), (2) for each row r
// computes y[r] = strict-FP dot of W[r,:] . x with the S8 pinned 8-lane fold,
// (3) writes each y[r]'s 4 LE bit-bytes to stdout in row-major order. Byte-
// identical to the MLIR canary matmul-f32-v (64x64, seed 0xDEADBEEF). NEW export
// never reached during self-compile — the integer+float native-ELF oracle stays
// byte-identical.
pub fn selftest_native_elf_matmul_f32_v(m: i64, n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 131072);
    let kc: String = nb_f32matmul_consts(p0, m, n);
    let jmps: i64 = __mind_alloc(64 * 8 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let gens: String = nb_f32matmul_gen_loops(kc, n, jmps, jcell);
    let rows: String = nb_f32matmul_row_loop(gens, jmps, jcell);
    // exit(0).
    let e1: String = nb_intdot_movimm(rows, 0, 0 - 256);
    let e2: String = nb_load_rax(e1, 0 - 256);
    let code: String = nb_emit_return(e2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// movq rax, xmm0 = 66 48 0F 7E C0 (f64 bits -> rax, all 64 bits; the REX.W=0x48
// widens the movd form 66 0F 7E C0 to a full quadword, so the 8-LE-byte store ==
// `to_bits() as i64` of the scalar double — u64 pattern reinterpreted, no zero-ext).
pub fn nb_fp_movq_rax_xmm0(code: String) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 126);
    nb_push(c4, 192)
}

// STEP (RI-B2 f64 rung, #108): emit a runnable x86-64 ET_EXEC that reproduces the
// cross-substrate canary scalar-float-f64 — the strict-IEEE scalar chain
// `a + b - c * d / a` (ref_scalar_f64_chain), fixed source precedence, NO
// contraction: the operation tree is t1=a+b, t2=c*d, t3=t2/a, t4=t1-t3. Each of
// a,b,c,d is a compile-time f64 bit-pattern spilled to a stack slot; the chain runs
// entirely through the RI-B1 memory-operand SSE2 f64 encoders (movsd load/store,
// addsd/mulsd/divsd/subsd on [rbp+disp]), then movq rax,xmm0 lifts the result's
// 64-bit pattern and writes its 8 LE bit-bytes (`to_bits() as i64`) to stdout.
// The Python oracle sha256's those 8 bytes and asserts == the committed canary
// scalar-float-f64 hash — byte-identity to the MLIR canary, unfused, zero MLIR/LLVM.
// NEW export, never reached during self-compile: the integer+float native-ELF
// oracle stays byte-identical. Slots: a=0 b=1 c=2 d=3 t1=4 t3=5 (nb_slot_disp);
// result=-64 bufaddr=-72 fd=-80 count=-88 exit=-96.
pub fn selftest_native_elf_scalar_f64(a_bits: i64, b_bits: i64, c_bits: i64, d_bits: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 256);
    // Spill the four constants to slots 0..3.
    let s0: String = nb_fp_const_xmm(p0, a_bits, 0);
    let s1: String = nb_fp_movsd_store_xmm0(s0, nb_slot_disp(0));
    let s2: String = nb_fp_const_xmm(s1, b_bits, 0);
    let s3: String = nb_fp_movsd_store_xmm0(s2, nb_slot_disp(1));
    let s4: String = nb_fp_const_xmm(s3, c_bits, 0);
    let s5: String = nb_fp_movsd_store_xmm0(s4, nb_slot_disp(2));
    let s6: String = nb_fp_const_xmm(s5, d_bits, 0);
    let s7: String = nb_fp_movsd_store_xmm0(s6, nb_slot_disp(3));
    // t1 = a + b  ->  slot4.
    let a0: String = nb_fp_movsd_load_xmm0(s7, nb_slot_disp(0));
    let a1: String = nb_fp_binop_xmm0_mem(a0, 0, nb_slot_disp(1));
    let a2: String = nb_fp_movsd_store_xmm0(a1, nb_slot_disp(4));
    // t3 = (c * d) / a  ->  slot5.
    let m0: String = nb_fp_movsd_load_xmm0(a2, nb_slot_disp(2));
    let m1: String = nb_fp_binop_xmm0_mem(m0, 2, nb_slot_disp(3));
    let m2: String = nb_fp_binop_xmm0_mem(m1, 3, nb_slot_disp(0));
    let m3: String = nb_fp_movsd_store_xmm0(m2, nb_slot_disp(5));
    // t4 = t1 - t3  (result in xmm0).
    let r0: String = nb_fp_movsd_load_xmm0(m3, nb_slot_disp(4));
    let r1: String = nb_fp_binop_xmm0_mem(r0, 1, nb_slot_disp(5));
    // movq rax,xmm0 ; store ; write(1, &result, 8) ; exit(0).
    let q0: String = nb_fp_movq_rax_xmm0(r1);
    let q1: String = nb_store_rax(q0, 0 - 64);
    let w0: String = nb_intdot_lea(q1, 0 - 64, 0 - 72);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 80);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 88);
    let w3: String = nb_emit_write(w2, 0 - 80, 0 - 72, 0 - 88);
    let z0: String = nb_intdot_movimm(w3, 0, 0 - 96);
    let z1: String = nb_load_rax(z0, 0 - 96);
    let code: String = nb_emit_return(z1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// Phase C1-remainder f32 scalar rung — native-ELF SINGLE-precision scalar chain.
// `selftest_native_elf_scalar_f32(a_bits,b_bits,c_bits,d_bits)` (each arg carries a
// 32-bit f32 pattern zero-extended into i64) emits a runnable x86-64 ET_EXEC that
// computes the strict-source-precedence, unfused chain `a + b - c * d / a` entirely
// in SINGLE precision via the F3-prefix scalar-single encoders:
//   movss load/store (nb_fp_movss_*), addss/subss/mulss/divss (nb_fp_ss_binop_mem),
//   each intermediate rounded to f32. The result is then round-tripped f32->f64->f32
//   (cvtss2sd ; cvtsd2ss) — value-preserving, so it exercises the new narrowing
//   nb_fp_cvtsd2ss_xmm0 while leaving the single-rounded result unchanged — and
//   truncated to a signed i64 (nb_fp_cvttss2si_rax). Output is 12 bytes:
//     [0..8]  = (i64) trunc(result)          (LE, cvttss2si)
//     [8..12] = result.to_bits()             (LE, movd eax,xmm0)
// CPU-as-oracle only: the deleted Rust native backend rejected ConstF64, so there is
// NO byte-oracle for scalar float native emission (unlike the int/control-flow path);
// the smoke checks execution-correctness against numpy.float32 single-precision.
// NEW export, never reached during self-compile (main.mind is float-free) -> the
// integer + f64 native-ELF oracle stays byte-identical (additivity).
// Slot map (frame 256): a=slot0(-8) b=slot1(-16) c=slot2(-24) d=slot3(-32)
//   t1=slot4(-40) t3=slot5(-48) ; buffer: trunc_i64=[rbp-64] f32_bits=[rbp-56]
//   ; scratch bufptr=-72 fd=-80 count=-88 exit=-96.
pub fn selftest_native_elf_scalar_f32(a_bits: i64, b_bits: i64, c_bits: i64, d_bits: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 256);
    // Spill the four f32 constants to slots 0..3 (movss writes the low 4 bytes).
    let s0: String = nb_fp_const_xmm(p0, a_bits, 0);
    let s1: String = nb_fp_movss_store_xmm0(s0, nb_slot_disp(0));
    let s2: String = nb_fp_const_xmm(s1, b_bits, 0);
    let s3: String = nb_fp_movss_store_xmm0(s2, nb_slot_disp(1));
    let s4: String = nb_fp_const_xmm(s3, c_bits, 0);
    let s5: String = nb_fp_movss_store_xmm0(s4, nb_slot_disp(2));
    let s6: String = nb_fp_const_xmm(s5, d_bits, 0);
    let s7: String = nb_fp_movss_store_xmm0(s6, nb_slot_disp(3));
    // t1 = a + b  ->  slot4.
    let a0: String = nb_fp_movss_load_xmm0(s7, nb_slot_disp(0));
    let a1: String = nb_fp_ss_binop_mem(a0, 0, nb_slot_disp(1));
    let a2: String = nb_fp_movss_store_xmm0(a1, nb_slot_disp(4));
    // t3 = (c * d) / a  ->  slot5.
    let m0: String = nb_fp_movss_load_xmm0(a2, nb_slot_disp(2));
    let m1: String = nb_fp_ss_binop_mem(m0, 2, nb_slot_disp(3));
    let m2: String = nb_fp_ss_binop_mem(m1, 3, nb_slot_disp(0));
    let m3: String = nb_fp_movss_store_xmm0(m2, nb_slot_disp(5));
    // t4 = t1 - t3  (single-rounded result in xmm0).
    let r0: String = nb_fp_movss_load_xmm0(m3, nb_slot_disp(4));
    let r1: String = nb_fp_ss_binop_mem(r0, 1, nb_slot_disp(5));
    // Round-trip f32->f64->f32 (exercises the new cvtsd2ss; value preserved).
    let rt0: String = nb_fp_cvtss2sd_xmm0(r1);
    let rt1: String = nb_fp_cvtsd2ss_xmm0(rt0);
    // Store the f32 result bits into the buffer high 4 bytes ([rbp-56]).
    let b0: String = nb_fp_movss_store_xmm0(rt1, 0 - 56);
    // Truncate f32 -> i64 (new cvttss2si); store into buffer low 8 bytes ([rbp-64]).
    let tc0: String = nb_fp_movss_load_xmm0(b0, 0 - 56);
    let tc1: String = nb_fp_cvttss2si_rax(tc0);
    let tc2: String = nb_store_rax(tc1, 0 - 64);
    // write(1, &buf, 12) ; exit(0).
    let w0: String = nb_intdot_lea(tc2, 0 - 64, 0 - 72);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 80);
    let w2: String = nb_intdot_movimm(w1, 12, 0 - 88);
    let w3: String = nb_emit_write(w2, 0 - 80, 0 - 72, 0 - 88);
    let z0: String = nb_intdot_movimm(w3, 0, 0 - 96);
    let z1: String = nb_load_rax(z0, 0 - 96);
    let code: String = nb_emit_return(z1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2 scalar-cast-conv rung (#108) — native-ELF int<->float `as`-cast chain,
// byte-identical to the MLIR canary scalar-cast-conv. Reproduces ref_scalar_cast_conv:
// six SATURATING float->i64 edges (9.7->9, 1e30->INT64_MAX, -1e30->INT64_MIN,
// NaN->0, +inf->INT64_MAX, -inf->INT64_MIN), int->f64->i64 (b0), int->f32->i64 (b1,
// the f32 rounding: 16777219 -> 16777220), bool->f64->i64 (b2 = (inr<povf) -> 1),
// folded in FIXED source order into one i64 via the wrapping polynomial
// acc = acc*1000003 + term (two's-complement imul/add), then its 8 LE bytes written.
//
// SATURATING float->i64 is BRANCHLESS SSE2 (nb_sat_f64_to_i64): raw = cvttsd2si(x)
// (INT64_MIN sentinel for +ovf/-ovf/+inf/-inf/NaN; note -ovf and -inf ALREADY give
// the correct INT64_MIN). Two masks fix the rest: mpos = (2^63 <= x) ? -1 : 0
// (cmplesd, ordered -> false for NaN, true for +inf) and mnan = (x unord x) ? -1 : 0
// (cmpunordsd). result = raw ^ ((raw ^ INT64_MAX) & mpos) then & ~mnan (spelled
// result ^ (result & mnan)) -> NaN->0, +ovf/+inf->INT64_MAX, -ovf/-inf->INT64_MIN,
// in-range->raw. Built only from IEEE-defined ops, so byte-identical to the MLIR
// canary result. b1 widens f32->f64 (cvtss2sd) then reuses the SAME f64 saturator
// (widening is exact, value in range). NEW export, never reached during self-compile:
// the integer+float native-ELF oracle stays byte-identical.
// Slot map (frame 512): inr=-8 povf=-16 novf=-24 nan=-32 pinf=-40 ninf=-48
//   n_int=-56 INT64_MAX=-72 K=-80 ONE=-88 raw=-96 mpos=-104 mnan=-112 term=-120
//   acc=-128 result=-136 bufaddr=-144 fd=-152 count=-160 exit=-168 tmp_f64=-176.
// ============================================================================

// cvtsi2sd xmm0, qword [rbp+disp32] = F2 48 0F 2A 85 <disp32> (signed i64 -> f64).
pub fn nb_fp_cvtsi2sd_mem(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 42);
    let c5: String = nb_push(c4, 133);
    nb_i32le_signed(c5, disp)
}

// cvtss2sd xmm0, xmm0 = F3 0F 5A C0 (widen f32 -> f64, exact).
pub fn nb_fp_cvtss2sd_xmm0(code: String) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 90);
    nb_push(c3, 192)
}

// cvtsd2ss xmm0, xmm0 = F2 0F 5A C0 (narrow f64 -> f32, single-rounded). Mirrors
// the widening nb_fp_cvtss2sd_xmm0 with the F2 (double-src) prefix. Used to
// materialize an f32 value from an f64 const and for an `x as f32` cast.
pub fn nb_fp_cvtsd2ss_xmm0(code: String) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 90);
    nb_push(c3, 192)
}

// cvttss2si rax, xmm0 = F3 48 0F 2C C0 (truncate f32 -> signed i64, toward zero).
// The scalar-single counterpart of cvttsd2si; used for an `f32 as i64` cast.
pub fn nb_fp_cvttss2si_rax(code: String) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 44);
    nb_push(c4, 192)
}

// cmpsd xmm{which}, [rbp+disp32], imm8 = F2 0F C2 <modrm> <disp32> <imm8>.
// modrm 0x85 (xmm0) / 0x8D (xmm1); pred 1=LT 2=LE 3=UNORD (SSE2 ordered set).
// Result lane = all-ones (predicate true) or 0 — the branchless select mask.
pub fn nb_fp_cmpsd_mem(code: String, which: i64, disp: i64, pred: i64) -> String {
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 194);
    let modrm: i64 = if which == 0 {
        133
    } else {
        141
    };
    let c4: String = nb_push(c3, modrm);
    let c5: String = nb_i32le_signed(c4, disp);
    nb_push(c5, pred)
}

// movq rax, xmm1 = 66 48 0F 7E C8 (lift the mask lane from xmm1 to a gpr).
pub fn nb_fp_movq_rax_xmm1(code: String) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 126);
    nb_push(c4, 200)
}

// Branchless SATURATING f64->i64 (Rust `as` / LLVM fptosi.sat semantics) of the
// double in slot x_disp, writing the i64 to out_disp. Scratch: raw=-96 mpos=-104
// mnan=-112 (reused each call); consts INT64_MAX=-72 + the 2^63 f64 immediate.
pub fn nb_sat_f64_to_i64(code: String, x_disp: i64, out_disp: i64) -> String {
    // raw = cvttsd2si(x)  (INT64_MIN sentinel on overflow/nan).
    let a1: String = nb_fp_movsd_load_xmm0(code, x_disp);
    let a2: String = nb_fp_trunc_rax_xmm0(a1);
    let a3: String = nb_store_rax(a2, 0 - 96);
    // mpos = (2^63 <= x) ? -1 : 0   [xmm1 = 2^63 ; cmplesd xmm1, [x]].
    let b1: String = nb_fp_const_xmm(a3, 4890909195324358656, 1);
    let b2: String = nb_fp_cmpsd_mem(b1, 1, x_disp, 2);
    let b3: String = nb_fp_movq_rax_xmm1(b2);
    let b4: String = nb_store_rax(b3, 0 - 104);
    // mnan = (x unord x) ? -1 : 0   [cmpunordsd xmm0, [x]].
    let c1: String = nb_fp_movsd_load_xmm0(b4, x_disp);
    let c2: String = nb_fp_cmpsd_mem(c1, 0, x_disp, 3);
    let c3: String = nb_fp_movq_rax_xmm0(c2);
    let c4: String = nb_store_rax(c3, 0 - 112);
    // result = raw ^ ((raw ^ INT64_MAX) & mpos).
    let d1: String = nb_load_rax(c4, 0 - 96);
    let d2: String = nb_arith_rax_mem(d1, op_bitxor(), 0 - 72);
    let d3: String = nb_arith_rax_mem(d2, op_bitand(), 0 - 104);
    let d4: String = nb_arith_rax_mem(d3, op_bitxor(), 0 - 96);
    let d5: String = nb_store_rax(d4, out_disp);
    // result = result & ~mnan   (spelled result ^ (result & mnan)).
    let e1: String = nb_load_rax(d5, out_disp);
    let e2: String = nb_arith_rax_mem(e1, op_bitand(), 0 - 112);
    let e3: String = nb_store_rax(e2, 0 - 96);
    let e4: String = nb_load_rax(e3, out_disp);
    let e5: String = nb_arith_rax_mem(e4, op_bitxor(), 0 - 96);
    nb_store_rax(e5, out_disp)
}

// One wrapping-polynomial fold step: acc = acc*K + term  (K=-80, term=-120,
// acc=-128). imul/add wrap in two's complement, matching arith.muli/arith.addi.
pub fn nb_cast_fold(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 128);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 80);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 120);
    nb_store_rax(a3, 0 - 128)
}

// Emit an ET_EXEC that reproduces ref_scalar_cast_conv over the six f64 edge bit
// patterns + the int source n (all emit-time args, spilled to runtime slots so the
// conversions provably execute), folds the nine cast results in fixed source order,
// and writes the 8 LE bytes of the folded i64 to stdout. n baked at emit time.
pub fn selftest_native_elf_scalar_cast_conv(inr_bits: i64, povf_bits: i64, novf_bits: i64, nan_bits: i64, pinf_bits: i64, ninf_bits: i64, n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 512);
    // Spill the six edge f64 bit patterns to slots -8..-48.
    let s0: String = nb_fp_const_xmm(p0, inr_bits, 0);
    let s1: String = nb_fp_movsd_store_xmm0(s0, 0 - 8);
    let s2: String = nb_fp_const_xmm(s1, povf_bits, 0);
    let s3: String = nb_fp_movsd_store_xmm0(s2, 0 - 16);
    let s4: String = nb_fp_const_xmm(s3, novf_bits, 0);
    let s5: String = nb_fp_movsd_store_xmm0(s4, 0 - 24);
    let s6: String = nb_fp_const_xmm(s5, nan_bits, 0);
    let s7: String = nb_fp_movsd_store_xmm0(s6, 0 - 32);
    let s8: String = nb_fp_const_xmm(s7, pinf_bits, 0);
    let s9: String = nb_fp_movsd_store_xmm0(s8, 0 - 40);
    let s10: String = nb_fp_const_xmm(s9, ninf_bits, 0);
    let s11: String = nb_fp_movsd_store_xmm0(s10, 0 - 48);
    // n integer + constants (INT64_MAX, K, ONE).
    let k0: String = nb_intdot_movimm(s11, n, 0 - 56);
    let k1: String = nb_intdot_movimm(k0, 9223372036854775807, 0 - 72);
    let k2: String = nb_intdot_movimm(k1, 1000003, 0 - 80);
    let k3: String = nb_intdot_movimm(k2, 1, 0 - 88);
    // e0 = sat(inr) -> acc (fold seed).
    let e0: String = nb_sat_f64_to_i64(k3, 0 - 8, 0 - 128);
    // e1..e5 = sat(edge) -> term ; fold.
    let e1a: String = nb_sat_f64_to_i64(e0, 0 - 16, 0 - 120);
    let e1b: String = nb_cast_fold(e1a);
    let e2a: String = nb_sat_f64_to_i64(e1b, 0 - 24, 0 - 120);
    let e2b: String = nb_cast_fold(e2a);
    let e3a: String = nb_sat_f64_to_i64(e2b, 0 - 32, 0 - 120);
    let e3b: String = nb_cast_fold(e3a);
    let e4a: String = nb_sat_f64_to_i64(e3b, 0 - 40, 0 - 120);
    let e4b: String = nb_cast_fold(e4a);
    let e5a: String = nb_sat_f64_to_i64(e4b, 0 - 48, 0 - 120);
    let e5b: String = nb_cast_fold(e5a);
    // b0 = (n as f64) as i64 ; fold.
    let b0a: String = nb_fp_cvtsi2sd_mem(e5b, 0 - 56);
    let b0b: String = nb_fp_movsd_store_xmm0(b0a, 0 - 176);
    let b0c: String = nb_sat_f64_to_i64(b0b, 0 - 176, 0 - 120);
    let b0d: String = nb_cast_fold(b0c);
    // b1 = (n as f32) as i64 ; fold. cvtsi2ss -> widen f32->f64 -> sat.
    let b1a: String = nb_fp_cvtsi2ss_mem(b0d, 0 - 56);
    let b1b: String = nb_fp_cvtss2sd_xmm0(b1a);
    let b1c: String = nb_fp_movsd_store_xmm0(b1b, 0 - 176);
    let b1d: String = nb_sat_f64_to_i64(b1c, 0 - 176, 0 - 120);
    let b1e: String = nb_cast_fold(b1d);
    // b2 = (inr < povf) as f64 as i64 ; fold. cmpltsd -> mask & 1 (bool round-trips).
    let b2a: String = nb_fp_movsd_load_xmm0(b1e, 0 - 8);
    let b2b: String = nb_fp_cmpsd_mem(b2a, 0, 0 - 16, 1);
    let b2c: String = nb_fp_movq_rax_xmm0(b2b);
    let b2d: String = nb_arith_rax_mem(b2c, op_bitand(), 0 - 88);
    let b2e: String = nb_store_rax(b2d, 0 - 120);
    let b2f: String = nb_cast_fold(b2e);
    // result = acc -> write(1, &result, 8) ; exit(0).
    let r0: String = nb_load_rax(b2f, 0 - 128);
    let r1: String = nb_store_rax(r0, 0 - 136);
    let w0: String = nb_intdot_lea(r1, 0 - 136, 0 - 144);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 152);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 160);
    let w3: String = nb_emit_write(w2, 0 - 152, 0 - 144, 0 - 160);
    let z0: String = nb_intdot_movimm(w3, 0, 0 - 168);
    let z1: String = nb_load_rax(z0, 0 - 168);
    let code: String = nb_emit_return(z1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2 L1-Q16 rung (#108) — native-ELF Q16.16 L1 distance, byte-identical to the
// MLIR canary dot-l1-q16 (len 65536, seed 0xDEADBEEF). Shares the S4 Q16 LCG
// generator (nb_q16gen_body VERBATIM — identical a[]/b[] i32 element streams) and
// the whole intdot_q16 driver; the ONLY change is the reduction body: instead of
// per-product `(sext a * sext b) >> 16`, each term is `|sext(a[i]) - sext(b[i])|`
// summed into a full i64 accumulator, then narrowed ONCE to i32 (movsxd — the
// canary's `acc as i32`) and the 8 LE bytes written to stdout.
//
// ABS is BRANCHLESS integer, reusing the existing single-instruction encoders (no
// new opcode): d = a - b (48 2B, op_sub) ; t = d SAR 63 (op_shr IS arithmetic sar
// rax,cl — the sign mask, 0 for d>=0, -1 for d<0) ; abs = (d ^ t) - t (op_bitxor
// 48 33, then op_sub). For d>=0: t=0 -> abs=d; for d<0: t=-1 -> (~d)+1 = -d. Exact
// integer add is associative/commutative so the sum is grouping-/substrate-
// independent (RFC 0015 §3.1), byte-identical to the MLIR canary.
// Slots reuse the S4 Q16 map; two NEW scratch slots below the exit slot:
//   sixty_three = -1048760 (SAR count constant) ; t_mask = -1048768 (sign mask).
// ============================================================================

// One L1-Q16 reduction body: aval = movsxd dword a[baseA + i*8] ; bval = movsxd
// dword b[baseB + i*8] ; d = aval - bval ; t = d SAR 63 ; abs = (d ^ t) - t ;
// acc += abs ; i += 1. NO >>16 rescale (L1 is |a-b|, not a Q16 product).
pub fn nb_q16l1_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048608);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048616);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048656);
    let a4: String = nb_store_rax(a3, 0 - 1048672);
    let a5: String = nb_emit_load_i32_sx(a4, 0 - 1048672);
    let a6: String = nb_store_rax(a5, 0 - 1048680);
    let b1: String = nb_load_rax(a6, 0 - 1048608);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 1048616);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 1048664);
    let b4: String = nb_store_rax(b3, 0 - 1048672);
    let b5: String = nb_emit_load_i32_sx(b4, 0 - 1048672);
    let b6: String = nb_store_rax(b5, 0 - 1048688);
    // d = aval - bval  ->  prod slot -1048696.
    let c1: String = nb_load_rax(b6, 0 - 1048680);
    let c2: String = nb_arith_rax_mem(c1, op_sub(), 0 - 1048688);
    let c3: String = nb_store_rax(c2, 0 - 1048696);
    // t = d SAR 63  ->  t_mask slot -1048768.
    let m1: String = nb_load_rax(c3, 0 - 1048696);
    let m2: String = nb_arith_rax_mem(m1, op_shr(), 0 - 1048760);
    let m3: String = nb_store_rax(m2, 0 - 1048768);
    // abs = (d ^ t) - t  ->  prod slot -1048696.
    let x1: String = nb_load_rax(m3, 0 - 1048696);
    let x2: String = nb_arith_rax_mem(x1, op_bitxor(), 0 - 1048768);
    let x3: String = nb_arith_rax_mem(x2, op_sub(), 0 - 1048768);
    let x4: String = nb_store_rax(x3, 0 - 1048696);
    // acc += abs.
    let d1: String = nb_load_rax(x4, 0 - 1048632);
    let d2: String = nb_arith_rax_mem(d1, op_add(), 0 - 1048696);
    let d3: String = nb_store_rax(d2, 0 - 1048632);
    // i += 1.
    let e1: String = nb_load_rax(d3, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048648);
    nb_store_rax(e2, 0 - 1048608)
}

// Emit an ET_EXEC that generates a[0..n]/b[0..n] via the EXACT Q16.16 LCG (shared
// with intdot_q16), computes acc = Sum |sext(a[i]) - sext(b[i])| in a full i64
// accumulator, narrows ONCE to i32 (the canary's `acc as i32`), and writes the 8
// LE bytes of the result to stdout. n baked at emit time (canary uses 65536).
// NEW export, never reached during self-compile: the integer+float native-ELF
// oracle stays byte-identical.
pub fn selftest_native_elf_dot_l1_q16(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 1048592);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 1048600);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 1048616);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 1048648);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 1048704);
    let k5b: String = nb_intdot_movimm(k5, 44, 0 - 1048712);
    let k6: String = nb_intdot_movimm(k5b, 3735928559, 0 - 1048584);
    let k7: String = nb_intdot_movimm(k6, 0, 0 - 1048632);
    let k8: String = nb_intdot_movimm(k7, n, 0 - 1048624);
    // SAR count constant for the branchless abs.
    let k9: String = nb_intdot_movimm(k8, 63, 0 - 1048760);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k9, 0 - 1048576, 0 - 1048656);
    let bb: String = nb_intdot_lea(ba, 0 - 524288, 0 - 1048664);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- generate A[0..n] (base slot -1048656) ---
    let ga0: String = nb_intdot_movimm(bb, 0, 0 - 1048608);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 1048608);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gac3: String = nb_store_rax(gac2, 0 - 1048640);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 1048640, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_q16gen_body(gacj, 0 - 1048656);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..n] (base slot -1048664), LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 1048608);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 1048608);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gbc3: String = nb_store_rax(gbc2, 0 - 1048640);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 1048640, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_q16gen_body(gbcj, 0 - 1048664);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    // --- L1 loop: acc = Sum |sext(a[i]) - sext(b[i])| ---
    let d0: String = nb_intdot_movimm(gbjb, 0, 0 - 1048608);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 1048608);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let dc3: String = nb_store_rax(dc2, 0 - 1048640);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 1048640, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_q16l1_body(dcj);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Narrow ONCE to i32 and sign-extend to i64 (the canary's `acc as i32`).
    let t1: String = nb_load_rax(djb, 0 - 1048632);
    let t2: String = nb_movsxd_rax_eax(t1);
    let t3: String = nb_store_rax(t2, 0 - 1048720);
    // write(1, &result, 8).
    let t4: String = nb_intdot_lea(t3, 0 - 1048720, 0 - 1048736);
    let t5: String = nb_intdot_movimm(t4, 1, 0 - 1048728);
    let t6: String = nb_intdot_movimm(t5, 8, 0 - 1048744);
    let t7: String = nb_emit_write(t6, 0 - 1048728, 0 - 1048736, 0 - 1048744);
    // exit(0).
    let t8: String = nb_intdot_movimm(t7, 0, 0 - 1048752);
    let t9: String = nb_load_rax(t8, 0 - 1048752);
    let code: String = nb_emit_return(t9, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S10 (#108) — native-ELF PACKED-SIMD (SSE2/SSE4.1, 128-bit) Q16.16
// DOT-PRODUCT, byte-identical to the SAME MLIR canary dot-l2-q16 = 1d7f272b the
// scalar S4 rung hit. Opens the SIMD tier: the pure-MIND native-ELF backend emits
// VECTOR SIMD whose i64 result is byte-identical to the scalar/MLIR value —
// deterministic SIMD, zero LLVM.
//
// WHY it is byte-identical: integer add is associative/commutative (mod 2^64) and
// the per-product Q16 rescale `>>16` is arithmetic (SAR) applied PER PRODUCT — the
// SAME per-product as scalar. So a 2-wide lane-accumulate (paddq) followed by a
// horizontal reduce (pshufd 0x4E + paddq) yields the IDENTICAL i64 as the scalar
// sequential accumulate, then `acc as i32` (movsxd) narrows identically. No specific
// MLIR SIMD idiom is matched instruction-for-instruction — only the i64 VALUE.
//
// LAYOUT TRICK: the S4 Q16 generator (nb_q16gen_body, reused VERBATIM) stores each
// i32 element SIGN-EXTENDED to a full 8-byte cell (base + i*8). So one movdqu of 16
// bytes loads TWO consecutive cells = [elem_i(i64), elem_{i+1}(i64)] with the two
// elements already in dword lanes 0 and 2. PMULDQ (SSE4.1, 66 0F 38 28) reads
// exactly signed dword lanes 0 and 2, sign-extends and multiplies -> two i64
// products [a_i*b_i, a_{i+1}*b_{i+1}] in one instruction (each element fits i32, so
// dword-lane sign == cell sign). No repack, no separate widening load.
//
// ARITHMETIC >>16 on 64-bit lanes: SSE2/4.1 has no psraq. Emulated per lane as
// (x >>_logical 16) | (signmask << 48): movdqa copy ; pshufd 0xF5 (broadcast each
// qword's high dword into both its halves) ; psrad 31 (each 64-bit lane -> all-ones
// iff negative) ; psrlq 16 on x (logical) ; psllq 48 on the mask (top 16 bits set
// iff negative) ; por. Verified equal to the signed arithmetic shift for every sign.
//
// Slots reuse the S4 Q16 map; ONE new scratch slot below the exit slot:
//   two = -1048768 (loop stride, i += 2 per SIMD iteration).
// n=65536 is divisible by 2, so no scalar remainder is needed.
// NEW export, never reached during self-compile: the integer+float native-ELF
// oracle stays byte-identical.
// ============================================================================

// ---- packed-int SSE encoders (all 66/F3-prefix; xmm reg number args) ----------

// movdqu xmm{r}, [rax]  =  F3 0F 6F <(r<<3)|0>   (128-bit unaligned load, reg-indirect).
pub fn nb_simd_movdqu_ld_rax(code: String, r: i64) -> String {
    let c1: String = nb_push(code, 243);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 111);
    nb_push(c3, r * 8)
}

// pxor xmm{d}, xmm{s}  =  66 0F EF <0xC0|(d<<3)|s>   (zero an accumulator: pxor r,r).
pub fn nb_simd_pxor(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 239);
    nb_push(c3, 192 + d * 8 + s)
}

// movdqa xmm{d}, xmm{s}  =  66 0F 6F <0xC0|(d<<3)|s>   (reg-reg 128-bit copy).
pub fn nb_simd_movdqa(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 111);
    nb_push(c3, 192 + d * 8 + s)
}

// pmuldq xmm{d}, xmm{s}  =  66 0F 38 28 <0xC0|(d<<3)|s>   (SSE4.1 3-byte escape:
// signed 32x32->64 of dword lanes 0 and 2 -> two i64 in lanes 0 and 1).
pub fn nb_simd_pmuldq(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 56);
    let c4: String = nb_push(c3, 40);
    nb_push(c4, 192 + d * 8 + s)
}

// paddq xmm{d}, xmm{s}  =  66 0F D4 <0xC0|(d<<3)|s>   (packed i64 add, per 64-bit lane).
pub fn nb_simd_paddq(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 212);
    nb_push(c3, 192 + d * 8 + s)
}

// por xmm{d}, xmm{s}  =  66 0F EB <0xC0|(d<<3)|s>   (bitwise OR, 128-bit).
pub fn nb_simd_por(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 235);
    nb_push(c3, 192 + d * 8 + s)
}

// pshufd xmm{d}, xmm{s}, imm8  =  66 0F 70 <0xC0|(d<<3)|s> <imm8>   (dword shuffle).
pub fn nb_simd_pshufd(code: String, d: i64, s: i64, imm: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 112);
    let c4: String = nb_push(c3, 192 + d * 8 + s);
    nb_push(c4, imm)
}

// psrad xmm{r}, imm8  =  66 0F 72 /4 <0xE0|r> <imm8>   (per-32-bit arithmetic shift right).
pub fn nb_simd_psrad(code: String, r: i64, imm: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 114);
    let c4: String = nb_push(c3, 224 + r);
    nb_push(c4, imm)
}

// psrlq xmm{r}, imm8  =  66 0F 73 /2 <0xD0|r> <imm8>   (per-64-bit LOGICAL shift right).
pub fn nb_simd_psrlq(code: String, r: i64, imm: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 115);
    let c4: String = nb_push(c3, 208 + r);
    nb_push(c4, imm)
}

// psllq xmm{r}, imm8  =  66 0F 73 /6 <0xF0|r> <imm8>   (per-64-bit shift left).
pub fn nb_simd_psllq(code: String, r: i64, imm: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 115);
    let c4: String = nb_push(c3, 240 + r);
    nb_push(c4, imm)
}

// movq rax, xmm{r}  =  66 48 0F 7E <0xC0|(r<<3)>   (lift a 64-bit lane to rax).
pub fn nb_simd_movq_rax_xmm(code: String, r: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 72);
    let c3: String = nb_push(c2, 15);
    let c4: String = nb_push(c3, 126);
    nb_push(c4, 192 + r * 8)
}

// Arithmetic >>16 of the two signed i64 lanes in xmm0 (scratch xmm2), result -> xmm0.
// (x >>_logical 16) | (per-lane-signmask << 48). See section header for the proof.
pub fn nb_simd_asr16_xmm0(code: String) -> String {
    let c1: String = nb_simd_movdqa(code, 2, 0);
    let c2: String = nb_simd_pshufd(c1, 2, 2, 245);
    let c3: String = nb_simd_psrad(c2, 2, 31);
    let c4: String = nb_simd_psrlq(c3, 0, 16);
    let c5: String = nb_simd_psllq(c4, 2, 48);
    nb_simd_por(c5, 0, 2)
}

// One packed-SIMD dot iteration over 2 elements (i, i+1) of the S4 stride-8 layout:
//   aptr = baseA + i*8 -> rax ; va = movdqu[rax]  (2 sign-ext i64 cells)
//   bptr = baseB + i*8 -> rax ; vb = movdqu[rax]
//   prod = pmuldq(va, vb)     ([a_i*b_i, a_{i+1}*b_{i+1}] as two i64)
//   prod = asr16(prod)        (per-product Q16 rescale, arithmetic)
//   acc(xmm7) += prod (paddq) ; i += 2.
pub fn nb_simd_q16dot_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 1048608);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 1048616);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 1048656);
    let a4: String = nb_simd_movdqu_ld_rax(a3, 0);
    let b1: String = nb_load_rax(a4, 0 - 1048608);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 1048616);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 1048664);
    let b4: String = nb_simd_movdqu_ld_rax(b3, 1);
    let p1: String = nb_simd_pmuldq(b4, 0, 1);
    let p2: String = nb_simd_asr16_xmm0(p1);
    let p3: String = nb_simd_paddq(p2, 7, 0);
    let e1: String = nb_load_rax(p3, 0 - 1048608);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 1048768);
    nb_store_rax(e2, 0 - 1048608)
}

// STEP A (de-risk): emit an ET_EXEC that runs the FULL packed-SIMD arithmetic core
// on a KNOWN 2-element input (no LCG, no loop): bake a=[100000,-30000], b=[-50000,
// -7000] as sign-extended 8-byte cells, movdqu-load both, pmuldq -> two i64
// products, asr16 per lane, paddq into a pxor-zeroed acc, horizontal reduce
// (pshufd 0x4E + paddq), movq to rax, narrow `as i32` (movsxd), write the 8 LE
// bytes. Proves movdqu-load, pmuldq, asr16 (movdqa/pshufd/psrad/psrlq/psllq/por),
// paddq/pxor, the horizontal reduce, and movq extract — everything Step B needs
// except the generation loop. The Python oracle recomputes ((a0*b0)>>16 +
// (a1*b1)>>16) as i32 and asserts byte-equality.
pub fn selftest_native_elf_simd_probe() -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 256);
    // a-cells contiguous at [rbp-32]=a0, [rbp-24]=a1 ; b-cells [rbp-64]=b0, [rbp-56]=b1.
    let s0: String = nb_intdot_movimm(p0, 100000, 0 - 32);
    let s1: String = nb_intdot_movimm(s0, 0 - 30000, 0 - 24);
    let s2: String = nb_intdot_movimm(s1, 0 - 50000, 0 - 64);
    let s3: String = nb_intdot_movimm(s2, 0 - 7000, 0 - 56);
    // acc = 0.
    let z0: String = nb_simd_pxor(s3, 7, 7);
    // va = movdqu [rbp-32] ; vb = movdqu [rbp-64]  (lea leaves the address in rax).
    let l1: String = nb_intdot_lea(z0, 0 - 32, 0 - 72);
    let m1: String = nb_simd_movdqu_ld_rax(l1, 0);
    let l2: String = nb_intdot_lea(m1, 0 - 64, 0 - 72);
    let m2: String = nb_simd_movdqu_ld_rax(l2, 1);
    // prod = asr16(pmuldq(va, vb)) ; acc += prod.
    let q1: String = nb_simd_pmuldq(m2, 0, 1);
    let q2: String = nb_simd_asr16_xmm0(q1);
    let q3: String = nb_simd_paddq(q2, 7, 0);
    // horizontal reduce lane0+lane1 -> rax ; narrow as i32.
    let h1: String = nb_simd_pshufd(q3, 2, 7, 78);
    let h2: String = nb_simd_paddq(h1, 7, 2);
    let h3: String = nb_simd_movq_rax_xmm(h2, 7);
    let h4: String = nb_movsxd_rax_eax(h3);
    let h5: String = nb_store_rax(h4, 0 - 80);
    // write(1, &result, 8) ; exit(0).
    let w0: String = nb_intdot_lea(h5, 0 - 80, 0 - 88);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 96);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 104);
    let w3: String = nb_emit_write(w2, 0 - 96, 0 - 88, 0 - 104);
    let e0: String = nb_intdot_movimm(w3, 0, 0 - 112);
    let e1: String = nb_load_rax(e0, 0 - 112);
    let code: String = nb_emit_return(e1, 1);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// STEP B: emit an ET_EXEC that (1) generates a[0..n] then b[0..n] via the EXACT S4
// Q16.16 LCG (nb_q16gen_body VERBATIM — identical i32 element streams, stride-8
// sign-extended cells), (2) computes acc = Sum (sext(a[i]) * sext(b[i])) >> 16 with
// a PACKED-SIMD 2-wide i64 lane accumulator (movdqu/pmuldq/asr16/paddq), (3)
// horizontally reduces the 2 lanes, narrows ONCE to i32 (movsxd — the canary's
// `acc as i32`), (4) writes the 8 LE bytes to stdout. Byte-identical to the MLIR
// canary dot-l2-q16. n baked at emit time (the canary uses 65536, divisible by 2).
pub fn selftest_native_elf_simd_dot_q16(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 1052672);
    // Constants (identical to S4).
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 1048592);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 1048600);
    let k3: String = nb_intdot_movimm(k2, 8, 0 - 1048616);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 1048648);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 1048704);
    let k5b: String = nb_intdot_movimm(k5, 44, 0 - 1048712);
    let k6: String = nb_intdot_movimm(k5b, 3735928559, 0 - 1048584);
    let k7: String = nb_intdot_movimm(k6, 0, 0 - 1048632);
    let k8: String = nb_intdot_movimm(k7, n, 0 - 1048624);
    // SIMD loop stride (i += 2 per packed iteration).
    let k9: String = nb_intdot_movimm(k8, 2, 0 - 1048768);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k9, 0 - 1048576, 0 - 1048656);
    let bb: String = nb_intdot_lea(ba, 0 - 524288, 0 - 1048664);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- generate A[0..n] (base slot -1048656) ---
    let ga0: String = nb_intdot_movimm(bb, 0, 0 - 1048608);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 1048608);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gac3: String = nb_store_rax(gac2, 0 - 1048640);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 1048640, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_q16gen_body(gacj, 0 - 1048656);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..n] (base slot -1048664), LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 1048608);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 1048608);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let gbc3: String = nb_store_rax(gbc2, 0 - 1048640);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 1048640, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_q16gen_body(gbcj, 0 - 1048664);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    // Zero the packed i64 accumulator (xmm7) before the dot loop.
    let pz: String = nb_simd_pxor(gbjb, 7, 7);
    // --- packed-SIMD dot loop: acc(xmm7) += [asr16(a_i*b_i), asr16(a_{i+1}*b_{i+1})] ---
    let d0: String = nb_intdot_movimm(pz, 0, 0 - 1048608);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 1048608);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 1048624);
    let dc3: String = nb_store_rax(dc2, 0 - 1048640);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 1048640, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_simd_q16dot_body(dcj);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Horizontal reduce the 2 i64 lanes -> rax, then narrow ONCE to i32.
    let r1: String = nb_simd_pshufd(djb, 2, 7, 78);
    let r2: String = nb_simd_paddq(r1, 7, 2);
    let r3: String = nb_simd_movq_rax_xmm(r2, 7);
    let t2: String = nb_movsxd_rax_eax(r3);
    let t3: String = nb_store_rax(t2, 0 - 1048720);
    // write(1, &result, 8).
    let t4: String = nb_intdot_lea(t3, 0 - 1048720, 0 - 1048736);
    let t5: String = nb_intdot_movimm(t4, 1, 0 - 1048728);
    let t6: String = nb_intdot_movimm(t5, 8, 0 - 1048744);
    let t7: String = nb_emit_write(t6, 0 - 1048728, 0 - 1048736, 0 - 1048744);
    // exit(0).
    let t8: String = nb_intdot_movimm(t7, 0, 0 - 1048752);
    let t9: String = nb_load_rax(t8, 0 - 1048752);
    let code: String = nb_emit_return(t9, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S11 (#108) — native-ELF PACKED-f32 SIMD (SSE, 128-bit) STRICT-FP
// DOT-PRODUCT, byte-identical to the SAME MLIR canary dot-f32-v = a132f7b9 the
// scalar S8 rung hit (len 4093, seed 0xDEADBEEF). The float SIMD rung: the
// pure-MIND native-ELF backend emits VECTOR packed-f32 SIMD whose f32 result is
// byte-identical to the scalar/MLIR value. Deterministic strict-FP SIMD, zero LLVM.
//
// WHY it is byte-identical: f32 add is NOT associative, so byte-identity rests on
// reproducing ref_dot_f32_strict's fold BIT-FOR-BIT. That fold is an 8-LANE
// accumulator: acc[lane] += a[i+lane]*b[i+lane] for lane 0..8, per block of 8, in
// increasing block order; then a PINNED left-to-right horizontal fold hs=acc[0];
// hs+=acc[1]..acc[7]; then a scalar tail. Packed mulps/addps apply the SAME
// per-lane IEEE round-to-nearest single mul/add as scalar mulss/addss, UNFUSED,
// with NO cross-lane interaction — so per lane the value stream is IDENTICAL to
// S8's scalar 8-lane accumulate.
//
// 8 LANES -> 2 XMM (SSE = 4 f32/XMM): acc_lo(xmm6)=lanes0..3, acc_hi(xmm7)=lanes4..7.
// Per block of 8: movups a[i..i+4]->xmm0, movups b[i..i+4]->xmm1, mulps xmm0,xmm1,
// addps acc_lo,xmm0 (lanes 0..3); then movups a[i+4..i+8]/b[i+4..i+8], mulps, addps
// acc_hi (lanes 4..7). movups is UNALIGNED (any address). XMM lane 0 = lowest
// address (little-endian) = a[i+0], lane 1 = a[i+1], ... — the lane map matches ref.
//
// LAYOUT: unlike the stride-8 Q16 SIMD (S10), packed movups needs 4 CONTIGUOUS
// f32, so the arrays are PACKED (stride 4). The S8 LCG gen (nb_f32gen_body) is
// reused VERBATIM with its stride slot -40 set to 4 (not 8) -> contiguous f32.
// The scalar tail (nb_f32dot_tail_body) is reused VERBATIM (it reads element i at
// base + i*(-40) = base + i*4, matching the packed layout, and folds into sslot).
//
// HORIZONTAL FOLD: movups-store acc_lo then acc_hi to 8 contiguous f32 scratch
// slots (-320..-292), then read them back with movss/addss left-to-right lane
// 0..7 (== ref's hs=acc[0]; hs+=acc[1]..acc[7]). Then the scalar tail (i in ve..n)
// continues from sslot with unfused mulss/addss. Result f32's 8 LE bit-bytes to
// stdout. n=4093 -> ve=(4093/8)*8=4088, tail = elements 4088..4093.
//
// NEW packed-f32 encoders (no prefix): movups load (0F 10), movups store (0F 11),
// mulps (0F 59), addps (0F 58). Reuses the S8 F3-prefix scalar-single family
// (movss/addss/mulss) for the fold + tail, and pxor (S10) to zero the two XMM accs
// (0.0f bits == 0). NEW export, never reached during self-compile: the integer +
// scalar-float native-ELF oracle stays byte-identical (additivity).
// ============================================================================

// movups xmm{r}, [rax]  =  0F 10 <(r<<3)|0>   (128-bit UNALIGNED packed-f32 load, reg-indirect).
pub fn nb_simd_movups_ld_rax(code: String, r: i64) -> String {
    let c1: String = nb_push(code, 15);
    let c2: String = nb_push(c1, 16);
    nb_push(c2, r * 8)
}

// movups [rax], xmm{r}  =  0F 11 <(r<<3)|0>   (128-bit UNALIGNED packed-f32 store, reg-indirect).
pub fn nb_simd_movups_st_rax(code: String, r: i64) -> String {
    let c1: String = nb_push(code, 15);
    let c2: String = nb_push(c1, 17);
    nb_push(c2, r * 8)
}

// mulps xmm{d}, xmm{s}  =  0F 59 <0xC0|(d<<3)|s>   (packed-f32 per-lane multiply, unfused).
pub fn nb_simd_mulps(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 15);
    let c2: String = nb_push(c1, 89);
    nb_push(c2, 192 + d * 8 + s)
}

// addps xmm{d}, xmm{s}  =  0F 58 <0xC0|(d<<3)|s>   (packed-f32 per-lane add).
pub fn nb_simd_addps(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 15);
    let c2: String = nb_push(c1, 88);
    nb_push(c2, 192 + d * 8 + s)
}

// One packed-f32 SIMD main-loop iteration over 8 elements (i..i+8):
//   acc_lo(xmm6) += a[i..i+4]*b[i..i+4]   (lanes 0..3)
//   acc_hi(xmm7) += a[i+4..i+8]*b[i+4..i+8]  (lanes 4..7)
//   i += 8.  Stride slot -40 = 4 (packed f32); baseA=-96, baseB=-104, i=-32, +8=-280.
pub fn nb_simd_f32dot_body(code: String) -> String {
    // lanes 0..3 -> acc_lo (xmm6)
    let a1: String = nb_load_rax(code, 0 - 32);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 40);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 96);
    let a4: String = nb_simd_movups_ld_rax(a3, 0);
    let b1: String = nb_load_rax(a4, 0 - 32);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 40);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 104);
    let b4: String = nb_simd_movups_ld_rax(b3, 1);
    let m1: String = nb_simd_mulps(b4, 0, 1);
    let lo: String = nb_simd_addps(m1, 6, 0);
    // lanes 4..7 -> acc_hi (xmm7); addresses += 16 bytes (4 f32)
    let c1: String = nb_load_rax(lo, 0 - 32);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 40);
    let c3: String = nb_arith_rax_mem(c2, op_add(), 0 - 96);
    let c4: String = nb_fp_add_rax_imm(c3, 16);
    let c5: String = nb_simd_movups_ld_rax(c4, 0);
    let d1: String = nb_load_rax(c5, 0 - 32);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 40);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 104);
    let d4: String = nb_fp_add_rax_imm(d3, 16);
    let d5: String = nb_simd_movups_ld_rax(d4, 1);
    let m2: String = nb_simd_mulps(d5, 0, 1);
    let hi: String = nb_simd_addps(m2, 7, 0);
    // i += 8
    let e1: String = nb_load_rax(hi, 0 - 32);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 280);
    nb_store_rax(e2, 0 - 32)
}

// Horizontal fold: movups-store acc_lo(xmm6)->[-320..-308], acc_hi(xmm7)->[-304..-292]
// (8 contiguous f32), then hs = f[0]; hs += f[1] .. f[7] left-to-right -> sslot -216.
// Matches ref_dot_f32_strict's pinned lane 0..7 fold exactly (movss + 7x addss).
pub fn nb_simd_f32dot_fold(code: String) -> String {
    let l1: String = nb_intdot_lea(code, 0 - 320, 0 - 112);
    let s1: String = nb_simd_movups_st_rax(l1, 6);
    let l2: String = nb_intdot_lea(s1, 0 - 304, 0 - 112);
    let s2: String = nb_simd_movups_st_rax(l2, 7);
    let h0: String = nb_fp_movss_load_xmm0(s2, 0 - 320);
    let h1: String = nb_fp_ss_binop_mem(h0, 0, 0 - 316);
    let h2: String = nb_fp_ss_binop_mem(h1, 0, 0 - 312);
    let h3: String = nb_fp_ss_binop_mem(h2, 0, 0 - 308);
    let h4: String = nb_fp_ss_binop_mem(h3, 0, 0 - 304);
    let h5: String = nb_fp_ss_binop_mem(h4, 0, 0 - 300);
    let h6: String = nb_fp_ss_binop_mem(h5, 0, 0 - 296);
    let h7: String = nb_fp_ss_binop_mem(h6, 0, 0 - 292);
    nb_fp_movss_store_xmm0(h7, 0 - 216)
}

// STEP C: emit an ET_EXEC that (1) LCG-generates a[0..n] then b[0..n] as PACKED f32
// (stride 4, fresh seed 0xDEADBEEF — the SAME next_f32_unit as the canary), (2)
// computes the strict-FP dot with a 2x-XMM packed-f32 8-lane accumulate (movups/
// mulps/addps), the pinned left-to-right horizontal fold, and the scalar tail, (3)
// writes the result f32's 8 LE bit-bytes to stdout. Byte-identical to the MLIR
// canary dot-f32-v (n=4093, seed 0xDEADBEEF). Frame 131072: A base -131072 (packed),
// B base -98304 (packed); fold scratch -320..-288; sslot -216; result -224.
pub fn selftest_native_elf_simd_dot_f32(n: i64) -> EmitState {
    let ve: i64 = (n / 8) * 8;
    let p0: String = nb_fp_prologue_frame(string_new(), 131072);
    // Integer + f32-bit constants (identical to S8 except stride -40 = 4 for packed f32).
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 4, 0 - 40);
    let k4: String = nb_intdot_movimm(k3, n, 0 - 48);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 56);
    let k6: String = nb_intdot_movimm(k5, 4294967295, 0 - 64);
    let k7: String = nb_intdot_movimm(k6, 1, 0 - 88);
    let k8: String = nb_intdot_movimm(k7, 1333788672, 0 - 128);
    let k9: String = nb_intdot_movimm(k8, 1073741824, 0 - 136);
    let k10: String = nb_intdot_movimm(k9, 1065353216, 0 - 144);
    let k11: String = nb_intdot_movimm(k10, 3735928559, 0 - 8);
    let k12: String = nb_intdot_movimm(k11, ve, 0 - 264);
    // SIMD main-loop stride (i += 8 per packed iteration of 8 lanes).
    let k13: String = nb_intdot_movimm(k12, 8, 0 - 280);
    // Runtime base addresses of the two in-frame PACKED f32 arrays.
    let ba: String = nb_intdot_lea(k13, 0 - 131072, 0 - 96);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 104);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // Generate a (base slot -96) then b (base slot -104); LCG state continues.
    let ga: String = nb_f32_gen_loop(bb, 0 - 96, jmps, jcell);
    let gb: String = nb_f32_gen_loop(ga, 0 - 104, jmps, jcell);
    // Zero both packed-f32 accumulators (xmm6=lanes0..3, xmm7=lanes4..7) — 0.0f bits.
    let pz0: String = nb_simd_pxor(gb, 6, 6);
    let pz1: String = nb_simd_pxor(pz0, 7, 7);
    // Packed-SIMD main loop: i in 0..ve step 8, 8-lane accumulate.
    let m0: String = nb_intdot_movimm(pz1, 0, 0 - 32);
    let m_hdr: i64 = string_len(m0);
    let mc1: String = nb_load_rax(m0, 0 - 32);
    let mc2: String = nb_cmp_rax_mem(mc1, nb_setcc_opcode(op_lt()), 0 - 264);
    let mc3: String = nb_store_rax(mc2, 0 - 80);
    let mcj: String = nb_emit_cmp_je_zero(mc3, 0 - 80, jmps, jcell);
    let m_je: i64 = __mind_load_i64(jcell) - 1;
    let mb: String = nb_simd_f32dot_body(mcj);
    let mjb: String = nb_emit_jmp(mb, jmps, jcell);
    let m_bk: i64 = __mind_load_i64(jcell) - 1;
    let _mp1: i64 = nb_jmp_set_target(jmps, jcell, m_bk, m_hdr);
    let m_end: i64 = string_len(mjb);
    let _mp2: i64 = nb_jmp_set_target(jmps, jcell, m_je, m_end);
    // Horizontal fold -> sslot (i is left == ve, reused as the tail counter).
    let fld: String = nb_simd_f32dot_fold(mjb);
    // Scalar tail: i in ve..n (reuses the S8 scalar tail body verbatim; stride -40 = 4).
    let t_hdr: i64 = string_len(fld);
    let tc1: String = nb_load_rax(fld, 0 - 32);
    let tc2: String = nb_cmp_rax_mem(tc1, nb_setcc_opcode(op_lt()), 0 - 48);
    let tc3: String = nb_store_rax(tc2, 0 - 80);
    let tcj: String = nb_emit_cmp_je_zero(tc3, 0 - 80, jmps, jcell);
    let t_je: i64 = __mind_load_i64(jcell) - 1;
    let tb: String = nb_f32dot_tail_body(tcj);
    let tjb: String = nb_emit_jmp(tb, jmps, jcell);
    let t_bk: i64 = __mind_load_i64(jcell) - 1;
    let _tp1: i64 = nb_jmp_set_target(jmps, jcell, t_bk, t_hdr);
    let t_end: i64 = string_len(tjb);
    let _tp2: i64 = nb_jmp_set_target(jmps, jcell, t_je, t_end);
    // result bits: movss xmm0,[sslot] ; movd eax,xmm0 ; store rax -> result.
    let r0: String = nb_fp_movss_load_xmm0(tjb, 0 - 216);
    let r1f: String = nb_fp_movd_eax_xmm0(r0);
    let r2f: String = nb_store_rax(r1f, 0 - 224);
    // write(1, &result, 8).
    let w0: String = nb_intdot_lea(r2f, 0 - 224, 0 - 240);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 232);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 248);
    let w3: String = nb_emit_write(w2, 0 - 232, 0 - 240, 0 - 248);
    // exit(0).
    let ee1: String = nb_intdot_movimm(w3, 0, 0 - 256);
    let ee2: String = nb_load_rax(ee1, 0 - 256);
    let code: String = nb_emit_return(ee2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S13 (#108) — native-ELF PACKED-f32 SIMD via 256-bit AVX2 (VEX/YMM),
// STRICT-FP DOT-PRODUCT, byte-identical to the SAME MLIR canary dot-f32-v =
// a132f7b9 that the scalar S8 and SSE 2x-XMM S11 rungs hit (len 4093, seed
// 0xDEADBEEF). The 256-bit float SIMD rung: the pure-MIND native-ELF backend
// now emits VEX-encoded 8-lane YMM packed-f32 SIMD whose f32 result is
// byte-identical to the scalar/SSE/MLIR value. Deterministic strict-FP AVX2,
// zero MLIR/LLVM.
//
// WHY it is byte-identical (the SAME argument as S11, one YMM instead of 2 XMM):
// f32 add is NOT associative, so byte-identity rests on reproducing
// ref_dot_f32_strict's fold BIT-FOR-BIT. That fold is an 8-LANE accumulator:
// acc[lane] += a[i+lane]*b[i+lane] for lane 0..8, per block of 8, in increasing
// block order; then a PINNED left-to-right horizontal fold hs=acc[0];
// hs+=acc[1]..acc[7]; then a scalar tail. YMM has 8 f32 lanes NATURALLY, so one
// vmulps/vaddps applies the SAME per-lane IEEE round-to-nearest single mul/add as
// scalar mulss/addss, UNFUSED, with NO cross-lane interaction — per lane the value
// stream is IDENTICAL to S8's scalar and S11's 2x-XMM 8-lane accumulate.
//
// 8 LANES -> 1 YMM (AVX = 8 f32/YMM): acc(ymm6)=lanes0..7. Per block of 8:
// vmovups a[i..i+8]->ymm0, vmovups b[i..i+8]->ymm1, vmulps ymm0,ymm0,ymm1,
// vaddps acc,acc,ymm0. vmovups is UNALIGNED (any address). YMM lane 0 = lowest
// address (little-endian) = a[i+0], lane 1 = a[i+1], ... — the lane map matches ref.
//
// LAYOUT: same PACKED (stride 4) arrays as S11 — one vmovups reads 8 CONTIGUOUS
// f32 (32 bytes). The S8 LCG gen (nb_f32gen_body) is reused VERBATIM with stride
// slot -40 = 4. The scalar tail (nb_f32dot_tail_body) is reused VERBATIM.
//
// HORIZONTAL FOLD: store acc's low 128 (xmm6 = lanes0..3) to [-320..-308] with a
// legacy movups store, vextractf128 the hi 128 (lanes4..7) into xmm0 and store to
// [-304..-292], then read the 8 contiguous f32 back with movss/addss left-to-right
// lane 0..7 (== ref's hs=acc[0]; hs+=acc[1]..acc[7]) — reuses S11's proven fold
// tail. Then the scalar tail (i in ve..n). Result f32's 8 LE bit-bytes to stdout.
// n=4093 -> ve=(4093/8)*8=4088, tail = elements 4088..4093.
//
// NEW VEX-PREFIX EMITTER: nb_vex2 (2-byte C5, for 0F-escape with no X/B/W) and
// nb_vex3 (3-byte C4, for 0F38/0F3A or when W/X/B needed), plus 256-bit YMM forms
// vxorps (VEX.256.0F.WIG 57), vmovups load (VEX.256.0F.WIG 10), vmulps
// (VEX.NDS.256.0F.WIG 59), vaddps (VEX.NDS.256.0F.WIG 58), vextractf128
// (VEX.256.0F3A.W0 19 ib). All ymm regs are 0..7 so R/X/B extension bits are 0.
// Reuses the S11 legacy movups store + S8 F3-prefix scalar-single family for the
// fold + tail. NEW export, never reached during self-compile: the integer +
// scalar/SSE-float native-ELF oracle stays byte-identical (additivity).
// ============================================================================

// 2-byte VEX prefix (C5): 0F-escape map, no X/B/W. r = R-extension bit (0/1),
// vvvv = src1 register number (0..15; pass 0 when the op has NO vvvv operand ->
// stored 1111), l = 1 for 256-bit YMM, pp = 00/01/10/11 (mandatory-prefix code).
//   byte1 = (~R<<7)|(~vvvv<<3)|(L<<2)|pp  where ~R=(1-R) as 1 bit, ~vvvv=(15-vvvv)
//   as 4 bits (15 - x == 4-bit bitwise NOT for x in 0..15).
pub fn nb_vex2(code: String, r: i64, vvvv: i64, l: i64, pp: i64) -> String {
    let c1: String = nb_push(code, 197);
    nb_push(c1, (1 - r) * 128 + (15 - vvvv) * 8 + l * 4 + pp)
}

// 3-byte VEX prefix (C4): for the 0F38/0F3A opcode maps or when W/X/B is needed.
//   byte1 = (~R<<7)|(~X<<6)|(~B<<5)|mmmmm  (mmmmm: 0F=1, 0F38=2, 0F3A=3)
//   byte2 = (W<<7)|(~vvvv<<3)|(L<<2)|pp.
pub fn nb_vex3(code: String, r: i64, x: i64, b: i64, mmmmm: i64, w: i64, vvvv: i64, l: i64, pp: i64) -> String {
    let c1: String = nb_push(code, 196);
    let c2: String = nb_push(c1, (1 - r) * 128 + (1 - x) * 64 + (1 - b) * 32 + mmmmm);
    nb_push(c2, w * 128 + (15 - vvvv) * 8 + l * 4 + pp)
}

// vxorps ymm{d}, ymm{s1}, ymm{s2} = VEX.NDS.256.0F.WIG 57 /r  (zero an accumulator
// with d=s1=s2). byte sequence for ymm6,ymm6,ymm6 = C5 CC 57 F6 (objdump-verified).
pub fn nb_avx_vxorps(code: String, d: i64, s1: i64, s2: i64) -> String {
    let c1: String = nb_vex2(code, 0, s1, 1, 0);
    let c2: String = nb_push(c1, 87);
    nb_push(c2, 192 + d * 8 + s2)
}

// vmovups ymm{r}, [rax] = VEX.256.0F.WIG 10 /r  (256-bit UNALIGNED packed-f32 load,
// reg-indirect). No vvvv operand -> pass 0. ymm0,[rax] = C5 FC 10 00 (objdump-verified).
pub fn nb_avx_vmovups_ld_rax(code: String, r: i64) -> String {
    let c1: String = nb_vex2(code, 0, 0, 1, 0);
    let c2: String = nb_push(c1, 16);
    nb_push(c2, r * 8)
}

// vmulps ymm{d}, ymm{s1}, ymm{s2} = VEX.NDS.256.0F.WIG 59 /r  (packed-f32 per-lane
// multiply, unfused). ymm0,ymm0,ymm1 = C5 FC 59 C1 (objdump-verified).
pub fn nb_avx_vmulps(code: String, d: i64, s1: i64, s2: i64) -> String {
    let c1: String = nb_vex2(code, 0, s1, 1, 0);
    let c2: String = nb_push(c1, 89);
    nb_push(c2, 192 + d * 8 + s2)
}

// vaddps ymm{d}, ymm{s1}, ymm{s2} = VEX.NDS.256.0F.WIG 58 /r  (packed-f32 per-lane
// add). ymm6,ymm6,ymm0 = C5 CC 58 F0 (objdump-verified).
pub fn nb_avx_vaddps(code: String, d: i64, s1: i64, s2: i64) -> String {
    let c1: String = nb_vex2(code, 0, s1, 1, 0);
    let c2: String = nb_push(c1, 88);
    nb_push(c2, 192 + d * 8 + s2)
}

// vextractf128 xmm{d}, ymm{s}, imm8 = VEX.256.0F3A.W0 19 /r ib  (extract a 128-bit
// lane; reg field = source ymm, rm = dest xmm). xmm0,ymm6,1 = C4 E3 7D 19 F0 01
// (objdump-verified). 0F3A map -> 3-byte VEX, pp=01 (implied 66).
pub fn nb_avx_vextractf128(code: String, d: i64, s: i64, imm: i64) -> String {
    let c1: String = nb_vex3(code, 0, 0, 0, 3, 0, 0, 1, 1);
    let c2: String = nb_push(c1, 25);
    let c3: String = nb_push(c2, 192 + s * 8 + d);
    nb_push(c3, imm)
}

// One 256-bit AVX2 SIMD main-loop iteration over 8 elements (i..i+8):
//   acc(ymm6) += a[i..i+8]*b[i..i+8]   (all 8 lanes in one YMM)
//   i += 8.  Stride slot -40 = 4 (packed f32); baseA=-96, baseB=-104, i=-32, +8=-280.
pub fn nb_avx_f32dot_body(code: String) -> String {
    // rax = i*4 + baseA ; vmovups ymm0,[rax]  (a[i..i+8])
    let a1: String = nb_load_rax(code, 0 - 32);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 40);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 96);
    let a4: String = nb_avx_vmovups_ld_rax(a3, 0);
    // rax = i*4 + baseB ; vmovups ymm1,[rax]  (b[i..i+8])
    let b1: String = nb_load_rax(a4, 0 - 32);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 40);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 104);
    let b4: String = nb_avx_vmovups_ld_rax(b3, 1);
    // ymm0 = a*b (per-lane, unfused) ; acc(ymm6) += ymm0
    let m1: String = nb_avx_vmulps(b4, 0, 0, 1);
    let ac: String = nb_avx_vaddps(m1, 6, 6, 0);
    // i += 8
    let e1: String = nb_load_rax(ac, 0 - 32);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 280);
    nb_store_rax(e2, 0 - 32)
}

// Horizontal fold: store acc low 128 (xmm6 = lanes 0..3) -> [-320..-308], extract
// acc hi 128 (lanes 4..7) into xmm0 and store -> [-304..-292], then hs = f[0];
// hs += f[1] .. f[7] left-to-right -> sslot -216. Matches ref_dot_f32_strict's
// pinned lane 0..7 fold exactly (movss + 7x addss). Reuses S11's fold tail; the
// only difference vs S11 is the hi 4 lanes come from vextractf128 (not xmm7).
pub fn nb_avx_f32dot_fold(code: String) -> String {
    let l1: String = nb_intdot_lea(code, 0 - 320, 0 - 112);
    let s1: String = nb_simd_movups_st_rax(l1, 6);
    let ex: String = nb_avx_vextractf128(s1, 0, 6, 1);
    let l2: String = nb_intdot_lea(ex, 0 - 304, 0 - 112);
    let s2: String = nb_simd_movups_st_rax(l2, 0);
    let h0: String = nb_fp_movss_load_xmm0(s2, 0 - 320);
    let h1: String = nb_fp_ss_binop_mem(h0, 0, 0 - 316);
    let h2: String = nb_fp_ss_binop_mem(h1, 0, 0 - 312);
    let h3: String = nb_fp_ss_binop_mem(h2, 0, 0 - 308);
    let h4: String = nb_fp_ss_binop_mem(h3, 0, 0 - 304);
    let h5: String = nb_fp_ss_binop_mem(h4, 0, 0 - 300);
    let h6: String = nb_fp_ss_binop_mem(h5, 0, 0 - 296);
    let h7: String = nb_fp_ss_binop_mem(h6, 0, 0 - 292);
    nb_fp_movss_store_xmm0(h7, 0 - 216)
}

// STEP C: emit an ET_EXEC that (1) LCG-generates a[0..n] then b[0..n] as PACKED f32
// (stride 4, fresh seed 0xDEADBEEF — the SAME next_f32_unit as the canary), (2)
// computes the strict-FP dot with a 1x-YMM 256-bit AVX2 8-lane accumulate (vmovups/
// vmulps/vaddps), the pinned left-to-right horizontal fold (vextractf128 + movss/
// addss), and the scalar tail, (3) writes the result f32's 8 LE bit-bytes to stdout.
// Byte-identical to the MLIR canary dot-f32-v (n=4093, seed 0xDEADBEEF). Frame
// 131072: A base -131072 (packed), B base -98304 (packed); fold scratch -320..-288;
// sslot -216; result -224.
pub fn selftest_native_elf_avx2_dot_f32(n: i64) -> EmitState {
    let ve: i64 = (n / 8) * 8;
    let p0: String = nb_fp_prologue_frame(string_new(), 131072);
    // Integer + f32-bit constants (identical to S8/S11; stride -40 = 4 for packed f32).
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 16);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 24);
    let k3: String = nb_intdot_movimm(k2, 4, 0 - 40);
    let k4: String = nb_intdot_movimm(k3, n, 0 - 48);
    let k5: String = nb_intdot_movimm(k4, 16, 0 - 56);
    let k6: String = nb_intdot_movimm(k5, 4294967295, 0 - 64);
    let k7: String = nb_intdot_movimm(k6, 1, 0 - 88);
    let k8: String = nb_intdot_movimm(k7, 1333788672, 0 - 128);
    let k9: String = nb_intdot_movimm(k8, 1073741824, 0 - 136);
    let k10: String = nb_intdot_movimm(k9, 1065353216, 0 - 144);
    let k11: String = nb_intdot_movimm(k10, 3735928559, 0 - 8);
    let k12: String = nb_intdot_movimm(k11, ve, 0 - 264);
    // SIMD main-loop stride (i += 8 per packed iteration of 8 lanes).
    let k13: String = nb_intdot_movimm(k12, 8, 0 - 280);
    // Runtime base addresses of the two in-frame PACKED f32 arrays.
    let ba: String = nb_intdot_lea(k13, 0 - 131072, 0 - 96);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 104);
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // Generate a (base slot -96) then b (base slot -104); LCG state continues.
    let ga: String = nb_f32_gen_loop(bb, 0 - 96, jmps, jcell);
    let gb: String = nb_f32_gen_loop(ga, 0 - 104, jmps, jcell);
    // Zero the single 8-lane YMM accumulator (ymm6) with vxorps (0.0f bits == 0).
    let pz: String = nb_avx_vxorps(gb, 6, 6, 6);
    // 256-bit AVX2 packed-SIMD main loop: i in 0..ve step 8, 8-lane YMM accumulate.
    let m0: String = nb_intdot_movimm(pz, 0, 0 - 32);
    let m_hdr: i64 = string_len(m0);
    let mc1: String = nb_load_rax(m0, 0 - 32);
    let mc2: String = nb_cmp_rax_mem(mc1, nb_setcc_opcode(op_lt()), 0 - 264);
    let mc3: String = nb_store_rax(mc2, 0 - 80);
    let mcj: String = nb_emit_cmp_je_zero(mc3, 0 - 80, jmps, jcell);
    let m_je: i64 = __mind_load_i64(jcell) - 1;
    let mb: String = nb_avx_f32dot_body(mcj);
    let mjb: String = nb_emit_jmp(mb, jmps, jcell);
    let m_bk: i64 = __mind_load_i64(jcell) - 1;
    let _mp1: i64 = nb_jmp_set_target(jmps, jcell, m_bk, m_hdr);
    let m_end: i64 = string_len(mjb);
    let _mp2: i64 = nb_jmp_set_target(jmps, jcell, m_je, m_end);
    // Horizontal fold -> sslot (i is left == ve, reused as the tail counter).
    let fld: String = nb_avx_f32dot_fold(mjb);
    // Scalar tail: i in ve..n (reuses the S8 scalar tail body verbatim; stride -40 = 4).
    let t_hdr: i64 = string_len(fld);
    let tc1: String = nb_load_rax(fld, 0 - 32);
    let tc2: String = nb_cmp_rax_mem(tc1, nb_setcc_opcode(op_lt()), 0 - 48);
    let tc3: String = nb_store_rax(tc2, 0 - 80);
    let tcj: String = nb_emit_cmp_je_zero(tc3, 0 - 80, jmps, jcell);
    let t_je: i64 = __mind_load_i64(jcell) - 1;
    let tb: String = nb_f32dot_tail_body(tcj);
    let tjb: String = nb_emit_jmp(tb, jmps, jcell);
    let t_bk: i64 = __mind_load_i64(jcell) - 1;
    let _tp1: i64 = nb_jmp_set_target(jmps, jcell, t_bk, t_hdr);
    let t_end: i64 = string_len(tjb);
    let _tp2: i64 = nb_jmp_set_target(jmps, jcell, t_je, t_end);
    // result bits: movss xmm0,[sslot] ; movd eax,xmm0 ; store rax -> result.
    let r0: String = nb_fp_movss_load_xmm0(tjb, 0 - 216);
    let r1f: String = nb_fp_movd_eax_xmm0(r0);
    let r2f: String = nb_store_rax(r1f, 0 - 224);
    // write(1, &result, 8).
    let w0: String = nb_intdot_lea(r2f, 0 - 224, 0 - 240);
    let w1: String = nb_intdot_movimm(w0, 1, 0 - 232);
    let w2: String = nb_intdot_movimm(w1, 8, 0 - 248);
    let w3: String = nb_emit_write(w2, 0 - 232, 0 - 240, 0 - 248);
    // exit(0).
    let ee1: String = nb_intdot_movimm(w3, 0, 0 - 256);
    let ee2: String = nb_load_rax(ee1, 0 - 256);
    let code: String = nb_emit_return(ee2, 1);
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// RI-B2-S12 (#108) — native-ELF PACKED-int16 SIMD (SSE2, 128-bit) DOT-PRODUCT
// via the pmaddwd idiom, byte-identical to the SAME MLIR canary dot-i16-4096 =
// af0fc3cf the scalar S2 rung hit (len 4096, seed 0xDEADBEEF). The int16 SIMD
// rung: the pure-MIND native-ELF backend emits VECTOR packed-int16 SIMD whose
// i64 result is byte-identical to the scalar/MLIR value. Deterministic integer
// SIMD, zero LLVM.
//
// WHY it is byte-identical (the C3 risk resolved — pmaddwd-i32-pairwise MATCHES
// the pure-i64 scalar model): the scalar S2 model is acc:i64 = Sum sext(a[i]) *
// sext(b[i]), then `acc as i32` (ref_dot_i16_scalar). pmaddwd (66 0F F5) does a
// packed 16x16 signed multiply then adds ADJACENT PAIRS into i32 lanes:
// out[k] = wrap32(a[2k]*b[2k] + a[2k+1]*b[2k+1]). We accumulate the 4 i32 lanes
// across blocks with paddd (i32 wrap per lane), then horizontally reduce the 4
// lanes with pshufd+paddd (i32 wrap), then narrow ONCE `as i32` (movsxd). This
// equals the pure-i64 sum-then-narrow because every step is LINEAR mod 2^32:
// each pmaddwd pair, each paddd, and the horizontal fold differ from the exact
// i64 partial ONLY by multiples of 2^32, and the final `as i32` narrow reduces
// mod 2^32 — so the i32-pairwise-wrap is absorbed exactly. (Empirically the 4096
// LCG stream never overflows i64 in the accumulator; 2048 pairs * <2^31 << 2^63.)
//
// 8 int16 per iteration: one movdqu loads 8 packed int16 (128 bits); pmaddwd
// folds them to 4 i32 partials; paddd accumulates into xmm7. n=4096 is divisible
// by 8 -> no scalar tail (mirrors the stride-2 Q16 SIMD S10 no-tail structure).
//
// LAYOUT: unlike the stride-8 scalar int16 (S2), packed movdqu needs CONTIGUOUS
// int16, so the arrays are PACKED (stride 2). The LCG gen stores the low 16 bits
// of each draw with a WORD store (66 89) at base + i*2 -> contiguous int16. The
// element stream is IDENTICAL to S2's (element = (state>>32) low 16 as i16); only
// the storage width differs (word vs 8-byte cell), and pmaddwd reads the packed
// int16 as signed 16-bit lanes — same values, same signedness.
//
// HORIZONTAL FOLD: xmm7 = [l0,l1,l2,l3]; pshufd 0x4E + paddd -> [l0+l2, l1+l3,..];
// pshufd 0xB1 + paddd -> all lanes = l0+l1+l2+l3; movdqa xmm0,xmm7; movd eax,xmm0
// -> the i32 sum (wraps); movsxd rax,eax -> `as i32`; write 8 LE bytes to stdout.
// n=4096 -> the whole reduction is packed (no tail).
//
// NEW packed-int16 encoders (66-prefixed): pmaddwd (66 0F F5), paddd (66 0F FE),
// plus a WORD store nb_emit_store_i16 (66 89 08). Reuses S10's movdqu-load, pxor,
// pshufd, movdqa and the scalar movsxd + f32's movd(eax<-xmm0). NEW export, never
// reached during self-compile: the integer + scalar/f32 native-ELF oracle stays
// byte-identical (additivity).
// ============================================================================

// emit_store_i16(addr_disp, val_disp): write the LOW 16 BITS of val only (the
// packed-int16 sibling of nb_emit_store_i8). The word store must NOT clobber the
// adjacent 6 bytes of the 8-byte-aligned slot; movdqu later reads 8 contiguous
// int16 across such stores.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov rcx,[rbp+val] = 48 8B 8D
//   <disp32> ; mov word [rax],cx = 66 89 08.
pub fn nb_emit_store_i16(code: String, addr_disp: i64, val_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 141);
    let c8: String = nb_i32le_signed(c7, val_disp);
    let c9: String = nb_push(c8, 102);
    let c10: String = nb_push(c9, 137);
    nb_push(c10, 8)
}

// pmaddwd xmm{d}, xmm{s}  =  66 0F F5 <0xC0|(d<<3)|s>   (packed signed 16x16
// multiply of the 8 word lanes, then add ADJACENT PAIRS -> 4 i32 lanes, wrapping).
pub fn nb_simd_pmaddwd(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 245);
    nb_push(c3, 192 + d * 8 + s)
}

// paddd xmm{d}, xmm{s}  =  66 0F FE <0xC0|(d<<3)|s>   (packed i32 add, per 32-bit
// lane, wrapping — accumulates the 4 pmaddwd partials and folds them horizontally).
pub fn nb_simd_paddd(code: String, d: i64, s: i64) -> String {
    let c1: String = nb_push(code, 102);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 254);
    nb_push(c3, 192 + d * 8 + s)
}

// One packed-int16 generation-loop body: advance the LCG one draw and store the
// int16 element to memory[base + i*2] as a contiguous WORD (packed int16 layout).
//   state = state*1664525 + 1013904223 ; val = state >> 32 (low 16 = element) ;
//   ptr = base + i*2 ; *(word)ptr = val ; i += 1.
// base_d is a slot holding the runtime base ADDRESS of the target array.
// Slot map (rbp-relative): state=-65544 mul=-65552 addc=-65560 sh32=-65600
//   i=-65568 two=-65584 val=-65624 ptr=-65616 one=-65680.
pub fn nb_i16gen_packed_body(code: String, base_d: i64) -> String {
    let a1: String = nb_load_rax(code, 0 - 65544);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 65552);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 65560);
    let a4: String = nb_store_rax(a3, 0 - 65544);
    let b1: String = nb_load_rax(a4, 0 - 65544);
    let b2: String = nb_arith_rax_mem(b1, op_shr(), 0 - 65600);
    let b3: String = nb_store_rax(b2, 0 - 65624);
    let c1: String = nb_load_rax(b3, 0 - 65568);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 65584);
    let c3: String = nb_arith_rax_mem(c2, op_add(), base_d);
    let c4: String = nb_store_rax(c3, 0 - 65616);
    let d1: String = nb_emit_store_i16(c4, 0 - 65616, 0 - 65624);
    let e1: String = nb_load_rax(d1, 0 - 65568);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 65680);
    nb_store_rax(e2, 0 - 65568)
}

// One packed-int16 SIMD dot iteration over 8 elements (i..i+8) of the stride-2
// packed layout:
//   aptr = baseA + i*2 -> rax ; va = movdqu[rax] (8 int16)  xmm0
//   bptr = baseB + i*2 -> rax ; vb = movdqu[rax] (8 int16)  xmm1
//   pmaddwd xmm0, xmm1 -> [a0*b0+a1*b1, .., a6*b6+a7*b7] (4 i32)
//   paddd  xmm7, xmm0  (accumulate the 4 i32 lanes) ; i += 8.
// baseA=-65664 baseB=-65672 i=-65568 two=-65584 eight=-65688.
pub fn nb_simd_i16dot_body(code: String) -> String {
    let a1: String = nb_load_rax(code, 0 - 65568);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 65584);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 65664);
    let a4: String = nb_simd_movdqu_ld_rax(a3, 0);
    let b1: String = nb_load_rax(a4, 0 - 65568);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 65584);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 65672);
    let b4: String = nb_simd_movdqu_ld_rax(b3, 1);
    let p1: String = nb_simd_pmaddwd(b4, 0, 1);
    let p2: String = nb_simd_paddd(p1, 7, 0);
    let e1: String = nb_load_rax(p2, 0 - 65568);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 65688);
    nb_store_rax(e2, 0 - 65568)
}

// STEP: emit an ET_EXEC that (1) LCG-generates a[0..n] then b[0..n] as PACKED
// int16 (stride 2, the SAME element stream as the scalar S2 canary), (2) computes
// the dot with an 8-wide packed pmaddwd accumulate (4 i32 lanes in xmm7), (3)
// horizontally reduces the 4 lanes, narrows ONCE to i32 (movsxd — the canary's
// `acc as i32`), (4) writes the result's 8 LE bytes to stdout. Byte-identical to
// the MLIR canary dot-i16-4096 (n=4096, seed 0xDEADBEEF). Frame 73728: A base
// -65536 (packed int16, [-65536,-57344)), B base -32768 ([-32768,-24576)); all
// scalar scratch slots live below -65536 (<= -65544). n baked at emit time.
pub fn selftest_native_elf_simd_dot_i16(n: i64) -> EmitState {
    let p0: String = nb_fp_prologue_frame(string_new(), 73728);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, 1664525, 0 - 65552);
    let k2: String = nb_intdot_movimm(k1, 1013904223, 0 - 65560);
    let k3: String = nb_intdot_movimm(k2, 2, 0 - 65584);
    let k4: String = nb_intdot_movimm(k3, 1, 0 - 65680);
    let k5: String = nb_intdot_movimm(k4, 32, 0 - 65600);
    let k6: String = nb_intdot_movimm(k5, 3735928559, 0 - 65544);
    let k7: String = nb_intdot_movimm(k6, n, 0 - 65576);
    let k8: String = nb_intdot_movimm(k7, 8, 0 - 65688);
    // Runtime base addresses of the two in-frame PACKED int16 arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 65536, 0 - 65664);
    let bb: String = nb_intdot_lea(ba, 0 - 32768, 0 - 65672);
    // Jump scaffold buffer shared by the three loops (genA, genB, dot).
    let jmps: i64 = __mind_alloc(64 * 4 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- generate A[0..n] (base slot -65664) ---
    let ga0: String = nb_intdot_movimm(bb, 0, 0 - 65568);
    let ga_hdr: i64 = string_len(ga0);
    let gac1: String = nb_load_rax(ga0, 0 - 65568);
    let gac2: String = nb_cmp_rax_mem(gac1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let gac3: String = nb_store_rax(gac2, 0 - 65656);
    let gacj: String = nb_emit_cmp_je_zero(gac3, 0 - 65656, jmps, jcell);
    let ga_je: i64 = __mind_load_i64(jcell) - 1;
    let gab: String = nb_i16gen_packed_body(gacj, 0 - 65664);
    let gajb: String = nb_emit_jmp(gab, jmps, jcell);
    let ga_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, ga_bk, ga_hdr);
    let ga_end: i64 = string_len(gajb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, ga_je, ga_end);
    // --- generate B[0..n] (base slot -65672), LCG state continues ---
    let gb0: String = nb_intdot_movimm(gajb, 0, 0 - 65568);
    let gb_hdr: i64 = string_len(gb0);
    let gbc1: String = nb_load_rax(gb0, 0 - 65568);
    let gbc2: String = nb_cmp_rax_mem(gbc1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let gbc3: String = nb_store_rax(gbc2, 0 - 65656);
    let gbcj: String = nb_emit_cmp_je_zero(gbc3, 0 - 65656, jmps, jcell);
    let gb_je: i64 = __mind_load_i64(jcell) - 1;
    let gbb: String = nb_i16gen_packed_body(gbcj, 0 - 65672);
    let gbjb: String = nb_emit_jmp(gbb, jmps, jcell);
    let gb_bk: i64 = __mind_load_i64(jcell) - 1;
    let _hp1: i64 = nb_jmp_set_target(jmps, jcell, gb_bk, gb_hdr);
    let gb_end: i64 = string_len(gbjb);
    let _hp2: i64 = nb_jmp_set_target(jmps, jcell, gb_je, gb_end);
    // Zero the packed i32 accumulator (xmm7) before the dot loop.
    let pz: String = nb_simd_pxor(gbjb, 7, 7);
    // --- packed-SIMD dot loop: acc(xmm7) += pmaddwd(a[i..i+8], b[i..i+8]) ---
    let d0: String = nb_intdot_movimm(pz, 0, 0 - 65568);
    let d_hdr: i64 = string_len(d0);
    let dc1: String = nb_load_rax(d0, 0 - 65568);
    let dc2: String = nb_cmp_rax_mem(dc1, nb_setcc_opcode(op_lt()), 0 - 65576);
    let dc3: String = nb_store_rax(dc2, 0 - 65656);
    let dcj: String = nb_emit_cmp_je_zero(dc3, 0 - 65656, jmps, jcell);
    let d_je: i64 = __mind_load_i64(jcell) - 1;
    let db: String = nb_simd_i16dot_body(dcj);
    let djb: String = nb_emit_jmp(db, jmps, jcell);
    let d_bk: i64 = __mind_load_i64(jcell) - 1;
    let _dp1: i64 = nb_jmp_set_target(jmps, jcell, d_bk, d_hdr);
    let d_end: i64 = string_len(djb);
    let _dp2: i64 = nb_jmp_set_target(jmps, jcell, d_je, d_end);
    // Horizontal reduce the 4 i32 lanes -> lane0 (all four steps wrap at i32).
    let r1: String = nb_simd_pshufd(djb, 2, 7, 78);
    let r2: String = nb_simd_paddd(r1, 7, 2);
    let r3: String = nb_simd_pshufd(r2, 2, 7, 177);
    let r4: String = nb_simd_paddd(r3, 7, 2);
    // Extract lane0 to eax, narrow ONCE to i32 (movsxd — the canary's `acc as i32`).
    let r5: String = nb_simd_movdqa(r4, 0, 7);
    let r6: String = nb_fp_movd_eax_xmm0(r5);
    let t2: String = nb_movsxd_rax_eax(r6);
    let t3: String = nb_store_rax(t2, 0 - 65696);
    // write(1, &result, 8).
    let t4: String = nb_intdot_lea(t3, 0 - 65696, 0 - 65712);
    let t5: String = nb_intdot_movimm(t4, 1, 0 - 65704);
    let t6: String = nb_intdot_movimm(t5, 8, 0 - 65720);
    let t7: String = nb_emit_write(t6, 0 - 65704, 0 - 65712, 0 - 65720);
    // exit(0).
    let t8: String = nb_intdot_movimm(t7, 0, 0 - 65728);
    let t9: String = nb_load_rax(t8, 0 - 65728);
    let code: String = nb_emit_return(t9, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// C4-T1 — native-ELF TENSOR ELEMENT-WISE ADD (i64), the first tensor/linalg
// rung that drops MLIR for one tensor op. `selftest_native_elf_tensor_ewadd_i64(n)`
// emits a runnable ET_EXEC that (1) materializes two length-n i64 buffers in the
// frame with deterministic self-seeding a[i]=i+1, b[i]=2*i, (2) computes the
// element-wise sum c[i] = a[i] + b[i] via an emitted counted loop over the C2
// element load/store primitives (base + i*8 indexing), (3) horizontally reduces
// sum = Sum c[i] via a second emitted loop, (4) writes the 8 LE bytes of `sum`
// to stdout (the FULL-width observable — a Python smoke asserts them against the
// closed-form Sum(3i+1) = 3n(n-1)/2 + n), and (5) exits with the discriminating
// code (sum == expected)*41 + 1 — 42 only on an EXACT i64 match against the
// emit-time-baked closed form, 1 otherwise (not a mod-256-maskable residue).
// This introduces the reusable tensor-value shape (base pointer + length +
// element loop) later C4 rungs (broadcast, axis reductions, matmul) build on.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path (the deleted Rust native backend had no tensor entry); the gate is
// EXECUTION CORRECTNESS — emit, run, assert stdout+exit. n is capped at 4096 by
// the frame layout (three 32768-byte arrays).
//
// Frame: A base = -131072 (A[i] at -131072+8i), B base = -98304, C base = -65536
// (each 32768 bytes = 4096 elements). Scratch below the arrays:
//   i=-131080 n=-131088 eight=-131096 one=-131104 two=-131112 cmpflag=-131120
//   baseA=-131128 baseB=-131136 baseC=-131144 ptr=-131152 aval=-131160
//   bval=-131168 cval=-131176 sum=-131184 expected=-131192 result=-131200
//   fd=-131208 bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240.
// ============================================================================

// One materialization-loop body: a[i] = i+1 ; b[i] = 2*i ; i += 1. Element
// addresses re-derived at runtime as base + i*8 (the C2 addressing shape).
pub fn nb_ewadd_gen_body(code: String) -> String {
    // a[i] = i + 1
    let a1: String = nb_load_rax(code, 0 - 131080);
    let a2: String = nb_arith_rax_mem(a1, op_add(), 0 - 131104);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    let a4: String = nb_load_rax(a3, 0 - 131080);
    let a5: String = nb_arith_rax_mem(a4, op_mul(), 0 - 131096);
    let a6: String = nb_arith_rax_mem(a5, op_add(), 0 - 131128);
    let a7: String = nb_store_rax(a6, 0 - 131152);
    let a8: String = nb_emit_store_i64(a7, 0 - 131152, 0 - 131160);
    // b[i] = 2 * i
    let b1: String = nb_load_rax(a8, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131112);
    let b3: String = nb_store_rax(b2, 0 - 131168);
    let b4: String = nb_load_rax(b3, 0 - 131080);
    let b5: String = nb_arith_rax_mem(b4, op_mul(), 0 - 131096);
    let b6: String = nb_arith_rax_mem(b5, op_add(), 0 - 131136);
    let b7: String = nb_store_rax(b6, 0 - 131152);
    let b8: String = nb_emit_store_i64(b7, 0 - 131152, 0 - 131168);
    // i += 1
    let e1: String = nb_load_rax(b8, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One element-wise-add-loop body: aval = a[i] ; bval = b[i] ; c[i] = aval+bval ;
// i += 1. Loads go through nb_intdot_load_elem (ptr = base + i*8, then the
// register-indirect i64 deref); the store re-derives C's element address.
pub fn nb_ewadd_add_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131128, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    let b1: String = nb_intdot_load_elem(a1, 0 - 131136, 0 - 131152, 0 - 131168, 0 - 131080, 0 - 131096);
    // cval = aval + bval
    let c1: String = nb_load_rax(b1, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_add(), 0 - 131168);
    let c3: String = nb_store_rax(c2, 0 - 131176);
    // ptr = i*8 + baseC ; *ptr = cval
    let d1: String = nb_load_rax(c3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131144);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let d5: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131176);
    // i += 1
    let e1: String = nb_load_rax(d5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One reduction-loop body: sum += c[i] ; i += 1.
pub fn nb_ewadd_sum_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131144, 0 - 131152, 0 - 131176, 0 - 131080, 0 - 131096);
    let b1: String = nb_load_rax(a1, 0 - 131184);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131176);
    let b3: String = nb_store_rax(b2, 0 - 131184);
    let e1: String = nb_load_rax(b3, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// The C4-T1 driver. n is baked at emit time (n <= 4096 by the frame layout);
// the closed-form expected sum Sum_{i=0..n-1}((i+1) + 2i) = 3n(n-1)/2 + n is
// computed HOST-side and baked as the full-width comparison operand.
pub fn selftest_native_elf_tensor_ewadd_i64(n: i64) -> EmitState {
    let expected: i64 = (3 * n * (n - 1)) / 2 + n;
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, n, 0 - 131088);
    let k2: String = nb_intdot_movimm(k1, 8, 0 - 131096);
    let k3: String = nb_intdot_movimm(k2, 1, 0 - 131104);
    let k4: String = nb_intdot_movimm(k3, 2, 0 - 131112);
    let k5: String = nb_intdot_movimm(k4, 0, 0 - 131184);
    let k6: String = nb_intdot_movimm(k5, expected, 0 - 131192);
    let k7: String = nb_intdot_movimm(k6, 41, 0 - 131240);
    // Runtime base addresses of the three in-frame arrays.
    let ba: String = nb_intdot_lea(k7, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    let bc: String = nb_intdot_lea(bb, 0 - 65536, 0 - 131144);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop 1: materialize a[i]=i+1, b[i]=2*i ---
    let g0: String = nb_intdot_movimm(bc, 0, 0 - 131080);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131080);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let gb: String = nb_ewadd_gen_body(gcj);
    let gjb: String = nb_emit_jmp(gb, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    // --- loop 2: c[i] = a[i] + b[i] (the tensor element-wise op) ---
    let w0: String = nb_intdot_movimm(gjb, 0, 0 - 131080);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131080);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    let wb: String = nb_ewadd_add_body(wcj);
    let wjb: String = nb_emit_jmp(wb, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _wp1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _wp2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    // --- loop 3: sum = Sum c[i] (horizontal reduction) ---
    let s0: String = nb_intdot_movimm(wjb, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    let sb: String = nb_ewadd_sum_body(scj);
    let sjb: String = nb_emit_jmp(sb, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _sp1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _sp2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(sjb, 0 - 131184);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131184);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// C4-T2 — native-ELF TENSOR DOT PRODUCT (i64), the multiply-accumulate rung.
// `selftest_native_elf_tensor_dot_i64(n)` emits a runnable ET_EXEC that
// (1) materializes two length-n i64 buffers in the frame with deterministic
// self-seeding a[i]=i+1, b[i]=2*i+3 (nonzero dot at EVERY n, including n=1, so
// each shape discriminates), (2) computes acc = Sum a[i]*b[i] via ONE emitted
// counted loop doing the load-load-mul-accumulate step (the core reduction of
// matmul — a later T3 nests this loop for 2-D matmul), (3) writes the 8 LE
// bytes of `acc` to stdout (full-width observable, checked by a Python smoke
// against an independent reference), and (4) exits (acc == expected)*41 + 1 —
// 42 only on an EXACT i64 match against the emit-time-baked closed form
// Sum(i+1)(2i+3) = n(n-1)(2n-1)/3 + 5n(n-1)/2 + 3n, 1 otherwise (not a
// mod-256-maskable residue). `expected` exceeds imm32 at large n; the movimm
// helper is movabs (full imm64), so the baked comparison stays full-width.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does
// not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. No frozen byte oracle exists
// for this path (the deleted Rust native backend had no tensor entry); the
// gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit. n is capped
// at 4096 by the frame layout (two 32768-byte arrays).
//
// Frame (T1's map minus the C array, plus three=-131248):
//   A base = -131072 (A[i] at -131072+8i), B base = -98304 (32768 B each).
//   i=-131080 n=-131088 eight=-131096 one=-131104 two=-131112 cmpflag=-131120
//   baseA=-131128 baseB=-131136 ptr=-131152 aval=-131160 bval=-131168
//   acc=-131184 expected=-131192 result=-131200 fd=-131208 bufaddr=-131216
//   count=-131224 exitcode=-131232 fortyone=-131240 three=-131248.
// ============================================================================

// One materialization-loop body: a[i] = i+1 ; b[i] = 2*i+3 ; i += 1. Element
// addresses re-derived at runtime as base + i*8 (the C2 addressing shape).
pub fn nb_tdot_gen_body(code: String) -> String {
    // a[i] = i + 1
    let a1: String = nb_load_rax(code, 0 - 131080);
    let a2: String = nb_arith_rax_mem(a1, op_add(), 0 - 131104);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    let a4: String = nb_load_rax(a3, 0 - 131080);
    let a5: String = nb_arith_rax_mem(a4, op_mul(), 0 - 131096);
    let a6: String = nb_arith_rax_mem(a5, op_add(), 0 - 131128);
    let a7: String = nb_store_rax(a6, 0 - 131152);
    let a8: String = nb_emit_store_i64(a7, 0 - 131152, 0 - 131160);
    // b[i] = 2*i + 3
    let b1: String = nb_load_rax(a8, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131112);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131248);
    let b4: String = nb_store_rax(b3, 0 - 131168);
    let b5: String = nb_load_rax(b4, 0 - 131080);
    let b6: String = nb_arith_rax_mem(b5, op_mul(), 0 - 131096);
    let b7: String = nb_arith_rax_mem(b6, op_add(), 0 - 131136);
    let b8: String = nb_store_rax(b7, 0 - 131152);
    let b9: String = nb_emit_store_i64(b8, 0 - 131152, 0 - 131168);
    // i += 1
    let e1: String = nb_load_rax(b9, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One multiply-accumulate-loop body: aval = a[i] ; bval = b[i] ;
// acc += aval*bval ; i += 1. Loads go through nb_intdot_load_elem (ptr =
// base + i*8, then the register-indirect i64 deref); the product and the
// accumulate stay in rax across the two memory-operand arith ops.
pub fn nb_tdot_mac_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131128, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    let b1: String = nb_intdot_load_elem(a1, 0 - 131136, 0 - 131152, 0 - 131168, 0 - 131080, 0 - 131096);
    // acc = acc + aval*bval
    let c1: String = nb_load_rax(b1, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131168);
    let c3: String = nb_arith_rax_mem(c2, op_add(), 0 - 131184);
    let c4: String = nb_store_rax(c3, 0 - 131184);
    // i += 1
    let e1: String = nb_load_rax(c4, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// The C4-T2 driver. n is baked at emit time (n <= 4096 by the frame layout);
// the closed-form expected dot Sum_{i=0..n-1}(i+1)(2i+3) =
// n(n-1)(2n-1)/3 + 5n(n-1)/2 + 3n is computed HOST-side (each division is
// exact: 3 divides n(n-1)(2n-1), 2 divides n(n-1)) and baked via movabs.
pub fn selftest_native_elf_tensor_dot_i64(n: i64) -> EmitState {
    let expected: i64 = (n * (n - 1) * (2 * n - 1)) / 3 + (5 * (n * (n - 1))) / 2 + 3 * n;
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, n, 0 - 131088);
    let k2: String = nb_intdot_movimm(k1, 8, 0 - 131096);
    let k3: String = nb_intdot_movimm(k2, 1, 0 - 131104);
    let k4: String = nb_intdot_movimm(k3, 2, 0 - 131112);
    let k5: String = nb_intdot_movimm(k4, 3, 0 - 131248);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131184);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    let k8: String = nb_intdot_movimm(k7, 41, 0 - 131240);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    // Jump scaffold buffer shared by both loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop 1: materialize a[i]=i+1, b[i]=2*i+3 ---
    let g0: String = nb_intdot_movimm(bb, 0, 0 - 131080);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131080);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let gb: String = nb_tdot_gen_body(gcj);
    let gjb: String = nb_emit_jmp(gb, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    // --- loop 2: acc = Sum a[i]*b[i] (the multiply-accumulate reduction) ---
    let w0: String = nb_intdot_movimm(gjb, 0, 0 - 131080);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131080);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    let wb: String = nb_tdot_mac_body(wcj);
    let wjb: String = nb_emit_jmp(wb, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _wp1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _wp2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    // result = acc ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(wjb, 0 - 131184);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (acc == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131184);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// ============================================================================
// C4-T3 — native-ELF TENSOR MATMUL (i64), the nested-loop 2-D addressing rung.
// `selftest_native_elf_tensor_matmul_i64(m, k, n)` emits a runnable ET_EXEC
// that (1) materializes A (MxK) and B (KxN) row-major in the frame with
// deterministic self-seeding A[r*K+c] = r+c+1, B[p*N+j] = p*j+1 (both nonzero
// at every index, so every shape discriminates), (2) computes C = A @ B as the
// canonical triple nest — for i in M: for j in N: acc = 0; for p in K:
// acc += A[i*K+p] * B[p*N+j]; C[i*N+j] = acc — all three 2-D row-major element
// addresses formed at runtime as ((a*dim)+b)*8 + base, (3) reduces
// sum = Sum C[t] over the M*N result elements via a fourth counted loop,
// (4) writes the 8 LE bytes of `sum` to stdout (full-width observable, checked
// by a Python smoke against an independent pure-Python matmul), and (5) exits
// (sum == expected)*41 + 1 — 42 only on an EXACT i64 match against the
// emit-time-baked expected total (movabs-baked, full-width past imm32), 1
// otherwise. `expected` is computed HOST-side by exact i64 recursion over the
// same closed seeds (the Python smoke is the independent oracle). This proves
// nested loops with 2-D row-major addressing (i*K+p, p*N+j, i*N+j) — the core
// of real linalg — lower to native-ELF with zero MLIR/LLVM.
//
// SHAPE GUARD (the T1/T2 audit hazard, fixed by construction): the frame holds
// three 4096-element i64 arrays (A base -131072, B base -98304, C base -65536,
// 32768 B each). The driver FAILS CLOSED — returns an empty-buf EmitState —
// unless 1 <= m,k,n AND m*k <= 4096 AND k*n <= 4096 AND m*n <= 4096, so no
// shape can overrun A, B, or C.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does
// not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. No frozen byte oracle exists
// for this path (the deleted Rust native backend had no tensor entry); the
// gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
//
// Frame (T1/T2 map + matmul slots):
//   A base = -131072, B base = -98304, C base = -65536 (4096 i64 each).
//   t=-131080 mn=-131088 eight=-131096 one=-131104 cmpflag=-131120
//   baseA=-131128 baseB=-131136 baseC=-131144 ptr=-131152 aval=-131160
//   bval=-131168 acc=-131184 expected=-131192 result=-131200 fd=-131208
//   bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240
//   m=-131256 kdim=-131264 ndim=-131272 sum=-131288 ri=-131296 cj=-131304
//   pp=-131312.
// ============================================================================

// HOST-side expected C[i][j] for the fixed seeds: Sum_{p<k} (i+p+1)*(p*j+1),
// by exact i64 recursion over p (self-host subset — no loops needed).
pub fn nb_tmm_cell(i: i64, j: i64, k: i64, p: i64) -> i64 {
    if p >= k {
        return 0;
    }
    (i + p + 1) * (p * j + 1) + nb_tmm_cell(i, j, k, p + 1)
}

// HOST-side Sum_{j<n} C[i][j].
pub fn nb_tmm_rowsum(i: i64, k: i64, n: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    nb_tmm_cell(i, j, k, 0) + nb_tmm_rowsum(i, k, n, j + 1)
}

// HOST-side grand total Sum_{i<m} Sum_{j<n} C[i][j] — the baked `expected`.
pub fn nb_tmm_total(m: i64, k: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    nb_tmm_rowsum(i, k, n, 0) + nb_tmm_total(m, k, n, i + 1)
}

// 2-D row-major element address: ptr = (([a]*[dim]) + [b]) * 8 + [base], into
// the shared ptr slot (-131152). The one addressing shape all three matmul
// operands use (A: (ri*kdim)+pp, B: (pp*ndim)+cj, C: (ri*ndim)+cj).
pub fn nb_tmm_idx2_ptr(code: String, a_disp: i64, dim_disp: i64, b_disp: i64, base_disp: i64) -> String {
    let c1: String = nb_load_rax(code, a_disp);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), dim_disp);
    let c3: String = nb_arith_rax_mem(c2, op_add(), b_disp);
    let c4: String = nb_arith_rax_mem(c3, op_mul(), 0 - 131096);
    let c5: String = nb_arith_rax_mem(c4, op_add(), base_disp);
    nb_store_rax(c5, 0 - 131152)
}

// Inner seed-A loop: for cj in 0..kdim { A[ri*kdim+cj] = ri+cj+1 }. Emitted
// INSIDE the outer row body, so cj re-inits to 0 each outer iteration.
pub fn nb_tmm_seed_a_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131264);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = ri + cj + 1
    let b1: String = nb_load_rax(wcj, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131304);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131104);
    let b4: String = nb_store_rax(b3, 0 - 131160);
    // A[ri*kdim + cj] = aval
    let p1: String = nb_tmm_idx2_ptr(b4, 0 - 131296, 0 - 131264, 0 - 131304, 0 - 131128);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed-A loop: for ri in 0..m { inner }.
pub fn nb_tmm_seed_a(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_tmm_seed_a_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Inner seed-B loop: for cj in 0..ndim { B[ri*ndim+cj] = ri*cj+1 }.
pub fn nb_tmm_seed_b_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // bval = ri * cj + 1
    let b1: String = nb_load_rax(wcj, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131304);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131104);
    let b4: String = nb_store_rax(b3, 0 - 131168);
    // B[ri*ndim + cj] = bval
    let p1: String = nb_tmm_idx2_ptr(b4, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131136);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131168);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed-B loop: for ri in 0..kdim { inner } (B has kdim rows).
pub fn nb_tmm_seed_b(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131264);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_tmm_seed_b_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Innermost MAC loop: for pp in 0..kdim { acc += A[ri*kdim+pp] * B[pp*ndim+cj] }
// — T2's multiply-accumulate kernel nested under the (ri, cj) result loops,
// with BOTH element addresses formed by 2-D row-major arithmetic.
pub fn nb_tmm_mac_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131312);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131312);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131264);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*kdim + pp]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131264, 0 - 131312, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // bval = B[pp*ndim + cj]
    let b1: String = nb_tmm_idx2_ptr(a3, 0 - 131312, 0 - 131272, 0 - 131304, 0 - 131136);
    let b2: String = nb_emit_load_i64(b1, 0 - 131152);
    let b3: String = nb_store_rax(b2, 0 - 131168);
    // acc += aval * bval
    let c1: String = nb_load_rax(b3, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131168);
    let c3: String = nb_arith_rax_mem(c2, op_add(), 0 - 131184);
    let c4: String = nb_store_rax(c3, 0 - 131184);
    // pp += 1
    let e1: String = nb_load_rax(c4, 0 - 131312);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131312);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Middle column loop: for cj in 0..ndim { acc = 0; MAC over pp; C[ri*ndim+cj]
// = acc }.
pub fn nb_tmm_col_loop(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // acc = 0 for this (ri, cj) result element
    let z0: String = nb_intdot_movimm(wcj, 0, 0 - 131184);
    let mac: String = nb_tmm_mac_inner(z0, jmps, jcell);
    // C[ri*ndim + cj] = acc
    let p1: String = nb_tmm_idx2_ptr(mac, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131144);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131184);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer row loop: for ri in 0..m { column loop }. The full triple nest.
pub fn nb_tmm_row_loop(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_tmm_col_loop(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Reduction loop: sum = Sum_{t < m*n} C[t] (linear over the result buffer, the
// T1 horizontal-reduction shape; bound m*n baked in slot -131088).
pub fn nb_tmm_reduce(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    let r1: String = nb_intdot_load_elem(scj, 0 - 131144, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    let r2: String = nb_load_rax(r1, 0 - 131288);
    let r3: String = nb_arith_rax_mem(r2, op_add(), 0 - 131160);
    let r4: String = nb_store_rax(r3, 0 - 131288);
    let e1: String = nb_load_rax(r4, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Fail-closed empty artifact for rejected matmul shapes (covered tail-literal
// shape — the same final-expression form every selftest driver ends with).
pub fn nb_tmm_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T3 driver. m/k/n are baked at emit time; FAILS CLOSED (empty buf) on
// any shape whose A (m*k), B (k*n) or C (m*n) would overrun its 4096-element
// frame array. Each dim is bounded <= 4096 BEFORE the products are formed, so
// the products cannot i64-overflow-wrap past the `> 4096` checks — the emitted
// code can never index past a buffer, for any (m,k,n) including 2^32-class dims.
pub fn selftest_native_elf_tensor_matmul_i64(m: i64, k: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_tmm_empty();
    }
    if k < 1 {
        return nb_tmm_empty();
    }
    if n < 1 {
        return nb_tmm_empty();
    }
    // Bound each dim <= 4096 BEFORE forming products, so m*k / k*n / m*n cannot
    // exceed 4096*4096 (16.7M) and can never wrap the i64 product past the
    // `> 4096` checks below. Without this, a shape like (2^32,2^32,2^32) wraps
    // every product to 0 mod 2^64, slips the product guards, and the emitted
    // seed/MAC loops march off the frame. Any valid shape already needs each
    // dim <= 4096 (a single row/col fills a 4096-element array), so this only
    // rejects shapes that were already out of range.
    if m > 4096 {
        return nb_tmm_empty();
    }
    if k > 4096 {
        return nb_tmm_empty();
    }
    if n > 4096 {
        return nb_tmm_empty();
    }
    let mk: i64 = m * k;
    if mk > 4096 {
        return nb_tmm_empty();
    }
    let kn: i64 = k * n;
    if kn > 4096 {
        return nb_tmm_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_tmm_empty();
    }
    let expected: i64 = nb_tmm_total(m, k, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected total.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, k, 0 - 131264);
    let k6: String = nb_intdot_movimm(k5, n, 0 - 131272);
    let k7: String = nb_intdot_movimm(k6, mn, 0 - 131088);
    let k8: String = nb_intdot_movimm(k7, 0, 0 - 131288);
    let k9: String = nb_intdot_movimm(k8, expected, 0 - 131192);
    // Runtime base addresses of the three in-frame arrays.
    let ba: String = nb_intdot_lea(k9, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    let bc: String = nb_intdot_lea(bb, 0 - 65536, 0 - 131144);
    // Jump scaffold shared by all 8 loops (16 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sa: String = nb_tmm_seed_a(bc, jmps, jcell);
    let sb: String = nb_tmm_seed_b(sa, jmps, jcell);
    let mm: String = nb_tmm_row_loop(sb, jmps, jcell);
    let rd: String = nb_tmm_reduce(mm, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(rd, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}


// ===== Batch-ported type-checker rules (E2015/E2006/shape-annot/classify) — additive selftest exports =====

// ---- E2015_LET_CLASS_MISMATCH ----
// E2015 LET_CLASS_MISMATCH (let/assign arm): true (1) when a binding
// `let dst: ANN = <value>` or a reassignment `dst = <value>` crosses the
// int/float scalar-class boundary — i.e. the annotated/declared class and the
// value's confident class are both known scalar classes and differ. Byte-exact
// twin of the Rust `ann_class != val_class` guard in the Node::Let / Node::Assign
// arms of check_scalar_class_stmt (src/type_checker/mod.rs). The class-comparison
// kernel is shared with the landed generic mismatch predicate — reused here, not
// re-derived, so the let/assign framing adds no duplicate logic.
pub fn tc_is_let_class_mismatch(ann_ty: i64, val_ty: i64) -> i64 {
    tc_is_class_mismatch(ann_ty, val_ty)
}

// Isolated selftest entry (ADDITIVE — never reached through mindc_compile).
// Selectors: 0=i32, 1=i64, 2=f64, 3=bool. Returns 1 iff the let/assign pair
// (dst: ANN = <VAL>) is an int<->float class mismatch, else 0.
pub fn selftest_tc_let_class_mismatch(ann_sel: i64, val_sel: i64) -> i64 {
    let ann_buf: i64 = tc_name_by_sel(ann_sel);
    let ann_len: i64 = tc_len_by_sel(ann_sel);
    let val_buf: i64 = tc_name_by_sel(val_sel);
    let val_len: i64 = tc_len_by_sel(val_sel);
    let ann_ty: i64 = resolve_type_ident(ann_buf, 0, ann_len);
    let val_ty: i64 = resolve_type_ident(val_buf, 0, val_len);
    tc_is_let_class_mismatch(ann_ty, val_ty)
}

// ---- E2006 ----
// "bytes[" — bytes 98 121 116 101 115 91 ("bytes" is the leading 5-byte prefix).
pub fn tc_fixed_bytes_name_buf() -> i64 {
    make_byte_buf_6(98, 121, 116, 101, 115, 91)
}

// True (1) iff the type name [lo,hi) is EXACTLY "bytes" (the growable vec) —
// twin of the Rust param guard `matches!(param, TypeAnn::Named(n) if n == "bytes")`.
// Exact-length equality: a `bytes[N]` name (len >= 6) can never match.
pub fn tc_name_is_growable_bytes(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo != 5 {
        return 0;
    }
    let ref: i64 = tc_fixed_bytes_name_buf();
    if bytes_eq(buf, lo, lo + 5, ref, 0, 5) == 1 {
        return 1;
    }
    0
}

// True (1) iff the type name [lo,hi) starts with "bytes[" (a fixed-size buffer
// type) — twin of the Rust `typeann_is_fixed_bytes`: `n.starts_with("bytes[")`.
// starts_with is: len >= 6 AND the first 6 bytes equal the prefix.
pub fn tc_name_is_fixed_bytes(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo < 6 {
        return 0;
    }
    let ref: i64 = tc_fixed_bytes_name_buf();
    if bytes_eq(buf, lo, lo + 6, ref, 0, 6) == 1 {
        return 1;
    }
    0
}

// E2006: 1 iff binding an argument of type-name ARG into a parameter of
// type-name PARAM is the Bug #38 fixed-`bytes[N]`-into-growable-`bytes`
// miscompile — i.e. PARAM is exactly "bytes" AND ARG starts with "bytes[".
pub fn tc_is_fixed_bytes_into_vec(param_buf: i64, plo: i64, phi: i64, arg_buf: i64, alo: i64, ahi: i64) -> i64 {
    if tc_name_is_growable_bytes(param_buf, plo, phi) == 0 {
        return 0;
    }
    if tc_name_is_fixed_bytes(arg_buf, alo, ahi) == 1 {
        return 1;
    }
    0
}

// Isolated selftest entry (ADDITIVE — never reached through mindc_compile).
pub fn selftest_tc_fixed_bytes_into_vec(pb0: i64, pb1: i64, pb2: i64, pb3: i64, pb4: i64, pb5: i64, pb6: i64, plen: i64, ab0: i64, ab1: i64, ab2: i64, ab3: i64, ab4: i64, ab5: i64, ab6: i64, alen: i64) -> i64 {
    let param_buf: i64 = make_byte_buf_7(pb0, pb1, pb2, pb3, pb4, pb5, pb6);
    let arg_buf: i64 = make_byte_buf_7(ab0, ab1, ab2, ab3, ab4, ab5, ab6);
    tc_is_fixed_bytes_into_vec(param_buf, 0, plen, arg_buf, 0, alen)
}

// ---- shape_annot_compat ----
// RFC-0012 Phase A shape annotation-compat guard. Twin of the three ordered
// checks in `check_tensor_shape_compat` (src/type_checker/mod.rs ~4952-5014),
// which compares a declared `Tensor<...>` annotation against the inferred
// tensor type at a `let x: Tensor<...> = rhs` site. The Rust order is: dtype
// mismatch first (shape::dtype_mismatch), then rank mismatch (shape::rank_mismatch,
// before individual dims), then per-axis dim mismatch (shape::dim_mismatch) but
// ONLY for pairs where both sides are `ShapeDim::Known` — symbolic dims are
// always compatible at a single binding site.

// shape::dtype_mismatch — 1 iff annotation dtype selector != inferred dtype
// selector (the `ann.dtype != inferred.dtype` guard; only equality matters).
pub fn tc_is_shape_dtype_mismatch(ann_dtype: i64, inf_dtype: i64) -> i64 {
    if ann_dtype != inf_dtype {
        return 1;
    }
    0
}

// shape::rank_mismatch — 1 iff annotation rank != inferred rank (the
// `ann.shape.len() != inferred.shape.len()` guard).
pub fn tc_is_shape_rank_mismatch(ann_rank: i64, inf_rank: i64) -> i64 {
    if ann_rank != inf_rank {
        return 1;
    }
    0
}

// shape::dim_mismatch — one right-aligned/positional axis pair. Twin of the
// `if let (ShapeDim::Known(an), ShapeDim::Known(inf)) = (adim, idim) { if an != inf }`
// loop body: a symbolic dim is encoded as a negative value (< 0) and is always
// compatible (the pattern gate skips it); 1 iff BOTH dims are concrete (>= 0)
// and differ.
pub fn tc_is_shape_dim_mismatch(adim: i64, idim: i64) -> i64 {
    if adim < 0 {
        return 0;
    }
    if idim < 0 {
        return 0;
    }
    if adim != idim {
        return 1;
    }
    0
}

// Combined shape annotation-compat verdict in Rust guard order: 1 = dtype
// mismatch (shape::dtype_mismatch), 2 = rank mismatch (shape::rank_mismatch),
// 3 = at least one concrete-dim mismatch (shape::dim_mismatch — the `pushed`
// bool the Rust returns), 0 = compatible. Supports up to rank 2 (axes a0/a1 vs
// i0/i1); an axis absent at the current rank is passed symbolic (-1) by the
// smoke so it can never manufacture a mismatch, exactly like the loop only
// iterating over the shared, equal-length axes after the rank check passes.
pub fn selftest_tc_shape_annot_compat(ann_dtype: i64, inf_dtype: i64, ann_rank: i64, inf_rank: i64, a0: i64, i0: i64, a1: i64, i1: i64) -> i64 {
    if tc_is_shape_dtype_mismatch(ann_dtype, inf_dtype) == 1 {
        return 1;
    }
    if tc_is_shape_rank_mismatch(ann_rank, inf_rank) == 1 {
        return 2;
    }
    if tc_is_shape_dim_mismatch(a0, i0) == 1 {
        return 3;
    }
    if tc_is_shape_dim_mismatch(a1, i1) == 1 {
        return 3;
    }
    0
}

// ---- classify_error_code ----
pub fn tc_classify_error_code(c1: i64, c2: i64, c3: i64, c4: i64, c5: i64, c6: i64, c7: i64, c8: i64, c9: i64) -> i64 {
    if c1 == 1 {
        return 0;
    }
    if c2 == 1 {
        return 1;
    }
    if c3 == 1 {
        return 2;
    }
    if c4 == 1 {
        return 3;
    }
    if c5 == 1 {
        return 4;
    }
    if c6 == 1 {
        return 5;
    }
    if c7 == 1 {
        return 6;
    }
    if c8 == 1 {
        return 7;
    }
    if c9 == 1 {
        return 8;
    }
    9
}

pub fn selftest_tc_classify_error_code(c1: i64, c2: i64, c3: i64, c4: i64, c5: i64, c6: i64, c7: i64, c8: i64, c9: i64) -> i64 {
    tc_classify_error_code(c1, c2, c3, c4, c5, c6, c7, c8, c9)
}



// ============================================================================
// C4-T4 — native-ELF TENSOR ROW REDUCTION (i64), the axis-reduction rung.
// `selftest_native_elf_tensor_rowsum_i64(m, n)` emits a runnable ET_EXEC that
// (1) materializes A (MxN) row-major in the frame with deterministic
// self-seeding A[i*n+j] = i*n+j+1 (the flat index t+1 — nonzero at every
// index, so every shape discriminates), (2) computes rowsum[i] = Sum_{j<n}
// A[i*n+j] for each row via an inner counted loop nested under the row loop
// (2-D row-major addressing ((i*n)+j)*8 + base, the T3 idx shape), (3) folds
// the rows into a POSITION-WEIGHTED checksum sum = Sum_{i<m} rowsum[i]*rowsum[i]
// (SQUARED — layout-discriminating: a wrong axis / a column reduction gives a
// different sum-of-squares even though the grand sum of A is layout-invariant),
// (4) writes the 8 LE bytes of `sum` to stdout (full-width observable, checked
// by a Python smoke against an independent pure-Python reference), and (5) exits
// (sum == expected)*41 + 1 — 42 only on an EXACT i64 match against the
// emit-time-baked expected checksum (movabs-baked, full-width past imm32), 1
// otherwise. `expected` is computed HOST-side by exact i64 recursion over the
// same closed seeds (no loops; the Python smoke is the independent oracle).
//
// SHAPE GUARD (the T1/T2/T3 audit hazard, fixed by construction): A is a single
// 4096-element i64 frame array (A base -131072). The driver FAILS CLOSED —
// returns an empty-buf EmitState — unless 1 <= m,n AND m <= 4096 AND n <= 4096
// AND m*n <= 4096. Each dim is bounded <= 4096 BEFORE the product m*n is formed,
// so the product cannot i64-overflow-wrap past the `> 4096` check (a shape like
// (2^33, 2^33) wraps m*n to 0 mod 2^64; the per-dim bound refuses it first).
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does
// not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. No frozen byte oracle exists
// for this path; the gate is EXECUTION CORRECTNESS — emit, run, assert
// stdout+exit. Reuses the matmul frame arrays + nb_tmm_idx2_ptr addressing.
//
// Frame (matmul map subset): A base = -131072 (only A used). eight=-131096
// one=-131104 cmpflag=-131120 baseA=-131128 ptr=-131152 aval=-131160
// acc=-131184 (per-row rowsum) expected=-131192 result=-131200 fd=-131208
// bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240 m=-131256
// ndim=-131272 (n) sum=-131288 (checksum) ri=-131296 cj=-131304.
// ============================================================================

// HOST-side rowsum[i] = Sum_{j..n-1} (i*n + j + 1), by exact i64 recursion over
// j (self-host subset — no loops needed).
pub fn nb_rsum_rowval(i: i64, n: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    (i * n + j + 1) + nb_rsum_rowval(i, n, j + 1)
}

// HOST-side checksum Sum_{i..m-1} rowsum[i]*rowsum[i] — the baked `expected`.
// SQUARED per-row so a wrong reduction axis changes the value.
pub fn nb_rsum_total(m: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    let r: i64 = nb_rsum_rowval(i, n, 0);
    r * r + nb_rsum_total(m, n, i + 1)
}

// Inner seed loop: for cj in 0..ndim { A[ri*ndim+cj] = ri*ndim + cj + 1 }.
// Emitted INSIDE the outer row body, so cj re-inits to 0 each outer iteration.
pub fn nb_rsum_seed_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = ri*ndim + cj + 1  (the flat row-major index t+1)
    let b1: String = nb_load_rax(wcj, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131272);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131304);
    let b4: String = nb_arith_rax_mem(b3, op_add(), 0 - 131104);
    let b5: String = nb_store_rax(b4, 0 - 131160);
    // A[ri*ndim + cj] = aval
    let p1: String = nb_tmm_idx2_ptr(b5, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed loop: for ri in 0..m { inner }.
pub fn nb_rsum_seed_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_rsum_seed_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Inner reduce loop: for cj in 0..ndim { acc += A[ri*ndim+cj] } — the per-row
// horizontal sum, 2-D row-major addressing under the row loop.
pub fn nb_rsum_row_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // acc += aval
    let c1: String = nb_load_rax(a3, 0 - 131184);
    let c2: String = nb_arith_rax_mem(c1, op_add(), 0 - 131160);
    let c3: String = nb_store_rax(c2, 0 - 131184);
    // cj += 1
    let e1: String = nb_load_rax(c3, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer row loop: for ri in 0..m { acc = 0; reduce over cj; sum += acc*acc }.
// The SQUARED fold is what makes the observable layout-discriminating.
pub fn nb_rsum_row_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    // acc = 0 for this row
    let z0: String = nb_intdot_movimm(gcj, 0, 0 - 131184);
    let body: String = nb_rsum_row_inner(z0, jmps, jcell);
    // sum += acc*acc  (rax = acc; rax *= acc; rax += sum; sum = rax)
    let q1: String = nb_load_rax(body, 0 - 131184);
    let q2: String = nb_arith_rax_mem(q1, op_mul(), 0 - 131184);
    let q3: String = nb_arith_rax_mem(q2, op_add(), 0 - 131288);
    let q4: String = nb_store_rax(q3, 0 - 131288);
    // ri += 1
    let e1: String = nb_load_rax(q4, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Fail-closed empty artifact for rejected rowsum shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guards use).
pub fn nb_rsum_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T4 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n) would overrun its 4096-element frame array. Each dim is
// bounded <= 4096 BEFORE the product is formed, so m*n cannot wrap past the
// `> 4096` check — the emitted seed/reduce loops can never index off the frame.
pub fn selftest_native_elf_tensor_rowsum_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_rsum_empty();
    }
    if n < 1 {
        return nb_rsum_empty();
    }
    if m > 4096 {
        return nb_rsum_empty();
    }
    if n > 4096 {
        return nb_rsum_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_rsum_empty();
    }
    let expected: i64 = nb_rsum_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, n, 0 - 131272);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131288);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    // Runtime base address of the in-frame A array.
    let ba: String = nb_intdot_lea(k7, 0 - 131072, 0 - 131128);
    // Jump scaffold shared by all 4 loops (8 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sd: String = nb_rsum_seed_outer(ba, jmps, jcell);
    let rw: String = nb_rsum_row_outer(sd, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(rw, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// HOST-side Sum_{j<n} idx*val for row i, idx = j*m+i, val = A[i*n+j] = i*n+j+1.
pub fn nb_tt_rowsum(m: i64, n: i64, i: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    (j * m + i) * (i * n + j + 1) + nb_tt_rowsum(m, n, i, j + 1)
}

// HOST-side position-weighted grand total Sum_{i<m} Sum_{j<n} (j*m+i)*(i*n+j+1)
// — the baked `expected` checksum over the transposed output B.
pub fn nb_tt_total(m: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    nb_tt_rowsum(m, n, i, 0) + nb_tt_total(m, n, i + 1)
}

// Seed loop (linear): for t in 0..m*n { A[t] = t+1 } — materializes the
// row-major input A[i*n+j] = i*n+j+1 via ptr = baseA + t*8.
pub fn nb_tt_seed_a(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = t + 1
    let b1: String = nb_load_rax(scj, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131104);
    let b3: String = nb_store_rax(b2, 0 - 131160);
    // ptr = baseA + t*8
    let d1: String = nb_load_rax(b3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131128);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    // A[t] = aval
    let s1: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131160);
    // t += 1
    let e1: String = nb_load_rax(s1, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Inner transpose loop: for cj in 0..ndim { aval = A[ri*ndim+cj];
// B[cj*m+ri] = aval } — A read uses (a=ri, dim=ndim, b=cj); B write uses the
// OPPOSITE (a=cj, dim=m, b=ri), both through nb_tmm_idx2_ptr.
pub fn nb_tt_xpose_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // B[cj*m + ri] = aval
    let p1: String = nb_tmm_idx2_ptr(a3, 0 - 131304, 0 - 131256, 0 - 131296, 0 - 131136);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer transpose loop: for ri in 0..m { inner }. The full i/j nest.
pub fn nb_tt_xpose_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_tt_xpose_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Position-weighted checksum loop: for idx in 0..m*n { chk += idx * B[idx] }
// over the transposed output buffer (bound m*n baked in slot -131088).
pub fn nb_tt_checksum(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = B[idx]
    let r1: String = nb_intdot_load_elem(scj, 0 - 131136, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    // chk += idx * B[idx]
    let c1: String = nb_load_rax(r1, 0 - 131080);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131160);
    let c3: String = nb_arith_rax_mem(c2, op_add(), 0 - 131288);
    let c4: String = nb_store_rax(c3, 0 - 131288);
    // idx += 1
    let e1: String = nb_load_rax(c4, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// The C4-T4 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n) or B (n*m) would overrun its 4096-element frame array.
// Each dim is bounded <= 4096 BEFORE the product is formed, so m*n cannot wrap
// the i64 product past the `> 4096` check — the emitted loops can never index
// past a buffer, for any (m,n) including 2^32-class dims.
pub fn selftest_native_elf_tensor_transpose_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_tmm_empty();
    }
    if n < 1 {
        return nb_tmm_empty();
    }
    if m > 4096 {
        return nb_tmm_empty();
    }
    if n > 4096 {
        return nb_tmm_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_tmm_empty();
    }
    let expected: i64 = nb_tt_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, n, 0 - 131272);
    let k6: String = nb_intdot_movimm(k5, mn, 0 - 131088);
    let k7: String = nb_intdot_movimm(k6, 0, 0 - 131288);
    let k8: String = nb_intdot_movimm(k7, expected, 0 - 131192);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    // Jump scaffold shared by all 4 loops (8 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sa: String = nb_tt_seed_a(bb, jmps, jcell);
    let xp: String = nb_tt_xpose_outer(sa, jmps, jcell);
    let cs: String = nb_tt_checksum(xp, jmps, jcell);
    // result = chk ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(cs, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (chk == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}



// ============================================================================
// C4-T5 — native-ELF TENSOR ELEMENT-WISE MULTIPLY (i64), the 1-D Hadamard rung.
// `selftest_native_elf_tensor_ewmul_i64(n)` emits a runnable ET_EXEC that
// (1) materializes two length-n i64 buffers in the frame with deterministic
// self-seeding a[i]=i+1, b[i]=2*i+3 (both nonzero at EVERY index, including
// n=1, so every shape discriminates), (2) computes the element-wise product
// c[i] = a[i]*b[i] via an emitted counted loop over the C2 element load/store
// primitives (base + i*8 indexing), (3) folds the result into a POSITION-
// WEIGHTED checksum sum = Sum_{i<n} (i+1)*c[i] via a third emitted loop
// (weight (i+1) makes the observable index-sensitive: a wrong OP (add not mul),
// a swapped/wrong index, or a mis-strided read all yield a different weighted
// sum — a plain grand-sum of c would be position-invariant), (4) writes the 8
// LE bytes of `sum` to stdout (the FULL-width observable — a Python smoke checks
// them against an independent pure-Python reference), and (5) exits with the
// discriminating code (sum == expected)*41 + 1 — 42 only on an EXACT i64 match
// against the emit-time-baked expected (movabs-baked past imm32, so the compare
// stays full-width), 1 otherwise (not a mod-256-maskable residue). `expected` is
// computed HOST-side by exact i64 recursion over the same closed seeds (no
// loops; the Python smoke is the independent oracle).
//
// SHAPE GUARD: A/B/C are three 4096-element i64 frame arrays (A base -131072,
// B base -98304, C base -65536). The driver FAILS CLOSED — returns an empty-buf
// EmitState — unless 1 <= n <= 4096, so no shape can overrun A, B, or C. The
// per-dim bound is applied BEFORE any product is formed, so no i64-overflow
// shape can slip a product guard (there is no product here — a single length n).
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
//
// Frame (T1 ewadd map + three=-131248):
//   A base = -131072, B base = -98304, C base = -65536 (each 32768 B = 4096 el).
//   i=-131080 n=-131088 eight=-131096 one=-131104 two=-131112 cmpflag=-131120
//   baseA=-131128 baseB=-131136 baseC=-131144 ptr=-131152 aval=-131160
//   bval=-131168 cval=-131176 sum=-131184 expected=-131192 result=-131200
//   fd=-131208 bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240
//   three=-131248.
// ============================================================================

// HOST-side baked checksum Sum_{i..n-1} (i+1)*c[i], c[i] = (i+1)*(2i+3), by
// exact i64 recursion over i (self-host subset — no loops needed). POSITION-
// WEIGHTED (weight (i+1)) so a wrong op/index changes the value.
pub fn nb_ewmul_wsum(n: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    (i + 1) * ((i + 1) * (2 * i + 3)) + nb_ewmul_wsum(n, i + 1)
}

// One materialization-loop body: a[i] = i+1 ; b[i] = 2*i+3 ; i += 1. Element
// addresses re-derived at runtime as base + i*8 (the C2 addressing shape).
pub fn nb_ewmul_gen_body(code: String) -> String {
    // a[i] = i + 1
    let a1: String = nb_load_rax(code, 0 - 131080);
    let a2: String = nb_arith_rax_mem(a1, op_add(), 0 - 131104);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    let a4: String = nb_load_rax(a3, 0 - 131080);
    let a5: String = nb_arith_rax_mem(a4, op_mul(), 0 - 131096);
    let a6: String = nb_arith_rax_mem(a5, op_add(), 0 - 131128);
    let a7: String = nb_store_rax(a6, 0 - 131152);
    let a8: String = nb_emit_store_i64(a7, 0 - 131152, 0 - 131160);
    // b[i] = 2*i + 3
    let b1: String = nb_load_rax(a8, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131112);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131248);
    let b4: String = nb_store_rax(b3, 0 - 131168);
    let b5: String = nb_load_rax(b4, 0 - 131080);
    let b6: String = nb_arith_rax_mem(b5, op_mul(), 0 - 131096);
    let b7: String = nb_arith_rax_mem(b6, op_add(), 0 - 131136);
    let b8: String = nb_store_rax(b7, 0 - 131152);
    let b9: String = nb_emit_store_i64(b8, 0 - 131152, 0 - 131168);
    // i += 1
    let e1: String = nb_load_rax(b9, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One element-wise-multiply-loop body: aval = a[i] ; bval = b[i] ;
// c[i] = aval*bval ; i += 1. Loads go through nb_intdot_load_elem (ptr =
// base + i*8, then the register-indirect i64 deref); the store re-derives C's
// element address. Same shape as the ewadd body but the fuse op is MUL.
pub fn nb_ewmul_mul_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131128, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    let b1: String = nb_intdot_load_elem(a1, 0 - 131136, 0 - 131152, 0 - 131168, 0 - 131080, 0 - 131096);
    // cval = aval * bval
    let c1: String = nb_load_rax(b1, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131168);
    let c3: String = nb_store_rax(c2, 0 - 131176);
    // ptr = i*8 + baseC ; *ptr = cval
    let d1: String = nb_load_rax(c3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131144);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let d5: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131176);
    // i += 1
    let e1: String = nb_load_rax(d5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One position-weighted reduction-loop body: cval = c[i] ;
// sum += (i+1)*c[i] ; i += 1. The (i+1) weight is what makes the observable
// index-sensitive (a wrong op/stride shifts the products, so the weighted sum
// diverges even when a plain grand-sum would not).
pub fn nb_ewmul_wsum_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131144, 0 - 131152, 0 - 131176, 0 - 131080, 0 - 131096);
    // rax = i ; rax += 1 (weight) ; rax *= c[i] ; rax += sum ; sum = rax
    let b1: String = nb_load_rax(a1, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131104);
    let b3: String = nb_arith_rax_mem(b2, op_mul(), 0 - 131176);
    let b4: String = nb_arith_rax_mem(b3, op_add(), 0 - 131184);
    let b5: String = nb_store_rax(b4, 0 - 131184);
    // i += 1
    let e1: String = nb_load_rax(b5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// Fail-closed empty artifact for rejected ewmul shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guard uses).
pub fn nb_ewmul_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T5 driver. n is baked at emit time; FAILS CLOSED (empty buf) unless
// 1 <= n <= 4096 (a single length fits one 4096-element frame array). The
// position-weighted expected Sum_{i<n} (i+1)*(i+1)*(2i+3) is computed HOST-side
// by exact i64 recursion and baked via movabs (full-width past imm32).
pub fn selftest_native_elf_tensor_ewmul_i64(n: i64) -> EmitState {
    if n < 1 {
        return nb_ewmul_empty();
    }
    if n > 4096 {
        return nb_ewmul_empty();
    }
    let expected: i64 = nb_ewmul_wsum(n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, n, 0 - 131088);
    let k2: String = nb_intdot_movimm(k1, 8, 0 - 131096);
    let k3: String = nb_intdot_movimm(k2, 1, 0 - 131104);
    let k4: String = nb_intdot_movimm(k3, 2, 0 - 131112);
    let k5: String = nb_intdot_movimm(k4, 3, 0 - 131248);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131184);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    let k8: String = nb_intdot_movimm(k7, 41, 0 - 131240);
    // Runtime base addresses of the three in-frame arrays.
    let ba: String = nb_intdot_lea(k8, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    let bc: String = nb_intdot_lea(bb, 0 - 65536, 0 - 131144);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop 1: materialize a[i]=i+1, b[i]=2*i+3 ---
    let g0: String = nb_intdot_movimm(bc, 0, 0 - 131080);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131080);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let gb: String = nb_ewmul_gen_body(gcj);
    let gjb: String = nb_emit_jmp(gb, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    // --- loop 2: c[i] = a[i] * b[i] (the tensor element-wise product) ---
    let w0: String = nb_intdot_movimm(gjb, 0, 0 - 131080);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131080);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    let wb: String = nb_ewmul_mul_body(wcj);
    let wjb: String = nb_emit_jmp(wb, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _wp1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _wp2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    // --- loop 3: sum = Sum (i+1)*c[i] (position-weighted reduction) ---
    let s0: String = nb_intdot_movimm(wjb, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    let sb: String = nb_ewmul_wsum_body(scj);
    let sjb: String = nb_emit_jmp(sb, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _sp1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _sp2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(sjb, 0 - 131184);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131184);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}


// ============================================================================
// C4-T5 — native-ELF i64 tensor COLUMN REDUCTION (colsum), zero MLIR/LLVM.
// `selftest_native_elf_tensor_colsum_i64(m, n)` emits a runnable ET_EXEC that
// (1) materializes A (MxN) row-major in the frame with deterministic
// self-seeding A[i*n+j] = i*n+j+1 (the flat index t+1 — nonzero at every
// index, so every shape discriminates), (2) computes colsum[j] = Sum_{i<m}
// A[i*n+j] for each COLUMN via an inner counted loop over ROWS (ri) nested
// under the column loop (cj) — the AXIS-TRANSPOSE of C4-T4 rowsum: outer=cj,
// inner=ri, same 2-D row-major addressing ((i*n)+j)*8 + base (a=ri, dim=n,
// b=cj) through nb_tmm_idx2_ptr, (3) folds the columns into a POSITION-WEIGHTED
// checksum sum = Sum_{j<n} colsum[j]*colsum[j] (SQUARED — layout/axis-
// discriminating: the grand sum of A is axis-invariant so a plain sum of
// colsums equals the sum of rowsums; squaring each colsum makes the observable
// depend on the COLUMN partition, so a row reduction, a transposed stride, or a
// wrong bound yields a different sum-of-squares on any non-square shape),
// (4) writes the 8 LE bytes of `sum` to stdout (full-width observable, checked
// by the Python smoke against an independent pure-Python reference), and
// (5) exits (sum == expected)*41 + 1 — 42 only on an EXACT i64 match against
// the emit-time-baked expected checksum (movabs-baked, full-width past imm32),
// 1 otherwise. `expected` is computed HOST-side by exact i64 recursion over the
// same closed seeds (no loops; the Python smoke is the independent oracle).
//
// SHAPE GUARD (the T1/T2/T3 audit hazard, fixed by construction): A is a single
// 4096-element i64 frame array (A base -131072). The driver FAILS CLOSED —
// returns an empty-buf EmitState — unless 1 <= m,n AND m <= 4096 AND n <= 4096
// AND m*n <= 4096. Each dim is bounded <= 4096 BEFORE the product m*n is formed,
// so the product cannot i64-overflow-wrap past the `> 4096` check.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does
// not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. Reuses the matmul frame
// arrays + nb_tmm_idx2_ptr addressing; all emit helpers carry the UNIQUE
// `nb_csum_` prefix so they cannot collide with rowsum's `nb_rsum_` set.
//
// Frame (matmul map subset, same as rowsum): A base = -131072 (only A used).
// eight=-131096 one=-131104 cmpflag=-131120 baseA=-131128 ptr=-131152
// aval=-131160 acc=-131184 (per-column colsum) expected=-131192 result=-131200
// fd=-131208 bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240
// m=-131256 ndim=-131272 (n) sum=-131288 (checksum) ri=-131296 cj=-131304.
// ============================================================================

// HOST-side colsum[j] = Sum_{i..m-1} (i*n + j + 1), by exact i64 recursion over
// i (self-host subset — no loops needed).
pub fn nb_csum_colval(m: i64, n: i64, j: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    (i * n + j + 1) + nb_csum_colval(m, n, j, i + 1)
}

// HOST-side checksum Sum_{j..n-1} colsum[j]*colsum[j] — the baked `expected`.
// SQUARED per-column so a wrong reduction axis changes the value.
pub fn nb_csum_total(m: i64, n: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    let c: i64 = nb_csum_colval(m, n, j, 0);
    c * c + nb_csum_total(m, n, j + 1)
}

// Inner seed loop: for cj in 0..ndim { A[ri*ndim+cj] = ri*ndim + cj + 1 }.
// Emitted INSIDE the outer row body, so cj re-inits to 0 each outer iteration.
// (Own copy — keeps colsum self-contained, no cross-op coupling to nb_rsum_*.)
pub fn nb_csum_seed_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = ri*ndim + cj + 1  (the flat row-major index t+1)
    let b1: String = nb_load_rax(wcj, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131272);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131304);
    let b4: String = nb_arith_rax_mem(b3, op_add(), 0 - 131104);
    let b5: String = nb_store_rax(b4, 0 - 131160);
    // A[ri*ndim + cj] = aval
    let p1: String = nb_tmm_idx2_ptr(b5, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed loop: for ri in 0..m { inner }.
pub fn nb_csum_seed_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_csum_seed_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Inner reduce loop: for ri in 0..m { acc += A[ri*ndim+cj] } — the per-column
// VERTICAL sum down the column, 2-D row-major addressing (a=ri, dim=ndim,
// b=cj) under the column loop. This is the axis-transpose of nb_rsum_row_inner
// (which iterates cj under a row loop); here ri is the inner index and cj is
// held fixed by the outer loop.
pub fn nb_csum_col_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131296);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // acc += aval
    let c1: String = nb_load_rax(a3, 0 - 131184);
    let c2: String = nb_arith_rax_mem(c1, op_add(), 0 - 131160);
    let c3: String = nb_store_rax(c2, 0 - 131184);
    // ri += 1
    let e1: String = nb_load_rax(c3, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer column loop: for cj in 0..ndim { acc = 0; reduce over ri; sum += acc*acc }.
// The SQUARED fold is what makes the observable layout/axis-discriminating.
pub fn nb_csum_col_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131304);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    // acc = 0 for this column
    let z0: String = nb_intdot_movimm(gcj, 0, 0 - 131184);
    let body: String = nb_csum_col_inner(z0, jmps, jcell);
    // sum += acc*acc  (rax = acc; rax *= acc; rax += sum; sum = rax)
    let q1: String = nb_load_rax(body, 0 - 131184);
    let q2: String = nb_arith_rax_mem(q1, op_mul(), 0 - 131184);
    let q3: String = nb_arith_rax_mem(q2, op_add(), 0 - 131288);
    let q4: String = nb_store_rax(q3, 0 - 131288);
    // cj += 1
    let e1: String = nb_load_rax(q4, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Fail-closed empty artifact for rejected colsum shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guards use).
pub fn nb_csum_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T5 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n) would overrun its 4096-element frame array. Each dim is
// bounded <= 4096 BEFORE the product is formed, so m*n cannot wrap past the
// `> 4096` check — the emitted seed/reduce loops can never index off the frame.
pub fn selftest_native_elf_tensor_colsum_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_csum_empty();
    }
    if n < 1 {
        return nb_csum_empty();
    }
    if m > 4096 {
        return nb_csum_empty();
    }
    if n > 4096 {
        return nb_csum_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_csum_empty();
    }
    let expected: i64 = nb_csum_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, n, 0 - 131272);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131288);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    // Runtime base address of the in-frame A array.
    let ba: String = nb_intdot_lea(k7, 0 - 131072, 0 - 131128);
    // Jump scaffold shared by all 4 loops (8 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sd: String = nb_csum_seed_outer(ba, jmps, jcell);
    let cl: String = nb_csum_col_outer(sd, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(cl, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}


// ============================================================================
// C4-T5 — native-ELF TENSOR ROW-VECTOR BROADCAST ADD (i64), the stride-0
// broadcast rung. `selftest_native_elf_tensor_bcastadd_i64(m, n)` emits a
// runnable ET_EXEC that (1) materializes A (MxN) row-major in the frame with
// deterministic self-seeding A[i*n+j] = i*n+j+1 (the flat index t+1) AND a
// length-N row vector B with B[j] = j*3+1 (both nonzero at every index, so
// every shape discriminates), (2) computes C[i*n+j] = A[i*n+j] + B[j] with B
// BROADCAST across all m rows — the B element address depends on the column cj
// ONLY (stride 0 in the row axis i), the defining feature of a row-vector
// broadcast — via a 2-D nest over ((i*n)+j)*8+base for A/C and cj*8+baseB for B,
// (3) folds the result into a POSITION-WEIGHTED checksum
// chk = Sum_{i,j} (i*n+j) * C[i*n+j] over the M*N result elements (weighting by
// the flat position, so a WRONG broadcast axis — B[i] instead of B[j] — or a
// no-broadcast variant produces a different checksum even on shapes where a
// plain grand-sum would coincide), (4) writes the 8 LE bytes of `chk` to stdout
// (full-width observable, checked by a Python smoke against an independent
// pure-Python reference), and (5) exits (chk == expected)*41 + 1 — 42 only on
// an EXACT i64 match against the emit-time-baked expected checksum (movabs-baked,
// full-width past imm32), 1 otherwise. `expected` is computed HOST-side by exact
// i64 recursion over the same closed seeds (no loops; the Python smoke is the
// independent oracle). This proves stride-0 (broadcast) addressing — a mixed
// 2-D/1-D operand indexing pattern at the core of bias-add and layer-norm
// affine steps — lowers to native-ELF with zero MLIR/LLVM.
//
// SHAPE GUARD (the T1..T4 audit hazard, fixed by construction): the frame holds
// three 4096-element i64 arrays (A base -131072, B base -98304 length n,
// C base -65536). The driver FAILS CLOSED — returns an empty-buf EmitState —
// unless 1 <= m,n AND m <= 4096 AND n <= 4096 AND m*n <= 4096. Each dim is
// bounded <= 4096 BEFORE the product m*n is formed, so the product cannot
// i64-overflow-wrap past the `> 4096` check (a shape like (2^33, 2^33) wraps m*n
// to 0 mod 2^64; the per-dim bound refuses it first). B is length n <= 4096, so
// the broadcast read cj*8+baseB can never leave the B array.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does
// not call it), so every self-host fixture lowers exactly as before and the
// integer native-ELF oracle stays byte-identical. No frozen byte oracle exists
// for this path; the gate is EXECUTION CORRECTNESS — emit, run, assert
// stdout+exit. Reuses the matmul frame arrays + nb_tmm_idx2_ptr addressing.
//
// Frame (matmul map subset): A base = -131072, B base = -98304, C base = -65536.
// t/idx=-131080 mn=-131088 eight=-131096 one=-131104 cmpflag=-131120
// baseA=-131128 baseB=-131136 baseC=-131144 ptr=-131152 aval=-131160
// bval=-131168 cval=-131184 expected=-131192 result=-131200 fd=-131208
// bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240 three=-131248
// m=-131256 ndim=-131272 (n) sum=-131288 (checksum) ri=-131296 cj=-131304.
// ============================================================================

// HOST-side Sum_{j<n} (i*n+j) * C[i*n+j] for row i, C[i*n+j] = (i*n+j+1)+(j*3+1),
// by exact i64 recursion over j (self-host subset — no loops needed). The
// position weight (i*n+j) is what makes a wrong broadcast axis observable.
pub fn nb_bcast_rowval(m: i64, n: i64, i: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    (i * n + j) * ((i * n + j + 1) + (j * 3 + 1)) + nb_bcast_rowval(m, n, i, j + 1)
}

// HOST-side position-weighted grand total Sum_{i<m} Sum_{j<n} (i*n+j)*C[i*n+j] —
// the baked `expected` checksum over the broadcast-add output C.
pub fn nb_bcast_total(m: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    nb_bcast_rowval(m, n, i, 0) + nb_bcast_total(m, n, i + 1)
}

// Seed loop (linear): for t in 0..m*n { A[t] = t+1 } — materializes the
// row-major input A[i*n+j] = i*n+j+1 via ptr = baseA + t*8.
pub fn nb_bcast_seed_a(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = t + 1
    let b1: String = nb_load_rax(scj, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131104);
    let b3: String = nb_store_rax(b2, 0 - 131160);
    // ptr = baseA + t*8
    let d1: String = nb_load_rax(b3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131128);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let s1: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131160);
    // t += 1
    let e1: String = nb_load_rax(s1, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Seed loop (linear): for j in 0..ndim { B[j] = j*3 + 1 } — materializes the
// length-n row vector via ptr = baseB + j*8. Uses the counter slot -131080 and
// bound ndim (-131272); the multiplier 3 lives in slot -131248.
pub fn nb_bcast_seed_b(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // bval = j*3 + 1
    let b1: String = nb_load_rax(scj, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131248);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131104);
    let b4: String = nb_store_rax(b3, 0 - 131168);
    // ptr = baseB + j*8
    let d1: String = nb_load_rax(b4, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131136);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let s1: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131168);
    // j += 1
    let e1: String = nb_load_rax(s1, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Inner compute loop: for cj in 0..ndim { aval = A[ri*ndim+cj];
// bval = B[cj]; C[ri*ndim+cj] = aval + bval }. A/C use 2-D row-major addressing
// (ri*ndim+cj) via nb_tmm_idx2_ptr; B uses cj*8+baseB — the column index ONLY,
// independent of ri (stride 0 in the row axis) — the row-vector broadcast.
pub fn nb_bcast_compute_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // bval = B[cj]  (ptr = baseB + cj*8 — broadcast: depends on cj ONLY, stride 0 in ri)
    let b1: String = nb_load_rax(a3, 0 - 131304);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131096);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131136);
    let b4: String = nb_store_rax(b3, 0 - 131152);
    let b5: String = nb_emit_load_i64(b4, 0 - 131152);
    let b6: String = nb_store_rax(b5, 0 - 131168);
    // cval = aval + bval
    let c1: String = nb_load_rax(b6, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_add(), 0 - 131168);
    let c3: String = nb_store_rax(c2, 0 - 131184);
    // C[ri*ndim + cj] = cval
    let p1: String = nb_tmm_idx2_ptr(c3, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131144);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131184);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer compute loop: for ri in 0..m { inner }. The full i/j nest.
pub fn nb_bcast_compute_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_bcast_compute_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Position-weighted checksum loop: for idx in 0..m*n { chk += idx * C[idx] }
// over the broadcast-add output buffer (bound m*n baked in slot -131088). The
// idx weight catches a wrong broadcast axis / no-broadcast layout.
pub fn nb_bcast_checksum(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = C[idx]
    let r1: String = nb_intdot_load_elem(scj, 0 - 131144, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    // chk += idx * C[idx]
    let c1: String = nb_load_rax(r1, 0 - 131080);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131160);
    let c3: String = nb_arith_rax_mem(c2, op_add(), 0 - 131288);
    let c4: String = nb_store_rax(c3, 0 - 131288);
    // idx += 1
    let e1: String = nb_load_rax(c4, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Fail-closed empty artifact for rejected bcastadd shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guards use).
pub fn nb_bcast_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T5 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n), B (n) or C (m*n) would overrun its 4096-element frame
// array. Each dim is bounded <= 4096 BEFORE the product m*n is formed, so m*n
// cannot wrap the i64 product past the `> 4096` check — the emitted seed/compute/
// checksum loops can never index off the frame, for any (m,n) including
// 2^32-class dims.
pub fn selftest_native_elf_tensor_bcastadd_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_bcast_empty();
    }
    if n < 1 {
        return nb_bcast_empty();
    }
    if m > 4096 {
        return nb_bcast_empty();
    }
    if n > 4096 {
        return nb_bcast_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_bcast_empty();
    }
    let expected: i64 = nb_bcast_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, 3, 0 - 131248);
    let k5: String = nb_intdot_movimm(k4, m, 0 - 131256);
    let k6: String = nb_intdot_movimm(k5, n, 0 - 131272);
    let k7: String = nb_intdot_movimm(k6, mn, 0 - 131088);
    let k8: String = nb_intdot_movimm(k7, 0, 0 - 131288);
    let k9: String = nb_intdot_movimm(k8, expected, 0 - 131192);
    // Runtime base addresses of the three in-frame arrays.
    let ba: String = nb_intdot_lea(k9, 0 - 131072, 0 - 131128);
    let bb: String = nb_intdot_lea(ba, 0 - 98304, 0 - 131136);
    let bc: String = nb_intdot_lea(bb, 0 - 65536, 0 - 131144);
    // Jump scaffold shared by all 5 loops (10 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sa: String = nb_bcast_seed_a(bc, jmps, jcell);
    let sb: String = nb_bcast_seed_b(sa, jmps, jcell);
    let cp: String = nb_bcast_compute_outer(sb, jmps, jcell);
    let cs: String = nb_bcast_checksum(cp, jmps, jcell);
    // result = chk ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(cs, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (chk == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}




// ============================================================================
// C4-T6 — native-ELF TENSOR ROW MAX-REDUCTION (i64), the argmax-reduction rung.
// `selftest_native_elf_tensor_maxrowmax_i64(m, n)` emits a runnable ET_EXEC that
// (1) materializes A (MxN) row-major in the frame with deterministic self-seeding
// A[i*n+j] = ((i*7 + j*3 + 1) mod 97) + 1 — every element is in [1,97] (nonzero
// at every index) and, because the +3 column stride WRAPS mod 97, the per-row
// values are NON-MONOTONE, so each row's maximum is a genuine interior argmax,
// NOT trivially the last (or first) element, (2) computes rowmax[i] =
// max_{j<n} A[i*n+j] for each row via an inner counted loop nested under the row
// loop (2-D row-major addressing ((i*n)+j)*8 + base, the T3/T4 idx shape) whose
// running max is tracked with a native `cmp rax,[acc] ; cmovl rax,[aval]` — a
// real compare + conditional-move, so the max is data-selected in-register with
// NO branch in the reduction body, (3) folds the rows into a POSITION-WEIGHTED
// checksum sum = Sum_{i<m} (i+1)*rowmax[i] (each row scaled by its 1-based index,
// so a wrong reduction — a MIN, a first/last-element pick, or a wrong axis — that
// changes even one rowmax lands at a DIFFERENT weighted total; a plain unweighted
// sum-of-maxes could coincide across a permutation of the per-row maxes, the
// weight forecloses that), (4) writes the 8 LE bytes of `sum` to stdout
// (full-width observable, checked by a Python smoke against an independent
// pure-Python reference), and (5) exits (sum == expected)*41 + 1 — 42 only on an
// EXACT i64 match against the emit-time-baked expected checksum (movabs-baked,
// full 8-byte immediate), 1 otherwise. `expected` is computed HOST-side by exact
// i64 recursion over the same closed seeds (no loops; the Python smoke is the
// independent oracle).
//
// SHAPE GUARD (the T1..T5 audit hazard, fixed by construction): A is a single
// 4096-element i64 frame array (A base -131072). The driver FAILS CLOSED —
// returns an empty-buf EmitState via `return nb_rmx_empty();` (nfn-matcher-safe,
// no early struct literal) — unless 1 <= m,n AND m <= 4096 AND n <= 4096 AND
// m*n <= 4096. Each dim is bounded <= 4096 BEFORE the product m*n is formed, so
// the product cannot i64-overflow-wrap past the `> 4096` check and the emitted
// seed/reduce loops can never index off the frame.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
// Reuses the matmul frame arrays + nb_tmm_idx2_ptr addressing; ALL helpers carry
// the UNIQUE `nb_rmx_` prefix so they cannot collide with any other rung.
//
// Frame (matmul map subset): A base = -131072 (only A used). eight=-131096
// one=-131104 cmpflag=-131120 baseA=-131128 ptr=-131152 aval=-131160
// acc=-131184 (per-row running max) expected=-131192 result=-131200 fd=-131208
// bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240 m=-131256
// ndim=-131272 (n) sum=-131288 (checksum) ri=-131296 cj=-131304. NEW private
// slots (all BELOW every landed scalar at -131304, above the frame bottom
// -135168, and well below A's -98304 top — no overlap): c7=-131320 c3=-131328
// c97=-131336 posw=-131344 (the i+1 row weight scratch).
// ============================================================================

// HOST-side seed A[i*n+j] = ((i*7 + j*3 + 1) mod 97) + 1 — the exact closed form
// the emitted code self-materializes at runtime (the independent oracle mirrors
// it in pure Python). Positive dividend, so `%` matches x86 idiv truncation.
pub fn nb_rmx_seedval(i: i64, j: i64) -> i64 {
    ((i * 7 + j * 3 + 1) % 97) + 1
}

// HOST-side rowmax[i] = max_{j<n} seedval(i,j), by exact i64 tail recursion over
// j carrying the running max `cur` (self-host subset — no loops). Seeds are all
// >= 1, so seeding `cur = 0` at the call site makes the first element win and the
// true row maximum fall out.
pub fn nb_rmx_rowmax(i: i64, n: i64, j: i64, cur: i64) -> i64 {
    if j >= n {
        return cur;
    }
    let v: i64 = nb_rmx_seedval(i, j);
    if v > cur {
        return nb_rmx_rowmax(i, n, j + 1, v);
    }
    nb_rmx_rowmax(i, n, j + 1, cur)
}

// HOST-side position-weighted checksum Sum_{i<m} (i+1)*rowmax[i] — the baked
// `expected`. The (i+1) weight is what makes the observable discriminate a wrong
// reduction (min / first-or-last element / wrong axis) that a bare sum-of-maxes
// could hide under a permutation.
pub fn nb_rmx_total(m: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    let r: i64 = nb_rmx_rowmax(i, n, 0, 0);
    (i + 1) * r + nb_rmx_total(m, n, i + 1)
}

// Inner seed loop: for cj in 0..ndim { A[ri*ndim+cj] = ((ri*7+cj*3+1) mod 97)+1 }.
// Emitted INSIDE the outer row body, so cj re-inits to 0 each outer iteration.
// The `mod 97` uses the proven native op_mod arm (nb_div_guarded is_mod=1) — the
// same guarded idiv path div_shift_cmp_edge_smoke pins at runtime.
pub fn nb_rmx_seed_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // x = ri*7 (into aval temp)
    let b1: String = nb_load_rax(wcj, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131320);
    let b3: String = nb_store_rax(b2, 0 - 131160);
    // x = x + cj*3 + 1
    let b4: String = nb_load_rax(b3, 0 - 131304);
    let b5: String = nb_arith_rax_mem(b4, op_mul(), 0 - 131328);
    let b6: String = nb_arith_rax_mem(b5, op_add(), 0 - 131160);
    let b7: String = nb_arith_rax_mem(b6, op_add(), 0 - 131104);
    let b8: String = nb_store_rax(b7, 0 - 131160);
    // aval = (x mod 97) + 1  — in [1,97], nonzero at every index
    let b9: String = nb_load_rax(b8, 0 - 131160);
    let b10: String = nb_arith_rax_mem(b9, op_mod(), 0 - 131336);
    let b11: String = nb_arith_rax_mem(b10, op_add(), 0 - 131104);
    let b12: String = nb_store_rax(b11, 0 - 131160);
    // A[ri*ndim + cj] = aval
    let p1: String = nb_tmm_idx2_ptr(b12, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed loop: for ri in 0..m { inner }.
pub fn nb_rmx_seed_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_rmx_seed_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// The running-max update: acc = max(acc, aval), branchless via a real
// compare + conditional-move. rax = acc ; `cmp rax,[rbp+aval]` sets the signed
// flags for (acc - aval) ; `cmovl rax,[rbp+aval]` (48 0F 4C 85 disp32) overwrites
// rax with aval ONLY when acc < aval (SF!=OF) ; store rax back to acc. No jump is
// emitted — the reduction body has no branch, so this adds ZERO jump records to
// the scaffold (the loop's je/jmp bookkeeping stays identical to rowsum's).
pub fn nb_rmx_cmove(code: String, aval_disp: i64, acc_disp: i64) -> String {
    let c0: String = nb_load_rax(code, acc_disp);
    // cmp rax, [rbp+aval] = 48 3B 85 <disp32>
    let c1: String = nb_push(c0, 72);
    let c2: String = nb_push(c1, 59);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, aval_disp);
    // cmovl rax, [rbp+aval] = 48 0F 4C 85 <disp32>
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 76);
    let c8: String = nb_push(c7, 133);
    let c9: String = nb_i32le_signed(c8, aval_disp);
    nb_store_rax(c9, acc_disp)
}

// Inner reduce loop: for cj in 0..ndim { aval = A[ri*ndim+cj]; acc = max(acc,aval) }
// — the per-row horizontal MAX, 2-D row-major addressing under the row loop, the
// running max tracked by the cmp+cmovl select above.
pub fn nb_rmx_row_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // acc = max(acc, aval)  (cmp + cmovl select — no branch)
    let mx: String = nb_rmx_cmove(a3, 0 - 131160, 0 - 131184);
    // cj += 1
    let e1: String = nb_load_rax(mx, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer row loop: for ri in 0..m { acc = 0; max-reduce over cj; sum += (ri+1)*acc }.
// The POSITION-WEIGHTED fold is what makes the observable discriminate a wrong
// reduction. acc seeds at 0 (all elements >= 1, so the first element wins).
pub fn nb_rmx_row_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    // acc = 0 for this row
    let z0: String = nb_intdot_movimm(gcj, 0, 0 - 131184);
    let body: String = nb_rmx_row_inner(z0, jmps, jcell);
    // posw = ri + 1
    let q1: String = nb_load_rax(body, 0 - 131296);
    let q2: String = nb_arith_rax_mem(q1, op_add(), 0 - 131104);
    let q3: String = nb_store_rax(q2, 0 - 131344);
    // sum += posw * acc
    let q4: String = nb_load_rax(q3, 0 - 131184);
    let q5: String = nb_arith_rax_mem(q4, op_mul(), 0 - 131344);
    let q6: String = nb_arith_rax_mem(q5, op_add(), 0 - 131288);
    let q7: String = nb_store_rax(q6, 0 - 131288);
    // ri += 1
    let e1: String = nb_load_rax(q7, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Fail-closed empty artifact for rejected max-reduction shapes (covered
// tail-literal shape — the nfn-matcher-safe `return helper();` form the guards
// use, so no early struct literal trips the nfn early-return gotcha).
pub fn nb_rmx_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T6 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n) would overrun its 4096-element frame array. Each dim is
// bounded <= 4096 BEFORE the product is formed, so m*n cannot wrap past the
// `> 4096` check — the emitted seed/reduce loops can never index off the frame.
pub fn selftest_native_elf_tensor_maxrowmax_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_rmx_empty();
    }
    if n < 1 {
        return nb_rmx_empty();
    }
    if m > 4096 {
        return nb_rmx_empty();
    }
    if n > 4096 {
        return nb_rmx_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_rmx_empty();
    }
    let expected: i64 = nb_rmx_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum + seed constants.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, n, 0 - 131272);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131288);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    let k8: String = nb_intdot_movimm(k7, 7, 0 - 131320);
    let k9: String = nb_intdot_movimm(k8, 3, 0 - 131328);
    let k10: String = nb_intdot_movimm(k9, 97, 0 - 131336);
    // Runtime base address of the in-frame A array.
    let ba: String = nb_intdot_lea(k10, 0 - 131072, 0 - 131128);
    // Jump scaffold shared by all 4 loops (8 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sd: String = nb_rmx_seed_outer(ba, jmps, jcell);
    let rw: String = nb_rmx_row_outer(sd, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(rw, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}




// ============================================================================
// C4-T6 — native-ELF i64 tensor ELEMENTWISE RELU (max(x,0)), zero MLIR/LLVM.
// `selftest_native_elf_tensor_relu_i64(n)` emits a runnable ET_EXEC that
// (1) materializes ONE length-n i64 buffer in the frame with deterministic
// self-seeding a[i] = (i - n/2)*3 — a ramp that STRADDLES ZERO (the lower ~half
// of indices are strictly negative, the upper ~half strictly positive), so the
// nonlinearity is exercised on BOTH sides at every non-trivial shape, (2)
// computes the element-wise rectifier c[i] = max(a[i], 0) via an emitted counted
// loop: each element is loaded, a signed `cmp a[i], 0 ; setg` yields the 0/1
// sign predicate (1 iff a[i] > 0), and c[i] = a[i] * predicate zeroes every
// non-positive input while passing positives through unchanged (a cmp-driven
// conditional zero — no MLIR select, no libm), (3) folds the result into a
// POSITION-WEIGHTED checksum sum = Sum_{i<n} (i+1)*c[i] via a third emitted loop
// (the (i+1) weight makes the observable index-sensitive: dropping the relu —
// keeping negatives — shifts the weighted sum DOWN because the clamped-away
// negative terms would otherwise SUBTRACT, so a plain copy yields a distinct
// value; a plain grand-sum of c would additionally be position-invariant), (4)
// writes the 8 LE bytes of `sum` to stdout (the FULL-width observable — a Python
// smoke checks them against an independent pure-Python reference), and (5) exits
// with the discriminating code (sum == expected)*41 + 1 — 42 only on an EXACT
// i64 match against the emit-time-baked expected (movabs-baked past imm32, so
// the compare stays full-width), 1 otherwise (not a mod-256-maskable residue).
// `expected` is computed HOST-side by exact i64 recursion over the same closed
// seed + rectifier (no loops; the Python smoke is the independent oracle).
//
// SHAPE GUARD: A is one 4096-element i64 frame array (A base -131072), C is one
// more (C base -65536). The driver FAILS CLOSED — returns an empty-buf EmitState
// — unless 1 <= n <= 4096, so no shape can overrun A or C. The bound is applied
// BEFORE any address is formed.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
//
// Frame (unique cells; A base -131072, C base -65536, each 32768 B = 4096 el):
//   i=-131080 n=-131088 eight=-131096 one=-131104 three=-131112 cmpflag=-131120
//   baseA=-131128 baseC=-131144 ptr=-131152 aval=-131160 flag=-131168
//   cval=-131176 sum=-131184 expected=-131192 result=-131200 fd=-131208
//   bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240 half=-131248
//   zero=-131256.
// ============================================================================

// One seed of the rectifier reference: relu of the ramp value at index i.
// a = (i - half)*3 ; returns max(a, 0). `half` is n/2 (baked HOST-side).
pub fn nb_relu_val(i: i64, half: i64) -> i64 {
    let a: i64 = (i - half) * 3;
    if a > 0 {
        return a;
    }
    return 0;
}

// HOST-side baked checksum Sum_{i..n-1} (i+1)*relu((i-half)*3), by exact i64
// recursion over i (self-host subset — no loops). POSITION-WEIGHTED (weight
// (i+1)) so dropping the relu or mis-striding the read changes the value.
pub fn nb_relu_wsum(n: i64, half: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    (i + 1) * nb_relu_val(i, half) + nb_relu_wsum(n, half, i + 1)
}

// One materialization-loop body: a[i] = (i - half)*3 ; i += 1. The ramp
// straddles zero (a[i] < 0 for i < half, > 0 for i > half). Element address
// re-derived at runtime as baseA + i*8 (the C2 addressing shape).
pub fn nb_relu_gen_body(code: String) -> String {
    // aval = (i - half) * 3
    let a1: String = nb_load_rax(code, 0 - 131080);
    let a2: String = nb_arith_rax_mem(a1, op_sub(), 0 - 131248);
    let a3: String = nb_arith_rax_mem(a2, op_mul(), 0 - 131112);
    let a4: String = nb_store_rax(a3, 0 - 131160);
    // ptr = i*8 + baseA ; *ptr = aval
    let d1: String = nb_load_rax(a4, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131128);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let d5: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131160);
    // i += 1
    let e1: String = nb_load_rax(d5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One elementwise-relu-loop body: aval = a[i] ; flag = (aval > 0) via a signed
// `cmp aval, 0 ; setg` ; c[i] = aval*flag (the cmp-driven conditional zero —
// positives pass, non-positives clamp to 0) ; i += 1. Load goes through
// nb_intdot_load_elem (ptr = baseA + i*8, then register-indirect i64 deref); the
// store re-derives C's element address.
pub fn nb_relu_relu_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131128, 0 - 131152, 0 - 131160, 0 - 131080, 0 - 131096);
    // flag = (aval > 0) — signed setg against the baked zero cell (0/1 in rax)
    let f1: String = nb_load_rax(a1, 0 - 131160);
    let f2: String = nb_cmp_rax_mem(f1, nb_setcc_opcode(op_gt()), 0 - 131256);
    let f3: String = nb_store_rax(f2, 0 - 131168);
    // cval = aval * flag  (aval when aval>0, else 0 — the rectifier)
    let c1: String = nb_load_rax(f3, 0 - 131160);
    let c2: String = nb_arith_rax_mem(c1, op_mul(), 0 - 131168);
    let c3: String = nb_store_rax(c2, 0 - 131176);
    // ptr = i*8 + baseC ; *ptr = cval
    let d1: String = nb_load_rax(c3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131144);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    let d5: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131176);
    // i += 1
    let e1: String = nb_load_rax(d5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// One position-weighted reduction-loop body: cval = c[i] ; sum += (i+1)*c[i] ;
// i += 1. The (i+1) weight is what makes the observable index-sensitive.
pub fn nb_relu_wsum_body(code: String) -> String {
    let a1: String = nb_intdot_load_elem(code, 0 - 131144, 0 - 131152, 0 - 131176, 0 - 131080, 0 - 131096);
    let b1: String = nb_load_rax(a1, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131104);
    let b3: String = nb_arith_rax_mem(b2, op_mul(), 0 - 131176);
    let b4: String = nb_arith_rax_mem(b3, op_add(), 0 - 131184);
    let b5: String = nb_store_rax(b4, 0 - 131184);
    let e1: String = nb_load_rax(b5, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    nb_store_rax(e2, 0 - 131080)
}

// Fail-closed empty artifact for rejected relu shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guard uses).
pub fn nb_relu_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T6 driver. n is baked at emit time; FAILS CLOSED (empty buf) unless
// 1 <= n <= 4096 (a single length fits one 4096-element frame array). half = n/2
// is baked HOST-side; the position-weighted expected Sum_{i<n} (i+1)*relu((i-
// half)*3) is computed HOST-side by exact i64 recursion and baked via movabs.
pub fn selftest_native_elf_tensor_relu_i64(n: i64) -> EmitState {
    if n < 1 {
        return nb_relu_empty();
    }
    if n > 4096 {
        return nb_relu_empty();
    }
    let half: i64 = n / 2;
    let expected: i64 = nb_relu_wsum(n, half, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants.
    let k1: String = nb_intdot_movimm(p0, n, 0 - 131088);
    let k2: String = nb_intdot_movimm(k1, 8, 0 - 131096);
    let k3: String = nb_intdot_movimm(k2, 1, 0 - 131104);
    let k4: String = nb_intdot_movimm(k3, 3, 0 - 131112);
    let k5: String = nb_intdot_movimm(k4, 0, 0 - 131184);
    let k6: String = nb_intdot_movimm(k5, expected, 0 - 131192);
    let k7: String = nb_intdot_movimm(k6, 41, 0 - 131240);
    let k8: String = nb_intdot_movimm(k7, half, 0 - 131248);
    let k9: String = nb_intdot_movimm(k8, 0, 0 - 131256);
    // Runtime base addresses of the two in-frame arrays.
    let ba: String = nb_intdot_lea(k9, 0 - 131072, 0 - 131128);
    let bc: String = nb_intdot_lea(ba, 0 - 65536, 0 - 131144);
    // Jump scaffold buffer shared by all three loops.
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop 1: materialize a[i] = (i - half)*3 (the zero-straddling ramp) ---
    let g0: String = nb_intdot_movimm(bc, 0, 0 - 131080);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131080);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let gb: String = nb_relu_gen_body(gcj);
    let gjb: String = nb_emit_jmp(gb, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _gp1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _gp2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    // --- loop 2: c[i] = max(a[i], 0) (the tensor elementwise rectifier) ---
    let w0: String = nb_intdot_movimm(gjb, 0, 0 - 131080);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131080);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    let wb: String = nb_relu_relu_body(wcj);
    let wjb: String = nb_emit_jmp(wb, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _wp1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _wp2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    // --- loop 3: sum = Sum (i+1)*c[i] (position-weighted reduction) ---
    let s0: String = nb_intdot_movimm(wjb, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    let sb: String = nb_relu_wsum_body(scj);
    let sjb: String = nb_emit_jmp(sb, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _sp1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _sp2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(sjb, 0 - 131184);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131184);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}




// ============================================================================
// C2 — native-ELF NARROW-INT (i8) WRAP ARITHMETIC, zero MLIR/LLVM.
// `selftest_native_elf_narrow_add_i8(a, b)` emits a runnable x86-64 ET_EXEC that
// computes  r = ((a as i8) + (b as i8)) as i8  with TWO'S-COMPLEMENT wrap at the
// i8 width, entirely in native code:
//   (1) bakes the host i64 operands a and b full-width via movabs,
//   (2) narrows each to i8 at RUNTIME with the reg-to-reg wrap primitive
//       nb_wrap_rax_w(_, 8) = movsx rax,al  (mask low 8 bits, re-sign bit 7),
//   (3) adds the two narrowed values in a full 64-bit register, then
//   (4) narrows the SUM back to i8 with the SAME wrap primitive — so an
//       overflowing narrow sum wraps (100+100 -> -56, 127+1 -> -128) instead of
//       i64-widening,
//   (5) writes the 8 LE bytes of the (sign-extended) i8 result to stdout — the
//       FULL-width observable a Python smoke checks against an independent
//       pure-Python i8-wrap reference, and
//   (6) exits with the discriminating code (r == baked_expected)*41 + 1 — 42
//       only on an EXACT i64 match against the emit-time-baked expected (movabs-
//       baked past imm32, so the compare stays full-width; a wrong lowering that
//       i64-widened would produce 200/128, differ in BOTH stdout and exit, and
//       is NOT a mod-256-maskable residue). `expected` is computed HOST-side by
//       exact i8 two's-complement wrap over the same closed operands.
//
// FAIL-CLOSED DOMAIN GUARD: this is scalar arithmetic (no arrays/loops, so no
// frame can overrun), but the export still FAILS CLOSED — returns an empty-buf
// EmitState — unless -1000000 <= a <= 1000000 and the same for b, bounding the
// baked test domain to well-defined small operands (the smoke asserts the
// refusal on out-of-domain operands, mirroring the tensor rungs' shape guard).
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
//
// Frame (small, 4096 B; all slots literal negative disps, deepest -104):
//   A=-8 B=-16 Aw=-24 Bw=-32 result=-40 expected=-48 fortyone=-56 one=-64
//   cmpflag=-72 fd=-80 bufaddr=-88 count=-96 exitcode=-104.
// ============================================================================

// HOST-side low-8-bits nonnegative modulo: r in [0,256). Robust to either integer
// division rounding (trunc-to-zero or floor) — for a negative intermediate r the
// `+ 256` folds it back into range. UNIQUE prefix nb_narrowadd8_ (no collision).
pub fn nb_narrowadd8_lowmod(x: i64) -> i64 {
    let r: i64 = x - (x / 256) * 256;
    if r < 0 {
        return r + 256;
    }
    r
}

// HOST-side exact i8 two's-complement wrap: (x as i8) as i64. Low 8 bits, then
// re-sign bit 7 (>=128 -> subtract 256). Idempotent (wrap(-56) == -56), matching
// the emitted movsx rax,al exactly: 200 -> -56, 128 -> -128, 100 -> 100, 255 -> -1.
pub fn nb_narrowadd8_wrap(x: i64) -> i64 {
    let low: i64 = nb_narrowadd8_lowmod(x);
    if low >= 128 {
        return low - 256;
    }
    low
}

// HOST-side baked expected: wrap8(wrap8(a) + wrap8(b)) — the SAME order the
// emitted code applies (narrow both operands, add full-width, narrow the sum).
pub fn nb_narrowadd8_expected(a: i64, b: i64) -> i64 {
    nb_narrowadd8_wrap(nb_narrowadd8_wrap(a) + nb_narrowadd8_wrap(b))
}

// Fail-closed empty artifact for out-of-domain operands (tail struct-literal —
// nfn-matcher-safe; the guard reaches it via `return nb_narrowadd8_empty();`).
pub fn nb_narrowadd8_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C2 narrow-int i8 wrap-add driver. a and b are baked at emit time; FAILS
// CLOSED (empty buf) unless both operands are within [-1000000, 1000000]. The
// exact i8-wrap `expected` is computed HOST-side and baked via movabs (full-width
// past imm32). The emitted code narrows each operand and the sum through
// nb_wrap_rax_w(_, 8) = movsx rax,al, so INT8 overflow wraps two's-complement.
pub fn selftest_native_elf_narrow_add_i8(a: i64, b: i64) -> EmitState {
    if a < 0 - 1000000 {
        return nb_narrowadd8_empty();
    }
    if a > 1000000 {
        return nb_narrowadd8_empty();
    }
    if b < 0 - 1000000 {
        return nb_narrowadd8_empty();
    }
    if b > 1000000 {
        return nb_narrowadd8_empty();
    }
    let expected: i64 = nb_narrowadd8_expected(a, b);
    let p0: String = nb_fp_prologue_frame(string_new(), 4096);
    // Baked operands + constants.
    let k1: String = nb_intdot_movimm(p0, a, 0 - 8);
    let k2: String = nb_intdot_movimm(k1, b, 0 - 16);
    let k3: String = nb_intdot_movimm(k2, expected, 0 - 48);
    let k4: String = nb_intdot_movimm(k3, 41, 0 - 56);
    let k5: String = nb_intdot_movimm(k4, 1, 0 - 64);
    let k6: String = nb_intdot_movimm(k5, 1, 0 - 80);
    let k7: String = nb_intdot_movimm(k6, 8, 0 - 96);
    // aw = (a as i8) : load a, movsx rax,al, store Aw.
    let w1: String = nb_load_rax(k7, 0 - 8);
    let w2: String = nb_wrap_rax_w(w1, 8);
    let w3: String = nb_store_rax(w2, 0 - 24);
    // bw = (b as i8).
    let w4: String = nb_load_rax(w3, 0 - 16);
    let w5: String = nb_wrap_rax_w(w4, 8);
    let w6: String = nb_store_rax(w5, 0 - 32);
    // r = ((aw + bw) as i8) : add full-width in rax, then narrow the SUM.
    let s1: String = nb_load_rax(w6, 0 - 24);
    let s2: String = nb_arith_rax_mem(s1, op_add(), 0 - 32);
    let s3: String = nb_wrap_rax_w(s2, 8);
    let s4: String = nb_store_rax(s3, 0 - 40);
    // write(1, &result, 8) — the full-width (sign-extended i8) stdout observable.
    let t3: String = nb_intdot_lea(s4, 0 - 40, 0 - 88);
    let t6: String = nb_emit_write(t3, 0 - 80, 0 - 88, 0 - 96);
    // exitcode = (result == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 40);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 48);
    let u3: String = nb_store_rax(u2, 0 - 72);
    let u4: String = nb_load_rax(u3, 0 - 72);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 56);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 64);
    let u7: String = nb_store_rax(u6, 0 - 104);
    let u8: String = nb_load_rax(u7, 0 - 104);
    let code: String = nb_emit_return(u8, 1);
    // No intra-fn jumps to patch (straight-line scalar arithmetic).
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}




// ============================================================================
// C4-T6 — native-ELF 3-D BATCHED SUM (i64), the FIRST N-D indexing rung.
// `selftest_native_elf_tensor_batchsum_i64(b, m, n)` emits a runnable ET_EXEC
// that (1) materializes a b×m×n i64 tensor A row-major in the frame with
// deterministic self-seeding A[k*m*n + i*n + j] = k*m*n+i*n+j+1 (the FLAT index
// t+1 — nonzero at every element, so every shape discriminates), (2) computes,
// per batch, S[k] = Sum_{i<m} Sum_{j<n} A[k*m*n + i*n + j] via a TRIPLE nest
// (kk over batches, ri over rows, cj over cols) whose innermost body forms the
// genuine 3-D flat address k*m*n + i*n + j at runtime (kk*mn + ri*ndim + cj,
// then *8 + base — the FIRST rung that composes THREE index terms, not two),
// (3) folds the batches into a POSITION-WEIGHTED, SQUARED checksum
// sum = Sum_{k<b} (k+1)*S[k]*S[k] — both the (k+1) weight AND the square make
// the observable batch-partition-sensitive: a wrong batch stride (e.g. reading
// the k axis transposed, k*m*n vs a mis-strided offset), a collapsed batch
// dimension, or a wrong bound all yield a different weighted sum-of-squares,
// whereas a plain grand-sum of A is layout/partition-invariant — (4) writes the
// 8 LE bytes of `sum` to stdout (full-width observable, checked by a Python
// smoke against an independent pure-Python reference), and (5) exits
// (sum == expected)*41 + 1 — 42 only on an EXACT i64 match against the
// emit-time-baked expected checksum (movabs-baked, full-width past imm32), 1
// otherwise. `expected` is computed HOST-side by exact i64 recursion over the
// same closed seeds (no loops; the Python smoke is the independent oracle).
//
// SHAPE GUARD (the T1..T5 audit hazard, fixed by construction): A is a single
// 4096-element i64 frame array (A base -131072). The driver FAILS CLOSED —
// returns an empty-buf EmitState — unless 1 <= b,m,n AND m <= 4096 AND n <= 4096
// AND b <= 4096 AND m*n <= 4096 AND b*m*n <= 4096. Every per-dim bound is applied
// BEFORE the products (m*n, then b*(m*n)) are formed, so no i64-overflow shape
// (where a product wraps mod 2^64 to slip a `> 4096` check) can march the emitted
// seed/reduce loops off the frame array.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
//
// Frame (matmul map extended with mn/S/tmp; all `nb_b3s_` helpers unique-prefixed
// so they cannot collide with any other rung's helpers):
//   A base = -131072 (4096 i64 = 32768 B). t=-131080 total=-131088 eight=-131096
//   one=-131104 cmpflag=-131120 baseA=-131128 ptr=-131152 aval=-131160
//   expected=-131192 result=-131200 fd=-131208 bufaddr=-131216 count=-131224
//   exitcode=-131232 fortyone=-131240 bdim=-131256 mdim=-131264 ndim=-131272
//   mn=-131280 sum=-131288 kk=-131296 ri=-131304 cj=-131312 S=-131320 tmp=-131328.
// ============================================================================

// HOST-side Sum_{j<n} A[k*m*n+i*n+j] for a fixed (k, i), A value = flat+1.
pub fn nb_b3s_row(m: i64, n: i64, k: i64, i: i64, j: i64) -> i64 {
    if j >= n {
        return 0;
    }
    (k * m * n + i * n + j + 1) + nb_b3s_row(m, n, k, i, j + 1)
}

// HOST-side per-batch sum S[k] = Sum_{i<m} Sum_{j<n} A[k*m*n+i*n+j].
pub fn nb_b3s_bsum(m: i64, n: i64, k: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    nb_b3s_row(m, n, k, i, 0) + nb_b3s_bsum(m, n, k, i + 1)
}

// HOST-side position-weighted squared checksum Sum_{k<b} (k+1)*S[k]*S[k] — the
// baked `expected`. Uses `return 0;` (helper-only early return; no struct literal
// — avoids the nfn early-return-struct-literal gotcha).
pub fn nb_b3s_total(b: i64, m: i64, n: i64, k: i64) -> i64 {
    if k >= b {
        return 0;
    }
    let s: i64 = nb_b3s_bsum(m, n, k, 0);
    (k + 1) * s * s + nb_b3s_total(b, m, n, k + 1)
}

// Fail-closed empty artifact for rejected batchsum shapes (covered tail-literal
// shape — the same final-expression form every selftest driver ends with).
pub fn nb_b3s_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// 3-D flat element address: ptr = (kk*mn + ri*ndim + cj) * 8 + baseA, into the
// shared ptr slot (-131152). Composes THREE index terms — the batch stride
// kk*mn, the row stride ri*ndim, and the column cj — via the `tmp` scratch slot
// (-131328), which no loop counter aliases. This is the N-D addressing kernel.
pub fn nb_b3s_idx3_ptr(code: String) -> String {
    // tmp = ri*ndim + cj
    let t1: String = nb_load_rax(code, 0 - 131304);
    let t2: String = nb_arith_rax_mem(t1, op_mul(), 0 - 131272);
    let t3: String = nb_arith_rax_mem(t2, op_add(), 0 - 131312);
    let t4: String = nb_store_rax(t3, 0 - 131328);
    // rax = kk*mn + tmp
    let a1: String = nb_load_rax(t4, 0 - 131296);
    let a2: String = nb_arith_rax_mem(a1, op_mul(), 0 - 131280);
    let a3: String = nb_arith_rax_mem(a2, op_add(), 0 - 131328);
    // ptr = rax*8 + baseA
    let p1: String = nb_arith_rax_mem(a3, op_mul(), 0 - 131096);
    let p2: String = nb_arith_rax_mem(p1, op_add(), 0 - 131128);
    nb_store_rax(p2, 0 - 131152)
}

// Seed loop (linear): for t in 0..b*m*n { A[t] = t+1 } — materializes the flat
// row-major input A[k*m*n+i*n+j] = k*m*n+i*n+j+1 via ptr = baseA + t*8.
pub fn nb_b3s_seed_a(code: String, jmps: i64, jcell: i64) -> String {
    let s0: String = nb_intdot_movimm(code, 0, 0 - 131080);
    let s_hdr: i64 = string_len(s0);
    let sc1: String = nb_load_rax(s0, 0 - 131080);
    let sc2: String = nb_cmp_rax_mem(sc1, nb_setcc_opcode(op_lt()), 0 - 131088);
    let sc3: String = nb_store_rax(sc2, 0 - 131120);
    let scj: String = nb_emit_cmp_je_zero(sc3, 0 - 131120, jmps, jcell);
    let s_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = t + 1
    let b1: String = nb_load_rax(scj, 0 - 131080);
    let b2: String = nb_arith_rax_mem(b1, op_add(), 0 - 131104);
    let b3: String = nb_store_rax(b2, 0 - 131160);
    // ptr = baseA + t*8
    let d1: String = nb_load_rax(b3, 0 - 131080);
    let d2: String = nb_arith_rax_mem(d1, op_mul(), 0 - 131096);
    let d3: String = nb_arith_rax_mem(d2, op_add(), 0 - 131128);
    let d4: String = nb_store_rax(d3, 0 - 131152);
    // A[t] = aval
    let s1: String = nb_emit_store_i64(d4, 0 - 131152, 0 - 131160);
    // t += 1
    let e1: String = nb_load_rax(s1, 0 - 131080);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131080);
    let sjb: String = nb_emit_jmp(e3, jmps, jcell);
    let s_bk: i64 = __mind_load_i64(jcell) - 1;
    let _s1: i64 = nb_jmp_set_target(jmps, jcell, s_bk, s_hdr);
    let s_end: i64 = string_len(sjb);
    let _s2: i64 = nb_jmp_set_target(jmps, jcell, s_je, s_end);
    sjb
}

// Innermost column loop: for cj in 0..ndim { S += A[kk*mn + ri*ndim + cj] } —
// the 3-D flat read via nb_b3s_idx3_ptr, accumulated into the per-batch S slot.
pub fn nb_b3s_j_loop(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131312);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131312);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[kk*mn + ri*ndim + cj]
    let a1: String = nb_b3s_idx3_ptr(wcj);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // S += aval
    let c1: String = nb_load_rax(a3, 0 - 131320);
    let c2: String = nb_arith_rax_mem(c1, op_add(), 0 - 131160);
    let c3: String = nb_store_rax(c2, 0 - 131320);
    // cj += 1
    let e1: String = nb_load_rax(c3, 0 - 131312);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131312);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Middle row loop: for ri in 0..mdim { column loop }.
pub fn nb_b3s_i_loop(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131304);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131264);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_b3s_j_loop(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Outer batch loop: for kk in 0..bdim { S = 0; (ri,cj) reduction nest;
// sum += (kk+1)*S*S }. The full triple nest + the position-weighted squared
// fold, using the tmp slot (-131328) to stage (kk+1) and aval (-131160) to stage
// S*S then (kk+1)*S*S (both free at this point — the reduction nest has exited).
pub fn nb_b3s_batch_outer(code: String, jmps: i64, jcell: i64) -> String {
    let h0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let h_hdr: i64 = string_len(h0);
    let hc1: String = nb_load_rax(h0, 0 - 131296);
    let hc2: String = nb_cmp_rax_mem(hc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let hc3: String = nb_store_rax(hc2, 0 - 131120);
    let hcj: String = nb_emit_cmp_je_zero(hc3, 0 - 131120, jmps, jcell);
    let h_je: i64 = __mind_load_i64(jcell) - 1;
    // S = 0 for this batch
    let z0: String = nb_intdot_movimm(hcj, 0, 0 - 131320);
    let body: String = nb_b3s_i_loop(z0, jmps, jcell);
    // tmp = kk + 1
    let w1: String = nb_load_rax(body, 0 - 131296);
    let w2: String = nb_arith_rax_mem(w1, op_add(), 0 - 131104);
    let w3: String = nb_store_rax(w2, 0 - 131328);
    // aval = S * S
    let s1: String = nb_load_rax(w3, 0 - 131320);
    let s2: String = nb_arith_rax_mem(s1, op_mul(), 0 - 131320);
    let s3: String = nb_store_rax(s2, 0 - 131160);
    // aval = (kk+1) * S * S
    let s4: String = nb_load_rax(s3, 0 - 131160);
    let s5: String = nb_arith_rax_mem(s4, op_mul(), 0 - 131328);
    let s6: String = nb_store_rax(s5, 0 - 131160);
    // sum += aval
    let m1: String = nb_load_rax(s6, 0 - 131288);
    let m2: String = nb_arith_rax_mem(m1, op_add(), 0 - 131160);
    let m3: String = nb_store_rax(m2, 0 - 131288);
    // kk += 1
    let e1: String = nb_load_rax(m3, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let hjb: String = nb_emit_jmp(e3, jmps, jcell);
    let h_bk: i64 = __mind_load_i64(jcell) - 1;
    let _h1: i64 = nb_jmp_set_target(jmps, jcell, h_bk, h_hdr);
    let h_end: i64 = string_len(hjb);
    let _h2: i64 = nb_jmp_set_target(jmps, jcell, h_je, h_end);
    hjb
}

// The C4-T6 driver. b/m/n are baked at emit time; FAILS CLOSED (empty buf) on
// any shape whose A (b*m*n) would overrun its 4096-element frame array. Every
// per-dim bound is applied BEFORE the products (m*n, then b*(m*n)) are formed, so
// the products cannot i64-overflow-wrap past the `> 4096` checks — the emitted
// seed/reduce loops can never index past the buffer, for any (b,m,n) including
// 2^32-class dims.
pub fn selftest_native_elf_tensor_batchsum_i64(b: i64, m: i64, n: i64) -> EmitState {
    if b < 1 {
        return nb_b3s_empty();
    }
    if m < 1 {
        return nb_b3s_empty();
    }
    if n < 1 {
        return nb_b3s_empty();
    }
    if b > 4096 {
        return nb_b3s_empty();
    }
    if m > 4096 {
        return nb_b3s_empty();
    }
    if n > 4096 {
        return nb_b3s_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_b3s_empty();
    }
    let bmn: i64 = b * mn;
    if bmn > 4096 {
        return nb_b3s_empty();
    }
    let expected: i64 = nb_b3s_total(b, m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum.
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, b, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, m, 0 - 131264);
    let k6: String = nb_intdot_movimm(k5, n, 0 - 131272);
    let k7: String = nb_intdot_movimm(k6, mn, 0 - 131280);
    let k8: String = nb_intdot_movimm(k7, bmn, 0 - 131088);
    let k9: String = nb_intdot_movimm(k8, 0, 0 - 131288);
    let k10: String = nb_intdot_movimm(k9, expected, 0 - 131192);
    // Runtime base address of the single in-frame A array.
    let ba: String = nb_intdot_lea(k10, 0 - 131072, 0 - 131128);
    // Jump scaffold shared by all 4 loops (8 records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sd: String = nb_b3s_seed_a(ba, jmps, jcell);
    let bt: String = nb_b3s_batch_outer(sd, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(bt, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}



// ============================================================================
// C4-T6 — native-ELF 2-D ROW MIN-REDUCTION (i64), zero MLIR/LLVM.
//
// `selftest_native_elf_tensor_rowmin_i64(m, n)` emits a runnable ET_EXEC that
// (1) materializes A (MxN) row-major in the frame with the NON-MONOTONE self-seed
// A[i*n+j] = ((i*5 + j*11 + 7) mod 89) + 1 (values in [1,89]; the min of a row is
// NOT at a fixed column, so a wrong reduction is caught), (2) computes
// rowmin[i] = min_{j<n} A[i*n+j] for each row via an inner counted loop nested
// under the row loop — the running min is tracked with an emitted `cmp rax,[acc]`
// + `jl` (signed conditional jump: fall through to the acc-store only when the new
// element is strictly less), 2-D row-major addressing ((i*n)+j)*8 + base (the T3
// idx shape), (3) folds the rows into a POSITION-WEIGHTED checksum
// sum = Sum_{i<m} (i+1)*rowmin[i] (the (i+1) weight is layout-discriminating: a
// wrong axis / a MAX reduction / a permuted-row order all change the value even
// though the multiset of per-row minima might not), (4) writes the 8 LE bytes of
// `sum` to stdout (full-width observable, checked by a Python smoke against an
// independent pure-Python reference), and (5) exits (sum == expected)*41 + 1 — 42
// only on an EXACT i64 match against the emit-time-baked expected checksum
// (movabs-baked, full-width past imm32), 1 otherwise. `expected` is computed
// HOST-side by exact i64 recursion over the same closed seeds (no loops; the
// Python smoke is the independent oracle).
//
// SHAPE GUARD (the T1/T2/T3 audit hazard, fixed by construction): A is a single
// 4096-element i64 frame array (A base -131072). The driver FAILS CLOSED —
// returns an empty-buf EmitState — unless 1 <= m,n AND m <= 4096 AND n <= 4096
// AND m*n <= 4096. Each dim is bounded <= 4096 BEFORE the product m*n is formed,
// so the product cannot i64-overflow-wrap past the `> 4096` check.
//
// ADDITIVITY: a NEW export never reached during self-compile (main.mind does not
// call it), so every self-host fixture lowers exactly as before and the integer
// native-ELF oracle stays byte-identical. No frozen byte oracle exists for this
// path; the gate is EXECUTION CORRECTNESS — emit, run, assert stdout+exit.
// Reuses the matmul frame arrays + nb_tmm_idx2_ptr addressing; all emit helpers
// carry the UNIQUE `nb_rmn_` prefix so they cannot collide with other rungs.
//
// Frame (matmul map subset): A base = -131072 (only A used). eight=-131096
// one=-131104 cmpflag=-131120 baseA=-131128 ptr=-131152 aval=-131160
// acc=-131184 (per-row running min) expected=-131192 result=-131200 fd=-131208
// bufaddr=-131216 count=-131224 exitcode=-131232 fortyone=-131240 m=-131256
// ndim=-131272 (n) sum=-131288 (checksum) ri=-131296 cj=-131304. NEW rowmin
// slots (deeper than any prior scalar, no overlap with A at -131072): c5=-131312
// c11=-131320 c7=-131328 c89=-131336 tmp=-131344.
// ============================================================================

// HOST-side rowmin[i] = min_{j<n} (((i*5 + j*11 + 7) mod 89) + 1), by exact i64
// recursion over j with a running `cur` (self-host subset — no loops, no value-if:
// the min is chosen with two `return helper();` tails so the nfn early-return
// struct-literal gotcha cannot apply).
pub fn nb_rmn_rowmin(i: i64, n: i64, j: i64, cur: i64) -> i64 {
    if j >= n {
        return cur;
    }
    let v: i64 = ((i * 5 + j * 11 + 7) % 89) + 1;
    if v < cur {
        return nb_rmn_rowmin(i, n, j + 1, v);
    }
    return nb_rmn_rowmin(i, n, j + 1, cur);
}

// HOST-side checksum Sum_{i<m} (i+1)*rowmin[i] — the baked `expected`. The (i+1)
// weight makes the fold POSITION-discriminating (a wrong axis / a max reduction /
// a row permutation changes the value). cur seed 1000000000 > 89 so a row of >=1
// elements always resolves to a real element (n>=1 guaranteed by the driver).
pub fn nb_rmn_total(m: i64, n: i64, i: i64) -> i64 {
    if i >= m {
        return 0;
    }
    let r: i64 = nb_rmn_rowmin(i, n, 0, 1000000000);
    (i + 1) * r + nb_rmn_total(m, n, i + 1)
}

// `cmp rax, [rbp+rhs_disp]` = 48 3B 85 <disp32> — the RAW signed compare (sets
// flags only, no setcc/movzx), for feeding a `jl`. Distinct from nb_cmp_rax_mem,
// which materializes a 0/1 boolean.
pub fn nb_rmn_raw_cmp(code: String, rhs_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 59);
    let c3: String = nb_push(c2, 133);
    nb_i32le_signed(c3, rhs_disp)
}

// `jl rel32(0 placeholder)` = 0F 8C <rel32> — signed jump-if-less. Records the
// rel32 site (fn-relative) into the jumps table with target -1 (back-patched by
// the caller once the join offset is known), exactly like nb_emit_jmp/je.
pub fn nb_rmn_jl(code: String, jmps: i64, jcell: i64) -> String {
    let c1: String = nb_push(code, 15);
    let c2: String = nb_push(c1, 140);
    let site: i64 = string_len(c2);
    let _j: i64 = nb_jmps_push(jmps, jcell, site, 0 - 1);
    nb_u32(c2, 0)
}

// Inner seed loop: for cj in 0..ndim { A[ri*ndim+cj] = ((ri*5+cj*11+7) mod 89)+1 }.
// Emitted INSIDE the outer row body, so cj re-inits to 0 each outer iteration.
pub fn nb_rmn_seed_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // tmp = cj * 11
    let t1: String = nb_load_rax(wcj, 0 - 131304);
    let t2: String = nb_arith_rax_mem(t1, op_mul(), 0 - 131320);
    let t3: String = nb_store_rax(t2, 0 - 131344);
    // aval = ((ri*5 + cj*11 + 7) mod 89) + 1
    let b1: String = nb_load_rax(t3, 0 - 131296);
    let b2: String = nb_arith_rax_mem(b1, op_mul(), 0 - 131312);
    let b3: String = nb_arith_rax_mem(b2, op_add(), 0 - 131344);
    let b4: String = nb_arith_rax_mem(b3, op_add(), 0 - 131328);
    let b5: String = nb_arith_rax_mem(b4, op_mod(), 0 - 131336);
    let b6: String = nb_arith_rax_mem(b5, op_add(), 0 - 131104);
    let b7: String = nb_store_rax(b6, 0 - 131160);
    // A[ri*ndim + cj] = aval
    let p1: String = nb_tmm_idx2_ptr(b7, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let s1: String = nb_emit_store_i64(p1, 0 - 131152, 0 - 131160);
    // cj += 1
    let e1: String = nb_load_rax(s1, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer seed loop: for ri in 0..m { inner }.
pub fn nb_rmn_seed_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    let body: String = nb_rmn_seed_inner(gcj, jmps, jcell);
    // ri += 1
    let e1: String = nb_load_rax(body, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Inner reduce loop: for cj in 0..ndim { aval = A[ri*ndim+cj];
//   if aval < acc { acc = aval } } — the per-row horizontal MIN via cmp+jl.
// The min-update is: mov rax,[aval] ; cmp rax,[acc] ; jl L_upd ; jmp L_after ;
// L_upd: mov [acc],rax ; L_after: — rax still holds aval on the taken jl edge.
pub fn nb_rmn_row_inner(code: String, jmps: i64, jcell: i64) -> String {
    let w0: String = nb_intdot_movimm(code, 0, 0 - 131304);
    let w_hdr: i64 = string_len(w0);
    let wc1: String = nb_load_rax(w0, 0 - 131304);
    let wc2: String = nb_cmp_rax_mem(wc1, nb_setcc_opcode(op_lt()), 0 - 131272);
    let wc3: String = nb_store_rax(wc2, 0 - 131120);
    let wcj: String = nb_emit_cmp_je_zero(wc3, 0 - 131120, jmps, jcell);
    let w_je: i64 = __mind_load_i64(jcell) - 1;
    // aval = A[ri*ndim + cj]
    let a1: String = nb_tmm_idx2_ptr(wcj, 0 - 131296, 0 - 131272, 0 - 131304, 0 - 131128);
    let a2: String = nb_emit_load_i64(a1, 0 - 131152);
    let a3: String = nb_store_rax(a2, 0 - 131160);
    // min-update: if aval < acc { acc = aval }  (cmp + jl skip-jump)
    let m0: String = nb_load_rax(a3, 0 - 131160);
    let m1: String = nb_rmn_raw_cmp(m0, 0 - 131184);
    let m2: String = nb_rmn_jl(m1, jmps, jcell);
    let idx_jl: i64 = __mind_load_i64(jcell) - 1;
    let m3: String = nb_emit_jmp(m2, jmps, jcell);
    let idx_jmp: i64 = __mind_load_i64(jcell) - 1;
    // jl target = the acc-store (fall-through past the join jmp)
    let l_upd: i64 = string_len(m3);
    let _u1: i64 = nb_jmp_set_target(jmps, jcell, idx_jl, l_upd);
    let m4: String = nb_store_rax(m3, 0 - 131184);
    // join jmp target = right after the acc-store
    let l_after: i64 = string_len(m4);
    let _u2: i64 = nb_jmp_set_target(jmps, jcell, idx_jmp, l_after);
    // cj += 1
    let e1: String = nb_load_rax(m4, 0 - 131304);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131304);
    let wjb: String = nb_emit_jmp(e3, jmps, jcell);
    let w_bk: i64 = __mind_load_i64(jcell) - 1;
    let _w1: i64 = nb_jmp_set_target(jmps, jcell, w_bk, w_hdr);
    let w_end: i64 = string_len(wjb);
    let _w2: i64 = nb_jmp_set_target(jmps, jcell, w_je, w_end);
    wjb
}

// Outer row loop: for ri in 0..m { acc = BIG; min over cj; sum += (ri+1)*acc }.
// The (ri+1)-WEIGHTED fold is what makes the observable position-discriminating.
pub fn nb_rmn_row_outer(code: String, jmps: i64, jcell: i64) -> String {
    let g0: String = nb_intdot_movimm(code, 0, 0 - 131296);
    let g_hdr: i64 = string_len(g0);
    let gc1: String = nb_load_rax(g0, 0 - 131296);
    let gc2: String = nb_cmp_rax_mem(gc1, nb_setcc_opcode(op_lt()), 0 - 131256);
    let gc3: String = nb_store_rax(gc2, 0 - 131120);
    let gcj: String = nb_emit_cmp_je_zero(gc3, 0 - 131120, jmps, jcell);
    let g_je: i64 = __mind_load_i64(jcell) - 1;
    // acc = BIG sentinel (1000000000 > 89) for this row
    let z0: String = nb_intdot_movimm(gcj, 1000000000, 0 - 131184);
    let body: String = nb_rmn_row_inner(z0, jmps, jcell);
    // sum += (ri+1)*acc  (rax = ri; rax += one; rax *= acc; rax += sum; sum = rax)
    let q1: String = nb_load_rax(body, 0 - 131296);
    let q2: String = nb_arith_rax_mem(q1, op_add(), 0 - 131104);
    let q3: String = nb_arith_rax_mem(q2, op_mul(), 0 - 131184);
    let q4: String = nb_arith_rax_mem(q3, op_add(), 0 - 131288);
    let q5: String = nb_store_rax(q4, 0 - 131288);
    // ri += 1
    let e1: String = nb_load_rax(q5, 0 - 131296);
    let e2: String = nb_arith_rax_mem(e1, op_add(), 0 - 131104);
    let e3: String = nb_store_rax(e2, 0 - 131296);
    let gjb: String = nb_emit_jmp(e3, jmps, jcell);
    let g_bk: i64 = __mind_load_i64(jcell) - 1;
    let _g1: i64 = nb_jmp_set_target(jmps, jcell, g_bk, g_hdr);
    let g_end: i64 = string_len(gjb);
    let _g2: i64 = nb_jmp_set_target(jmps, jcell, g_je, g_end);
    gjb
}

// Fail-closed empty artifact for rejected rowmin shapes (covered tail-literal
// shape — the nfn-matcher-safe `return helper();` form the guards use).
pub fn nb_rmn_empty() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0, lets: env_new() }
}

// The C4-T6 driver. m/n are baked at emit time; FAILS CLOSED (empty buf) on any
// shape whose A (m*n) would overrun its 4096-element frame array. Each dim is
// bounded <= 4096 BEFORE the product is formed, so m*n cannot wrap past the
// `> 4096` check — the emitted seed/reduce loops can never index off the frame.
pub fn selftest_native_elf_tensor_rowmin_i64(m: i64, n: i64) -> EmitState {
    if m < 1 {
        return nb_rmn_empty();
    }
    if n < 1 {
        return nb_rmn_empty();
    }
    if m > 4096 {
        return nb_rmn_empty();
    }
    if n > 4096 {
        return nb_rmn_empty();
    }
    let mn: i64 = m * n;
    if mn > 4096 {
        return nb_rmn_empty();
    }
    let expected: i64 = nb_rmn_total(m, n, 0);
    let p0: String = nb_fp_prologue_frame(string_new(), 135168);
    // Constants + dims + the baked expected checksum + seed constants (5,11,7,89).
    let k1: String = nb_intdot_movimm(p0, 8, 0 - 131096);
    let k2: String = nb_intdot_movimm(k1, 1, 0 - 131104);
    let k3: String = nb_intdot_movimm(k2, 41, 0 - 131240);
    let k4: String = nb_intdot_movimm(k3, m, 0 - 131256);
    let k5: String = nb_intdot_movimm(k4, n, 0 - 131272);
    let k6: String = nb_intdot_movimm(k5, 0, 0 - 131288);
    let k7: String = nb_intdot_movimm(k6, expected, 0 - 131192);
    let k8: String = nb_intdot_movimm(k7, 5, 0 - 131312);
    let k9: String = nb_intdot_movimm(k8, 11, 0 - 131320);
    let k10: String = nb_intdot_movimm(k9, 7, 0 - 131328);
    let k11: String = nb_intdot_movimm(k10, 89, 0 - 131336);
    // Runtime base address of the in-frame A array.
    let ba: String = nb_intdot_lea(k11, 0 - 131072, 0 - 131128);
    // Jump scaffold shared by all 4 loops + the per-element min-update (10
    // records; capacity 64).
    let jmps: i64 = __mind_alloc(64 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    let sd: String = nb_rmn_seed_outer(ba, jmps, jcell);
    let rw: String = nb_rmn_row_outer(sd, jmps, jcell);
    // result = sum ; write(1, &result, 8) — the full-width stdout observable.
    let t1: String = nb_load_rax(rw, 0 - 131288);
    let t2: String = nb_store_rax(t1, 0 - 131200);
    let t3: String = nb_intdot_lea(t2, 0 - 131200, 0 - 131216);
    let t4: String = nb_intdot_movimm(t3, 1, 0 - 131208);
    let t5: String = nb_intdot_movimm(t4, 8, 0 - 131224);
    let t6: String = nb_emit_write(t5, 0 - 131208, 0 - 131216, 0 - 131224);
    // exitcode = (sum == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 131288);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 131192);
    let u3: String = nb_store_rax(u2, 0 - 131120);
    let u4: String = nb_load_rax(u3, 0 - 131120);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 131240);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 131104);
    let u7: String = nb_store_rax(u6, 0 - 131232);
    let u8: String = nb_load_rax(u7, 0 - 131232);
    let code: String = nb_emit_return(u8, 1);
    // Patch every recorded intra-fn jump (entry_off = 0).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(code), jmps, njmps, 0);
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}



// ============================================================================
// C2 — native-ELF NARROW-INT WRAP ARITHMETIC, generalized: {add,sub,mul} x {i8,i16}.
// Extends selftest_native_elf_narrow_add_i8 (the i8-add rung) to an op- and
// width-parametric driver. Each emits a runnable ET_EXEC that narrows both baked
// operands to width w via nb_wrap_rax_w(_, w), applies the op in a full 64-bit
// register, narrows the RESULT again so overflow wraps two's-complement at width
// w (never i64-widens), writes the 8 LE bytes of the sign-extended result to
// stdout, and exits (result == baked_expected)*41 + 1 — 42 only on an EXACT
// full-width i64 match against the emit-time-baked expected (movabs past imm32).
// `expected` is baked HOST-side via the width-parametric wrap below. All operands
// guarded to [-1000000, 1000000]; both i8 AND i16 WRAP within that band
// (1e6 >> 127 and >> 32767), so every corpus case is a genuine wrap test.
// ADDITIVE: NEW exports never reached during self-compile — the integer
// native-ELF oracle stays byte-identical. The gate is EXECUTION CORRECTNESS
// (emit, run, assert stdout+exit against an independent Python reference).
// ============================================================================

// Width -> two's-complement modulus (2^w) for w in {8,16,32}.
pub fn nb_narrow_modulus(w: i64) -> i64 {
    if w == 8 {
        return 256;
    }
    if w == 16 {
        return 65536;
    }
    4294967296
}

// HOST-side non-negative low residue x mod 2^w (nb_narrowadd8_lowmod generalized):
// MIND signed div truncates toward zero, so re-add the modulus when the remainder
// is negative — giving a residue in [0, 2^w).
pub fn nb_narrow_lowmod_w(x: i64, m: i64) -> i64 {
    let r: i64 = x - (x / m) * m;
    if r < 0 {
        return r + m;
    }
    r
}

// HOST-side exact width-w two's-complement wrap: (x as iW) as i64. Low w bits,
// then re-sign the top bit (>= 2^(w-1) -> subtract 2^w). Idempotent; matches the
// emitted nb_wrap_rax_w(_, w) (movsx al / movsx ax / movsxd eax) byte-for-byte.
pub fn nb_narrow_wrap_w(x: i64, w: i64) -> i64 {
    let m: i64 = nb_narrow_modulus(w);
    let low: i64 = nb_narrow_lowmod_w(x, m);
    let half: i64 = m / 2;
    if low >= half {
        return low - m;
    }
    low
}

// HOST-side baked expected: wrap_w(wrap_w(a) OP wrap_w(b)) — the SAME order the
// emitted code applies (narrow both operands, op full-width, narrow the result).
pub fn nb_narrow_arith_expected(a: i64, b: i64, op: i64, w: i64) -> i64 {
    let aw: i64 = nb_narrow_wrap_w(a, w);
    let bw: i64 = nb_narrow_wrap_w(b, w);
    if op == op_sub() {
        return nb_narrow_wrap_w(aw - bw, w);
    }
    if op == op_mul() {
        return nb_narrow_wrap_w(aw * bw, w);
    }
    nb_narrow_wrap_w(aw + bw, w)
}

// Operand guard bound by width: the narrow band [-1e6,1e6] keeps i8/i16 baking
// small AND already wraps them (1e6 >> 127, >> 32767). i32 only WRAPS past
// ~2^31, so w=32 widens the band to [-3e9,3e9] to exercise it — operands are
// movabs-baked full-width (nb_intdot_movimm = movabs rax,imm64), so no imm32
// truncation. Unknown widths fall through to the narrow band.
pub fn nb_narrow_guard_hi(w: i64) -> i64 {
    if w == 32 {
        return 3000000000;
    }
    1000000
}

// The generalized C2 narrow-int wrap driver: op in {add,sub,mul}, width w in
// {8,16,32}. Clones selftest_native_elf_narrow_add_i8 with the op and wrap width
// parametric. FAILS CLOSED (empty buf) unless both operands within the
// width-dependent band nb_narrow_guard_hi(w) ([-1e6,1e6] for i8/i16, [-3e9,3e9]
// for i32).
pub fn selftest_native_elf_narrow_arith(a: i64, b: i64, op: i64, w: i64) -> EmitState {
    let hi: i64 = nb_narrow_guard_hi(w);
    if a < 0 - hi {
        return nb_narrowadd8_empty();
    }
    if a > hi {
        return nb_narrowadd8_empty();
    }
    if b < 0 - hi {
        return nb_narrowadd8_empty();
    }
    if b > hi {
        return nb_narrowadd8_empty();
    }
    let expected: i64 = nb_narrow_arith_expected(a, b, op, w);
    let p0: String = nb_fp_prologue_frame(string_new(), 4096);
    // Baked operands + constants.
    let k1: String = nb_intdot_movimm(p0, a, 0 - 8);
    let k2: String = nb_intdot_movimm(k1, b, 0 - 16);
    let k3: String = nb_intdot_movimm(k2, expected, 0 - 48);
    let k4: String = nb_intdot_movimm(k3, 41, 0 - 56);
    let k5: String = nb_intdot_movimm(k4, 1, 0 - 64);
    let k6: String = nb_intdot_movimm(k5, 1, 0 - 80);
    let k7: String = nb_intdot_movimm(k6, 8, 0 - 96);
    // aw = (a as iW) : load a, narrow to width w, store Aw.
    let w1: String = nb_load_rax(k7, 0 - 8);
    let w2: String = nb_wrap_rax_w(w1, w);
    let w3: String = nb_store_rax(w2, 0 - 24);
    // bw = (b as iW).
    let w4: String = nb_load_rax(w3, 0 - 16);
    let w5: String = nb_wrap_rax_w(w4, w);
    let w6: String = nb_store_rax(w5, 0 - 32);
    // r = ((aw OP bw) as iW) : op full-width in rax, then narrow the RESULT.
    let s1: String = nb_load_rax(w6, 0 - 24);
    let s2: String = nb_arith_rax_mem(s1, op, 0 - 32);
    let s3: String = nb_wrap_rax_w(s2, w);
    let s4: String = nb_store_rax(s3, 0 - 40);
    // write(1, &result, 8) — the full-width (sign-extended iW) stdout observable.
    let t3: String = nb_intdot_lea(s4, 0 - 40, 0 - 88);
    let t6: String = nb_emit_write(t3, 0 - 80, 0 - 88, 0 - 96);
    // exitcode = (result == expected)*41 + 1 — 42 only on an exact i64 match.
    let u1: String = nb_load_rax(t6, 0 - 40);
    let u2: String = nb_cmp_rax_mem(u1, nb_setcc_opcode(op_eq()), 0 - 48);
    let u3: String = nb_store_rax(u2, 0 - 72);
    let u4: String = nb_load_rax(u3, 0 - 72);
    let u5: String = nb_arith_rax_mem(u4, op_mul(), 0 - 56);
    let u6: String = nb_arith_rax_mem(u5, op_add(), 0 - 64);
    let u7: String = nb_store_rax(u6, 0 - 104);
    let u8: String = nb_load_rax(u7, 0 - 104);
    let code: String = nb_emit_return(u8, 1);
    // No intra-fn jumps to patch (straight-line scalar arithmetic).
    let hbuf: i64 = __mind_alloc(32);
    let note: String = nb_build_note(string_new(), hbuf);
    let elf: String = nb_write_elf(code, 0, note);
    EmitState { buf: elf, next_id: 0, last_id: 0, lets: env_new() }
}

// Thin op/width wrappers — one export per rung (the batch smoke calls each).
pub fn selftest_native_elf_narrow_sub_i8(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_sub(), 8)
}
pub fn selftest_native_elf_narrow_mul_i8(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_mul(), 8)
}
pub fn selftest_native_elf_narrow_add_i16(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_add(), 16)
}
pub fn selftest_native_elf_narrow_mul_i16(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_mul(), 16)
}
pub fn selftest_native_elf_narrow_sub_i16(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_sub(), 16)
}
pub fn selftest_native_elf_narrow_add_i32(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_add(), 32)
}
pub fn selftest_native_elf_narrow_sub_i32(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_sub(), 32)
}
pub fn selftest_native_elf_narrow_mul_i32(a: i64, b: i64) -> EmitState {
    selftest_native_elf_narrow_arith(a, b, op_mul(), 32)
}
