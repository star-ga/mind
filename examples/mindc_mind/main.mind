            // stays on the proven type-2 emit (byte-preserved, e.g. is_alpha). ANYTHING
            // else — a deeper nested if, OR a `let* + return` bottom block (inner_ret<0,
            // multi-stmt) — routes through the recursive chain emitter (type 5), which
            // handles arbitrary depth + then-block lets with SSA binding bubble-up.
            let clean_d2: i64 = if inner_ret < 0 {
                0
            } else {
                if ast_kind(inner_ret) == ast_return() {
                    1
                } else {
                    0
                }
            };
            if clean_d2 == 0 {
                let p5_nodes: i64 = __mind_alloc(256 * 32);
                let p5_cursor: i64 = __mind_alloc(8);
                let p5_vidbuf: i64 = __mind_alloc(256 * 8);
                let p5_cell: i64 = __mind_alloc(8);
                __mind_store_i64(p5_cell, 0 - 1);
                let p5_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _p5lv: i64 = seq_env_to_lvenv(env, nlets, 0, p5_lvenv, 0, 0);
                let p5_bindout: i64 = __mind_alloc(64 * 24);
                let p5_nbind: i64 = __mind_alloc(8);
                let p5: EmitState = emit_if_chain_instr_lv(es_new(), stmt, src, params_addr, n_params, p5_nodes, p5_cursor, p5_vidbuf, 0, p5_cell, p5_lvenv, nlets, 0, 0, 0, p5_bindout, p5_nbind);
                let p5_dst: i64 = __mind_load_i64(p5_cell);
                if p5_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 5);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, p5_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
                return 0;
            }
            let n2_rs: i64 = __mind_load_i64(cursor);
            let n2_ocr: i64 = flatten_expr_env(ast_child0(stmt), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_ocr < 0 {
                return 0;
            }
            let n2_s1: i64 = __mind_load_i64(cursor);
            let n2_icr: i64 = flatten_expr_env(ast_child0(ret_stmt), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_icr < 0 {
                return 0;
            }
            let n2_s2: i64 = __mind_load_i64(cursor);
            let n2_irr: i64 = flatten_expr_env(ast_child0(inner_ret), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_irr < 0 {
                return 0;
            }
            let n2_re: i64 = __mind_load_i64(cursor);
            __mind_store_i64(plan + p * 64 + 0, 2);
            __mind_store_i64(plan + p * 64 + 8, n2_rs);
            __mind_store_i64(plan + p * 64 + 16, n2_re);
            __mind_store_i64(plan + p * 64 + 24, n2_ocr);
            __mind_store_i64(plan + p * 64 + 32, n2_icr);
            __mind_store_i64(plan + p * 64 + 40, n2_irr);
            __mind_store_i64(plan + p * 64 + 48, n2_s1);
            __mind_store_i64(plan + p * 64 + 56, n2_s2);
            __mind_store_i64(nplan_cell, p + 1);
            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
        }
        if ast_kind(ret_stmt) != ast_return() {
            return 0;
        }
        let cond_expr: i64 = ast_child0(stmt);
        let ret_expr: i64 = ast_child0(ret_stmt);
        let cstart: i64 = __mind_load_i64(cursor);
        let cond_root: i64 = flatten_expr_env(cond_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
        if cond_root < 0 {
            return 0;
        }
        let cend: i64 = __mind_load_i64(cursor);
        let rstart: i64 = __mind_load_i64(cursor);
        let ret_root: i64 = flatten_expr_env(ret_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
        if ret_root < 0 {
            return 0;
        }
        let rend: i64 = __mind_load_i64(cursor);
        __mind_store_i64(plan + p * 64 + 0, 1);
        __mind_store_i64(plan + p * 64 + 8, cstart);
        __mind_store_i64(plan + p * 64 + 16, cend);
        __mind_store_i64(plan + p * 64 + 24, cond_root);
        __mind_store_i64(plan + p * 64 + 32, rstart);
        __mind_store_i64(plan + p * 64 + 40, rend);
        __mind_store_i64(plan + p * 64 + 48, ret_root);
        __mind_store_i64(nplan_cell, p + 1);
        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
    }
    // (type 10) TOP-LEVEL STATEMENT WHILE `while C { body }`. Lowers to ONE OP_WHILE
    // (+ trailing unit ConstI64). Probe emit_mic3_while_general (base0=n_params, empty
    // probe lv-env carrying the seq lets by NAME) to learn the vid delta; store the
    // node + params. Pass B advances base by the delta; emit calls the general emitter.
    if ast_kind(stmt) == ast_while() {
        let w_probe_lv: i64 = __mind_alloc((nlets + 1) * 24);
        let _wpl: i64 = seq_env_to_lvenv(env, nlets, 0, w_probe_lv, 0, 0);
        let w_merge: i64 = __mind_alloc(64 * 24);
        let w_nm: i64 = __mind_alloc(8);
        __mind_store_i64(w_nm, 0);
        let w_end: i64 = __mind_alloc(8);
        __mind_store_i64(w_end, 0 - 1);
        let w_ok: i64 = __mind_alloc(8);
        __mind_store_i64(w_ok, 1);
        let _wp: EmitState = emit_mic3_while_general(es_new(), stmt, src, params_addr, n_params, n_params, w_probe_lv, nlets, 0, 0, 0, w_merge, w_nm, w_end, w_ok);
        if __mind_load_i64(w_ok) == 1 {
            // vid delta = (endbase - n_params) + 1: endbase is the trailing-unit vid, +1
            // for the unit itself. Base-relative, recomputed at emit time too.
            let w_delta: i64 = __mind_load_i64(w_end) - n_params + 1;
            __mind_store_i64(plan + p * 64 + 0, 10);
            __mind_store_i64(plan + p * 64 + 8, stmt);
            __mind_store_i64(plan + p * 64 + 16, w_delta);
            __mind_store_i64(plan + p * 64 + 24, params_addr);
            __mind_store_i64(plan + p * 64 + 32, n_params);
            __mind_store_i64(plan + p * 64 + 48, 0);
            __mind_store_i64(nplan_cell, p + 1);
            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
        }
    }
    // (type 0, reuse) TOP-LEVEL STRAIGHT-LINE REASSIGN `NAME = VALUE` (i64).
    // Mirrors eval/lower.rs's body_env.insert: `w = w + 100` emits the RHS
    // instructions and REBINDS NAME to the RHS result vid — there is NO dedicated
    // Assign instruction, so the emitted mic@3 body is byte-identical to a `let w2 =
    // w + 100` (mic@3 bodies are SSA vids, no variable names). It reuses the type-0
    // let plan path EXACTLY (same [start,end) range-resolution + one env entry), the
    // only difference being the shadow env entry re-uses NAME (child0), so
    // letenv_lookup's last-match-wins resolves every LATER read of NAME to the
    // reassigned slot while the RHS — flattened FIRST, against the prior env — still
    // reads the pre-assign binding. Additive: main.mind's float-free, immutable-style
    // source has NO top-level straight-line assign in any kept fn (else this build
    // would already fail closed and the self-host loop would break), so no
    // currently-emitting fn reaches this arm — byte-identical self-compile.
    if ast_kind(stmt) == ast_assign() {
        let aname: i64 = ast_child0(stmt);
        let aval: i64 = ast_child2(stmt);
        // (type 7, reuse) value-if RHS `NAME = if C {A} else {B}` (i64). Mirrors the
        // type-7 value-if LET sub-case above EXACTLY (emit_if_expr_any_lv + a synth
        // dst-slot node bound to the merged OP_IF dst in Pass B); the ONLY difference
        // is the env entry re-uses NAME (child0) so letenv_lookup's last-match-wins
        // rebinds every LATER read of NAME to the reassigned merged value, while the
        // if-expr's branches — flattened against the prior env — still read the
        // pre-assign binding. The plan type-7 entry records NO name, so downstream
        // (seq_fix_deltas / seq_body_len / emit_stmt_seq) is byte-identical to the let
        // case. Additive: no kept main.mind fn has a top-level value-if reassign.
        if is_any_value_if_expr(aval) == 1 {
            let a7_nodes: i64 = __mind_alloc(256 * 32);
            let a7_cursor: i64 = __mind_alloc(8);
            let a7_vidbuf: i64 = __mind_alloc(256 * 8);
            let a7_cell: i64 = __mind_alloc(8);
            __mind_store_i64(a7_cell, 0 - 1);
            let a7_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
            let _a7lv: i64 = seq_env_to_lvenv(env, nlets, 0, a7_lvenv, 0, 0);
            let a7: EmitState = emit_if_expr_any_lv(es_new(), aval, src, params_addr, n_params, a7_nodes, a7_cursor, a7_vidbuf, 0, a7_cell, a7_lvenv, nlets, 0, 0, 0, 0, 0);
            let a7_dst: i64 = __mind_load_i64(a7_cell);
            if a7_dst >= 0 {
                let a7_slot: i64 = __mind_load_i64(cursor);
                __mind_store_i64(nodes + a7_slot * 32 + 0, 0);
                __mind_store_i64(nodes + a7_slot * 32 + 8, 0);
                __mind_store_i64(nodes + a7_slot * 32 + 16, 0);
                __mind_store_i64(nodes + a7_slot * 32 + 24, 0);
                __mind_store_i64(cursor, a7_slot + 1);
                __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(aname));
                __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(aname));
                __mind_store_i64(env + nlets * 24 + 16, a7_slot);
                __mind_store_i64(nlets_cell, nlets + 1);
                __mind_store_i64(plan + p * 64 + 0, 7);
                __mind_store_i64(plan + p * 64 + 8, aval);
                __mind_store_i64(plan + p * 64 + 16, a7_dst + 1);
                __mind_store_i64(plan + p * 64 + 24, params_addr);
                __mind_store_i64(plan + p * 64 + 32, n_params);
                __mind_store_i64(plan + p * 64 + 40, a7_slot);
                __mind_store_i64(nplan_cell, p + 1);
                return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
            }
        }
        let astart: i64 = __mind_load_i64(cursor);
        let aroot: i64 = flatten_expr_env(aval, src, params_addr, n_params, nodes, cursor, env, nlets);
        if aroot < 0 {
            return 0;
        }
        let aend: i64 = __mind_load_i64(cursor);
        __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(aname));
        __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(aname));
        __mind_store_i64(env + nlets * 24 + 16, aroot);
        __mind_store_i64(nlets_cell, nlets + 1);
        __mind_store_i64(plan + p * 64 + 0, 0);
        __mind_store_i64(plan + p * 64 + 8, astart);
        __mind_store_i64(plan + p * 64 + 16, aend);
        __mind_store_i64(nplan_cell, p + 1);
        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
    }
    // BARE EXPRESSION STATEMENT (a call/expr emitted for side-effect; its result vid
    // is allocated then discarded, e.g. `__mind_store_i64(n, kind);` in ast_new_leaf).
    // Flatten it like a let-init but bind NO name. Type 11, NOT type 0: a real `let`
    // segment (type 0) always pairs 1-for-1 with an `env` entry (name_lo/name_hi/slot)
    // appended above; this bare statement binds no name, so it must NOT be counted as
    // an env entry by seq_fix_deltas / emit_stmt_seq's envk / seq_lvenv_append_one —
    // those walk `plan` and `env` in LOCKSTEP, incrementing their env-side cursor once
    // per env-bearing plan entry. Reusing type 0 here desyncs that cursor the moment a
    // bare-call statement follows a real let: every subsequent env read then lands one
    // slot past the real (populated) entries into unzeroed __mind_alloc memory, whose
    // content is whatever the process's prior allocation history left behind — silently
    // wrong bytes on some runs, a wild-pointer-as-index SIGSEGV on others (the exact
    // "ASLR-dependent flake" this type split fixes). seq_body_len / seq_assign_vids /
    // emit_stmt_seq all carry an explicit type-11 arm (identical range-resolution to
    // type 0, zero env/live-env bookkeeping); seq_fix_deltas / build_trail_env need NO
    // type-11 arm — their existing "any other type" fallthrough already leaves
    // nnames/env_k/tk untouched, which is exactly correct here. Fails closed if
    // flatten_expr_env rejects the stmt (then this fn / seq is unsupported).
    let bstart: i64 = __mind_load_i64(cursor);
    let broot: i64 = flatten_expr_env(stmt, src, params_addr, n_params, nodes, cursor, env, nlets);
    if broot < 0 {
        return 0;
    }
    let bend: i64 = __mind_load_i64(cursor);
    __mind_store_i64(plan + p * 64 + 0, 11);
    __mind_store_i64(plan + p * 64 + 8, bstart);
    __mind_store_i64(plan + p * 64 + 16, bend);
    __mind_store_i64(nplan_cell, p + 1);
    flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1)
}

// Pass B — assign vids across the plan in source order, threading `base`. A let
// segment resolves its [start,end) slots from base. An if-return block resolves the
// cond tree from base, then injects the OP_IF synth/dst vids: then-synth, the ret
// tree (from then-synth+1), the else-synth, and dst — advancing base past the whole
// block, exactly as emit_mic3_if_stmt_instr lays them out. Returns the final base.
// Convert the seq let-env (name_lo, name_hi, root_SLOT) into an lv-env (name_lo,
// name_hi, VID) for the _lv segment emitters, so a segment cond/init that refers
// to a sequence-level let (e.g. `if n == 2` where `let n = ...` precedes it)
// resolves it. When resolve==1, vid = vidbuf[root_slot] (Pass-B-resolved); when 0
// (probe, vids not yet assigned) vid = 0 (only the NAME matters — let-refs are
// 0-count leaves whose vid does not affect the dst delta). Returns nlets.
pub fn seq_env_to_lvenv(env: i64, nlets: i64, vidbuf: i64, lvbuf: i64, resolve: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    __mind_store_i64(lvbuf + i * 24 + 0, __mind_load_i64(env + i * 24 + 0));
    __mind_store_i64(lvbuf + i * 24 + 8, __mind_load_i64(env + i * 24 + 8));
    let v: i64 = if resolve == 1 {
        __mind_load_i64(vidbuf + __mind_load_i64(env + i * 24 + 16) * 8)
    } else {
        0
    };
    __mind_store_i64(lvbuf + i * 24 + 16, v);
    seq_env_to_lvenv(env, nlets, vidbuf, lvbuf, resolve, i + 1)
}

// PRE-PASS (between flatten and Pass B): correct each divergent segment's vid delta for
// already-BOUND then-block lets. The flatten-time probe sees only the sequence lets bound
// before the segment (no prior-segment escapes), so it classifies every then-block let as
// FRESH (each consuming a placeholder + merge_id = 2 vids). But a let whose name is already
// live (a prior segment's escaped binding) consumes only 1 vid (merge_id, no placeholder).
// Walk the plan in source order threading a POSITION-AWARE name env (sequence lets appended
// at their position + each divergent segment's escaped names), re-probe each type-5 segment
// against it (base0=0, name-only env — only found/not-found matters for the delta), and
// rewrite plan[i].next_delta = dst+1. `names_buf` is name-only (vid=0). Mirrors the emit-time
// live env in emit_stmt_seq so Pass B + emit agree on the layout. Returns final name count.
pub fn seq_fix_deltas(src: i64, plan: i64, nplan: i64, env: i64, names_buf: i64, nnames: i64, env_k: i64, i: i64, nodes: i64, cursor: i64) -> i64 {
    if i >= nplan {
        return nnames;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        __mind_store_i64(names_buf + nnames * 24 + 0, __mind_load_i64(env + env_k * 24 + 0));
        __mind_store_i64(names_buf + nnames * 24 + 8, __mind_load_i64(env + env_k * 24 + 8));
        __mind_store_i64(names_buf + nnames * 24 + 16, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + 1, env_k + 1, i + 1, nodes, cursor);
    }
    if ty == 7 {
        // Re-probe the let = if-EXPRESSION with the position-aware env so its delta reflects
        // any branch let already live in the outer env (bound -> 1 vid, not 2). The if-expr
        // escapes ONLY the seq let it binds (its branch lets are block-scoped); append that.
        let init7: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa7: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np7: i64 = __mind_load_i64(plan + i * 64 + 32);
        let v_nodes: i64 = __mind_alloc(256 * 32);
        let v_cursor: i64 = __mind_alloc(8);
        let v_vidbuf: i64 = __mind_alloc(256 * 8);
        let v_cell: i64 = __mind_alloc(8);
        __mind_store_i64(v_cell, 0 - 1);
        let _v: EmitState = emit_if_expr_any_lv(es_new(), init7, src, pa7, np7, v_nodes, v_cursor, v_vidbuf, 0, v_cell, names_buf, nnames, 0, 0, 0, 0, 0);
        let v_dst: i64 = __mind_load_i64(v_cell);
        if v_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, v_dst + 1)
        }
        __mind_store_i64(names_buf + nnames * 24 + 0, __mind_load_i64(env + env_k * 24 + 0));
        __mind_store_i64(names_buf + nnames * 24 + 8, __mind_load_i64(env + env_k * 24 + 8));
        __mind_store_i64(names_buf + nnames * 24 + 16, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + 1, env_k + 1, i + 1, nodes, cursor);
    }
    if ty == 5 {
        let if_node5: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa5: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np5: i64 = __mind_load_i64(plan + i * 64 + 32);
        let p_nodes: i64 = __mind_alloc(256 * 32);
        let p_cursor: i64 = __mind_alloc(8);
        let p_vidbuf: i64 = __mind_alloc(256 * 8);
        let p_cell: i64 = __mind_alloc(8);
        __mind_store_i64(p_cell, 0 - 1);
        let p_bo: i64 = __mind_alloc(64 * 24);
        let p_nb: i64 = __mind_alloc(8);
        __mind_store_i64(p_nb, 0);
        let _p: EmitState = emit_if_chain_instr_lv(es_new(), if_node5, src, pa5, np5, p_nodes, p_cursor, p_vidbuf, 0, p_cell, names_buf, nnames, 0, 0, 0, p_bo, p_nb);
        let p_dst: i64 = __mind_load_i64(p_cell);
        if p_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, p_dst + 1);
            let nb: i64 = __mind_load_i64(p_nb);
            let _ap: i64 = lvenv_append_escapes(names_buf, nnames, p_bo, nb, 0);
            let p_slots: i64 = __mind_alloc((nb + 1) * 32);
            let _ps: i64 = synth_rebind_slots(p_bo, nb, nodes, cursor, p_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb);
            __mind_store_i64(plan + i * 64 + 56, p_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    if ty == 8 {
        let if8: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa8: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np8: i64 = __mind_load_i64(plan + i * 64 + 32);
        let q_nodes: i64 = __mind_alloc(256 * 32);
        let q_cursor: i64 = __mind_alloc(8);
        let q_vidbuf: i64 = __mind_alloc(256 * 8);
        let q_cell: i64 = __mind_alloc(8);
        __mind_store_i64(q_cell, 0 - 1);
        let q_then: i64 = ast_child1(if8);
        let q_lvbuf: i64 = __mind_alloc((nnames + ast_aux(q_then) + 512) * 24);
        let q_bo: i64 = __mind_alloc(64 * 24);
        let q_nb: i64 = __mind_alloc(8);
        __mind_store_i64(q_nb, 0);
        let _q: EmitState = emit_if_fallthrough_lv(es_new(), if8, src, pa8, np8, q_nodes, q_cursor, q_vidbuf, 0, q_cell, names_buf, nnames, q_lvbuf, 0, 0, 0, q_bo, q_nb);
        let q_dst: i64 = __mind_load_i64(q_cell);
        if q_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, q_dst + 1);
            let nb8: i64 = __mind_load_i64(q_nb);
            let _ap8: i64 = lvenv_append_escapes(names_buf, nnames, q_bo, nb8, 0);
            let q_slots: i64 = __mind_alloc((nb8 + 1) * 32);
            let _qs: i64 = synth_rebind_slots(q_bo, nb8, nodes, cursor, q_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb8);
            __mind_store_i64(plan + i * 64 + 56, q_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb8, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    if ty == 4 {
        let if4: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa4: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np4: i64 = __mind_load_i64(plan + i * 64 + 32);
        let r_nodes: i64 = __mind_alloc(256 * 32);
        let r_cursor: i64 = __mind_alloc(8);
        let r_vidbuf: i64 = __mind_alloc(256 * 8);
        let r_cell: i64 = __mind_alloc(8);
        __mind_store_i64(r_cell, 0 - 1);
        let r_then: i64 = ast_child1(if4);
        let r_nlets: i64 = count_leading_lets(ast_child0(r_then), ast_aux(r_then), 0);
        let r_lvbuf: i64 = __mind_alloc((nnames + r_nlets + 8) * 24);
        let r_bo: i64 = __mind_alloc(64 * 24);
        let r_nb: i64 = __mind_alloc(8);
        __mind_store_i64(r_nb, 0);
        let _r: EmitState = emit_if_let_seq_then_instr_lv(es_new(), if4, src, pa4, np4, r_nodes, r_cursor, r_vidbuf, 0, r_cell, names_buf, nnames, r_lvbuf, 0, 0, 0, r_bo, r_nb);
        let r_dst: i64 = __mind_load_i64(r_cell);
        if r_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, r_dst + 1);
            let nb4: i64 = __mind_load_i64(r_nb);
            let _ap4: i64 = lvenv_append_escapes(names_buf, nnames, r_bo, nb4, 0);
            let r_slots: i64 = __mind_alloc((nb4 + 1) * 32);
            let _rs: i64 = synth_rebind_slots(r_bo, nb4, nodes, cursor, r_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb4);
            __mind_store_i64(plan + i * 64 + 56, r_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb4, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    if ty == 6 {
        let if6: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa6: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np6: i64 = __mind_load_i64(plan + i * 64 + 32);
        let u_nodes: i64 = __mind_alloc(256 * 32);
        let u_cursor: i64 = __mind_alloc(8);
        let u_vidbuf: i64 = __mind_alloc(256 * 8);
        let u_cell: i64 = __mind_alloc(8);
        __mind_store_i64(u_cell, 0 - 1);
        let u_bo: i64 = __mind_alloc(64 * 24);
        let u_nb: i64 = __mind_alloc(8);
        __mind_store_i64(u_nb, 0);
        let _u: EmitState = emit_if_mixed_then_instr_lv(es_new(), if6, src, pa6, np6, u_nodes, u_cursor, u_vidbuf, 0, u_cell, names_buf, nnames, 0, 0, 0, u_bo, u_nb);
        let u_dst: i64 = __mind_load_i64(u_cell);
        if u_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, u_dst + 1);
            let nb6: i64 = __mind_load_i64(u_nb);
            let _ap6: i64 = lvenv_append_escapes(names_buf, nnames, u_bo, nb6, 0);
            let u_slots: i64 = __mind_alloc((nb6 + 1) * 32);
            let _us: i64 = synth_rebind_slots(u_bo, nb6, nodes, cursor, u_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb6);
            __mind_store_i64(plan + i * 64 + 56, u_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb6, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    if ty == 9 {
        let if9: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa9: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np9: i64 = __mind_load_i64(plan + i * 64 + 32);
        let w_nodes: i64 = __mind_alloc(256 * 32);
        let w_cursor: i64 = __mind_alloc(8);
        let w_vidbuf: i64 = __mind_alloc(256 * 8);
        let w_cell: i64 = __mind_alloc(8);
        __mind_store_i64(w_cell, 0 - 1);
        let w_bo: i64 = __mind_alloc(64 * 24);
        let w_nb: i64 = __mind_alloc(8);
        __mind_store_i64(w_nb, 0);
        let _w: EmitState = emit_if_else_fallthrough_lv(es_new(), if9, src, pa9, np9, w_nodes, w_cursor, w_vidbuf, 0, w_cell, names_buf, nnames, 0, 0, 0, 0, w_bo, w_nb);
        let w_dst: i64 = __mind_load_i64(w_cell);
        if w_dst >= 0 {
            __mind_store_i64(plan + i * 64 + 16, w_dst + 1);
            let nb9: i64 = __mind_load_i64(w_nb);
            let _ap9: i64 = lvenv_append_escapes(names_buf, nnames, w_bo, nb9, 0);
            let w_slots: i64 = __mind_alloc((nb9 + 1) * 32);
            let _ws: i64 = synth_rebind_slots(w_bo, nb9, nodes, cursor, w_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb9);
            __mind_store_i64(plan + i * 64 + 56, w_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb9, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    if ty == 10 {
        // top-level statement while: re-probe at base0=0 against the position-aware lv-env
        // to learn (a) its vid delta and (b) the loop-carried EXIT-id overlay. Each carried
        // var's post-loop value is its exit_id; append the (name, exit_id_rel) overlay (a
        // SHADOW of the earlier seq let) + synth rebind slots so a later read / the trailing
        // value resolves to the dominating exit id. Mirrors the type-8 escape handling.
        let w_node10: i64 = __mind_load_i64(plan + i * 64 + 8);
        let pa10: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np10: i64 = __mind_load_i64(plan + i * 64 + 32);
        let w_mo: i64 = __mind_alloc(64 * 24);
        let w_nm: i64 = __mind_alloc(8);
        __mind_store_i64(w_nm, 0);
        let w_eb: i64 = __mind_alloc(8);
        __mind_store_i64(w_eb, 0 - 1);
        let w_ok: i64 = __mind_alloc(8);
        __mind_store_i64(w_ok, 1);
        let _w10: EmitState = emit_mic3_while_general(es_new(), w_node10, src, pa10, np10, 0, names_buf, nnames, 0, 0, 0, w_mo, w_nm, w_eb, w_ok);
        if __mind_load_i64(w_ok) == 1 {
            __mind_store_i64(plan + i * 64 + 16, __mind_load_i64(w_eb) + 1);
            let nb10: i64 = __mind_load_i64(w_nm);
            let _ap10: i64 = lvenv_append_escapes(names_buf, nnames, w_mo, nb10, 0);
            let w_slots: i64 = __mind_alloc((nb10 + 1) * 32);
            let _ws10: i64 = synth_rebind_slots(w_mo, nb10, nodes, cursor, w_slots, 0);
            __mind_store_i64(plan + i * 64 + 48, nb10);
            __mind_store_i64(plan + i * 64 + 56, w_slots);
            return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames + nb10, env_k, i + 1, nodes, cursor);
        }
        __mind_store_i64(plan + i * 64 + 48, 0);
        return seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor);
    }
    // Tail: types 1/2 (if-return) and 11 (bare expression statement) all land here
    // UNCHANGED (nnames/env_k pass through) — none of them binds a name, so none of
    // them owns an `env` entry to consume or a position-aware name to publish.
    seq_fix_deltas(src, plan, nplan, env, names_buf, nnames, env_k, i + 1, nodes, cursor)
}

pub fn seq_assign_vids(nodes: i64, vidbuf: i64, plan: i64, nplan: i64, base: i64, i: i64) -> i64 {
    if i >= nplan {
        return base;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        let nb: i64 = seq_resolve_range(nodes, start, end, vidbuf, base);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, nb, i + 1);
    }
    // (type 11) bare expression statement (no bound name) — identical vid-range
    // resolution to type 0. MUST be its own arm: falling through to the implicit
    // if-return (type 1) default below would read plan[+32]/[+40] as rstart/rend,
    // fields this plan entry never wrote (unzeroed __mind_alloc garbage).
    if ty == 11 {
        let bstart: i64 = __mind_load_i64(plan + i * 64 + 8);
        let bend: i64 = __mind_load_i64(plan + i * 64 + 16);
        let bnb: i64 = seq_resolve_range(nodes, bstart, bend, vidbuf, base);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, bnb, i + 1);
    }
    if ty == 3 {
        // if-with-SEQ-then-block. The whole OP_IF (cond + segments + else + dst)
        // consumes `next_delta` vids relative to `base` (probed at flatten time,
        // base-relative). Advance past it.
        let next_delta: i64 = __mind_load_i64(plan + i * 64 + 16);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta, i + 1);
    }
    if ty == 4 {
        // if-with-LET-then-block (merge tail). Same base-relative delta convention
        // as type 3 — the whole OP_IF (cond + let inits + segments + merge tail)
        // consumes `next_delta` vids relative to `base`.
        let next_delta4: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv4: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta4, i + 1);
    }
    if ty == 5 {
        // single nested-if-chain segment (arbitrary depth). Base-relative delta.
        let next_delta5: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv5: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta5, i + 1);
    }
    if ty == 7 {
        // let = if-EXPRESSION. The OP_IF consumes `next_delta` vids; its dst (the let's
        // value) = base + next_delta - 1. Bind the dst-slot to it so later refs resolve.
        let next_delta7: i64 = __mind_load_i64(plan + i * 64 + 16);
        let dst_slot7: i64 = __mind_load_i64(plan + i * 64 + 40);
        __mind_store_i64(vidbuf + dst_slot7 * 8, base + next_delta7 - 1);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta7, i + 1);
    }
    if ty == 6 {
        // MIXED returning then-block. Base-relative delta (probed at flatten time).
        let next_delta6: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv6: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta6, i + 1);
    }
    if ty == 8 {
        // FALL-THROUGH side-effect block. Base-relative delta.
        let next_delta8: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv8: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta8, i + 1);
    }
    if ty == 9 {
        // Two-sided fall-through if-else statement. Base-relative delta.
        let next_delta9: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv9: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta9, i + 1);
    }
    if ty == 10 {
        // top-level statement while. Base-relative vid delta (OP_WHILE vids + trailing
        // unit). Set each loop-carried var's rebind slot vid = base + exit_id_rel so a
        // post-loop read of that name resolves to the dominating exit id (Pass-B).
        let w_delta10: i64 = __mind_load_i64(plan + i * 64 + 16);
        let _rv10: i64 = seq_set_rebind_vids(vidbuf, __mind_load_i64(plan + i * 64 + 56), __mind_load_i64(plan + i * 64 + 48), base, 0);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + w_delta10, i + 1);
    }
    if ty == 2 {
        // NESTED if-return segment. Same vid layout as emit_mic3_nested_if_instr,
        // base-threaded: outer cond -> then-synth -> inner cond -> inner-then-synth ->
        // inner ret -> inner-else-synth -> inner-dst -> outer-else-synth -> outer-dst.
        let n2_rs: i64 = __mind_load_i64(plan + i * 64 + 8);
        let n2_re: i64 = __mind_load_i64(plan + i * 64 + 16);
        let n2_s1: i64 = __mind_load_i64(plan + i * 64 + 48);
        let n2_s2: i64 = __mind_load_i64(plan + i * 64 + 56);
        let n2_after_oc: i64 = seq_resolve_range(nodes, n2_rs, n2_s1, vidbuf, base);
        let n2_after_ic: i64 = seq_resolve_range(nodes, n2_s1, n2_s2, vidbuf, n2_after_oc + 1);
        let n2_after_ir: i64 = seq_resolve_range(nodes, n2_s2, n2_re, vidbuf, n2_after_ic + 1);
        let n2_next: i64 = n2_after_ir + 4;
        return seq_assign_vids(nodes, vidbuf, plan, nplan, n2_next, i + 1);
    }
    // if-return block.
    let cstart: i64 = __mind_load_i64(plan + i * 64 + 8);
    let cend: i64 = __mind_load_i64(plan + i * 64 + 16);
    let rstart: i64 = __mind_load_i64(plan + i * 64 + 32);
    let rend: i64 = __mind_load_i64(plan + i * 64 + 40);
    let after_cond: i64 = seq_resolve_range(nodes, cstart, cend, vidbuf, base);
    // then-synth at after_cond; ret tree resolves from after_cond+1; else-synth and
    // dst follow.
    let after_ret: i64 = seq_resolve_range(nodes, rstart, rend, vidbuf, after_cond + 1);
    let next_base: i64 = after_ret + 2;
    seq_assign_vids(nodes, vidbuf, plan, nplan, next_base, i + 1)
}

// Append one resolved sequence let (name_lo/name_hi/vid, from `seqr[k]`) to the
// growing live lv-env `live` at index `at`; return at+1. Used so each sequence-level
// let becomes visible to SUBSEQUENT segments at its source position (NOT before).
pub fn seq_lvenv_append_one(live: i64, at: i64, seqr: i64, k: i64) -> i64 {
    __mind_store_i64(live + at * 24 + 0, __mind_load_i64(seqr + k * 24 + 0));
    __mind_store_i64(live + at * 24 + 8, __mind_load_i64(seqr + k * 24 + 8));
    __mind_store_i64(live + at * 24 + 16, __mind_load_i64(seqr + k * 24 + 16));
    at + 1
}

// Append `n` escaped bindings (24-byte name_lo/name_hi/merge_id records, from a
// segment's `bindout`) to the growing live lv-env at index `at`; return at+n. A let
// in a divergent if-then-block stays LIVE after the block as its merge result (SSA
// F2), so a later segment that rebinds the same name merges against this vid — and a
// later segment merely referencing it resolves to it. Mirrors src/eval/lower.rs.
pub fn lvenv_append_escapes(live: i64, at: i64, bo: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return at + n;
    }
    __mind_store_i64(live + (at + i) * 24 + 0, __mind_load_i64(bo + i * 24 + 0));
    __mind_store_i64(live + (at + i) * 24 + 8, __mind_load_i64(bo + i * 24 + 8));
    __mind_store_i64(live + (at + i) * 24 + 16, __mind_load_i64(bo + i * 24 + 16));
    lvenv_append_escapes(live, at, bo, n, i + 1)
}

// SHADOW-MERGE REBIND. A divergent fall-through if escapes one merge binding per name
// (bo: name_lo, name_hi, base0-relative merge_id). After such an if, a later Pass-A read
// of that name (a trailing value) must resolve to the MERGE vid, not the pre-if outer
// slot — otherwise a name SHADOWED inside the if reads the wrong vid. For each escaping
// binding: synthesise a placeholder descriptor slot (kind 0, like the type-7 dst-slot —
// never emitted, only referenced), and record (name_lo, name_hi, slot, merge_id) into
// `slots_out` (32-byte records). Pass B sets vidbuf[slot] = entry_base + merge_id; the
// driver weaves these slots into a POSITION-ORDERED trailing env (build_trail_env) so a
// later seq-level let of the same name correctly shadows an earlier merge. Returns nb.
pub fn synth_rebind_slots(bo: i64, nb: i64, nodes: i64, cursor: i64, slots_out: i64, i: i64) -> i64 {
    if i >= nb {
        return nb;
    }
    let lo: i64 = __mind_load_i64(bo + i * 24 + 0);
    let hi: i64 = __mind_load_i64(bo + i * 24 + 8);
    let mid: i64 = __mind_load_i64(bo + i * 24 + 16);
    let dst_slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + dst_slot * 32 + 0, 0);
    __mind_store_i64(nodes + dst_slot * 32 + 8, 0);
    __mind_store_i64(nodes + dst_slot * 32 + 16, 0);
    __mind_store_i64(nodes + dst_slot * 32 + 24, 0);
    __mind_store_i64(cursor, dst_slot + 1);
    __mind_store_i64(slots_out + i * 32 + 0, lo);
    __mind_store_i64(slots_out + i * 32 + 8, hi);
    __mind_store_i64(slots_out + i * 32 + 16, dst_slot);
    __mind_store_i64(slots_out + i * 32 + 24, mid);
    synth_rebind_slots(bo, nb, nodes, cursor, slots_out, i + 1)
}

// Pass B — set each rebind slot's vid to the absolute merge vid (entry base + the
// base0-relative merge_id recorded by synth_rebind_slots). Returns nb.
pub fn seq_set_rebind_vids(vidbuf: i64, slots: i64, nb: i64, base: i64, i: i64) -> i64 {
    if i >= nb {
        return nb;
    }
    let dst_slot: i64 = __mind_load_i64(slots + i * 32 + 16);
    let mid: i64 = __mind_load_i64(slots + i * 32 + 24);
    __mind_store_i64(vidbuf + dst_slot * 8, base + mid);
    seq_set_rebind_vids(vidbuf, slots, nb, base, i + 1)
}

// Copy `n` rebind slots' (name_lo, name_hi, dst_slot) from 32-byte `slots` records into
// the 24-byte trailing-env `tenv` at `at`; return at+n. Used by build_trail_env.
pub fn copy_rebind_to_tenv(tenv: i64, at: i64, slots: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return at + n;
    }
    __mind_store_i64(tenv + (at + i) * 24 + 0, __mind_load_i64(slots + i * 32 + 0));
    __mind_store_i64(tenv + (at + i) * 24 + 8, __mind_load_i64(slots + i * 32 + 8));
    __mind_store_i64(tenv + (at + i) * 24 + 16, __mind_load_i64(slots + i * 32 + 16));
    copy_rebind_to_tenv(tenv, at, slots, n, i + 1)
}

// Build the POSITION-ORDERED trailing env for the FN_DEF result expression: walk the plan
// in source order, emitting each type-0/type-7 let's env entry (from `env`, consumed via
// env_k) and each divergent segment's rebind overlay slots (from plan+56). Mirrors the
// position-aware live env so the trailing value's letenv_lookup (last-match) resolves a
// SHADOWED name to its latest binding — a later seq let shadows an earlier merge, an
// earlier merge shadows the pre-if outer let. Returns the trailing-env length.
pub fn build_trail_env(plan: i64, nplan: i64, env: i64, tenv: i64, env_k: i64, tk: i64, i: i64) -> i64 {
    if i >= nplan {
        return tk;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        __mind_store_i64(tenv + tk * 24 + 0, __mind_load_i64(env + env_k * 24 + 0));
        __mind_store_i64(tenv + tk * 24 + 8, __mind_load_i64(env + env_k * 24 + 8));
        __mind_store_i64(tenv + tk * 24 + 16, __mind_load_i64(env + env_k * 24 + 16));
        return build_trail_env(plan, nplan, env, tenv, env_k + 1, tk + 1, i + 1);
    }
    if ty == 7 {
        __mind_store_i64(tenv + tk * 24 + 0, __mind_load_i64(env + env_k * 24 + 0));
        __mind_store_i64(tenv + tk * 24 + 8, __mind_load_i64(env + env_k * 24 + 8));
        __mind_store_i64(tenv + tk * 24 + 16, __mind_load_i64(env + env_k * 24 + 16));
        return build_trail_env(plan, nplan, env, tenv, env_k + 1, tk + 1, i + 1);
    }
    // Only the divergent escaping types (4/5/6/8/9) carry rebind overlay slots at +48/+56;
    // other types never write those fields (unzeroed malloc), so guard before reading them.
    // (type 11, bare expression statement, and type 1/2, if-return, all fall through to the
    // unconditional tail below UNCHANGED — none of them bind a name, so none contributes an
    // env entry or a rebind slot; env_k/tk must NOT advance for them.)
    if seq_ty_escapes(ty) == 1 {
        let rb_nb: i64 = __mind_load_i64(plan + i * 64 + 48);
        if rb_nb > 0 {
            let slots: i64 = __mind_load_i64(plan + i * 64 + 56);
            let tk2: i64 = copy_rebind_to_tenv(tenv, tk, slots, rb_nb, 0);
            return build_trail_env(plan, nplan, env, tenv, env_k, tk2, i + 1);
        }
    }
    build_trail_env(plan, nplan, env, tenv, env_k, tk, i + 1)
}

// Resolve the position-ordered trailing env `tenv` (name_lo, name_hi, descriptor-slot)
// into a (name_lo, name_hi, VID) lv-env by reading each slot's Pass-B vid from `vidbuf`.
// Used to give a trailing value if-expr the same resolved seq lv-env emit_stmt_seq builds
// in `live`, so its branch refs to sequence lets resolve byte-exactly. Returns tk.
pub fn resolve_tenv_lvenv(tenv: i64, tk: i64, vidbuf: i64, out: i64, i: i64) -> i64 {
    if i >= tk {
        return tk;
    }
    let slot: i64 = __mind_load_i64(tenv + i * 24 + 16);
    __mind_store_i64(out + i * 24 + 0, __mind_load_i64(tenv + i * 24 + 0));
    __mind_store_i64(out + i * 24 + 8, __mind_load_i64(tenv + i * 24 + 8));
    __mind_store_i64(out + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    resolve_tenv_lvenv(tenv, tk, vidbuf, out, i + 1)
}

// Does plan type `ty` carry a rebind overlay (escaping fall-through merge bindings)?
pub fn seq_ty_escapes(ty: i64) -> i64 {
    if ty == 4 {
        return 1;
    }
    if ty == 5 {
        return 1;
    }
    if ty == 6 {
        return 1;
    }
    if ty == 8 {
        return 1;
    }
    if ty == 9 {
        return 1;
    }
    if ty == 10 {
        return 1;
    }
    0
}

// Pass C — emit the body instrs for the plan in source order. A let segment emits
// its [start,end) tree. An if-return block emits ONE OP_IF (0x1C): cond tree, then
// (synth const + ret tree + Return(ret_root_vid)), else (synth const), dst, empty
// bindings/merges — reading every vid from the shared vidbuf resolved in Pass B.
// `seq_lvbuf` is the GROWING live lv-env, `seq_nlv` its current length: each sequence
// let appends at its position (via `seqr`/`envk`) and each divergent segment appends
// its escaped bindings, so a segment sees exactly what is live AT its source position
// (position-aware scoping — NOT the static full-sequence env, which would expose
// forward-defined lets and miss prior segments' escapes).
pub fn emit_stmt_seq(s: EmitState, nodes: i64, vidbuf: i64, src: i64, strbuf: i64, offs: i64, ncount: i64, plan: i64, nplan: i64, base: i64, i: i64, seq_lvbuf: i64, seq_nlv: i64, seqr: i64, envk: i64) -> EmitState {
    if i >= nplan {
        return s;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        let nb: i64 = seq_resolve_range(nodes, start, end, vidbuf, base);
        let s1: EmitState = emit_mic3_tree_body(s, nodes, end, vidbuf, src, strbuf, offs, ncount, start);
        let _ap0: i64 = seq_lvenv_append_one(seq_lvbuf, seq_nlv, seqr, envk);
        return emit_stmt_seq(s1, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, nb, i + 1, seq_lvbuf, seq_nlv + 1, seqr, envk + 1);
    }
    // (type 11) bare expression statement (no bound name) — emit its [start,end)
    // tree exactly like type 0, but bind NO name: no seq_lvenv_append_one, seq_nlv
    // and envk pass through UNCHANGED. This is the entire fix — type 0's env-cursor
    // advance assumed every segment corresponds 1:1 with an `env`/`seqr` entry, which
    // is false for a statement that binds nothing (see flatten_stmt_seq).
    if ty == 11 {
        let bstart: i64 = __mind_load_i64(plan + i * 64 + 8);
        let bend: i64 = __mind_load_i64(plan + i * 64 + 16);
        let bnb: i64 = seq_resolve_range(nodes, bstart, bend, vidbuf, base);
        let bs1: EmitState = emit_mic3_tree_body(s, nodes, bend, vidbuf, src, strbuf, offs, ncount, bstart);
        return emit_stmt_seq(bs1, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, bnb, i + 1, seq_lvbuf, seq_nlv, seqr, envk);
    }
    if ty == 3 {
        // if-with-SEQ-then-block -> ONE outer OP_IF whose then-branch is a sequence
        // of if-segments. Self-contained (own scratch so the shared nodes/vidbuf used
        // by other segments are untouched); base-threaded. dst = base + next_delta - 1.
        // The seq lv-env lets the cond reference sequence-level lets (`if n == 2`).
        let if_node3: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta3: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa3: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np3: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e3_nodes: i64 = __mind_alloc(256 * 32);
        let e3_cursor: i64 = __mind_alloc(8);
        let e3_vidbuf: i64 = __mind_alloc(256 * 8);
        let e3_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e3_cell, 0 - 1);
        let s3i: EmitState = emit_if_seq_then_instr_lv(s, if_node3, src, pa3, np3, e3_nodes, e3_cursor, e3_vidbuf, base, e3_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount);
        return emit_stmt_seq(s3i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta3, i + 1, seq_lvbuf, seq_nlv, seqr, envk);
    }
    if ty == 4 {
        // if-with-LET-then-block (merge tail) -> ONE outer OP_IF. Self-contained
        // scratch; base-threaded. strbuf/offs/ncount resolve the binding names. The
        // seq lv-env (seq_lvbuf/seq_nlv) seeds lvenv0 so the cond + then-lets resolve
        // sequence-level lets; the then-block lets append after seq_nlv.
        let if_node4: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta4: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa4: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np4: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e4_nodes: i64 = __mind_alloc(256 * 32);
        let e4_cursor: i64 = __mind_alloc(8);
        let e4_vidbuf: i64 = __mind_alloc(256 * 8);
        let e4_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e4_cell, 0 - 1);
        let e4_then_blk: i64 = ast_child1(if_node4);
        let e4_nlets: i64 = count_leading_lets(ast_child0(e4_then_blk), ast_aux(e4_then_blk), 0);
        let e4_lvbuf: i64 = __mind_alloc((seq_nlv + e4_nlets + 512) * 24);
        let e4_bo: i64 = __mind_alloc(64 * 24);
        let e4_nb: i64 = __mind_alloc(8);
        let s4i: EmitState = emit_if_let_seq_then_instr_lv(s, if_node4, src, pa4, np4, e4_nodes, e4_cursor, e4_vidbuf, base, e4_cell, seq_lvbuf, seq_nlv, e4_lvbuf, strbuf, offs, ncount, e4_bo, e4_nb);
        let e4_n: i64 = __mind_load_i64(e4_nb);
        let _ap4: i64 = lvenv_append_escapes(seq_lvbuf, seq_nlv, e4_bo, e4_n, 0);
        return emit_stmt_seq(s4i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta4, i + 1, seq_lvbuf, seq_nlv + e4_n, seqr, envk);
    }
    if ty == 5 {
        // single nested-if-chain segment of ARBITRARY depth -> ONE OP_IF via the
        // recursive chain emitter (subsumes the depth-2 type-2). Self-contained
        // scratch; base-threaded; seq lv-env lets the cond reference sequence lets.
        let if_node5: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta5: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa5: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np5: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e5_nodes: i64 = __mind_alloc(256 * 32);
        let e5_cursor: i64 = __mind_alloc(8);
        let e5_vidbuf: i64 = __mind_alloc(256 * 8);
        let e5_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e5_cell, 0 - 1);
        let e5_bindout: i64 = __mind_alloc(64 * 24);
        let e5_nbind: i64 = __mind_alloc(8);
        let s5i: EmitState = emit_if_chain_instr_lv(s, if_node5, src, pa5, np5, e5_nodes, e5_cursor, e5_vidbuf, base, e5_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount, e5_bindout, e5_nbind);
        let e5_n: i64 = __mind_load_i64(e5_nbind);
        let _ap5: i64 = lvenv_append_escapes(seq_lvbuf, seq_nlv, e5_bindout, e5_n, 0);
        return emit_stmt_seq(s5i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta5, i + 1, seq_lvbuf, seq_nlv + e5_n, seqr, envk);
    }
    if ty == 7 {
        // let = if-EXPRESSION -> ONE OP_IF (value). Self-contained scratch; the seq
        // lv-env resolves sequence-let refs in the cond/branches. dst = base+delta-1.
        let init7: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta7: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa7: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np7: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e7_nodes: i64 = __mind_alloc(256 * 32);
        let e7_cursor: i64 = __mind_alloc(8);
        let e7_vidbuf: i64 = __mind_alloc(256 * 8);
        let e7_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e7_cell, 0 - 1);
        let s7i: EmitState = emit_if_expr_any_lv(s, init7, src, pa7, np7, e7_nodes, e7_cursor, e7_vidbuf, base, e7_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount, 0, 0);
        let _ap7: i64 = seq_lvenv_append_one(seq_lvbuf, seq_nlv, seqr, envk);
        return emit_stmt_seq(s7i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta7, i + 1, seq_lvbuf, seq_nlv + 1, seqr, envk + 1);
    }
    if ty == 6 {
        // MIXED returning then-block -> ONE OP_IF (segments + lets + Return + poison
        // merge tail). Self-contained scratch; base-threaded; seq lv-env threaded.
        let if_node6: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta6: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa6: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np6: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e6_nodes: i64 = __mind_alloc(256 * 32);
        let e6_cursor: i64 = __mind_alloc(8);
        let e6_vidbuf: i64 = __mind_alloc(256 * 8);
        let e6_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e6_cell, 0 - 1);
        let e6_bindout: i64 = __mind_alloc(64 * 24);
        let e6_nbind: i64 = __mind_alloc(8);
        let s6i: EmitState = emit_if_mixed_then_instr_lv(s, if_node6, src, pa6, np6, e6_nodes, e6_cursor, e6_vidbuf, base, e6_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount, e6_bindout, e6_nbind);
        let e6_n: i64 = __mind_load_i64(e6_nbind);
        let _ap6: i64 = lvenv_append_escapes(seq_lvbuf, seq_nlv, e6_bindout, e6_n, 0);
        return emit_stmt_seq(s6i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta6, i + 1, seq_lvbuf, seq_nlv + e6_n, seqr, envk);
    }
    if ty == 8 {
        // FALL-THROUGH side-effect block `if C { lets + bare-calls }` -> ONE OP_IF whose
        // then-block runs the side effects and falls off the end; lets merge with POISON.
        // Mirrors ty==4; self-contained scratch; base-threaded; seq lv-env threaded.
        let if_node8: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta8: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa8: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np8: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e8_nodes: i64 = __mind_alloc(256 * 32);
        let e8_cursor: i64 = __mind_alloc(8);
        let e8_vidbuf: i64 = __mind_alloc(256 * 8);
        let e8_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e8_cell, 0 - 1);
        let e8_then_blk: i64 = ast_child1(if_node8);
        let e8_lvbuf: i64 = __mind_alloc((seq_nlv + ast_aux(e8_then_blk) + 512) * 24);
        let e8_bo: i64 = __mind_alloc(64 * 24);
        let e8_nb: i64 = __mind_alloc(8);
        let s8i: EmitState = emit_if_fallthrough_lv(s, if_node8, src, pa8, np8, e8_nodes, e8_cursor, e8_vidbuf, base, e8_cell, seq_lvbuf, seq_nlv, e8_lvbuf, strbuf, offs, ncount, e8_bo, e8_nb);
        let e8_n: i64 = __mind_load_i64(e8_nb);
        let _ap8: i64 = lvenv_append_escapes(seq_lvbuf, seq_nlv, e8_bo, e8_n, 0);
        return emit_stmt_seq(s8i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta8, i + 1, seq_lvbuf, seq_nlv + e8_n, seqr, envk);
    }
    if ty == 9 {
        // Two-sided FALL-THROUGH if-else statement -> ONE OP_IF with both branches' side
        // effects + two-sided merge tail. Self-contained scratch; base-threaded; seq lv-env.
        let if_node9: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta9: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa9: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np9: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e9_nodes: i64 = __mind_alloc(256 * 32);
        let e9_cursor: i64 = __mind_alloc(8);
        let e9_vidbuf: i64 = __mind_alloc(256 * 8);
        let e9_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e9_cell, 0 - 1);
        let e9_bo: i64 = __mind_alloc(64 * 24);
        let e9_nb: i64 = __mind_alloc(8);
        let s9i: EmitState = emit_if_else_fallthrough_lv(s, if_node9, src, pa9, np9, e9_nodes, e9_cursor, e9_vidbuf, base, e9_cell, seq_lvbuf, seq_nlv, 0, strbuf, offs, ncount, e9_bo, e9_nb);
        let e9_n: i64 = __mind_load_i64(e9_nb);
        let _ap9: i64 = lvenv_append_escapes(seq_lvbuf, seq_nlv, e9_bo, e9_n, 0);
        return emit_stmt_seq(s9i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta9, i + 1, seq_lvbuf, seq_nlv + e9_n, seqr, envk);
    }
    if ty == 10 {
        // top-level statement while -> OP_WHILE (via emit_mic3_while_general) + trailing
        // unit ConstI64. base-threaded; the seq lv-env resolves cond/body refs to seq lets.
        let w_node: i64 = __mind_load_i64(plan + i * 64 + 8);
        let w_delta: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa10: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np10: i64 = __mind_load_i64(plan + i * 64 + 32);
        let w_merge: i64 = __mind_alloc(64 * 24);
        let w_nm: i64 = __mind_alloc(8);
        __mind_store_i64(w_nm, 0);
        let w_end: i64 = __mind_alloc(8);
        __mind_store_i64(w_end, 0 - 1);
        let w_ok: i64 = __mind_alloc(8);
        __mind_store_i64(w_ok, 1);
        let sw: EmitState = emit_mic3_while_general(s, w_node, src, pa10, np10, base, seq_lvbuf, seq_nlv, strbuf, offs, ncount, w_merge, w_nm, w_end, w_ok);
        // trailing unit ConstI64 at endbase (= one past the exit_ids).
        let sw2: EmitState = emit_mic3_const_i64(sw, __mind_load_i64(w_end), 0);
        return emit_stmt_seq(sw2, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + w_delta, i + 1, seq_lvbuf, seq_nlv, seqr, envk);
    }
    if ty == 2 {
        // NESTED if-return segment -> ONE outer OP_IF whose then-branch is `synth +
        // inner OP_IF`. Reads vids from the shared vidbuf (resolved in Pass B), trees
        // from the shared node ranges. Mirrors emit_mic3_nested_if_instr, base-threaded.
        let n2_rs: i64 = __mind_load_i64(plan + i * 64 + 8);
        let n2_re: i64 = __mind_load_i64(plan + i * 64 + 16);
        let n2_ocr: i64 = __mind_load_i64(plan + i * 64 + 24);
        let n2_icr: i64 = __mind_load_i64(plan + i * 64 + 32);
        let n2_irr: i64 = __mind_load_i64(plan + i * 64 + 40);
        let n2_s1: i64 = __mind_load_i64(plan + i * 64 + 48);
        let n2_s2: i64 = __mind_load_i64(plan + i * 64 + 56);
        let n2_oc_n: i64 = count_descriptor_nonparam_range(nodes, n2_rs, n2_s1);
        let n2_after_oc: i64 = base + n2_oc_n;
        let n2_ic_n: i64 = count_descriptor_nonparam_range(nodes, n2_s1, n2_s2);
        let n2_after_ic: i64 = n2_after_oc + 1 + n2_ic_n;
        let n2_ir_n: i64 = count_descriptor_nonparam_range(nodes, n2_s2, n2_re);
        let n2_after_ir: i64 = n2_after_ic + 1 + n2_ir_n;
        let n2_inner_dst: i64 = n2_after_ir + 1;
        let n2_outer_else: i64 = n2_after_ir + 2;
        let n2_outer_dst: i64 = n2_after_ir + 3;
        let n2_oc_vid: i64 = __mind_load_i64(vidbuf + n2_ocr * 8);
        let n2_ic_vid: i64 = __mind_load_i64(vidbuf + n2_icr * 8);
        let n2_ir_vid: i64 = __mind_load_i64(vidbuf + n2_irr * 8);
        // outer OP_IF: cond
        let q1: EmitState = es_push(s, 28);
        let q2: EmitState = emit_uleb128(q1, n2_oc_vid);
        let q3: EmitState = emit_uleb128(q2, n2_oc_n);
        let q4: EmitState = emit_mic3_tree_body(q3, nodes, n2_s1, vidbuf, src, strbuf, offs, ncount, n2_rs);
        // outer then = synth + inner OP_IF (2 instrs)
        let q5: EmitState = emit_uleb128(q4, 2);
        let q6: EmitState = emit_mic3_const_i64(q5, n2_after_oc, 0);
        // inner OP_IF: cond
        let q7: EmitState = es_push(q6, 28);
        let q8: EmitState = emit_uleb128(q7, n2_ic_vid);
        let q9: EmitState = emit_uleb128(q8, n2_ic_n);
        let q10: EmitState = emit_mic3_tree_body(q9, nodes, n2_s2, vidbuf, src, strbuf, offs, ncount, n2_s1);
        // inner then = synth + ret tree + Return
        let q11: EmitState = emit_uleb128(q10, n2_ir_n + 2);
        let q12: EmitState = emit_mic3_const_i64(q11, n2_after_ic, 0);
        let q13: EmitState = emit_mic3_tree_body(q12, nodes, n2_re, vidbuf, src, strbuf, offs, ncount, n2_s2);
        let q14: EmitState = emit_mic3_return(q13, 1, n2_ir_vid);
        let q15: EmitState = emit_uleb128(q14, n2_ir_vid);
        // inner else = synth
        let q16: EmitState = emit_uleb128(q15, 1);
        let q17: EmitState = emit_mic3_const_i64(q16, n2_after_ir, 0);
        let q18: EmitState = emit_uleb128(q17, n2_after_ir);
        // inner dst + bindings + merges
        let q19: EmitState = emit_uleb128(q18, n2_inner_dst);
        let q20: EmitState = emit_uleb128(q19, 0);
        let q21: EmitState = emit_uleb128(q20, 0);
        // outer then-result = inner dst
        let q22: EmitState = emit_uleb128(q21, n2_inner_dst);
        // outer else = synth
        let q23: EmitState = emit_uleb128(q22, 1);
        let q24: EmitState = emit_mic3_const_i64(q23, n2_outer_else, 0);
        let q25: EmitState = emit_uleb128(q24, n2_outer_else);
        // outer dst + bindings + merges
        let q26: EmitState = emit_uleb128(q25, n2_outer_dst);
        let q27: EmitState = emit_uleb128(q26, 0);
        let q28: EmitState = emit_uleb128(q27, 0);
        return emit_stmt_seq(q28, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, n2_outer_dst + 1, i + 1, seq_lvbuf, seq_nlv, seqr, envk);
    }
    // if-return block. Recompute the same vid layout as Pass B to learn synth/dst.
    let cstart: i64 = __mind_load_i64(plan + i * 64 + 8);
    let cend: i64 = __mind_load_i64(plan + i * 64 + 16);
    let cond_root: i64 = __mind_load_i64(plan + i * 64 + 24);
    let rstart: i64 = __mind_load_i64(plan + i * 64 + 32);
    let rend: i64 = __mind_load_i64(plan + i * 64 + 40);
    let ret_root: i64 = __mind_load_i64(plan + i * 64 + 48);
    let after_cond: i64 = base + count_descriptor_nonparam_range(nodes, cstart, cend);
    let then_synth: i64 = after_cond;
    let ret_n: i64 = count_descriptor_nonparam_range(nodes, rstart, rend);
    let after_ret: i64 = after_cond + 1 + ret_n;
    let else_synth: i64 = after_ret;
    let dst: i64 = after_ret + 1;
    let cond_vid: i64 = __mind_load_i64(vidbuf + cond_root * 8);
    let ret_vid: i64 = __mind_load_i64(vidbuf + ret_root * 8);
    // OP_IF: cond.
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_vid);
    let cond_n: i64 = count_descriptor_nonparam_range(nodes, cstart, cend);
    let s3: EmitState = emit_uleb128(s2, cond_n);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cend, vidbuf, src, strbuf, offs, ncount, cstart);
    // then: synth const + ret tree + Return(ret_vid). length = ret_n + 2.
    let s5: EmitState = emit_uleb128(s4, ret_n + 2);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, rend, vidbuf, src, strbuf, offs, ncount, rstart);
    let s8: EmitState = emit_mic3_return(s7, 1, ret_vid);
    let s9: EmitState = emit_uleb128(s8, ret_vid);
    // else: synth const only.
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    // dst + empty bindings + empty merges.
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    emit_stmt_seq(s15, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, dst + 1, i + 1, seq_lvbuf, seq_nlv, seqr, envk)
}

// Emit ONE fn's FN_DEF whose body is a general statement sequence (lets and
// if-early-returns in any order, then a trailing value expr). Generalises cases
// (f)+(g). Writes 1 to ok_cell on success, 0 (fail-closed, returns seed `s`) on any
// wall. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_mic3_module_fndef_seq(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, env: i64, nlets_cell: i64, plan: i64, nplan_cell: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    __mind_store_i64(nplan_cell, 0);
    let plan_ok: i64 = flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, 0);
    if plan_ok == 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let nplan: i64 = __mind_load_i64(nplan_cell);
    // PRE-PASS: correct each divergent segment's vid delta for already-bound then-block
    // lets (a rebound name keeps its outer vid -> 1 vid, not 2), threading a position-aware
    // name env. Must run BEFORE Pass B (seq_assign_vids) so vid assignment matches the emit.
    let fix_names: i64 = __mind_alloc((nlets + 1024) * 24);
    // seq_fix_deltas also handles shadow-merge rebinds: it synthesises a placeholder slot
    // per escaping binding (advancing `cursor`) and records (name, slot, base0-merge_id)
    // into the plan (+48/+56), so a later Pass-A read of a name SHADOWED inside a
    // fall-through if can resolve to the merge vid (set in Pass B) not the outer slot.
    let _fd: i64 = seq_fix_deltas(src, plan, nplan, env, fix_names, 0, 0, 0, nodes, cursor);
    // Build the POSITION-ORDERED trailing env (type-0/7 lets + rebind overlay slots, in
    // plan order) so the FN_DEF result expression resolves a shadowed name to its latest
    // binding via letenv_lookup's last-match (a later seq let shadows an earlier merge).
    let tenv: i64 = __mind_alloc((nlets + 1024) * 24);
    let tk: i64 = build_trail_env(plan, nplan, env, tenv, 0, 0, 0);
    // Trailing value expr (the final statement) -> the FN_DEF ret vid. A body that
    // ends in `return E` lowers identically to a bare trailing `E` PLUS an explicit
    // RETURN <ret_vid> instruction (body_len + 1) — unwrap to E here, emit the Return
    // below. `is_trail_ret` records whether to append it.
    let trail_start: i64 = __mind_load_i64(cursor);
    let final_stmt: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    let is_trail_ret: i64 = if ast_kind(final_stmt) == ast_return() {
        1
    } else {
        0
    };
    let final_expr: i64 = if is_trail_ret == 1 {
        ast_child0(final_stmt)
    } else {
        final_stmt
    };
    // A trailing VALUE if-expr (`...; if C {A} else {B}`) is the FN_DEF result: emit it as
    // ONE OP_IF (the last body instr) via emit_if_expr_any_lv, NOT a flattened tree. Its
    // branches resolve sequence lets against the resolved trailing lv-env (resolve_tenv_lvenv).
    let trail_is_if: i64 = if is_trail_ret == 1 {
        0
    } else {
        is_any_value_if_expr(final_expr)
    };
    let trail_root: i64 = if trail_is_if == 1 {
        0
    } else {
        flatten_expr_env(final_expr, src, params_addr, n_params, nodes, cursor, tenv, tk)
    };
    if trail_is_if == 0 {
        if trail_root < 0 {
            __mind_store_i64(ok_cell, 0);
            return s;
        }
    }
    let trail_end: i64 = __mind_load_i64(cursor);
    // Pass B — assign vids across statement segments (lets + OP_IF blocks).
    let trail_base: i64 = seq_assign_vids(nodes, vidbuf, plan, nplan, n_params, 0);
    // Resolved trailing lv-env (name -> Pass-B vid) for a trailing if-expr's branch refs.
    let trail_lv: i64 = __mind_alloc((tk + 1) * 24);
    let _tlv: i64 = resolve_tenv_lvenv(tenv, tk, vidbuf, trail_lv, 0);
    // ret_vid: for a trailing if-expr, probe its OP_IF dst (base0=0) and rebase to trail_base;
    // otherwise the trailing tree's root vid. body_len: an if-expr is 1 top-level OP_IF instr.
    let ie_probe_dst: i64 = if trail_is_if == 1 {
        let ip_nodes: i64 = __mind_alloc(256 * 32);
        let ip_cursor: i64 = __mind_alloc(8);
        let ip_vidbuf: i64 = __mind_alloc(256 * 8);
        let ip_cell: i64 = __mind_alloc(8);
        __mind_store_i64(ip_cell, 0 - 1);
        let _ip: EmitState = emit_if_expr_any_lv(es_new(), final_expr, src, params_addr, n_params, ip_nodes, ip_cursor, ip_vidbuf, 0, ip_cell, trail_lv, tk, 0, 0, 0, 0, 0);
        __mind_load_i64(ip_cell)
    } else {
        0 - 1
    };
    if trail_is_if == 1 {
        if ie_probe_dst < 0 {
            __mind_store_i64(ok_cell, 0);
            return s;
        }
    }
    let ret_vid: i64 = if trail_is_if == 1 {
        trail_base + ie_probe_dst
    } else {
        let _rr: i64 = seq_resolve_range(nodes, trail_start, trail_end, vidbuf, trail_base);
        __mind_load_i64(vidbuf + trail_root * 8)
    };
    // body_len = n_params PARAMs + per-segment non-param body instrs + 1 per OP_IF.
    let seg_instrs: i64 = seq_body_len(nodes, plan, nplan, 0);
    let trail_instrs: i64 = if trail_is_if == 1 {
        1
    } else {
        count_descriptor_nonparam_range(nodes, trail_start, trail_end)
    };
    let body_len: i64 = n_params + seg_instrs + trail_instrs + is_trail_ret;
    // Build the RESOLVED seq lv-env (sequence-level lets -> their vids), then emit with
    // a POSITION-AWARE live env: `live` starts empty and grows as emit_stmt_seq walks the
    // plan — each sequence let appends from `seqr` at its source position, each divergent
    // segment appends its escaped bindings. So a segment sees only what is live at its
    // position (no forward-defined lets, prior escapes included) — matching lower.rs SSA.
    let seqr: i64 = __mind_alloc((nlets + 1) * 24);
    let _sr: i64 = seq_env_to_lvenv(env, nlets, vidbuf, seqr, 1, 0);
    let live: i64 = __mind_alloc((nlets + 1024) * 24);
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, ret_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_stmt_seq(s7, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, n_params, 0, live, 0, seqr, 0);
    let s9: EmitState = if trail_is_if == 1 {
        let ie_nodes: i64 = __mind_alloc(256 * 32);
        let ie_cursor: i64 = __mind_alloc(8);
        let ie_vidbuf: i64 = __mind_alloc(256 * 8);
        let ie_cell: i64 = __mind_alloc(8);
        __mind_store_i64(ie_cell, 0 - 1);
        emit_if_expr_any_lv(s8, final_expr, src, params_addr, n_params, ie_nodes, ie_cursor, ie_vidbuf, trail_base, ie_cell, trail_lv, tk, strbuf, offs, ncount, 0, 0)
    } else {
        emit_mic3_tree_body(s8, nodes, trail_end, vidbuf, src, strbuf, offs, ncount, trail_start)
    };
    // Body-terminal `return E`: append the explicit RETURN <ret_vid>.
    let s10: EmitState = if is_trail_ret == 1 {
        emit_mic3_return(s9, 1, ret_vid)
    } else {
        s9
    };
    __mind_store_i64(ok_cell, 1);
    s10
}

// body_len contribution of the statement segments: each let segment's non-param
// descriptor instrs, plus 1 OP_IF instr per if-return block (its cond/then/else
// trees live INSIDE the OP_IF, so they do NOT count as top-level body instrs).
pub fn seq_body_len(nodes: i64, plan: i64, nplan: i64, i: i64) -> i64 {
    if i >= nplan {
        return 0;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        return count_descriptor_nonparam_range(nodes, start, end) + seq_body_len(nodes, plan, nplan, i + 1);
    }
    // (type 11) bare expression statement (no bound name) — same [start,end) range
    // instr-counting as type 0; see flatten_stmt_seq's BARE EXPRESSION STATEMENT arm
    // for why this cannot share type 0's tag.
    if ty == 11 {
        let bstart: i64 = __mind_load_i64(plan + i * 64 + 8);
        let bend: i64 = __mind_load_i64(plan + i * 64 + 16);
        return count_descriptor_nonparam_range(nodes, bstart, bend) + seq_body_len(nodes, plan, nplan, i + 1);
    }
    // (type 10) top-level statement while: OP_WHILE + trailing unit ConstI64 = 2 instrs.
    if ty == 10 {
        return 2 + seq_body_len(nodes, plan, nplan, i + 1);
    }
    1 + seq_body_len(nodes, plan, nplan, i + 1)
}

// ===========================================================================
// FIELD-READ PRE-RESOLVE (call-fold) — rewrite `recv.field` AST nodes into the
// equivalent `__mind_load_i64(field_addr)` Call subtree BEFORE flatten_ast runs.
// flatten_ast/flatten_expr_env/count_nonparam_nodes already lower calls (kind
// 3/4/5) with zero threading, so this is a PURE in-place AST rewrite — no new
// params on flatten_ast and no dedicated shape-case. Mirrors lower.rs's
// FieldAccess resolved arm: idx==0 -> addr is the receiver vid directly; idx>0
// -> ConstI64(idx*8) + BinOp Add(recv, off); then Call("__mind_load_i64",[addr]).
// Fail-closed: an unresolvable field read is left as ast_field (flatten rejects
// it), so the module simply fails to emit — never partial/wrong bytes.
// ===========================================================================

// Match the 15-byte literal "__mind_load_i64" in `src` starting at offset `at`.
pub fn load_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 15 {
        return 1;
    }
    let want: i64 = load_i64_name_byte(j);
    if load_byte(src, at + j) != want {
        return 0;
    }
    load_name_matches_at(src, at + 0, j + 1)
}

// Scan `src[0..len)` for the literal "__mind_load_i64"; store [lo,hi) of the
// first occurrence into the 2-i64 cell and return 1, else 0. Used so the
// pre-fold's synthetic callee leaf carries a REAL source span (whose interned
// bytes equal the oracle's "__mind_load_i64" string-table entry).
pub fn find_load_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 15 > len {
        return 0;
    }
    if load_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 15);
        return 1;
    }
    find_load_name_span(src, len, i + 1, cell)
}

// Build a synthetic int-literal leaf carrying `value` DIRECTLY (no source decimal
// to parse): child0(+24)=value, child1(+32)=1 SENTINEL (flatten reads child0 when
// child1==1; real source int-lits have child1==0). Used for the idx*8 field offset.
pub fn mk_syn_intlit(value: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_int_lit());
    __mind_store_i64(n + 8, 0);
    __mind_store_i64(n + 16, 0);
    __mind_store_i64(n + 24, value);
    __mind_store_i64(n + 32, 1);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

// Resolve `recv.field` (recv an ast_ident param of struct type) to the field
// index. `fn_node` supplies the params; `srt` the struct registry. Returns the
// 0-based field index, or -1 on any failure (unknown param / non-struct type /
// unknown field) — fail-closed.
// Find the declared type node of a `let <name>: TYPE = ..` binding in a statement
// list, recursing through if then/else blocks. Returns the type node, or 0 if no such
// let. Names are SSA-unique in the bootstrap source (s1, s2, ..) so the first match is
// authoritative.
pub fn find_let_ty_in_stmts(stmts_addr: i64, stmts_len: i64, src: i64, recv_lo: i64, recv_hi: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let name: i64 = ast_child0(stmt);
        if span_bytes_equal(src, recv_lo, recv_hi, ast_span_lo(name), ast_span_hi(name)) == 1 {
            return ast_child1(stmt);
        }
    }
    if k == ast_if() {
        let then_blk: i64 = ast_child1(stmt);
        if ast_kind(then_blk) == ast_block() {
            let t: i64 = find_let_ty_in_stmts(ast_child0(then_blk), ast_aux(then_blk), src, recv_lo, recv_hi, 0);
            if t != 0 {
                return t;
            }
        }
        let else_blk: i64 = ast_child2(stmt);
        if else_blk != 0 {
            if ast_kind(else_blk) == ast_block() {
                let e: i64 = find_let_ty_in_stmts(ast_child0(else_blk), ast_aux(else_blk), src, recv_lo, recv_hi, 0);
                if e != 0 {
                    return e;
                }
            }
        }
    }
    find_let_ty_in_stmts(stmts_addr, stmts_len, src, recv_lo, recv_hi, i + 1)
}

// Resolve the TYPE node of a field-access receiver: a param (from the signature) or a
// let-bound local (scanning the body). Returns the type node, or 0 if unresolvable.
pub fn field_recv_ty(fn_node: i64, src: i64, recv_lo: i64, recv_hi: i64) -> i64 {
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let pidx: i64 = resolve_param(params_addr, n_params, src, recv_lo, recv_hi);
    if pidx >= 0 {
        let pnode: i64 = __mind_load_i64(params_addr + pidx * 8);
        return ast_child1(pnode);
    }
    let body: i64 = ast_child2(fn_node);
    if ast_kind(body) != ast_block() {
        return 0;
    }
    find_let_ty_in_stmts(ast_child0(body), ast_aux(body), src, recv_lo, recv_hi, 0)
}

pub fn field_recv_field_idx(fn_node: i64, src: i64, srt: i64, recv_lo: i64, recv_hi: i64, fld_lo: i64, fld_hi: i64) -> i64 {
    let ty: i64 = field_recv_ty(fn_node, src, recv_lo, recv_hi);
    if ty == 0 {
        return 0 - 1;
    }
    let k: i64 = srt_find_by_name(srt, src, ast_span_lo(ty), ast_span_hi(ty), 0);
    if k < 0 {
        return 0 - 1;
    }
    srt_field_index(srt, k, src, fld_lo, fld_hi, 0)
}

// Build the `__mind_load_i64(field_addr)` Call subtree for `recv.field` at field
// index `fidx`. idx==0 -> addr is the receiver node directly; idx>0 -> Add(recv,
// const idx*8). callee = ast_ident leaf spanning the source "__mind_load_i64".
pub fn field_build_load_call(recv_node: i64, fidx: i64, load_lo: i64, load_hi: i64) -> i64 {
    let addr: i64 = if fidx == 0 {
        recv_node
    } else {
        ast_new_binop(0, 0, recv_node, mk_syn_intlit(fidx * 8), op_add())
    };
    let callee: i64 = ast_new_leaf(ast_ident(), load_lo, load_hi);
    let args: i64 = __mind_alloc(8);
    __mind_store_i64(args + 0, addr);
    ast_new_call(0, 0, callee, args, 1)
}

// Recursively rewrite every resolvable `recv.field` node under `node` into the
// load-call subtree, in place. Returns the (possibly new) node to store back.
// ast_field with an ast_ident receiver that resolves -> the load call; otherwise
// the node is returned unchanged (fail-closed). Recurses through paren / binop /
// neg / not / call args, storing rewritten children back into their slots.
// Unwrap nested parentheses around an expression, returning the bare inner node.
pub fn strip_parens(node: i64) -> i64 {
    if ast_kind(node) == ast_paren() {
        return strip_parens(ast_child0(node));
    }
    node
}

pub fn field_rewrite_expr(node: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if node == 0 {
        return 0;
    }
    let k: i64 = ast_kind(node);
    if k == ast_field() {
        let recv: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, recv);
        // Strip parens around the receiver so `(s).a` resolves like `s.a`.
        let bare: i64 = strip_parens(recv);
        if ast_kind(bare) != ast_ident() {
            return node;
        }
        let fidx: i64 = field_recv_field_idx(fn_node, src, srt, ast_span_lo(bare), ast_span_hi(bare), ast_child1(node), ast_child2(node));
        if fidx < 0 {
            // Unresolvable field (e.g. `.a` on a non-struct i64 receiver): the oracle lowers
            // it to a CONST 0 placeholder, not a load. Match that with a synthetic int-lit 0.
            return mk_syn_intlit(0);
        }
        return field_build_load_call(bare, fidx, load_lo, load_hi);
    }
    if k == ast_if() {
        // A value if-EXPR (`if c { s.a } else { s.b }`) in expr position: descend into the
        // cond and both branch blocks so field-reads inside the branches fold too. Mirrors
        // field_rewrite_stmts' ast_if arm.
        let ic: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, ic);
        let then_blk: i64 = ast_child1(node);
        if ast_kind(then_blk) == ast_block() {
            let _t: i64 = field_rewrite_stmts(ast_child0(then_blk), ast_aux(then_blk), 0, src, srt, fn_node, load_lo, load_hi);
        }
        let else_blk: i64 = ast_child2(node);
        if else_blk != 0 {
            if ast_kind(else_blk) == ast_block() {
                let _e: i64 = field_rewrite_stmts(ast_child0(else_blk), ast_aux(else_blk), 0, src, srt, fn_node, load_lo, load_hi);
            }
        }
        return node;
    }
    if k == ast_paren() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_neg() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_not() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_binop() {
        let l: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, l);
        let r: i64 = field_rewrite_expr(ast_child1(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 32, r);
        return node;
    }
    if k == ast_call() {
        let _a: i64 = field_rewrite_args(ast_child1(node), ast_aux(node), 0, src, srt, fn_node, load_lo, load_hi);
        return node;
    }
    if k == ast_struct_lit() {
        // Rewrite field-reads inside each struct-lit field VALUE in place (e.g.
        // `EmitState { buf: s3.buf, .. }`), so the later struct-lit annotation captures
        // the already-folded `__mind_load_i64(..)` value.
        let _sf: i64 = field_rewrite_slit_fields(ast_child1(node), ast_aux(node), 0, src, srt, fn_node, load_lo, load_hi);
        return node;
    }
    node
}

// Rewrite each struct-lit field value (triple slot +16) in place.
pub fn field_rewrite_slit_fields(fields_addr: i64, ntriples: i64, i: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if i >= ntriples {
        return 0;
    }
    let val: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    let nv: i64 = field_rewrite_expr(val, src, srt, fn_node, load_lo, load_hi);
    __mind_store_i64(fields_addr + (i * 3 + 2) * 8, nv);
    field_rewrite_slit_fields(fields_addr, ntriples, i + 1, src, srt, fn_node, load_lo, load_hi)
}

// Rewrite each arg of a call's args vec in place.
pub fn field_rewrite_args(args_addr: i64, args_len: i64, i: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + i * 8);
    let na: i64 = field_rewrite_expr(arg, src, srt, fn_node, load_lo, load_hi);
    __mind_store_i64(args_addr + i * 8, na);
    field_rewrite_args(args_addr, args_len, i + 1, src, srt, fn_node, load_lo, load_hi)
}

// Rewrite each statement of a fn body block in place: let -> rewrite init
// (child2/+40); return -> rewrite value (child0/+24); if -> cond + then/else
// blocks; block -> recurse its stmts; else -> rewrite the stmt expr in place.
pub fn field_rewrite_stmts(stmts_addr: i64, stmts_len: i64, i: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let init: i64 = field_rewrite_expr(ast_child2(stmt), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(stmt + 40, init)
    } else {
        if k == ast_return() {
            let v: i64 = field_rewrite_expr(ast_child0(stmt), src, srt, fn_node, load_lo, load_hi);
            __mind_store_i64(stmt + 24, v)
        } else {
            if k == ast_if() {
                let c: i64 = field_rewrite_expr(ast_child0(stmt), src, srt, fn_node, load_lo, load_hi);
                __mind_store_i64(stmt + 24, c);
                let then_blk: i64 = ast_child1(stmt);
                if ast_kind(then_blk) == ast_block() {
                    let _t: i64 = field_rewrite_stmts(ast_child0(then_blk), ast_aux(then_blk), 0, src, srt, fn_node, load_lo, load_hi);
                }
                let else_blk: i64 = ast_child2(stmt);
                if else_blk != 0 {
                    if ast_kind(else_blk) == ast_block() {
                        let _e: i64 = field_rewrite_stmts(ast_child0(else_blk), ast_aux(else_blk), 0, src, srt, fn_node, load_lo, load_hi);
                    }
                }
            } else {
                if k == ast_while() {
                    // while: fold field-reads in the COND (child0/+24) + recurse the BODY block.
                    let wc: i64 = field_rewrite_expr(ast_child0(stmt), src, srt, fn_node, load_lo, load_hi);
                    __mind_store_i64(stmt + 24, wc);
                    let wbody: i64 = ast_child1(stmt);
                    if ast_kind(wbody) == ast_block() {
                        let _wb: i64 = field_rewrite_stmts(ast_child0(wbody), ast_aux(wbody), 0, src, srt, fn_node, load_lo, load_hi);
                    }
                } else {
                    if k == ast_assign() {
                        // assign: fold field-reads in the RHS value (child2/+40).
                        let av: i64 = field_rewrite_expr(ast_child2(stmt), src, srt, fn_node, load_lo, load_hi);
                        __mind_store_i64(stmt + 40, av)
                    } else {
                        let e: i64 = field_rewrite_expr(stmt, src, srt, fn_node, load_lo, load_hi);
                        __mind_store_i64(stmts_addr + i * 8, e)
                    }
                }
            }
        }
    }
    field_rewrite_stmts(stmts_addr, stmts_len, i + 1, src, srt, fn_node, load_lo, load_hi)
}

// Pre-fold one fn's body. Guard: at least one struct in the registry AND the
// literal "__mind_load_i64" present in source (else no fold can resolve and the
// callee span would be invalid). Rewrites the body block's statements in place.
pub fn field_prefold_body(src: i64, src_len: i64, fn_node: i64, srt: i64) -> i64 {
    if srt_count(srt) < 1 {
        return 0;
    }
    let cell: i64 = __mind_alloc(16);
    if find_load_name_span(src, src_len, 0, cell) == 0 {
        return 0;
    }
    let load_lo: i64 = __mind_load_i64(cell + 0);
    let load_hi: i64 = __mind_load_i64(cell + 8);
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    field_rewrite_stmts(stmts_addr, stmts_len, 0, src, srt, fn_node, load_lo, load_hi)
}

// Iterate every top-level fn_def, pre-folding its body. Other items are skipped.
pub fn field_prefold_module(src: i64, src_len: i64, items_addr: i64, items_len: i64, i: i64, srt: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let _r: i64 = field_prefold_body(src, src_len, item, srt);
    }
    field_prefold_module(src, src_len, items_addr, items_len, i + 1, srt)
}

// ===========================================================================
// STRUCT-LIT CONSTRUCTION DESUGAR — pre-resolve `T { a: x, b: y }` into the
// alloc+stores+ret let-chain the oracle lowers it to (src/eval/lower.rs StructLit
// arm; see the intern_*_literal comment block): `let __sl = __mind_alloc(8 *
// nfields); __mind_store_i64(__sl (+ idx*8), val) per field in DECLARED order; __sl`.
// Run in the prefold pass BEFORE build_module_strtab so __mind_alloc / __mind_store_i64
// intern in body order, and the resulting let-chain emits via the proven case (f).
// Synthetic let names reuse the `__mind_alloc` (ptr) / `__mind_store_i64` (throwaway)
// source spans — letenv resolves by source-byte span, and those literals are present
// in the module (they are the call callees). NO threading; flatten_ast unchanged.
// ===========================================================================

// "__mind_alloc" (12 bytes) per-index byte source.
pub fn alloc_name_byte(j: i64) -> i64 {
    if j == 0 {
        return 95;
    }
    if j == 1 {
        return 95;
    }
    if j == 2 {
        return 109;
    }
    if j == 3 {
        return 105;
    }
    if j == 4 {
        return 110;
    }
    if j == 5 {
        return 100;
    }
    if j == 6 {
        return 95;
    }
    if j == 7 {
        return 97;
    }
    if j == 8 {
        return 108;
    }
    if j == 9 {
        return 108;
    }
    if j == 10 {
        return 111;
    }
    99
}

pub fn alloc_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 12 {
        return 1;
    }
    if load_byte(src, at + j) != alloc_name_byte(j) {
        return 0;
    }
    alloc_name_matches_at(src, at, j + 1)
}

pub fn find_alloc_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 12 > len {
        return 0;
    }
    if alloc_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 12);
        return 1;
    }
    find_alloc_name_span(src, len, i + 1, cell)
}

// "__mind_store_i64" (16 bytes) per-index byte source.
pub fn store_name_byte(j: i64) -> i64 {
    if j == 0 {
        return 95;
    }
    if j == 1 {
        return 95;
    }
    if j == 2 {
        return 109;
    }
    if j == 3 {
        return 105;
    }
    if j == 4 {
        return 110;
    }
    if j == 5 {
        return 100;
    }
    if j == 6 {
        return 95;
    }
    if j == 7 {
        return 115;
    }
    if j == 8 {
        return 116;
    }
    if j == 9 {
        return 111;
    }
    if j == 10 {
        return 114;
    }
    if j == 11 {
        return 101;
    }
    if j == 12 {
        return 95;
    }
    if j == 13 {
        return 105;
    }
    if j == 14 {
        return 54;
    }
    52
}

pub fn store_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 16 {
        return 1;
    }
    if load_byte(src, at + j) != store_name_byte(j) {
        return 0;
    }
    store_name_matches_at(src, at, j + 1)
}

pub fn find_store_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 16 > len {
        return 0;
    }
    if store_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 16);
        return 1;
    }
    find_store_name_span(src, len, i + 1, cell)
}

// Byte-copy src[0..n) into dst.
pub fn nfn_copy_src_bytes(dst: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i8(dst + i, load_byte(src, i));
    nfn_copy_src_bytes(dst, src, n, i + 1)
}

// Write the 12-byte `__mind_alloc` literal at dst[0..12) using alloc_name_byte.
pub fn nfn_fill_alloc_name(dst: i64, j: i64) -> i64 {
    if j >= 12 {
        return 12;
    }
    __mind_store_i8(dst + j, alloc_name_byte(j));
    nfn_fill_alloc_name(dst, j + 1)
}

// Write the 16-byte `__mind_store_i64` literal at dst[0..16) using store_name_byte.
pub fn nfn_fill_store_name(dst: i64, j: i64) -> i64 {
    if j >= 16 {
        return 16;
    }
    __mind_store_i8(dst + j, store_name_byte(j));
    nfn_fill_store_name(dst, j + 1)
}

// Write the 15-byte `__mind_load_i64` literal at dst[0..15) using load_i64_name_byte.
pub fn nfn_fill_load_name(dst: i64, j: i64) -> i64 {
    if j >= 15 {
        return 15;
    }
    __mind_store_i8(dst + j, load_i64_name_byte(j));
    nfn_fill_load_name(dst, j + 1)
}

// Build a copy of `src[0..src_len)` with the intrinsic literals appended: `__mind_alloc`
// (12B) at [src_len, src_len+12), `__mind_store_i64` (16B) at [+12, +28), and
// `__mind_load_i64` (15B) at [+28, +43). The lexer scans only [0, src_len), so the tail is
// invisible to parsing; the struct-lit desugar/annotation and the field-read prefold intern
// their synthetic alloc/store/load names from those appended spans. Only built when the
// source itself lacks the literals (so main.mind never uses it).
pub fn build_src_intrinsics(src_addr: i64, src_len: i64) -> i64 {
    let buf: i64 = __mind_alloc(src_len + 48);
    let _c: i64 = nfn_copy_src_bytes(buf, src_addr, src_len, 0);
    let _a: i64 = nfn_fill_alloc_name(buf + src_len, 0);
    let _s: i64 = nfn_fill_store_name(buf + src_len + 12, 0);
    let _l: i64 = nfn_fill_load_name(buf + src_len + 28, 0);
    buf
}

// Value node for CANONICAL field `j` of struct `k` (match its declared name span
// against the source-order triples). Returns the value AST node, or 0 if absent.
pub fn slit_canon_value(fields_addr: i64, ntriples: i64, src: i64, srt: i64, k: i64, j: i64) -> i64 {
    let clo: i64 = srt_field_lo(srt, k, j);
    let chi: i64 = srt_field_hi(srt, k, j);
    slit_value_for(fields_addr, ntriples, src, clo, chi, 0)
}

// Build `let __sN = __mind_store_i64(addr, val)` for canonical field index `j`:
// addr = ptr ref (j==0) or Add(ptr, idx*8). The let name + ptr ref reuse the
// `__mind_alloc` span (alo/ahi); the store callee + let name reuse `__mind_store_i64`.
// Bind the field VALUE to a let BEFORE its store, so the value is emitted ahead of the
// store address — matching the oracle's StructLit lowering (eval field value, THEN compute
// the address, THEN store). The let's name span = the value node's own span (unique per
// field, never collides with a sequence let), and the store references it by that span. A
// plain `__mind_store_i64(addr, val)` call would otherwise flatten the addr arg first.
pub fn slit_build_value_let(val: i64) -> i64 {
    let name: i64 = ast_new_leaf(ast_ident(), ast_span_lo(val), ast_span_hi(val));
    ast_new_let(0, 0, name, 0, val)
}
pub fn slit_build_store_let(alo: i64, ahi: i64, slo: i64, shi: i64, j: i64, vref: i64) -> i64 {
    let sl_ref: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let addr: i64 = if j == 0 {
        sl_ref
    } else {
        ast_new_binop(0, 0, sl_ref, mk_syn_intlit(j * 8), op_add())
    };
    let callee: i64 = ast_new_leaf(ast_ident(), slo, shi);
    let args: i64 = __mind_alloc(16);
    __mind_store_i64(args + 0, addr);
    __mind_store_i64(args + 8, vref);
    let call: i64 = ast_new_call(0, 0, callee, args, 2);
    let name: i64 = ast_new_leaf(ast_ident(), slo, shi);
    ast_new_let(0, 0, name, 0, call)
}

// Fill new_stmts[1 .. 1+nfields] with per-canonical-field store-lets. Returns 1, or
// 0 if any canonical field is missing from the literal (fail-closed).
pub fn slit_fill_stores(new_stmts: i64, fields_addr: i64, ntriples: i64, src: i64, srt: i64, k: i64, nfields: i64, alo: i64, ahi: i64, slo: i64, shi: i64, j: i64) -> i64 {
    if j >= nfields {
        return 1;
    }
    let val: i64 = slit_canon_value(fields_addr, ntriples, src, srt, k, j);
    if val == 0 {
        return 0;
    }
    let vlet: i64 = slit_build_value_let(val);
    let vref: i64 = ast_new_leaf(ast_ident(), ast_span_lo(val), ast_span_hi(val));
    let slet: i64 = slit_build_store_let(alo, ahi, slo, shi, j, vref);
    __mind_store_i64(new_stmts + (1 + 2 * j) * 8, vlet);
    __mind_store_i64(new_stmts + (1 + 2 * j + 1) * 8, slet);
    slit_fill_stores(new_stmts, fields_addr, ntriples, src, srt, k, nfields, alo, ahi, slo, shi, j + 1)
}

// Desugar a single-stmt struct-lit-bodied fn body in place into the let-chain.
// Returns 1 if rewritten, 0 if not applicable (body left intact, fails closed later).
pub fn slit_desugar_body(fn_node: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0;
    }
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    if ast_kind(snode) != ast_struct_lit() {
        return 0;
    }
    let ty_lo: i64 = ast_child0(snode);
    let ty_hi: i64 = ast_child2(snode);
    let k: i64 = srt_find_by_name(srt, src, ty_lo, ty_hi, 0);
    if k < 0 {
        return 0;
    }
    let nfields: i64 = srt_field_count(srt, k);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    if ntriples != nfields {
        return 0;
    }
    let new_len: i64 = 2 * nfields + 2;
    let new_stmts: i64 = __mind_alloc(new_len * 8);
    // (0) `let __sl = __mind_alloc(8 * nfields)`.
    let size: i64 = ast_new_binop(0, 0, mk_syn_intlit(8), mk_syn_intlit(nfields), op_mul());
    let acallee: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let aargs: i64 = __mind_alloc(8);
    __mind_store_i64(aargs + 0, size);
    let acall: i64 = ast_new_call(0, 0, acallee, aargs, 1);
    let aname: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let alet: i64 = ast_new_let(0, 0, aname, 0, acall);
    __mind_store_i64(new_stmts + 0, alet);
    // (1..nfields) per-field stores in canonical order.
    let okf: i64 = slit_fill_stores(new_stmts, fields_addr, ntriples, src, srt, k, nfields, alo, ahi, slo, shi, 0);
    if okf == 0 {
        return 0;
    }
    // (last) trailing ptr ref -> ret vid = alloc vid.
    let tref: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    __mind_store_i64(new_stmts + (2 * nfields + 1) * 8, tref);
    // Replace the body block's statements (child0 = stmts_addr, aux = stmts_len).
    __mind_store_i64(body + 24, new_stmts);
    __mind_store_i64(body + 48, new_len);
    1
}

// If `stmt` is a desugarable struct-lit STATEMENT (`let x = T{..}`, `return T{..}`, or a
// bare `T{..}` trailing value), return the struct-lit AST node; else 0.
pub fn slit_stmt_snode(stmt: i64) -> i64 {
    let k: i64 = ast_kind(stmt);
    if k == ast_struct_lit() {
        return stmt;
    }
    if k == ast_let() {
        if ast_kind(ast_child2(stmt)) == ast_struct_lit() {
            return ast_child2(stmt);
        }
        return 0;
    }
    if k == ast_return() {
        if ast_kind(ast_child0(stmt)) == ast_struct_lit() {
            return ast_child0(stmt);
        }
        return 0;
    }
    0
}

// Number of output statements a top-level statement expands to: a desugarable struct-lit
// (resolvable type, all fields present) -> nfields + 2 (alloc-let + stores + final), else 1.
pub fn slit_stmt_outn(stmt: i64, src: i64, srt: i64) -> i64 {
    let snode: i64 = slit_stmt_snode(stmt);
    if snode != 0 {
        let k: i64 = srt_find_by_name(srt, src, ast_child0(snode), ast_child2(snode), 0);
        if k < 0 {
            return 1;
        }
        let nfields: i64 = srt_field_count(srt, k);
        if ast_aux(snode) != nfields {
            return 1;
        }
        return 2 * nfields + 2;
    }
    // HOIST: a struct-lit passed as a call-arg expands to [alloc + stores] (2*nf+1) plus
    // the using statement (1), with the struct-lit replaced by an __mind_alloc ident.
    let hnode: i64 = slit_stmt_hoist_snode(stmt);
    if hnode != 0 {
        let hk: i64 = srt_find_by_name(srt, src, ast_child0(hnode), ast_child2(hnode), 0);
        if hk < 0 {
            return 1;
        }
        let hnf: i64 = srt_field_count(srt, hk);
        if ast_aux(hnode) != hnf {
            return 1;
        }
        return 2 * hnf + 2;
    }
    1
}

// Sum of expanded lengths over a statement list (used to size the new array).
pub fn slit_seq_len(stmts_addr: i64, stmts_len: i64, src: i64, srt: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    slit_stmt_outn(stmt, src, srt) + slit_seq_len(stmts_addr, stmts_len, src, srt, i + 1)
}

// Write the per-field store-lets for one struct-lit into new_stmts[base..base+nfields).
pub fn slit_fill_stores_at(new_stmts: i64, base: i64, fields_addr: i64, ntriples: i64, src: i64, srt: i64, k: i64, nfields: i64, alo: i64, ahi: i64, slo: i64, shi: i64, j: i64) -> i64 {
    if j >= nfields {
        return 1;
    }
    let val: i64 = slit_canon_value(fields_addr, ntriples, src, srt, k, j);
    if val == 0 {
        return 0;
    }
    let vlet: i64 = slit_build_value_let(val);
    let vref: i64 = ast_new_leaf(ast_ident(), ast_span_lo(val), ast_span_hi(val));
    let slet: i64 = slit_build_store_let(alo, ahi, slo, shi, j, vref);
    __mind_store_i64(new_stmts + (base + 2 * j) * 8, vlet);
    __mind_store_i64(new_stmts + (base + 2 * j + 1) * 8, slet);
    slit_fill_stores_at(new_stmts, base, fields_addr, ntriples, src, srt, k, nfields, alo, ahi, slo, shi, j + 1)
}

// Expand one struct-lit statement into [alloc-let, stores, final] at new_stmts[out..].
// final = `let x = __sl` (let-init) / `return __sl` (return) / bare `__sl` (trailing).
// __sl (the alloc handle) is named with the __mind_alloc span; at a function's TOP LEVEL
// (no enclosing if) these synthetic lets bind no merge, matching the oracle's anonymous
// alloc/store SSA values byte-for-byte.
pub fn slit_emit_ctor(new_stmts: i64, out: i64, orig_stmt: i64, snode: i64, src: i64, srt: i64, k: i64, nfields: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let size: i64 = ast_new_binop(0, 0, mk_syn_intlit(8), mk_syn_intlit(nfields), op_mul());
    let acallee: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let aargs: i64 = __mind_alloc(8);
    __mind_store_i64(aargs + 0, size);
    let acall: i64 = ast_new_call(0, 0, acallee, aargs, 1);
    let aname: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let alet: i64 = ast_new_let(0, 0, aname, 0, acall);
    __mind_store_i64(new_stmts + out * 8, alet);
    let _f: i64 = slit_fill_stores_at(new_stmts, out + 1, ast_child1(snode), ast_aux(snode), src, srt, k, nfields, alo, ahi, slo, shi, 0);
    let sl_ref: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let kind: i64 = ast_kind(orig_stmt);
    let final: i64 = if kind == ast_let() {
        // Preserve the original let's TYPE annotation so a later field-read
        // prefold (`s.a` where `let s: S = T{..}`) can resolve the receiver's
        // struct type. The init becomes the alloc handle ref; type is unchanged.
        ast_new_let(0, 0, ast_child0(orig_stmt), ast_child1(orig_stmt), sl_ref)
    } else {
        if kind == ast_return() {
            ast_new_return(0, 0, sl_ref)
        } else {
            sl_ref
        }
    };
    __mind_store_i64(new_stmts + (out + 2 * nfields + 1) * 8, final);
    1
}

// The expression that carries a statement's value (let init / return value / trailing).
pub fn slit_hoist_expr_of(stmt: i64) -> i64 {
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        return ast_child2(stmt);
    }
    if k == ast_return() {
        return ast_child0(stmt);
    }
    stmt
}

// Find the FIRST struct-lit among a call's args (non-mutating). Returns the node or 0.
pub fn slit_find_slit_arg(args: i64, nargs: i64, i: i64) -> i64 {
    if i >= nargs {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args + i * 8);
    if ast_kind(arg) == ast_struct_lit() {
        return arg;
    }
    slit_find_slit_arg(args, nargs, i + 1)
}

// Detect (non-mutating) a HOISTABLE nested struct-lit: a `T{..}` passed as a direct call
// argument in the statement's value expr (`g(S{..})`, `let x = mk(S{..})`, `return f(S{..})`).
// Returns the struct-lit node or 0. (A struct-lit that is itself the value expr is the DIRECT
// case handled by slit_stmt_snode.)
pub fn slit_stmt_hoist_snode(stmt: i64) -> i64 {
    let expr: i64 = slit_hoist_expr_of(stmt);
    if ast_kind(expr) != ast_call() {
        return 0;
    }
    slit_find_slit_arg(ast_child1(expr), ast_aux(expr), 0)
}

// Replace the FIRST struct-lit call-arg with a fresh `__mind_alloc` ident leaf (so the call
// resolves the hoisted alloc handle via letenv_lookup last-match); return the struct-lit.
pub fn slit_hoist_replace_arg(args: i64, nargs: i64, i: i64, alo: i64, ahi: i64) -> i64 {
    if i >= nargs {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args + i * 8);
    if ast_kind(arg) == ast_struct_lit() {
        __mind_store_i64(args + i * 8, ast_new_leaf(ast_ident(), alo, ahi));
        return arg;
    }
    slit_hoist_replace_arg(args, nargs, i + 1, alo, ahi)
}

// Mutate: hoist the statement's nested struct-lit call-arg, returning the struct-lit node.
pub fn slit_hoist_replace(stmt: i64, alo: i64, ahi: i64) -> i64 {
    let expr: i64 = slit_hoist_expr_of(stmt);
    if ast_kind(expr) != ast_call() {
        return 0;
    }
    slit_hoist_replace_arg(ast_child1(expr), ast_aux(expr), 0, alo, ahi)
}

// Emit ONLY the alloc-let + per-field value/store-lets for a hoisted struct-lit (NO final
// statement — the using statement, with the struct-lit replaced by an __mind_alloc ident,
// follows). Returns the count emitted (2*nfields + 1). The __mind_alloc-named handle is
// resolved by the following statement via letenv_lookup last-match, byte-exact vs the
// oracle's anonymous alloc/store SSA values.
pub fn slit_emit_ctor_hoist(new_stmts: i64, out: i64, snode: i64, src: i64, srt: i64, k: i64, nfields: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let size: i64 = ast_new_binop(0, 0, mk_syn_intlit(8), mk_syn_intlit(nfields), op_mul());
    let acallee: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let aargs: i64 = __mind_alloc(8);
    __mind_store_i64(aargs + 0, size);
    let acall: i64 = ast_new_call(0, 0, acallee, aargs, 1);
    let aname: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let alet: i64 = ast_new_let(0, 0, aname, 0, acall);
    __mind_store_i64(new_stmts + out * 8, alet);
    let _f: i64 = slit_fill_stores_at(new_stmts, out + 1, ast_child1(snode), ast_aux(snode), src, srt, k, nfields, alo, ahi, slo, shi, 0);
    2 * nfields + 1
}

// Fill the new (expanded) statement array, copying non-struct-lit statements and
// expanding struct-lit statements via slit_emit_ctor. `out_cell` threads the running
// output index.
pub fn slit_seq_fill(new_stmts: i64, out_cell: i64, stmts_addr: i64, stmts_len: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let out: i64 = __mind_load_i64(out_cell);
    let outn: i64 = slit_stmt_outn(stmt, src, srt);
    if outn == 1 {
        __mind_store_i64(new_stmts + out * 8, stmt);
        __mind_store_i64(out_cell, out + 1)
    } else {
        let snode: i64 = slit_stmt_snode(stmt);
        if snode != 0 {
            let k: i64 = srt_find_by_name(srt, src, ast_child0(snode), ast_child2(snode), 0);
            let nfields: i64 = srt_field_count(srt, k);
            let _e: i64 = slit_emit_ctor(new_stmts, out, stmt, snode, src, srt, k, nfields, alo, ahi, slo, shi);
            __mind_store_i64(out_cell, out + 2 * nfields + 2)
        } else {
            // HOIST: mutate the statement (struct-lit arg -> __mind_alloc ident), emit the
            // alloc+stores, then the rewritten statement.
            let hnode: i64 = slit_hoist_replace(stmt, alo, ahi);
            let hk: i64 = srt_find_by_name(srt, src, ast_child0(hnode), ast_child2(hnode), 0);
            let hnf: i64 = srt_field_count(srt, hk);
            let hc: i64 = slit_emit_ctor_hoist(new_stmts, out, hnode, src, srt, hk, hnf, alo, ahi, slo, shi);
            __mind_store_i64(new_stmts + (out + hc) * 8, stmt);
            __mind_store_i64(out_cell, out + hc + 1)
        }
    }
    slit_seq_fill(new_stmts, out_cell, stmts_addr, stmts_len, src, srt, alo, ahi, slo, shi, i + 1)
}

// Desugar struct-lit STATEMENTS in a function's TOP-LEVEL body block (a let-init,
// return, or trailing value among other statements). Does NOT recurse into if-blocks —
// a struct-lit inside an if-branch needs expression-level (anonymous-value) lowering,
// since a named let there would wrongly escape as a merge binding. Returns 1 if it
// rewrote the body, else 0.
pub fn slit_desugar_body_seq(fn_node: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    if ast_kind(body) != ast_block() {
        return 0;
    }
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    let new_len: i64 = slit_seq_len(stmts_addr, stmts_len, src, srt, 0);
    if new_len == stmts_len {
        return 0;
    }
    let new_stmts: i64 = __mind_alloc(new_len * 8);
    let out_cell: i64 = __mind_alloc(8);
    __mind_store_i64(out_cell, 0);
    let _fl: i64 = slit_seq_fill(new_stmts, out_cell, stmts_addr, stmts_len, src, srt, alo, ahi, slo, shi, 0);
    __mind_store_i64(body + 24, new_stmts);
    __mind_store_i64(body + 48, new_len);
    1
}

// Module pass: desugar struct-lit ctors in every top-level fn_def.
pub fn slit_desugar_module(src: i64, src_len: i64, items_addr: i64, items_len: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let handled: i64 = slit_desugar_body(item, src, srt, alo, ahi, slo, shi);
        if handled == 0 {
            let _r2: i64 = slit_desugar_body_seq(item, src, srt, alo, ahi, slo, shi);
        }
    }
    slit_desugar_module(src, src_len, items_addr, items_len, srt, alo, ahi, slo, shi, i + 1)
}

// STRUCT-LIT ANNOTATION PREFOLD. For every struct-lit EXPRESSION that survived the
// statement-level desugar (i.e. the ones inside if-branches), store at node+56 a
// resolved [alo, ahi, slo, shi, def-ordered-value-nodes] record, so flatten_struct_lit_lv
// can lower it into the alloc/store descriptor subtree with NO srt/span threading. Runs
// AFTER field_prefold (so field-read field values are already folded) and BEFORE the
// strtab pass + emit. Unresolvable struct-lits keep node+56 = 0 (flatten fails closed).
pub fn slit_set_annotation(node: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let k: i64 = srt_find_by_name(srt, src, ast_child0(node), ast_child2(node), 0);
    if k < 0 {
        return 0;
    }
    let nf: i64 = srt_field_count(srt, k);
    if ast_aux(node) != nf {
        return 0;
    }
    let fields: i64 = ast_child1(node);
    let values: i64 = __mind_alloc(nf * 8 + 8);
    let ok: i64 = slit_fill_defvalues(values, fields, nf, src, srt, k, nf, 0);
    if ok == 0 {
        return 0;
    }
    let ann: i64 = __mind_alloc(40);
    __mind_store_i64(ann + 0, alo);
    __mind_store_i64(ann + 8, ahi);
    __mind_store_i64(ann + 16, slo);
    __mind_store_i64(ann + 24, shi);
    __mind_store_i64(ann + 32, values);
    __mind_store_i64(node + 56, ann);
    1
}
pub fn slit_fill_defvalues(values: i64, fields: i64, ntriples: i64, src: i64, srt: i64, k: i64, nf: i64, j: i64) -> i64 {
    if j >= nf {
        return 1;
    }
    let val: i64 = slit_value_for(fields, ntriples, src, srt_field_lo(srt, k, j), srt_field_hi(srt, k, j), 0);
    if val == 0 {
        return 0;
    }
    __mind_store_i64(values + j * 8, val);
    slit_fill_defvalues(values, fields, ntriples, src, srt, k, nf, j + 1)
}
pub fn slit_annotate_expr(node: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    if node == 0 {
        return 0;
    }
    let k: i64 = ast_kind(node);
    if k == ast_struct_lit() {
        let _fv: i64 = slit_annotate_fieldvals(ast_child1(node), ast_aux(node), 0, src, srt, alo, ahi, slo, shi);
        let _sa: i64 = slit_set_annotation(node, src, srt, alo, ahi, slo, shi);
        return 0;
    }
    if k == ast_paren() {
        return slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
    }
    if k == ast_neg() {
        return slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
    }
    if k == ast_not() {
        return slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
    }
    if k == ast_binop() {
        let _l: i64 = slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
        return slit_annotate_expr(ast_child1(node), src, srt, alo, ahi, slo, shi);
    }
    if k == ast_field() {
        return slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
    }
    if k == ast_call() {
        return slit_annotate_args(ast_child1(node), ast_aux(node), 0, src, srt, alo, ahi, slo, shi);
    }
    if k == ast_if() {
        let _c: i64 = slit_annotate_expr(ast_child0(node), src, srt, alo, ahi, slo, shi);
        let tb: i64 = ast_child1(node);
        if ast_kind(tb) == ast_block() {
            let _t: i64 = slit_annotate_stmts(ast_child0(tb), ast_aux(tb), 0, src, srt, alo, ahi, slo, shi);
        }
        let eb: i64 = ast_child2(node);
        if eb != 0 {
            if ast_kind(eb) == ast_block() {
                let _e: i64 = slit_annotate_stmts(ast_child0(eb), ast_aux(eb), 0, src, srt, alo, ahi, slo, shi);
            }
        }
        return 0;
    }
    0
}
pub fn slit_annotate_args(args_addr: i64, args_len: i64, i: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let _a: i64 = slit_annotate_expr(__mind_load_i64(args_addr + i * 8), src, srt, alo, ahi, slo, shi);
    slit_annotate_args(args_addr, args_len, i + 1, src, srt, alo, ahi, slo, shi)
}
pub fn slit_annotate_fieldvals(fields: i64, ntriples: i64, i: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    if i >= ntriples {
        return 0;
    }
    let _v: i64 = slit_annotate_expr(__mind_load_i64(fields + (i * 3 + 2) * 8), src, srt, alo, ahi, slo, shi);
    slit_annotate_fieldvals(fields, ntriples, i + 1, src, srt, alo, ahi, slo, shi)
}
pub fn slit_annotate_stmts(stmts_addr: i64, stmts_len: i64, i: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let _i: i64 = slit_annotate_expr(ast_child2(stmt), src, srt, alo, ahi, slo, shi);
    } else {
        if k == ast_return() {
            let _r: i64 = slit_annotate_expr(ast_child0(stmt), src, srt, alo, ahi, slo, shi);
        } else {
            if k == ast_if() {
                let _x: i64 = slit_annotate_expr(stmt, src, srt, alo, ahi, slo, shi);
            } else {
                let _e: i64 = slit_annotate_expr(stmt, src, srt, alo, ahi, slo, shi);
            }
        }
    }
    slit_annotate_stmts(stmts_addr, stmts_len, i + 1, src, srt, alo, ahi, slo, shi)
}
pub fn slit_annotate_module(src: i64, items_addr: i64, items_len: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let body: i64 = ast_child2(item);
        if ast_kind(body) == ast_block() {
            let _b: i64 = slit_annotate_stmts(ast_child0(body), ast_aux(body), 0, src, srt, alo, ahi, slo, shi);
        }
    }
    slit_annotate_module(src, items_addr, items_len, srt, alo, ahi, slo, shi, i + 1)
}

// Recursively detect whether an AST subtree contains a function CALL (or a struct
// literal, which lowers to __mind_alloc/__mind_store_i64 calls). The narrow fast-
// path shapes (g)/(g2) in emit_mic3_module_fndef emit their cond/ret/trail tree
// bodies with a NULL strtab (ncount=0), so any call's name_idx would resolve to -1
// (emitted as the 1-byte 127). They are byte-exact ONLY for pure param/const/binop
// bodies; when a call is present the body must defer to the general sequence path
// (h), which threads the real strtab. Walks the expression kinds flatten_branch /
// flatten_ast accept plus the if/return/let/block statement kinds reached inside a
// then-block. Unknown leaf kinds (ident/int_lit) carry no call -> 0.
pub fn node_has_call(node: i64) -> i64 {
    if node == 0 {
        return 0;
    }
    let k: i64 = ast_kind(node);
    if k == ast_call() {
        return 1;
    }
    if k == ast_struct_lit() {
        return 1;
    }
    if k == ast_paren() {
        return node_has_call(ast_child0(node));
    }
    if k == ast_binop() {
        if node_has_call(ast_child0(node)) == 1 {
            return 1;
        }
        return node_has_call(ast_child1(node));
    }
    if k == ast_if() {
        if node_has_call(ast_child0(node)) == 1 {
            return 1;
        }
        if node_has_call(ast_child1(node)) == 1 {
            return 1;
        }
        return node_has_call(ast_child2(node));
    }
    if k == ast_return() {
        return node_has_call(ast_child0(node));
    }
    if k == ast_let() {
        return node_has_call(ast_child2(node));
    }
    if k == ast_block() {
        return block_has_call(ast_child0(node), ast_aux(node), 0);
    }
    if k == ast_field() {
        return node_has_call(ast_child0(node));
    }
    0
}
pub fn block_has_call(stmts_addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    if node_has_call(__mind_load_i64(stmts_addr + i * 8)) == 1 {
        return 1;
    }
    block_has_call(stmts_addr, n, i + 1)
}

// Emit the FN_DEF (body) for one function, dispatching on its proven shape. Does
// NOT emit the module-level scaffold (the caller appends emit_mic3_scaffold(k)).
// Writes a 1 into ok_cell on a matched shape, 0 (fail-closed) otherwise; on a
// miss the returned state is unspecified (the caller discards the whole module).
pub fn emit_mic3_module_fndef(s: EmitState, src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let nidx: i64 = fn_name_idx(src, fn_node, strbuf, offs, ncount);
    if nidx < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    // (a) zero-arg const-return.
    let cv: i64 = const_fn_value(src, fn_node);
    if cv >= 0 {
        __mind_store_i64(ok_cell, 1);
        return emit_mic3_fndef_const(s, nidx, cv);
    }
    // (b) 2-param arith (direct `pa OP pb`, or `let t = pa OP pb; t`).
    let ob_direct: i64 = arith_fn_opbyte(src, fn_node);
    let ob_let: i64 = let_arith_fn_opbyte(src, fn_node);
    let ob: i64 = if ob_direct >= 0 {
        ob_direct
    } else {
        ob_let
    };
    if ob >= 0 {
        let pscratch: i64 = __mind_alloc(16);
        let pok: i64 = arith_param_str_idxs(src, fn_node, strbuf, offs, ncount, pscratch);
        if pok == 1 {
            __mind_store_i64(ok_cell, 1);
            let p0i: i64 = __mind_load_i64(pscratch + 0);
            let p1i: i64 = __mind_load_i64(pscratch + 8);
            return emit_mic3_fndef_arith(s, nidx, p0i, p1i, ob);
        }
    }
    // (c) zero-arg CALL with two int-literal args.
    let ascratch: i64 = __mind_alloc(16);
    let aok: i64 = call_fn_args2(src, fn_node, ascratch);
    if aok == 1 {
        let cidx: i64 = call_fn_callee_idx(src, fn_node, strbuf, offs, ncount);
        if cidx >= 0 {
            __mind_store_i64(ok_cell, 1);
            let cva: i64 = __mind_load_i64(ascratch + 0);
            let cvb: i64 = __mind_load_i64(ascratch + 8);
            return emit_mic3_fndef_call(s, nidx, cidx, cva, cvb);
        }
    }
    // Beyond the three narrow shapes: an arbitrary expression-tree body OR a single
    // if-expression body, both wired to the already-proven per-fn emitters. Both
    // need the module-wide param string indices and per-fn tree scratch.
    let n_params: i64 = ast_aux(fn_node) / 2;
    let pstr: i64 = __mind_alloc(n_params * 8 + 8);
    let pres: i64 = module_param_str_idxs(src, fn_node, strbuf, offs, ncount, pstr, 0);
    if pres == 1 {
        let body: i64 = ast_child2(fn_node);
        let stmts_addr: i64 = ast_child0(body);
        let stmts_len: i64 = ast_aux(body);
        if stmts_len == 1 {
            let expr: i64 = __mind_load_i64(stmts_addr + 0);
            let nodes: i64 = __mind_alloc(256 * 32);
            let cursor: i64 = __mind_alloc(8);
            let vidbuf: i64 = __mind_alloc(256 * 8);
            // (e) single if-expression value: if cond { then } else { else }, each
            // branch a single param/const/binop expression (empty merges/bindings).
            if ast_kind(expr) == ast_if() {
                let else_blk: i64 = ast_child2(expr);
                if else_blk != 0 {
                    let cond_expr: i64 = ast_child0(expr);
                    let then_expr: i64 = branch_single_expr(ast_child1(expr));
                    let else_expr: i64 = branch_single_expr(else_blk);
                    // (e2) BOTH branches diverge: `if C { return A } else { return B }` -> ONE
                    // OP_IF (synth + value + Return per branch, phantom merge dst = the ret vid).
                    // No-call branches only (narrow emitter has no strtab); else fall through.
                    if then_expr >= 0 {
                        if else_expr >= 0 {
                            if ast_kind(then_expr) == ast_return() {
                                if ast_kind(else_expr) == ast_return() {
                                    let then_rv: i64 = ast_child0(then_expr);
                                    let else_rv: i64 = ast_child0(else_expr);
                                    let br_call: i64 = node_has_call(cond_expr) + node_has_call(then_rv) + node_has_call(else_rv);
                                    if br_call == 0 {
                                        let sbr: EmitState = emit_mic3_module_fndef_if_both_return(s, src, fn_node, nidx, pstr, n_params, cond_expr, then_rv, else_rv, nodes, cursor, vidbuf, ok_cell);
                                        if __mind_load_i64(ok_cell) == 1 {
                                            return sbr;
                                        }
                                    }
                                }
                            }
                        }
                    }
                    if then_expr >= 0 {
                        if else_expr >= 0 {
                            // The narrow path (emit_mic3_if_instr) emits branch/cond trees with
                            // NO strtab (intern_find n=0 -> name_idx=-1), so a CALL in any of the
                            // three sub-exprs would emit byte 127. Defer those to the general
                            // ifany path (threads strbuf/offs/ncount); keep the narrow path for
                            // pure param/const/binop branches (byte-identical, no interning).
                            let any_call: i64 = node_has_call(cond_expr) + node_has_call(then_expr) + node_has_call(else_expr);
                            if any_call == 0 {
                                let sif: EmitState = emit_mic3_module_fndef_if(s, src, fn_node, nidx, pstr, n_params, cond_expr, then_expr, else_expr, nodes, cursor, vidbuf, ok_cell);
                                if __mind_load_i64(ok_cell) == 1 {
                                    return sif;
                                }
                            }
                        }
                    }
                }
                // General value if-EXPRESSION body: block branches with leading lets and/or
                // a nested else-if chain trailing value (the narrow path above only takes
                // single param/const/binop branches). Gate on is_value_if_expr (NOT ok_cell,
                // which the narrow path leaves seeded when its branch_single_expr guards skip).
                if is_any_value_if_expr(expr) == 1 {
                    let sany: EmitState = emit_mic3_module_fndef_ifany(s, src, fn_node, nidx, pstr, n_params, expr, nodes, cursor, vidbuf, strbuf, offs, ncount, ok_cell);
                    if __mind_load_i64(ok_cell) == 1 {
                        return sany;
                    }
                }
            }
            // (d) arbitrary param/const/binop expression tree.
            if ast_kind(expr) != ast_if() {
                let stree: EmitState = emit_mic3_module_fndef_tree(s, src, strbuf, offs, ncount, fn_node, nidx, pstr, n_params, expr, nodes, cursor, vidbuf, ok_cell);
                if __mind_load_i64(ok_cell) == 1 {
                    return stree;
                }
            }
        }
        // (f) multi-statement let chain: >1 stmts, a sequence of `let NAME = INIT`
        // bindings then a trailing value expression (every init/expr a param /
        // const / binop / let-ref tree). Substitution-equivalent to the nested
        // expression, so byte-exact vs --emit-mic3.
        if stmts_len >= 2 {
            let nodes2: i64 = __mind_alloc(4096 * 32);
            let cursor2: i64 = __mind_alloc(8);
            let vidbuf2: i64 = __mind_alloc(4096 * 8);
            let env: i64 = __mind_alloc(512 * 24);
            let nlets_cell: i64 = __mind_alloc(8);
            let slet: EmitState = emit_mic3_module_fndef_letchain(s, src, fn_node, nidx, pstr, n_params, stmts_addr, stmts_len, nodes2, cursor2, vidbuf2, env, nlets_cell, strbuf, offs, ncount, ok_cell);
            if __mind_load_i64(ok_cell) == 1 {
                return slet;
            }
        }
        // (g) if-statement early-return: exactly 2 stmts where stmt[0] is an
        // else-less if whose then-block's single statement is `return E`, and
        // stmt[1] is a trailing param/const/binop value expr. Byte-exact vs
        // --emit-mic3 (additive; the canary path is untouched).
        if stmts_len == 2 {
            let if_stmt: i64 = __mind_load_i64(stmts_addr + 0);
            // (g)/(g2) emit cond/ret/trail trees with a NULL strtab; a call's name_idx
            // would resolve to -1 (127). Defer to the general path (h) on any call.
            let g_has_call: i64 = if node_has_call(if_stmt) == 1 {
                1
            } else {
                node_has_call(__mind_load_i64(stmts_addr + 8))
            };
            if g_has_call == 0 {
                if ast_kind(if_stmt) == ast_if() {
                    if ast_child2(if_stmt) == 0 {
                        let then_blk: i64 = ast_child1(if_stmt);
                        let ret_stmt: i64 = branch_single_expr(then_blk);
                        if ret_stmt >= 0 {
                            // (g2) NESTED if-return: the then-block's single stmt is ITSELF
                            // an else-less if whose then-block is `return E` -> nested OP_IF.
                            if ast_kind(ret_stmt) == ast_if() {
                                // RECURSIVE if-chain (any depth): then-block's single stmt is
                                // itself an else-less if. The chain emitter validates + emits
                                // arbitrary depth; supersedes the depth-2 dedicated case.
                                let ntrail: i64 = __mind_load_i64(stmts_addr + 8);
                                let cnodes: i64 = __mind_alloc(256 * 32);
                                let ccursor: i64 = __mind_alloc(8);
                                let cvidbuf: i64 = __mind_alloc(256 * 8);
                                let ctnodes: i64 = __mind_alloc(256 * 32);
                                let ctcursor: i64 = __mind_alloc(8);
                                let ctvidbuf: i64 = __mind_alloc(256 * 8);
                                let snif: EmitState = emit_mic3_module_fndef_if_chain(s, src, fn_node, nidx, pstr, n_params, if_stmt, ntrail, cnodes, ccursor, cvidbuf, ctnodes, ctcursor, ctvidbuf, ok_cell);
                                if __mind_load_i64(ok_cell) == 1 {
                                    return snif;
                                }
                            }
                            if ast_kind(ret_stmt) == ast_return() {
                                let cond_expr: i64 = ast_child0(if_stmt);
                                let ret_expr: i64 = ast_child0(ret_stmt);
                                let trail_expr: i64 = __mind_load_i64(stmts_addr + 8);
                                let gnodes: i64 = __mind_alloc(256 * 32);
                                let gcursor: i64 = __mind_alloc(8);
                                let gvidbuf: i64 = __mind_alloc(256 * 8);
                                let tnodes: i64 = __mind_alloc(256 * 32);
                                let tcursor: i64 = __mind_alloc(8);
                                let tvidbuf: i64 = __mind_alloc(256 * 8);
                                let sif: EmitState = emit_mic3_module_fndef_ifstmt(s, src, fn_node, nidx, pstr, n_params, cond_expr, ret_expr, trail_expr, gnodes, gcursor, gvidbuf, tnodes, tcursor, tvidbuf, ok_cell);
                                if __mind_load_i64(ok_cell) == 1 {
                                    return sif;
                                }
                            }
                        }
                    }
                }
            }
        }
        // (h) GENERAL statement sequence: >1 stmts mixing `let NAME = INIT` and
        // `if COND { return E; }` in arbitrary order, then a trailing value expr.
        // Strict superset of (f)+(g); reached only when those narrow shapes miss.
        // Byte-exact vs --emit-mic3 (additive; canary untouched). stmts_len >= 1 so a
        // single trailing `return E` / value if-expr body reaches the seq path too (the
        // narrow stmts_len==1 cases above already return before here when they match).
        if stmts_len >= 1 {
            let hnodes: i64 = __mind_alloc(4096 * 32);
            let hcursor: i64 = __mind_alloc(8);
            let hvidbuf: i64 = __mind_alloc(4096 * 8);
            let henv: i64 = __mind_alloc(512 * 24);
            let hnlets: i64 = __mind_alloc(8);
            let hplan: i64 = __mind_alloc(512 * 64);
            let hnplan: i64 = __mind_alloc(8);
            let sseq: EmitState = emit_mic3_module_fndef_seq(s, src, fn_node, nidx, pstr, n_params, stmts_addr, stmts_len, hnodes, hcursor, hvidbuf, henv, hnlets, hplan, hnplan, strbuf, offs, ncount, ok_cell);
            if __mind_load_i64(ok_cell) == 1 {
                return sseq;
            }
        }
    }
    __mind_store_i64(ok_cell, 0);
    s
}

// Loop over the N top-level fn_defs (k = 0..n_fns), emitting each FN_DEF then its
// scaffold ConstI64(%k,0)/Output(%k). If any fn's shape is unmatched, ok_cell is
// left 0 and the caller fails the whole module closed. `k`/`item_i` advance in
// lockstep: k counts fn_defs seen, item_i walks the raw item array.
pub fn emit_mic3_module_fns_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return emit_mic3_module_fns_loop(s, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k, item_i + 1);
    }
    let s1: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return s1;
    }
    let s2: EmitState = emit_mic3_scaffold(s1, k);
    emit_mic3_module_fns_loop(s2, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1)
}

// ITEM-ORDER N-ITEM module loop: walk EVERY top-level item in declaration order,
// emitting one module-level scaffold per item at the running vid `k` (which counts
// BOTH struct decls and fn defs, matching the oracle's flat module-level vid space).
// A struct decl emits only its CONST/OUTPUT placeholder pair; a fn def emits its
// FN_DEF body then its placeholder pair. Fails closed via ok_cell on any unmatched
// fn shape. Generalizes emit_mic3_module_fns_loop (fns only) to struct-containing
// modules so the scaffold vids interleave exactly as --emit-mic3 produces them.
pub fn emit_mic3_module_items_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        // Struct (or other non-fn) decl: scaffold-only placeholder at vid k.
        let ss: EmitState = emit_mic3_scaffold(s, k);
        return emit_mic3_module_items_loop(ss, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1);
    }
    let s1: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return s1;
    }
    let s2: EmitState = emit_mic3_scaffold(s1, k);
    emit_mic3_module_items_loop(s2, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1)
}

// AST-DRIVEN N-FUNCTION module driver: lex+parse `src`, build the deduped
// first-seen string table, then assemble a complete mic@3 module for ANY number
// of functions whose bodies are the proven shapes, byte-exact vs --emit-mic3.
// Fails closed (es_new(), empty buf) when fewer than 1 fn is present or any fn's
// shape is unmatched.
pub fn selftest_mic3_module_nfn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Multi-struct registry (declaration order with per-struct field spans). N==0
    // for struct-less modules, in which case the registry/strtab tail stays empty
    // and the bytes are unchanged from the original fns-only path.
    let srt: i64 = srt_build(src_addr, src_len);
    let n_structs: i64 = srt_count(srt);
    // STRUCT-LIT CONSTRUCTION DESUGAR: rewrite `T{..}` ctors into the
    // alloc+stores+ret let-chain BEFORE the strtab pass (so __mind_alloc /
    // __mind_store_i64 intern in body order) and BEFORE the field-read prefold (so
    // field-read values inside store args still fold). No-op when those literals are
    // absent from source or no fn constructs a struct (fails closed downstream).
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    let alloc_found: i64 = find_alloc_name_span(src_addr, src_len, 0, slit_acell);
    let store_found: i64 = find_store_name_span(src_addr, src_len, 0, slit_scell);
    let have_spans: i64 = if alloc_found == 1 {
        store_found
    } else {
        0
    };
    // A module that CONSTRUCTS a struct but never spells `__mind_alloc`/`__mind_store_i64`
    // in source has no span to intern the desugar's synthetic alloc/store callee names from,
    // so the desugar/annotation was skipped and every struct-lit fell closed. Append the two
    // literals to a src copy and use appended-offset spans. main.mind itself contains both
    // literals (have_spans==1), so it keeps src_addr + the real spans BYTE-FOR-BYTE.
    let src_use: i64 = if have_spans == 1 {
        src_addr
    } else {
        build_src_intrinsics(src_addr, src_len)
    };
    let alo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 0)
    } else {
        src_len
    };
    let ahi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_acell + 8)
    } else {
        src_len + 12
    };
    let slo: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 0)
    } else {
        src_len + 12
    };
    let shi: i64 = if have_spans == 1 {
        __mind_load_i64(slit_scell + 8)
    } else {
        src_len + 28
    };
    let _sl: i64 = slit_desugar_module(src_use, src_len, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    // FIELD-READ PRE-RESOLVE: rewrite every resolvable `recv.field` into the
    // equivalent `__mind_load_i64(field_addr)` Call subtree, IN PLACE, BEFORE the
    // strtab pass. Order is load-bearing: the oracle interns "__mind_load_i64" at
    // the field-read's first-seen position, so the strtab must walk the rewritten
    // calls (not ast_field) to match the oracle's first-seen string order.
    // field_prefold's guard searches for `__mind_load_i64`; when it was appended to src_use,
    // extend the search length past src_len so the guard finds it (an unresolvable field-read
    // then lowers to a CONST 0 stub, a resolvable one to a load — both matching the oracle).
    let prefold_len: i64 = if have_spans == 1 {
        src_len
    } else {
        src_len + 43
    };
    let _pf: i64 = field_prefold_module(src_use, prefold_len, items_addr, items_len, 0, srt);
    let _an: i64 = slit_annotate_module(src_use, items_addr, items_len, srt, alo, ahi, slo, shi, 0);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_use, items_addr, items_len, 0);
    // Append every struct's TYPE + FIELD names to the strtab in BTreeMap-sorted
    // (struct-name) order, matching the oracle's collect_struct_def_strings pass
    // (registry strings come AFTER all instruction strings). intern_span dedups, so
    // a struct/field name that already appeared as a fn/param name reuses its slot.
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let n_fns: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    if n_fns < 1 {
        return es_new();
    }
    // header || strtab || next_id(=items_len) || exports(0) ||
    //   instr_count(=2*items_len + n_fns). The scaffold loop emits ONE placeholder per
    //   TOP-LEVEL ITEM (each consumes vid k => next_id == items_len) plus a FN_DEF for
    //   each fn. A module may carry items that are neither a registry struct nor a fn
    //   (e.g. extra struct decls beyond the lit registry), so count items_len directly
    //   rather than n_structs+n_fns, which undercounts those.
    let n_items: i64 = items_len;
    let s1: EmitState = emit_mic3_header(es_new());
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, ncount);
    let s3: EmitState = emit_uleb128(s2, n_items);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, items_len + items_len + n_fns);
    // Per-item placeholder + per-fn FN_DEF, in declaration order, threaded through
    // one ok_cell. The running vid counts both structs and fns (flat module space).
    let ok_cell: i64 = __mind_alloc(8);
    __mind_store_i64(ok_cell, 1);
    let s6: EmitState = emit_mic3_module_items_loop(s5, src_use, items_addr, items_len, strbuf, offs, ncount, ok_cell, 0, 0);
    if __mind_load_i64(ok_cell) == 0 {
        return es_new();
    }
    // Registries: populated struct_defs (BTreeMap-sorted, sorted-rank strbases)
    // when structs exist, else the empty triple. const_array_defs / repr_c = 0.
    if n_structs == 0 {
        return emit_mic3_empty_registries(s6);
    }
    let s7: EmitState = emit_uleb128(s6, n_structs);
    let s8: EmitState = srt_emit_registry_sorted_interned(s7, strbuf, offs, ccell, src_addr, srt, 0);
    let s9: EmitState = emit_uleb128(s8, 0);
    emit_uleb128(s9, 0)
}

// DIAGNOSTIC (cutover tooling): walk every fn_def, emit_mic3_module_fndef each, and
// return the SOURCE span_lo (fn-name byte offset) of the FIRST fn that fails closed
// (ok_cell==0), or -1 if all fns emit. Locates the next nfn-driver wall on main.mind.
pub fn nfn_first_fail_loop(src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, item_i: i64) -> i64 {
    if item_i >= items_len {
        return 0 - 1;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return nfn_first_fail_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1);
    }
    let ok: i64 = __mind_alloc(8);
    __mind_store_i64(ok, 1);
    let _s: EmitState = emit_mic3_module_fndef(es_new(), src, item, strbuf, offs, ncount, ok);
    if __mind_load_i64(ok) == 0 {
        let nm: i64 = ast_child0(item);
        return ast_span_lo(nm);
    }
    nfn_first_fail_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1)
}

pub fn selftest_nfn_fail_span(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build(src_addr, src_len);
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, slit_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, slit_scell) == 1 {
            let _sl: i64 = slit_desugar_module(src_addr, src_len, items_addr, items_len, srt, __mind_load_i64(slit_acell + 0), __mind_load_i64(slit_acell + 8), __mind_load_i64(slit_scell + 0), __mind_load_i64(slit_scell + 8), 0);
        }
    }
    let _pf: i64 = field_prefold_module(src_addr, src_len, items_addr, items_len, 0, srt);
    let sa_acell: i64 = __mind_alloc(16);
    let sa_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, sa_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, sa_scell) == 1 {
            let _an: i64 = slit_annotate_module(src_addr, items_addr, items_len, srt, __mind_load_i64(sa_acell + 0), __mind_load_i64(sa_acell + 8), __mind_load_i64(sa_scell + 0), __mind_load_i64(sa_scell + 8), 0);
        }
    }
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    nfn_first_fail_loop(src_addr, items_addr, items_len, strbuf, offs, ncount, 0)
}

// Emit ONLY the `target`-th fn_def (0-indexed among fn_defs). Returns 1=byte-emit ok,
// 0=fail-closed, -2=out of range. Used fork-isolated from Python so a fn whose emit
// CRASHES (segfault) is pinpointed without killing the whole survey.
pub fn nfn_emit_nth_loop(src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, item_i: i64, target: i64, seen: i64) -> i64 {
    if item_i >= items_len {
        return 0 - 2;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return nfn_emit_nth_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1, target, seen);
    }
    if seen == target {
        let ok: i64 = __mind_alloc(8);
        __mind_store_i64(ok, 1);
        let _s: EmitState = emit_mic3_module_fndef(es_new(), src, item, strbuf, offs, ncount, ok);
        return __mind_load_i64(ok);
    }
    nfn_emit_nth_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1, target, seen + 1)
}

pub fn selftest_nfn_emit_nth(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, n: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build(src_addr, src_len);
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, slit_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, slit_scell) == 1 {
            let _sl: i64 = slit_desugar_module(src_addr, src_len, items_addr, items_len, srt, __mind_load_i64(slit_acell + 0), __mind_load_i64(slit_acell + 8), __mind_load_i64(slit_scell + 0), __mind_load_i64(slit_scell + 8), 0);
        }
    }
    let _pf: i64 = field_prefold_module(src_addr, src_len, items_addr, items_len, 0, srt);
    let sa_acell: i64 = __mind_alloc(16);
    let sa_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, sa_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, sa_scell) == 1 {
            let _an: i64 = slit_annotate_module(src_addr, items_addr, items_len, srt, __mind_load_i64(sa_acell + 0), __mind_load_i64(sa_acell + 8), __mind_load_i64(sa_scell + 0), __mind_load_i64(sa_scell + 8), 0);
        }
    }
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    nfn_emit_nth_loop(src_addr, items_addr, items_len, strbuf, offs, ncount, 0, n, 0)
}

// Count how many fn_defs fail-closed (the cutover progress metric: 0 == full self-host).
pub fn nfn_fail_count_loop(src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, item_i: i64, acc: i64) -> i64 {
    if item_i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return nfn_fail_count_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1, acc);
    }
    let ok: i64 = __mind_alloc(8);
    __mind_store_i64(ok, 1);
    let _s: EmitState = emit_mic3_module_fndef(es_new(), src, item, strbuf, offs, ncount, ok);
    let nacc: i64 = if __mind_load_i64(ok) == 0 {
        acc + 1
    } else {
        acc
    };
    nfn_fail_count_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1, nacc)
}

// Returns fail_count * 100000 + total_fn_defs (so one i64 carries both: progress = how
// many of total still fail-closed; 0 fails == ready to flip the fixed_point oracle).
pub fn selftest_nfn_fail_count(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build(src_addr, src_len);
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, slit_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, slit_scell) == 1 {
            let _sl: i64 = slit_desugar_module(src_addr, src_len, items_addr, items_len, srt, __mind_load_i64(slit_acell + 0), __mind_load_i64(slit_acell + 8), __mind_load_i64(slit_scell + 0), __mind_load_i64(slit_scell + 8), 0);
        }
    }
    let _pf: i64 = field_prefold_module(src_addr, src_len, items_addr, items_len, 0, srt);
    let sa_acell: i64 = __mind_alloc(16);
    let sa_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, sa_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, sa_scell) == 1 {
            let _an: i64 = slit_annotate_module(src_addr, items_addr, items_len, srt, __mind_load_i64(sa_acell + 0), __mind_load_i64(sa_acell + 8), __mind_load_i64(sa_scell + 0), __mind_load_i64(sa_scell + 8), 0);
        }
    }
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let nfail: i64 = nfn_fail_count_loop(src_addr, items_addr, items_len, strbuf, offs, ncount, 0, 0);
    let ntotal: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    nfail * 100000 + ntotal
}

// ===== mic@3 COMPLETE with-body module — the 2-param arithmetic function family (Phase 4c) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>, <pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust oracle. Extends Phase 4a (const-return) to functions with
// PARAMETERS and a real BINOP body. `buf`/`offs` carry 3 strings (name, pa, pb);
// `op_byte` is binop_to_byte(op) (0 = Add, as `a + b`). The exact shape emit_mic3 +
// the lowering produce (decoded from the oracle):
//   header || strtab(3:name,pa,pb) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0),(2,%1)], ret=%2, body=[PARAM %0, PARAM %1,
//            BINOP %2 = %0 op %1]} || ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// For add(a,b){a+b} (op_byte=0) this reproduces the 49-byte oracle byte-for-byte.
pub fn emit_mic3_arith_fn_module(s: EmitState, buf: i64, offs: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 3);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    emit_mic3_empty_registries(s20)
}

pub fn selftest_mic3_arith_fn(buf: i64, offs: i64, op_byte: i64) -> EmitState {
    emit_mic3_arith_fn_module(es_new(), buf, offs, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the single-param identity family (Phase 4d) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>) -> i64 { <pa> }`, byte-exact vs
// the Rust oracle. This is the FIRST function whose RETURN is a PARAMETER directly:
// the FN_DEF ret_vid is the param's own vid (%0) and the body is a single PARAM
// instruction — no BINOP, no body ConstI64 (distinct from Phase 4a const-return,
// where the body is a ConstI64, and Phase 4c arith, where the body is PARAM,PARAM,
// BINOP). `buf`/`offs` carry 2 strings (name, pa). The exact shape emit_mic3 + the
// lowering produce (decoded from the oracle for `ident(a){a}`, 38 bytes):
//   header || strtab(2:name,pa) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)], ret=%0, body=[PARAM %0]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_ident_fn_module(s: EmitState, buf: i64, offs: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_mic3_opt_vid(s10, 1, 0);
    let s12: EmitState = es_push(s11, 0);
    let s13: EmitState = emit_uleb128(s12, 1);
    let s14: EmitState = emit_mic3_param(s13, 0, 1, 0);
    let s15: EmitState = emit_mic3_const_i64(s14, 0, 0);
    let s16: EmitState = emit_mic3_output(s15, 0);
    emit_mic3_empty_registries(s16)
}

pub fn selftest_mic3_ident_fn(buf: i64, offs: i64) -> EmitState {
    emit_mic3_ident_fn_module(es_new(), buf, offs)
}

// ===== mic@3 COMPLETE with-body module — the N-param chained-binop family (Phase 4e) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { p0 OP p1 OP .. }`,
// byte-exact vs the Rust oracle, for N >= 2 left-associated binops of one op. This is
// the FIRST body that emits MORE THAN ONE BINOP where each consumes the previous
// binop's result: params take %0..%(n-1), then %n = %0 op %1, %(n+1) = %n op %2,
// %(n+2) = %(n+1) op %3, ... — the second operand of binop k (k>=1) is param %(k+1)
// and the first operand is the running accumulator %(n+k-1). The FN_DEF ret_vid is
// the FINAL binop's vid (2n-2) and body_len = n PARAMs + (n-1) BINOPs = 2n-1.
// `buf`/`offs` carry (n+1) strings (name then the n params, str_idx i+1 -> vid i);
// `op_byte` is binop_to_byte(op) (0 = Add). Decoded from the oracle for
// chain(a,b,c){a+b+c} (n=3, 64 bytes: ret %4, body_len 5) and
// chain4(a,b,c,d){a+b+c+d} (n=4, 78 bytes: ret %6, body_len 7). Generalizes the
// Phase 4c 2-param arith module (n=2 collapses to a single binop, identical shape).
//   header || strtab(n+1) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%(2n-2),
//            body=[PARAM %0..PARAM %(n-1), BINOP %n=%0 op %1,
//                  BINOP %(n+1)=%n op %2, ..]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_chain_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header (inline: name_idx=0, then encode_named_vids param list).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    // ret = Some %(2n-2) (final binop vid); reap None; body_len = 2n-1.
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, n + n - 2);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + n - 1);
    // Body: n PARAM instrs (%i, str i+1, index i), then the binop chain.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_chain_binops(s12, n, op_byte, 1);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// FN_DEF param list (encode_named_vids): uleb(n) then n pairs (str_idx i+1, vid i).
pub fn emit_mic3_chain_param_pairs(s: EmitState, n: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, n);
    emit_mic3_chain_param_pairs_loop(s1, n, 0)
}

pub fn emit_mic3_chain_param_pairs_loop(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, i + 1);
    let s2: EmitState = emit_uleb128(s1, i);
    emit_mic3_chain_param_pairs_loop(s2, n, i + 1)
}

// Body PARAM instrs: PARAM(%i, name=i+1, index=i) for i in 0..n.
pub fn emit_mic3_chain_params(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, i, i + 1, i);
    emit_mic3_chain_params(s1, n, i + 1)
}

// Body BINOP chain: for k in 1..n emit BINOP(dst=%(n+k-1), op, lhs, rhs):
//   k == 1: lhs=%0, rhs=%1 (the first add of the two leading params);
//   k  > 1: lhs=%(n+k-2) (running accumulator), rhs=%k (next param).
// Caller passes k starting at 1; there are n-1 binops.
pub fn emit_mic3_chain_binops(s: EmitState, n: i64, op_byte: i64, k: i64) -> EmitState {
    if k >= n {
        return s;
    }
    let dst: i64 = n + k - 1;
    if k == 1 {
        let s1: EmitState = emit_mic3_binop(s, dst, op_byte, 0, 1);
        return emit_mic3_chain_binops(s1, n, op_byte, k + 1);
    }
    let s2: EmitState = emit_mic3_binop(s, dst, op_byte, n + k - 2, k);
    emit_mic3_chain_binops(s2, n, op_byte, k + 1)
}

pub fn selftest_mic3_chain_fn(buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    emit_mic3_chain_fn_module(es_new(), buf, offs, n, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the mixed-operator expression-tree family (Phase 4f) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { <expr-tree> }`,
// byte-exact vs the Rust oracle, for an ARBITRARY binary-expression tree of MIXED
// operators — the first body that is NOT a left-spine accumulator. Examples:
//   mixed(a,b,c,d){a*b+c*d}  (tree +(*(a,b),*(c,d)), 77-byte oracle)
//   f(a,b,c){(a+b)*c}        (tree *(+(a,b),c),       60-byte oracle)
//
// The tree is supplied as a flat POST-ORDER node array (the standard flattening of
// a recursive post-order walk — the lowering emits each subtree, allocates a fresh
// vid, then references the two child vids). `nodes` is a heap array of `n_nodes`
// 4-i64 records (32 bytes each):
//   record[0] = kind: 0 = LEAF (param), 1 = BINOP.
//   LEAF :  record[1] = param index (its vid IS the index, since param i -> vid i).
//   BINOP:  record[1] = op_byte, record[2] = left child slot, record[3] = right slot.
// Nodes are in post-order, so a binop's child slots always precede it. The vid of a
// LEAF slot is its param index; the vid of a BINOP slot is allocated n, n+1, .. in
// post-order array order (== emission order). The FN_DEF ret_vid is the LAST node's
// vid (the tree root). body_len = n PARAMs + (#BINOP nodes). Decoded from the oracle:
//   header || strtab(n+1: name,p0..p(n-1)) || next_id(1) || exports(0) || uleb(3) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%root,
//            body=[PARAM %0..%(n-1), then BINOP per binop-node in post-order with
//                  the two child slot vids]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// Generalizes Phase 4e (the left-spine chain is the special case where every binop's
// left child is the previous binop and right child is the next leaf).
//
// `vidbuf` is a caller-supplied heap scratch array of `n_nodes` i64s used to record
// each slot's resolved vid (a binop references children by slot, so the slot->vid map
// must be materialized before the binops emit). It is filled by the first pass below.
pub fn emit_mic3_tree_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    // Pass 1: resolve every slot's vid into vidbuf (post-order, binops from %n).
    let root: i64 = tree_resolve_vids(nodes, n_nodes, n, vidbuf, 0, n);
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, encode_named_vids param list, ret Some %root, reap
    // None, body_len = n PARAMs + nbinops.
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, root);
    let s10: EmitState = es_push(s9, 0);
    // body_len = one instr per node: n PARAMs + every non-param node (binops and
    // const leaves). Since params are slots 0..(some) and ALL n_nodes nodes emit
    // exactly one body instr, body_len == n_nodes. For a param-only tree this is
    // identical to the former `n + nbinops` (every leaf is a param) — byte-exact.
    let s11: EmitState = emit_uleb128(s10, n_nodes);
    // Body: n PARAM instrs (reuse the chain param-body writer), then every
    // non-param node in post-order — binops with resolved child vids, const leaves
    // as their own ConstI64 at the interleaved slot.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_tree_body(s12, nodes, n_nodes, vidbuf, 0, 0, 0, 0, 0);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Pass 1: walk slots 0..n_nodes in order and record each slot's vid in vidbuf.
//   kind 0 (PARAM leaf): vid = param index (params own vids 0..n-1).
//   kind 1 (BINOP) and kind 2 (CONST leaf): vid = the running counter `nxt`
//     (starts at n). Const leaves and binops SHARE the post-order vid counter —
//     the Rust --emit-mic3 oracle interleaves them (e.g. h(a){a*2+1} resolves
//     PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4). Since both non-param
//     kinds fall through to the same `nxt++` branch, the post-order slot order
//     IS the oracle's interleaved vid order. Returns the LAST slot's vid (root).
// `i` is the current slot, `nxt` the next free non-param vid.
pub fn tree_resolve_vids(nodes: i64, n_nodes: i64, n: i64, vidbuf: i64, i: i64, nxt: i64) -> i64 {
    if i >= n_nodes {
        return __mind_load_i64(vidbuf + (n_nodes - 1) * 8);
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL — they emit no instr
    // and consume NO vid (mirror the param-leaf skip). The call node (kind 3) and the
    // value-producing kinds (1 binop / 2 const / 3 call) take the running counter.
    if kind == 4 {
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    if kind == 5 {
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    __mind_store_i64(vidbuf + i * 8, nxt);
    tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt + 1)
}

// Pass 2: emit one body instr per NON-PARAM slot, in post-order array order.
//   kind 0 (PARAM leaf): emit nothing (its PARAM was written in the param pass).
//   kind 1 (BINOP): dst = vidbuf[slot]; lhs/rhs = vidbuf[left]/vidbuf[right].
//   kind 2 (CONST leaf): record[1] holds the RAW literal value; emit a ConstI64
//     at vidbuf[slot] (emit_mic3_const_i64 zigzag-encodes it, so lit 2 -> the
//     oracle's CONST 4). Const slots are interleaved with binops by post-order.
// For a param-only tree no kind-2 slot exists, so this is byte-identical to the
// former emit_mic3_tree_binops (Bound by MIND-CONSTITUTION §I — param-only path
// unchanged).
pub fn emit_mic3_tree_body(s: EmitState, nodes: i64, n_nodes: i64, vidbuf: i64, src: i64, strbuf: i64, offs: i64, n_strings: i64, i: i64) -> EmitState {
    if i >= n_nodes {
        return s;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL metadata — emit
    // nothing (their vids were never assigned; the call node walks them).
    if kind == 4 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    if kind == 5 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    let dst: i64 = __mind_load_i64(vidbuf + i * 8);
    if kind == 2 {
        let lit: i64 = __mind_load_i64(nodes + i * 32 + 8);
        let sc: EmitState = emit_mic3_const_i64(s, dst, lit);
        return emit_mic3_tree_body(sc, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    if kind == 3 {
        // CALL: child0 = callee leaf slot (its span -> strtab index), child1 = first
        // arg-cons slot. nargs is the chain length; arg vids are each cons node's
        // child0 arg-root-slot's vid (vidbuf). OP_CALL (0x16): dst || name_idx ||
        // nargs || arg_vids — matches --emit-mic3 (Bound by MIND-CONSTITUTION §I).
        let cleaf: i64 = __mind_load_i64(nodes + i * 32 + 16);
        let lo: i64 = __mind_load_i64(nodes + cleaf * 32 + 8);
        let hi: i64 = __mind_load_i64(nodes + cleaf * 32 + 16);
        let name_idx: i64 = intern_find(strbuf, offs, n_strings, src, lo, hi, 0);
        let first_cons: i64 = __mind_load_i64(nodes + i * 32 + 24);
        let nargs: i64 = argcons_len(nodes, first_cons, 0);
        let s1: EmitState = es_push(s, 22);
        let s2: EmitState = emit_uleb128(s1, dst);
        let s3: EmitState = emit_uleb128(s2, name_idx);
        let s4: EmitState = emit_uleb128(s3, nargs);
        let s5: EmitState = emit_argcons_vids(s4, nodes, vidbuf, first_cons);
        return emit_mic3_tree_body(s5, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    let op_byte: i64 = __mind_load_i64(nodes + i * 32 + 8);
    let lslot: i64 = __mind_load_i64(nodes + i * 32 + 16);
    let rslot: i64 = __mind_load_i64(nodes + i * 32 + 24);
    let lvid: i64 = __mind_load_i64(vidbuf + lslot * 8);
    let rvid: i64 = __mind_load_i64(vidbuf + rslot * 8);
    let s1: EmitState = emit_mic3_binop(s, dst, op_byte, lvid, rvid);
    emit_mic3_tree_body(s1, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1)
}

// Count the arg-cons chain length starting at cons slot `c` (0 = end).
pub fn argcons_len(nodes: i64, c: i64, acc: i64) -> i64 {
    if c == 0 {
        return acc;
    }
    let next: i64 = __mind_load_i64(nodes + c * 32 + 24);
    argcons_len(nodes, next, acc + 1)
}

// Emit each arg's resolved vid by walking the arg-cons chain in order. Each cons
// node's child0 (offset 16) is the arg-root descriptor slot; its vid is vidbuf[slot].
pub fn emit_argcons_vids(s: EmitState, nodes: i64, vidbuf: i64, c: i64) -> EmitState {
    if c == 0 {
        return s;
    }
    let arg_root: i64 = __mind_load_i64(nodes + c * 32 + 16);
    let vid: i64 = __mind_load_i64(vidbuf + arg_root * 8);
    let s1: EmitState = emit_uleb128(s, vid);
    let next: i64 = __mind_load_i64(nodes + c * 32 + 24);
    emit_argcons_vids(s1, nodes, vidbuf, next)
}

pub fn selftest_mic3_tree_fn(buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    emit_mic3_tree_fn_module(es_new(), buf, offs, n, nodes, n_nodes, vidbuf)
}

// ===========================================================================
// Phase 4g/4h — AST-DRIVEN mic@3 expression emission (the bootstrap-parser bridge)
// ===========================================================================
//
// Phase 4f drove emit_mic3_tree_fn_module from a SYNTHETIC hand-built 4-i64 node
// descriptor. Phase 4g closed the gap to self-compilation: it walks the LIVE
// bootstrap-parser AST (real 56-byte ast_binop / ast_ident nodes — see
// ast_new_binop at line ~621, ast_child0=lhs+24, ast_child1=rhs+32, ast_aux=op+48)
// and FLATTENS it into the same post-order descriptor the proven 4f emitter
// consumes. The byte-exact emitter is reused, so the param-only path is byte-exact-
// by-construction with the Phase 4f path AND the Rust oracle.
//
// Phase 4h adds CONST LEAVES (ast_int_lit). The descriptor gains a third record
// kind (kind 2 = const, record[1] = raw literal). A const leaf gets its own
// post-order slot whose vid is allocated INTERLEAVED with the binops (the oracle
// does NOT batch consts with params): e.g. h(a){a*2+1} resolves
//   PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4
// and the const value is zigzag-encoded at emit (lit 2 -> CONST 4, lit 3 -> CONST
// 6) by the existing emit_mic3_const_i64. Pass 1 (tree_resolve_vids) already routes
// every non-param node through the shared `nxt++` counter, and Pass 2
// (emit_mic3_tree_body) emits a ConstI64 at a const slot — so param-only trees keep
// the exact former bytes (no kind-2 slot fires) while const leaves now lower
// byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
//
// SCOPE: ast_binop trees whose leaves are ast_ident PARAM references and/or
// ast_int_lit CONST literals. field access / calls / if / let are later-phase
// walls (flatten_ast returns -1, the driver fails closed — no partial bytes).

// AST binop op-tag (op_add()=1, op_sub()=2, op_mul()=3, op_div()=4,
// op_lt()=5, op_gt()=6, op_eq()=7, op_le()=8, op_ge()=9, op_ne()=10) -> the
// mic@3 op_byte the oracle stores. The arithmetic ops map op_byte = op_tag - 1
// (add=0, sub=1, mul=2, div=3 — verified vs --emit-mic3). The comparison ops do
// NOT share that offset: the MIND op-tag order (lt,gt,eq,le,ge,ne) differs from
// the Rust BinOp byte order (Lt=0x05, Le=0x06, Gt=0x07, Ge=0x08, Eq=0x09,
// Ne=0x0A — src/ir/compact/v3/emit.rs binop_to_byte), so each is mapped
// explicitly. Verified byte-exact vs --emit-mic3 on lt/gt/eq/le/ge/ne fns.
pub fn binop_to_byte(op_tag: i64) -> i64 {
    if op_tag == op_lt() {
        return 5;
    }
    if op_tag == op_gt() {
        return 7;
    }
    if op_tag == op_eq() {
        return 9;
    }
    if op_tag == op_le() {
        return 6;
    }
    if op_tag == op_ge() {
        return 8;
    }
    if op_tag == op_ne() {
        return 10;
    }
    // Bitwise / shift ops. The MIND op-tag order (bitand=11, bitor=12, bitxor=13,
    // shl=14, shr=15) matches the Rust BinOp byte order (BitAnd=0x0B, BitOr=0x0C,
    // BitXor=0x0D, Shl=0x0E, Shr=0x0F — src/ir/compact/v3/emit.rs binop_to_byte),
    // so the offset is op_tag - 0 = op_tag here. Verified byte-exact vs --emit-mic3.
    if op_tag == op_bitand() {
        return 11;
    }
    if op_tag == op_bitor() {
        return 12;
    }
    if op_tag == op_bitxor() {
        return 13;
    }
    if op_tag == op_shl() {
        return 14;
    }
    if op_tag == op_shr() {
        return 15;
    }
    // Mod=0x04 — MIND op-tag order appends mod=16 after the shift ops, but the
    // Rust BinOp byte order (src/ir/compact/v3/emit.rs) places Mod=0x04 right
    // after Div=0x03, so map it explicitly (op_tag - 1 would yield 15 = Shr).
    if op_tag == op_mod() {
        return 4;
    }
    op_tag - 1
}

// Recursive post-order flatten of a param-only binary-expression AST sub-tree into
// the 4-i64 descriptor array `nodes` (kind,a,b,c per record, 32 bytes). `cursor` is
// a 1-i64 heap cell holding the next free slot. Returns the slot index of `node`'s
// emitted record, or -1 if the sub-tree contains an unsupported construct (a
// const/int leaf, or anything that is not ast_ident / ast_binop). On -1 the caller
// MUST abort (the descriptor is then partial/invalid) — fail-closed, never a
// byte-mismatched emit (Bound by MIND-CONSTITUTION §I).
pub fn flatten_ast(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        // Parentheses are purely structural — the mic@3 oracle carries no paren
        // node (verified vs --emit-mic3 on (a+b)*c). Recurse transparently.
        return flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 0);
        __mind_store_i64(nodes + slot * 32 + 8, idx);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_int_lit() {
        // Phase 4h: const leaf. The int-literal node carries no stored value, only
        // its source span [lo,hi) — parse the decimal digits to the raw literal.
        // Descriptor kind=2, record[1]=raw literal (emit_mic3_const_i64 zigzag-
        // encodes it at emission, matching the oracle's CONST lit*2). A const leaf
        // gets its own post-order slot (vid allocated interleaved with binops).
        // SYNTHETIC int-lit (field-read offset idx*8): child1==1 sentinel carries the
        // value DIRECT in child0 (no source decimal); real source int-lits have
        // child1==0 so this never fires for them.
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_ast(ast_child1(node), buf, params_addr, n_params, nodes, cursor);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        // Strategy-A cutover: a call with arbitrary expression arguments, encoded as
        // an ARG-CONS CHAIN inside the existing 32B descriptor array — no separate
        // arglist buffer, no flatten-param threading. Post-order is preserved: each
        // arg EXPRESSION sub-tree is flattened first (so its vids are assigned before
        // the call), then the structural callee-leaf (kind=5) + arg-cons (kind=4)
        // nodes (which emit NOTHING and consume NO vid), then the call node (kind=3)
        // LAST so it takes the final vid (matching the --emit-mic3 oracle).
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        // (1)+(2): flatten each arg expr post-order + build the arg-cons chain.
        let first_cons: i64 = flatten_argcons(args_addr, args_len, 0, buf, params_addr, n_params, nodes, cursor);
        if first_cons < 0 {
            return 0 - 1;
        }
        // (3): callee leaf — stores the callee NAME span (resolved to a strtab index
        // at emit time). kind=5, [span_lo, span_hi], emits nothing.
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        // (4): the call node, LAST in post-order. child0=callee leaf, child1=first
        // arg-cons slot (0 when zero-arg).
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_neg() {
        // Unary `-x` desugars to `0 - x` (CONST 0, then `sub`) — exactly how the
        // Rust front-end lowers it (verified vs --emit-mic3: CONST %k=0 then
        // BINOP %k+1 = %k sub %operand). Post-order: flatten the operand first, then
        // a synthetic const-0 leaf, then the `sub` binop LAST. Additive — main.mind
        // has no unary neg, so the flip stays byte-identical.
        let oslot: i64 = flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
        if oslot < 0 {
            return 0 - 1;
        }
        let zslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + zslot * 32 + 0, 2);
        __mind_store_i64(nodes + zslot * 32 + 8, 0);
        __mind_store_i64(nodes + zslot * 32 + 16, 0);
        __mind_store_i64(nodes + zslot * 32 + 24, 0);
        __mind_store_i64(cursor, zslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(op_sub()));
        __mind_store_i64(nodes + slot * 32 + 16, zslot);
        __mind_store_i64(nodes + slot * 32 + 24, oslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_not() {
        // Unary logical NOT `!x` desugars to `x == 0` — exactly how the Rust
        // front-end lowers it (src/eval/lower.rs Node::Not: lhs = lower(operand);
        // zero = CONST 0; dst = BinOp Eq(lhs, zero)). Verified byte-identical vs
        // --emit-mic3: `!a` and `a == 0` emit the same 45-byte mic@3 module.
        // Post-order: operand first, then a synthetic const-0, then the Eq binop
        // LAST (so it takes the final vid, lhs=operand slot, rhs=const-0 slot).
        // Additive — main.mind uses no `!` in a flattened trailing expression, so
        // the whole-module self-host gates stay byte-identical.
        let operand: i64 = ast_child0(node);
        // `!<int-literal>` fast path — mirrors src/eval/lower.rs Node::Not `!Lit(Int(n))`
        // => a single ConstI64(id, (n == 0)). One const leaf, NOT operand+zero+Eq. This
        // must match the oracle exactly: the count arm (count_nonparam_nodes ast_not)
        // now activates the module driver for `!`, so a bare `!5` would otherwise emit
        // 3 instrs where the oracle emits 1 (byte-divergence).
        if ast_kind(operand) == ast_int_lit() {
            let litv: i64 = if ast_child1(operand) == 1 {
                ast_child0(operand)
            } else {
                parse_int_span(buf, ast_span_lo(operand), ast_span_hi(operand), 0)
            };
            let cval: i64 = if litv == 0 {
                1
            } else {
                0
            };
            let cslot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + cslot * 32 + 0, 2);
            __mind_store_i64(nodes + cslot * 32 + 8, cval);
            __mind_store_i64(nodes + cslot * 32 + 16, 0);
            __mind_store_i64(nodes + cslot * 32 + 24, 0);
            __mind_store_i64(cursor, cslot + 1);
            return cslot;
        }
        let oslot: i64 = flatten_ast(operand, buf, params_addr, n_params, nodes, cursor);
        if oslot < 0 {
            return 0 - 1;
        }
        let zslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + zslot * 32 + 0, 2);
        __mind_store_i64(nodes + zslot * 32 + 8, 0);
        __mind_store_i64(nodes + zslot * 32 + 16, 0);
        __mind_store_i64(nodes + zslot * 32 + 24, 0);
        __mind_store_i64(cursor, zslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(op_eq()));
        __mind_store_i64(nodes + slot * 32 + 16, oslot);
        __mind_store_i64(nodes + slot * 32 + 24, zslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_struct_lit() {
        // PARSE-ONLY frontier: struct-literal CONSTRUCTION is parsed but not yet
        // lowered. Fail closed (no bytes) — the desugar/emit half lands later.
        return 0 - 1;
    }
    // Every other kind (field access, if, ...) = a later-phase wall — reject.
    0 - 1
}

// Flatten the args of a call into the descriptor array as an arg-cons chain. Arg
// `i`'s EXPRESSION sub-tree is flattened first (post-order — its vids are assigned
// before any later arg and before the call), then this arg's cons node (kind=4,
// child0=arg-root-slot, child1=next-cons-slot) is written. Returns the slot of the
// FIRST cons node (the head the call node points at), 0 when args_len == 0, or -1 if
// any arg sub-tree contains an unsupported construct (fail-closed, no partial bytes).
pub fn flatten_argcons(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_ast(arg, buf, params_addr, n_params, nodes, cursor);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons(args_addr, args_len, idx + 1, buf, params_addr, n_params, nodes, cursor);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// Count the slots a param-only AST sub-tree flattens to (= total nodes in the tree),
// so the caller can size the descriptor / vidbuf scratch. Returns -1 on an
// unsupported construct (mirrors flatten_ast's rejection set exactly).
pub fn count_ast_nodes(node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_ast_nodes(ast_child0(node));
    }
    if k == ast_ident() {
        return 1;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_ast_nodes(ast_child0(node));
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_ast_nodes(ast_child1(node));
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    0 - 1
}

// AST-driven driver: flatten a real param-only binary-expression AST `expr` into the
// 4f descriptor, then emit byte-exact via the proven emit_mic3_tree_fn_module. Two
// buffers: `src` (source bytes, holds the scattered param-name spans used by
// flatten_ast for param-index resolution) and `strbuf`/`offs` (a CONTIGUOUS name
// buffer + offset array — string i spans strbuf[offs[i]..offs[i+1]] — for the mic@3
// string table; emit_mic3_strtab requires contiguous packing, the source spans are
// not). `n` is the param count, `params_addr`/`n_params` the parsed param block.
// `nodes`/`cursor`/`vidbuf` are caller-supplied heap scratch (nodes: n_nodes*32
// bytes; cursor: 1 i64; vidbuf: n_nodes i64). On an unsupported body (const leaf /
// non-arith) it returns the unmodified seed state `s` so the caller can detect
// non-emission — fail-closed, no partial bytes (Bound by MIND-CONSTITUTION §I.4).
pub fn emit_mic3_ast_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, expr: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    let root: i64 = flatten_ast(expr, src, params_addr, n_params, nodes, cursor);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4g): lex+parse `src`, find the first fn_def, take its
// trailing body expression, flatten the REAL AST, and emit mic@3 — byte-exact vs
// the Rust --emit-mic3 oracle for param-only bodies (e.g. mixed(a,b,c,d){a*b+c*d}).
// `strbuf`/`offs` are the caller-supplied CONTIGUOUS string-table name buffer +
// offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf` are caller-supplied heap
// scratch sized to the body's node count. Returns the EmitState (Python harness
// decodes EmitState.buf); for a const-leaf body it returns es_new() unchanged (empty
// buf) — the Phase 4h deferral, detectable by the harness.
pub fn selftest_mic3_ast_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    emit_mic3_ast_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, expr, nodes, cursor, vidbuf)
}

// ===========================================================================
// Phase 4i — LET-BOUND LOCALS / multi-statement bodies (the let-env bridge)
// ===========================================================================
//
// Phase 4g/4h emitted a SINGLE trailing-expression body. Phase 4i extends the
// AST walk to a STATEMENT SEQUENCE: zero or more `let name: ty = init;` bindings
// feeding a final expression. The oracle (--emit-mic3) rule, decoded byte-for-byte
// from f(a,b){let t=a*b; t+1}, g(a){let x=a+1; let y=x*2; y}, h(a,b){let s=a+b; s*s}:
//
//   * Each `let name = init` flattens `init` post-order into the SAME descriptor
//     array; the resulting ROOT slot's vid is bound to `name`. No instruction and
//     no string-table entry is emitted for the let-name — it is a pure vid ALIAS
//     (strtab carries only the fn name + params; t/x/y/s are absent).
//   * A later ast_ident referencing a let-name returns that bound SLOT (an alias,
//     emits no new node) — exactly as a param ident returns its param slot. So
//     `t+1` -> BINOP whose lhs is the let-init's slot; `s*s` reuses ONE slot twice.
//   * The trailing expression flattens normally; its root slot vid = the FN_DEF
//     ret_vid. body_len = total descriptor nodes (PARAMs + every CONST/BINOP);
//     let-name aliases contribute nothing (Bound by MIND-CONSTITUTION §I —
//     verified byte-exact: letf 55B / letg 50B / leth 52B).
//
// The single-expression path (selftest_mic3_ast_fn) is UNTOUCHED below this point;
// flatten_ast / emit_mic3_ast_fn_module stay byte-identical for param/const bodies.
//
// SCOPE: bodies whose statements are `let` bindings (param/const/binop inits, the
// 4g/4h expr grammar) plus a trailing expression. A let whose init contains a
// non-arith construct, or any statement that is not a let / final expr, is a
// later-phase wall (flatten returns -1, the driver fails closed — no partial bytes).

// Let-env: parallel heap array. Entry j at `lenv + j*24` = [name_lo, name_hi, slot].
// `lcount` is a 1-i64 cell holding the live entry count. Look up the ident span
// buf[lo..hi): return the bound descriptor slot, or -1 if not a let-name. Span
// comparison (span_bytes_equal) mirrors resolve_param exactly — no hashing, so no
// collision risk on fresh let names.
pub fn resolve_let(lenv: i64, lcount: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_let_loop(lenv, __mind_load_i64(lcount), buf, lo, hi, 0)
}
pub fn resolve_let_loop(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    resolve_let_loop(lenv, n, buf, lo, hi, i + 1)
}

// Let-env-aware post-order flatten. Identical to flatten_ast (Phase 4g/4h) except
// the ast_ident branch first tries params, THEN let-names (alias to the bound slot,
// no new node). Threads lenv/lcount through paren/binop recursion. Returns the
// node's slot index, or -1 on an unsupported construct (fail-closed).
pub fn flatten_ast_le(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            let slot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + slot * 32 + 0, 0);
            __mind_store_i64(nodes + slot * 32 + 8, idx);
            __mind_store_i64(nodes + slot * 32 + 16, 0);
            __mind_store_i64(nodes + slot * 32 + 24, 0);
            __mind_store_i64(cursor, slot + 1);
            return slot;
        }
        // Not a param: a let-bound local resolves to its init's already-emitted
        // slot (an alias — emit no new node, return the bound slot directly).
        let lslot: i64 = resolve_let(lenv, lcount, buf, ast_span_lo(node), ast_span_hi(node));
        if lslot >= 0 {
            return lslot;
        }
        return 0 - 1;
    }
    if k == ast_int_lit() {
        let lit: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let ls: i64 = flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if ls < 0 {
            return 0 - 1;
        }
        let rs: i64 = flatten_ast_le(ast_child1(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if rs < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, ls);
        __mind_store_i64(nodes + slot * 32 + 24, rs);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_not() {
        // Unary logical NOT `!x` desugars to `x == 0` (operand, synth CONST 0, Eq
        // binop LAST) — mirrors the base flatten_ast ast_not arm, byte-identical vs
        // --emit-mic3. Additive: enables `!x` inside a multi-statement let body.
        // `!<int-literal>` fast path — mirrors src/eval/lower.rs `!Lit(Int(n))` => a
        // single ConstI64((n == 0)); one const leaf, NOT operand+zero+Eq.
        let notop: i64 = ast_child0(node);
        if ast_kind(notop) == ast_int_lit() {
            let litv: i64 = if ast_child1(notop) == 1 {
                ast_child0(notop)
            } else {
                parse_int_span(buf, ast_span_lo(notop), ast_span_hi(notop), 0)
            };
            let cval: i64 = if litv == 0 {
                1
            } else {
                0
            };
            return desc_emit_const(nodes, cursor, cval);
        }
        let oslot: i64 = flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if oslot < 0 {
            return 0 - 1;
        }
        let zslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + zslot * 32 + 0, 2);
        __mind_store_i64(nodes + zslot * 32 + 8, 0);
        __mind_store_i64(nodes + zslot * 32 + 16, 0);
        __mind_store_i64(nodes + zslot * 32 + 24, 0);
        __mind_store_i64(cursor, zslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(op_eq()));
        __mind_store_i64(nodes + slot * 32 + 16, oslot);
        __mind_store_i64(nodes + slot * 32 + 24, zslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_struct_lit() {
        // PARSE-ONLY frontier: reject struct-literal construction (fail closed).
        return 0 - 1;
    }
    0 - 1
}

// Walk a block's statement list: each `let` flattens its init and binds the
// let-name span -> the init's root slot in the let-env; the FINAL statement is the
// trailing expression, flattened and its root slot returned (the fn ret slot).
// Returns the trailing expr's root slot, or -1 on any wall (a non-let / non-final
// statement, a let-init that doesn't flatten, or an unsupported trailing expr).
pub fn flatten_stmts(stmts_addr: i64, stmts_len: i64, i: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if i + 1 >= stmts_len {
        // Final statement = the trailing value expression.
        return flatten_ast_le(stmt, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    // Non-final statements must be `let` bindings.
    if ast_kind(stmt) != ast_let() {
        return 0 - 1;
    }
    let init: i64 = ast_child2(stmt);
    let slot: i64 = flatten_ast_le(init, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if slot < 0 {
        return 0 - 1;
    }
    let name_leaf: i64 = ast_child0(stmt);
    let j: i64 = __mind_load_i64(lcount);
    __mind_store_i64(lenv + j * 24 + 0, ast_span_lo(name_leaf));
    __mind_store_i64(lenv + j * 24 + 8, ast_span_hi(name_leaf));
    __mind_store_i64(lenv + j * 24 + 16, slot);
    __mind_store_i64(lcount, j + 1);
    flatten_stmts(stmts_addr, stmts_len, i + 1, buf, params_addr, n_params, nodes, cursor, lenv, lcount)
}

// AST-driven driver for multi-statement (let-bound) bodies: flatten the whole
// statement sequence into the 4f descriptor, then emit byte-exact via the proven
// emit_mic3_tree_fn_module. Fails closed (returns the seed state `s`) on any wall.
pub fn emit_mic3_let_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let root: i64 = flatten_stmts(stmts_addr, stmts_len, 0, src, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4i): lex+parse `src`, find the first fn_def, walk its full
// body statement list (let bindings + trailing expr), and emit mic@3 — byte-exact
// vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied CONTIGUOUS
// string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf`
// are heap scratch sized to the body node count; `lenv`/`lcount` are the let-env
// scratch (lenv: n_lets*24 bytes; lcount: 1 i64).
pub fn selftest_mic3_let_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    emit_mic3_let_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, stmts_addr, stmts_len, nodes, cursor, vidbuf, lenv, lcount)
}

// ===========================================================================
// Phase 4j — IF-EXPRESSION as a value (the control-flow frontier)
// ===========================================================================
//
// `if cond { then } else { else }` used as a value lowers to ONE top-level body
// instruction: OP_IF (0x1C). Decoded byte-for-byte from the Rust --emit-mic3
// oracle (src/ir/compact/v3/emit.rs Instr::If arm + src/eval/lower.rs):
//
//   OP_IF(0x1C)
//     vid(cond_id)
//     uleb(cond_instrs.len) || cond_instrs...
//     uleb(then_instrs.len) || then_instrs...
//     vid(then_result)
//     uleb(else_instrs.len) || else_instrs...
//     vid(else_result)
//     vid(dst)
//     encode_named_vids(branch_bindings)   // uleb(count) || (str,vid)*
//     encode_vid_triples(merges)           // uleb(count) || (vid,vid,vid)*
//
// VID THREADING (decoded; params own vids 0..n-1, the counter starts at n):
//   * cond: its NON-param nodes take vids n, n+1, ... (params re-use their own
//     vid, emit NO sub-instr). cond_id = cond's root vid. No synth const.
//   * then: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1406),
//     then the then-expr's non-param nodes. then_result = then-expr's root vid.
//   * else: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1476),
//     then the else-expr's non-param nodes. else_result = else-expr's root vid.
//   * dst = the next free vid after both branches (the if's value / ret_vid).
//
// SCOPE (the SMALLEST canary-safe increment): cond / then-expr / else-expr are
// each a param/const/binop tree (the same construct flatten_ast already lowers),
// the else clause is PRESENT, and neither branch writes an outer var or binds a
// branch-local let — so branch_bindings and merges are BOTH empty (count 0).
// Let-in-branch, no-else, and nested if are later 4j sub-steps. This path is
// ISOLATED from the canary (exported only via selftest_mic3_if_fn); the
// AST-driven body emitter still rejects ast_if (flatten_ast/flatten_ast_le
// return -1), so the fixed point stays byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Count the non-param nodes a param/const/binop tree flattens to (= CONST leaves
// + BINOP nodes). Params contribute 0 (they re-use their own vid, no sub-instr).
// Returns -1 on any unsupported construct (mirrors flatten_ast's rejection set).
pub fn count_nonparam_nodes(node: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        return 0;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_nonparam_nodes(ast_child1(node), buf, params_addr, n_params);
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    if k == ast_call() {
        // The call emits ONE instr (the OP_CALL). The structural callee-leaf and
        // arg-cons descriptor nodes emit nothing. Each arg contributes its own
        // non-param instrs (consts/binops/nested calls).
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let a: i64 = count_nonparam_args(args_addr, args_len, 0, buf, params_addr, n_params);
        if a < 0 {
            return 0 - 1;
        }
        return 1 + a;
    }
    if k == ast_neg() {
        // `-x` -> CONST 0 (1 instr) + `sub` binop (1 instr) + the operand's own instrs.
        let o: i64 = count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
        if o < 0 {
            return 0 - 1;
        }
        return 2 + o;
    }
    if k == ast_not() {
        // `!<int-literal>` fast path — the oracle collapses `!Lit(n)` to ONE ConstI64,
        // so the pre-count must be 1 (not 2 + operand's 1). Mirror flatten_ast exactly.
        if ast_kind(ast_child0(node)) == ast_int_lit() {
            return 1;
        }
        // `!x` -> CONST 0 (1 instr) + `==` binop (1 instr) + the operand's own instrs.
        // Parallels the ast_neg arm and the base flatten_ast ast_not desugar so the
        // pre-count agrees with the flattener (no buffer under-allocation).
        let o: i64 = count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
        if o < 0 {
            return 0 - 1;
        }
        return 2 + o;
    }
    0 - 1
}

// Sum the non-param instr counts of a call's arguments (left-to-right).
pub fn count_nonparam_args(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let c: i64 = count_nonparam_nodes(arg, buf, params_addr, n_params);
    if c < 0 {
        return 0 - 1;
    }
    let rest: i64 = count_nonparam_args(args_addr, args_len, idx + 1, buf, params_addr, n_params);
    if rest < 0 {
        return 0 - 1;
    }
    c + rest
}

// ===========================================================================
// LET-VID-aware flatten (6c prep) — then-block let bindings via kind-0 leaves
// ===========================================================================
//
// A then-block local `let NAME = INIT` resolves a later reference to NAME to the
// let's value VID. We carry an lv-environment: a scratch buffer of 24-byte records
// [name_lo, name_hi, vid]; `nlv` holds the count. A reference span that matches a
// recorded name (lvenv_lookup >= 0) emits a KIND-0 LEAF whose +8 field = the let's
// recorded vid — exactly how flatten_ast emits a param leaf (kind-0, +8=pidx), but
// carrying the let's vid instead of the param index. A kind-0 leaf emits NO
// instruction and contributes its +8 value as the vid in tree_resolve_vids_base /
// emit_mic3_tree_body. Every other arm is IDENTICAL to flatten_ast and recurses via
// flatten_ast_lv. With nlv == 0 lvenv_lookup never matches, so flatten_ast_lv,
// flatten_argcons_lv, flatten_branch_lv, count_nonparam_nodes_lv and
// count_nonparam_args_lv are BYTE-FOR-BYTE equivalent to their non-lv counterparts
// (Bound by MIND-CONSTITUTION §I — this prep is byte-identical until an lv-env is
// actually populated by 6c-2).

// Resolve an ident span against the lv-environment. Returns the bound vid, or -1 if
// the name is not an lv-bound variable. Records are [name_lo, name_hi, vid] (24B).
pub fn lvenv_lookup(src: i64, lo: i64, hi: i64, lvenv: i64, nlv: i64, i: i64) -> i64 {
    if i >= nlv {
        return 0 - 1;
    }
    // Return the INNERMOST (highest-index) binding so a then-block let shadows a
    // same-named outer (sequence-level) let — lexical scoping. The lv-env is laid out
    // [outer seq lets ... | inner then-block lets], so recurse to the deepest match
    // first and prefer it; only fall back to this index's binding when none is deeper.
    // (scan binds `kind`/`next_toks` both at the sequence level AND inside the is_alpha
    // then-block; a first-match search would wrongly pick the forward-defined outer one.)
    let deeper: i64 = lvenv_lookup(src, lo, hi, lvenv, nlv, i + 1);
    if deeper >= 0 {
        return deeper;
    }
    let nlo: i64 = __mind_load_i64(lvenv + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(lvenv + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return __mind_load_i64(lvenv + i * 24 + 16);
    }
    0 - 1
}

// Descriptor-node emit helpers (write one node into nodes[cursor], advance cursor, return
// its slot). Kinds: 2=CONST, 1=BINOP(op byte + l/r slots), 4=arg-cons(arg slot + next),
// 5=callee-leaf(name span), 3=CALL(callee slot + first-cons slot). Match flatten_ast_lv.
pub fn desc_emit_const(nodes: i64, cursor: i64, val: i64) -> i64 {
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 2);
    __mind_store_i64(nodes + slot * 32 + 8, val);
    __mind_store_i64(nodes + slot * 32 + 16, 0);
    __mind_store_i64(nodes + slot * 32 + 24, 0);
    __mind_store_i64(cursor, slot + 1);
    slot
}
pub fn desc_emit_binop(nodes: i64, cursor: i64, op_byte: i64, l: i64, r: i64) -> i64 {
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 1);
    __mind_store_i64(nodes + slot * 32 + 8, op_byte);
    __mind_store_i64(nodes + slot * 32 + 16, l);
    __mind_store_i64(nodes + slot * 32 + 24, r);
    __mind_store_i64(cursor, slot + 1);
    slot
}
pub fn desc_emit_call1(nodes: i64, cursor: i64, clo: i64, chi: i64, arg0: i64) -> i64 {
    let cons0: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + cons0 * 32 + 0, 4);
    __mind_store_i64(nodes + cons0 * 32 + 8, 0);
    __mind_store_i64(nodes + cons0 * 32 + 16, arg0);
    __mind_store_i64(nodes + cons0 * 32 + 24, 0);
    __mind_store_i64(cursor, cons0 + 1);
    let cleaf: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + cleaf * 32 + 0, 5);
    __mind_store_i64(nodes + cleaf * 32 + 8, clo);
    __mind_store_i64(nodes + cleaf * 32 + 16, chi);
    __mind_store_i64(nodes + cleaf * 32 + 24, 0);
    __mind_store_i64(cursor, cleaf + 1);
    let call: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + call * 32 + 0, 3);
    __mind_store_i64(nodes + call * 32 + 8, 0);
    __mind_store_i64(nodes + call * 32 + 16, cleaf);
    __mind_store_i64(nodes + call * 32 + 24, cons0);
    __mind_store_i64(cursor, call + 1);
    call
}
pub fn desc_emit_call2(nodes: i64, cursor: i64, clo: i64, chi: i64, arg0: i64, arg1: i64) -> i64 {
    let vcons: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + vcons * 32 + 0, 4);
    __mind_store_i64(nodes + vcons * 32 + 8, 0);
    __mind_store_i64(nodes + vcons * 32 + 16, arg1);
    __mind_store_i64(nodes + vcons * 32 + 24, 0);
    __mind_store_i64(cursor, vcons + 1);
    let acons: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + acons * 32 + 0, 4);
    __mind_store_i64(nodes + acons * 32 + 8, 0);
    __mind_store_i64(nodes + acons * 32 + 16, arg0);
    __mind_store_i64(nodes + acons * 32 + 24, vcons);
    __mind_store_i64(cursor, acons + 1);
    let cleaf: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + cleaf * 32 + 0, 5);
    __mind_store_i64(nodes + cleaf * 32 + 8, clo);
    __mind_store_i64(nodes + cleaf * 32 + 16, chi);
    __mind_store_i64(nodes + cleaf * 32 + 24, 0);
    __mind_store_i64(cursor, cleaf + 1);
    let call: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + call * 32 + 0, 3);
    __mind_store_i64(nodes + call * 32 + 8, 0);
    __mind_store_i64(nodes + call * 32 + 16, cleaf);
    __mind_store_i64(nodes + call * 32 + 24, acons);
    __mind_store_i64(cursor, call + 1);
    call
}

// Lower a struct-lit EXPRESSION into existing descriptor kinds: `8*nf -> __mind_alloc`
// (the ROOT = the struct handle) then, per declared field in order, the field VALUE tree,
// the field ADDR (alloc for field 0, else alloc + idx*8), and a `__mind_store_i64(addr,
// value)` CALL. Reads the resolved alloc/store spans + def-ordered field-value nodes from
// the node's +56 annotation (set by the nfn struct-lit prefold) — no srt/span threading.
// Returns the alloc slot, or -1 if unannotated / a field value fails to flatten.
pub fn flatten_struct_lit_lv(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64) -> i64 {
    let ann: i64 = __mind_load_i64(node + 56);
    if ann == 0 {
        return 0 - 1;
    }
    let alo: i64 = __mind_load_i64(ann + 0);
    let ahi: i64 = __mind_load_i64(ann + 8);
    let slo: i64 = __mind_load_i64(ann + 16);
    let shi: i64 = __mind_load_i64(ann + 24);
    let values: i64 = __mind_load_i64(ann + 32);
    let nf: i64 = ast_aux(node);
    let c8: i64 = desc_emit_const(nodes, cursor, 8);
    let cnf: i64 = desc_emit_const(nodes, cursor, nf);
    let mul: i64 = desc_emit_binop(nodes, cursor, binop_to_byte(op_mul()), c8, cnf);
    let alloc_slot: i64 = desc_emit_call1(nodes, cursor, alo, ahi, mul);
    let ok: i64 = slit_emit_field_stores(buf, params_addr, n_params, nodes, cursor, lvenv, nlv, values, nf, alloc_slot, slo, shi, 0);
    if ok == 0 {
        return 0 - 1;
    }
    alloc_slot
}
pub fn slit_emit_field_stores(buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64, values: i64, nf: i64, alloc_slot: i64, slo: i64, shi: i64, j: i64) -> i64 {
    if j >= nf {
        return 1;
    }
    let val_slot: i64 = flatten_ast_lv(__mind_load_i64(values + j * 8), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if val_slot < 0 {
        return 0;
    }
    let addr_slot: i64 = if j == 0 {
        alloc_slot
    } else {
        let coff: i64 = desc_emit_const(nodes, cursor, j * 8);
        desc_emit_binop(nodes, cursor, binop_to_byte(op_add()), alloc_slot, coff)
    };
    let _st: i64 = desc_emit_call2(nodes, cursor, slo, shi, addr_slot, val_slot);
    slit_emit_field_stores(buf, params_addr, n_params, nodes, cursor, lvenv, nlv, values, nf, alloc_slot, slo, shi, j + 1)
}

// Exactly flatten_ast, except an ident found in the lv-env (lvenv_lookup >= 0) emits
// a KIND-0 leaf carrying the let's vid in +8 (mirroring the param-leaf shape). All
// other arms identical, recursing via flatten_ast_lv.
pub fn flatten_ast_lv(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_ast_lv(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    }
    if k == ast_ident() {
        // A `let` SHADOWS a same-named param within its scope, so resolve the lv-env (lets in
        // scope at this position) BEFORE params; fall back to params. For a non-shadow ident
        // exactly one side matches, so the order is immaterial; and a let's init lv-env excludes
        // the let itself, so a self-referential `let p = p + 1` still binds the param on the RHS.
        let lvid: i64 = lvenv_lookup(buf, ast_span_lo(node), ast_span_hi(node), lvenv, nlv, 0);
        if lvid >= 0 {
            let lslot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + lslot * 32 + 0, 0);
            __mind_store_i64(nodes + lslot * 32 + 8, lvid);
            __mind_store_i64(nodes + lslot * 32 + 16, 0);
            __mind_store_i64(nodes + lslot * 32 + 24, 0);
            __mind_store_i64(cursor, lslot + 1);
            return lslot;
        }
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 0);
        __mind_store_i64(nodes + slot * 32 + 8, idx);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_int_lit() {
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_ast_lv(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_ast_lv(ast_child1(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let first_cons: i64 = flatten_argcons_lv(args_addr, args_len, 0, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if first_cons < 0 {
            return 0 - 1;
        }
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_not() {
        // Unary logical NOT `!x` desugars to `x == 0` (operand, synth CONST 0, Eq
        // binop LAST) — mirrors the base flatten_ast ast_not arm, byte-identical vs
        // --emit-mic3. Additive: enables `!x` inside a let-value / module body.
        // `!<int-literal>` fast path — mirrors src/eval/lower.rs `!Lit(Int(n))` => a
        // single ConstI64((n == 0)); one const leaf, NOT operand+zero+Eq.
        let notop: i64 = ast_child0(node);
        if ast_kind(notop) == ast_int_lit() {
            let litv: i64 = if ast_child1(notop) == 1 {
                ast_child0(notop)
            } else {
                parse_int_span(buf, ast_span_lo(notop), ast_span_hi(notop), 0)
            };
            let cval: i64 = if litv == 0 {
                1
            } else {
                0
            };
            return desc_emit_const(nodes, cursor, cval);
        }
        let oslot: i64 = flatten_ast_lv(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if oslot < 0 {
            return 0 - 1;
        }
        let zslot: i64 = desc_emit_const(nodes, cursor, 0);
        return desc_emit_binop(nodes, cursor, binop_to_byte(op_eq()), oslot, zslot);
    }
    if k == ast_struct_lit() {
        return flatten_struct_lit_lv(node, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    }
    0 - 1
}

// flatten_argcons, recursing via flatten_ast_lv.
pub fn flatten_argcons_lv(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_ast_lv(arg, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons_lv(args_addr, args_len, idx + 1, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// flatten_branch, flattening via flatten_ast_lv (resets cursor, resolves vids).
pub fn flatten_branch_lv(expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64, lvenv: i64, nlv: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast_lv(expr, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// count_nonparam_nodes, where an lv-env ident counts as 0 (kind-0 leaf, like a param).
pub fn count_nonparam_nodes_lv(node: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_nonparam_nodes_lv(ast_child0(node), buf, params_addr, n_params, lvenv, nlv);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            let lvid: i64 = lvenv_lookup(buf, ast_span_lo(node), ast_span_hi(node), lvenv, nlv, 0);
            if lvid < 0 {
                return 0 - 1;
            }
            return 0;
        }
        return 0;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_nonparam_nodes_lv(ast_child0(node), buf, params_addr, n_params, lvenv, nlv);
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_nonparam_nodes_lv(ast_child1(node), buf, params_addr, n_params, lvenv, nlv);
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let a: i64 = count_nonparam_args_lv(args_addr, args_len, 0, buf, params_addr, n_params, lvenv, nlv);
        if a < 0 {
            return 0 - 1;
        }
        return 1 + a;
    }
    if k == ast_struct_lit() {
        // vid count = 4 (CONST 8 / CONST nf / BINOP mul / alloc CALL) + per field
        // (value_nonparam + (idx>0 ? 2 : 0) [CONST off + BINOP add] + 1 [store CALL]).
        let ann: i64 = __mind_load_i64(node + 56);
        if ann == 0 {
            return 0 - 1;
        }
        let fc: i64 = slit_count_fields(__mind_load_i64(ann + 32), ast_aux(node), buf, params_addr, n_params, lvenv, nlv, 0);
        if fc < 0 {
            return 0 - 1;
        }
        return 4 + fc;
    }
    0 - 1
}
pub fn slit_count_fields(values: i64, nf: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64, j: i64) -> i64 {
    if j >= nf {
        return 0;
    }
    let vc: i64 = count_nonparam_nodes_lv(__mind_load_i64(values + j * 8), buf, params_addr, n_params, lvenv, nlv);
    if vc < 0 {
        return 0 - 1;
    }
    let addr_extra: i64 = if j == 0 {
        0
    } else {
        2
    };
    let rest: i64 = slit_count_fields(values, nf, buf, params_addr, n_params, lvenv, nlv, j + 1);
    if rest < 0 {
        return 0 - 1;
    }
    vc + addr_extra + 1 + rest
}

// count_nonparam_args, recursing via count_nonparam_nodes_lv.
pub fn count_nonparam_args_lv(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let c: i64 = count_nonparam_nodes_lv(arg, buf, params_addr, n_params, lvenv, nlv);
    if c < 0 {
        return 0 - 1;
    }
    let rest: i64 = count_nonparam_args_lv(args_addr, args_len, idx + 1, buf, params_addr, n_params, lvenv, nlv);
    if rest < 0 {
        return 0 - 1;
    }
    c + rest
}

// ===========================================================================
// Multi-statement LET CHAINS — substitution-based flatten (cutover construct)
// ===========================================================================
//
// A body `{ let n0: i64 = E0; let n1: i64 = E1; ... ; FINAL }` lowers BYTE-
// IDENTICAL to the fully-substituted nested expression (verified vs --emit-mic3:
// `f(x){let a=x+1; let b=a*2; b}` == `f(x){(x+1)*2}`). The Rust front-end treats
// sequential let-bindings as pure SSA aliasing — each let name takes the vid of
// its init expression's ROOT, and a later reference to that name reuses that vid
// with no extra instruction or string. We reproduce that by flattening every let
// init and the trailing expression into ONE shared post-order descriptor array,
// carrying a let-environment (name-span -> root descriptor slot). An ident that
// names a previously-bound let resolves to that slot (reused, no new node) exactly
// as a param leaf is reused; params still resolve first. The resulting descriptor
// feeds the SAME proven tree_resolve_vids + emit_mic3_tree_body pair, so the body
// is byte-exact by construction (Bound by MIND-CONSTITUTION §I).
//
// The let-environment is a scratch buffer of 24-byte records [name_lo, name_hi,
// slot]; `nlets`-cell holds the count. Lookup compares the reference span to each
// recorded name span (both in `src`, via span_bytes_equal2). Source-level let names
// within one body are distinct (the Rust checker rejects shadowing in this subset),
// but the struct-lit STATEMENT desugar (slit_emit_ctor) synthesises multiple
// alloc-lets ALL named with the `__mind_alloc` source span — so two struct-lit ctors
// in one body produce two identically-named `__sl` bindings. Resolve to the INNERMOST
// (highest-index, most-recent) match so each ctor's stores reference ITS OWN alloc
// handle, not the first ctor's; mirrors lvenv_lookup's last-match rule.

// Resolve an ident span against the let-environment. Returns the bound descriptor
// slot, or -1 if the name is not a let-bound variable.
pub fn letenv_lookup(src: i64, lo: i64, hi: i64, env: i64, nlets: i64, i: i64) -> i64 {
    if i >= nlets {
        return 0 - 1;
    }
    // Recurse to the deepest (latest) binding first and prefer it; fall back to this
    // index only when none is later (a later same-named synthetic `__sl` shadows).
    let later: i64 = letenv_lookup(src, lo, hi, env, nlets, i + 1);
    if later >= 0 {
        return later;
    }
    let nlo: i64 = __mind_load_i64(env + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(env + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return __mind_load_i64(env + i * 24 + 16);
    }
    0 - 1
}

// Flatten ONE expression tree into the shared descriptor, resolving idents against
// (a) params, then (b) the let-environment. A param ident emits a kind-0 leaf (as
// flatten_ast). A let-bound ident emits NO node — it returns the let's recorded
// root slot (SSA-aliased reuse, matching the oracle). Returns the node's slot, or
// -1 on an unsupported construct (fail-closed, identical rejection set to
// flatten_ast plus an unbound ident).
pub fn flatten_expr_env(node: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_expr_env(ast_child0(node), src, params_addr, n_params, nodes, cursor, env, nlets);
    }
    if k == ast_ident() {
        let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(node), ast_span_hi(node));
        if pidx >= 0 {
            let slot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + slot * 32 + 0, 0);
            __mind_store_i64(nodes + slot * 32 + 8, pidx);
            __mind_store_i64(nodes + slot * 32 + 16, 0);
            __mind_store_i64(nodes + slot * 32 + 24, 0);
            __mind_store_i64(cursor, slot + 1);
            return slot;
        }
        // Not a param: must be a previously-bound let name (reuse its slot).
        let lslot: i64 = letenv_lookup(src, ast_span_lo(node), ast_span_hi(node), env, nlets, 0);
        return lslot;
    }
    if k == ast_int_lit() {
        // SYNTHETIC int-lit (field-read offset): child1==1 sentinel -> value in
        // child0 direct; real source int-lits have child1==0.
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(src, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_neg() {
        let neg_operand: i64 = ast_child0(node);
        // `-<int literal>` constant-folds to a single negative CONST (the oracle folds it;
        // a `0 - 10` desugar would over-emit). Only a non-literal `-x` desugars to `0 - x`.
        if ast_kind(neg_operand) == ast_int_lit() {
            let nlit: i64 = if ast_child1(neg_operand) == 1 {
                ast_child0(neg_operand)
            } else {
                parse_int_span(src, ast_span_lo(neg_operand), ast_span_hi(neg_operand), 0)
            };
            let cslot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + cslot * 32 + 0, 2);
            __mind_store_i64(nodes + cslot * 32 + 8, 0 - nlit);
            __mind_store_i64(nodes + cslot * 32 + 16, 0);
            __mind_store_i64(nodes + cslot * 32 + 24, 0);
            __mind_store_i64(cursor, cslot + 1);
            return cslot;
        }
        // `-x` -> `0 - x`: operand first, then a synthetic const-0 leaf, then a `sub` binop
        // (op byte 1) LAST with lhs=const0, rhs=operand. Mirrors flatten_ast's ast_neg arm so
        // a seq-let init `let u = -p` lowers byte-exactly. Additive (no unary neg in main.mind's
        // seq positions).
        let oslot: i64 = flatten_expr_env(neg_operand, src, params_addr, n_params, nodes, cursor, env, nlets);
        if oslot < 0 {
            return 0 - 1;
        }
        let zslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + zslot * 32 + 0, 2);
        __mind_store_i64(nodes + zslot * 32 + 8, 0);
        __mind_store_i64(nodes + zslot * 32 + 16, 0);
        __mind_store_i64(nodes + zslot * 32 + 24, 0);
        __mind_store_i64(cursor, zslot + 1);
        let nslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + nslot * 32 + 0, 1);
        __mind_store_i64(nodes + nslot * 32 + 8, 1);
        __mind_store_i64(nodes + nslot * 32 + 16, zslot);
        __mind_store_i64(nodes + nslot * 32 + 24, oslot);
        __mind_store_i64(cursor, nslot + 1);
        return nslot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_expr_env(ast_child0(node), src, params_addr, n_params, nodes, cursor, env, nlets);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_expr_env(ast_child1(node), src, params_addr, n_params, nodes, cursor, env, nlets);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        // Let-env-aware CALL fold — mirrors flatten_ast's ast_call arm exactly (the
        // call-cons pattern: each arg sub-tree post-order, then the arg-cons chain
        // [kind=4], then the callee leaf [kind=5], then the call node [kind=3] LAST
        // so it takes the final vid). Args resolve idents against params THEN the
        // let-env, so a let-ref flowing into a later call (e.g. `let a = g(x);
        // h(a, k)`) reuses the earlier call's vid with no new node — byte-exact vs
        // --emit-mic3 (Bound by MIND-CONSTITUTION §I).
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let first_cons: i64 = flatten_argcons_env(args_addr, args_len, 0, src, params_addr, n_params, nodes, cursor, env, nlets);
        if first_cons < 0 {
            return 0 - 1;
        }
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    0 - 1
}

// Let-env-aware arg-cons builder — the flatten_argcons counterpart that resolves a
// let-ref arg to its bound slot. Arg `i`'s expression flattens first (post-order),
// then this arg's cons node (kind=4, child0=arg-root-slot, child1=next-cons-slot).
// Returns the FIRST cons slot, 0 when args_len == 0, or -1 on an unsupported
// construct (fail-closed, no partial bytes).
pub fn flatten_argcons_env(args_addr: i64, args_len: i64, idx: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_expr_env(arg, src, params_addr, n_params, nodes, cursor, env, nlets);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons_env(args_addr, args_len, idx + 1, src, params_addr, n_params, nodes, cursor, env, nlets);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// Walk the body's let-statement sequence (stmts 0..stmts_len-1), flattening each
// let's init expression into the shared descriptor and recording its name -> root
// slot in the let-env. Each stmt before the last must be `let NAME: TYPE = INIT`
// where INIT is a param/const/binop/let-ref tree. Returns 1 on success (env and
// nodes filled, cursor advanced), 0 on any wall (a non-let stmt, or an init the
// flatten rejects). Threads through recursion; `nlets_cell` accumulates the count.
pub fn flatten_let_chain(src: i64, stmts_addr: i64, stmts_len: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets_cell: i64, i: i64) -> i64 {
    if i >= stmts_len - 1 {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return 0;
    }
    let name: i64 = ast_child0(stmt);
    let init: i64 = ast_child2(stmt);
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let root_slot: i64 = flatten_expr_env(init, src, params_addr, n_params, nodes, cursor, env, nlets);
    if root_slot < 0 {
        return 0;
    }
    __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
    __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
    __mind_store_i64(env + nlets * 24 + 16, root_slot);
    __mind_store_i64(nlets_cell, nlets + 1);
    flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, i + 1)
}

// Emit ONE fn's FN_DEF whose body is a multi-statement let chain (>1 stmts: a
// sequence of `let NAME = INIT` bindings then a trailing value expression, every
// init/expr a param/const/binop/let-ref tree). Substitution-equivalent to the
// nested expression, so byte-exact vs --emit-mic3. Writes 1 to ok_cell on success,
// 0 (fail-closed, returns seed `s`) on any wall.
pub fn emit_mic3_module_fndef_letchain(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, env: i64, nlets_cell: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    let chain_ok: i64 = flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, 0);
    if chain_ok == 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let final_expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    let root_slot: i64 = flatten_expr_env(final_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
    if root_slot < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    // tree_resolve_vids FILLS vidbuf (side effect) and returns vidbuf[last]. Take
    // root_vid from the FINAL EXPR's resolved slot instead: they coincide when the
    // trailing expr builds a node (its root IS the last node), but a BARE let-ref
    // trailing (e.g. the struct-lit desugar's `__sl` -> alloc ptr) reuses an earlier
    // slot and creates NO node, so vidbuf[last] would be the wrong (last-store) vid.
    let _fill: i64 = tree_resolve_vids(nodes, n_nodes, n_params, vidbuf, 0, n_params);
    let root_vid: i64 = __mind_load_i64(vidbuf + root_slot * 8);
    // body_len = n_params PARAM instrs + every non-param descriptor node (every
    // kind-1 BINOP + kind-2 CONST; kind-0 param leaves emit no body instr — they
    // are mirrored by the de-duplicated PARAM emission). Count non-param slots.
    let body_len: i64 = n_params + count_descriptor_nonparam(nodes, n_nodes, 0);
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, root_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_tree_body(s7, nodes, n_nodes, vidbuf, src, strbuf, offs, ncount, 0);
    __mind_store_i64(ok_cell, 1);
    s8
}

// Count the BODY-INSTR descriptor slots in nodes[0..n_nodes) — the number of body
// instrs the tree emits (each CONST / BINOP / CALL). Mirrors the body_len
// derivation. Param leaves (kind 0) emit via the PARAM pass, and the structural
// arg-cons (kind 4) / callee-leaf (kind 5) nodes of a call emit NOTHING (they are
// walked by the call node), so both are excluded — matching tree_resolve_vids's
// vid-skip. Without the 4/5 skip a call body over-counts body_len by 2 per call.
pub fn count_descriptor_nonparam(nodes: i64, n_nodes: i64, i: i64) -> i64 {
    if i >= n_nodes {
        return 0;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    if kind == 4 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    if kind == 5 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    1 + count_descriptor_nonparam(nodes, n_nodes, i + 1)
}

// Pass-1 vid resolution with an arbitrary non-param base. Identical to
// tree_resolve_vids except the non-param counter starts at `base` (instead of n):
// param leaf -> param index; CONST/BINOP -> base, base+1, .. in post-order.
// Returns the next free vid after this tree (so the caller can thread it onward).
pub fn tree_resolve_vids_base(nodes: i64, n_nodes: i64, vidbuf: i64, i: i64, base: i64) -> i64 {
    if i >= n_nodes {
        return base;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL — they emit no instr
    // and consume NO vid (mirror tree_resolve_vids). Without this, a call value in a
    // struct-lit field shifts the call's dst vid by +2 (callee-leaf + arg-cons).
    if kind == 4 {
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    if kind == 5 {
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    __mind_store_i64(vidbuf + i * 8, base);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base + 1)
}

// Flatten ONE branch/cond expression tree into a fresh descriptor (resets cursor),
// resolve its slot vids from `base`, and return the root slot's resolved vid (or
// -1 on a wall). On success `cursor` holds n_nodes and `vidbuf` is filled — the
// caller emits the branch's non-param instrs via emit_mic3_tree_body.
pub fn flatten_branch(expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast(expr, buf, params_addr, n_params, nodes, cursor);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Extract a block's single trailing expression. The minimal 4j branch is a block
// whose only statement is the value expression (stmts_len == 1). Returns the
// expr node, or -1 if the block has != 1 statement (a later 4j sub-step).
pub fn branch_single_expr(blk: i64) -> i64 {
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len != 1 {
        return 0 - 1;
    }
    __mind_load_i64(stmts_addr + 0)
}

// Emit the OP_IF body instruction (0x1C) for the simplest if-expression: cond /
// then-expr / else-expr are each a param/const/binop tree, else present, no
// branch writes (branch_bindings + merges both empty). Threads the vid counter
// through cond -> then(synth + tree) -> else(synth + tree) -> dst, byte-exact vs
// the oracle. Returns the post-OP_IF EmitState; the if's result vid is `dst`
// (the caller uses it as the FN_DEF ret_vid). On a wall returns the seed `s`
// unchanged and writes -1 to `okcell` so the caller fails closed.
// Like emit_mic3_if_instr but each branch DIVERGES: `if C { return A } else { return B }`.
// Each branch block = synth ConstI64 + the return-value tree + Return(value), so the THEN/ELSE
// length is value_nonparam + 2 (the extra Return; Return consumes no vid). then_result/
// else_result = the returned value vid. The trailing merge dst is still allocated (a phantom
// the oracle emits even though both branches diverge); empty bindings/merges. Byte-exact.
pub fn emit_mic3_if_both_return_instr(s: EmitState, cond_expr: i64, then_val: i64, else_val: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(then_val, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(then_val, buf, params_addr, n_params);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 2);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
    let s7r: EmitState = emit_mic3_return(s7, 1, then_root);
    let s8: EmitState = emit_uleb128(s7r, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch(else_val, buf, params_addr, n_params, nodes, cursor, vidbuf, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(cursor);
    let else_nonparam: i64 = count_nonparam_nodes(else_val, buf, params_addr, n_params);
    let s9: EmitState = emit_uleb128(s8, else_nonparam + 2);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_mic3_tree_body(s10, nodes, else_n, vidbuf, 0, 0, 0, 0, 0);
    let s11r: EmitState = emit_mic3_return(s11, 1, else_root);
    let s12: EmitState = emit_uleb128(s11r, else_root);
    let after_else: i64 = after_then + 1 + else_nonparam;
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// FN_DEF whose body is a single `if C { return A } else { return B }`. Probe for dst (= the
// phantom merge = the ret vid), then emit FN_DEF (ret=dst, body_len = n_params + 1 OP_IF).
pub fn emit_mic3_module_fndef_if_both_return(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, cond_expr: i64, then_val: i64, else_val: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_mic3_if_both_return_instr(es_new(), cond_expr, then_val, else_val, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, dst);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, n_params + 1);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_if_both_return_instr(s7, cond_expr, then_val, else_val, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    __mind_store_i64(ok_cell, 1);
    s8
}

pub fn emit_mic3_if_instr(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    // --- cond ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then: synth ConstI64(after_cond, 0) FIRST, then the then-expr tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(then_expr, buf, params_addr, n_params);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_uleb128(s7, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else: synth ConstI64(after_then, 0) FIRST, then the else-expr tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch(else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(cursor);
    let else_nonparam: i64 = count_nonparam_nodes(else_expr, buf, params_addr, n_params);
    let s9: EmitState = emit_uleb128(s8, else_nonparam + 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_mic3_tree_body(s10, nodes, else_n, vidbuf, 0, 0, 0, 0, 0);
    let s12: EmitState = emit_uleb128(s11, else_root);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- dst (the if's value) + empty branch_bindings + empty merges ---
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// Assemble the full mic@3 module of
//   pub fn <name>(p0,..,p(n-1)) -> i64 { if cond { then } else { else } }
// byte-exact vs the Rust --emit-mic3 oracle. The body is n PARAM instrs then the
// single OP_IF instr (body_len = n + 1); ret_vid = the if's dst. Mirrors
// emit_mic3_tree_fn_module's framing (header/strtab/next_id/exports/FN_DEF/tail).
// Fails closed (returns the seed `s`) on any wall.
pub fn emit_mic3_if_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, cond_expr: i64, then_expr: i64, else_expr: i64, src: i64, params_addr: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, param-pair list, ret Some %dst, reap None, body_len.
    // The ret_vid (dst) is only known after the OP_IF is emitted, so emit the body
    // into a SCRATCH EmitState first to learn dst + body bytes, then frame it.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_instr(es_new(), cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_instr(s12, cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j): lex+parse `src`, find the first fn_def whose body is
// a single `if cond { then } else { else }` expression, and emit its mic@3 module
// byte-exact vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied
// CONTIGUOUS string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/
// `cursor`/`vidbuf` are heap scratch sized to the LARGEST single branch's node
// count; `okcell` is a 1-i64 cell (holds dst on success, -1 on a wall).
pub fn selftest_mic3_if_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    // The fn body block's single trailing statement must be the if-expression.
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    let then_expr: i64 = branch_single_expr(then_blk);
    let else_expr: i64 = branch_single_expr(else_blk);
    if then_expr < 0 {
        return es_new();
    }
    if else_expr < 0 {
        return es_new();
    }
    emit_mic3_if_fn_module(es_new(), strbuf, offs, n_params, cond_expr, then_expr, else_expr, src_addr, params_addr, nodes, cursor, vidbuf, okcell)
}

// ===========================================================================
// Phase 4j+ — IF with MULTI-STATEMENT branch blocks + NON-EMPTY merges
// ===========================================================================
//
// The 4j path above handles `if cond { expr } else { expr }` where each branch is a
// SINGLE value expression — no branch writes, so branch_bindings and merges are
// empty. This step extends a branch to a STATEMENT SEQUENCE `{ let n: ty = init; ..;
// trailing }` (the same grammar Phase 4i already lowers for fn bodies). A branch-local
// `let` is a WRITE of that name, which the Rust oracle (src/eval/lower.rs ~1399-1611)
// turns into a NON-EMPTY merge phi set. Decoded byte-for-byte from --emit-mic3:
//
//   * Each branch flattens its statement list (lets + trailing) into its OWN
//     post-order descriptor with its OWN let-env (reusing flatten_stmts/flatten_ast_le).
//     The branch's non-param vids resolve from its per-branch base; a `let` records the
//     name -> its init's resolved vid (the merge "value" for that branch).
//   * VID THREADING: params 0..n-1; cond non-param from n; then = synth ConstI64(0)
//     then then-tree; else = synth ConstI64(0) then else-tree. AFTER both branches,
//     for each merged name (then-writes then else-writes, deduped first-seen): if a
//     branch does NOT define the name, a placeholder ConstI64(fresh, 0) is appended to
//     THAT branch's body (its vid allocated from the running parent counter), in the
//     order then-placeholder, else-placeholder, then merge_id. dst is the final fresh.
//   * branch_bindings = (name_strtab_idx, merge_id) per merged name; merges =
//     (merge_id, then_val, else_val) per merged name. The strtab carries the let-names
//     (after name+params, in encounter order). Verified byte-exact vs --emit-mic3:
//     f(a,b){if a{let t=a*b; t+1}else{b}}=81B, both-let=75B, else-let=73B, two-name=88B.
//
// ISOLATED from the canary (exported only via selftest_mic3_if_let_fn); the AST-driven
// body emitter still rejects ast_if, so the fixed point is byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Flatten ONE branch block (a statement list) into a fresh per-branch descriptor with
// its own let-env, resolve its non-param vids from `base`, and return the trailing
// expression's resolved vid (or -1 on a wall). On success: `cursor` holds n_nodes,
// `vidbuf` is filled, and the let-env (`lenv`/`lcount`) holds each let-name's span +
// its RESOLVED vid (slot rewritten to vid). The caller reads writes from the let-env.
pub fn flatten_branch_block(blk: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let root_slot: i64 = flatten_stmts(stmts_addr, stmts_len, 0, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    // Rewrite each let-env entry's stored SLOT to its resolved VID so the merge pass
    // can read a branch's per-name value directly.
    lenv_slots_to_vids(lenv, __mind_load_i64(lcount), vidbuf, 0);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Rewrite let-env entry slots (offset +16) in place from descriptor slot -> resolved
// vid (vidbuf[slot]). Called once after tree_resolve_vids_base fills vidbuf.
pub fn lenv_slots_to_vids(lenv: i64, n: i64, vidbuf: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let slot: i64 = __mind_load_i64(lenv + i * 24 + 16);
    __mind_store_i64(lenv + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    lenv_slots_to_vids(lenv, n, vidbuf, i + 1)
}

// Look up a name span in a branch's let-env: return its resolved vid (entry +16) or -1.
pub fn lenv_lookup_vid(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    lenv_lookup_vid(lenv, n, buf, lo, hi, i + 1)
}

// Find a name span's string-table index. The contiguous name buffer `strbuf`/`offs`
// holds [name, p0..p(n-1), let-names..]; entry j spans buf[offs[j]..offs[j+1]).
// Returns the matching index, or -1. (Used to fill branch_bindings' name_strtab_idx.)
pub fn strtab_index_of(strbuf: i64, offs: i64, count: i64, buf: i64, lo: i64, hi: i64, j: i64) -> i64 {
    if j >= count {
        return 0 - 1;
    }
    let slo: i64 = __mind_load_i64(offs + j * 8);
    let shi: i64 = __mind_load_i64(offs + (j + 1) * 8);
    if span_bytes_equal2(strbuf, slo, shi, buf, lo, hi) == 1 {
        return j;
    }
    strtab_index_of(strbuf, offs, count, buf, lo, hi, j + 1)
}

// Span-equality across TWO distinct buffers (span_bytes_equal compares within one buf).
pub fn span_bytes_equal2(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, bhi: i64) -> i64 {
    if ahi - alo != bhi - blo {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, 0)
}
pub fn span_bytes_equal2_loop(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        return 1;
    }
    if load_byte(a, alo + k) != load_byte(b, blo + k) {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, k + 1)
}

// Build the merged-name list as spans into `buf`: then-lenv entries first, then
// else-lenv entries not already present (first-seen dedup). `outspans` is a heap array
// of (lo,hi) i64 pairs; returns the merged count. Each branch's lenv holds name spans.
pub fn build_merged_names(t_lenv: i64, t_n: i64, e_lenv: i64, e_n: i64, buf: i64, outspans: i64) -> i64 {
    let c1: i64 = copy_lenv_spans(t_lenv, t_n, buf, outspans, 0, 0);
    merge_else_spans(e_lenv, e_n, buf, outspans, c1, 0)
}
pub fn copy_lenv_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return copy_lenv_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    copy_lenv_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn merge_else_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return merge_else_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    merge_else_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn span_in_list(buf: i64, lo: i64, hi: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= oc {
        return 0;
    }
    let elo: i64 = __mind_load_i64(outspans + i * 16 + 0);
    let ehi: i64 = __mind_load_i64(outspans + i * 16 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return 1;
    }
    span_in_list(buf, lo, hi, outspans, oc, i + 1)
}

// Emit the OP_IF body instruction with NON-EMPTY merges. Threads cond -> then(synth
// +block) -> else(synth+block) -> [per-name then/else placeholders + merge_ids] -> dst,
// byte-exact vs the oracle. The two branch blocks carry their own let-envs (already
// resolved to vids). `mspans`/`mcount` are filled with the merged-name spans. Writes
// dst to `okcell` on success; -1 on a wall (caller fails closed). `extra` is a heap
// scratch of i64s: per merged name we store (then_extra_vid, else_extra_vid, merge_id)
// = 3 i64 at extra + k*24, with -1 where a branch already defines the name.
pub fn emit_mic3_if_block_instr(s: EmitState, cond_expr: i64, then_blk: i64, else_blk: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, params_addr: i64, n_params: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let base0: i64 = n_params;
    // --- cond (single value expr; reuse flatten_branch into the cond descriptor) ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, c_nodes, c_cur, c_vid, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(c_cur);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then block: synth ConstI64(after_cond, 0), then the block tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch_block(then_blk, buf, params_addr, n_params, t_nodes, t_cur, t_vid, t_lenv, t_lc, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(t_cur);
    let then_nonparam: i64 = nonparam_count_desc(t_nodes, then_n, 0);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else block: synth ConstI64(after_then, 0), then the block tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch_block(else_blk, buf, params_addr, n_params, e_nodes, e_cur, e_vid, e_lenv, e_lc, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(e_cur);
    let else_nonparam: i64 = nonparam_count_desc(e_nodes, else_n, 0);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- merge pass: merged names, per-name placeholders + merge_ids from after_else ---
    let t_lcount: i64 = __mind_load_i64(t_lc);
    let e_lcount: i64 = __mind_load_i64(e_lc);
    let mn: i64 = build_merged_names(t_lenv, t_lcount, e_lenv, e_lcount, buf, mspans);
    __mind_store_i64(mcount, mn);
    let final_ctr: i64 = assign_merge_vids(mspans, mn, buf, t_lenv, t_lcount, e_lenv, e_lcount, extra, after_else, 0);
    let dst: i64 = final_ctr;

    // --- emit OP_IF ---
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, c_nodes, cond_n, c_vid, 0, 0, 0, 0, 0);
    // then: synth + tree + then-edge placeholders.
    let then_extra_count: i64 = count_then_extras(extra, mn, 0);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1 + then_extra_count);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, t_nodes, then_n, t_vid, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_extra_consts(s7, extra, mn, 0, 0);
    let s9: EmitState = emit_uleb128(s8, then_root);
    // else: synth + tree + else-edge placeholders.
    let else_extra_count: i64 = count_else_extras(extra, mn, 0);
    let s10: EmitState = emit_uleb128(s9, else_nonparam + 1 + else_extra_count);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_mic3_tree_body(s11, e_nodes, else_n, e_vid, 0, 0, 0, 0, 0);
    let s13: EmitState = emit_extra_consts(s12, extra, mn, 1, 0);
    let s14: EmitState = emit_uleb128(s13, else_root);
    // dst, branch_bindings, merges.
    let s15: EmitState = emit_uleb128(s14, dst);
    let s16: EmitState = emit_uleb128(s15, mn);
    let s17: EmitState = emit_branch_bindings(s16, mspans, mn, buf, strbuf, offs, strcount, extra, 0);
    let s18: EmitState = emit_uleb128(s17, mn);
    let s19: EmitState = emit_merges(s18, extra, mn, 0);
    __mind_store_i64(okcell, dst);
    s19
}

// Count non-param nodes in an already-flattened descriptor (kind != 0).
pub fn nonparam_count_desc(nodes: i64, n_nodes: i64, i: i64) -> i64 {
    if i >= n_nodes {
        return 0;
    }
    let k: i64 = __mind_load_i64(nodes + i * 32);
    if k == 0 {
        return nonparam_count_desc(nodes, n_nodes, i + 1);
    }
    1 + nonparam_count_desc(nodes, n_nodes, i + 1)
}

// For each merged name allocate (then_extra, else_extra, merge_id) from the running
// counter `ctr`. A branch that DEFINES the name contributes -1 for its extra slot (no
// placeholder); otherwise a fresh vid is allocated (the per-branch placeholder). Order
// per name: then_extra, else_extra, merge_id. Returns the next free vid (= dst).
pub fn assign_merge_vids(mspans: i64, mn: i64, buf: i64, t_lenv: i64, t_lc: i64, e_lenv: i64, e_lc: i64, extra: i64, ctr: i64, k: i64) -> i64 {
    if k >= mn {
        return ctr;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let in_then: i64 = lenv_lookup_vid(t_lenv, t_lc, buf, lo, hi, 0);
    let in_else: i64 = lenv_lookup_vid(e_lenv, e_lc, buf, lo, hi, 0);
    // then_extra (placeholder vid, or -1 if the then-branch defines the name)
    let c1: i64 = ctr;
    if in_then >= 0 {
        __mind_store_i64(extra + k * 40 + 0, 0 - 1)
    }
    if in_then < 0 {
        __mind_store_i64(extra + k * 40 + 0, c1)
    }
    let c2: i64 = next_ctr(c1, in_then);
    // else_extra
    if in_else >= 0 {
        __mind_store_i64(extra + k * 40 + 8, 0 - 1)
    }
    if in_else < 0 {
        __mind_store_i64(extra + k * 40 + 8, c2)
    }
    let c3: i64 = next_ctr(c2, in_else);
    // merge_id (always fresh)
    __mind_store_i64(extra + k * 40 + 16, c3);
    // +24/+32 = the DEFINED-branch let-vid (used by emit_merges when extra slot is -1).
    __mind_store_i64(extra + k * 40 + 24, in_then);
    __mind_store_i64(extra + k * 40 + 32, in_else);
    assign_merge_vids(mspans, mn, buf, t_lenv, t_lc, e_lenv, e_lc, extra, c3 + 1, k + 1)
}
// ctr advances by 1 only when the branch did NOT define the name (in_branch < 0).
pub fn next_ctr(ctr: i64, in_branch: i64) -> i64 {
    if in_branch < 0 {
        return ctr + 1;
    }
    ctr
}

// Count then-edge / else-edge placeholders (extra slots != -1).
pub fn count_then_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 0);
    if v < 0 {
        return count_then_extras(extra, mn, k + 1);
    }
    1 + count_then_extras(extra, mn, k + 1)
}
pub fn count_else_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 8);
    if v < 0 {
        return count_else_extras(extra, mn, k + 1);
    }
    1 + count_else_extras(extra, mn, k + 1)
}

// Emit the placeholder ConstI64(vid, 0) for each merged name on the given edge
// (edge 0 = then-extra at +0, edge 1 = else-extra at +8), in merged-name order.
pub fn emit_extra_consts(s: EmitState, extra: i64, mn: i64, edge: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let off: i64 = edge * 8;
    let v: i64 = __mind_load_i64(extra + k * 40 + off);
    if v < 0 {
        return emit_extra_consts(s, extra, mn, edge, k + 1);
    }
    let s1: EmitState = emit_mic3_const_i64(s, v, 0);
    emit_extra_consts(s1, extra, mn, edge, k + 1)
}

// branch_bindings: per merged name (string_idx, merge_id). The name span is looked up
// in the contiguous strtab buffer to find its index.
pub fn emit_branch_bindings(s: EmitState, mspans: i64, mn: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, extra: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let sidx: i64 = strtab_index_of(strbuf, offs, strcount, buf, lo, hi, 0);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_branch_bindings(s2, mspans, mn, buf, strbuf, offs, strcount, extra, k + 1)
}

// merges: per merged name (merge_id, then_val, else_val). then_val = the then-branch's
// value (its let-vid if defined, else the then-placeholder); symmetric for else_val.
pub fn emit_merges(s: EmitState, extra: i64, mn: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let then_extra: i64 = __mind_load_i64(extra + k * 40 + 0);
    let else_extra: i64 = __mind_load_i64(extra + k * 40 + 8);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    // then_val: placeholder vid if extra set, else the resolved let-vid (stored at +24).
    let then_val: i64 = merge_val(then_extra, extra, k, 24);
    let else_val: i64 = merge_val(else_extra, extra, k, 32);
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = emit_uleb128(s1, then_val);
    let s3: EmitState = emit_uleb128(s2, else_val);
    emit_merges(s3, extra, mn, k + 1)
}
pub fn merge_val(extra_vid: i64, extra: i64, k: i64, off: i64) -> i64 {
    if extra_vid >= 0 {
        return extra_vid;
    }
    __mind_load_i64(extra + k * 40 + off)
}

// Assemble the full mic@3 module for
//   pub fn <name>(p0,..) -> i64 { if cond { <block> } else { <block> } }
// with non-empty merges, byte-exact vs --emit-mic3. `strcount` = n+1+n_letnames (the
// full string-table count: name, params, then branch-local let-names in encounter
// order). The body is n PARAM instrs then ONE OP_IF (body_len = n + 1).
pub fn emit_mic3_if_block_fn_module(s: EmitState, buf: i64, offs: i64, strcount: i64, n: i64, cond_expr: i64, then_blk: i64, else_blk: i64, src: i64, params_addr: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, strcount);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // Scratch pass to learn dst (the FN_DEF ret_vid) before framing.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_block_instr(es_new(), cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_block_instr(s12, cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j+): lex+parse `src`, find the first fn whose body is a
// single `if cond { block } else { block }` where a branch may be a multi-statement
// (let-bound) block, and emit its mic@3 module byte-exact vs --emit-mic3. `strbuf`/
// `offs`/`strcount` are the caller-supplied CONTIGUOUS string table (name, params,
// branch let-names in encounter order). All `*_nodes`/`*_cur`/`*_vid`/`*_lenv`/`*_lc`
// are per-branch heap scratch; `mspans` (merged-name spans), `mcount`, `extra`
// (per-name vid triples + values), `okcell` are merge scratch.
pub fn selftest_mic3_if_block_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, strcount: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    // Record the merge name-values into extra +24/+32 from the resolved let-envs: we
    // need a branch's per-name value (its let-vid). emit_mic3_if_block_instr fills
    // extra +0/+8/+16; the +24/+32 (then_val/else_val for defined names) are filled
    // by the binding pass via the let-envs. To keep merge_val simple, stash them here
    // after the scratch emit re-runs the merge — done inside the module emitter.
    emit_mic3_if_block_fn_module(es_new(), strbuf, offs, strcount, n_params, cond_expr, then_blk, else_blk, src_addr, params_addr, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell)
}

// ===== Fixed-literal writers =====

pub fn emit_lit_module_open(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 109);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 100);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 108);
    let s6: EmitState = es_push(s5, 101);
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, ch_lbrace());
    es_push(s8, ch_newline())
}

pub fn emit_lit_fn_comment_head(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_slash());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, 102);
    let s7: EmitState = es_push(s6, 110);
    es_push(s7, ch_space())
}

pub fn emit_lit_const_i64_head(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_percent());
    let s4: EmitState = emit_i64(s3, id);
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, ch_eq_sign());
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, 99);
    let s9: EmitState = es_push(s8, 111);
    let s10: EmitState = es_push(s9, 110);
    let s11: EmitState = es_push(s10, 115);
    let s12: EmitState = es_push(s11, 116);
    let s13: EmitState = es_push(s12, ch_dot());
    let s14: EmitState = es_push(s13, 105);
    let s15: EmitState = es_push(s14, 54);
    let s16: EmitState = es_push(s15, 52);
    es_push(s16, ch_space())
}

pub fn emit_lit_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, 111);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 116);
    let s6: EmitState = es_push(s5, 112);
    let s7: EmitState = es_push(s6, 117);
    let s8: EmitState = es_push(s7, 116);
    let s9: EmitState = es_push(s8, ch_space());
    let s10: EmitState = es_push(s9, ch_percent());
    let s11: EmitState = emit_i64(s10, id);
    es_push(s11, ch_newline())
}

// If-line literal fragments — the mic@1 text spelling of the flat If op
// `%dst = if cond=%c then=%t else=%e` (matches src/ir/print.rs).
pub fn emit_if_kw(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 105);
    es_push(s1, 102)
}
pub fn emit_cond_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 99);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 110);
    let s4: EmitState = es_push(s3, 100);
    es_push(s4, ch_eq_sign())
}
pub fn emit_then_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 116);
    let s2: EmitState = es_push(s1, 104);
    let s3: EmitState = es_push(s2, 101);
    let s4: EmitState = es_push(s3, 110);
    es_push(s4, ch_eq_sign())
}
pub fn emit_else_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 101);
    let s2: EmitState = es_push(s1, 108);
    let s3: EmitState = es_push(s2, 115);
    let s4: EmitState = es_push(s3, 101);
    es_push(s4, ch_eq_sign())
}

pub fn emit_lit_module_close(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_rbrace());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_slash());
    let s6: EmitState = es_push(s5, ch_space());
    let s7: EmitState = es_push(s6, 110);
    let s8: EmitState = es_push(s7, 101);
    let s9: EmitState = es_push(s8, 120);
    let s10: EmitState = es_push(s9, 116);
    let s11: EmitState = es_push(s10, 95);
    let s12: EmitState = es_push(s11, 105);
    let s13: EmitState = es_push(s12, 100);
    let s14: EmitState = es_push(s13, ch_space());
    let s15: EmitState = es_push(s14, ch_eq_sign());
    let s16: EmitState = es_push(s15, ch_space());
    let s17: EmitState = emit_i64(s16, s.next_id);
    es_push(s17, ch_newline())
}

pub fn emit_op_mnemonic(s: EmitState, op: i64) -> EmitState {
    if op == op_add() {
        let s1: EmitState = es_push(s, 97);
        let s2: EmitState = es_push(s1, 100);
        return es_push(s2, 100);
    }
    if op == op_sub() {
        let s1: EmitState = es_push(s, 115);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 98);
    }
    if op == op_mul() {
        let s1: EmitState = es_push(s, 109);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 108);
    }
    if op == op_div() {
        let s1: EmitState = es_push(s, 100);
        let s2: EmitState = es_push(s1, 105);
        return es_push(s2, 118);
    }
    if op == op_lt() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 116);
    }
    if op == op_gt() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 116);
    }
    if op == op_eq() {
        let s1: EmitState = es_push(s, 101);
        return es_push(s1, 113);
    }
    if op == op_le() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 101);
    }
    if op == op_ge() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 101);
    }
    if op == op_ne() {
        let s1: EmitState = es_push(s, 110);
        return es_push(s1, 101);
    }
    let s1: EmitState = es_push(s, 63);
    es_push(s1, 63)
}

// ===== Integer-literal value parsing =====

pub fn parse_int_span(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    parse_int_span(buf, lo + 1, hi, acc * 10 + (b - 48))
}

// ===== Expression lowering =====

pub fn emit_expr(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_ident() {
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_binop() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr(s1, buf, ast_child1(node));
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }

    if k == ast_paren() {
        return emit_expr(s, buf, ast_child0(node));
    }

    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args(s, buf, args_addr, args_len, 0);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

pub fn emit_call_args(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr(s, buf, arg_node);
    emit_call_args(s1, buf, args_addr, args_len, i + 1)
}

// ===== Statement lowering =====

pub fn emit_stmt(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return emit_expr(s, buf, ast_child2(node));
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let s2: EmitState = emit_lit_output(s1, s1.last_id);
        return s2;
    }
    emit_expr(s, buf, node)
}

pub fn emit_block_stmts(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt(s, buf, stmt_node);
    emit_block_stmts(s1, buf, stmts_addr, stmts_len, i + 1)
}

// ===== Function definition lowering =====

pub fn emit_fn_def(s: EmitState, buf: i64, node: i64) -> EmitState {
    let name_node: i64 = ast_child0(node);
    let name_lo: i64 = ast_span_lo(name_node);
    let name_hi: i64 = ast_span_hi(name_node);
    let s1: EmitState = emit_lit_fn_comment_head(s);
    let s2: EmitState = emit_byte_range(s1, buf, name_lo, name_hi);
    let s3: EmitState = es_push(s2, ch_newline());

    let id: i64 = s3.next_id;
    let s4: EmitState = emit_lit_const_i64_head(s3, id);
    let s5: EmitState = es_push(s4, 48);
    let s6: EmitState = es_push(s5, ch_newline());
    let s7: EmitState = EmitState { buf: s6.buf, next_id: id + 1, last_id: id, lets: s6.lets };
    emit_lit_output(s7, id)
}

// ===== Real-body lowering (param-resolving) — additive, isolated from the
//       canary path (mindc_compile->lower_program->emit_fn_def stays stubbed).
//       Resolves a parameter NAME to its SSA id (param i == %i), so function
//       bodies emit real ops (`%2 = add %0, %1` / `output %2`) instead of a
//       const.i64-0 placeholder. =====

// 1 if buf[alo..ahi] equals buf[blo..bhi] byte-for-byte, else 0.
pub fn span_bytes_equal(buf: i64, alo: i64, ahi: i64, blo: i64, bhi: i64) -> i64 {
    if (ahi - alo) == (bhi - blo) {
        span_bytes_equal_loop(buf, alo, ahi, blo, 0)
    } else {
        0
    }
}
pub fn span_bytes_equal_loop(buf: i64, alo: i64, ahi: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        1
    } else {
        if load_byte(buf, alo + k) == load_byte(buf, blo + k) {
            span_bytes_equal_loop(buf, alo, ahi, blo, k + 1)
        } else {
            0
        }
    }
}

// Return the SSA id (== param index) for the identifier buf[lo..hi] if it names
// a parameter of `params` (a block of ast_param nodes), else -1.
pub fn resolve_param(params_addr: i64, n_params: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_param_loop(buf, lo, hi, params_addr, n_params, 0)
}
pub fn resolve_param_loop(buf: i64, lo: i64, hi: i64, addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0 - 1
    } else {
        let pnode: i64 = __mind_load_i64(addr + i * 8);
        let name_leaf: i64 = ast_child0(pnode);
        if span_bytes_equal(buf, lo, hi, ast_span_lo(name_leaf), ast_span_hi(name_leaf)) == 1 {
            i
        } else {
            resolve_param_loop(buf, lo, hi, addr, n, i + 1)
        }
    }
}

// Expression lowering with a parameter environment. Identical to emit_expr
// except the ident branch resolves a param to its %SSA id (no instruction).
// Lower an if's else-branch into a scratch EmitState seeded at `else_seed`
// (the seed const id, consumed by Rust's else_ir.fresh()).  When there is no
// else clause (`else_blk == 0`) the seed const IS the else result, so we just
// return a scratch state whose last_id is the seed.  Otherwise we lower the
// else-block statements and return their trailing-value state.  The scratch
// buffer is discarded by the caller (the sub-stream ops are not printed in
// mic@1 text — see src/ir/print.rs Instr::If).
pub fn emit_if_else_branch(else_blk: i64, buf: i64, else_seed: i64, params_addr: i64, n_params: i64, lets: Map) -> EmitState {
    let sc: EmitState = EmitState { buf: string_new(), next_id: else_seed + 1, last_id: else_seed, lets: lets };
    if else_blk == 0 {
        return sc;
    }
    emit_block_stmts_env(sc, buf, ast_child0(else_blk), ast_aux(else_blk), 0, params_addr, n_params)
}

pub fn emit_expr_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: idx, lets: s.lets };
        }
        let lid: i64 = env_lookup(s.lets, buf, ast_span_lo(node), ast_span_hi(node));
        if lid != ty_unknown() {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: lid - 1, lets: s.lets };
        }
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_binop() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr_env(s1, buf, ast_child1(node), params_addr, n_params);
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_paren() {
        return emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    }
    if k == ast_neg() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_sub());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, c0);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, operand_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_not() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_eq());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, operand_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, c0);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_if() {
        // mic@1 If lowering — matches the Rust front-end (src/eval/lower.rs
        // ast::Node::If) and its print.rs text form: the condition, then-branch
        // and else-branch each lower into a hidden sub-stream, so the only
        // VISIBLE instruction in mic@1 text is the flat
        //   %dst = if cond=%c then=%t else=%e
        // line.  The sub-streams still consume SSA ids (each branch begins with
        // a `const.i64 0` seed via ir.fresh()), so we thread next_id through
        // scratch EmitStates to keep the dst id byte-identical to Rust, but we
        // discard their buffers (the sub-stream ops are not printed).
        let cond_node: i64 = ast_child0(node);
        let then_blk: i64 = ast_child1(node);
        let else_blk: i64 = ast_child2(node);

        // 1. Condition: lower into a scratch buffer seeded at the current id.
        let sc_cond: EmitState = EmitState { buf: string_new(), next_id: s.next_id, last_id: 0 - 1, lets: s.lets };
        let r_cond: EmitState = emit_expr_env(sc_cond, buf, cond_node, params_addr, n_params);
        let cond_id: i64 = r_cond.last_id;

        // 2. Then-branch: ir.fresh() seed const (consumed, not printed), then
        //    lower the block; then_result is the trailing value.
        let then_seed: i64 = r_cond.next_id;
        let sc_then: EmitState = EmitState { buf: string_new(), next_id: then_seed + 1, last_id: then_seed, lets: s.lets };
        let r_then: EmitState = emit_block_stmts_env(sc_then, buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params);
        let then_id: i64 = r_then.last_id;

        // 3. Else-branch: ir.fresh() seed const, then lower the block (or, when
        //    there is no else clause, the seed const IS the else result).
        let else_seed: i64 = r_then.next_id;
        let r_else: EmitState = emit_if_else_branch(else_blk, buf, else_seed, params_addr, n_params, s.lets);
        let else_id: i64 = r_else.last_id;

        // 4. dst = ir.fresh().
        let dst: i64 = r_else.next_id;

        // 5. Emit the single visible flat If line into the real buffer.
        let e1: EmitState = es_push(s, ch_space());
        let e2: EmitState = es_push(e1, ch_space());
        let e3: EmitState = es_push(e2, ch_percent());
        let e4: EmitState = emit_i64(e3, dst);
        let e5: EmitState = es_push(e4, ch_space());
        let e6: EmitState = es_push(e5, ch_eq_sign());
        let e7: EmitState = es_push(e6, ch_space());
        let e8: EmitState = emit_if_kw(e7);
        let e9: EmitState = es_push(e8, ch_space());
        let e10: EmitState = emit_cond_eq(e9);
        let e11: EmitState = es_push(e10, ch_percent());
        let e12: EmitState = emit_i64(e11, cond_id);
        let e13: EmitState = es_push(e12, ch_space());
        let e14: EmitState = emit_then_eq(e13);
        let e15: EmitState = es_push(e14, ch_percent());
        let e16: EmitState = emit_i64(e15, then_id);
        let e17: EmitState = es_push(e16, ch_space());
        let e18: EmitState = emit_else_eq(e17);
        let e19: EmitState = es_push(e18, ch_percent());
        let e20: EmitState = emit_i64(e19, else_id);
        let e21: EmitState = es_push(e20, ch_newline());
        return EmitState { buf: e21.buf, next_id: dst + 1, last_id: dst, lets: e21.lets };
    }
    if k == ast_field() {
        // mic@1 FieldAccess lowering — matches the Rust front-end
        // (src/eval/lower.rs ast::Node::FieldAccess) `None` arm: when the
        // receiver's struct type is unresolvable, the whole access lowers to a
        // single `const.i64 0` (the receiver is NOT re-lowered on that arm).
        // The bootstrap parser tracks no struct field-name order, so every
        // field access lands on the `None` arm and lowers to exactly one const.
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args_env(s, buf, args_addr, args_len, 0, params_addr, n_params);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

// Env-aware call-argument lowering: like emit_call_args but threads the
// parameter environment so an argument that names a parameter resolves to
// its %SSA id (and nested binops/consts lower to real ops). The call result
// itself stays a const.i64-0 placeholder (the canary/oracle does not surface
// a real call op in mic@1 text — only the arguments gain real lowering).
pub fn emit_call_args_env(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr_env(s, buf, arg_node, params_addr, n_params);
    emit_call_args_env(s1, buf, args_addr, args_len, i + 1, params_addr, n_params)
}

pub fn emit_stmt_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child2(node), params_addr, n_params);
        let name_leaf: i64 = ast_child0(node);
        let new_lets: Map = env_bind(s1.lets, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id + 1);
        return EmitState { buf: s1.buf, next_id: s1.next_id, last_id: s1.last_id, lets: new_lets };
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        return emit_lit_output(s1, s1.last_id);
    }
    emit_expr_env(s, buf, node, params_addr, n_params)
}

pub fn emit_block_stmts_env(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt_env(s, buf, stmt_node, params_addr, n_params);
    emit_block_stmts_env(s1, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// Real-body function lowering: params occupy SSA ids 0..n-1; the body emits
// real ops starting at %n, then the trailing value is `output`-ed.
pub fn emit_fn_def_with_body(s: EmitState, buf: i64, node: i64) -> EmitState {
    let params_addr: i64 = ast_child1(node);
    let n_params: i64 = ast_aux(node) / 2;
    let body: i64 = ast_child2(node);
    let s0: EmitState = EmitState { buf: s.buf, next_id: n_params, last_id: 0, lets: s.lets };
    let s1: EmitState = emit_block_stmts_env(s0, buf, ast_child0(body), ast_aux(body), 0, params_addr, n_params);
    emit_lit_output(s1, s1.last_id)
}

// Self-test entry: lex+parse `src`, find the first fn_def, lower its body with
// param resolution, return the EmitState (Python harness decodes EmitState.buf).
pub fn selftest_emit_fn_body(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    emit_fn_def_with_body(es_new(), src_addr, fn_node)
}
pub fn find_first_fn(addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0
    } else {
        let item: i64 = __mind_load_i64(addr + i * 8);
        if ast_kind(item) == ast_fn_def() {
            item
        } else {
            find_first_fn(addr, n, i + 1)
        }
    }
}

// ===========================================================================
// SECTION 4b — REAL-MLIR-TEXT EMITTER (Rust-independence #14, PHASE 1.1)
//
// ADDITIVE / canary-isolated. SECTION 4 (lower_program / emit_fn_def) emits the
// mic@1 IR text (`%0 = const.i64 0` / `output`) the keystone locks to byte-for-
// byte; mic@3 is the binary flip. NEITHER is real MLIR. This section adds a NEW
// emit target that reproduces `mindc <f> --emit-mlir` byte-for-byte for the
// scalar i64 subset (the bound of PHASE 1.1's FIRST increment):
//   module {
//     func.func @NAME(%0: i64, %1: i64) -> i64 {
//       %k = arith.addi %i, %j : i64
//       return %k : i64
//     }
//     func.func @main() -> (i64) {
//       %0 = arith.constant 0 : i64
//       return %0 : i64
//     }
//   }
// (then a trailing `\n` from the Rust `println!`).
//
// It REUSES the existing parser + AST walk + SSA numbering (params occupy
// %0..%n-1, the body continues at %n — identical to emit_fn_def_with_body's
// real-body path), and emits the MLIR spelling instead of mic@1. NOTHING here is
// reached through mindc_compile / lower_program — the keystone mic@3 flip and the
// fixed point are untouched. Exposed via selftest_emit_mlir (the Python gate
// diffs its EmitState.buf against `--emit-mlir` stdout).
//
// COVERED (byte-identical, scalar i64 subset only): the func.func wrapper with
// `%N: i64` params and `-> i64`, ConstI64 -> `arith.constant N : i64`, BinOp
// add/sub/mul/div -> `arith.{addi,subi,muli,divsi}`, ident -> param/let SSA id
// (no instr), let-binding, Return -> `return %k : i64`, plus the synthetic empty
// `@main`. Anything outside this subset (control flow, calls, tensors, narrow
// ints, floats, comparisons) is OUT OF SCOPE for this increment and not emitted.
// ===========================================================================

// `    %` (4 spaces + percent) — the SSA-result line indent inside a func body.
pub fn emit_mlir_indent_pct(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, ch_space());
    es_push(s4, ch_percent())
}

// ` : i64\n` — the scalar result type suffix.
pub fn emit_mlir_i64_nl(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, 58);
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, 105);
    let s5: EmitState = es_push(s4, 54);
    let s6: EmitState = es_push(s5, 52);
    es_push(s6, ch_newline())
}

// ` = arith.` — the operator-spelling prefix shared by every scalar op.
pub fn emit_mlir_eq_arith(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_eq_sign());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, 97);
    let s5: EmitState = es_push(s4, 114);
    let s6: EmitState = es_push(s5, 105);
    let s7: EmitState = es_push(s6, 116);
    let s8: EmitState = es_push(s7, 104);
    es_push(s8, ch_dot())
}

// `constant ` — the arith.constant tail (with trailing space).
pub fn emit_mlir_constant_kw(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 99);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 110);
    let s4: EmitState = es_push(s3, 115);
    let s5: EmitState = es_push(s4, 116);
    let s6: EmitState = es_push(s5, 97);
    let s7: EmitState = es_push(s6, 110);
    let s8: EmitState = es_push(s7, 116);
    es_push(s8, ch_space())
}

// The integer arith binop mnemonic + a trailing space:
//   add -> "addi " · sub -> "subi " · mul -> "muli " · div -> "divsi "
// (signed div is `divsi`; the scalar subset is signed i64). Anything else is
// OUT OF SCOPE for this increment — caller guards via expr_is_mlir_scalar.
pub fn emit_mlir_arith_op(s: EmitState, op: i64) -> EmitState {
    if op == op_add() {
        let s1: EmitState = es_push(s, 97);
        let s2: EmitState = es_push(s1, 100);
        let s3: EmitState = es_push(s2, 100);
        let s4: EmitState = es_push(s3, 105);
        return es_push(s4, ch_space());
    }
    if op == op_sub() {
        let s1: EmitState = es_push(s, 115);
        let s2: EmitState = es_push(s1, 117);
        let s3: EmitState = es_push(s2, 98);
        let s4: EmitState = es_push(s3, 105);
        return es_push(s4, ch_space());
    }
    if op == op_mul() {
        let s1: EmitState = es_push(s, 109);
        let s2: EmitState = es_push(s1, 117);
        let s3: EmitState = es_push(s2, 108);
        let s4: EmitState = es_push(s3, 105);
        return es_push(s4, ch_space());
    }
    if op == op_bitand() {
        // "andi "
        let s1: EmitState = es_push(s, 97);
        let s2: EmitState = es_push(s1, 110);
        let s3: EmitState = es_push(s2, 100);
        let s4: EmitState = es_push(s3, 105);
        return es_push(s4, ch_space());
    }
    if op == op_bitor() {
        // "ori "
        let s1: EmitState = es_push(s, 111);
        let s2: EmitState = es_push(s1, 114);
        let s3: EmitState = es_push(s2, 105);
        return es_push(s3, ch_space());
    }
    if op == op_bitxor() {
        // "xori "
        let s1: EmitState = es_push(s, 120);
        let s2: EmitState = es_push(s1, 111);
        let s3: EmitState = es_push(s2, 114);
        let s4: EmitState = es_push(s3, 105);
        return es_push(s4, ch_space());
    }
    if op == op_mod() {
        // "remsi " — signed remainder (arith.remsi), NOT arith.divsi. Without this
        // arm an op_mod binop fell through to the divsi tail below and emitted
        // integer DIVISION (quotient) for `a % b`.
        let s1: EmitState = es_push(s, 114);
        let s2: EmitState = es_push(s1, 101);
        let s3: EmitState = es_push(s2, 109);
        let s4: EmitState = es_push(s3, 115);
        let s5: EmitState = es_push(s4, 105);
        return es_push(s5, ch_space());
    }
    // op_div(): "divsi "
    let s1: EmitState = es_push(s, 100);
    let s2: EmitState = es_push(s1, 105);
    let s3: EmitState = es_push(s2, 118);
    let s4: EmitState = es_push(s3, 115);
    let s5: EmitState = es_push(s4, 105);
    es_push(s5, ch_space())
}

// Emit each call arg's instructions (lowering them with the SAME numbering as
// any other expr), recording each arg's resulting SSA id into the `ids` scratch
// array (ids[i] = arg i's last_id). Returns the EmitState after all args.
pub fn emit_mlir_call_args(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64, ids: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_mlir_expr_env(s, buf, arg_node, params_addr, n_params);
    __mind_store_i64(ids + i * 8, s1.last_id);
    emit_mlir_call_args(s1, buf, args_addr, args_len, i + 1, params_addr, n_params, ids)
}

// Emit the comma-separated `%a0, %a1, ...` operand list from the recorded ids.
pub fn emit_mlir_call_operands(s: EmitState, ids: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s0: EmitState = if i == 0 {
        s
    } else {
        let c1: EmitState = es_push(s, ch_comma());
        es_push(c1, ch_space())
    };
    let s1: EmitState = es_push(s0, ch_percent());
    let s2: EmitState = emit_i64(s1, __mind_load_i64(ids + i * 8));
    emit_mlir_call_operands(s2, ids, n, i + 1)
}

// Emit the comma-separated `i64, i64, ...` type list (n entries).
pub fn emit_mlir_i64_list(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s0: EmitState = if i == 0 {
        s
    } else {
        let c1: EmitState = es_push(s, ch_comma());
        es_push(c1, ch_space())
    };
    let s1: EmitState = es_push(s0, 105);
    let s2: EmitState = es_push(s1, 54);
    let s3: EmitState = es_push(s2, 52);
    emit_mlir_i64_list(s3, n, i + 1)
}

// Emit `shm`/`sha` (the named shift-mask/shift-amount prefixes). which: 0=shm, 1=sha.
pub fn emit_mlir_sh_name(s: EmitState, which: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_percent());
    let s2: EmitState = es_push(s1, 115);
    let s3: EmitState = es_push(s2, 104);
    if which == 0 {
        return es_push(s3, 109);
    }
    es_push(s3, 97)
}

// Lower a shift `a << b` / `a >> b` (op=1 for shli, op=0 for shrsi). Emits the
// 3-line masked-shift sequence; the result consumes ONE numeric id N, the named
// %shm<N>/%sha<N> values consume no numeric id.
//   %shm<N> = arith.constant 63 : i64
//   %sha<N> = arith.andi %b, %shm<N> : i64
//   %<N> = arith.shli|shrsi %a, %sha<N> : i64
pub fn emit_mlir_shift(s: EmitState, lhs_id: i64, rhs_id: i64, is_shl: i64) -> EmitState {
    let id: i64 = s.next_id;
    // Line 1: `    %shm<N> = arith.constant 63 : i64\n`
    let a1: EmitState = es_push(s, ch_space());
    let a2: EmitState = es_push(a1, ch_space());
    let a3: EmitState = es_push(a2, ch_space());
    let a4: EmitState = es_push(a3, ch_space());
    let a5: EmitState = emit_mlir_sh_name(a4, 0);
    let a6: EmitState = emit_i64(a5, id);
    let a7: EmitState = emit_mlir_eq_arith(a6);
    let a8: EmitState = emit_mlir_constant_kw(a7);
    let a9: EmitState = emit_i64(a8, 63);
    let a10: EmitState = emit_mlir_i64_nl(a9);
    // Line 2: `    %sha<N> = arith.andi %b, %shm<N> : i64\n`
    let b1: EmitState = es_push(a10, ch_space());
    let b2: EmitState = es_push(b1, ch_space());
    let b3: EmitState = es_push(b2, ch_space());
    let b4: EmitState = es_push(b3, ch_space());
    let b5: EmitState = emit_mlir_sh_name(b4, 1);
    let b6: EmitState = emit_i64(b5, id);
    let b7: EmitState = emit_mlir_eq_arith(b6);
    let b8: EmitState = emit_mlir_arith_op(b7, op_bitand());
    let b9: EmitState = es_push(b8, ch_percent());
    let b10: EmitState = emit_i64(b9, rhs_id);
    let b11: EmitState = es_push(b10, ch_comma());
    let b12: EmitState = es_push(b11, ch_space());
    let b13: EmitState = emit_mlir_sh_name(b12, 0);
    let b14: EmitState = emit_i64(b13, id);
    let b15: EmitState = emit_mlir_i64_nl(b14);
    // Line 3: `    %<N> = arith.shli|shrsi %a, %sha<N> : i64\n`
    let c1: EmitState = emit_mlir_indent_pct(b15);
    let c2: EmitState = emit_i64(c1, id);
    let c3: EmitState = emit_mlir_eq_arith(c2);
    let c4: EmitState = if is_shl == 1 {
        // "shli "
        let d1: EmitState = es_push(c3, 115);
        let d2: EmitState = es_push(d1, 104);
        let d3: EmitState = es_push(d2, 108);
        let d4: EmitState = es_push(d3, 105);
        es_push(d4, ch_space())
    } else {
        // "shrsi "
        let e1: EmitState = es_push(c3, 115);
        let e2: EmitState = es_push(e1, 104);
        let e3: EmitState = es_push(e2, 114);
        let e4: EmitState = es_push(e3, 115);
        let e5: EmitState = es_push(e4, 105);
        es_push(e5, ch_space())
    };
    let c5: EmitState = es_push(c4, ch_percent());
    let c6: EmitState = emit_i64(c5, lhs_id);
    let c7: EmitState = es_push(c6, ch_comma());
    let c8: EmitState = es_push(c7, ch_space());
    let c9: EmitState = emit_mlir_sh_name(c8, 1);
    let c10: EmitState = emit_i64(c9, id);
    let c11: EmitState = emit_mlir_i64_nl(c10);
    EmitState { buf: c11.buf, next_id: id + 1, last_id: id, lets: c11.lets }
}

// MLIR expression lowering, scalar i64 subset. Mirrors emit_expr_env's SSA
// numbering EXACTLY (so a port between targets keeps ids aligned) but emits the
// MLIR spelling. Returns an EmitState whose last_id is the value's SSA id.
//   int_lit -> `    %k = arith.constant N : i64`
//   ident   -> resolves to a param/let SSA id, NO instruction
//   binop   -> lowers both operands, then `    %k = arith.OP %i, %j : i64`
//   call    -> lowers each arg, then `    %k = func.call @NAME(%a..) : (i64..) -> i64`
//   paren   -> transparent
pub fn emit_mlir_expr_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_mlir_indent_pct(s);
        let s2: EmitState = emit_i64(s1, id);
        let s3: EmitState = emit_mlir_eq_arith(s2);
        let s4: EmitState = emit_mlir_constant_kw(s3);
        let s5: EmitState = emit_i64(s4, val);
        let s6: EmitState = emit_mlir_i64_nl(s5);
        return EmitState { buf: s6.buf, next_id: id + 1, last_id: id, lets: s6.lets };
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: idx, lets: s.lets };
        }
        let lid: i64 = env_lookup(s.lets, buf, ast_span_lo(node), ast_span_hi(node));
        return EmitState { buf: s.buf, next_id: s.next_id, last_id: lid - 1, lets: s.lets };
    }
    if k == ast_paren() {
        return emit_mlir_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        // Lower each arg first; record their SSA ids in a scratch buffer.
        let ids: i64 = __mind_alloc((args_len + 1) * 8);
        let sa: EmitState = emit_mlir_call_args(s, buf, args_addr, args_len, 0, params_addr, n_params, ids);
        let id: i64 = sa.next_id;
        // `    %k = func.call @NAME(`
        let c1: EmitState = emit_mlir_indent_pct(sa);
        let c2: EmitState = emit_i64(c1, id);
        let c3: EmitState = es_push(c2, ch_space());
        let c4: EmitState = es_push(c3, ch_eq_sign());
        let c5: EmitState = es_push(c4, ch_space());
        let c6: EmitState = es_push(c5, 102);
        let c7: EmitState = es_push(c6, 117);
        let c8: EmitState = es_push(c7, 110);
        let c9: EmitState = es_push(c8, 99);
        let c10: EmitState = es_push(c9, ch_dot());
        let c11: EmitState = es_push(c10, 99);
        let c12: EmitState = es_push(c11, 97);
        let c13: EmitState = es_push(c12, 108);
        let c14: EmitState = es_push(c13, 108);
        let c15: EmitState = es_push(c14, ch_space());
        let c16: EmitState = es_push(c15, 64);
        let c17: EmitState = emit_byte_range(c16, buf, ast_span_lo(callee), ast_span_hi(callee));
        let c18: EmitState = es_push(c17, 40);
        // `%a0, %a1, ...) : (i64, i64, ...) -> i64\n`
        let c19: EmitState = emit_mlir_call_operands(c18, ids, args_len, 0);
        let c20: EmitState = es_push(c19, 41);
        let c21: EmitState = es_push(c20, ch_space());
        let c22: EmitState = es_push(c21, 58);
        let c23: EmitState = es_push(c22, ch_space());
        let c24: EmitState = es_push(c23, 40);
        let c25: EmitState = emit_mlir_i64_list(c24, args_len, 0);
        let c26: EmitState = es_push(c25, 41);
        let c27: EmitState = es_push(c26, ch_space());
        let c28: EmitState = es_push(c27, 45);
        let c29: EmitState = es_push(c28, 62);
        let c30: EmitState = es_push(c29, ch_space());
        let c31: EmitState = es_push(c30, 105);
        let c32: EmitState = es_push(c31, 54);
        let c33: EmitState = es_push(c32, 52);
        let c34: EmitState = es_push(c33, ch_newline());
        return EmitState { buf: c34.buf, next_id: id + 1, last_id: id, lets: c34.lets };
    }
    // ast_binop(): lower both operands, then the arith op line.
    let s1: EmitState = emit_mlir_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    let lhs_id: i64 = s1.last_id;
    let s2: EmitState = emit_mlir_expr_env(s1, buf, ast_child1(node), params_addr, n_params);
    let rhs_id: i64 = s2.last_id;
    let op_tag: i64 = ast_aux(node);
    // Shift ops mask the amount to the low 6 bits via a named const + named andi,
    // then the shift itself consumes the next NUMERIC id; the named SSA values
    // (%shm<N>, %sha<N>) consume no numeric id.
    if op_tag == op_shl() {
        return emit_mlir_shift(s2, lhs_id, rhs_id, 1);
    }
    if op_tag == op_shr() {
        return emit_mlir_shift(s2, lhs_id, rhs_id, 0);
    }
    let id: i64 = s2.next_id;
    let s3: EmitState = emit_mlir_indent_pct(s2);
    let s4: EmitState = emit_i64(s3, id);
    let s5: EmitState = emit_mlir_eq_arith(s4);
    let s6: EmitState = emit_mlir_arith_op(s5, ast_aux(node));
    let s7: EmitState = es_push(s6, ch_percent());
    let s8: EmitState = emit_i64(s7, lhs_id);
    let s9: EmitState = es_push(s8, ch_comma());
    let s10: EmitState = es_push(s9, ch_space());
    let s11: EmitState = es_push(s10, ch_percent());
    let s12: EmitState = emit_i64(s11, rhs_id);
    let s13: EmitState = emit_mlir_i64_nl(s12);
    EmitState { buf: s13.buf, next_id: id + 1, last_id: id, lets: s13.lets }
}

// Emit the cmpi predicate token + `, ` for a comparison op code:
//   ==/!= -> "eq"/"ne" ; signed </<=/>/>= -> "slt"/"sle"/"sgt"/"sge".
// Emits the leading `"`, the mnemonic, then `", ` (close-quote, comma, space).
pub fn emit_mlir_cmpi_pred(s: EmitState, op: i64) -> EmitState {
    let s1: EmitState = es_push(s, 34);
    let s2: EmitState = if op == op_eq() {
        let a: EmitState = es_push(s1, 101);
        es_push(a, 113)
    } else {
        if op == op_ne() {
            let a: EmitState = es_push(s1, 110);
            es_push(a, 101)
        } else {
            // s + (l/g) + (t/e), the signed three-letter forms.
            let a: EmitState = es_push(s1, 115);
            let lg: i64 = if op == op_lt() {
                108
            } else {
                if op == op_le() {
                    108
                } else {
                    103
                }
            };
            let b: EmitState = es_push(a, lg);
            let te: i64 = if op == op_lt() {
                116
            } else {
                if op == op_gt() {
                    116
                } else {
                    101
                }
            };
            es_push(b, te)
        }
    };
    let s3: EmitState = es_push(s2, 34);
    let s4: EmitState = es_push(s3, ch_comma());
    es_push(s4, ch_space())
}

// Emit a comparison `    %k = arith.cmpi "PRED", %lhs, %rhs : i64\n`, lowering
// both operands first (mirroring the Rust IR builder's cond-sub numbering).
// Returns the EmitState with last_id = the i1 cmpi result id.
pub fn emit_mlir_cmpi(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let s1: EmitState = emit_mlir_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    let lhs_id: i64 = s1.last_id;
    let s2: EmitState = emit_mlir_expr_env(s1, buf, ast_child1(node), params_addr, n_params);
    let rhs_id: i64 = s2.last_id;
    let id: i64 = s2.next_id;
    let p1: EmitState = emit_mlir_indent_pct(s2);
    let p2: EmitState = emit_i64(p1, id);
    let p3: EmitState = es_push(p2, ch_space());
    let p4: EmitState = es_push(p3, ch_eq_sign());
    let p5: EmitState = es_push(p4, ch_space());
    // `arith.cmpi `
    let q1: EmitState = es_push(p5, 97);
    let q2: EmitState = es_push(q1, 114);
    let q3: EmitState = es_push(q2, 105);
    let q4: EmitState = es_push(q3, 116);
    let q5: EmitState = es_push(q4, 104);
    let q6: EmitState = es_push(q5, ch_dot());
    let q7: EmitState = es_push(q6, 99);
    let q8: EmitState = es_push(q7, 109);
    let q9: EmitState = es_push(q8, 112);
    let q10: EmitState = es_push(q9, 105);
    let q11: EmitState = es_push(q10, ch_space());
    let r1: EmitState = emit_mlir_cmpi_pred(q11, ast_aux(node));
    let r2: EmitState = es_push(r1, ch_percent());
    let r3: EmitState = emit_i64(r2, lhs_id);
    let r4: EmitState = es_push(r3, ch_comma());
    let r5: EmitState = es_push(r4, ch_space());
    let r6: EmitState = es_push(r5, ch_percent());
    let r7: EmitState = emit_i64(r6, rhs_id);
    let r8: EmitState = emit_mlir_i64_nl(r7);
    EmitState { buf: r8.buf, next_id: id + 1, last_id: id, lets: r8.lets }
}

// True iff `node` is a comparison binop (==,!=,<,<=,>,>=), i.e. already lowers
// to an i1 the if-stmt can branch on directly. A non-comparison cond (a plain
// i64 value) needs the `cmpi "ne", %v, 0` wrapper below.
pub fn cond_is_comparison(node: i64) -> i64 {
    if ast_kind(node) != ast_binop() {
        return 0;
    }
    let op: i64 = ast_aux(node);
    if op == op_eq() {
        return 1;
    }
    if op == op_ne() {
        return 1;
    }
    if op == op_lt() {
        return 1;
    }
    if op == op_le() {
        return 1;
    }
    if op == op_gt() {
        return 1;
    }
    if op == op_ge() {
        return 1;
    }
    0
}

// Emit `%cond_zero_N` (which=0) or `%cond_i1_N` (which=1): the named SSA values
// mindc synthesises when an if-condition is a plain i64 (not already an i1).
// Byte-identical to lower.rs's `cond_zero_<id>` / `cond_i1_<id>` naming.
pub fn emit_mlir_cond_name(s: EmitState, which: i64, n: i64) -> EmitState {
    let s0: EmitState = es_push(s, ch_percent());
    // `cond_`
    let c1: EmitState = es_push(s0, 99);
    let c2: EmitState = es_push(c1, 111);
    let c3: EmitState = es_push(c2, 110);
    let c4: EmitState = es_push(c3, 100);
    let c5: EmitState = es_push(c4, 95);
    let mid: EmitState = if which == 0 {
        // `zero`
        let z1: EmitState = es_push(c5, 122);
        let z2: EmitState = es_push(z1, 101);
        let z3: EmitState = es_push(z2, 114);
        es_push(z3, 111)
    } else {
        // `i1`
        let i1: EmitState = es_push(c5, 105);
        es_push(i1, 49)
    };
    let u: EmitState = es_push(mid, 95);
    emit_i64(u, n)
}

// Lower a plain-i64 if-condition `cond` to an i1 via the named-SSA wrapper:
//   %cond_zero_N = arith.constant 0 : i64
//   %cond_i1_N   = arith.cmpi "ne", %v, %cond_zero_N : i64
// The cond value itself must already be lowered (its id == cond_val_id); these
// named instrs consume NO numeric SSA ids, mirroring lower.rs. N == dst label.
pub fn emit_mlir_cond_ne_zero(s: EmitState, cond_val_id: i64, n: i64) -> EmitState {
    // `    %cond_zero_N = arith.constant 0 : i64\n`
    let z0: EmitState = es_push(s, ch_space());
    let z1: EmitState = es_push(z0, ch_space());
    let z2: EmitState = es_push(z1, ch_space());
    let z3: EmitState = es_push(z2, ch_space());
    let z4: EmitState = emit_mlir_cond_name(z3, 0, n);
    let z5: EmitState = emit_mlir_eq_arith(z4);
    let z6: EmitState = emit_mlir_constant_kw(z5);
    let z7: EmitState = es_push(z6, 48);
    let z8: EmitState = emit_mlir_i64_nl(z7);
    // `    %cond_i1_N = arith.cmpi "ne", %v, %cond_zero_N : i64\n`
    let p0: EmitState = es_push(z8, ch_space());
    let p1: EmitState = es_push(p0, ch_space());
    let p2: EmitState = es_push(p1, ch_space());
    let p3: EmitState = es_push(p2, ch_space());
    let p4: EmitState = emit_mlir_cond_name(p3, 1, n);
    let p5: EmitState = es_push(p4, ch_space());
    let p6: EmitState = es_push(p5, ch_eq_sign());
    let p7: EmitState = es_push(p6, ch_space());
    // `arith.cmpi `
    let q1: EmitState = es_push(p7, 97);
    let q2: EmitState = es_push(q1, 114);
    let q3: EmitState = es_push(q2, 105);
    let q4: EmitState = es_push(q3, 116);
    let q5: EmitState = es_push(q4, 104);
    let q6: EmitState = es_push(q5, ch_dot());
    let q7: EmitState = es_push(q6, 99);
    let q8: EmitState = es_push(q7, 109);
    let q9: EmitState = es_push(q8, 112);
    let q10: EmitState = es_push(q9, 105);
    let q11: EmitState = es_push(q10, ch_space());
    let r1: EmitState = emit_mlir_cmpi_pred(q11, op_ne());
    let r2: EmitState = es_push(r1, ch_percent());
    let r3: EmitState = emit_i64(r2, cond_val_id);
    let r4: EmitState = es_push(r3, ch_comma());
    let r5: EmitState = es_push(r4, ch_space());
    let r6: EmitState = emit_mlir_cond_name(r5, 0, n);
    let r7: EmitState = emit_mlir_i64_nl(r6);
    EmitState { buf: r7.buf, next_id: s.next_id, last_id: s.last_id, lets: r7.lets }
}

// Lower an if-condition to its branchable cond id, dispatching on whether the
// cond is already a comparison (i1) or a plain i64 needing the cmpi-ne wrapper.
// Returns the EmitState AFTER both the cond value and (if needed) the named
// wrapper are emitted. last_id = the value id fed to cond_br: for a comparison
// it is the numeric cmpi id; for a plain-i64 cond it is the lowered value id
// (the caller emits `%cond_i1_N` textually). Uses a function return (not a
// struct-valued if-expr) so the EmitState fields thread correctly.
pub fn emit_mlir_if_cond(s: EmitState, buf: i64, cond_node: i64, params_addr: i64, n_params: i64) -> EmitState {
    if cond_is_comparison(cond_node) == 1 {
        return emit_mlir_cmpi(s, buf, cond_node, params_addr, n_params);
    }
    let sv: EmitState = emit_mlir_expr_env(s, buf, cond_node, params_addr, n_params);
    // dst label N = next_id + 2 (then_result, else_result, dst); wrapper keeps
    // next_id/last_id so the caller's then/else/dst math is unchanged.
    let dst: i64 = sv.next_id + 2;
    emit_mlir_cond_ne_zero(sv, sv.last_id, dst)
}

// ` : i64)` — the block-arg type suffix + close paren (no newline).
pub fn emit_mlir_i64_close(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, 58);
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, 105);
    let s5: EmitState = es_push(s4, 54);
    let s6: EmitState = es_push(s5, 52);
    es_push(s6, 41)
}

// `cf.` (4-space indent) — shared opener for cf.cond_br / cf.br.
pub fn emit_mlir_cf_kw(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, ch_space());
    let s5: EmitState = es_push(s4, 99);
    let s6: EmitState = es_push(s5, 102);
    es_push(s6, ch_dot())
}

// `^if_then_`/`^if_else_`/`^if_after_` followed by the numeric label N.
// `which`: 0 = then, 1 = else, 2 = after. Emits `^if_WHICH_N`.
pub fn emit_mlir_if_label(s: EmitState, which: i64, n: i64) -> EmitState {
    let s1: EmitState = es_push(s, 94);
    let s2: EmitState = es_push(s1, 105);
    let s3: EmitState = es_push(s2, 102);
    let s4: EmitState = es_push(s3, 95);
    let s5: EmitState = if which == 0 {
        // then
        let a: EmitState = es_push(s4, 116);
        let b: EmitState = es_push(a, 104);
        let c: EmitState = es_push(b, 101);
        es_push(c, 110)
    } else {
        if which == 1 {
            // else
            let a: EmitState = es_push(s4, 101);
            let b: EmitState = es_push(a, 108);
            let c: EmitState = es_push(b, 115);
            es_push(c, 101)
        } else {
            // after
            let a: EmitState = es_push(s4, 97);
            let b: EmitState = es_push(a, 102);
            let c: EmitState = es_push(b, 116);
            let d: EmitState = es_push(c, 101);
            es_push(d, 114)
        }
    };
    let s6: EmitState = es_push(s5, 95);
    emit_i64(s6, n)
}

// Walk an if-block's statements (then or else), returning the EmitState after
// the last stmt. Threads `lets`/`next_id` as usual. Used by the if-stmt arm.
pub fn emit_mlir_if_body(s: EmitState, buf: i64, blk: i64, params_addr: i64, n_params: i64) -> EmitState {
    if blk == 0 {
        return s;
    }
    emit_mlir_block_stmts_env(s, buf, ast_child0(blk), ast_aux(blk), 0, params_addr, n_params)
}

// True iff the block's last statement is a `return` (so its `cf.br ^if_after`
// is omitted — the block is already terminated). Empty/0 block => false.
pub fn emit_mlir_block_ends_return(blk: i64) -> i64 {
    if blk == 0 {
        return 0;
    }
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len == 0 {
        return 0;
    }
    let last_stmt: i64 = __mind_load_i64(ast_child0(blk) + (stmts_len - 1) * 8);
    if ast_kind(last_stmt) == ast_return() {
        return 1;
    }
    0
}

// RECURSIVE ID-SPAN (Rust-independence #14, PHASE 1.1) — the foundational fix for
// NESTED control flow. The merge id `dst` (== the `^if_*_N` label suffix) is the
// LAST numeric id an if-construct consumes; a nested if in a branch consumes MANY
// ids, so a flat `then_result+2` formula shifts every inner id. These functions
// compute, RECURSIVELY, how many NUMERIC SSA ids emitting a construct consumes.
// Named SSA (%shm/%sha/%cond_i1) consume ZERO numeric ids. A value < 0 signals an
// expr/stmt OUTSIDE this subset; callers then fall back to the flat formula so the
// pre-existing flat cases never regress.
//
// mlir_expr_id_span: ident/param -> 0 ; int_lit -> 1 ; paren -> child ;
//   arith/shift/comparison binop -> lhs_span + rhs_span + 1 ; value-if -> if_span.
pub fn mlir_expr_id_span(expr: i64) -> i64 {
    if expr == 0 {
        return 0;
    }
    let k: i64 = ast_kind(expr);
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_ident() {
        return 0;
    }
    if k == ast_paren() {
        return mlir_expr_id_span(ast_child0(expr));
    }
    if k == ast_binop() {
        let ls: i64 = mlir_expr_id_span(ast_child0(expr));
        if ls < 0 {
            return 0 - 1;
        }
        let rs: i64 = mlir_expr_id_span(ast_child1(expr));
        if rs < 0 {
            return 0 - 1;
        }
        return ls + rs + 1;
    }
    if k == ast_if() {
        return mlir_if_id_span(expr);
    }
    0 - 1
}

// mlir_cond_id_span: numeric ids the if-condition lowering consumes. A comparison
// `x OP k` lowers via cmpi = lhs_span + rhs_span + 1 (the cmpi). A plain-i64 cond
// lowers the value then a NAMED %cond_i1 (zero numeric) = expr_span only.
pub fn mlir_cond_id_span(cond_node: i64) -> i64 {
    if cond_is_comparison(cond_node) == 1 {
        let ls: i64 = mlir_expr_id_span(ast_child0(cond_node));
        if ls < 0 {
            return 0 - 1;
        }
        let rs: i64 = mlir_expr_id_span(ast_child1(cond_node));
        if rs < 0 {
            return 0 - 1;
        }
        return ls + rs + 1;
    }
    mlir_expr_id_span(cond_node)
}

// mlir_stmt_id_span: a nested `if` -> if_span ; `return e` / `let _=e` -> expr_span ;
// a trailing bare expr -> its span.
pub fn mlir_stmt_id_span(stmt: i64) -> i64 {
    if stmt == 0 {
        return 0;
    }
    let k: i64 = ast_kind(stmt);
    if k == ast_if() {
        return mlir_if_id_span(stmt);
    }
    if k == ast_return() {
        return mlir_expr_id_span(ast_child0(stmt));
    }
    if k == ast_let() {
        return mlir_expr_id_span(ast_child2(stmt));
    }
    mlir_expr_id_span(stmt)
}

// mlir_branch_id_span: 1 (the dead placeholder every branch emits) + the sum of
// each statement's span over the block. A 0 block (no else) contributes the
// synthesized else of span 1 (the placeholder only) — handled by the caller.
pub fn mlir_branch_id_span(blk: i64) -> i64 {
    if blk == 0 {
        return 1;
    }
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    let acc: i64 = mlir_branch_stmts_span(stmts_addr, stmts_len, 0, 0);
    if acc < 0 {
        return 0 - 1;
    }
    1 + acc
}

// Sum mlir_stmt_id_span over a block's statements; -1 (and short-circuit) if any
// statement is outside the subset.
pub fn mlir_branch_stmts_span(stmts_addr: i64, stmts_len: i64, i: i64, acc: i64) -> i64 {
    if i >= stmts_len {
        return acc;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let sp: i64 = mlir_stmt_id_span(stmt_node);
    if sp < 0 {
        return 0 - 1;
    }
    mlir_branch_stmts_span(stmts_addr, stmts_len, i + 1, acc + sp)
}

// mlir_if_id_span: cond_span + then_branch_span + else_branch_span + 1 (the merge
// block-arg). A no-else if still has a synthesized else branch of span 1. Returns
// -1 if any sub-span is outside the subset.
pub fn mlir_if_id_span(if_node: i64) -> i64 {
    let cs: i64 = mlir_cond_id_span(ast_child0(if_node));
    if cs < 0 {
        return 0 - 1;
    }
    let ts: i64 = mlir_branch_id_span(ast_child1(if_node));
    if ts < 0 {
        return 0 - 1;
    }
    let es: i64 = mlir_branch_id_span(ast_child2(if_node));
    if es < 0 {
        return 0 - 1;
    }
    cs + ts + es + 1
}

// VALUE-POSITION IF (Rust-independence #14, PHASE 1.1) — the SSA phi merge.
// A `let r = if c { A } else { B };` / `return if c { A } else { B };` where the
// COND is a comparison and EACH branch is a SINGLE simple expr (bare identifier
// or integer literal). Lowered byte-identical to `mindc --emit-mlir`:
//   cf.cond_br %cond, ^if_then_N, ^if_else_N
//   ^if_then_N:  %tr = arith.constant 0 : i64   (dead placeholder, oracle emits it)
//                <opt const for a literal branch value>
//                cf.br ^if_after_N(%<then value> : i64)
//   ^if_else_N:  %er = arith.constant 0 : i64
//                <opt const for a literal branch value>
//                cf.br ^if_after_N(%<else value> : i64)
//   ^if_after_N(%dst : i64):    <-- %dst IS the merged result (last_id)
// SSA numbering is sequential: cond .. then-placeholder .. [then value] ..
// else-placeholder .. [else value] .. dst. The branch-value id-extra is 0 for a
// bare ident (resolves to a param/let id, no instr) or 1 for an int literal (a
// fresh `arith.constant`). N (the label) == dst, computed up front.
// ADDITIVE: only the let/return arms detecting a value-if route here.

// Id-extra a simple branch value consumes when emitted: 0 for ident/param,
// 1 for an int literal (one `arith.constant`). Branches are guaranteed simple
// by the caller's value-if guard.
pub fn emit_mlir_branch_value_extra(expr: i64) -> i64 {
    if ast_kind(expr) == ast_int_lit() {
        return 1;
    }
    0
}

// True iff `node` is a value-position if-expr in this increment's subset: an
// ast_if with a comparison cond, an else block, and BOTH branches a single
// simple expr (bare ident or int literal).
pub fn is_mlir_value_if(node: i64) -> i64 {
    if node == 0 {
        return 0;
    }
    if ast_kind(node) != ast_if() {
        return 0;
    }
    let cond_node: i64 = ast_child0(node);
    if cond_is_comparison(cond_node) != 1 {
        return 0;
    }
    let then_blk: i64 = ast_child1(node);
    let else_blk: i64 = ast_child2(node);
    if else_blk == 0 {
        return 0;
    }
    let then_expr: i64 = branch_single_expr(then_blk);
    let else_expr: i64 = branch_single_expr(else_blk);
    if then_expr < 0 {
        return 0;
    }
    if else_expr < 0 {
        return 0;
    }
    let tk: i64 = ast_kind(then_expr);
    let ek: i64 = ast_kind(else_expr);
    if tk != ast_ident() {
        if tk != ast_int_lit() {
            return 0;
        }
    }
    if ek != ast_ident() {
        if ek != ast_int_lit() {
            return 0;
        }
    }
    1
}

// Emit one branch of a value-if: the dead `%<placeholder> = arith.constant 0`,
// then the branch value, then `cf.br ^if_after_N(%<value> : i64)`. `placeholder`
// is the dead const's SSA id; `value_seed` is the next_id from which the branch
// VALUE is emitted (so a literal lands on the oracle id). `which` = 0 (then) /
// 1 (else) labels the block header. Returns the EmitState after the cf.br.
pub fn emit_mlir_value_if_branch(s: EmitState, buf: i64, which: i64, dst: i64, placeholder: i64, value_seed: i64, val_expr: i64, params_addr: i64, n_params: i64) -> EmitState {
    // `  ^if_WHICH_N:`
    let h0: EmitState = es_push(s, ch_space());
    let h0b: EmitState = es_push(h0, ch_space());
    let h1: EmitState = emit_mlir_if_label(h0b, which, dst);
    let h2: EmitState = es_push(h1, 58);
    let h3: EmitState = es_push(h2, ch_newline());
    // dead placeholder `    %placeholder = arith.constant 0 : i64`
    let p0: EmitState = emit_mlir_indent_pct(h3);
    let p1: EmitState = emit_i64(p0, placeholder);
    let p2: EmitState = emit_mlir_eq_arith(p1);
    let p3: EmitState = emit_mlir_constant_kw(p2);
    let p4: EmitState = es_push(p3, 48);
    let p5: EmitState = emit_mlir_i64_nl(p4);
    // branch value: ident emits nothing (last_id = param/let), literal emits a
    // const. Seed next_id at value_seed so a literal lands on the oracle id.
    let vstate: EmitState = EmitState { buf: p5.buf, next_id: value_seed, last_id: p5.last_id, lets: p5.lets };
    let vs: EmitState = emit_mlir_expr_env(vstate, buf, val_expr, params_addr, n_params);
    let val_id: i64 = vs.last_id;
    // `    cf.br ^if_after_N(%val_id : i64)`
    let z1: EmitState = emit_mlir_cf_kw(vs);
    let z2: EmitState = es_push(z1, 98);
    let z3: EmitState = es_push(z2, 114);
    let z4: EmitState = es_push(z3, ch_space());
    let z5: EmitState = emit_mlir_if_label(z4, 2, dst);
    let z6: EmitState = es_push(z5, 40);
    let z7: EmitState = es_push(z6, ch_percent());
    let z8: EmitState = emit_i64(z7, val_id);
    let z9: EmitState = emit_mlir_i64_close(z8);
    es_push(z9, ch_newline())
}

// Emit a value-position if-expr (cond_br + both cf.br branches + the phi after-
// block), byte-identical to the Rust oracle. Returns the EmitState whose last_id
// is the merged phi `dst`; next_id is dst + 1. The caller (let/return arm) uses
// `dst` as the bound value / returned id. Guarded by is_mlir_value_if.
pub fn emit_mlir_value_if(s: EmitState, buf: i64, if_node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let cond_node: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    let then_expr: i64 = branch_single_expr(then_blk);
    let else_expr: i64 = branch_single_expr(else_blk);
    // 1. condition (comparison cmpi). scw.last_id = the i1 cond id; scw.next_id
    // is the first fresh id (the then-placeholder).
    let scw: EmitState = emit_mlir_if_cond(s, buf, cond_node, params_addr, n_params);
    let cond_id: i64 = scw.last_id;
    // SSA numbering: then-placeholder, [then value extra], else-placeholder,
    // [else value extra], dst. Computed up front because N (label) == dst.
    let then_placeholder: i64 = scw.next_id;
    let then_extra: i64 = emit_mlir_branch_value_extra(then_expr);
    let then_value_seed: i64 = then_placeholder + 1;
    let else_placeholder: i64 = then_value_seed + then_extra;
    let else_extra: i64 = emit_mlir_branch_value_extra(else_expr);
    let else_value_seed: i64 = else_placeholder + 1;
    let dst: i64 = else_value_seed + else_extra;
    // 2. cf.cond_br %cond, ^if_then_N, ^if_else_N
    let b1: EmitState = emit_mlir_cf_kw(scw);
    let b2: EmitState = es_push(b1, 99);
    let b3: EmitState = es_push(b2, 111);
    let b4: EmitState = es_push(b3, 110);
    let b5: EmitState = es_push(b4, 100);
    let b6: EmitState = es_push(b5, 95);
    let b7: EmitState = es_push(b6, 98);
    let b8: EmitState = es_push(b7, 114);
    let b9: EmitState = es_push(b8, ch_space());
    let b10: EmitState = es_push(b9, ch_percent());
    let b11: EmitState = emit_i64(b10, cond_id);
    let b12: EmitState = es_push(b11, ch_comma());
    let b13: EmitState = es_push(b12, ch_space());
    let b14: EmitState = emit_mlir_if_label(b13, 0, dst);
    let b15: EmitState = es_push(b14, ch_comma());
    let b16: EmitState = es_push(b15, ch_space());
    let b17: EmitState = emit_mlir_if_label(b16, 1, dst);
    let b18: EmitState = es_push(b17, ch_newline());
    let bb: EmitState = EmitState { buf: b18.buf, next_id: dst, last_id: cond_id, lets: b18.lets };
    // 3. then-branch + 4. else-branch
    let then_s: EmitState = emit_mlir_value_if_branch(bb, buf, 0, dst, then_placeholder, then_value_seed, then_expr, params_addr, n_params);
    let else_s: EmitState = emit_mlir_value_if_branch(then_s, buf, 1, dst, else_placeholder, else_value_seed, else_expr, params_addr, n_params);
    // 5. ^if_after_N(%dst : i64):
    let a0: EmitState = es_push(else_s, ch_space());
    let a0b: EmitState = es_push(a0, ch_space());
    let a1: EmitState = emit_mlir_if_label(a0b, 2, dst);
    let a2: EmitState = es_push(a1, 40);
    let a3: EmitState = es_push(a2, ch_percent());
    let a4: EmitState = emit_i64(a3, dst);
    let a5: EmitState = es_push(a4, ch_space());
    let a6: EmitState = es_push(a5, 58);
    let a7: EmitState = es_push(a6, ch_space());
    let a8: EmitState = es_push(a7, 105);
    let a9: EmitState = es_push(a8, 54);
    let a10: EmitState = es_push(a9, 52);
    let a11: EmitState = es_push(a10, 41);
    let a12: EmitState = es_push(a11, 58);
    let a13: EmitState = es_push(a12, ch_newline());
    EmitState { buf: a13.buf, next_id: dst + 1, last_id: dst, lets: a13.lets }
}

// MLIR statement lowering, scalar i64 subset. `let` binds the value's SSA id;
// `return` emits `    return %k : i64`. A trailing bare expression just lowers.
//
// `if`-statement subset (Rust-independence #14, PHASE 1.1): a comparison-cond
// `if cmp { ... }` (optional simple `else { ... }`) where each branch is a
// straight statement list that may early-`return`. Lowered to the cf-dialect
// `cf.cond_br`/`^if_then`/`^if_else`/`cf.br ^if_after(%v : i64)` form, byte-
// identical to `mindc --emit-mlir`. The IR builder synthesises a placeholder
// `arith.constant 0` as each branch's first instr and threads the merge value
// as a block argument on `^if_after_N`. SSA numbering mirrors lower.rs exactly:
//   then_result = first id after cond ; else_result = next ; dst = next.
// ADDITIVE: only fires on ast_if; the scalar/call cases are byte-identical.
pub fn emit_mlir_stmt_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_if() {
        // ast_new_if: cond=child0(+24), then-block=child1(+32), else-block=child2(+40).
        let cond_node: i64 = ast_child0(node);
        let then_blk: i64 = ast_child1(node);
        let else_blk: i64 = ast_child2(node);
        // 1. condition. A comparison binop lowers operands + the cmpi directly
        // (numeric %id). A plain-i64 cond lowers the value then synthesises
        // `%cond_zero_N`/`%cond_i1_N` (no numeric ids) via emit_mlir_if_cond.
        let is_cmp: i64 = cond_is_comparison(cond_node);
        let scw: EmitState = emit_mlir_if_cond(s, buf, cond_node, params_addr, n_params);
        // For a comparison, scw.last_id is the i1 cond id; for a plain-i64 cond
        // it is the lowered value id (the named %cond_i1_N is emitted textually).
        let cond_id: i64 = scw.last_id;
        // 2. cf.cond_br %cond, ^if_then_N, ^if_else_N
        // then_result = the then-branch's dead placeholder (first id after cond);
        // the then-branch's NESTED instrs follow from then_result+1, so the else
        // placeholder = then_result + then_branch_span, and dst (== N, the merge
        // block-arg) = next_id + then_branch_span + else_branch_span. RECURSIVE so
        // a nested if in either branch shifts the ids correctly. A span of -1
        // (out-of-subset) falls back to the flat then_result+2 formula so the 15
        // flat cases never regress.
        let then_result: i64 = scw.next_id;
        let then_span: i64 = mlir_branch_id_span(then_blk);
        let else_span: i64 = mlir_branch_id_span(else_blk);
        let spans_ok: i64 = if then_span < 0 {
            0
        } else {
            if else_span < 0 {
                0
            } else {
                1
            }
        };
        let else_result: i64 = if spans_ok == 1 {
            then_result + then_span
        } else {
            then_result + 1
        };
        let dst: i64 = if spans_ok == 1 {
            then_result + then_span + else_span
        } else {
            else_result + 1
        };
        let b1: EmitState = emit_mlir_cf_kw(scw);
        // `cond_br %`
        let b2: EmitState = es_push(b1, 99);
        let b3: EmitState = es_push(b2, 111);
        let b4: EmitState = es_push(b3, 110);
        let b5: EmitState = es_push(b4, 100);
        let b6: EmitState = es_push(b5, 95);
        let b7: EmitState = es_push(b6, 98);
        let b8: EmitState = es_push(b7, 114);
        let b9: EmitState = es_push(b8, ch_space());
        // comparison: `%<numeric id>` ; plain-i64: `%cond_i1_N`
        let b11: EmitState = if is_cmp == 1 {
            let bp: EmitState = es_push(b9, ch_percent());
            emit_i64(bp, cond_id)
        } else {
            emit_mlir_cond_name(b9, 1, dst)
        };
        let b12: EmitState = es_push(b11, ch_comma());
        let b13: EmitState = es_push(b12, ch_space());
        let b14: EmitState = emit_mlir_if_label(b13, 0, dst);
        let b15: EmitState = es_push(b14, ch_comma());
        let b16: EmitState = es_push(b15, ch_space());
        let b17: EmitState = emit_mlir_if_label(b16, 1, dst);
        let b18: EmitState = es_push(b17, ch_newline());
        // 3. ^if_then_N:
        let t0: EmitState = es_push(b18, ch_space());
        let t0b: EmitState = es_push(t0, ch_space());
        let t1: EmitState = emit_mlir_if_label(t0b, 0, dst);
        let t2: EmitState = es_push(t1, 58);
        let t3: EmitState = es_push(t2, ch_newline());
        // synthetic placeholder `%then_result = arith.constant 0 : i64`
        let t4: EmitState = emit_mlir_indent_pct(t3);
        let t5: EmitState = emit_i64(t4, then_result);
        let t6: EmitState = emit_mlir_eq_arith(t5);
        let t7: EmitState = emit_mlir_constant_kw(t6);
        let t8: EmitState = es_push(t7, 48);
        let t9: EmitState = emit_mlir_i64_nl(t8);
        // The then-branch's NESTED instrs follow its placeholder, so seed next_id
        // at then_result+1 (the flat case emits no numeric ids, so it is unused
        // there and stays byte-identical).
        let tb: EmitState = EmitState { buf: t9.buf, next_id: then_result + 1, last_id: then_result, lets: t9.lets };
        let then_s: EmitState = emit_mlir_if_body(tb, buf, then_blk, params_addr, n_params);
        // then-edge cf.br only if the block did not already `return`.
        let then_ret: i64 = emit_mlir_block_ends_return(then_blk);
        let after_then: EmitState = if then_ret == 1 {
            then_s
        } else {
            let z1: EmitState = emit_mlir_cf_kw(then_s);
            let z2: EmitState = es_push(z1, 98);
            let z3: EmitState = es_push(z2, 114);
            let z4: EmitState = es_push(z3, ch_space());
            let z5: EmitState = emit_mlir_if_label(z4, 2, dst);
            let z6: EmitState = es_push(z5, 40);
            let z7: EmitState = es_push(z6, ch_percent());
            let z8: EmitState = emit_i64(z7, then_s.last_id);
            let z9: EmitState = emit_mlir_i64_close(z8);
            es_push(z9, ch_newline())
        };
        // 4. ^if_else_N:
        let e0: EmitState = es_push(after_then, ch_space());
        let e0b: EmitState = es_push(e0, ch_space());
        let e1: EmitState = emit_mlir_if_label(e0b, 1, dst);
        let e2: EmitState = es_push(e1, 58);
        let e3: EmitState = es_push(e2, ch_newline());
        // synthetic placeholder `%else_result = arith.constant 0 : i64`
        let e4: EmitState = emit_mlir_indent_pct(e3);
        let e5: EmitState = emit_i64(e4, else_result);
        let e6: EmitState = emit_mlir_eq_arith(e5);
        let e7: EmitState = emit_mlir_constant_kw(e6);
        let e8: EmitState = es_push(e7, 48);
        let e9: EmitState = emit_mlir_i64_nl(e8);
        // Likewise seed the else-branch's nested instrs at else_result+1.
        let eb: EmitState = EmitState { buf: e9.buf, next_id: else_result + 1, last_id: else_result, lets: e9.lets };
        let else_s: EmitState = emit_mlir_if_body(eb, buf, else_blk, params_addr, n_params);
        let else_ret: i64 = emit_mlir_block_ends_return(else_blk);
        let after_else: EmitState = if else_ret == 1 {
            else_s
        } else {
            let z1: EmitState = emit_mlir_cf_kw(else_s);
            let z2: EmitState = es_push(z1, 98);
            let z3: EmitState = es_push(z2, 114);
            let z4: EmitState = es_push(z3, ch_space());
            let z5: EmitState = emit_mlir_if_label(z4, 2, dst);
            let z6: EmitState = es_push(z5, 40);
            let z7: EmitState = es_push(z6, ch_percent());
            let z8: EmitState = emit_i64(z7, else_s.last_id);
            let z9: EmitState = emit_mlir_i64_close(z8);
            es_push(z9, ch_newline())
        };
        // 5. ^if_after_N(%dst : i64):
        let a0: EmitState = es_push(after_else, ch_space());
        let a0b: EmitState = es_push(a0, ch_space());
        let a1: EmitState = emit_mlir_if_label(a0b, 2, dst);
        let a2: EmitState = es_push(a1, 40);
        let a3: EmitState = es_push(a2, ch_percent());
        let a4: EmitState = emit_i64(a3, dst);
        let a5: EmitState = es_push(a4, ch_space());
        let a6: EmitState = es_push(a5, 58);
        let a7: EmitState = es_push(a6, ch_space());
        let a8: EmitState = es_push(a7, 105);
        let a9: EmitState = es_push(a8, 54);
        let a10: EmitState = es_push(a9, 52);
        let a11: EmitState = es_push(a10, 41);
        let a12: EmitState = es_push(a11, 58);
        let a13: EmitState = es_push(a12, ch_newline());
        return EmitState { buf: a13.buf, next_id: dst + 1, last_id: dst, lets: a13.lets };
    }
    if k == ast_let() {
        let init: i64 = ast_child2(node);
        if is_mlir_value_if(init) == 1 {
            let vif: EmitState = emit_mlir_value_if(s, buf, init, params_addr, n_params);
            let nl: i64 = ast_child0(node);
            let vlets: Map = env_bind(vif.lets, buf, ast_span_lo(nl), ast_span_hi(nl), vif.last_id + 1);
            return EmitState { buf: vif.buf, next_id: vif.next_id, last_id: vif.last_id, lets: vlets };
        }
        let s1: EmitState = emit_mlir_expr_env(s, buf, init, params_addr, n_params);
        let name_leaf: i64 = ast_child0(node);
        let new_lets: Map = env_bind(s1.lets, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id + 1);
        return EmitState { buf: s1.buf, next_id: s1.next_id, last_id: s1.last_id, lets: new_lets };
    }
    if k == ast_return() {
        let ret_val: i64 = ast_child0(node);
        if is_mlir_value_if(ret_val) == 1 {
            let vif: EmitState = emit_mlir_value_if(s, buf, ret_val, params_addr, n_params);
            let rid0: i64 = vif.last_id;
            let r1: EmitState = es_push(vif, ch_space());
            let r2: EmitState = es_push(r1, ch_space());
            let r3: EmitState = es_push(r2, ch_space());
            let r4: EmitState = es_push(r3, ch_space());
            let r5: EmitState = es_push(r4, 114);
            let r6: EmitState = es_push(r5, 101);
            let r7: EmitState = es_push(r6, 116);
            let r8: EmitState = es_push(r7, 117);
            let r9: EmitState = es_push(r8, 114);
            let r10: EmitState = es_push(r9, 110);
            let r11: EmitState = es_push(r10, ch_space());
            let r12: EmitState = es_push(r11, ch_percent());
            let r13: EmitState = emit_i64(r12, rid0);
            return emit_mlir_i64_nl(r13);
        }
        let s1: EmitState = emit_mlir_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let rid: i64 = s1.last_id;
        let s2: EmitState = es_push(s1, ch_space());
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_space());
        let s6: EmitState = es_push(s5, 114);
        let s7: EmitState = es_push(s6, 101);
        let s8: EmitState = es_push(s7, 116);
        let s9: EmitState = es_push(s8, 117);
        let s10: EmitState = es_push(s9, 114);
        let s11: EmitState = es_push(s10, 110);
        let s12: EmitState = es_push(s11, ch_space());
        let s13: EmitState = es_push(s12, ch_percent());
        let s14: EmitState = emit_i64(s13, rid);
        return emit_mlir_i64_nl(s14);
    }
    emit_mlir_expr_env(s, buf, node, params_addr, n_params)
}

pub fn emit_mlir_block_stmts_env(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_mlir_stmt_env(s, buf, stmt_node, params_addr, n_params);
    emit_mlir_block_stmts_env(s1, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// Emit one func.func parameter `%i: i64`, comma-separated for i > 0.
pub fn emit_mlir_params(s: EmitState, i: i64, n_params: i64) -> EmitState {
    if i >= n_params {
        return s;
    }
    let s0: EmitState = if i == 0 {
        s
    } else {
        let c1: EmitState = es_push(s, ch_comma());
        es_push(c1, ch_space())
    };
    let s1: EmitState = es_push(s0, ch_percent());
    let s2: EmitState = emit_i64(s1, i);
    let s3: EmitState = es_push(s2, 58);
    let s4: EmitState = es_push(s3, ch_space());
    let s5: EmitState = es_push(s4, 105);
    let s6: EmitState = es_push(s5, 54);
    let s7: EmitState = es_push(s6, 52);
    emit_mlir_params(s7, i + 1, n_params)
}

// `  func.func @` (2-space indent) — the per-fn wrapper opener prefix.
pub fn emit_mlir_funcfunc_head(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, 102);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 110);
    let s6: EmitState = es_push(s5, 99);
    let s7: EmitState = es_push(s6, ch_dot());
    let s8: EmitState = es_push(s7, 102);
    let s9: EmitState = es_push(s8, 117);
    let s10: EmitState = es_push(s9, 110);
    let s11: EmitState = es_push(s10, 99);
    let s12: EmitState = es_push(s11, ch_space());
    es_push(s12, 64)
}

// Emit a complete scalar-i64 `func.func @NAME(...) -> i64 { ... }` for a fn_def
// node. Params occupy %0..%n-1; the body emits real ops from %n. SSA numbering
// matches the Rust oracle (and emit_fn_def_with_body) exactly.
pub fn emit_mlir_fn(s: EmitState, buf: i64, node: i64) -> EmitState {
    let name_node: i64 = ast_child0(node);
    let name_lo: i64 = ast_span_lo(name_node);
    let name_hi: i64 = ast_span_hi(name_node);
    let params_addr: i64 = ast_child1(node);
    let n_params: i64 = ast_aux(node) / 2;
    let body: i64 = ast_child2(node);

    // `  func.func @NAME(`
    let s1: EmitState = emit_mlir_funcfunc_head(s);
    let s2: EmitState = emit_byte_range(s1, buf, name_lo, name_hi);
    let s3: EmitState = es_push(s2, 40);
    // params `%i: i64`...
    let s4: EmitState = emit_mlir_params(s3, 0, n_params);
    // `) -> i64 {\n`
    let s5: EmitState = es_push(s4, 41);
    let s6: EmitState = es_push(s5, ch_space());
    let s7: EmitState = es_push(s6, 45);
    let s8: EmitState = es_push(s7, 62);
    let s9: EmitState = es_push(s8, ch_space());
    let s10: EmitState = es_push(s9, 105);
    let s11: EmitState = es_push(s10, 54);
    let s12: EmitState = es_push(s11, 52);
    let s13: EmitState = es_push(s12, ch_space());
    let s14: EmitState = es_push(s13, ch_lbrace());
    let s15: EmitState = es_push(s14, ch_newline());

    // Body: SSA ids continue at n_params; lets env starts fresh.
    let sb0: EmitState = EmitState { buf: s15.buf, next_id: n_params, last_id: 0 - 1, lets: env_new() };
    let sb1: EmitState = emit_mlir_block_stmts_env(sb0, buf, ast_child0(body), ast_aux(body), 0, params_addr, n_params);

    // `  }\n`
    let sc1: EmitState = es_push(sb1, ch_space());
    let sc2: EmitState = es_push(sc1, ch_space());
    let sc3: EmitState = es_push(sc2, ch_rbrace());
    es_push(sc3, ch_newline())
}

// Emit `n` lines of `    %i = arith.constant 0 : i64\n` (i = 0..n-1).
pub fn emit_mlir_main_consts(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let m1: EmitState = emit_mlir_indent_pct(s);
    let m2: EmitState = emit_i64(m1, i);
    let m3: EmitState = emit_mlir_eq_arith(m2);
    let m4: EmitState = emit_mlir_constant_kw(m3);
    let m5: EmitState = es_push(m4, 48);
    let m6: EmitState = emit_mlir_i64_nl(m5);
    emit_mlir_main_consts(m6, n, i + 1)
}

// Emit the comma-separated `%0, %1, ...` return-id list (n entries).
pub fn emit_mlir_main_retids(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s0: EmitState = if i == 0 {
        s
    } else {
        let c1: EmitState = es_push(s, ch_comma());
        es_push(c1, ch_space())
    };
    let s1: EmitState = es_push(s0, ch_percent());
    let s2: EmitState = emit_i64(s1, i);
    emit_mlir_main_retids(s2, n, i + 1)
}

// The synthetic `@main` the Rust assembler always appends — one i64 result per
// top-level fn (`n_fns` entries):
//   func.func @main() -> (i64, ...) {
//     %0 = arith.constant 0 : i64
//     ...
//     return %0, ... : i64, ...
//   }
pub fn emit_mlir_main(s: EmitState, n_fns: i64) -> EmitState {
    // `  func.func @main() -> (` then the i64 list, then `) {\n`.
    let s1: EmitState = emit_mlir_funcfunc_head(s);
    let s2: EmitState = es_push(s1, 109);
    let s3: EmitState = es_push(s2, 97);
    let s4: EmitState = es_push(s3, 105);
    let s5: EmitState = es_push(s4, 110);
    let s6: EmitState = es_push(s5, 40);
    let s7: EmitState = es_push(s6, 41);
    let s8: EmitState = es_push(s7, ch_space());
    let s9: EmitState = es_push(s8, 45);
    let s10: EmitState = es_push(s9, 62);
    let s11: EmitState = es_push(s10, ch_space());
    let s12: EmitState = es_push(s11, 40);
    let s13: EmitState = emit_mlir_i64_list(s12, n_fns, 0);
    let s16: EmitState = es_push(s13, 41);
    let s17: EmitState = es_push(s16, ch_space());
    let s18: EmitState = es_push(s17, ch_lbrace());
    let s19: EmitState = es_push(s18, ch_newline());
    // `    %i = arith.constant 0 : i64\n` (n_fns of them)
    let m6: EmitState = emit_mlir_main_consts(s19, n_fns, 0);
    // `    return %0, ... ` then the i64 type list then `\n`
    let r1: EmitState = es_push(m6, ch_space());
    let r2: EmitState = es_push(r1, ch_space());
    let r3: EmitState = es_push(r2, ch_space());
    let r4: EmitState = es_push(r3, ch_space());
    let r5: EmitState = es_push(r4, 114);
    let r6: EmitState = es_push(r5, 101);
    let r7: EmitState = es_push(r6, 116);
    let r8: EmitState = es_push(r7, 117);
    let r9: EmitState = es_push(r8, 114);
    let r10: EmitState = es_push(r9, 110);
    let r11: EmitState = es_push(r10, ch_space());
    let r12: EmitState = emit_mlir_main_retids(r11, n_fns, 0);
    let r13: EmitState = es_push(r12, ch_space());
    let r14: EmitState = es_push(r13, 58);
    let r15: EmitState = es_push(r14, ch_space());
    let r16: EmitState = emit_mlir_i64_list(r15, n_fns, 0);
    let r17: EmitState = es_push(r16, ch_newline());
    // `  }\n`
    let c1: EmitState = es_push(r17, ch_space());
    let c2: EmitState = es_push(c1, ch_space());
    let c3: EmitState = es_push(c2, ch_rbrace());
    es_push(c3, ch_newline())
}

// Walk the program items, emitting one `func.func` per fn_def (scalar subset).
pub fn emit_mlir_items(s: EmitState, buf: i64, items_addr: i64, items_len: i64, i: i64) -> EmitState {
    if i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let s1: EmitState = if ast_kind(item) == ast_fn_def() {
        emit_mlir_fn(s, buf, item)
    } else {
        s
    };
    emit_mlir_items(s1, buf, items_addr, items_len, i + 1)
}

// Full real-MLIR module emit:
//   module {\n <fns> <@main> }\n\n
// The trailing extra `\n` mirrors the Rust `println!("{}", text)` that wraps the
// module text (`--emit-mlir` stdout). Pure / additive / canary-isolated.
pub fn emit_mlir_module(ast_addr: i64, buf: i64) -> EmitState {
    let items_addr: i64 = ast_child0(ast_addr);
    let items_len: i64 = ast_aux(ast_addr);
    let s0: EmitState = es_new();
    // `module {\n`
    let s1: EmitState = es_push(s0, 109);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 100);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 108);
    let s6: EmitState = es_push(s5, 101);
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, ch_lbrace());
    let s9: EmitState = es_push(s8, ch_newline());
    let s10: EmitState = emit_mlir_items(s9, buf, items_addr, items_len, 0);
    let n_fns: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    let s11: EmitState = emit_mlir_main(s10, n_fns);
    // `}\n` + the println trailing `\n`.
    let s12: EmitState = es_push(s11, ch_rbrace());
    let s13: EmitState = es_push(s12, ch_newline());
    es_push(s13, ch_newline())
}

// Selftest export: lex+parse `src`, then emit the full real-MLIR module text.
// The Python gate decodes EmitState.buf and diffs it against `--emit-mlir`.
pub fn selftest_emit_mlir(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    emit_mlir_module(ast_root, src_addr)
}

// ===== Program-level lowering =====

// Emit a single const.i64 0 / output stub for items that lower to a placeholder
// (UseDecl and StructDef — matches mindc-Rust lower_to_ir behaviour).
pub fn emit_item_stub(s: EmitState) -> EmitState {
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    let s4: EmitState = EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    emit_lit_output(s4, id)
}

// ===== Bare top-level expression (const-folded) =====
//
// A file whose top level is a single arithmetic expression (e.g. `1 + 2 * 3`, no
// items) lowers — in mindc-Rust — to ONE const-folded `const.i64 <val>` whose id
// is (node_count - 1), with next_id = node_count (Rust reserves one SSA id per AST
// node in post-order; parens are transparent). These helpers reproduce that
// exactly for integer +,-,*,/ arithmetic. Verified byte-identical to `--emit-ir`
// on 5 / 1+1 / 2*3 / 1+2*3 / 1+2+3 / 10-4 / (1+2)*3 / 7/2.

pub fn is_bare_expr_kind(k: i64) -> i64 {
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        return 1;
    }
    if k == ast_paren() {
        return 1;
    }
    0
}

// Count AST nodes the way Rust reserves SSA ids: int-lit = 1, binop = 1 + both
// operands, paren = transparent (no own id). The root gets id (count - 1).
pub fn count_expr_nodes(node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_paren() {
        return count_expr_nodes(ast_child0(node));
    }
    if k == ast_binop() {
        return 1 + count_expr_nodes(ast_child0(node)) + count_expr_nodes(ast_child1(node));
    }
    1
}

// Const-fold an integer arithmetic expression to its i64 value (+,-,*,/ with
// truncating division, matching mindc-Rust / the i64 backend).
pub fn eval_const_expr(node: i64, buf: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
    }
    if k == ast_paren() {
        return eval_const_expr(ast_child0(node), buf);
    }
    if k == ast_binop() {
        let l: i64 = eval_const_expr(ast_child0(node), buf);
        let r: i64 = eval_const_expr(ast_child1(node), buf);
        let op: i64 = ast_aux(node);
        if op == op_add() {
            return l + r;
        }
        if op == op_sub() {
            return l - r;
        }
        if op == op_mul() {
            return l * r;
        }
        if op == op_div() {
            return l / r;
        }
        return 0;
    }
    0
}

// Emit a bare top-level expression as one const-folded result:
//   %<count-1> = const.i64 <val>
//   output %<count-1>
// and set next_id = count, matching the mindc-Rust module-level output.
pub fn emit_bare_expr(s: EmitState, buf: i64, node: i64) -> EmitState {
    let count: i64 = count_expr_nodes(node);
    let val: i64 = eval_const_expr(node, buf);
    let id: i64 = count - 1;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = emit_i64(s1, val);
    let s3: EmitState = es_push(s2, ch_newline());
    let s4: EmitState = EmitState { buf: s3.buf, next_id: count, last_id: id, lets: s3.lets };
    emit_lit_output(s4, id)
}

pub fn emit_program_items(s: EmitState, buf: i64, items_addr: i64, items_len: i64, i: i64) -> EmitState {
    if i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let k: i64 = ast_kind(item);
    let s1: EmitState = if k == ast_fn_def() {
        emit_fn_def(s, buf, item)
    } else {
        if k == ast_use() {
            emit_item_stub(s)
        } else {
            if k == ast_struct_def() {
                emit_item_stub(s)
            } else {
                if is_bare_expr_kind(k) == 1 {
                    emit_bare_expr(s, buf, item)
                } else {
                    s
                }
            }
        }
    };
    emit_program_items(s1, buf, items_addr, items_len, i + 1)
}

// ===== Public entry: lower_program =====

pub fn lower_program(ast_addr: i64, buf: i64) -> EmitState {
    let items_addr: i64 = ast_child0(ast_addr);
    let items_len: i64 = ast_aux(ast_addr);
    let s0: EmitState = es_new();
    let s1: EmitState = emit_lit_module_open(s0);
    let s2: EmitState = emit_program_items(s1, buf, items_addr, items_len, 0);
    emit_lit_module_close(s2)
}

pub fn flush_to_stdout(s: EmitState) -> i64 {
    print_bytes(string_addr(s.buf), string_len(s.buf))
}

// ===========================================================================
// SECTION 5 — COMBINED DRIVER (Phase 6.5 Stage 5 APEX)
// ===========================================================================

// mindc_compile(src_addr, src_len) -> i64
//
// Runs the full compilation pipeline:
//   1. lex(src_addr, src_len)         -> Vec (token stream)
//   2. parse(tokens, src_addr)         -> i64 (AST root / ast_program)
//   3. typecheck(ast_root, src_addr)   -> String (type-check report, unused)
//   4. lower_program(ast_root, src_addr) -> EmitState (MLIR text accumulator)
//
// Returns the i64 heap-record address of the EmitState.  The caller
// reads EmitState fields at the returned address:
//   offset  0 : buf     (String handle — addr/len/cap)
//   offset  8 : next_id (SSA value counter)
//   offset 16 : last_id (most-recently allocated SSA id)
//
// The Python harness (bootstrap_smoke.py) reads the EmitState via
// ctypes and compares the decoded String bytes to EXPECTED.md.

// mindc_compile returns EmitState (heap-record address in Option-C ABI).
// The Python harness calls it with c_int64 restype and reads the
// EmitState fields at the returned address:
//   offset  0 : buf     (String handle)
//   offset  8 : next_id (SSA counter)
//   offset 16 : last_id (last allocated SSA id)
pub fn mindc_compile(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let _tc: String = typecheck(ast_root, src_addr);
    lower_program(ast_root, src_addr)
}

// ===========================================================================
// SECTION 6 — STRUCT FIELD-NAME RETENTION (field-access groundwork, part 1)
//
// ADDITIVE / canary-isolated. The canonical parse_struct_def (above) still
// discards field names and emits exactly one stub leaf, so this code does NOT
// touch the mic@1/mic@3 emit path, EmitState, or the fixed-point bytes. It only
// PARSES the `name: type` field pairs of a struct and RETAINS the ordered
// field-name spans in a heap table, exposed via the selftests below. The table
// is the prerequisite for part 2 (param-type resolution + registry emit +
// flatten_ast field-idx); nothing here is reached through mindc_compile.
//
// Heap field-table layout (a single __mind_alloc block):
//   word[0]              : field count (n)
//   word[1 + 2*k + 0]    : span_lo of field k's name
//   word[1 + 2*k + 1]    : span_hi of field k's name
// Capacity is fixed at 64 fields (table = 8 * (1 + 2*64) = 1032 bytes), which
// comfortably covers any struct in main.mind's own grammar.
// ===========================================================================

pub fn sft_table_cap() -> i64 {
    64
}

pub fn sft_table_alloc() -> i64 {
    // 1 count word + cap*2 span words, 8 bytes each.
    let t: i64 = __mind_alloc((1 + sft_table_cap() * 2) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn sft_table_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

pub fn sft_table_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 2 + 0) * 8)
}

pub fn sft_table_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 2 + 1) * 8)
}

// Append one field-name span (lo, hi) to the table, bumping the count. Silently
// drops fields beyond sft_table_cap() (no struct in the grammar reaches it).
pub fn sft_table_push(t: i64, name_lo: i64, name_hi: i64) -> i64 {
    let n: i64 = sft_table_count(t);
    if n >= sft_table_cap() {
        return t;
    }
    __mind_store_i64(t + (1 + n * 2 + 0) * 8, name_lo);
    __mind_store_i64(t + (1 + n * 2 + 1) * 8, name_hi);
    __mind_store_i64(t + 0, n + 1);
    t
}

// Scan the token stream for the `{` that opens the first struct body. Returns
// the token index of the field-list start (just past `{`), or -1 if no struct.
// Mirrors parse_item's dispatch: a tk_ident whose span spells "struct" is the
// struct keyword; the next token is the name, then `{`.
pub fn sft_find_struct_body(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_struct_kw(buf, lo, hi) == 1 {
            // pos = struct kw, pos+1 = Name, pos+2 = `{`, fields start at pos+3.
            return pos + 3;
        }
    }
    sft_find_struct_body(toks, buf, pos + 1)
}

// Parse the `name: type` field pairs of a struct body into the table `t`.
// `pos` points just past `{`. Each field is `ident : type [,]`; the body ends at
// `}`. Retains only the field-NAME span (the ident before `:`). Tail-recursive.
pub fn sft_parse_fields(toks: Vec, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        return t;
    }
    // Expect: ident(name) colon ident(type). Retain the name span.
    if tok_kind(toks, pos) == tk_ident() {
        let _t: i64 = sft_table_push(t, tok_lo(toks, pos), tok_hi(toks, pos));
        // Skip `: type`. If the next token is a colon, step over colon + type.
        if tok_kind(toks, pos + 1) == tk_colon() {
            // After the type token may come a `,` separator; the loop's rbrace /
            // ident checks handle both the trailing-comma and no-comma cases.
            if tok_kind(toks, pos + 3) == tk_comma() {
                return sft_parse_fields(toks, pos + 4, t);
            }
            return sft_parse_fields(toks, pos + 3, t);
        }
    }
    // Defensive: unexpected token — advance one to avoid a non-terminating scan.
    sft_parse_fields(toks, pos + 1, t)
}

// Build (and return) a fresh field table for the first struct in `src`.
pub fn sft_build_table(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = sft_table_alloc();
    let body: i64 = sft_find_struct_body(tokens, src_addr, 0);
    if body < 0 {
        return t;
    }
    sft_parse_fields(tokens, body, t)
}

// Selftest export: number of fields parsed for the (first) struct in `src`.
pub fn selftest_struct_field_count(src_addr: i64, src_len: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    sft_table_count(t)
}

// Selftest export: the span_lo of field `i`'s name (or -1 if out of range).
pub fn selftest_struct_field_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_lo(t, i)
}

// Selftest export: the span_hi of field `i`'s name (or -1 if out of range).
pub fn selftest_struct_field_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_hi(t, i)
}

// Selftest export: the length (in bytes) of field `i`'s name span (hi - lo),
// or -1 if out of range. Lets a harness verify the right ident was retained
// without dealing in absolute source offsets.
pub fn selftest_struct_field_name_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_hi(t, i) - sft_table_name_lo(t, i)
}

// ===========================================================================
// SECTION 6c — RECURSIVE-EMIT STRTAB COLLECTION FOR FIELD STRINGS (cutover
// fold, step 1). COLLECTION ONLY — no mic@3 byte-output, no canary touch.
//
// The recursive emit (selftest_mic3_module_from_ast) builds its string table via
// a SEPARATE collection pass (build_module_strtab -> collect_fn_strings ->
// collect_body_strings -> collect_expr_strings), mirroring Rust collect_strings /
// collect_instr_strings (src/ir/compact/v3/emit.rs ~492-586). Step 1 extends that
// pass so an ast_field (kind 17) anywhere in a body interns the synthetic
// "__mind_load_i64" call name in the EXACT first-seen order the oracle's
// collect_instr_strings(Instr::Call) produces (receiver strings first, then the
// load name; the CONST/BINOP offset path interns nothing; struct type/field names
// come from the registry pass, NOT the body traversal).
//
// These selftest exports run the collection pass over a parsed module into
// internally-allocated scratch and expose the interned table by index, so a unit
// smoke can assert names + first-seen order WITHOUT any byte emission.
// ===========================================================================

// Allocate scratch, lex+parse `src`, run build_module_strtab over the top-level
// item list, and return the strtab triple packed into a 4-i64 cell:
//   cell[0] = strbuf, cell[1] = offs, cell[2] = ccell, cell[3] = interned count.
// Returns the cell pointer. Scratch is sized for any small field-using module in
// the test grammar (4 KiB names, 256 offset slots).
pub fn cfs_run(src_addr: i64, src_len: i64) -> i64 {
    let strbuf: i64 = __mind_alloc(4096);
    let offs: i64 = __mind_alloc(256 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let cell: i64 = __mind_alloc(4 * 8);
    __mind_store_i64(cell + 0, strbuf);
    __mind_store_i64(cell + 8, offs);
    __mind_store_i64(cell + 16, ccell);
    __mind_store_i64(cell + 24, __mind_load_i64(ccell));
    cell
}

// Selftest export: number of strings interned by the collection pass for `src`.
pub fn selftest_collect_field_strings_count(src_addr: i64, src_len: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    __mind_load_i64(cell + 24)
}

// Selftest export: byte length of interned string `i` (offs[i+1]-offs[i]), or -1
// if out of range. Lets the smoke verify e.g. "__mind_load_i64" landed (len 15).
pub fn selftest_collect_field_strings_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let offs: i64 = __mind_load_i64(cell + 8);
    __mind_load_i64(offs + (i + 1) * 8) - __mind_load_i64(offs + i * 8)
}

// Selftest export: the j-th byte of interned string `i`, or -1 if out of range.
// The smoke reconstructs each interned name to assert first-seen order exactly.
pub fn selftest_collect_field_strings_byte(src_addr: i64, src_len: i64, i: i64, j: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let strbuf: i64 = __mind_load_i64(cell + 0);
    let offs: i64 = __mind_load_i64(cell + 8);
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if j < 0 {
        return 0 - 1;
    }
    if j >= hi - lo {
        return 0 - 1;
    }
    load_byte(strbuf, lo + j)
}

// ---------------------------------------------------------------------------
// SECTION 6c (step 2) — RECURSIVE-EMIT REGISTRY-STRTAB COLLECTION.
// COLLECTION ONLY — no mic@3 byte-output, no canary touch. Purely additive.
//
// After the body-traversal pass (build_module_strtab, step 1) interns the instr
// strings, the canonical full string table APPENDS the struct_defs registry
// strings. The Rust oracle (src/ir/compact/v3/emit.rs collect_struct_def_strings,
// ~600-609) iterates module.struct_defs, which is a BTreeMap<String, Vec<String>>
// — so structs are visited in NAME-SORTED (alphabetical) order, NOT declaration
// order, and for each struct its TYPE name is interned first, then each FIELD name
// in declared order. Verified vs real --emit-mic3 on an out-of-declaration-order
// pair (declared Zeta, Alpha -> interned Alpha,p,q then Zeta,x,y).
//
// SECTION 6b's srt_* registry stores structs in DECLARATION order, so this pass
// drives a sorted traversal: srt_sorted_kth picks the k-th-smallest struct name,
// then srt_intern_all-style interning runs in that order. intern_span dedups, so
// re-interning is idempotent; struct/field names are distinct from instr strings.
// ---------------------------------------------------------------------------

// Lexicographic comparison of src[alo..ahi) vs src[blo..bhi): -1 if a<b, 0 if
// equal, 1 if a>b. Byte-wise compare to the shorter length; on a tie the shorter
// span is smaller. Mirrors Rust String Ord (BTreeMap key ordering) for ASCII
// identifier names. Both spans index the SAME source buffer.
pub fn span_cmp(src: i64, alo: i64, ahi: i64, blo: i64, bhi: i64) -> i64 {
    span_cmp_loop(src, alo, ahi, blo, bhi, 0)
}
pub fn span_cmp_loop(src: i64, alo: i64, ahi: i64, blo: i64, bhi: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        if blo + k >= bhi {
            return 0;
        }
        return 0 - 1;
    }
    if blo + k >= bhi {
        return 1;
    }
    let ca: i64 = load_byte(src, alo + k);
    let cb: i64 = load_byte(src, blo + k);
    if ca < cb {
        return 0 - 1;
    }
    if ca > cb {
        return 1;
    }
    span_cmp_loop(src, alo, ahi, blo, bhi, k + 1)
}

// Count how many struct names in registry `t` are strictly less than struct k's
// name (lexicographically). This is k's rank in sorted order — a selection-sort
// position without mutating the registry. (Struct names are distinct, so rank is
// unique.)
pub fn srt_rank_of(t: i64, src: i64, k: i64) -> i64 {
    srt_rank_loop(t, src, k, 0, 0)
}
pub fn srt_rank_loop(t: i64, src: i64, k: i64, j: i64, acc: i64) -> i64 {
    if j >= srt_count(t) {
        return acc;
    }
    if j == k {
        return srt_rank_loop(t, src, k, j + 1, acc);
    }
    if span_cmp(src, srt_name_lo(t, j), srt_name_hi(t, j), srt_name_lo(t, k), srt_name_hi(t, k)) < 0 {
        return srt_rank_loop(t, src, k, j + 1, acc + 1);
    }
    srt_rank_loop(t, src, k, j + 1, acc)
}

// Return the DECLARATION-order index of the struct whose name has sorted rank
// `r` (i.e. the r-th-smallest name), or -1 if none. Used to walk the registry in
// the BTreeMap order the oracle interns.
pub fn srt_sorted_kth(t: i64, src: i64, r: i64) -> i64 {
    srt_sorted_kth_loop(t, src, r, 0)
}
pub fn srt_sorted_kth_loop(t: i64, src: i64, r: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0 - 1;
    }
    if srt_rank_of(t, src, k) == r {
        return k;
    }
    srt_sorted_kth_loop(t, src, r, k + 1)
}

// Append the registry strings (struct type names + field names) to the strtab in
// BTreeMap-sorted order, reusing srt_intern_all's per-struct interning (type name
// then each field). `r` is the current sorted rank. Idempotent / additive.
pub fn build_module_registry_strtab(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> i64 {
    if r >= srt_count(t) {
        return 0;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    build_module_registry_strtab(strbuf, offs, ccell, src, t, r + 1)
}

// Run the FULL strtab collection for a field-using module: the step-1 body pass
// (instr strings) THEN the step-2 registry pass (struct type+field names, sorted),
// into internally-allocated scratch. Returns a 4-i64 cell:
//   cell[0]=strbuf, cell[1]=offs, cell[2]=ccell, cell[3]=interned count.
// This is the recursive-emit equivalent of emit_mic3's pre-pass
// (collect_strings ; collect_struct_def_strings). COLLECTION ONLY.
pub fn cfs_full_run(src_addr: i64, src_len: i64) -> i64 {
    let strbuf: i64 = __mind_alloc(4096);
    let offs: i64 = __mind_alloc(256 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let r0: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let srt: i64 = srt_build(src_addr, src_len);
    let r1: i64 = build_module_registry_strtab(strbuf, offs, ccell, src_addr, srt, 0);
    let cell: i64 = __mind_alloc(4 * 8);
    __mind_store_i64(cell + 0, strbuf);
    __mind_store_i64(cell + 8, offs);
    __mind_store_i64(cell + 16, ccell);
    __mind_store_i64(cell + 24, __mind_load_i64(ccell));
    cell
}

// Selftest export: total strings interned by the FULL (instr + registry) pass.
pub fn selftest_full_strtab_count(src_addr: i64, src_len: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    __mind_load_i64(cell + 24)
}

// Selftest export: byte length of FULL-pass interned string `i`, or -1.
pub fn selftest_full_strtab_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let offs: i64 = __mind_load_i64(cell + 8);
    __mind_load_i64(offs + (i + 1) * 8) - __mind_load_i64(offs + i * 8)
}

// Selftest export: the j-th byte of FULL-pass interned string `i`, or -1.
pub fn selftest_full_strtab_byte(src_addr: i64, src_len: i64, i: i64, j: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let strbuf: i64 = __mind_load_i64(cell + 0);
    let offs: i64 = __mind_load_i64(cell + 8);
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if j < 0 {
        return 0 - 1;
    }
    if j >= hi - lo {
        return 0 - 1;
    }
    load_byte(strbuf, lo + j)
}

// ===========================================================================
// SECTION 6b — MULTI-STRUCT REGISTRY TABLE (field-access groundwork, part 1b)
//
// ADDITIVE / canary-isolated. Extends SECTION 6 from "the FIRST struct" to "ALL
// structs in declaration order", so a `recv.field` whose receiver is declared as
// the 2nd+ struct resolves against the CORRECT struct's field list. Mirrors how
// the Rust struct_defs registry (src/ir/compact/v3/emit.rs) lists every struct,
// and how emit_mic3 interns each struct's type name + fields in source order.
//
// Heap registry-table layout (a single __mind_alloc block):
//   word[0]                       : struct count (N)
//   per struct k, a fixed slot at  base = 1 + k * srt_slot_words():
//     slot[0]                     : span_lo of struct k's NAME
//     slot[1]                     : span_hi of struct k's NAME
//     slot[2]                     : field count of struct k (fc)
//     slot[3 + 2*j + 0]           : span_lo of field j's name
//     slot[3 + 2*j + 1]           : span_hi of field j's name
// Capacity is fixed at 16 structs * 16 fields each, comfortably covering any
// source in main.mind's own grammar.
// ===========================================================================

pub fn srt_struct_cap() -> i64 {
    16
}

pub fn srt_field_cap() -> i64 {
    16
}

// Words per struct slot: name_lo + name_hi + field_count + field_cap*2 spans.
pub fn srt_slot_words() -> i64 {
    3 + srt_field_cap() * 2
}

pub fn srt_alloc() -> i64 {
    // 1 count word + struct_cap slots, 8 bytes each.
    let t: i64 = __mind_alloc((1 + srt_struct_cap() * srt_slot_words()) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn srt_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

// Base WORD index of struct k's slot.
pub fn srt_slot_base(k: i64) -> i64 {
    1 + k * srt_slot_words()
}

pub fn srt_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 0) * 8)
}

pub fn srt_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 1) * 8)
}

pub fn srt_field_count(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 2) * 8)
}

pub fn srt_field_lo(t: i64, k: i64, j: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 3 + j * 2 + 0) * 8)
}

pub fn srt_field_hi(t: i64, k: i64, j: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 3 + j * 2 + 1) * 8)
}

// Append a struct with name span (nlo, nhi) and zero fields, returning its index.
pub fn srt_push_struct(t: i64, nlo: i64, nhi: i64) -> i64 {
    let n: i64 = srt_count(t);
    if n >= srt_struct_cap() {
        return n;
    }
    __mind_store_i64(t + (srt_slot_base(n) + 0) * 8, nlo);
    __mind_store_i64(t + (srt_slot_base(n) + 1) * 8, nhi);
    __mind_store_i64(t + (srt_slot_base(n) + 2) * 8, 0);
    __mind_store_i64(t + 0, n + 1);
    n
}

// Append a field span (flo, fhi) to struct k, bumping its field count.
pub fn srt_push_field(t: i64, k: i64, flo: i64, fhi: i64) -> i64 {
    let fc: i64 = srt_field_count(t, k);
    if fc >= srt_field_cap() {
        return t;
    }
    __mind_store_i64(t + (srt_slot_base(k) + 3 + fc * 2 + 0) * 8, flo);
    __mind_store_i64(t + (srt_slot_base(k) + 3 + fc * 2 + 1) * 8, fhi);
    __mind_store_i64(t + (srt_slot_base(k) + 2) * 8, fc + 1);
    t
}

// Parse the `name: type` field pairs of struct k's body into the registry `t`.
// `pos` points just past `{`; ends at `}`. Retains each field-NAME span. Mirrors
// sft_parse_fields exactly but writes into struct k's slot. Tail-recursive.
pub fn srt_parse_fields(toks: Vec, pos: i64, t: i64, k: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let _t: i64 = srt_push_field(t, k, tok_lo(toks, pos), tok_hi(toks, pos));
        if tok_kind(toks, pos + 1) == tk_colon() {
            if tok_kind(toks, pos + 3) == tk_comma() {
                return srt_parse_fields(toks, pos + 4, t, k);
            }
            return srt_parse_fields(toks, pos + 3, t, k);
        }
    }
    srt_parse_fields(toks, pos + 1, t, k)
}

// Scan the token stream collecting EVERY `struct Name { fields }` into the
// registry `t` in declaration order. `pos` is the current token index. Mirrors
// sft_find_struct_body's struct-keyword detection but does not stop at the first.
pub fn srt_collect(toks: Vec, buf: i64, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_struct_kw(buf, lo, hi) == 1 {
            // pos = struct kw, pos+1 = Name, pos+2 = `{`, fields start at pos+3.
            let k: i64 = srt_push_struct(t, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1));
            let _t: i64 = srt_parse_fields(toks, pos + 3, t, k);
            // Skip past this struct body to avoid re-scanning its inner idents.
            let after: i64 = skip_to_rbrace(toks, pos + 3);
            return srt_collect(toks, buf, after, t);
        }
    }
    srt_collect(toks, buf, pos + 1, t)
}

// Build (and return) a fresh registry covering every struct in `src`.
pub fn srt_build(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = srt_alloc();
    srt_collect(tokens, src_addr, 0, t)
}

// RI-D2 S-C1 fix: struct registry from an ALREADY-lexed token stream (the srt twin of
// frt_build_from_tokens). Lets the whole-compiler native path (selftest_native_elf_hb)
// build BOTH registries from the single token Vec it already lexed, instead of two more
// full-source lexes into the fixed 1 GiB native bump arena. Byte-identical registry.
pub fn srt_build_from_tokens(tokens: Vec, src_addr: i64) -> i64 {
    let t: i64 = srt_alloc();
    srt_collect(tokens, src_addr, 0, t)
}

// Find the struct index whose NAME span equals src[tlo..thi), or -1. This is the
// multi-struct key: the receiver's declared type name selects the right struct.
pub fn srt_find_by_name(t: i64, src: i64, tlo: i64, thi: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0 - 1;
    }
    if span_bytes_equal(src, tlo, thi, srt_name_lo(t, k), srt_name_hi(t, k)) == 1 {
        return k;
    }
    srt_find_by_name(t, src, tlo, thi, k + 1)
}

// Resolve field name src[flo..fhi) to its index within struct k, or -1.
pub fn srt_field_index(t: i64, k: i64, src: i64, flo: i64, fhi: i64, j: i64) -> i64 {
    if j >= srt_field_count(t, k) {
        return 0 - 1;
    }
    if span_bytes_equal(src, flo, fhi, srt_field_lo(t, k, j), srt_field_hi(t, k, j)) == 1 {
        return j;
    }
    srt_field_index(t, k, src, flo, fhi, j + 1)
}

// Sum of field counts across structs 0..k (exclusive). The accessed field's
// string index = 4 (fn,param,load,struct0-type) ... actually each struct k
// contributes (1 type-name + its fields) strings in order, so the base string
// index of struct k's FIRST field is 3 + (k+1) + cumulative_fields(k); see
// srt_field_strbase below.
pub fn srt_cumulative_fields(t: i64, k: i64, acc: i64) -> i64 {
    if k <= 0 {
        return acc;
    }
    srt_cumulative_fields(t, k - 1, acc + srt_field_count(t, k - 1))
}

// String index of the FIRST field of struct k. Strings are interned in order:
//   0: fn name, 1: param name, 2: __mind_load_i64,
//   then per struct in declaration order: [type name] [field0..fieldN-1].
// So struct k's type name is at  3 + k + cumulative_fields(k); its first field
// at one past that.
pub fn srt_field_strbase(t: i64, k: i64) -> i64 {
    3 + k + srt_cumulative_fields(t, k, 0) + 1
}

// String index of struct k's TYPE name.
pub fn srt_type_strbase(t: i64, k: i64) -> i64 {
    3 + k + srt_cumulative_fields(t, k, 0)
}

// ---- SORTED-ORDER strbase math (cutover fold step 3) ----
// The canonical full string table appends registry strings in BTreeMap-sorted
// (struct-name) order, so a struct's string indices are keyed on its SORTED RANK,
// not its declaration index. These mirror srt_cumulative_fields / *_strbase but
// walk the first `r` SORTED-rank structs. cumulative_fields_sorted(r) sums the
// field counts of the r smallest-named structs; type_strbase_sorted(r) =
// 3 + r + that; field_strbase_sorted(r) = one past the type name.

// Sum of field counts across the structs of sorted rank 0..r (exclusive).
pub fn srt_cumulative_fields_sorted(t: i64, src: i64, r: i64, acc: i64) -> i64 {
    if r <= 0 {
        return acc;
    }
    let kp: i64 = srt_sorted_kth(t, src, r - 1);
    srt_cumulative_fields_sorted(t, src, r - 1, acc + srt_field_count(t, kp))
}

// String index of the TYPE name of the struct at sorted rank r.
pub fn srt_type_strbase_sorted(t: i64, src: i64, r: i64) -> i64 {
    3 + r + srt_cumulative_fields_sorted(t, src, r, 0)
}

// String index of the FIRST field of the struct at sorted rank r.
pub fn srt_field_strbase_sorted(t: i64, src: i64, r: i64) -> i64 {
    srt_type_strbase_sorted(t, src, r) + 1
}

// Intern every struct's strings in BTreeMap-sorted (name) order: for each sorted
// rank r, intern the type name then each field in declared order. Mirrors the
// Rust oracle's collect_struct_def_strings BTreeMap traversal (step 2's
// build_module_registry_strtab) but into the byte-emitter's own strbuf, so the
// emitted string indices match the sorted strtab. intern_span dedups.
pub fn srt_intern_all_sorted(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> i64 {
    if r >= srt_count(t) {
        return 0;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    srt_intern_all_sorted(strbuf, offs, ccell, src, t, r + 1)
}

// Emit the struct_defs registry for ALL N structs in BTreeMap-sorted (name) order:
// each entry is uleb(type_str_idx) || uleb(field_count) || field string idxs, the
// idxs computed against SORTED rank. Mirrors srt_emit_registry but sorted.
pub fn srt_emit_registry_sorted(s: EmitState, t: i64, src: i64, r: i64) -> EmitState {
    if r >= srt_count(t) {
        return s;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let s1: EmitState = emit_uleb128(s, srt_type_strbase_sorted(t, src, r));
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = ffa_emit_field_idxs(s2, srt_field_strbase_sorted(t, src, r), fc, 0);
    srt_emit_registry_sorted(s3, t, src, r + 1)
}

// Emit the struct_defs registry for ALL N structs in BTreeMap-sorted (name) order,
// resolving each string index by RE-INTERNING its span (intern_span is idempotent
// and dedup-aware, so it returns the slot already assigned by the strtab pass —
// independent of how many instruction strings preceded it). This is the dedup- and
// base-offset-correct variant of srt_emit_registry_sorted (which assumes the fixed
// 3-string field-read instr base); used by the general N-fn nfn driver where the
// instruction-string base varies per module. Each entry =
// uleb(type_str_idx) || uleb(field_count) || field string idxs.
pub fn srt_emit_registry_sorted_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> EmitState {
    if r >= srt_count(t) {
        return s;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let ty_idx: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let s1: EmitState = emit_uleb128(s, ty_idx);
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = srt_emit_field_idxs_interned(s2, strbuf, offs, ccell, src, t, k, 0);
    srt_emit_registry_sorted_interned(s3, strbuf, offs, ccell, src, t, r + 1)
}

// Emit struct k's field string indices by re-interning each field-name span
// (idempotent), in declared field order. Mirrors ffa_emit_field_idxs_interned but
// keyed on the multi-struct registry's per-struct field spans.
pub fn srt_emit_field_idxs_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64, j: i64) -> EmitState {
    if j >= srt_field_count(t, k) {
        return s;
    }
    let idx: i64 = intern_span(strbuf, offs, ccell, src, srt_field_lo(t, k, j), srt_field_hi(t, k, j));
    let s1: EmitState = emit_uleb128(s, idx);
    srt_emit_field_idxs_interned(s1, strbuf, offs, ccell, src, t, k, j + 1)
}

// ===========================================================================
// SECTION 7 — PER-FUNCTION PARAM-TYPE TABLE (field-access groundwork, part 2)
//
// ADDITIVE / canary-isolated. Mirrors SECTION 6's heap-table idiom exactly. The
// canonical parse_fn_def / parse_params_rest (above) are UNCHANGED: this code
// only re-scans a fn signature's `name: Type` param list and RETAINS the ordered
// (param-name span, type-name span) pairs in a heap table, exposed via the
// selftests below. It does NOT touch the mic@1/mic@3 emit path, EmitState, or the
// fixed-point bytes; nothing here is reached through mindc_compile.
//
// The (param-name -> declared type-name) binding is the receiver-type info a
// later `recv.field` access needs: resolve recv -> its declared struct type
// (part 2, this table) -> the field index in that struct (part 1's field table).
//
// Heap param-type-table layout (a single __mind_alloc block):
//   word[0]              : param count (n)
//   word[1 + 4*k + 0]    : span_lo of param k's NAME
//   word[1 + 4*k + 1]    : span_hi of param k's NAME
//   word[1 + 4*k + 2]    : span_lo of param k's declared TYPE name
//   word[1 + 4*k + 3]    : span_hi of param k's declared TYPE name
// Capacity is fixed at 32 params (table = 8 * (1 + 4*32) = 1032 bytes), which
// comfortably covers any fn signature in main.mind's own grammar.
// ===========================================================================

pub fn ptt_table_cap() -> i64 {
    32
}

pub fn ptt_table_alloc() -> i64 {
    // 1 count word + cap*4 span words, 8 bytes each.
    let t: i64 = __mind_alloc((1 + ptt_table_cap() * 4) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn ptt_table_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

pub fn ptt_table_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 0) * 8)
}

pub fn ptt_table_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 1) * 8)
}

pub fn ptt_table_type_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 2) * 8)
}

pub fn ptt_table_type_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 3) * 8)
}

// Append one (param-name span, type-name span) row to the table, bumping the
// count. Silently drops params beyond ptt_table_cap() (no fn in the grammar
// reaches it).
pub fn ptt_table_push(t: i64, name_lo: i64, name_hi: i64, type_lo: i64, type_hi: i64) -> i64 {
    let n: i64 = ptt_table_count(t);
    if n >= ptt_table_cap() {
        return t;
    }
    __mind_store_i64(t + (1 + n * 4 + 0) * 8, name_lo);
    __mind_store_i64(t + (1 + n * 4 + 1) * 8, name_hi);
    __mind_store_i64(t + (1 + n * 4 + 2) * 8, type_lo);
    __mind_store_i64(t + (1 + n * 4 + 3) * 8, type_hi);
    __mind_store_i64(t + 0, n + 1);
    t
}

// Scan the token stream for the first fn signature's param-list start. Returns
// the token index just past `(`, or -1 if no fn. Mirrors parse_item's dispatch:
// a tk_kw_pub is skipped, a tk_kw_fn marks the signature; then pos+1 = name,
// pos+2 = `(`, params start at pos+3 (exactly parse_fn_def's layout).
pub fn ptt_find_param_list(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_kw_fn() {
        // pos = fn kw, pos+1 = Name, pos+2 = `(`, params start at pos+3.
        return pos + 3;
    }
    ptt_find_param_list(toks, pos + 1)
}

// Parse the `name: Type [,]` params of a fn signature into the table `t`.
// `pos` points just past `(`. Each param is `ident : Type`; the list ends at
// `)`. Retains both the param-NAME span and the declared TYPE-name span. Mirrors
// parse_params_rest's token layout exactly: name(pos), `:`(pos+1), Type(pos+2),
// then pos+3 is `,` (advance +4) or `)` (end). Tail-recursive.
pub fn ptt_parse_params(toks: Vec, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rparen() {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        // Expect: ident(name) colon ident(Type). Retain name + type spans.
        if tok_kind(toks, pos + 1) == tk_colon() {
            let _t: i64 = ptt_table_push(t, tok_lo(toks, pos), tok_hi(toks, pos), tok_lo(toks, pos + 2), tok_hi(toks, pos + 2));
            if tok_kind(toks, pos + 3) == tk_comma() {
                return ptt_parse_params(toks, pos + 4, t);
            }
            return ptt_parse_params(toks, pos + 3, t);
        }
    }
    // Defensive: unexpected token — advance one to avoid a non-terminating scan.
    ptt_parse_params(toks, pos + 1, t)
}

// Build (and return) a fresh param-type table for the first fn in `src`.
pub fn ptt_build_table(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = ptt_table_alloc();
    let plist: i64 = ptt_find_param_list(tokens, 0);
    if plist < 0 {
        return t;
    }
    ptt_parse_params(tokens, plist, t)
}

// Selftest export: number of params parsed for the (first) fn in `src`.
pub fn selftest_param_type_count(src_addr: i64, src_len: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_count(t)
}

// Selftest export: the span_lo of param `i`'s declared TYPE name (or -1).
pub fn selftest_param_type_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_lo(t, i)
}

// Selftest export: the span_hi of param `i`'s declared TYPE name (or -1).
pub fn selftest_param_type_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_hi(t, i)
}

// Selftest export: the length (bytes) of param `i`'s declared TYPE name span
// (hi - lo), or -1 if out of range.
pub fn selftest_param_type_name_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_hi(t, i) - ptt_table_type_lo(t, i)
}

// Selftest export: the span_lo of param `i`'s NAME (or -1). Lets a harness
// confirm the receiver binding (param-name -> declared type) is intact.
pub fn selftest_param_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_name_lo(t, i)
}

// Selftest export: the span_hi of param `i`'s NAME (or -1).
pub fn selftest_param_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_name_hi(t, i)
}

// ===========================================================================
// SECTION 8 — METHOD-CALL PARSER (UFCS groundwork, part 1)
//
// ADDITIVE / canary-isolated. A pure PARSER step — NO mic@3 byte-output, NO
// EmitState — so it cannot perturb the canary fixed point and cannot hit the
// EmitState segfault. It proves the pure-MIND front-end can PARSE a method call
// `recv.method(args...)` into a distinct node, retaining the method-NAME span,
// the receiver, and the argument count.
//
// The Rust oracle (src/eval/lower.rs MethodCall arm) lowers `recv.method(args)`
// via UFCS desugar to a plain Instr::Call named `{lowercase(ReceiverType)}_{method}`
// with the receiver threaded as the FIRST call arg: call_args = [recv, args...].
// Confirmed live: `p.dist(7)` on `p: Point` interns + calls `point_dist` in the
// mic@3 string table (130-byte artifact). Capturing the method-name span + arg
// count here is the prerequisite for that desugar; the receiver-type resolution
// (already built in SECTION 7's param-type table) supplies the `{lowercase(T)}_`
// prefix in a later, byte-output part.
//
// `ast_method` node layout (reuses the 7xi64 ast record):
//   [kind=ast_method, span_lo, span_hi, receiver(child0),
//    method_lo(child1), method_hi(child2), arg_count(aux)]
//
// This helper is self-contained: it token-scans for the first `ident . ident (`
// method-call shape (mirroring sft_find_struct_body's scan), parses the receiver
// as an ident leaf, and counts args via the existing parse_args_rest. It does
// NOT touch parse_postfix_rest (the shared parser), so the canary parse of
// main.mind's own source — which contains zero `recv.method(...)` calls — is
// byte-identical.
// ===========================================================================

// Build an ast_method node from an already-resolved receiver + method span +
// arg count.
pub fn mc_new_method(span_lo: i64, span_hi: i64, receiver: i64, method_lo: i64, method_hi: i64, arg_count: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_method());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, receiver);
    __mind_store_i64(n + 32, method_lo);
    __mind_store_i64(n + 40, method_hi);
    __mind_store_i64(n + 48, arg_count);
    n
}

// Scan the token stream for the first `ident . ident (` method-call shape.
// Returns the token index of the RECEIVER ident, or -1 if none. (`recv` at pos,
// `.` at pos+1, `method` ident at pos+2, `(` at pos+3.)
pub fn mc_find_method_call(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if tok_kind(toks, pos + 1) == tk_dot() {
            if tok_kind(toks, pos + 2) == tk_ident() {
                if tok_kind(toks, pos + 3) == tk_lparen() {
                    return pos;
                }
            }
        }
    }
    mc_find_method_call(toks, pos + 1)
}

// Parse the first method call in `src` into an ast_method node, or 0 if none.
pub fn mc_parse_first(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let rpos: i64 = mc_find_method_call(tokens, 0);
    if rpos < 0 {
        return 0;
    }
    let recv_lo: i64 = tok_lo(tokens, rpos);
    let recv_hi: i64 = tok_hi(tokens, rpos);
    let receiver: i64 = ast_new_leaf(ast_ident(), recv_lo, recv_hi);
    let method_lo: i64 = tok_lo(tokens, rpos + 2);
    let method_hi: i64 = tok_hi(tokens, rpos + 2);
    // pos+3 = `(`. Zero-arg fast path: `(` immediately followed by `)`.
    let after_open: i64 = rpos + 4;
    if tok_kind(tokens, after_open) == tk_rparen() {
        let close_hi: i64 = tok_hi(tokens, after_open);
        return mc_new_method(recv_lo, close_hi, receiver, method_lo, method_hi, 0);
    }
    let args_res: ParseResult = parse_args_rest(tokens, after_open, src_addr, vec_new());
    let after_args: i64 = pr_pos(args_res);
    let args_node: i64 = pr_node(args_res);
    let arg_count: i64 = ast_aux(args_node);
    let close_hi: i64 = tok_hi(tokens, after_args);
    mc_new_method(recv_lo, close_hi, receiver, method_lo, method_hi, arg_count)
}

// Selftest export: 1 if `src` contains a parseable method call, else 0.
pub fn selftest_method_present(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0;
    }
    1
}

// Selftest export: the span_lo of the method NAME (or -1 if no method call).
pub fn selftest_method_name_lo(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child1(m)
}

// Selftest export: the span_hi of the method NAME (or -1 if no method call).
pub fn selftest_method_name_hi(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child2(m)
}

// Selftest export: the length (bytes) of the method NAME span, or -1.
pub fn selftest_method_name_len(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child2(m) - ast_child1(m)
}

// Selftest export: the number of arguments parsed in the method call, or -1.
pub fn selftest_method_arg_count(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_aux(m)
}

// Selftest export: the AST kind of the receiver node (proves the receiver
// parsed as an ident leaf), or -1.
pub fn selftest_method_recv_kind(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_kind(ast_child0(m))
}

// PARSE-ONLY struct-literal probes (additive, canary-isolated — reached only via
// these exports, never through mindc_compile). Parse the WHOLE source buffer as a
// single expression with struct-lit ALLOWED (no_struct=0) starting at token 0;
// `selftest_struct_lit_kind` returns the root AST kind (ast_struct_lit()==19 for
// `Name { .. }`), `selftest_struct_lit_field_count` the field count. These prove
// the parse half landed; the emit half still fails closed (flatten_ast rejects
// ast_struct_lit), so no bytes are produced for a struct-lit body yet.
pub fn selftest_struct_lit_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let e: ParseResult = parse_expr_ns(toks, 0, src_addr, 0);
    ast_kind(pr_node(e))
}

pub fn selftest_struct_lit_field_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let e: ParseResult = parse_expr_ns(toks, 0, src_addr, 0);
    let n: i64 = pr_node(e);
    if ast_kind(n) != ast_struct_lit() {
        return 0 - 1;
    }
    ast_aux(n)
}

// Selftest export: the span_lo of the RECEIVER (or -1). Lets a harness confirm
// the receiver binding is intact for the later UFCS type-prefix resolution.
pub fn selftest_method_recv_lo(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_span_lo(ast_child0(m))
}

// ===========================================================================
// SECTION 9 — METHOD-CALL RECEIVER-TYPE RESOLUTION -> UFCS CALLEE (part 2)
//
// ADDITIVE / canary-isolated. PARSER + RESOLUTION + STRING-BUILDING only — NO
// mic@3 byte-output, NO EmitState, NO touch of the canary. It cannot perturb the
// fixed point and cannot hit the EmitState segfault. It computes the UFCS callee
// NAME for a `recv.method(args)` call so part 3 (the byte-output) can intern it.
//
// The Rust oracle (src/eval/lower.rs MethodCall arm) desugars `recv.method(args)`
// to a plain Instr::Call named `{lowercase(ReceiverType)}_{method}`, receiver
// threaded as the FIRST call arg. Example: `p: Point`, `p.dist(7)` -> callee
// "point_dist". This part resolves recv -> its declared struct type T (reusing
// SECTION 7's param-type table ptt_*), then builds the callee string
// `{lowercase(T)}_{method}` into a caller-provided byte buffer.
//
// Resolution: ptt_build_table parses the (first) fn's params into the
// param-name -> declared-type-name table; mcr_find_param_by_name scans it for
// the param whose NAME bytes equal the receiver ident, yielding the param row
// (and thus its declared TYPE span). The lowercase transform maps ASCII A-Z
// (65..90) to a-z (+32); all other bytes pass through unchanged (mirrors the
// Rust to_lowercase on the leading type segment used by the UFCS desugar).
// ===========================================================================

// Lowercase one ASCII byte: A-Z (65..90) -> +32, all else unchanged.
pub fn mcr_lower_byte(b: i64) -> i64 {
    if b >= 65 {
        if b <= 90 {
            return b + 32;
        }
    }
    b
}

// Find the param index whose NAME span equals the receiver ident src[recv_lo..
// recv_hi); returns the index or -1. Tail-recursive over the ptt rows.
pub fn mcr_find_param_by_name(ptt: i64, src: i64, recv_lo: i64, recv_hi: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0 - 1;
    }
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k)) == 1 {
        return k;
    }
    mcr_find_param_by_name(ptt, src, recv_lo, recv_hi, k + 1)
}

// Write the lowercased bytes of src[lo..hi) into outbuf at cursor `j`; return the
// new cursor. Single-byte writes (__mind_store_i8), byte-contiguous.
pub fn mcr_write_lowered(outbuf: i64, j: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return j;
    }
    __mind_store_i8(outbuf + j, mcr_lower_byte(load_byte(src, lo)));
    mcr_write_lowered(outbuf, j + 1, src, lo + 1, hi)
}

// Write the raw (unmodified) bytes of src[lo..hi) into outbuf at cursor `j`;
// return the new cursor.
pub fn mcr_write_raw(outbuf: i64, j: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return j;
    }
    __mind_store_i8(outbuf + j, load_byte(src, lo));
    mcr_write_raw(outbuf, j + 1, src, lo + 1, hi)
}

// Resolve the receiver of the first method call in `src` to its declared struct
// type span. Returns a packed 1-i64 cell address holding [type_lo, type_hi] is
// awkward without tuples, so we expose the spans via dedicated selftests below
// and centralize the resolution here returning the matched ptt param index
// (-1 = no method call / receiver not a known param).
pub fn mcr_resolve_recv_param(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    let recv_lo: i64 = ast_span_lo(ast_child0(m));
    let recv_hi: i64 = ast_span_hi(ast_child0(m));
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    mcr_find_param_by_name(ptt, src_addr, recv_lo, recv_hi, 0)
}

// Selftest export: the ptt param index the receiver resolves to, or -1.
pub fn selftest_method_recv_param_idx(src_addr: i64, src_len: i64) -> i64 {
    mcr_resolve_recv_param(src_addr, src_len)
}

// Selftest export: span_lo of the receiver's resolved declared TYPE name, or -1.
pub fn selftest_method_recv_type_lo(src_addr: i64, src_len: i64) -> i64 {
    let k: i64 = mcr_resolve_recv_param(src_addr, src_len);
    if k < 0 {
        return 0 - 1;
    }
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_type_lo(ptt, k)
}

// Selftest export: span_hi of the receiver's resolved declared TYPE name, or -1.
pub fn selftest_method_recv_type_hi(src_addr: i64, src_len: i64) -> i64 {
    let k: i64 = mcr_resolve_recv_param(src_addr, src_len);
    if k < 0 {
        return 0 - 1;
    }
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_type_hi(ptt, k)
}

// Build the UFCS callee name `{lowercase(ReceiverType)}_{method}` for the first
// method call in `src`, writing the bytes into the caller-provided `outbuf`.
// Returns the callee length in bytes, or -1 if there is no parseable method call
// whose receiver resolves to a known param type (fail-closed; writes nothing on
// failure). The buffer is byte-contiguous (one __mind_store_i8 per byte).
pub fn selftest_method_callee_name_into(src_addr: i64, src_len: i64, outbuf: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    let recv_lo: i64 = ast_span_lo(ast_child0(m));
    let recv_hi: i64 = ast_span_hi(ast_child0(m));
    let method_lo: i64 = ast_child1(m);
    let method_hi: i64 = ast_child2(m);
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    let k: i64 = mcr_find_param_by_name(ptt, src_addr, recv_lo, recv_hi, 0);
    if k < 0 {
        return 0 - 1;
    }
    let ty_lo: i64 = ptt_table_type_lo(ptt, k);
    let ty_hi: i64 = ptt_table_type_hi(ptt, k);
    // {lowercase(T)} then `_` (95) then {method}.
    let j1: i64 = mcr_write_lowered(outbuf, 0, src_addr, ty_lo, ty_hi);
    __mind_store_i8(outbuf + j1, 95);
    let j2: i64 = j1 + 1;
    let j3: i64 = mcr_write_raw(outbuf, j2, src_addr, method_lo, method_hi);
    j3
}

// ===========================================================================
// SECTION 10 — WHILE-LOOP STRUCTURE SELFTEST (loops part 1)
//
// ADDITIVE / canary-isolated. PARSER + STRUCTURE-READING only — NO mic@3
// byte-output, NO EmitState, NO touch of the canary mindc_compile path. It
// cannot perturb the fixed point and cannot hit the EmitState segfault.
//
// The bootstrap dispatch (parse_stmt / parse_primary) does NOT recognise the
// `while` keyword — main.mind's own source uses no while loops — so a `while`
// spelling lexes as a bare tk_ident. This selftest therefore locates the loop
// by scanning the token stream for an ident-token spelling "while", then reads
// its structure by REUSING the existing parse_expr (condition) and parse_block
// (body) helpers. It never adds `while` to the shared statement dispatch, so the
// canary parse path — and the byte-identical fixed point — is unchanged.
//
// Token shape: `while COND { BODY }` — the `while` ident at `wp`, COND is a full
// expression (parse_expr stops at `{`, which has no infix precedence), then the
// `{` opens the body block which parse_block consumes. Mirrors the Rust
// front-end's parse_while (src/parser/mod.rs): consume "while", parse_expr cond,
// expect '{', parse body stmts, expect '}'.
// ===========================================================================

// Returns 1 if the bytes buf[lo..hi) spell "while" (5 bytes:
// w=119,h=104,i=105,l=108,e=101), else 0.
pub fn is_ident_while(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo) == 119 {
            if load_byte(buf, lo + 1) == 104 {
                if load_byte(buf, lo + 2) == 105 {
                    if load_byte(buf, lo + 3) == 108 {
                        if load_byte(buf, lo + 4) == 101 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// Scan the token stream for the first ident-token spelling "while". Returns the
// token index of that `while` token, or -1 if none. Tail-recursive.
pub fn wl_find_while(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if is_ident_while(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
            return pos;
        }
    }
    wl_find_while(toks, buf, pos + 1)
}

// Selftest export: 1 if `src` contains a `while` loop, else 0.
pub fn selftest_while_present(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0;
    }
    1
}

// Selftest export: the AST kind of the while CONDITION expression, or -1 if no
// while loop. Reuses parse_expr starting just after the `while` token; for a
// comparison condition (e.g. `i < n`) this is ast_binop().
pub fn selftest_while_cond_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0 - 1;
    }
    let cond: ParseResult = parse_expr_ns(toks, wp + 1, src_addr, 1);
    ast_kind(pr_node(cond))
}

// Selftest export: the number of statements in the while BODY block, or -1 if no
// while loop. parse_expr consumes the condition (stopping at `{`), then
// parse_block consumes the body and ast_aux yields its statement count.
pub fn selftest_while_body_stmt_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0 - 1;
    }
    let cond: ParseResult = parse_expr_ns(toks, wp + 1, src_addr, 1);
    let after_cond: i64 = pr_pos(cond);
    let body: ParseResult = parse_block(toks, after_cond, src_addr);
    ast_aux(pr_node(body))
}

// ===========================================================================
// SECTION 11 — WHILE-LOOP mic@3 BYTE-OUTPUT (0x1b While) (loops part 2)
//
// ADDITIVE / canary-isolated. Emits the mic@3 byte stream of a while-loop
// counter function, byte-identical to `mindc --emit-mic3`. Reached ONLY via
// the selftest_ export below — never through the canary mindc_compile path —
// so it cannot perturb the fixed point. EmitState idiom only (es_new/es_push,
// immutable threading); no raw es field reads.
//
// Instr::While layout (src/ir/compact/v3/emit.rs:1040, mirrored here):
//   OP_WHILE(0x1b) || vid(cond_id) || uleb(cond_instrs.len) || cond_instrs...
//     || uleb(body.len) || body... || encode_named_vids(live_vars)
//     || encode_vid_vec(init_ids) || encode_vid_vec(exit_ids)
//
// The oracle target is `pub fn count(n: i64) -> i64 {
//     let mut s: i64 = 0; while s < n { s = s + 1; } return s; }`
// whose FN_DEF body (5 instrs) is:
//   Param  %0 = n#1 idx 0
//   Const  %1 = 0                         (let mut s = 0)
//   While: cond_id=%2, cond=[Binop %2 = op_byte(%1,%0)]   (s < n)
//          body=[Const %3 = incr, Binop %4 = Add(%1,%3)]   (s = s + incr)
//          live_vars=[(s#2, %4)], init_ids=[%1], exit_ids=[%5]
//   Const  %6 = 0                         (while-stmt unit placeholder)
//   Return %5                             (return s -> the exit_id)
// The FN_DEF ret_id is %5 (the loop-carried exit id). The module-level scaffold
// (ConstI64 %0=0, Output %0) threads the FLAT next_id (= 1) — the body's vids
// %0..%6 live in the nested SSA namespace, not the flat module counter.
//
// Parametrised by `op_byte` (the comparison, 5 = Lt) and `incr` (the body
// increment constant). Verified incr=1 -> 73-byte oracle and incr=2 -> 71-byte
// oracle (the two differ ONLY in the single zigzag(incr) body-const byte), so
// this is a genuine narrow lowering, not a hardcoded blob.
// strtab[3] in first-seen order: count(#0), n(#1), s(#2). exports empty.
// ===========================================================================

// Instr::While { cond_id, cond_instrs=[Binop], body=[Const,Binop],
//   live_vars=[(s, %4)], init_ids=[%1], exit_ids=[%5] } — the loop node for the
// counter shape `while s < n { s = s + incr }`. cond %1<%0, body s+incr -> %4.
pub fn emit_mic3_while_counter(s: EmitState, op_byte: i64, incr: i64, s_name_idx: i64) -> EmitState {
    let s1: EmitState = es_push(s, 27);
    let s2: EmitState = emit_uleb128(s1, 2);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_mic3_binop(s3, 2, op_byte, 1, 0);
    let s5: EmitState = emit_uleb128(s4, 2);
    let s6: EmitState = emit_mic3_const_i64(s5, 3, incr);
    let s7: EmitState = emit_mic3_binop(s6, 4, 0, 1, 3);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, s_name_idx);
    let s10: EmitState = emit_uleb128(s9, 4);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_uleb128(s12, 1);
    emit_uleb128(s13, 5)
}

// Assemble the COMPLETE mic@3 module for the while-loop counter function,
// byte-exact vs the Rust --emit-mic3 oracle. Section order: header || strtab ||
// uleb(next_id=1) || exports(0) || uleb(instr_count=3) || FN_DEF count{...} ||
// ConstI64 %0=0 || Output %0 || empty registries.
pub fn emit_mic3_while_count_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, incr: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 3);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF count: name#0, params=[(n#1, %0)], ret_id=%5, body_len=5.
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_mic3_opt_vid(s10, 1, 5);
    let s12: EmitState = es_push(s11, 0);
    let s13: EmitState = emit_uleb128(s12, 5);
    let s14: EmitState = emit_mic3_param(s13, 0, 1, 0);
    let s15: EmitState = emit_mic3_const_i64(s14, 1, 0);
    let s16: EmitState = emit_mic3_while_counter(s15, op_byte, incr, 2);
    let s17: EmitState = emit_mic3_const_i64(s16, 6, 0);
    let s18: EmitState = emit_mic3_return(s17, 1, 5);
    // module-level scaffold: ConstI64 %0=0, Output %0 (flat next_id = 1).
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    emit_mic3_empty_registries(s20)
}

pub fn selftest_mic3_while_count(buf: i64, offs: i64, op_byte: i64, incr: i64) -> EmitState {
    emit_mic3_while_count_module(es_new(), buf, offs, op_byte, incr)
}

// ===========================================================================
// SECTION 11b — GENERAL WHILE-LOOP mic@3 EMISSION (descriptor/vid-driven)
//
// Generalises emit_mic3_while_counter to ARBITRARY cond trees, arbitrary body
// statement sequences (bare side-effect stores/calls + multiple loop-carried
// assigns + body-local lets), MULTIPLE loop-carried vars, byte-identical to the
// Rust `compact::v3::emit_mic3` OP_WHILE arm (src/ir/compact/v3/emit.rs:1080) with
// loop-carried merge semantics mirroring src/eval/lower.rs Node::While (4565-4818).
//
// Wire format (OP_WHILE = 27):
//   es_push(27) || uleb(cond_id) || uleb(cond_instrs.len) || cond_instrs...
//     || uleb(body.len) || body... || encode_named_vids(live_vars)
//     || encode_vid_vec(init_ids) || encode_vid_vec(exit_ids)
//
// The body walk threads a body lv-env clone; for each statement (lower.rs
// 4632-4779):
//   Let   -> new body-local SSA binding (flatten init, bind name). NOT loop-carried.
//   Assign NAME=RHS -> flatten RHS, rebind body-env[NAME]; on FIRST sight of a
//                      PRE-LOOP var record init_id<-pre-loop vid + live_var<-(NAME,
//                      post_vid); on later sight just update live_var post_vid.
//   bare call/expr   -> emit as a side-effect instr (no binding, no merge).
// exit_ids = one FRESH id per live_var, allocated AFTER cond+body (lower.rs 4801).
// After the loop the enclosing env REBINDS each live_var name -> exit_ids[k] so a
// post-loop read (incl. a value-if else-branch trailing value) resolves to the
// loop EXIT id, guaranteeing SSA dominance (lower.rs region_exit_rebindings).
// ===========================================================================

// ===========================================================================
// IF-ELSE STATEMENT (assign-branches) INSIDE A WHILE BODY — mic@3 OP_IF with
// loop-carried merges. Handles `if C { NAME = E; .. } else { NAME = E; .. }`
// where every branch statement is an `Assign` to a name already bound in the
// enclosing while-body env (a loop-carried outer let or an earlier body-local
// let). Mirrors lower.rs Node::If (3865-4311): a synthetic ConstI64(0) leads
// each branch; both branches fall through; the merge set = then-writes ++
// else-writes (deduped, first-occurrence order); a merged name's per-branch
// value is that branch's post-walk env binding (the incoming value when the
// branch does not write it — NO placeholder, since the name is pre-bound); merge
// ids + dst are allocated AFTER both branch id spaces. Byte-exact vs emit_mic3's
// OP_IF arm (0x1c). Fails closed on any non-assign / unknown-target statement.
// ===========================================================================

// Every stmt in a branch is an Assign whose target name is bound in `benv`?
pub fn while_if_branch_all_assigns(sa: i64, sl: i64, buf: i64, benv: i64, nlv: i64, i: i64) -> i64 {
    if i >= sl {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    if ast_kind(stmt) != ast_assign() {
        return 0;
    }
    let name: i64 = ast_child0(stmt);
    let slot: i64 = lvenv_index_of(buf, ast_span_lo(name), ast_span_hi(name), benv, nlv);
    if slot < 0 {
        return 0;
    }
    while_if_branch_all_assigns(sa, sl, buf, benv, nlv, i + 1)
}

// Find (lo,hi) in a 24-byte name buffer of length n; -1 if absent.
pub fn while_if_name_find(out: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    if span_bytes_equal2(buf, lo, hi, buf, __mind_load_i64(out + i * 24 + 0), __mind_load_i64(out + i * 24 + 8)) == 1 {
        return i;
    }
    while_if_name_find(out, n, buf, lo, hi, i + 1)
}

// Append each branch assign-target name (deduped) into the 24-byte `out` buffer;
// `ncell` holds the running count. Called for the then branch then the else branch
// so `out` ends up = then-writes ++ else-writes (first-occurrence order).
pub fn while_if_collect_names(sa: i64, sl: i64, buf: i64, out: i64, ncell: i64, i: i64) -> i64 {
    if i >= sl {
        return __mind_load_i64(ncell);
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    let name: i64 = ast_child0(stmt);
    let lo: i64 = ast_span_lo(name);
    let hi: i64 = ast_span_hi(name);
    let n: i64 = __mind_load_i64(ncell);
    if while_if_name_find(out, n, buf, lo, hi, 0) < 0 {
        __mind_store_i64(out + n * 24 + 0, lo);
        __mind_store_i64(out + n * 24 + 8, hi);
        __mind_store_i64(ncell, n + 1)
    }
    while_if_collect_names(sa, sl, buf, out, ncell, i + 1)
}

// PURE branch walk: flatten each assign RHS at the threaded base, rebind the
// branch env, record the last root into result_cell, advance base_cell. Returns
// the end base (one past the branch's last instr). -1 / okcell=0 on a wall.
pub fn while_if_layout_branch(sa: i64, sl: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, wnodes: i64, wcursor: i64, wvidbuf: i64, base_cell: i64, benv: i64, nlv: i64, result_cell: i64, okcell: i64) -> i64 {
    if idx >= sl {
        return __mind_load_i64(base_cell);
    }
    if __mind_load_i64(okcell) == 0 {
        return 0 - 1;
    }
    let stmt: i64 = __mind_load_i64(sa + idx * 8);
    let name: i64 = ast_child0(stmt);
    let rhs: i64 = ast_child2(stmt);
    let cur: i64 = __mind_load_i64(base_cell);
    let root: i64 = flatten_branch_lv(rhs, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur, benv, nlv);
    if root < 0 {
        __mind_store_i64(okcell, 0);
        return 0 - 1;
    }
    let nn: i64 = count_nonparam_nodes_lv(rhs, buf, params_addr, n_params, benv, nlv);
    if nn < 0 {
        __mind_store_i64(okcell, 0);
        return 0 - 1;
    }
    let slot: i64 = lvenv_index_of(buf, ast_span_lo(name), ast_span_hi(name), benv, nlv);
    if slot < 0 {
        __mind_store_i64(okcell, 0);
        return 0 - 1;
    }
    __mind_store_i64(benv + slot * 24 + 16, root);
    __mind_store_i64(result_cell, root);
    __mind_store_i64(base_cell, cur + nn);
    while_if_layout_branch(sa, sl, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, benv, nlv, result_cell, okcell)
}

// Fill per-merge 40-byte records M[k] = (lo, hi, merge_id, then_val, else_val).
pub fn while_if_fill_merges(m: i64, names: i64, n: i64, else_end: i64, buf: i64, tenv: i64, eenv: i64, nlv: i64, k: i64) -> i64 {
    if k >= n {
        return n;
    }
    let lo: i64 = __mind_load_i64(names + k * 24 + 0);
    let hi: i64 = __mind_load_i64(names + k * 24 + 8);
    __mind_store_i64(m + k * 40 + 0, lo);
    __mind_store_i64(m + k * 40 + 8, hi);
    __mind_store_i64(m + k * 40 + 16, else_end + k);
    __mind_store_i64(m + k * 40 + 24, lvenv_lookup(buf, lo, hi, tenv, nlv, 0));
    __mind_store_i64(m + k * 40 + 32, lvenv_lookup(buf, lo, hi, eenv, nlv, 0));
    while_if_fill_merges(m, names, n, else_end, buf, tenv, eenv, nlv, k + 1)
}

// PURE layout of the if-else assign-merge shape. Fills L[0..9] scalar cells and the
// 40-byte merge buffer M. Returns 1 on success, 0 (fail-closed) on any unsupported shape.
//   L+0 cond_id  L+8 cond_n  L+16 then_synth(=after_cond)  L+24 then_end  L+32 then_result
//   L+40 else_synth  L+48 else_end  L+56 else_result  L+64 n_merged  L+72 dst
pub fn while_if_layout(if_node: i64, buf: i64, params_addr: i64, n_params: i64, base0: i64, wenv: i64, wnlv: i64, l: i64, m: i64) -> i64 {
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return 0;
    }
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    if then_sl < 1 {
        return 0;
    }
    if else_sl < 1 {
        return 0;
    }
    if while_if_branch_all_assigns(then_sa, then_sl, buf, wenv, wnlv, 0) != 1 {
        return 0;
    }
    if while_if_branch_all_assigns(else_sa, else_sl, buf, wenv, wnlv, 0) != 1 {
        return 0;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let cnodes: i64 = __mind_alloc(256 * 32);
    let ccursor: i64 = __mind_alloc(8);
    let cvidbuf: i64 = __mind_alloc(256 * 8);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, cnodes, ccursor, cvidbuf, base0, wenv, wnlv);
    if cond_id < 0 {
        return 0;
    }
    let cond_n: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, wenv, wnlv);
    if cond_n < 0 {
        return 0;
    }
    let after_cond: i64 = base0 + cond_n;
    let bnodes: i64 = __mind_alloc(256 * 32);
    let bcursor: i64 = __mind_alloc(8);
    let bvidbuf: i64 = __mind_alloc(256 * 8);
    // THEN branch.
    let tenv: i64 = __mind_alloc((wnlv + 1) * 24);
    let _tc: i64 = lvenv_copy(tenv, wenv, wnlv, 0);
    let tbase: i64 = __mind_alloc(8);
    __mind_store_i64(tbase, after_cond + 1);
    let tresult: i64 = __mind_alloc(8);
    __mind_store_i64(tresult, after_cond);
    let tok: i64 = __mind_alloc(8);
    __mind_store_i64(tok, 1);
    let then_end: i64 = while_if_layout_branch(then_sa, then_sl, 0, buf, params_addr, n_params, bnodes, bcursor, bvidbuf, tbase, tenv, wnlv, tresult, tok);
    if __mind_load_i64(tok) == 0 {
        return 0;
    }
    // ELSE branch.
    let else_synth: i64 = then_end;
    let eenv: i64 = __mind_alloc((wnlv + 1) * 24);
    let _ec: i64 = lvenv_copy(eenv, wenv, wnlv, 0);
    let ebase: i64 = __mind_alloc(8);
    __mind_store_i64(ebase, else_synth + 1);
    let eresult: i64 = __mind_alloc(8);
    __mind_store_i64(eresult, else_synth);
    let eok: i64 = __mind_alloc(8);
    __mind_store_i64(eok, 1);
    let else_end: i64 = while_if_layout_branch(else_sa, else_sl, 0, buf, params_addr, n_params, bnodes, bcursor, bvidbuf, ebase, eenv, wnlv, eresult, eok);
    if __mind_load_i64(eok) == 0 {
        return 0;
    }
    // Merge set = then-writes ++ else-writes (deduped).
    let names: i64 = __mind_alloc((then_sl + else_sl + 1) * 24);
    let ncell: i64 = __mind_alloc(8);
    __mind_store_i64(ncell, 0);
    let _cn1: i64 = while_if_collect_names(then_sa, then_sl, buf, names, ncell, 0);
    let _cn2: i64 = while_if_collect_names(else_sa, else_sl, buf, names, ncell, 0);
    let n_merged: i64 = __mind_load_i64(ncell);
    let _fm: i64 = while_if_fill_merges(m, names, n_merged, else_end, buf, tenv, eenv, wnlv, 0);
    let dst: i64 = else_end + n_merged;
    __mind_store_i64(l + 0, cond_id);
    __mind_store_i64(l + 8, cond_n);
    __mind_store_i64(l + 16, after_cond);
    __mind_store_i64(l + 24, then_end);
    __mind_store_i64(l + 32, __mind_load_i64(tresult));
    __mind_store_i64(l + 40, else_synth);
    __mind_store_i64(l + 48, else_end);
    __mind_store_i64(l + 56, __mind_load_i64(eresult));
    __mind_store_i64(l + 64, n_merged);
    __mind_store_i64(l + 72, dst);
    1
}

// EMIT branch: re-flatten each assign RHS at the threaded base and emit its instr
// tree; rebind the branch env; advance base. Mirrors while_if_layout_branch's walk.
pub fn while_if_emit_branch(s: EmitState, sa: i64, sl: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, wnodes: i64, wcursor: i64, wvidbuf: i64, base_cell: i64, benv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, okcell: i64) -> EmitState {
    if idx >= sl {
        return s;
    }
    if __mind_load_i64(okcell) == 0 {
        return s;
    }
    let stmt: i64 = __mind_load_i64(sa + idx * 8);
    let name: i64 = ast_child0(stmt);
    let rhs: i64 = ast_child2(stmt);
    let cur: i64 = __mind_load_i64(base_cell);
    let root: i64 = flatten_branch_lv(rhs, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur, benv, nlv);
    if root < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let nn: i64 = count_nonparam_nodes_lv(rhs, buf, params_addr, n_params, benv, nlv);
    let nodes_n: i64 = __mind_load_i64(wcursor);
    let s1: EmitState = emit_mic3_tree_body(s, wnodes, nodes_n, wvidbuf, buf, strbuf, offs, ncount, 0);
    let slot: i64 = lvenv_index_of(buf, ast_span_lo(name), ast_span_hi(name), benv, nlv);
    __mind_store_i64(benv + slot * 24 + 16, root);
    __mind_store_i64(base_cell, cur + nn);
    while_if_emit_branch(s1, sa, sl, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, benv, nlv, strbuf, offs, ncount, okcell)
}

// Emit the merge `branch_bindings` (name_idx, merge_id) pairs from M.
pub fn while_if_emit_bindings(s: EmitState, m: i64, n: i64, strbuf: i64, offs: i64, ncount: i64, buf: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let nidx: i64 = intern_find(strbuf, offs, ncount, buf, __mind_load_i64(m + i * 40 + 0), __mind_load_i64(m + i * 40 + 8), 0);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(m + i * 40 + 16));
    while_if_emit_bindings(s2, m, n, strbuf, offs, ncount, buf, i + 1)
}

// Emit the merge triples (merge_id, then_val, else_val) from M.
pub fn while_if_emit_merges(s: EmitState, m: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(m + i * 40 + 16));
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(m + i * 40 + 24));
    let s3: EmitState = emit_uleb128(s2, __mind_load_i64(m + i * 40 + 32));
    while_if_emit_merges(s3, m, n, i + 1)
}

// Copy (lo, hi, merge_id) from M into a 24-byte overlay buffer for the caller.
pub fn while_if_merge_out(dst: i64, m: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(dst + i * 24 + 0, __mind_load_i64(m + i * 40 + 0));
    __mind_store_i64(dst + i * 24 + 8, __mind_load_i64(m + i * 40 + 8));
    __mind_store_i64(dst + i * 24 + 16, __mind_load_i64(m + i * 40 + 16));
    while_if_merge_out(dst, m, n, i + 1)
}

// Emit ONE OP_IF for the assign-branch if-else at `base0`. Fills merge_out (24-byte
// name/merge_id overlay) + nmerge_cell + endbase_cell (= dst+1). okcell=0 on a wall.
pub fn emit_while_if_assign(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, base0: i64, wenv: i64, wnlv: i64, strbuf: i64, offs: i64, ncount: i64, merge_out: i64, nmerge_cell: i64, endbase_cell: i64, okcell: i64) -> EmitState {
    let l: i64 = __mind_alloc(16 * 8);
    let m: i64 = __mind_alloc(256 * 40);
    if while_if_layout(if_node, buf, params_addr, n_params, base0, wenv, wnlv, l, m) == 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let cond_id: i64 = __mind_load_i64(l + 0);
    let cond_n: i64 = __mind_load_i64(l + 8);
    let then_synth: i64 = __mind_load_i64(l + 16);
    let then_end: i64 = __mind_load_i64(l + 24);
    let then_result: i64 = __mind_load_i64(l + 32);
    let else_synth: i64 = __mind_load_i64(l + 40);
    let else_end: i64 = __mind_load_i64(l + 48);
    let else_result: i64 = __mind_load_i64(l + 56);
    let n_merged: i64 = __mind_load_i64(l + 64);
    let dst: i64 = __mind_load_i64(l + 72);
    let then_len: i64 = 1 + (then_end - (then_synth + 1));
    let else_len: i64 = 1 + (else_end - (else_synth + 1));
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    // OP_IF header + cond.
    let cnodes: i64 = __mind_alloc(256 * 32);
    let ccursor: i64 = __mind_alloc(8);
    let cvidbuf: i64 = __mind_alloc(256 * 8);
    let _cid: i64 = flatten_branch_lv(ast_child0(if_node), buf, params_addr, n_params, cnodes, ccursor, cvidbuf, base0, wenv, wnlv);
    let cond_emit_n: i64 = __mind_load_i64(ccursor);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_n);
    let s4: EmitState = emit_mic3_tree_body(s3, cnodes, cond_emit_n, cvidbuf, buf, strbuf, offs, ncount, 0);
    // THEN block.
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let tenv2: i64 = __mind_alloc((wnlv + 1) * 24);
    let _tc2: i64 = lvenv_copy(tenv2, wenv, wnlv, 0);
    let bnodes: i64 = __mind_alloc(256 * 32);
    let bcursor: i64 = __mind_alloc(8);
    let bvidbuf: i64 = __mind_alloc(256 * 8);
    let tbase: i64 = __mind_alloc(8);
    __mind_store_i64(tbase, then_synth + 1);
    let tok: i64 = __mind_alloc(8);
    __mind_store_i64(tok, 1);
    let s7: EmitState = while_if_emit_branch(s6, then_sa, then_sl, 0, buf, params_addr, n_params, bnodes, bcursor, bvidbuf, tbase, tenv2, wnlv, strbuf, offs, ncount, tok);
    if __mind_load_i64(tok) == 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let s8: EmitState = emit_uleb128(s7, then_result);
    // ELSE block.
    let s9: EmitState = emit_uleb128(s8, else_len);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let eenv2: i64 = __mind_alloc((wnlv + 1) * 24);
    let _ec2: i64 = lvenv_copy(eenv2, wenv, wnlv, 0);
    let ebnodes: i64 = __mind_alloc(256 * 32);
    let ebcursor: i64 = __mind_alloc(8);
    let ebvidbuf: i64 = __mind_alloc(256 * 8);
    let ebase: i64 = __mind_alloc(8);
    __mind_store_i64(ebase, else_synth + 1);
    let eok: i64 = __mind_alloc(8);
    __mind_store_i64(eok, 1);
    let s11: EmitState = while_if_emit_branch(s10, else_sa, else_sl, 0, buf, params_addr, n_params, ebnodes, ebcursor, ebvidbuf, ebase, eenv2, wnlv, strbuf, offs, ncount, eok);
    if __mind_load_i64(eok) == 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let s12: EmitState = emit_uleb128(s11, else_result);
    let s13: EmitState = emit_uleb128(s12, dst);
    // branch_bindings + merges.
    let s14: EmitState = emit_uleb128(s13, n_merged);
    let s15: EmitState = while_if_emit_bindings(s14, m, n_merged, strbuf, offs, ncount, buf, 0);
    let s16: EmitState = emit_uleb128(s15, n_merged);
    let s17: EmitState = while_if_emit_merges(s16, m, n_merged, 0);
    if merge_out != 0 {
        let _mo: i64 = while_if_merge_out(merge_out, m, n_merged, 0);
        __mind_store_i64(nmerge_cell, n_merged)
    }
    __mind_store_i64(endbase_cell, dst + 1);
    __mind_store_i64(okcell, 1);
    s17
}

// MEASURE-side: record each merged name as loop-carried (if a pre-loop var) then
// rebind wenv[name] -> merge_id, so later statements + the while live_vars see it.
pub fn while_if_record_merges(m: i64, n: i64, pre_nlv: i64, lv: i64, init: i64, nlv_w_cell: i64, wenv: i64, wnlv: i64, buf: i64, k: i64) -> i64 {
    if k >= n {
        return n;
    }
    let lo: i64 = __mind_load_i64(m + k * 24 + 0);
    let hi: i64 = __mind_load_i64(m + k * 24 + 8);
    let mid: i64 = __mind_load_i64(m + k * 24 + 16);
    let slot: i64 = lvenv_index_of(buf, lo, hi, wenv, wnlv);
    if slot >= 0 {
        let pre_vid: i64 = __mind_load_i64(wenv + slot * 24 + 16);
        let _rc: i64 = while_record_carry(slot, pre_nlv, lv, init, nlv_w_cell, buf, lo, hi, mid, pre_vid);
        __mind_store_i64(wenv + slot * 24 + 16, mid)
    }
    while_if_record_merges(m, n, pre_nlv, lv, init, nlv_w_cell, wenv, wnlv, buf, k + 1)
}

// EMIT-side: rebind wenv[name] -> merge_id for each merged name.
pub fn while_if_rebind(m: i64, n: i64, wenv: i64, wnlv: i64, buf: i64, k: i64) -> i64 {
    if k >= n {
        return n;
    }
    let lo: i64 = __mind_load_i64(m + k * 24 + 0);
    let hi: i64 = __mind_load_i64(m + k * 24 + 8);
    let mid: i64 = __mind_load_i64(m + k * 24 + 16);
    let slot: i64 = lvenv_index_of(buf, lo, hi, wenv, wnlv);
    if slot >= 0 {
        __mind_store_i64(wenv + slot * 24 + 16, mid)
    }
    while_if_rebind(m, n, wenv, wnlv, buf, k + 1)
}

// Walk one while-body statement, threading the body lv-env + base + (in emit mode)
// the EmitState. `mode`: 0 = MEASURE (no bytes; learn live_vars/body_len/post-vids),
// 1 = EMIT. Records loop-carried vars into the 24-byte `lv` buffer (name_lo, name_hi,
// post_vid) keyed by FIRST sight; `init` (parallel) holds each carried var's pre-loop
// vid. `nlv_w_cell` = count of live_vars. `body_len_cell` accumulates emitted body
// instrs. `pre_nlv` = the number of OUTER (pre-loop) lv-env entries — a var bound at
// index < pre_nlv in `wenv` is a loop-carried candidate; a body-local let appends at
// index >= pre_nlv and is NOT carried. Fails closed via okcell on any unsupported stmt.
// MEASURE pass (pure i64, no EmitState): walk the while body, threading the body
// lv-env + base, learning the loop-carried live_vars (lv/init), body_len, and the
// final base. Self-flip-clean: straight i64 recursion, no value-if-EmitState lets.
// `mode`-free — emission is a separate function (while_body_emit). Returns 0/1 ok via
// okcell. For each statement (lower.rs 4632-4779):
//   Assign NAME=RHS -> flatten RHS, rebind body-env[NAME]; first sight of a PRE-LOOP var
//                      records init_id + live_var; later just updates post.
//   Let            -> body-local SSA binding (NOT carried).
//   bare call/expr -> side-effect instr (no binding).
//   if-else assign-branches -> ONE nested OP_IF with loop-carried merges.
pub fn while_body_measure(stmts_addr: i64, n: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, wnodes: i64, wcursor: i64, wvidbuf: i64, base_cell: i64, wenv: i64, wnlv_cell: i64, pre_nlv: i64, lv: i64, init: i64, nlv_w_cell: i64, body_len_cell: i64, okcell: i64) -> i64 {
    if idx >= n {
        return 1;
    }
    if __mind_load_i64(okcell) == 0 {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    let wnlv: i64 = __mind_load_i64(wnlv_cell);
    let cur_base: i64 = __mind_load_i64(base_cell);
    // if-else STATEMENT (assign-branches) -> ONE nested OP_IF with loop-carried merges.
    // Pure layout (no bytes): learn the merge set + dst, record carried vars, rebind wenv,
    // advance base to dst+1, count the OP_IF as ONE body instr.
    if ast_kind(stmt) == ast_if() {
        let if_l: i64 = __mind_alloc(16 * 8);
        let if_m: i64 = __mind_alloc(256 * 40);
        if while_if_layout(stmt, buf, params_addr, n_params, cur_base, wenv, wnlv, if_l, if_m) == 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        let if_nm: i64 = __mind_load_i64(if_l + 64);
        let if_dst: i64 = __mind_load_i64(if_l + 72);
        // Copy (lo,hi,merge_id) from the 40-byte layout records to 24-byte overlay records.
        let if_ov: i64 = __mind_alloc((if_nm + 1) * 24);
        let _ov: i64 = while_if_merge_out(if_ov, if_m, if_nm, 0);
        let _rm: i64 = while_if_record_merges(if_ov, if_nm, pre_nlv, lv, init, nlv_w_cell, wenv, wnlv, buf, 0);
        __mind_store_i64(base_cell, if_dst + 1);
        __mind_store_i64(body_len_cell, __mind_load_i64(body_len_cell) + 1);
        return while_body_measure(stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, pre_nlv, lv, init, nlv_w_cell, body_len_cell, okcell);
    }
    if ast_kind(stmt) == ast_assign() {
        let name: i64 = ast_child0(stmt);
        let rhs: i64 = ast_child2(stmt);
        // pre_vid = NAME's binding BEFORE this assign (loop-carried init OR prior post).
        let pre_vid: i64 = lvenv_lookup(buf, ast_span_lo(name), ast_span_hi(name), wenv, wnlv, 0);
        if pre_vid < 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        let root: i64 = flatten_branch_lv(rhs, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
        if root < 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        let nn: i64 = count_nonparam_nodes_lv(rhs, buf, params_addr, n_params, wenv, wnlv);
        if nn < 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        // Rebind NAME -> root in the body env (the assign target is always already bound —
        // outer carried var or earlier body-local let).
        let slot_i: i64 = lvenv_index_of(buf, ast_span_lo(name), ast_span_hi(name), wenv, wnlv);
        __mind_store_i64(wenv + slot_i * 24 + 16, root);
        // A PRE-LOOP var (index < pre_nlv) becomes loop-carried. Record on FIRST sight.
        let _rec: i64 = while_record_carry(slot_i, pre_nlv, lv, init, nlv_w_cell, buf, ast_span_lo(name), ast_span_hi(name), root, pre_vid);
        __mind_store_i64(base_cell, cur_base + nn);
        __mind_store_i64(body_len_cell, __mind_load_i64(body_len_cell) + nn);
        return while_body_measure(stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, pre_nlv, lv, init, nlv_w_cell, body_len_cell, okcell);
    }
    if ast_kind(stmt) == ast_let() {
        let name: i64 = ast_child0(stmt);
        let linit: i64 = ast_child2(stmt);
        let root: i64 = flatten_branch_lv(linit, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
        if root < 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        let nn: i64 = count_nonparam_nodes_lv(linit, buf, params_addr, n_params, wenv, wnlv);
        if nn < 0 {
            __mind_store_i64(okcell, 0);
            return 0;
        }
        // Body-local let: append a NEW lv-env binding (NOT loop-carried).
        __mind_store_i64(wenv + wnlv * 24 + 0, ast_span_lo(name));
        __mind_store_i64(wenv + wnlv * 24 + 8, ast_span_hi(name));
        __mind_store_i64(wenv + wnlv * 24 + 16, root);
        __mind_store_i64(wnlv_cell, wnlv + 1);
        __mind_store_i64(base_cell, cur_base + nn);
        __mind_store_i64(body_len_cell, __mind_load_i64(body_len_cell) + nn);
        return while_body_measure(stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, pre_nlv, lv, init, nlv_w_cell, body_len_cell, okcell);
    }
    // BARE side-effect statement (call/store): flatten, advance base, bind NO name.
    let be_root: i64 = flatten_branch_lv(stmt, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
    if be_root < 0 {
        __mind_store_i64(okcell, 0);
        return 0;
    }
    let be_nn: i64 = count_nonparam_nodes_lv(stmt, buf, params_addr, n_params, wenv, wnlv);
    if be_nn < 0 {
        __mind_store_i64(okcell, 0);
        return 0;
    }
    __mind_store_i64(base_cell, cur_base + be_nn);
    __mind_store_i64(body_len_cell, __mind_load_i64(body_len_cell) + be_nn);
    while_body_measure(stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, pre_nlv, lv, init, nlv_w_cell, body_len_cell, okcell)
}

// Record an assign target as loop-carried IF it is a pre-loop var (slot < pre_nlv).
// First sight -> append (name, post=root) + init_id=pre_vid; later -> update post.
pub fn while_record_carry(slot_i: i64, pre_nlv: i64, lv: i64, init: i64, nlv_w_cell: i64, buf: i64, lo: i64, hi: i64, root: i64, pre_vid: i64) -> i64 {
    if slot_i >= pre_nlv {
        return 0;
    }
    let lvpos: i64 = lv_find(lv, __mind_load_i64(nlv_w_cell), buf, lo, hi);
    if lvpos >= 0 {
        __mind_store_i64(lv + lvpos * 24 + 16, root);
        return 0;
    }
    let at: i64 = __mind_load_i64(nlv_w_cell);
    __mind_store_i64(lv + at * 24 + 0, lo);
    __mind_store_i64(lv + at * 24 + 8, hi);
    __mind_store_i64(lv + at * 24 + 16, root);
    __mind_store_i64(init + at * 8, pre_vid);
    __mind_store_i64(nlv_w_cell, at + 1);
    1
}

// EMIT pass: walk the while body, emitting each statement's instr tree. Threads the
// body lv-env + base identically to the measure pass (deterministic), so the emitted
// vids match the measured layout. Straight EmitState recursion — self-flip-clean (no
// value-if-EmitState, no leading-let branch). Sets okcell=0 on a wall.
pub fn while_body_emit(s: EmitState, stmts_addr: i64, n: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, wnodes: i64, wcursor: i64, wvidbuf: i64, base_cell: i64, wenv: i64, wnlv_cell: i64, strbuf: i64, offs: i64, ncount: i64, okcell: i64) -> EmitState {
    if idx >= n {
        return s;
    }
    if __mind_load_i64(okcell) == 0 {
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    let wnlv: i64 = __mind_load_i64(wnlv_cell);
    let cur_base: i64 = __mind_load_i64(base_cell);
    // if-else STATEMENT (assign-branches) -> ONE nested OP_IF with loop-carried merges.
    if ast_kind(stmt) == ast_if() {
        let if_ov: i64 = __mind_alloc(256 * 24);
        let if_nm: i64 = __mind_alloc(8);
        let if_end: i64 = __mind_alloc(8);
        let if_ok: i64 = __mind_alloc(8);
        __mind_store_i64(if_ok, 1);
        let sif: EmitState = emit_while_if_assign(s, stmt, buf, params_addr, n_params, cur_base, wenv, wnlv, strbuf, offs, ncount, if_ov, if_nm, if_end, if_ok);
        if __mind_load_i64(if_ok) == 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        let _rb: i64 = while_if_rebind(if_ov, __mind_load_i64(if_nm), wenv, wnlv, buf, 0);
        __mind_store_i64(base_cell, __mind_load_i64(if_end));
        return while_body_emit(sif, stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, strbuf, offs, ncount, okcell);
    }
    if ast_kind(stmt) == ast_assign() {
        let name: i64 = ast_child0(stmt);
        let rhs: i64 = ast_child2(stmt);
        let root: i64 = flatten_branch_lv(rhs, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
        if root < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        let nn: i64 = count_nonparam_nodes_lv(rhs, buf, params_addr, n_params, wenv, wnlv);
        let nodes_n: i64 = __mind_load_i64(wcursor);
        let s1: EmitState = emit_mic3_tree_body(s, wnodes, nodes_n, wvidbuf, buf, strbuf, offs, ncount, 0);
        let slot_i: i64 = lvenv_index_of(buf, ast_span_lo(name), ast_span_hi(name), wenv, wnlv);
        __mind_store_i64(wenv + slot_i * 24 + 16, root);
        __mind_store_i64(base_cell, cur_base + nn);
        return while_body_emit(s1, stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, strbuf, offs, ncount, okcell);
    }
    if ast_kind(stmt) == ast_let() {
        let name: i64 = ast_child0(stmt);
        let linit: i64 = ast_child2(stmt);
        let root: i64 = flatten_branch_lv(linit, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
        if root < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        let nn: i64 = count_nonparam_nodes_lv(linit, buf, params_addr, n_params, wenv, wnlv);
        let nodes_n: i64 = __mind_load_i64(wcursor);
        let s1: EmitState = emit_mic3_tree_body(s, wnodes, nodes_n, wvidbuf, buf, strbuf, offs, ncount, 0);
        __mind_store_i64(wenv + wnlv * 24 + 0, ast_span_lo(name));
        __mind_store_i64(wenv + wnlv * 24 + 8, ast_span_hi(name));
        __mind_store_i64(wenv + wnlv * 24 + 16, root);
        __mind_store_i64(wnlv_cell, wnlv + 1);
        __mind_store_i64(base_cell, cur_base + nn);
        return while_body_emit(s1, stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, strbuf, offs, ncount, okcell);
    }
    let be_root: i64 = flatten_branch_lv(stmt, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, cur_base, wenv, wnlv);
    if be_root < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let be_nn: i64 = count_nonparam_nodes_lv(stmt, buf, params_addr, n_params, wenv, wnlv);
    let be_nodes_n: i64 = __mind_load_i64(wcursor);
    let be_s: EmitState = emit_mic3_tree_body(s, wnodes, be_nodes_n, wvidbuf, buf, strbuf, offs, ncount, 0);
    __mind_store_i64(base_cell, cur_base + be_nn);
    while_body_emit(be_s, stmts_addr, n, idx + 1, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, base_cell, wenv, wnlv_cell, strbuf, offs, ncount, okcell)
}

// Find the index of NAME (lo,hi span) in a 24-byte lv-env, INNERMOST (highest) first
// so a body-local shadow rebinds itself, not an outer carried var. -1 if absent.
pub fn lvenv_index_of(src: i64, lo: i64, hi: i64, lvenv: i64, nlv: i64) -> i64 {
    lvenv_index_of_loop(src, lo, hi, lvenv, nlv, nlv - 1)
}
pub fn lvenv_index_of_loop(src: i64, lo: i64, hi: i64, lvenv: i64, nlv: i64, i: i64) -> i64 {
    if i < 0 {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(lvenv + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(lvenv + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return i;
    }
    lvenv_index_of_loop(src, lo, hi, lvenv, nlv, i - 1)
}

// Find NAME (lo,hi) in the live_var accumulator `lv` (24-byte records); -1 if absent.
pub fn lv_find(lv: i64, nlv_w: i64, src: i64, lo: i64, hi: i64) -> i64 {
    lv_find_loop(lv, nlv_w, src, lo, hi, 0)
}
pub fn lv_find_loop(lv: i64, nlv_w: i64, src: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= nlv_w {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(lv + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(lv + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return i;
    }
    lv_find_loop(lv, nlv_w, src, lo, hi, i + 1)
}

// Emit encode_named_vids(live_vars): uleb(count) || (string_idx(name), uleb(post_vid))*.
pub fn emit_while_live_vars(s: EmitState, lv: i64, nlv_w: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= nlv_w {
        return s;
    }
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, __mind_load_i64(lv + i * 24 + 0), __mind_load_i64(lv + i * 24 + 8), 0);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(lv + i * 24 + 16));
    emit_while_live_vars(s2, lv, nlv_w, strbuf, offs, ncount, src, i + 1)
}

// Emit encode_vid_vec from a packed i64 array `vec` of length `n`: uleb(n) || uleb(v)*.
pub fn emit_while_vid_vec(s: EmitState, vec: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(vec + i * 8));
    emit_while_vid_vec(s1, vec, n, i + 1)
}

// GENERAL OP_WHILE emitter. Emits one while-loop node byte-identical to the oracle,
// starting vids at `base0` (the cond root resolves first). Threads the loop-carried
// merge: writes the merge bindings (name_lo, name_hi, exit_id) into `merge_out` (24-
// byte records), their count into `nmerge_cell`, and the FINAL base (one past the
// trailing-unit const) into `endbase_cell`. The enclosing emitter binds each merged
// name -> exit_id in its env so post-loop reads hit the dominating exit id. The body
// env starts as a clone of `lvenv[0..nlv]`; loop-carried vars are those rebound at an
// index < nlv. Fails closed via okcell (set to 0) on any wall. okcell unchanged on ok.
pub fn emit_mic3_while_general(s: EmitState, while_node: i64, buf: i64, params_addr: i64, n_params: i64, base0: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, merge_out: i64, nmerge_cell: i64, endbase_cell: i64, okcell: i64) -> EmitState {
    let cond_expr: i64 = ast_child0(while_node);
    let body_blk: i64 = ast_child1(while_node);
    let body_sa: i64 = ast_child0(body_blk);
    let body_sl: i64 = ast_aux(body_blk);
    // --- cond: flatten + resolve from base0; cond_id = cond root vid. ---
    let cnodes: i64 = __mind_alloc(256 * 32);
    let ccursor: i64 = __mind_alloc(8);
    let cvidbuf: i64 = __mind_alloc(256 * 8);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, cnodes, ccursor, cvidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let cond_n: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    if cond_n < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let after_cond: i64 = base0 + cond_n;
    // --- MEASURE pass: learn body_len, live_vars, post-vids (no bytes). The body env is
    // a fresh clone; loop-carried vars rebound at index < nlv. wnodes/wvidbuf scratch. ---
    let wenv: i64 = __mind_alloc((nlv + body_sl + 64) * 24);
    let _cp: i64 = lvenv_copy(wenv, lvenv, nlv, 0);
    let wnodes: i64 = __mind_alloc(1024 * 32);
    let wcursor: i64 = __mind_alloc(8);
    let wvidbuf: i64 = __mind_alloc(1024 * 8);
    let m_wnlv: i64 = __mind_alloc(8);
    __mind_store_i64(m_wnlv, nlv);
    let m_base: i64 = __mind_alloc(8);
    __mind_store_i64(m_base, after_cond);
    let lv: i64 = __mind_alloc((body_sl + 8) * 24);
    let init: i64 = __mind_alloc((body_sl + 8) * 8);
    let nlv_w: i64 = __mind_alloc(8);
    __mind_store_i64(nlv_w, 0);
    let body_len: i64 = __mind_alloc(8);
    __mind_store_i64(body_len, 0);
    let m_ok: i64 = __mind_alloc(8);
    __mind_store_i64(m_ok, 1);
    let _m: i64 = while_body_measure(body_sa, body_sl, 0, buf, params_addr, n_params, wnodes, wcursor, wvidbuf, m_base, wenv, m_wnlv, nlv, lv, init, nlv_w, body_len, m_ok);
    if __mind_load_i64(m_ok) == 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let nmerge: i64 = __mind_load_i64(nlv_w);
    let blen: i64 = __mind_load_i64(body_len);
    let body_end: i64 = __mind_load_i64(m_base);
    // exit_ids: one fresh id per live_var, allocated AFTER cond+body (lower.rs 4801).
    let exit_ids: i64 = __mind_alloc((nmerge + 1) * 8);
    let _ei: i64 = while_alloc_exit_ids(exit_ids, nmerge, body_end, 0);
    // --- EMIT pass: OP_WHILE header + cond + body (re-walk a FRESH body env) + tails. ---
    let s1: EmitState = es_push(s, 27);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_n);
    let cond_emit_n: i64 = __mind_load_i64(ccursor);
    let s4: EmitState = emit_mic3_tree_body(s3, cnodes, cond_emit_n, cvidbuf, buf, strbuf, offs, ncount, 0);
    let s5: EmitState = emit_uleb128(s4, blen);
    // Re-clone the env + reset scratch for the byte-emitting walk.
    let wenv2: i64 = __mind_alloc((nlv + body_sl + 64) * 24);
    let _cp2: i64 = lvenv_copy(wenv2, lvenv, nlv, 0);
    let wnodes2: i64 = __mind_alloc(1024 * 32);
    let wcursor2: i64 = __mind_alloc(8);
    let wvidbuf2: i64 = __mind_alloc(1024 * 8);
    let e_wnlv: i64 = __mind_alloc(8);
    __mind_store_i64(e_wnlv, nlv);
    let e_base: i64 = __mind_alloc(8);
    __mind_store_i64(e_base, after_cond);
    let e_ok: i64 = __mind_alloc(8);
    __mind_store_i64(e_ok, 1);
    let s6: EmitState = while_body_emit(s5, body_sa, body_sl, 0, buf, params_addr, n_params, wnodes2, wcursor2, wvidbuf2, e_base, wenv2, e_wnlv, strbuf, offs, ncount, e_ok);
    if __mind_load_i64(e_ok) == 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    // live_vars || init_ids || exit_ids.
    let s7: EmitState = emit_uleb128(s6, nmerge);
    let s8: EmitState = emit_while_live_vars(s7, lv, nmerge, strbuf, offs, ncount, buf, 0);
    let s9: EmitState = emit_uleb128(s8, nmerge);
    let s10: EmitState = emit_while_vid_vec(s9, init, nmerge, 0);
    let s11: EmitState = emit_uleb128(s10, nmerge);
    let s12: EmitState = emit_while_vid_vec(s11, exit_ids, nmerge, 0);
    // Record the merge overlay (name -> exit_id) for the enclosing scope.
    if merge_out != 0 {
        let _mo: i64 = while_fill_merge_out(merge_out, lv, exit_ids, nmerge, 0);
        __mind_store_i64(nmerge_cell, nmerge)
    }
    // A statement-level while pushes a trailing unit ConstI64 AFTER the While node
    // (lower.rs 4815). It occupies vid body_end + nmerge (one past the exit_ids). The
    // CALLER emits that const (it varies: a top-level seq const vs a branch's synth).
    // endbase = first vid AFTER the exit_ids (the trailing-unit vid).
    __mind_store_i64(endbase_cell, body_end + nmerge);
    s12
}

// Allocate exit_ids[k] = body_end + k (one fresh dominating id per live_var).
pub fn while_alloc_exit_ids(exit_ids: i64, nmerge: i64, body_end: i64, i: i64) -> i64 {
    if i >= nmerge {
        return nmerge;
    }
    __mind_store_i64(exit_ids + i * 8, body_end + i);
    while_alloc_exit_ids(exit_ids, nmerge, body_end, i + 1)
}

// Copy (name_lo, name_hi, exit_id) into the 24-byte merge_out overlay for each carried var.
pub fn while_fill_merge_out(merge_out: i64, lv: i64, exit_ids: i64, nmerge: i64, i: i64) -> i64 {
    if i >= nmerge {
        return nmerge;
    }
    __mind_store_i64(merge_out + i * 24 + 0, __mind_load_i64(lv + i * 24 + 0));
    __mind_store_i64(merge_out + i * 24 + 8, __mind_load_i64(lv + i * 24 + 8));
    __mind_store_i64(merge_out + i * 24 + 16, __mind_load_i64(exit_ids + i * 8));
    while_fill_merge_out(merge_out, lv, exit_ids, nmerge, i + 1)
}

// ===========================================================================
// SECTION 12 — MATCH STRUCTURE (the match frontier, part 1)
//
// ADDITIVE / canary-isolated. PARSER + STRUCTURE-READING only — NO mic@3
// byte-output, NO EmitState, NO touch of the canary mindc_compile path. It
// cannot perturb the fixed point and cannot hit the EmitState segfault.
//
// The Rust front-end lowers `match` as a PURE AST-level desugar to a nested
// if/else chain (src/eval/lower.rs desugar_match_to_if): each test arm becomes
// a `<scrutinee> == <pat>` comparison feeding the keystone-protected If
// lowering, and a `_` / bare-ident arm becomes the terminal else. There is NO
// dedicated match/switch opcode — `match k { 0 => 10, 1 => 20, _ => 99 }` and
// the hand-written `if k == 0 { 10 } else if k == 1 { 20 } else { 99 }` emit
// byte-IDENTICAL mic@3 (both end in OP_IF 0x1c chains). So match byte-output,
// when it lands (part 2), reuses the OP_IF machinery — no new opcode.
//
// The bootstrap dispatch (parse_stmt / parse_primary) does NOT recognise the
// `match` keyword — main.mind's own source uses NO surface `match` (it
// dispatches AST node kinds with `if kind == X` chains) — so a `match`
// spelling lexes as a bare tk_ident. These selftests therefore locate the
// match by scanning the token stream for an ident-token spelling "match",
// parse the scrutinee with the existing parse_expr (which stops at `{`), then
// read the arm structure directly off the token stream. They never add `match`
// to the shared statement dispatch, so the canary parse path — and the
// byte-identical fixed point — is unchanged.
//
// Token shape: `match SCRUT { PAT => BODY , PAT => BODY , _ => BODY }`. The
// fat arrow `=>` is NOT a bootstrap token: byte `=` (61) fails the `==`
// peek-ahead and byte `>` (62) fails the `>=` peek-ahead, so `=>` lexes as the
// two-token sequence tk_eq() then tk_gt(). Each arm has exactly one `=>`, so
// the arm count is the number of `tk_eq tk_gt` pairs at brace-depth 0 inside
// the match body. A wildcard arm is a bare `_` (a single tk_ident spelling
// "_", byte 95 is alpha) immediately preceding a `=>` at depth 0.
// ===========================================================================

// Returns 1 if the bytes buf[lo..hi) spell "match" (5 bytes:
// m=109,a=97,t=116,c=99,h=104), else 0.
pub fn is_ident_match(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo) == 109 {
            if load_byte(buf, lo + 1) == 97 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 99 {
                        if load_byte(buf, lo + 4) == 104 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// Returns 1 if the bytes buf[lo..hi) spell "_" (1 byte: underscore=95), else 0.
pub fn is_ident_underscore(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 1 {
        if load_byte(buf, lo) == 95 {
            return 1;
        }
    }
    0
}

// Scan the token stream for the first ident-token spelling "match". Returns the
// token index of that `match` token, or -1 if none. Tail-recursive.
pub fn mt_find_match(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if is_ident_match(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
            return pos;
        }
    }
    mt_find_match(toks, buf, pos + 1)
}

// Count the `=>` fat arrows (tk_eq immediately followed by tk_gt) at brace
// depth 0 between the match body's opening `{` and its matching `}`. `pos` is
// the token index just AFTER the opening `{`; `depth` is the open-brace nesting
// (0 at the arm level). Each arm contributes exactly one depth-0 `=>`, so the
// returned count is the arm count. Tail-recursive with an accumulator.
pub fn mt_count_arrows(toks: Vec, pos: i64, depth: i64, acc: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return acc;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return mt_count_arrows(toks, pos + 1, depth + 1, acc);
    }
    if k == tk_rbrace() {
        if depth == 0 {
            return acc;
        }
        return mt_count_arrows(toks, pos + 1, depth - 1, acc);
    }
    if depth == 0 {
        if k == tk_eq() {
            if tok_kind(toks, pos + 1) == tk_gt() {
                return mt_count_arrows(toks, pos + 2, depth, acc + 1);
            }
        }
    }
    mt_count_arrows(toks, pos + 1, depth + 0, acc)
}

// Scan the arm region for a wildcard arm: a bare `_` ident token immediately
// followed by a `=>` (tk_eq tk_gt) at brace depth 0. Returns 1 if found, else
// 0. `pos` is just after the opening `{`. Tail-recursive.
pub fn mt_find_wildcard(toks: Vec, buf: i64, pos: i64, depth: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return mt_find_wildcard(toks, buf, pos + 1, depth + 1);
    }
    if k == tk_rbrace() {
        if depth == 0 {
            return 0;
        }
        return mt_find_wildcard(toks, buf, pos + 1, depth - 1);
    }
    if depth == 0 {
        if k == tk_ident() {
            if is_ident_underscore(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
                if tok_kind(toks, pos + 1) == tk_eq() {
                    if tok_kind(toks, pos + 2) == tk_gt() {
                        return 1;
                    }
                }
            }
        }
    }
    mt_find_wildcard(toks, buf, pos + 1, depth + 0)
}

// Selftest export: 1 if `src` contains a `match` expression, else 0.
pub fn selftest_match_present(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0;
    }
    1
}

// Selftest export: the number of arms in the match, or -1 if no match. The
// scrutinee is parsed with the existing parse_expr (it stops at `{`), then the
// arm count is the number of depth-0 `=>` arrows in the match body.
pub fn selftest_match_arm_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    let lbrace_pos: i64 = pr_pos(scrut);
    mt_count_arrows(toks, lbrace_pos + 1, 0, 0)
}

// Selftest export: the AST kind of the match SCRUTINEE expression, or -1 if no
// match. Reuses parse_expr starting just after the `match` token; for a bare
// identifier scrutinee (e.g. `match k`) this is ast_ident().
pub fn selftest_match_scrut_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    ast_kind(pr_node(scrut))
}

// Selftest export: 1 if the match has a wildcard `_` arm, 0 if not, -1 if no
// match.
pub fn selftest_match_has_wildcard(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    let lbrace_pos: i64 = pr_pos(scrut);
    mt_find_wildcard(toks, src_addr, lbrace_pos + 1, 0)
}

// ===========================================================================
// SECTION 4c — NATIVE x86-64 / ELF EMITTER (Rust-independence #14, PHASE 1.3)
//
// ADDITIVE / canary-isolated. SECTION 4b ports src/mlir/lowering.rs (the MLIR
// TEXT target). THIS section ports src/native/mod.rs — the zero-LLVM
// IR -> x86-64 -> static ELF64 backend — for the SCALAR i64 slice, byte-for-byte
// identical to the Rust `mind-native <f>` artifact (498-byte add/main fixture).
//
// It REUSES the same parser + AST walk + SSA numbering as SECTION 4b: for the
// scalar subset (no lets / no control flow) a value's SSA id from
// emit_mlir_expr_env EXACTLY equals its frame-slot index in src/native (params
// occupy %0..%n-1 == slots 0..n-1; body values continue at %n == slot n). So the
// frame displacement of value `id` is rbp - 8*(id+1), and the native walk mirrors
// the MLIR walk arm-for-arm, emitting machine code into a code String instead of
// MLIR text. NOTHING here is reached through mindc_compile / lower_program — the
// keystone mic@1 canary, the mic@3 flip, and the fixed point are all untouched.
// Exposed via selftest_native_elf (the Python gate diffs its returned ELF bytes
// against the Rust `mind-native` ELF).
//
// COVERED (byte-identical, scalar i64 subset only): FnDef with `%N: i64` params
// and `-> i64`, ConstI64 -> `movabs rax, imm64; mov [slot], rax`, BinOp add/sub/
// mul -> `mov rax,[lhs]; OP rax,[rhs]; mov [dst],rax`, ident -> param/let slot
// (no instruction), intra-module Call -> argreg spills + `call rel32` (linker-
// patched) + result spill, Return -> `mov rax,[v]; epilogue/ret` (or, in `main`,
// `mov rdi,rax; mov rax,60; syscall`). The entry function (`main`) gets the
// STACK_TOP rsp-switch prologue; a library with no `main` gets the synth
// exit(0) stub. The four PT_LOAD/PT_NOTE phdrs (code, note, arena, stack) and the
// trace-hash note are reproduced exactly. Anything outside this subset
// (control flow, division/shift/compare, tensors, narrow ints, floats) is OUT OF
// SCOPE for this increment and not emitted.
// ===========================================================================

// ---- native ABI / layout constants (mirror src/native/mod.rs) ----
pub fn nb_load_addr() -> i64 {
    // LOAD_ADDR = 0x40_0000 (4 MiB)
    4194304
}
pub fn nb_hdrs() -> i64 {
    // 64 (ehdr) + 4*56 (phdrs) = 288
    288
}
pub fn nb_arena_addr() -> i64 {
    // ARENA_ADDR = 0x100_0000 (16 MiB)
    16777216
}
pub fn nb_arena_bytes() -> i64 {
    // ARENA_BYTES = 1024*1024*1024 = 1 GiB
    1073741824
}
pub fn nb_stack_bytes() -> i64 {
    // STACK_BYTES = 4 GiB
    4294967296
}
pub fn nb_stack_addr() -> i64 {
    // STACK_ADDR = ARENA_ADDR + ARENA_BYTES + 0x1000
    nb_arena_addr() + nb_arena_bytes() + 4096
}
pub fn nb_stack_top() -> i64 {
    // STACK_TOP = STACK_ADDR + STACK_BYTES
    nb_stack_addr() + nb_stack_bytes()
}

// ---- low-level byte emitters into a code String ----
// Push the low byte of `b` (string_push_byte stores via __mind_store_i8).
pub fn nb_push(code: String, b: i64) -> String {
    string_push_byte(code, b)
}

// Append `n` low bytes of `v`, least-significant first (two's-complement i64).
// `n` in 1..8. `& 255` isolates the low byte (bitwise, correct for any sign); the
// shift MUST be a floor/arithmetic >>8 (not the language's trunc-toward-zero `/`),
// else a NEGATIVE i64 whose bit-magnitude is < 2^56 loses its sign bytes — e.g. the
// f64 bit pattern -inf = 0xFFF0000000000000 (small-magnitude signed i64) truncated
// to 0x00F0000000000000, so `x as i64` of -inf mis-emitted. For v>=0 floor == trunc
// (every ELF-header/disp32 caller is unaffected, byte-identical); for v<0 use
// (v-255)/256 == floor(v/256) == an arithmetic 8-bit right shift.
pub fn nb_le(code: String, v: i64, n: i64) -> String {
    if n <= 0 {
        return code;
    }
    let c1: String = string_push_byte(code, v & 255);
    let next: i64 = if v < 0 {
        (v - 255) / 256
    } else {
        v / 256
    };
    nb_le(c1, next, n - 1)
}

// 16-bit / 32-bit / 64-bit little-endian helpers (e_type, e_phoff, disp32, etc.).
pub fn nb_u16(code: String, v: i64) -> String {
    nb_le(code, v, 2)
}
pub fn nb_u32(code: String, v: i64) -> String {
    nb_le(code, v, 4)
}
pub fn nb_i64le(code: String, v: i64) -> String {
    nb_le(code, v, 8)
}

// Frame displacement of value/slot `id`: rbp - 8*(id+1). Two's-complement i32.
pub fn nb_slot_disp(id: i64) -> i64 {
    0 - (8 * (id + 1))
}

// ---- x86-64 instruction emitters (mirror src/native/mod.rs byte-for-byte) ----

// store_rax(disp): `mov [rbp+disp32], rax`  = 48 89 85 <disp32>
pub fn nb_store_rax(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 137);
    let c3: String = nb_push(c2, 133);
    nb_i32le_signed(c3, disp)
}

// load_rax(disp): `mov rax, [rbp+disp32]` = 48 8B 85 <disp32>
pub fn nb_load_rax(code: String, disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    nb_i32le_signed(c3, disp)
}

// Emit a (possibly negative) value as a 4-byte little-endian disp32. A negative
// disp must encode as its 32-bit two's complement (v + 2^32), so the low 4 bytes
// are correct; nb_le's `& 255` then picks the right bytes.
pub fn nb_i32le_signed(code: String, v: i64) -> String {
    let u: i64 = if v < 0 {
        v + 4294967296
    } else {
        v
    };
    nb_le(code, u, 4)
}

// arith_rax_mem(op, disp): the in-place op of rax with [rbp+disp32].
//   Add -> 48 03 85 ; Sub -> 48 2B 85 ; Mul -> 48 0F AF 85
pub fn nb_arith_rax_mem(code: String, op: i64, disp: i64) -> String {
    if op == op_add() {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 3);
        let c3: String = nb_push(c2, 133);
        return nb_i32le_signed(c3, disp);
    }
    if op == op_sub() {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 43);
        let c3: String = nb_push(c2, 133);
        return nb_i32le_signed(c3, disp);
    }
    // Single-instruction bitwise ops (src/native arith_rax_mem 176-180):
    //   and rax,[rbp+disp] = 48 23 85 ; or = 48 0B 85 ; xor = 48 33 85.
    if op == op_bitand() {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 35);
        let c3: String = nb_push(c2, 133);
        return nb_i32le_signed(c3, disp);
    }
    if op == op_bitor() {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 11);
        let c3: String = nb_push(c2, 133);
        return nb_i32le_signed(c3, disp);
    }
    if op == op_bitxor() {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 51);
        let c3: String = nb_push(c2, 133);
        return nb_i32le_signed(c3, disp);
    }
    // op_div(): the branchless guarded signed-division sequence (lhs already in
    // rax). Byte-for-byte src/native::emit_div_mod_guarded(is_mod=false): substitute
    // divisor 1 when rhs==0 OR (rax==INT_MIN && rcx==-1) so idiv never traps, then
    // force the result to 0 when rhs==0 — giving MIND's defined edges x/0=0,
    // INT_MIN/-1=INT_MIN. op_mod routes to the SAME guarded sequence with is_mod=1,
    // which appends a `mov rax,rdx` tail (remainder, not quotient). tk_to_op DOES
    // yield op_mod (the `%` operator), so the mod arm below is live.
    if op == op_div() {
        return nb_div_guarded(code, disp, 0);
    }
    // op_mod(): the guarded signed remainder — byte-for-byte the div sequence plus a
    // `mov rax,rdx` after idiv (the remainder is in rdx). Without this arm `a % b`
    // fell through to the imul tail below and native-lowered to `a * b`.
    if op == op_mod() {
        return nb_div_guarded(code, disp, 1);
    }
    // op_shl/op_shr: x86 variable shift takes the count in cl (src/native 760-766).
    //   mov rcx, [rbp+disp32]   = 48 8B 8D <disp32>
    //   shl rax, cl (D3 /4 = E0) | shr is ARITHMETIC: sar rax, cl (/7 = F8) = 48 D3 mod
    // Ported for the SHA-256 trace-hash leg (nb_rotr32 / nb_shr32 / BE byte packing /
    // digest serialise all use `<<`/`>>`). Byte-for-byte with the oracle's mind-native.
    if op == op_shl() {
        let s1: String = nb_push(code, 72);
        let s2: String = nb_push(s1, 139);
        let s3: String = nb_push(s2, 141);
        let s4: String = nb_i32le_signed(s3, disp);
        let s5: String = nb_push(s4, 72);
        let s6: String = nb_push(s5, 211);
        return nb_push(s6, 224);
    }
    if op == op_shr() {
        let s1: String = nb_push(code, 72);
        let s2: String = nb_push(s1, 139);
        let s3: String = nb_push(s2, 141);
        let s4: String = nb_i32le_signed(s3, disp);
        let s5: String = nb_push(s4, 72);
        let s6: String = nb_push(s5, 211);
        return nb_push(s6, 248);
    }
    // op_mul(): imul rax, [rbp+disp32] = 48 0F AF 85 <disp32>
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 175);
    let c4: String = nb_push(c3, 133);
    nb_i32le_signed(c4, disp)
}
// Emit `emit_div_mod_guarded(is_mod=?, rhs=disp)` — the branchless guarded signed
// div/mod with the dividend already in rax. Flat sequential `nb_push` chain (one let
// per byte-group, no value-if-expr) to stay self-flip-clean. INT_MIN is emitted as
// its raw 8 LE bytes (00*7, 0x80) so no i64 literal is needed. When is_mod==1 the
// idiv is followed by `mov rax,rdx` (48 89 D0) so the RESULT is the remainder (in
// rdx), not the quotient (in rax) — 63 bytes for mod vs 60 for div.
pub fn nb_div_guarded(code: String, disp: i64, is_mod: i64) -> String {
    // mov rcx, [rbp+rhs]  = 48 8B 8D <disp32>
    let a1: String = nb_push(code, 72);
    let a2: String = nb_push(a1, 139);
    let a3: String = nb_push(a2, 141);
    let a4: String = nb_i32le_signed(a3, disp);
    // xor r8,r8 = 4D 31 C0 ; test rcx,rcx = 48 85 C9 ; sete r8b = 41 0F 94 C0
    let b1: String = nb_push(a4, 77);
    let b2: String = nb_push(b1, 49);
    let b3: String = nb_push(b2, 192);
    let b4: String = nb_push(b3, 72);
    let b5: String = nb_push(b4, 133);
    let b6: String = nb_push(b5, 201);
    let b7: String = nb_push(b6, 65);
    let b8: String = nb_push(b7, 15);
    let b9: String = nb_push(b8, 148);
    let b10: String = nb_push(b9, 192);
    // movabs r10, INT_MIN = 49 BA 00 00 00 00 00 00 00 80
    let c1: String = nb_push(b10, 73);
    let c2: String = nb_push(c1, 186);
    let c3: String = nb_push(c2, 0);
    let c4: String = nb_push(c3, 0);
    let c5: String = nb_push(c4, 0);
    let c6: String = nb_push(c5, 0);
    let c7: String = nb_push(c6, 0);
    let c8: String = nb_push(c7, 0);
    let c9: String = nb_push(c8, 0);
    let c10: String = nb_push(c9, 128);
    // xor r9,r9 = 4D 31 C9 ; cmp rax,r10 = 4C 39 D0 ; sete r9b = 41 0F 94 C1
    let d1: String = nb_push(c10, 77);
    let d2: String = nb_push(d1, 49);
    let d3: String = nb_push(d2, 201);
    let d4: String = nb_push(d3, 76);
    let d5: String = nb_push(d4, 57);
    let d6: String = nb_push(d5, 208);
    let d7: String = nb_push(d6, 65);
    let d8: String = nb_push(d7, 15);
    let d9: String = nb_push(d8, 148);
    let d10: String = nb_push(d9, 193);
    // xor r11,r11 = 4D 31 DB ; cmp rcx,-1 = 48 83 F9 FF ; sete r11b = 41 0F 94 C3
    let e1: String = nb_push(d10, 77);
    let e2: String = nb_push(e1, 49);
    let e3: String = nb_push(e2, 219);
    let e4: String = nb_push(e3, 72);
    let e5: String = nb_push(e4, 131);
    let e6: String = nb_push(e5, 249);
    let e7: String = nb_push(e6, 255);
    let e8: String = nb_push(e7, 65);
    let e9: String = nb_push(e8, 15);
    let e10: String = nb_push(e9, 148);
    let e11: String = nb_push(e10, 195);
    // and r9,r11 = 4D 21 D9 ; or r9,r8 = 4D 09 C1
    let f1: String = nb_push(e11, 77);
    let f2: String = nb_push(f1, 33);
    let f3: String = nb_push(f2, 217);
    let f4: String = nb_push(f3, 77);
    let f5: String = nb_push(f4, 9);
    let f6: String = nb_push(f5, 193);
    // mov r10,1 = 49 C7 C2 01 00 00 00
    let g1: String = nb_push(f6, 73);
    let g2: String = nb_push(g1, 199);
    let g3: String = nb_push(g2, 194);
    let g4: String = nb_push(g3, 1);
    let g5: String = nb_push(g4, 0);
    let g6: String = nb_push(g5, 0);
    let g7: String = nb_push(g6, 0);
    // test r9,r9 = 4D 85 C9 ; cmovnz rcx,r10 = 49 0F 45 CA
    let h1: String = nb_push(g7, 77);
    let h2: String = nb_push(h1, 133);
    let h3: String = nb_push(h2, 201);
    let h4: String = nb_push(h3, 73);
    let h5: String = nb_push(h4, 15);
    let h6: String = nb_push(h5, 69);
    let h7: String = nb_push(h6, 202);
    // cqo = 48 99 ; idiv rcx = 48 F7 F9
    let i1: String = nb_push(h7, 72);
    let i2: String = nb_push(i1, 153);
    let i3: String = nb_push(i2, 72);
    let i4: String = nb_push(i3, 247);
    let i5: String = nb_push(i4, 249);
    // For mod (is_mod==1): the remainder is in rdx after idiv; move it into rax
    // BEFORE the zero-guard so the guard zeroes the MOD result on rhs==0 too.
    //   mov rax,rdx = 48 89 D0
    if is_mod == 1 {
        let m1: String = nb_push(i5, 72);
        let m2: String = nb_push(m1, 137);
        let m3: String = nb_push(m2, 208);
        return nb_div_guard_tail(m3);
    }
    nb_div_guard_tail(i5)
}
// The shared zero-guard tail of nb_div_guarded (div and mod): force the result to 0
// when rhs==0 (r8 was set to (rhs==0) earlier), giving MIND's defined edges x/0=0
// and x%0=0. Extracted so div (is_mod=0) stays byte-identical to before the mod arm.
//   xor r10,r10 = 4D 31 D2 ; test r8,r8 = 4D 85 C0 ; cmovnz rax,r10 = 49 0F 45 C2
pub fn nb_div_guard_tail(i5: String) -> String {
    let j1: String = nb_push(i5, 77);
    let j2: String = nb_push(j1, 49);
    let j3: String = nb_push(j2, 210);
    let j4: String = nb_push(j3, 77);
    let j5: String = nb_push(j4, 133);
    let j6: String = nb_push(j5, 192);
    let j7: String = nb_push(j6, 73);
    let j8: String = nb_push(j7, 15);
    let j9: String = nb_push(j8, 69);
    nb_push(j9, 194)
}

// The `setcc` second opcode byte for a comparison BinOp, or -1 for a
// non-comparison op (mirror src/native::setcc_opcode). Signed forms — MIND i64 is
// signed; sete/setne are sign-agnostic.
//   Lt setl 0x9C ; Le setle 0x9E ; Gt setg 0x9F ; Ge setge 0x9D ;
//   Eq sete 0x94 ; Ne setne 0x95.
pub fn nb_setcc_opcode(op: i64) -> i64 {
    if op == op_lt() {
        return 156;
    }
    if op == op_le() {
        return 158;
    }
    if op == op_gt() {
        return 159;
    }
    if op == op_ge() {
        return 157;
    }
    if op == op_eq() {
        return 148;
    }
    if op == op_ne() {
        return 149;
    }
    0 - 1
}

// cmp_rax_mem(setcc, rhs_disp): lhs already in rax — `cmp rax, [rbp+rhs] ;
// setcc al ; movzx eax, al` — leaves the 0/1 boolean in rax (mirror
// src/native::cmp_rax_mem).
//   cmp  = 48 3B 85 <disp32> ; setcc al = 0F <setcc> C0 ; movzx eax,al = 0F B6 C0
pub fn nb_cmp_rax_mem(code: String, setcc: i64, rhs_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 59);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, rhs_disp);
    let c5: String = nb_push(c4, 15);
    let c6: String = nb_push(c5, setcc);
    let c7: String = nb_push(c6, 192);
    let c8: String = nb_push(c7, 15);
    let c9: String = nb_push(c8, 182);
    nb_push(c9, 192)
}

// ---- Option-C i64-handle ABI intrinsic emitters (mirror src/native/mod.rs) ----
// These inline the front-end's struct-literal / field-read lowering: a struct
// value is the i64 heap base address, allocated by a deterministic bump arena
// (NEVER malloc/ASLR — byte-identity-by-construction), with per-field 8-byte
// stores and loads through the handle. Ported byte-for-byte from emit_alloc /
// emit_alloc_core / emit_store_i64 / emit_load_i64.

// emit_alloc_core: header + data bump over the fixed-vaddr BSS arena. Leaves the
// returned DATA pointer in rax. Expects the rounded data size already in rsi.
//   mov rdi,rsi ; add rdi,8 ; movabs rax,ARENA_ADDR ; mov rcx,[rax] ;
//   movabs rdx,ARENA_DATA ; mov rax,rcx ; add rax,rdx ; mov [rax],rsi ;
//   add rax,8 ; mov rdx,rcx ; add rdx,rdi ; movabs r8,ARENA_DATA_BYTES ;
//   cmp r8,rdx ; jae +2 ; ud2 ; movabs r9,ARENA_ADDR ; mov [r9],rdx
pub fn nb_emit_alloc_core(code: String) -> String {
    // mov rdi,rsi = 48 89 F7 ; add rdi,8 = 48 83 C7 08
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 137);
    let c3: String = nb_push(c2, 247);
    let c4: String = nb_push(c3, 72);
    let c5: String = nb_push(c4, 131);
    let c6: String = nb_push(c5, 199);
    let c7: String = nb_push(c6, 8);
    // movabs rax,ARENA_ADDR = 48 B8 <imm64> ; mov rcx,[rax] = 48 8B 08
    let c8: String = nb_push(c7, 72);
    let c9: String = nb_push(c8, 184);
    let c10: String = nb_i64le(c9, nb_arena_addr());
    let c11: String = nb_push(c10, 72);
    let c12: String = nb_push(c11, 139);
    let c13: String = nb_push(c12, 8);
    // movabs rdx,ARENA_DATA = 48 BA <imm64> (ARENA_DATA = ARENA_ADDR + 8)
    let c14: String = nb_push(c13, 72);
    let c15: String = nb_push(c14, 186);
    let c16: String = nb_i64le(c15, nb_arena_addr() + 8);
    // mov rax,rcx = 48 89 C8 ; add rax,rdx = 48 01 D0
    let c17: String = nb_push(c16, 72);
    let c18: String = nb_push(c17, 137);
    let c19: String = nb_push(c18, 200);
    let c20: String = nb_push(c19, 72);
    let c21: String = nb_push(c20, 1);
    let c22: String = nb_push(c21, 208);
    // mov [rax],rsi = 48 89 30 ; add rax,8 = 48 83 C0 08
    let c23: String = nb_push(c22, 72);
    let c24: String = nb_push(c23, 137);
    let c25: String = nb_push(c24, 48);
    let c26: String = nb_push(c25, 72);
    let c27: String = nb_push(c26, 131);
    let c28: String = nb_push(c27, 192);
    let c29: String = nb_push(c28, 8);
    // mov rdx,rcx = 48 89 CA ; add rdx,rdi = 48 01 FA
    let c30: String = nb_push(c29, 72);
    let c31: String = nb_push(c30, 137);
    let c32: String = nb_push(c31, 202);
    let c33: String = nb_push(c32, 72);
    let c34: String = nb_push(c33, 1);
    let c35: String = nb_push(c34, 250);
    // movabs r8,ARENA_DATA_BYTES = 49 B8 <imm64> (ARENA_BYTES - 8)
    let c36: String = nb_push(c35, 73);
    let c37: String = nb_push(c36, 184);
    let c38: String = nb_i64le(c37, nb_arena_bytes() - 8);
    // cmp r8,rdx = 49 39 D0 ; jae +2 = 0F 83 02 00 00 00 ; ud2 = 0F 0B
    let c39: String = nb_push(c38, 73);
    let c40: String = nb_push(c39, 57);
    let c41: String = nb_push(c40, 208);
    let c42: String = nb_push(c41, 15);
    let c43: String = nb_push(c42, 131);
    let c44: String = nb_push(c43, 2);
    let c45: String = nb_push(c44, 0);
    let c46: String = nb_push(c45, 0);
    let c47: String = nb_push(c46, 0);
    let c48: String = nb_push(c47, 15);
    let c49: String = nb_push(c48, 11);
    // movabs r9,ARENA_ADDR = 49 B9 <imm64> ; mov [r9],rdx = 49 89 11
    let c50: String = nb_push(c49, 73);
    let c51: String = nb_push(c50, 185);
    let c52: String = nb_i64le(c51, nb_arena_addr());
    let c53: String = nb_push(c52, 73);
    let c54: String = nb_push(c53, 137);
    nb_push(c54, 17)
}

// emit_alloc(bytes_disp): round the requested size up to the 8-byte stride into
// rsi, then bump. Leaves the data pointer in rax.
//   mov rsi,[rbp+bytes] = 48 8B B5 <disp32> ; add rsi,7 = 48 83 C6 07 ;
//   and rsi,-8 = 48 83 E6 F8 ; emit_alloc_core.
pub fn nb_emit_alloc(code: String, bytes_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 181);
    let c4: String = nb_i32le_signed(c3, bytes_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 131);
    let c7: String = nb_push(c6, 198);
    let c8: String = nb_push(c7, 7);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 131);
    let c11: String = nb_push(c10, 230);
    let c12: String = nb_push(c11, 248);
    nb_emit_alloc_core(c12)
}

// emit_store_i64(addr_disp, val_disp): 8-byte store through the i64 handle.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov rcx,[rbp+val] = 48 8B 8D
//   <disp32> ; mov [rax],rcx = 48 89 08.
pub fn nb_emit_store_i64(code: String, addr_disp: i64, val_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 141);
    let c8: String = nb_i32le_signed(c7, val_disp);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 137);
    nb_push(c10, 8)
}

// emit_load_i64(addr_disp): 8-byte load through the i64 handle. Result in rax.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov rax,[rax] = 48 8B 00.
pub fn nb_emit_load_i64(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    nb_push(c6, 0)
}

// emit_store_i8(addr_disp, val_disp): write the LOW BYTE of val only (mirror
// src/native::emit_store_i8). The byte store must NOT clobber the adjacent 7.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov rcx,[rbp+val] = 48 8B 8D
//   <disp32> ; mov byte [rax],cl = 88 08.
pub fn nb_emit_store_i8(code: String, addr_disp: i64, val_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 141);
    let c8: String = nb_i32le_signed(c7, val_disp);
    let c9: String = nb_push(c8, 136);
    nb_push(c9, 8)
}

// emit_load_i8(addr_disp): load ONE byte, ZERO-extend to i64 (mirror
// src/native::emit_load_i8). Result in rax.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; movzx rax,byte [rax] = 48 0F B6 00.
pub fn nb_emit_load_i8(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 182);
    nb_push(c7, 0)
}

// emit_load_i16_sx(addr_disp): load ONE 16-bit word, SIGN-extend to i64 (the
// signed narrow-load the int8 zero-extend sibling nb_emit_load_i8 lacks). The
// slot at [rbp+addr] holds the element's absolute runtime address; deref it as a
// signed word. First byte-identity-gated tensor rung (#108 RI-B2-S2) — the int16
// dot movsx-loads each element through this before the i64 multiply-accumulate.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; movsx rax,word [rax] = 48 0F BF 00.
pub fn nb_emit_load_i16_sx(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 191);
    nb_push(c7, 0)
}

// movsxd rax, eax = 48 63 C0 — narrow rax to its low 32 bits, then sign-extend
// back to i64 (`(x as i32) as i64`). The int16 dot's FINAL reduction step: the
// i64-accumulated sum is narrowed ONCE to i32 to match the MLIR canary's
// `acc as i32` (ref_dot_i16_scalar), which is what the dot-i16-4096 gate hashes.
pub fn nb_movsxd_rax_eax(code: String) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 99);
    nb_push(c2, 192)
}

// movsx rax, ax = 48 0F BF C0 — narrow rax to its low 16 bits, then sign-extend
// back to i64 (`(x as i16) as i64`). The reg-to-reg WORD sibling of the DWORD
// nb_movsxd_rax_eax (48 63 C0) and BYTE nb_movsx_rax_al (48 0F BE C0). This is the
// two's-complement WRAP-TO-WIDTH primitive for narrow-int arithmetic: after an i16
// add/sub/mul computed in full 64-bit registers, applying this masks off the high
// 48 bits and re-signs bit 15, so INT16_MAX+1 wraps to INT16_MIN (not i64-widens).
// C2 narrow-int wrap rung — user-reachable via __mind_wrap_i16 (nb_emit_intrinsic
// kind 18); never self-taken during self-compile, so the integer oracle is unchanged.
pub fn nb_movsx_rax_ax(code: String) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 191);
    nb_push(c3, 192)
}

// movsx rax, al = 48 0F BE C0 — narrow rax to its low 8 bits, then sign-extend back
// to i64 (`(x as i8) as i64`). The reg-to-reg BYTE sibling of nb_movsx_rax_ax /
// nb_movsxd_rax_eax. The two's-complement wrap primitive for i8 arithmetic: after an
// i8 add/sub/mul in full registers, this masks the high 56 bits and re-signs bit 7,
// so INT8_MAX+1 (0x80) wraps to -128 (not the i64 value 128). C2 narrow-int wrap
// rung — user-reachable via __mind_wrap_i8 (nb_emit_intrinsic kind 17); never
// self-taken during self-compile, so the integer native-ELF oracle is unchanged.
pub fn nb_movsx_rax_al(code: String) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 190);
    nb_push(c3, 192)
}

// Sign-extending 32-bit memory load (the Q16.16 i32 sibling of nb_emit_load_i16_sx,
// which does the WORD version). The slot at [rbp+addr] holds the element's absolute
// runtime address; deref it as a signed DWORD. The Q16.16 dot (#108 RI-B2-S4)
// movsxd-loads each i32 fixed-point element through this before the i64 product.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; movsxd rax,dword [rax] = 48 63 00.
pub fn nb_emit_load_i32_sx(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 99);
    nb_push(c6, 0)
}

// Sign-extending 8-bit memory load (the int8 SIGNED sibling of the zero-extend
// nb_emit_load_i8 and the WORD/DWORD nb_emit_load_i16_sx/nb_emit_load_i32_sx). The
// slot at [rbp+addr] holds the element's absolute runtime address; deref it as a
// signed BYTE. The int8 GEMM (#108 RI-B2-S7) movsx-byte-loads each int8 element
// through this before the i64 product (pure integer, no fixed-point rescale).
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; movsx rax,byte [rax] = 48 0F BE 00.
pub fn nb_emit_load_i8_sx(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 190);
    nb_push(c7, 0)
}

// emit_store_i32(addr_disp, val_disp): write the LOW 32 BITS of val only (the
// narrow-int C2 dword sibling of nb_emit_store_i8/nb_emit_store_i16). The dword
// store must NOT clobber the adjacent 4 bytes of the 8-byte slot. NEW user-
// reachable intrinsic surface (__mind_store_i32); never self-taken during
// self-compile, so the integer native-ELF oracle stays byte-identical.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov rcx,[rbp+val] = 48 8B 8D
//   <disp32> ; mov dword [rax],ecx = 89 08.
pub fn nb_emit_store_i32(code: String, addr_disp: i64, val_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 141);
    let c8: String = nb_i32le_signed(c7, val_disp);
    let c9: String = nb_push(c8, 137);
    nb_push(c9, 8)
}

// emit_load_i16_zx(addr_disp): load ONE 16-bit word, ZERO-extend to i64 (the
// UNSIGNED narrow-load sibling of nb_emit_load_i8's byte version; the signed
// counterpart is nb_emit_load_i16_sx). NEW user-reachable intrinsic surface
// (__mind_load_i16). Result in rax.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; movzx rax,word [rax] = 48 0F B7 00.
pub fn nb_emit_load_i16_zx(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 183);
    nb_push(c7, 0)
}

// emit_load_i32_zx(addr_disp): load ONE 32-bit dword, ZERO-extend to i64 (the
// UNSIGNED narrow-load sibling of nb_emit_load_i16_zx; the signed counterpart is
// nb_emit_load_i32_sx). A 32-bit mov to a 32-bit register implicitly zeroes the
// upper 32 bits of the 64-bit register, so no REX.W / movzx is needed. NEW user-
// reachable intrinsic surface (__mind_load_i32). Result in rax.
//   mov rax,[rbp+addr] = 48 8B 85 <disp32> ; mov eax,[rax] = 8B 00.
pub fn nb_emit_load_i32_zx(code: String, addr_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 133);
    let c4: String = nb_i32le_signed(c3, addr_disp);
    let c5: String = nb_push(c4, 139);
    nb_push(c5, 0)
}

// emit_write(fd_disp, buf_disp, count_disp): raw write(2) syscall, NO libc
// (mirror src/native::emit_write). The print path's offset arg is the -1 sentinel
// that write(2) already implements, so it is intentionally unused here.
//   mov rdi,[rbp+fd]    = 48 8B BD <disp32>
//   mov rsi,[rbp+buf]   = 48 8B B5 <disp32>
//   mov rdx,[rbp+count] = 48 8B 95 <disp32>
//   mov rax,1           = 48 C7 C0 01 00 00 00
//   syscall             = 0F 05
pub fn nb_emit_write(code: String, fd_disp: i64, buf_disp: i64, count_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 189);
    let c4: String = nb_i32le_signed(c3, fd_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 181);
    let c8: String = nb_i32le_signed(c7, buf_disp);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 139);
    let c11: String = nb_push(c10, 149);
    let c12: String = nb_i32le_signed(c11, count_disp);
    let c13: String = nb_push(c12, 72);
    let c14: String = nb_push(c13, 199);
    let c15: String = nb_push(c14, 192);
    let c16: String = nb_push(c15, 1);
    let c17: String = nb_push(c16, 0);
    let c18: String = nb_push(c17, 0);
    let c19: String = nb_push(c18, 0);
    let c20: String = nb_push(c19, 15);
    nb_push(c20, 5)
}

// emit_read(fd_disp, buf_disp, count_disp): raw read(2) syscall, NO libc (mirror
// src/native::emit_read). The exact dual of nb_emit_write; rax=0 (SYS_read).
//   mov rdi,[rbp+fd]    = 48 8B BD <disp32>
//   mov rsi,[rbp+buf]   = 48 8B B5 <disp32>
//   mov rdx,[rbp+count] = 48 8B 95 <disp32>
//   mov rax,0           = 48 C7 C0 00 00 00 00
//   syscall             = 0F 05
pub fn nb_emit_read(code: String, fd_disp: i64, buf_disp: i64, count_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 189);
    let c4: String = nb_i32le_signed(c3, fd_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 139);
    let c7: String = nb_push(c6, 181);
    let c8: String = nb_i32le_signed(c7, buf_disp);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 139);
    let c11: String = nb_push(c10, 149);
    let c12: String = nb_i32le_signed(c11, count_disp);
    let c13: String = nb_push(c12, 72);
    let c14: String = nb_push(c13, 199);
    let c15: String = nb_push(c14, 192);
    let c16: String = nb_push(c15, 0);
    let c17: String = nb_push(c16, 0);
    let c18: String = nb_push(c17, 0);
    let c19: String = nb_push(c18, 0);
    let c20: String = nb_push(c19, 15);
    nb_push(c20, 5)
}

// emit_open(path_disp): raw open(2) syscall, NO libc (RI-C task #228). Opens the
// NUL-terminated C string at [rbp+path] read-only. flags = O_RDONLY (0), mode = 0
// (unused for reading). Returns the fd (or a negative errno) in rax. The path must
// already be NUL-terminated — argv[i] pointers (from __mind_argv) are C strings, so
// they need no terminator; a String's backing bytes are NOT guaranteed terminated,
// so a caller passing a String must NUL-terminate it first (see io.mind io_open).
//   mov rdi,[rbp+path] = 48 8B BD <disp32>
//   xor esi,esi        = 31 F6            (flags = O_RDONLY)
//   xor edx,edx        = 31 D2            (mode = 0)
//   mov rax,2          = 48 C7 C0 02 00 00 00   (SYS_open)
//   syscall            = 0F 05
pub fn nb_emit_open(code: String, path_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 189);
    let c4: String = nb_i32le_signed(c3, path_disp);
    let c5: String = nb_push(c4, 49);
    let c6: String = nb_push(c5, 246);
    let c7: String = nb_push(c6, 49);
    let c8: String = nb_push(c7, 210);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 199);
    let c11: String = nb_push(c10, 192);
    let c12: String = nb_push(c11, 2);
    let c13: String = nb_push(c12, 0);
    let c14: String = nb_push(c13, 0);
    let c15: String = nb_push(c14, 0);
    let c16: String = nb_push(c15, 15);
    nb_push(c16, 5)
}

// emit_free: the no-free bump arena (mirror src/native::__mind_free arm). The ptr
// arg is intentionally unread; the contract value is 0.
//   xor rax,rax = 48 31 C0
pub fn nb_emit_free_xor(code: String) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 49);
    nb_push(c2, 192)
}

// emit_realloc(addr_disp, bytes_disp): grow-and-preserve over the no-free bump
// arena (mirror src/native::emit_realloc byte-for-byte). New DATA ptr -> rax. The
// three internal forward jumps (je-done, jge-exit, jmp-back) are self-contained
// within this emitted sequence; their rel32s are patched in-place after assembly
// using the captured absolute offsets (same pattern as the If-arm jumps). All
// emitted bytes are a pure function of the IR.
pub fn nb_emit_realloc(code: String, addr_disp: i64, bytes_disp: i64) -> String {
    // rsi = round_up([new_bytes],8)
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 181);
    let c4: String = nb_i32le_signed(c3, bytes_disp);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 131);
    let c7: String = nb_push(c6, 198);
    let c8: String = nb_push(c7, 7);
    let c9: String = nb_push(c8, 72);
    let c10: String = nb_push(c9, 131);
    let c11: String = nb_push(c10, 230);
    let c12: String = nb_push(c11, 248);
    // alloc the new block (header + data) -> rax
    let c13: String = nb_emit_alloc_core(c12);
    // r8 = [addr]  (old data ptr)  = 4C 8B 85 <disp32>
    let c14: String = nb_push(c13, 76);
    let c15: String = nb_push(c14, 139);
    let c16: String = nb_push(c15, 133);
    let c17: String = nb_i32le_signed(c16, addr_disp);
    // test r8,r8 = 4D 85 C0
    let c18: String = nb_push(c17, 77);
    let c19: String = nb_push(c18, 133);
    let c20: String = nb_push(c19, 192);
    // je rel32 (skip copy when addr==0) = 0F 84 <rel32>
    let c21: String = nb_push(c20, 15);
    let c22: String = nb_push(c21, 132);
    let je_site: i64 = string_len(c22);
    let c23: String = nb_u32(c22, 0);
    // r10 = [r8-8]  (old_size) = 4D 8B 50 F8
    let c24: String = nb_push(c23, 77);
    let c25: String = nb_push(c24, 139);
    let c26: String = nb_push(c25, 80);
    let c27: String = nb_push(c26, 248);
    // r11 = [rbp+new_bytes] = 4C 8B 9D <disp32>
    let c28: String = nb_push(c27, 76);
    let c29: String = nb_push(c28, 139);
    let c30: String = nb_push(c29, 157);
    let c31: String = nb_i32le_signed(c30, bytes_disp);
    // add r11,7 = 49 83 C3 07 ; and r11,-8 = 49 83 E3 F8
    let c32: String = nb_push(c31, 73);
    let c33: String = nb_push(c32, 131);
    let c34: String = nb_push(c33, 195);
    let c35: String = nb_push(c34, 7);
    let c36: String = nb_push(c35, 73);
    let c37: String = nb_push(c36, 131);
    let c38: String = nb_push(c37, 227);
    let c39: String = nb_push(c38, 248);
    // cmp r10,r11 = 4D 39 DA ; cmovg r10,r11 = 4D 0F 4F D3
    let c40: String = nb_push(c39, 77);
    let c41: String = nb_push(c40, 57);
    let c42: String = nb_push(c41, 218);
    let c43: String = nb_push(c42, 77);
    let c44: String = nb_push(c43, 15);
    let c45: String = nb_push(c44, 79);
    let c46: String = nb_push(c45, 211);
    // xor rcx,rcx = 48 31 C9
    let c47: String = nb_push(c46, 72);
    let c48: String = nb_push(c47, 49);
    let c49: String = nb_push(c48, 201);
    // loop_top:
    let loop_top: i64 = string_len(c49);
    // cmp rcx,r10 = 4C 39 D1
    let c50: String = nb_push(c49, 76);
    let c51: String = nb_push(c50, 57);
    let c52: String = nb_push(c51, 209);
    // jge rel32 (exit) = 0F 8D <rel32>
    let c53: String = nb_push(c52, 15);
    let c54: String = nb_push(c53, 141);
    let jge_site: i64 = string_len(c54);
    let c55: String = nb_u32(c54, 0);
    // mov rdx,[r8+rcx] = 49 8B 14 08 ; mov [rax+rcx],rdx = 48 89 14 08
    let c56: String = nb_push(c55, 73);
    let c57: String = nb_push(c56, 139);
    let c58: String = nb_push(c57, 20);
    let c59: String = nb_push(c58, 8);
    let c60: String = nb_push(c59, 72);
    let c61: String = nb_push(c60, 137);
    let c62: String = nb_push(c61, 20);
    let c63: String = nb_push(c62, 8);
    // add rcx,8 = 48 83 C1 08
    let c64: String = nb_push(c63, 72);
    let c65: String = nb_push(c64, 131);
    let c66: String = nb_push(c65, 193);
    let c67: String = nb_push(c66, 8);
    // jmp rel32 back to loop_top = E9 <rel32>
    let c68: String = nb_push(c67, 233);
    let jmp_site: i64 = string_len(c68);
    let c69: String = nb_u32(c68, 0);
    // after_loop: patch jge -> here
    let after_loop: i64 = string_len(c69);
    // done: (je target) -> here (same point: nothing emitted between)
    let done_at: i64 = after_loop;
    // Patch the three rel32s in place. rel = target - (site + 4).
    let addr: i64 = string_addr(c69);
    let _p1: i64 = nb_patch_rel32(addr, je_site, done_at - (je_site + 4));
    let _p2: i64 = nb_patch_rel32(addr, jge_site, after_loop - (jge_site + 4));
    let _p3: i64 = nb_patch_rel32(addr, jmp_site, loop_top - (jmp_site + 4));
    c69
}

// ===========================================================================
// RI-C — OS argc/argv access for native-ELF programs.
//
// At `_start` the SysV AMD64 initial stack holds `[rsp]=argc`, then argv[0..argc]
// (8-byte pointers), a NULL, envp, NULL, auxv. main.mind's native entry immediately
// switches rsp to STACK_TOP (`movabs rsp,STACK_TOP` = 48 BC) and abandons that
// stack, so argc/argv must be captured BEFORE that switch (the literal first bytes)
// or they are lost. We stash them in two reserved header slots of the fixed BSS
// arena — argc at ARENA_ADDR+8, &argv[0] at ARENA_ADDR+16 (the two 8-byte words
// just above the bump cursor at ARENA_ADDR+0) — and pre-seed the cursor to 16 so the
// bump allocator never hands out those 16 reserved bytes. Two intrinsics read them:
//   __mind_argc()  -> i64 argc
//   __mind_argv(i) -> i64 raw pointer to argv[i] (a NUL-terminated C string)
// The capture is emitted ONLY for an entry whose REACHABLE (pruned) fn set
// references argv (see nb_fns_use_argv), so every argv-free program — main.mind
// itself and every frozen native-ELF oracle fixture — is byte-identical to before
// this feature, EVEN when std.cli (whose args_from_os names the intrinsic) is
// seeded ahead of it but pruned away.

// argc capture reader: movabs rax,ARENA_ADDR+8 ; mov rax,[rax] ; store rax -> dst.
pub fn nb_emit_argc(code: String, dst_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, nb_arena_addr() + 8);
    let c4: String = nb_push(c3, 72);
    let c5: String = nb_push(c4, 139);
    let c6: String = nb_push(c5, 0);
    nb_store_rax(c6, dst_disp)
}

// argv[i] reader: argv_base = [ARENA_ADDR+16]; result = *(argv_base + i*8).
//   movabs rax,ARENA_ADDR+16 = 48 B8 <imm64> ; mov rax,[rax] = 48 8B 00 ;
//   mov rcx,[rbp+idx] = 48 8B 8D <disp32> ; mov rax,[rax+rcx*8] = 48 8B 04 C8 ;
//   store rax -> dst.
//
// Contract: NO bounds check against argc, same as every other raw __mind_*
// intrinsic (__mind_load_i8 et al.) — the caller must ensure `i < argc` before
// calling. `i == argc` reads the SysV NULL argv terminator; `i > argc` walks
// into envp/auxv, reading whatever pointer is stored there. The only
// production call site, cli.mind's args_from_os_rec, already guards `i < argc`
// before every call; a direct caller that skips that guard gets undefined
// (but not memory-unsafe to EMIT — the read itself never faults, only a
// dereference of a returned envp/auxv value as if it were a C string could)
// behavior. Bounds-checking here would depart from the raw-intrinsic contract
// every sibling __mind_* emitter shares — this documents it instead.
pub fn nb_emit_argv(code: String, idx_disp: i64, dst_disp: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, nb_arena_addr() + 16);
    let c4: String = nb_push(c3, 72);
    let c5: String = nb_push(c4, 139);
    let c6: String = nb_push(c5, 0);
    let c7: String = nb_push(c6, 72);
    let c8: String = nb_push(c7, 139);
    let c9: String = nb_push(c8, 141);
    let c10: String = nb_i32le_signed(c9, idx_disp);
    let c11: String = nb_push(c10, 72);
    let c12: String = nb_push(c11, 139);
    let c13: String = nb_push(c12, 4);
    let c14: String = nb_push(c13, 200);
    nb_store_rax(c14, dst_disp)
}

// The argc/argv CAPTURE — the literal first instructions of an argv-using entry,
// emitted BEFORE the STACK_TOP rsp switch (which abandons the OS stack). At _start
// rsp -> [argc][argv0..]. Stash argc at ARENA_ADDR+8 and &argv[0] at ARENA_ADDR+16,
// then set the bump cursor (ARENA_ADDR+0) to 16 so those 16 reserved header bytes
// are never allocated. 34 bytes:
//   mov rax,[rsp]        = 48 8B 04 24
//   movabs rcx,ARENA_ADDR= 48 B9 <imm64>
//   mov [rcx+8],rax      = 48 89 41 08
//   lea rax,[rsp+8]      = 48 8D 44 24 08
//   mov [rcx+16],rax     = 48 89 41 10
//   mov qword [rcx],16   = 48 C7 01 10 00 00 00
pub fn nb_emit_argv_capture(code: String) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, 4);
    let c4: String = nb_push(c3, 36);
    let c5: String = nb_push(c4, 72);
    let c6: String = nb_push(c5, 185);
    let c7: String = nb_i64le(c6, nb_arena_addr());
    let c8: String = nb_push(c7, 72);
    let c9: String = nb_push(c8, 137);
    let c10: String = nb_push(c9, 65);
    let c11: String = nb_push(c10, 8);
    let c12: String = nb_push(c11, 72);
    let c13: String = nb_push(c12, 141);
    let c14: String = nb_push(c13, 68);
    let c15: String = nb_push(c14, 36);
    let c16: String = nb_push(c15, 8);
    let c17: String = nb_push(c16, 72);
    let c18: String = nb_push(c17, 137);
    let c19: String = nb_push(c18, 65);
    let c20: String = nb_push(c19, 16);
    let c21: String = nb_push(c20, 72);
    let c22: String = nb_push(c21, 199);
    let c23: String = nb_push(c22, 1);
    let c24: String = nb_push(c23, 16);
    let c25: String = nb_push(c24, 0);
    let c26: String = nb_push(c25, 0);
    nb_push(c26, 0)
}

// Statement-form (Rule-4-safe: no struct-valued if-expr with a call branch) gate:
// prepend the argc/argv capture iff this fn is the entry AND the module uses argv.
pub fn nb_entry_prefix(code: String, is_entry: i64, uses_argv: i64) -> String {
    if is_entry == 1 {
        if uses_argv == 1 {
            return nb_emit_argv_capture(code);
        }
    }
    code
}

// 1 iff buf[lo..hi) spells exactly "__mind_argc" or "__mind_argv" (both 11 bytes).
pub fn nb_is_argv_name(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo != 11 {
        return 0;
    }
    if load_byte(buf, lo + 0) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 1) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 2) != 109 {
        return 0;
    }
    if load_byte(buf, lo + 3) != 105 {
        return 0;
    }
    if load_byte(buf, lo + 4) != 110 {
        return 0;
    }
    if load_byte(buf, lo + 5) != 100 {
        return 0;
    }
    if load_byte(buf, lo + 6) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 7) != 97 {
        return 0;
    }
    if load_byte(buf, lo + 8) != 114 {
        return 0;
    }
    if load_byte(buf, lo + 9) != 103 {
        return 0;
    }
    if load_byte(buf, lo + 10) == 99 {
        return 1;
    }
    if load_byte(buf, lo + 10) == 118 {
        return 1;
    }
    0
}

// (The entry argc/argv-capture gate now scans only the pruned/reachable fn set —
// see nb_fns_use_argv near nb_count_all_calls — so a seeded-but-unreachable std.cli
// mention of the intrinsic never false-triggers the capture. nb_is_argv_name above
// is shared by that reachability walk.)

// nb_intrinsic_id(buf, lo, hi): name-match the callee span [lo,hi) in buf against
// the inlined __mind_* intrinsic set (mirror the Rust Instr::Intrinsic dispatch at
// src/native/mod.rs:784-918). Returns a small code, or -1 for a regular call:
//   1 __mind_alloc   2 __mind_store_i64  3 __mind_load_i64  4 __mind_store_i8
//   5 __mind_load_i8 6 __mind_realloc    7 __mind_free      8 __mind_write
//   9 __mind_read   10 __mind_argc      11 __mind_argv (RI-C: OS argc/argv)
//  12 __mind_open (RI-C #228: open(2) O_RDONLY by path -> fd)
// Length-first then byte-by-byte (like is_struct_kw) so it stays in the self-host
// mic@3 subset and lowers byte-identically. All names share the "__mind_" prefix
// (95 95 109 105 110 100 95); only the suffix is matched per length.
pub fn nb_intrinsic_id(buf: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = hi - lo;
    // Common prefix "__mind_" guard (7 bytes). If absent, not an intrinsic.
    if n < 11 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 0) != 95 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 1) != 95 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 2) != 109 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 3) != 105 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 4) != 110 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 5) != 100 {
        return 0 - 1;
    }
    if load_byte(buf, lo + 6) != 95 {
        return 0 - 1;
    }
    // __mind_alloc (12): a l l o c
    if n == 12 {
        if load_byte(buf, lo + 7) == 97 {
            if load_byte(buf, lo + 8) == 108 {
                if load_byte(buf, lo + 9) == 108 {
                    if load_byte(buf, lo + 10) == 111 {
                        if load_byte(buf, lo + 11) == 99 {
                            return 1;
                        }
                    }
                }
            }
        }
        // __mind_write (12): w r i t e
        if load_byte(buf, lo + 7) == 119 {
            if load_byte(buf, lo + 8) == 114 {
                if load_byte(buf, lo + 9) == 105 {
                    if load_byte(buf, lo + 10) == 116 {
                        if load_byte(buf, lo + 11) == 101 {
                            return 8;
                        }
                    }
                }
            }
        }
        return 0 - 1;
    }
    // __mind_free (11): f r e e
    if n == 11 {
        if load_byte(buf, lo + 7) == 102 {
            if load_byte(buf, lo + 8) == 114 {
                if load_byte(buf, lo + 9) == 101 {
                    if load_byte(buf, lo + 10) == 101 {
                        return 7;
                    }
                }
            }
        }
        // __mind_read (11): r e a d
        if load_byte(buf, lo + 7) == 114 {
            if load_byte(buf, lo + 8) == 101 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 100 {
                        return 9;
                    }
                }
            }
        }
        // __mind_argc (10) / __mind_argv (11): a r g {c,v} (RI-C)
        if load_byte(buf, lo + 7) == 97 {
            if load_byte(buf, lo + 8) == 114 {
                if load_byte(buf, lo + 9) == 103 {
                    if load_byte(buf, lo + 10) == 99 {
                        return 10;
                    }
                    if load_byte(buf, lo + 10) == 118 {
                        return 11;
                    }
                }
            }
        }
        // __mind_open (12): o p e n (RI-C task #228)
        if load_byte(buf, lo + 7) == 111 {
            if load_byte(buf, lo + 8) == 112 {
                if load_byte(buf, lo + 9) == 101 {
                    if load_byte(buf, lo + 10) == 110 {
                        return 12;
                    }
                }
            }
        }
        return 0 - 1;
    }
    // Two 14-byte names: __mind_realloc and __mind_load_i8 (both 7+7). Resolve by
    // suffix.
    if n == 14 {
        // __mind_realloc: r e a l l o c
        if load_byte(buf, lo + 7) == 114 {
            if load_byte(buf, lo + 8) == 101 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 108 {
                        if load_byte(buf, lo + 11) == 108 {
                            if load_byte(buf, lo + 12) == 111 {
                                if load_byte(buf, lo + 13) == 99 {
                                    return 6;
                                }
                            }
                        }
                    }
                }
            }
        }
        // __mind_load_i8: l o a d _ i 8
        if load_byte(buf, lo + 7) == 108 {
            if load_byte(buf, lo + 8) == 111 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 100 {
                        if load_byte(buf, lo + 11) == 95 {
                            if load_byte(buf, lo + 12) == 105 {
                                if load_byte(buf, lo + 13) == 56 {
                                    return 5;
                                }
                            }
                        }
                    }
                }
            }
        }
        // __mind_wrap_i8 (14): w r a p _ i 8 (narrow-int C2 wrap arithmetic)
        if load_byte(buf, lo + 7) == 119 {
            if load_byte(buf, lo + 8) == 114 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 112 {
                        if load_byte(buf, lo + 11) == 95 {
                            if load_byte(buf, lo + 12) == 105 {
                                if load_byte(buf, lo + 13) == 56 {
                                    return 17;
                                }
                            }
                        }
                    }
                }
            }
        }
        return 0 - 1;
    }
    // __mind_store_i64 (16): s t o r e _ i 6 4
    if n == 16 {
        if load_byte(buf, lo + 7) == 115 {
            if load_byte(buf, lo + 8) == 116 {
                if load_byte(buf, lo + 9) == 111 {
                    if load_byte(buf, lo + 10) == 114 {
                        if load_byte(buf, lo + 11) == 101 {
                            if load_byte(buf, lo + 12) == 95 {
                                if load_byte(buf, lo + 13) == 105 {
                                    if load_byte(buf, lo + 14) == 54 {
                                        if load_byte(buf, lo + 15) == 52 {
                                            return 2;
                                        }
                                    }
                                    // __mind_store_i16 (16): ...i 1 6 (narrow-int C2)
                                    if load_byte(buf, lo + 14) == 49 {
                                        if load_byte(buf, lo + 15) == 54 {
                                            return 13;
                                        }
                                    }
                                    // __mind_store_i32 (16): ...i 3 2 (narrow-int C2)
                                    if load_byte(buf, lo + 14) == 51 {
                                        if load_byte(buf, lo + 15) == 50 {
                                            return 15;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return 0 - 1;
    }
    // __mind_load_i64 (15): l o a d _ i 6 4
    if n == 15 {
        if load_byte(buf, lo + 7) == 108 {
            if load_byte(buf, lo + 8) == 111 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 100 {
                        if load_byte(buf, lo + 11) == 95 {
                            if load_byte(buf, lo + 12) == 105 {
                                if load_byte(buf, lo + 13) == 54 {
                                    if load_byte(buf, lo + 14) == 52 {
                                        return 3;
                                    }
                                }
                                // __mind_load_i16 (15): ...i 1 6 (narrow-int C2)
                                if load_byte(buf, lo + 13) == 49 {
                                    if load_byte(buf, lo + 14) == 54 {
                                        return 14;
                                    }
                                }
                                // __mind_load_i32 (15): ...i 3 2 (narrow-int C2)
                                if load_byte(buf, lo + 13) == 51 {
                                    if load_byte(buf, lo + 14) == 50 {
                                        return 16;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        // __mind_store_i8 (15): s t o r e _ i 8
        if load_byte(buf, lo + 7) == 115 {
            if load_byte(buf, lo + 8) == 116 {
                if load_byte(buf, lo + 9) == 111 {
                    if load_byte(buf, lo + 10) == 114 {
                        if load_byte(buf, lo + 11) == 101 {
                            if load_byte(buf, lo + 12) == 95 {
                                if load_byte(buf, lo + 13) == 105 {
                                    if load_byte(buf, lo + 14) == 56 {
                                        return 4;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        // __mind_wrap_i16 (18) / __mind_wrap_i32 (19): w r a p _ i {1 6 | 3 2}
        // (narrow-int C2 wrap arithmetic — reg-to-reg movsx wrap-to-width)
        if load_byte(buf, lo + 7) == 119 {
            if load_byte(buf, lo + 8) == 114 {
                if load_byte(buf, lo + 9) == 97 {
                    if load_byte(buf, lo + 10) == 112 {
                        if load_byte(buf, lo + 11) == 95 {
                            if load_byte(buf, lo + 12) == 105 {
                                if load_byte(buf, lo + 13) == 49 {
                                    if load_byte(buf, lo + 14) == 54 {
                                        return 18;
                                    }
                                }
                                if load_byte(buf, lo + 13) == 51 {
                                    if load_byte(buf, lo + 14) == 50 {
                                        return 19;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return 0 - 1;
    }
    0 - 1
}

// nb_emit_intrinsic(code, kind, ids, args_len, dst_id): emit the inline body for a
// matched __mind_* intrinsic (mirror src/native/mod.rs:784-918). `ids[i]` holds
// arg i's value slot; dst_id is the call's result slot. Value-returning intrinsics
// store rax -> dst slot; the two store intrinsics leave dst untouched (the front-
// end never reads a store's dst). A pure function of the IR.
pub fn nb_emit_intrinsic(code: String, kind: i64, ids: i64, dst_id: i64) -> String {
    if kind == 1 {
        // __mind_alloc(bytes) -> addr
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_emit_alloc(code, nb_slot_disp(a0));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 2 {
        // __mind_store_i64(addr, val) — no dst store
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        return nb_emit_store_i64(code, nb_slot_disp(a0), nb_slot_disp(a1));
    }
    if kind == 3 {
        // __mind_load_i64(addr) -> val
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_emit_load_i64(code, nb_slot_disp(a0));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 4 {
        // __mind_store_i8(addr, val) — no dst store
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        return nb_emit_store_i8(code, nb_slot_disp(a0), nb_slot_disp(a1));
    }
    if kind == 5 {
        // __mind_load_i8(addr) -> val
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_emit_load_i8(code, nb_slot_disp(a0));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 6 {
        // __mind_realloc(addr, new_bytes) -> new_addr
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        let c1: String = nb_emit_realloc(code, nb_slot_disp(a0), nb_slot_disp(a1));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 7 {
        // __mind_free(ptr) -> 0
        let c1: String = nb_emit_free_xor(code);
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 8 {
        // __mind_write(fd, buf, count, offset) -> i64 (offset unused)
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        let a2: i64 = __mind_load_i64(ids + 2 * 8);
        let c1: String = nb_emit_write(code, nb_slot_disp(a0), nb_slot_disp(a1), nb_slot_disp(a2));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 10 {
        // __mind_argc() -> argc (RI-C; 0 args, reads reserved arena slot)
        return nb_emit_argc(code, nb_slot_disp(dst_id));
    }
    if kind == 11 {
        // __mind_argv(i) -> raw i64 pointer to argv[i] (RI-C)
        let av0: i64 = __mind_load_i64(ids + 0 * 8);
        return nb_emit_argv(code, nb_slot_disp(av0), nb_slot_disp(dst_id));
    }
    if kind == 12 {
        // __mind_open(path) -> fd (RI-C task #228; O_RDONLY, path = NUL-term C string)
        let op0: i64 = __mind_load_i64(ids + 0 * 8);
        let coo: String = nb_emit_open(code, nb_slot_disp(op0));
        return nb_store_rax(coo, nb_slot_disp(dst_id));
    }
    if kind == 13 {
        // __mind_store_i16(addr, val) — truncating word store, no dst store (C2)
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        return nb_emit_store_i16(code, nb_slot_disp(a0), nb_slot_disp(a1));
    }
    if kind == 14 {
        // __mind_load_i16(addr) -> val (zero-extend word to i64, C2)
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_emit_load_i16_zx(code, nb_slot_disp(a0));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 15 {
        // __mind_store_i32(addr, val) — truncating dword store, no dst store (C2)
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let a1: i64 = __mind_load_i64(ids + 1 * 8);
        return nb_emit_store_i32(code, nb_slot_disp(a0), nb_slot_disp(a1));
    }
    if kind == 16 {
        // __mind_load_i32(addr) -> val (zero-extend dword to i64, C2)
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_emit_load_i32_zx(code, nb_slot_disp(a0));
        return nb_store_rax(c1, nb_slot_disp(dst_id));
    }
    if kind == 17 {
        // __mind_wrap_i8(x) -> (x as i8) as i64 — narrow-int C2 two's-complement
        // wrap-to-width. Load the arg value into rax, movsx rax,al (48 0F BE C0)
        // masks the high 56 bits and re-signs bit 7, then store the wrapped result.
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_load_rax(code, nb_slot_disp(a0));
        let c2: String = nb_movsx_rax_al(c1);
        return nb_store_rax(c2, nb_slot_disp(dst_id));
    }
    if kind == 18 {
        // __mind_wrap_i16(x) -> (x as i16) as i64 — narrow-int C2 wrap-to-width.
        // Load arg into rax, movsx rax,ax (48 0F BF C0) masks high 48 bits and
        // re-signs bit 15, then store the wrapped result.
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_load_rax(code, nb_slot_disp(a0));
        let c2: String = nb_movsx_rax_ax(c1);
        return nb_store_rax(c2, nb_slot_disp(dst_id));
    }
    if kind == 19 {
        // __mind_wrap_i32(x) -> (x as i32) as i64 — narrow-int C2 wrap-to-width.
        // Load arg into rax, movsxd rax,eax (48 63 C0) masks high 32 bits and
        // re-signs bit 31, then store the wrapped result.
        let a0: i64 = __mind_load_i64(ids + 0 * 8);
        let c1: String = nb_load_rax(code, nb_slot_disp(a0));
        let c2: String = nb_movsxd_rax_eax(c1);
        return nb_store_rax(c2, nb_slot_disp(dst_id));
    }
    // kind == 9: __mind_read(fd, buf, count, offset) -> i64 (offset unused)
    let a0: i64 = __mind_load_i64(ids + 0 * 8);
    let a1: i64 = __mind_load_i64(ids + 1 * 8);
    let a2: i64 = __mind_load_i64(ids + 2 * 8);
    let c1: String = nb_emit_read(code, nb_slot_disp(a0), nb_slot_disp(a1), nb_slot_disp(a2));
    nb_store_rax(c1, nb_slot_disp(dst_id))
}

// RI-D2 S-E1 — recognise the `__mind_blas_dot_q16_v` BLAS extern by exact name
// (21 bytes: `_ _ m i n d _ b l a s _ d o t _ q 1 6 _ v`). The native analogue of
// MLIR Track-B's inline dispatch: this extern is NOT a linked C kernel (that would
// re-introduce a C-runtime dependency) — nb_expr INLINES the Q16.16 MAC loop
// (nb_emit_blas_dot_q16 below) so the call lowers to native x86-64 with zero
// MLIR/LLVM and no external symbol. Returns 1 on an exact match, else 0. main.mind
// itself never calls this extern, so the dispatch branch is not self-taken and the
// integer native-ELF fixture oracles stay byte-identical.
pub fn nb_is_blas_dot_q16_v(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo != 21 {
        return 0;
    }
    if load_byte(buf, lo + 0) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 1) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 2) != 109 {
        return 0;
    }
    if load_byte(buf, lo + 3) != 105 {
        return 0;
    }
    if load_byte(buf, lo + 4) != 110 {
        return 0;
    }
    if load_byte(buf, lo + 5) != 100 {
        return 0;
    }
    if load_byte(buf, lo + 6) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 7) != 98 {
        return 0;
    }
    if load_byte(buf, lo + 8) != 108 {
        return 0;
    }
    if load_byte(buf, lo + 9) != 97 {
        return 0;
    }
    if load_byte(buf, lo + 10) != 115 {
        return 0;
    }
    if load_byte(buf, lo + 11) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 12) != 100 {
        return 0;
    }
    if load_byte(buf, lo + 13) != 111 {
        return 0;
    }
    if load_byte(buf, lo + 14) != 116 {
        return 0;
    }
    if load_byte(buf, lo + 15) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 16) != 113 {
        return 0;
    }
    if load_byte(buf, lo + 17) != 49 {
        return 0;
    }
    if load_byte(buf, lo + 18) != 54 {
        return 0;
    }
    if load_byte(buf, lo + 19) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 20) != 118 {
        return 0;
    }
    1
}

// RI-D2 S-E1 — the CALLABLE Q16.16 dot-product, inlined at a `__mind_blas_dot_q16_v`
// call site. This is the CALLABLE variant of nb_q16dot_body: the standalone encoder
// bakes a_addr/b_addr/len as movabs immediates into a fixed 1 MiB frame and returns
// the result as the exit code; here the three operands live in the caller's already-
// lowered SSA arg slots (a_slot/b_slot/len_slot) and the result is stored into the
// call's own result slot (base_id) like any other call return. The REDUCTION is
// byte-identical to nb_q16dot_body: for each i in 0..len, prod = sext32(a[i]) *
// sext32(b[i]) (i64), prod >>= 16 (arithmetic SAR), acc(i64) += prod; the final acc
// is narrowed ONCE to i32 (movsxd) — the Q16 canary's `acc as i32`. Element stride is
// 8 bytes with the value in the low i32 (movsxd-loaded), matching the frozen dot-l2-q16
// canary layout. The delta vs the encoder is ONLY operand source (immediate -> slot)
// and result sink (exit-code -> result-slot); the inner MAC math is the same ops.
//
// Slot layout (SSA ids reserved by nb_count_expr's matching arm; base_id = result):
//   base_id result | +1 const8 | +2 const16 | +3 const1 | +4 i | +5 acc | +6 ptr
//   +7 aval | +8 bval | +9 prod | +10 cmpflag  (11 ids total).
// The loop's je/jmp use a LOCAL jump scaffold patched in place immediately (an intra-
// fn rel32 is position-independent, so the fn-relative patch is exact — mirrors
// nb_patch_jmps at the selftest driver), so nb_expr needs no threaded jmps table.
pub fn nb_emit_blas_dot_q16(code: String, a_slot: i64, b_slot: i64, len_slot: i64, base_id: i64) -> String {
    let c8: i64 = base_id + 1;
    let c16: i64 = base_id + 2;
    let c1v: i64 = base_id + 3;
    let iv: i64 = base_id + 4;
    let accv: i64 = base_id + 5;
    let ptrv: i64 = base_id + 6;
    let avalv: i64 = base_id + 7;
    let bvalv: i64 = base_id + 8;
    let prodv: i64 = base_id + 9;
    let cmpv: i64 = base_id + 10;
    // Constants (element stride 8, Q16 arithmetic shift 16, loop step 1).
    let k1: String = nb_intdot_movimm(code, 8, nb_slot_disp(c8));
    let k2: String = nb_intdot_movimm(k1, 16, nb_slot_disp(c16));
    let k3: String = nb_intdot_movimm(k2, 1, nb_slot_disp(c1v));
    // acc = 0 ; i = 0.
    let k4: String = nb_intdot_movimm(k3, 0, nb_slot_disp(accv));
    let k5: String = nb_intdot_movimm(k4, 0, nb_slot_disp(iv));
    // Local forward/back jump scaffold (je-exit + back-edge = 2 records).
    let jmps: i64 = __mind_alloc(4 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop header: cmpflag = (i < len) ; je exit when 0 ---
    let hdr: i64 = string_len(k5);
    let c1: String = nb_load_rax(k5, nb_slot_disp(iv));
    let c2: String = nb_cmp_rax_mem(c1, nb_setcc_opcode(op_lt()), nb_slot_disp(len_slot));
    let c3: String = nb_store_rax(c2, nb_slot_disp(cmpv));
    let c4: String = nb_emit_cmp_je_zero(c3, nb_slot_disp(cmpv), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    // ptr_a = a + i*8 ; aval = sext32 [ptr_a].
    let a1: String = nb_load_rax(c4, nb_slot_disp(iv));
    let a2: String = nb_arith_rax_mem(a1, op_mul(), nb_slot_disp(c8));
    let a3: String = nb_arith_rax_mem(a2, op_add(), nb_slot_disp(a_slot));
    let a4: String = nb_store_rax(a3, nb_slot_disp(ptrv));
    let a5: String = nb_emit_load_i32_sx(a4, nb_slot_disp(ptrv));
    let a6: String = nb_store_rax(a5, nb_slot_disp(avalv));
    // ptr_b = b + i*8 ; bval = sext32 [ptr_b].
    let b1: String = nb_load_rax(a6, nb_slot_disp(iv));
    let b2: String = nb_arith_rax_mem(b1, op_mul(), nb_slot_disp(c8));
    let b3: String = nb_arith_rax_mem(b2, op_add(), nb_slot_disp(b_slot));
    let b4: String = nb_store_rax(b3, nb_slot_disp(ptrv));
    let b5: String = nb_emit_load_i32_sx(b4, nb_slot_disp(ptrv));
    let b6: String = nb_store_rax(b5, nb_slot_disp(bvalv));
    // prod = aval * bval ; prod = sar(prod, 16).
    let p1: String = nb_load_rax(b6, nb_slot_disp(avalv));
    let p2: String = nb_arith_rax_mem(p1, op_mul(), nb_slot_disp(bvalv));
    let p3: String = nb_arith_rax_mem(p2, op_shr(), nb_slot_disp(c16));
    let p4: String = nb_store_rax(p3, nb_slot_disp(prodv));
    // acc += prod.
    let d1: String = nb_load_rax(p4, nb_slot_disp(accv));
    let d2: String = nb_arith_rax_mem(d1, op_add(), nb_slot_disp(prodv));
    let d3: String = nb_store_rax(d2, nb_slot_disp(accv));
    // i += 1.
    let e1: String = nb_load_rax(d3, nb_slot_disp(iv));
    let e2: String = nb_arith_rax_mem(e1, op_add(), nb_slot_disp(c1v));
    let e3: String = nb_store_rax(e2, nb_slot_disp(iv));
    // back-edge jmp -> header.
    let jb: String = nb_emit_jmp(e3, jmps, jcell);
    let jmp_which: i64 = __mind_load_i64(jcell) - 1;
    let _sb: i64 = nb_jmp_set_target(jmps, jcell, jmp_which, hdr);
    // exit target = first byte after the loop.
    let exit_off: i64 = string_len(jb);
    let _se: i64 = nb_jmp_set_target(jmps, jcell, je_which, exit_off);
    // result = (acc as i32) sign-extended -> the call's result slot.
    let r1: String = nb_load_rax(jb, nb_slot_disp(accv));
    let r2: String = nb_movsxd_rax_eax(r1);
    let r3: String = nb_store_rax(r2, nb_slot_disp(base_id));
    // Patch the two local jumps in place (fn-relative rel32).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(r3), jmps, njmps, 0);
    r3
}

// RI-D2 S-E2 — recognise the `__mind_blas_dot_i16_v` BLAS extern by exact name
// (21 bytes: `_ _ m i n d _ b l a s _ d o t _ i 1 6 _ v`). Identical byte pattern
// to nb_is_blas_dot_q16_v except lo+16 is `i` (105) not `q` (113). The int16 sibling
// of S-E1's Q16 dispatch: this extern is NOT a linked C kernel — nb_expr INLINES the
// int16 MAC loop (nb_emit_blas_dot_i16 below) so the call lowers to native x86-64 with
// zero MLIR/LLVM and no external symbol. Returns 1 on an exact match, else 0. main.mind
// never calls this extern, so the branch is not self-taken and the integer native-ELF
// fixture oracles stay byte-identical.
pub fn nb_is_blas_dot_i16_v(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo != 21 {
        return 0;
    }
    if load_byte(buf, lo + 0) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 1) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 2) != 109 {
        return 0;
    }
    if load_byte(buf, lo + 3) != 105 {
        return 0;
    }
    if load_byte(buf, lo + 4) != 110 {
        return 0;
    }
    if load_byte(buf, lo + 5) != 100 {
        return 0;
    }
    if load_byte(buf, lo + 6) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 7) != 98 {
        return 0;
    }
    if load_byte(buf, lo + 8) != 108 {
        return 0;
    }
    if load_byte(buf, lo + 9) != 97 {
        return 0;
    }
    if load_byte(buf, lo + 10) != 115 {
        return 0;
    }
    if load_byte(buf, lo + 11) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 12) != 100 {
        return 0;
    }
    if load_byte(buf, lo + 13) != 111 {
        return 0;
    }
    if load_byte(buf, lo + 14) != 116 {
        return 0;
    }
    if load_byte(buf, lo + 15) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 16) != 105 {
        return 0;
    }
    if load_byte(buf, lo + 17) != 49 {
        return 0;
    }
    if load_byte(buf, lo + 18) != 54 {
        return 0;
    }
    if load_byte(buf, lo + 19) != 95 {
        return 0;
    }
    if load_byte(buf, lo + 20) != 118 {
        return 0;
    }
    1
}

// RI-D2 S-E2 — the CALLABLE int16 dot-product, inlined at a `__mind_blas_dot_i16_v`
// call site. The int16 sibling of nb_emit_blas_dot_q16 (S-E1): same immediate->slot
// operand adaptation and exit-code->result-slot ABI, same nb_i16dot_body reduction
// model. For each i in 0..len: aval = movsx WORD sext16(a[i]), bval = movsx WORD
// sext16(b[i]), prod = aval * bval (i64, NO Q16 rescale — the DELTA vs S-E1 is exactly
// (1) movsx WORD loads via nb_emit_load_i16_sx not movsxd DWORD, and (2) no per-product
// `>> 16` SAR), acc(i64) += prod; the final acc is narrowed ONCE to i32 (movsxd) — the
// dot-i16-4096 canary's `acc as i32` (ref_dot_i16_scalar). Element stride is 8 bytes
// with the value in the low i16 (movsx-word loaded), matching the frozen dot-i16 canary
// layout. Because there is no Q16 shift constant this reserves ONE fewer scratch slot
// than S-E1 (10 total, not 11) — nb_count_expr's matching arm reserves the same 10.
//
// Slot layout (SSA ids reserved by nb_count_expr's matching arm; base_id = result):
//   base_id result | +1 const8 | +2 const1 | +3 i | +4 acc | +5 ptr
//   +6 aval | +7 bval | +8 prod | +9 cmpflag  (10 ids total).
// The loop's je/jmp use a LOCAL jump scaffold patched in place immediately (an intra-
// fn rel32 is position-independent, so the fn-relative patch is exact — mirrors S-E1),
// so nb_expr needs no threaded jmps table.
pub fn nb_emit_blas_dot_i16(code: String, a_slot: i64, b_slot: i64, len_slot: i64, base_id: i64) -> String {
    let c8: i64 = base_id + 1;
    let c1v: i64 = base_id + 2;
    let iv: i64 = base_id + 3;
    let accv: i64 = base_id + 4;
    let ptrv: i64 = base_id + 5;
    let avalv: i64 = base_id + 6;
    let bvalv: i64 = base_id + 7;
    let prodv: i64 = base_id + 8;
    let cmpv: i64 = base_id + 9;
    // Constants (element stride 8, loop step 1). No Q16 rescale constant — the int16
    // reduction is a straight i64 MAC (no per-product shift).
    let k1: String = nb_intdot_movimm(code, 8, nb_slot_disp(c8));
    let k2: String = nb_intdot_movimm(k1, 1, nb_slot_disp(c1v));
    // acc = 0 ; i = 0.
    let k3: String = nb_intdot_movimm(k2, 0, nb_slot_disp(accv));
    let k4: String = nb_intdot_movimm(k3, 0, nb_slot_disp(iv));
    // Local forward/back jump scaffold (je-exit + back-edge = 2 records).
    let jmps: i64 = __mind_alloc(4 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);
    // --- loop header: cmpflag = (i < len) ; je exit when 0 ---
    let hdr: i64 = string_len(k4);
    let c1: String = nb_load_rax(k4, nb_slot_disp(iv));
    let c2: String = nb_cmp_rax_mem(c1, nb_setcc_opcode(op_lt()), nb_slot_disp(len_slot));
    let c3: String = nb_store_rax(c2, nb_slot_disp(cmpv));
    let c4: String = nb_emit_cmp_je_zero(c3, nb_slot_disp(cmpv), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    // ptr_a = a + i*8 ; aval = movsx word [ptr_a].
    let a1: String = nb_load_rax(c4, nb_slot_disp(iv));
    let a2: String = nb_arith_rax_mem(a1, op_mul(), nb_slot_disp(c8));
    let a3: String = nb_arith_rax_mem(a2, op_add(), nb_slot_disp(a_slot));
    let a4: String = nb_store_rax(a3, nb_slot_disp(ptrv));
    let a5: String = nb_emit_load_i16_sx(a4, nb_slot_disp(ptrv));
    let a6: String = nb_store_rax(a5, nb_slot_disp(avalv));
    // ptr_b = b + i*8 ; bval = movsx word [ptr_b].
    let b1: String = nb_load_rax(a6, nb_slot_disp(iv));
    let b2: String = nb_arith_rax_mem(b1, op_mul(), nb_slot_disp(c8));
    let b3: String = nb_arith_rax_mem(b2, op_add(), nb_slot_disp(b_slot));
    let b4: String = nb_store_rax(b3, nb_slot_disp(ptrv));
    let b5: String = nb_emit_load_i16_sx(b4, nb_slot_disp(ptrv));
    let b6: String = nb_store_rax(b5, nb_slot_disp(bvalv));
    // prod = aval * bval  (i64, NO Q16 shift).
    let p1: String = nb_load_rax(b6, nb_slot_disp(avalv));
    let p2: String = nb_arith_rax_mem(p1, op_mul(), nb_slot_disp(bvalv));
    let p3: String = nb_store_rax(p2, nb_slot_disp(prodv));
    // acc += prod.
    let d1: String = nb_load_rax(p3, nb_slot_disp(accv));
    let d2: String = nb_arith_rax_mem(d1, op_add(), nb_slot_disp(prodv));
    let d3: String = nb_store_rax(d2, nb_slot_disp(accv));
    // i += 1.
    let e1: String = nb_load_rax(d3, nb_slot_disp(iv));
    let e2: String = nb_arith_rax_mem(e1, op_add(), nb_slot_disp(c1v));
    let e3: String = nb_store_rax(e2, nb_slot_disp(iv));
    // back-edge jmp -> header.
    let jb: String = nb_emit_jmp(e3, jmps, jcell);
    let jmp_which: i64 = __mind_load_i64(jcell) - 1;
    let _sb: i64 = nb_jmp_set_target(jmps, jcell, jmp_which, hdr);
    // exit target = first byte after the loop.
    let exit_off: i64 = string_len(jb);
    let _se: i64 = nb_jmp_set_target(jmps, jcell, je_which, exit_off);
    // result = (acc as i32) sign-extended -> the call's result slot.
    let r1: String = nb_load_rax(jb, nb_slot_disp(accv));
    let r2: String = nb_movsxd_rax_eax(r1);
    let r3: String = nb_store_rax(r2, nb_slot_disp(base_id));
    // Patch the two local jumps in place (fn-relative rel32).
    let njmps: i64 = __mind_load_i64(jcell);
    let _px: i64 = nb_patch_jmps(string_addr(r3), jmps, njmps, 0);
    r3
}

// System-V integer arg registers (index 0..5): (modrm_reg_field, needs_rex).
//   0 rdi(7,F) 1 rsi(6,F) 2 rdx(2,F) 3 rcx(1,F) 4 r8(0,T) 5 r9(1,T)
pub fn nb_argreg_field(i: i64) -> i64 {
    if i == 0 {
        return 7;
    }
    if i == 1 {
        return 6;
    }
    if i == 2 {
        return 2;
    }
    if i == 3 {
        return 1;
    }
    if i == 4 {
        return 0;
    }
    1
}
pub fn nb_argreg_ext(i: i64) -> i64 {
    if i >= 4 {
        return 1;
    }
    0
}

// store_argreg(i, disp): spill incoming param reg i to its slot.
//   (0x48 | ext<<2) 0x89 (0x80 | (reg&7)<<3 | 0x05) <disp32>
pub fn nb_store_argreg(code: String, i: i64, disp: i64) -> String {
    let reg: i64 = nb_argreg_field(i);
    let ext: i64 = nb_argreg_ext(i);
    let rex: i64 = 72 + ext * 4;
    let modrm: i64 = 128 + (reg & 7) * 8 + 5;
    let c1: String = nb_push(code, rex);
    let c2: String = nb_push(c1, 137);
    let c3: String = nb_push(c2, modrm);
    nb_i32le_signed(c3, disp)
}

// store_sse_argreg(k, disp): spill incoming SSE param reg xmm{k} to its slot via
// movsd. F2 0F 11 (0x80 | (k&7)<<3 | 0x05) <disp32>. ModRM reg=k selects xmm{k};
// k in 0..7 (the 8 SysV SSE arg registers) needs no REX. k==0 is byte-identical to
// nb_fp_movsd_store_xmm0. The GP arg path (nb_store_argreg) is untouched, so the
// all-integer param case (all of main.mind's own source) is byte-for-byte unchanged.
pub fn nb_store_sse_argreg(code: String, k: i64, disp: i64) -> String {
    let modrm: i64 = 128 + (k & 7) * 8 + 5;
    let c1: String = nb_push(code, 242);
    let c2: String = nb_push(c1, 15);
    let c3: String = nb_push(c2, 17);
    let c4: String = nb_push(c3, modrm);
    nb_i32le_signed(c4, disp)
}

// load_argreg(i, disp): load slot into incoming param reg i.
//   (0x48 | ext<<2) 0x8B (0x80 | (reg&7)<<3 | 0x05) <disp32>
pub fn nb_load_argreg(code: String, i: i64, disp: i64) -> String {
    let reg: i64 = nb_argreg_field(i);
    let ext: i64 = nb_argreg_ext(i);
    let rex: i64 = 72 + ext * 4;
    let modrm: i64 = 128 + (reg & 7) * 8 + 5;
    let c1: String = nb_push(code, rex);
    let c2: String = nb_push(c1, 139);
    let c3: String = nb_push(c2, modrm);
    nb_i32le_signed(c3, disp)
}

// emit_return(is_entry): the exit syscall (entry) or the epilogue+ret.
//   entry:  48 89 C7 (mov rdi,rax) ; 48 C7 C0 3C 00 00 00 (mov rax,60) ; 0F 05
//   non:    48 89 EC 5D C3        (mov rsp,rbp ; pop rbp ; ret)
pub fn nb_emit_return(code: String, is_entry: i64) -> String {
    if is_entry == 1 {
        let c1: String = nb_push(code, 72);
        let c2: String = nb_push(c1, 137);
        let c3: String = nb_push(c2, 199);
        let c4: String = nb_push(c3, 72);
        let c5: String = nb_push(c4, 199);
        let c6: String = nb_push(c5, 192);
        let c7: String = nb_push(c6, 60);
        let c8: String = nb_push(c7, 0);
        let c9: String = nb_push(c8, 0);
        let c10: String = nb_push(c9, 0);
        let c11: String = nb_push(c10, 15);
        return nb_push(c11, 5);
    }
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 137);
    let c3: String = nb_push(c2, 236);
    let c4: String = nb_push(c3, 93);
    nb_push(c4, 195)
}

// ---- calls scratch table ----
// One call record = 3 i64 words: (rel32_offset_within_fn, callee_lo, callee_hi).
// The calls buffer is a heap block passed in; nb_calls_push appends at index
// `n` and the caller threads the running count.
pub fn nb_calls_push(calls: i64, n: i64, rel_off: i64, lo: i64, hi: i64) -> i64 {
    __mind_store_i64(calls + (n * 3 + 0) * 8, rel_off);
    __mind_store_i64(calls + (n * 3 + 1) * 8, lo);
    __mind_store_i64(calls + (n * 3 + 2) * 8, hi);
    n + 1
}

// ---- intra-function forward-jump emit + patch (If control flow) ----
// The Rust native `If` arm patches je/jmp rel32s WITHIN the function once their
// targets are known (src/native::patch_rel32 over a Vec<u8>). The pure-MIND code
// buffer is an append-only String, so we instead RECORD each forward jump's
// fn-relative rel32 site into a jumps scratch table, leave a 0 placeholder, and
// patch the assembled fn code in place (string_addr) before it is concatenated.
// An intra-function jump's rel32 is position-independent (site and target move as
// one unit when the linker relocates the fn), so a fn-relative patch is exact.
//
// One jump record = 2 i64 words: (rel32_site_within_fn, target_off_within_fn).
// `jcell` is a 1-i64 count cell. nb_jmps_push appends at index [jcell] and bumps.
pub fn nb_jmps_push(jmps: i64, jcell: i64, site: i64, target: i64) -> i64 {
    let n: i64 = __mind_load_i64(jcell);
    __mind_store_i64(jmps + (n * 2 + 0) * 8, site);
    __mind_store_i64(jmps + (n * 2 + 1) * 8, target);
    __mind_store_i64(jcell, n + 1);
    0
}

// `cmp qword [rbp+disp32], 0 ; je rel32(0 placeholder)` (mirror
// src/native::emit_cmp_je_zero). Records the je's rel32 site (fn-relative) into
// the jumps table with target -1 (back-patched by the If arm once else_at known).
//   cmp = 48 83 BD <disp32> 00 ; je rel32 = 0F 84 <rel32>
pub fn nb_emit_cmp_je_zero(code: String, cond_disp: i64, jmps: i64, jcell: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 131);
    let c3: String = nb_push(c2, 189);
    let c4: String = nb_i32le_signed(c3, cond_disp);
    let c5: String = nb_push(c4, 0);
    let c6: String = nb_push(c5, 15);
    let c7: String = nb_push(c6, 132);
    // The rel32 field begins at the current length; record the site, emit 0.
    let site: i64 = string_len(c7);
    let _j: i64 = nb_jmps_push(jmps, jcell, site, 0 - 1);
    nb_u32(c7, 0)
}

// `jmp rel32(0 placeholder)` (mirror src/native::emit_jmp). Records the jmp's
// rel32 site (fn-relative), target -1 (back-patched once end_at known).
//   jmp = E9 <rel32>
pub fn nb_emit_jmp(code: String, jmps: i64, jcell: i64) -> String {
    let c1: String = nb_push(code, 233);
    let site: i64 = string_len(c1);
    let _j: i64 = nb_jmps_push(jmps, jcell, site, 0 - 1);
    nb_u32(c1, 0)
}

// Back-patch the MOST-RECENTLY-recorded jump's target (the one whose target is
// still the -1 sentinel) to `target`. The If arm records je then (maybe) jmp in
// order; it sets each one's target as soon as it is known, in LIFO order, so the
// last sentinel-targeted record is always the one being resolved.
pub fn nb_jmp_set_target(jmps: i64, jcell: i64, which: i64, target: i64) -> i64 {
    __mind_store_i64(jmps + (which * 2 + 1) * 8, target);
    0
}

// Patch every recorded forward jump into the assembled fn code buffer (in place).
// `code_addr` = string_addr of this fn's code String. For jump c: site/target are
// fn-relative; rel = target - (site + 4). Records whose target is still -1 (a
// diverging then-branch's omitted join jmp is never recorded, so this never fires
// on a sentinel — but guard anyway: skip -1).
pub fn nb_patch_jmps(code_addr: i64, jmps: i64, njmps: i64, c: i64) -> i64 {
    if c >= njmps {
        return 0;
    }
    let site: i64 = __mind_load_i64(jmps + (c * 2 + 0) * 8);
    let target: i64 = __mind_load_i64(jmps + (c * 2 + 1) * 8);
    if target < 0 {
        return nb_patch_jmps(code_addr, jmps, njmps, c + 1);
    }
    let rel: i64 = target - (site + 4);
    let _p: i64 = nb_patch_rel32(code_addr, site, rel);
    nb_patch_jmps(code_addr, jmps, njmps, c + 1)
}

// ---- NbState: threads the code buffer + SSA counter + call count ----
struct NbState {
    code: String,
    next_id: i64,
    last_id: i64,
    ncalls: i64,
}

// ---- native let-env (name span -> frame slot) ----
// A `let X = INIT` binding maps the name X to a frame slot (== its INIT value's
// SSA id, since slot id == SSA id in this model — mirrors emit_mlir_stmt_env's
// env_bind). Threaded as a heap buffer `lets` of (name_lo, name_hi, slot) triples
// (24 bytes each) plus a 1-i64 count cell `lcell`. For the scalar fixtures (add,
// if_ret) the buffer stays empty, so nb_expr's ident resolution is unchanged and
// their ELFs stay byte-identical.
// Each let-env entry is 5 i64 words: (name_lo, name_hi, slot, slit_node, width).
// The 4th word is the struct-LITERAL AST node the name was bound to (0 for a non-
// struct binding), so a later `p.field` read can recover the field-name ->
// declared-index mapping (offset = 8*index) without a separate struct registry.
// The 5th word is the binding's DECLARED int bit-width (C2 driver; 64 default).
// The scalar/value_if fixtures bind no struct, so slit_node stays 0 and the
// extra word never changes their emitted bytes — the 4-word stride is only a
// wider step over an otherwise-identical (lo, hi, slot) prefix.
// C2 declared-width driver: each entry carries a 5th word, the binding's DECLARED
// bit-width (64 for i64/unannotated/non-int — the universal default; 8/16/32 only
// for an explicit i8/i16/i32 annotation, via nb_width_of_ann). The width is a
// heap-table word only — recording 64 emits no machine code, so every all-i64
// module (all of main.mind) lowers byte-identically; the wrap fires only when a
// consumer reads back a narrow width.
pub fn nb_lets_bind(lets: i64, lcell: i64, name_lo: i64, name_hi: i64, slot: i64, slit_node: i64, width: i64) -> i64 {
    let n: i64 = __mind_load_i64(lcell);
    __mind_store_i64(lets + (n * 5 + 0) * 8, name_lo);
    __mind_store_i64(lets + (n * 5 + 1) * 8, name_hi);
    __mind_store_i64(lets + (n * 5 + 2) * 8, slot);
    __mind_store_i64(lets + (n * 5 + 3) * 8, slit_node);
    __mind_store_i64(lets + (n * 5 + 4) * 8, width);
    __mind_store_i64(lcell, n + 1);
    0
}

// Resolve a name span to its bound let-slot, or -1 if unbound. LAST-match wins
// (innermost / latest binding), mirroring env_lookup_rest's last-write-wins.
pub fn nb_lets_lookup(lets: i64, lcell: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(lcell);
    nb_lets_lookup_rest(lets, n, buf, lo, hi, 0, 0 - 1)
}
pub fn nb_lets_lookup_rest(lets: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64, best: i64) -> i64 {
    if i >= n {
        return best;
    }
    let nlo: i64 = __mind_load_i64(lets + (i * 5 + 0) * 8);
    let nhi: i64 = __mind_load_i64(lets + (i * 5 + 1) * 8);
    let new_best: i64 = if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        __mind_load_i64(lets + (i * 5 + 2) * 8)
    } else {
        best
    };
    nb_lets_lookup_rest(lets, n, buf, lo, hi, i + 1, new_best)
}

// Resolve a name span to the struct-LITERAL node it was bound to (or 0). LAST-
// match wins, mirroring nb_lets_lookup. Used by the ast_field read path to map
// the field name to its declared index (and thus its 8*index byte offset).
pub fn nb_lets_lookup_slit(lets: i64, lcell: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(lcell);
    nb_lets_lookup_slit_rest(lets, n, buf, lo, hi, 0, 0)
}
pub fn nb_lets_lookup_slit_rest(lets: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64, best: i64) -> i64 {
    if i >= n {
        return best;
    }
    let nlo: i64 = __mind_load_i64(lets + (i * 5 + 0) * 8);
    let nhi: i64 = __mind_load_i64(lets + (i * 5 + 1) * 8);
    let new_best: i64 = if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        __mind_load_i64(lets + (i * 5 + 3) * 8)
    } else {
        best
    };
    nb_lets_lookup_slit_rest(lets, n, buf, lo, hi, i + 1, new_best)
}

// Resolve a name span to its bound DECLARED width, or 64 if unbound (an unbound
// name — a param, a temp — is full-width by definition). LAST-match wins,
// mirroring nb_lets_lookup. The assign arm reads this so `x = x + 1` on a
// narrow-declared x re-wraps at x's width; every all-i64 lookup returns 64 and
// emits nothing (C2 declared-width driver).
pub fn nb_lets_lookup_width(lets: i64, lcell: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(lcell);
    nb_lets_lookup_width_rest(lets, n, buf, lo, hi, 0, 64)
}
pub fn nb_lets_lookup_width_rest(lets: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64, best: i64) -> i64 {
    if i >= n {
        return best;
    }
    let nlo: i64 = __mind_load_i64(lets + (i * 5 + 0) * 8);
    let nhi: i64 = __mind_load_i64(lets + (i * 5 + 1) * 8);
    let new_best: i64 = if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        __mind_load_i64(lets + (i * 5 + 4) * 8)
    } else {
        best
    };
    nb_lets_lookup_width_rest(lets, n, buf, lo, hi, i + 1, new_best)
}

// Classify a let's TYPE-annotation span as a declared int bit-width: "i8" -> 8,
// "i16" -> 16, "i32" -> 32; anything else — i64, f64/f32, bool, String, a struct
// name, or no annotation at all (type_leaf == 0) — is 64, the full-width default.
// Only these three narrow spellings ever trigger the auto-wrap; main.mind's own
// source declares no narrow-int lets (verified: zero i8/i16/i32 let annotations),
// so during self-compile this always returns 64 and the emission is byte-identical.
// bytes: i=105, 8=56, 1=49, 6=54, 3=51, 2=50.
pub fn nb_width_of_ann(buf: i64, type_leaf: i64) -> i64 {
    if type_leaf == 0 {
        return 64;
    }
    let lo: i64 = ast_span_lo(type_leaf);
    let hi: i64 = ast_span_hi(type_leaf);
    let i8_buf: i64 = make_byte_buf_3(105, 56, 0);
    if bytes_eq(buf, lo, hi, i8_buf, 0, 2) == 1 {
        return 8;
    }
    let i16_buf: i64 = make_byte_buf_3(105, 49, 54);
    if bytes_eq(buf, lo, hi, i16_buf, 0, 3) == 1 {
        return 16;
    }
    let i32_buf: i64 = make_byte_buf_3(105, 51, 50);
    if bytes_eq(buf, lo, hi, i32_buf, 0, 3) == 1 {
        return 32;
    }
    64
}

// Emit the reg-to-reg wrap-to-width for rax at declared width w: movsx rax,al (8),
// movsx rax,ax (16), movsxd rax,eax (32). Early-return statement form (the
// struct-valued if-expr mis-lower trap — Rule: never a value-if over String calls).
// Callers gate on w < 64, so the 32 fall-through is only ever reached for w == 32.
pub fn nb_wrap_rax_w(code: String, w: i64) -> String {
    if w == 8 {
        return nb_movsx_rax_al(code);
    }
    if w == 16 {
        return nb_movsx_rax_ax(code);
    }
    nb_movsxd_rax_eax(code)
}

// C2 param/return width driver: wrap rax at the fn's DECLARED return width just
// before the epilogue load's ret. FAIL-SAFE gating: only an EXACT narrow spelling
// (8/16/32) wraps — 64, or any other value (e.g. an uninitialized side-channel
// word on a hand-rolled driver path), is full-width and emits NOTHING. That
// no-emit default is what keeps every i64/float/unit-returning fn (all of
// main.mind) byte-identical.
pub fn nb_wrap_ret_w(code: String, retw: i64) -> String {
    if retw == 8 {
        return nb_movsx_rax_al(code);
    }
    if retw == 16 {
        return nb_movsx_rax_ax(code);
    }
    if retw == 32 {
        return nb_movsxd_rax_eax(code);
    }
    code
}

// C2 param-width driver: after the SysV spill (nb_emit_params), wrap each
// narrow-declared (i8/i16/i32) param IN PLACE in its home slot i — load rax,
// movsx/movsxd, store back. Slot i is the param's exclusive home at entry
// (register AND stack-passed params are both copied there by nb_emit_params;
// nothing aliases it yet), so the in-place wrap is safe and consumes NO SSA id —
// the frame count is unchanged, so no count-side mirror is needed. A width-64
// param (every param in main.mind's own source: i64/String/struct/float) emits
// NOTHING — the self-compile stays byte-for-byte identical.
pub fn nb_wrap_params_w(code: String, buf: i64, params_addr: i64, n_params: i64, i: i64) -> String {
    if i >= n_params {
        return code;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let w: i64 = nb_width_of_ann(buf, ast_child1(pnode));
    if w < 64 {
        let c1: String = nb_load_rax(code, nb_slot_disp(i));
        let c2: String = nb_wrap_rax_w(c1, w);
        let c3: String = nb_store_rax(c2, nb_slot_disp(i));
        return nb_wrap_params_w(c3, buf, params_addr, n_params, i + 1);
    }
    nb_wrap_params_w(code, buf, params_addr, n_params, i + 1)
}

// The declared index of the field named buf[flo..fhi) among a struct-literal's
// fields (3-i64 triples at fields_addr: name_lo, name_hi, value-node), in SOURCE
// order — which for the supported fixtures equals declaration order, so the
// field's byte offset is 8*index. Returns -1 when the name is not found.
pub fn nb_slit_field_index(slit_node: i64, buf: i64, flo: i64, fhi: i64) -> i64 {
    let fields_addr: i64 = ast_child1(slit_node);
    let nfields: i64 = ast_aux(slit_node);
    nb_slit_field_index_loop(fields_addr, nfields, buf, flo, fhi, 0)
}
pub fn nb_slit_field_index_loop(fields_addr: i64, nfields: i64, buf: i64, flo: i64, fhi: i64, i: i64) -> i64 {
    if i >= nfields {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(fields_addr + (i * 3 + 0) * 8);
    let nhi: i64 = __mind_load_i64(fields_addr + (i * 3 + 1) * 8);
    if span_bytes_equal(buf, flo, fhi, nlo, nhi) == 1 {
        return i;
    }
    nb_slit_field_index_loop(fields_addr, nfields, buf, flo, fhi, i + 1)
}

// ---- scalar expression lowering -> machine code ----
// Mirrors emit_mlir_expr_env's SSA numbering EXACTLY (so slot id == SSA id) but
// emits x86-64 into st.code. `calls` is the scratch call table; `params_addr` /
// `n_params` resolve idents to param slots. Returns the NbState whose last_id is
// the value's slot id.
//   int_lit -> movabs rax, val ; mov [slot], rax           (consumes one id)
//   ident   -> resolves to a param slot, NO instruction
//   paren   -> transparent
//   call    -> lower args, spill to argregs, call rel32, spill result
//   binop   -> lower lhs+rhs, mov rax,[lhs]; OP rax,[rhs]; mov [dst],rax
pub fn nb_expr(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, lets: i64, lcell: i64) -> NbState {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        // Honor the synthetic-int-lit sentinel (child1==1 ⇒ the value lives DIRECTLY
        // in child0, no source decimal to parse) — mirrors flatten_ast's mic@3 int-lit
        // arm. The short-circuit `&&`/`||` desugar emits mk_syn_intlit(0)/mk_syn_intlit(1)
        // for the false/true constants. main.mind's OWN source int-lits are all real
        // (child1==0), so they still parse their span here — byte-identical self-compile.
        let val: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let id: i64 = st.next_id;
        // movabs rax, imm64 = 48 B8 <imm64>
        let c1: String = nb_push(st.code, 72);
        let c2: String = nb_push(c1, 184);
        let c3: String = nb_i64le(c2, val);
        let c4: String = nb_store_rax(c3, nb_slot_disp(id));
        return NbState { code: c4, next_id: id + 1, last_id: id, ncalls: st.ncalls };
    }
    if k == ast_float_lit() {
        // RI-B1 float-scalar path (roadmap C1): a FLOAT literal lowers through the
        // SSE2 scalar-double encoders, NOT the GP-integer const path above. The arm
        // gate `k == ast_float_lit()` IS the dtype classification (== nb_node_dtype's
        // nb_dtype_float branch). Compute the IEEE-754 bits integer-only (main.mind
        // stays float-free — a float op in its own source would break self-host
        // byte-identity), load them into xmm0 (movabs + movq bridge) and spill to the
        // value's [rbp+disp32] stack slot with movsd — mirroring the integer arm's
        // movabs + mov [slot],rax, one register file over. main.mind's OWN source
        // contains NO float literals, so this arm is NEVER taken during self-compile;
        // every integer SSA value classifies INT and the integer native-ELF oracle is
        // byte-identical. (Float-op propagation FLOAT<op>FLOAT -> nb_fp_binop, which
        // needs the per-SSA dtype table threaded through NbState so a slot's dtype is
        // known at the consumer, is the follow-up slice.)
        // Exactness guard (roadmap C1): nb_float_lit_bits is exact ONLY for a dyadic
        // decimal (5^fk | num). A non-dyadic literal (0.1, 3.14, ...) truncates in
        // nb_strip_pow5's integer /5 and would emit SILENT wrong IEEE-754 bits
        // (0.1 -> 0.0). Refuse it loudly — fail-closed -1 last_id, caught by the
        // byte-diff / CPU-oracle gate — instead of a silent miscompile. Full
        // correctly-rounded dec2flt is the deferred L upgrade (nb_float_lit_bits
        // header). main.mind is float-free, so this arm is never taken during
        // self-compile and the integer native-ELF oracle stays byte-identical.
        if nb_float_lit_is_dyadic(buf, ast_span_lo(node), ast_span_hi(node)) == 0 {
            return NbState { code: st.code, next_id: st.next_id, last_id: 0 - 1, ncalls: st.ncalls };
        }
        let bits: i64 = nb_float_lit_bits(buf, ast_span_lo(node), ast_span_hi(node));
        let id: i64 = st.next_id;
        let cx: String = nb_fp_const_xmm(st.code, bits, 0);
        let cs: String = nb_fp_movsd_store_xmm0(cx, nb_slot_disp(id));
        return NbState { code: cs, next_id: id + 1, last_id: id, ncalls: st.ncalls };
    }
    if k == ast_ident() {
        // Resolve the let-env FIRST, then fall back to the param home slot. A param
        // that is REASSIGNED (loop-carried `x = x + 1`, or an if-branch merge) gets a
        // let-env binding at its live post-slot via nb_lets_bind — its home slot is
        // then STALE. Consulting resolve_param first read that stale home slot and
        // silently dropped the mutation (e.g. `fn f(x){ while.. x=x+1 } return x` for
        // f(10) returned 10, not 13 — a wrong value with no fail-closed signal). The
        // let-env holds the current slot for any reassigned OR let-shadowed name, so
        // it must win; a name with NO let-env binding (an unmutated param) falls
        // through to resolve_param unchanged. Byte-identical for main.mind's own
        // self-compile: it never reassigns or shadows a param, so every ident misses
        // the let-env here exactly as before and resolves to the same param slot.
        let lslot: i64 = nb_lets_lookup(lets, lcell, buf, ast_span_lo(node), ast_span_hi(node));
        if lslot >= 0 {
            return NbState { code: st.code, next_id: st.next_id, last_id: lslot, ncalls: st.ncalls };
        }
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            return NbState { code: st.code, next_id: st.next_id, last_id: idx, ncalls: st.ncalls };
        }
        // Out of the supported subset: fail loud by returning -1 last_id; the
        // caller's emit produces a deterministic but wrong slot, which the
        // byte-diff gate will catch.
        return NbState { code: st.code, next_id: st.next_id, last_id: 0 - 1, ncalls: st.ncalls };
    }
    if k == ast_paren() {
        return nb_expr(st, buf, ast_child0(node), params_addr, n_params, calls, lets, lcell);
    }
    if k == ast_struct_lit() {
        // `Name { f0: e0, .. }` for an all-i64 struct (legacy 8-byte-stride path,
        // mirrors eval/lower.rs's StructLit all_i64 arm + the IR the Rust native
        // backend inlines). IR (== oracle disasm): CONST 8 ; CONST n_fields ;
        // MUL(8,n) ; __mind_alloc(size) -> ptr ; then for each SOURCE-order field
        // i: emit value -> val ; addr = (i==0 ? ptr : CONST(8*i)+ADD(ptr,off)) ;
        // __mind_store_i64(addr, val) (its dst id is consumed but never read).
        // The struct value IS the ptr slot.
        let fields_addr: i64 = ast_child1(node);
        let nfields: i64 = ast_aux(node);
        // CONST 8 (element size).
        let sz_id: i64 = st.next_id;
        let a1: String = nb_push(st.code, 72);
        let a2: String = nb_push(a1, 184);
        let a3: String = nb_i64le(a2, 8);
        let a4: String = nb_store_rax(a3, nb_slot_disp(sz_id));
        // CONST n_fields.
        let nf_id: i64 = sz_id + 1;
        let b1: String = nb_push(a4, 72);
        let b2: String = nb_push(b1, 184);
        let b3: String = nb_i64le(b2, nfields);
        let b4: String = nb_store_rax(b3, nb_slot_disp(nf_id));
        // MUL(sz, nf) -> alloc size.
        let mul_id: i64 = nf_id + 1;
        let m1: String = nb_load_rax(b4, nb_slot_disp(sz_id));
        let m2: String = nb_arith_rax_mem(m1, op_mul(), nb_slot_disp(nf_id));
        let m3: String = nb_store_rax(m2, nb_slot_disp(mul_id));
        // __mind_alloc(size) -> ptr (the struct base).
        let ptr_id: i64 = mul_id + 1;
        let al1: String = nb_emit_alloc(m3, nb_slot_disp(mul_id));
        let al2: String = nb_store_rax(al1, nb_slot_disp(ptr_id));
        let s_alloc: NbState = NbState { code: al2, next_id: ptr_id + 1, last_id: ptr_id, ncalls: st.ncalls };
        // Per-field stores, in SOURCE order.
        let s_fields: NbState = nb_struct_fields(s_alloc, buf, fields_addr, nfields, 0, ptr_id, params_addr, n_params, calls, lets, lcell);
        // The struct-lit's VALUE is the base pointer.
        return NbState { code: s_fields.code, next_id: s_fields.next_id, last_id: ptr_id, ncalls: s_fields.ncalls };
    }
    if k == ast_field() {
        // `recv.field` field READ (mirrors eval/lower.rs FieldAccess + the Rust
        // native __mind_load_i64 inline). IR: lower recv -> ptr slot ; addr =
        // (off==0 ? ptr : CONST(off)+ADD(ptr,off)) ; __mind_load_i64(addr) -> dst.
        // The field's byte offset = 8*declared-index, recovered from the struct-
        // literal the receiver name was bound to (no separate struct registry).
        let recv: i64 = ast_child0(node);
        let s_recv: NbState = nb_expr(st, buf, recv, params_addr, n_params, calls, lets, lcell);
        let ptr_id: i64 = s_recv.last_id;
        // Resolve the field byte offset (8*declared-index, or 0 when unsupported)
        // and emit the read through a SINGLE tail-return helper, so this if-arm has
        // exactly one return (a dual-return branch lowers to an extra leading
        // const0 in the self-host subset, breaking the mic@3 flip).
        let off: i64 = nb_field_offset(recv, node, buf, lets, lcell);
        // RI-D2 S-D: an f64/f32 struct field READ returns a FLOAT-tagged value. Classify
        // the field's dtype from the struct binding (nb_field_dtype, value-node based for
        // a struct-literal binding); a FLOAT field loads through the SSE register file
        // (movsd) and tags its result slot FLOAT so it flows into float expressions, while
        // an INT/pointer field takes the UNCHANGED integer load. main.mind's own structs
        // have ZERO float fields, so every field read here classifies INT and emits the
        // byte-identical integer path during self-compile. Early-return statement form (no
        // struct-valued if-expr — the mis-lower trap).
        let fdt: i64 = nb_field_dtype(recv, node, buf, lets, lcell);
        if fdt == nb_dtype_float() {
            return nb_field_read_fp(s_recv.code, s_recv.next_id, ptr_id, off, s_recv.ncalls, __mind_load_i64(lcell + 8));
        }
        return nb_field_read(s_recv.code, s_recv.next_id, ptr_id, off, s_recv.ncalls);
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        // Lower each arg expr (advancing SSA ids), recording each arg's slot id AND
        // its classified dtype (arg_dts, parallel to ids). Both buffers are bounded by
        // the arg count (no full-source alloc) — arg_dts drives the two-pool arg ABI in
        // nb_emit_argregs (RI-D2 S-C2): a FLOAT arg is marshalled in the SSE pool
        // (xmm0..7) while int/ptr args keep the GP pool, mirroring nb_emit_params.
        let ids: i64 = __mind_alloc((args_len + 1) * 8);
        let arg_dts: i64 = __mind_alloc((args_len + 1) * 8);
        let sa: NbState = nb_call_args(st, buf, args_addr, args_len, 0, params_addr, n_params, calls, ids, arg_dts, lets, lcell);
        let id: i64 = sa.next_id;
        // Inlined __mind_* intrinsics (mirror src/native/mod.rs:784-918): name-match
        // the callee and emit the inline syscall/alloc/store/load sequence BEFORE the
        // regular 0xe8 call path. The args are already lowered into `ids` slots above
        // (same as the IR's pre-computed value slots the Rust Intrinsic arm reads).
        // The intrinsic's result slot is `id`; the SSA counter advances by one just
        // like a regular call, so downstream slot ids are unchanged.
        let intr: i64 = nb_intrinsic_id(buf, ast_span_lo(callee), ast_span_hi(callee));
        if intr >= 0 {
            let c_intr: String = nb_emit_intrinsic(sa.code, intr, ids, id);
            return NbState { code: c_intr, next_id: id + 1, last_id: id, ncalls: sa.ncalls };
        }
        // RI-D2 S-E1: the `__mind_blas_dot_q16_v` BLAS extern INLINES the Q16.16 MAC
        // loop (the native analogue of MLIR Track-B) instead of emitting a `call` to an
        // unresolved external symbol — no C kernel, no MLIR/LLVM. The three args are the
        // already-lowered slots ids[0..3] (a_addr, b_addr, len); the result is stored
        // into slot `id`. The SSA counter advances by 11 (result + 10 scratch), exactly
        // the count nb_count_expr's matching arm reserved. main.mind never calls this
        // extern, so the branch is not self-taken and the integer oracles are unchanged.
        if nb_is_blas_dot_q16_v(buf, ast_span_lo(callee), ast_span_hi(callee)) == 1 {
            let c_bd: String = nb_emit_blas_dot_q16(sa.code, __mind_load_i64(ids + 0 * 8), __mind_load_i64(ids + 1 * 8), __mind_load_i64(ids + 2 * 8), id);
            return NbState { code: c_bd, next_id: id + 11, last_id: id, ncalls: sa.ncalls };
        }
        // RI-D2 S-E2: the `__mind_blas_dot_i16_v` BLAS extern INLINES the int16 MAC loop
        // (nb_emit_blas_dot_i16), the int16 sibling of the S-E1 Q16 dispatch — no C kernel,
        // no MLIR/LLVM. The three args are the already-lowered slots ids[0..3] (a_addr,
        // b_addr, len); the result is stored into slot `id`. The SSA counter advances by 10
        // (result + 9 scratch — one fewer than Q16, which needs a rescale constant), exactly
        // the count nb_count_expr's matching arm reserved. main.mind never calls this extern,
        // so the branch is not self-taken and the integer oracles are unchanged.
        if nb_is_blas_dot_i16_v(buf, ast_span_lo(callee), ast_span_hi(callee)) == 1 {
            let c_bi: String = nb_emit_blas_dot_i16(sa.code, __mind_load_i64(ids + 0 * 8), __mind_load_i64(ids + 1 * 8), __mind_load_i64(ids + 2 * 8), id);
            return NbState { code: c_bi, next_id: id + 10, last_id: id, ncalls: sa.ncalls };
        }
        // Caller-side System-V sequence for args_len args (mirror src/native/mod.rs
        // Call arm, lines 929-955), in EXACT byte order:
        //   1. `sub rsp,8` pad when an odd count of 7th+ args would misalign rsp;
        //   2. push args[6:] right-to-left (mov rax,[slot] ; push rax);
        //   3. load args[0..6] into the arg registers;
        //   4. `call` opcode + rel32 placeholder (recorded for the linker);
        //   5. `add rsp,cleanup` to pop the stack args + pad;
        //   6. spill the result (rax) into the call's dst slot.
        // For <=6 args this is byte-identical to the prior register-only path
        // (pad/push/cleanup all no-op).
        let c_pad: String = nb_emit_stack_pad(sa.code, arg_dts, args_len);
        let c_stk: String = nb_emit_stackargs(c_pad, ids, arg_dts, args_len, args_len - 1);
        let c_args: String = nb_emit_argregs(c_stk, ids, arg_dts, args_len, 0, 0, 0);
        // call rel32 (placeholder 0; linker-patched). Record the rel32 offset.
        let c_e8: String = nb_push(c_args, 232);
        let rel_off: i64 = string_len(c_e8);
        let c_rel: String = nb_u32(c_e8, 0);
        let nc: i64 = nb_calls_push(calls, sa.ncalls, rel_off, ast_span_lo(callee), ast_span_hi(callee));
        // Pop the stack args + alignment pad before reading the result.
        let c_clean: String = nb_emit_stack_cleanup(c_rel, arg_dts, args_len);
        // RI-D2 S-C1: spill the call result per the callee's DECLARED return dtype (frt,
        // at lcell+16). A FLOAT-returning callee returns in xmm0 (SysV), so spill xmm0 ->
        // dst slot (movsd) and TAG the dst slot FLOAT in the per-fn dtype table (at
        // lcell+8) so a downstream expr / let sees the call result as float. An INT/pointer
        // callee returns in rax — the UNCHANGED nb_store_rax path. Every callee in
        // main.mind's float-free source registers INT (frt all-INT), so every call here
        // takes the rax branch and the emission is byte-for-byte identical.
        let callee_dt: i64 = frt_lookup_dtype(__mind_load_i64(lcell + 16), buf, ast_span_lo(callee), ast_span_hi(callee));
        if callee_dt == nb_dtype_float() {
            let c_fres: String = nb_fp_movsd_store_xmm0(c_clean, nb_slot_disp(id));
            let _tg: i64 = nb_dtype_tag_slot(__mind_load_i64(lcell + 8), id, nb_dtype_float());
            return NbState { code: c_fres, next_id: id + 1, last_id: id, ncalls: nc };
        }
        // Spill the result (rax) into the call's dst slot.
        let c_res: String = nb_store_rax(c_clean, nb_slot_disp(id));
        return NbState { code: c_res, next_id: id + 1, last_id: id, ncalls: nc };
    }
    if k == ast_neg() {
        // FIX #170: unary minus. Pre-fix nb_expr had NO ast_neg arm, so a `-EXPR`
        // node (e.g. a negative float literal `-1.0`) fell through to the binop tail
        // below, which read ast_child1(node) == 0 and recursed into a NULL node ->
        // ast_kind(0) null-deref SIGSEGV in the emitter. Lower the operand, then negate
        // it in its own register file: a FLOAT operand via `0.0 - operand` (xmm0 = 0.0
        // const, subsd xmm0,[operand]) which is exact for all finite values and yields a
        // FLOAT-tagged result; an INT operand via `neg rax`. One SSA id for the negated
        // result (matching nb_count_expr's ast_neg arm: count(operand)+1). main.mind's
        // native-emitted source has no unary-minus node (it would already have crashed
        // here), so this arm never fires during self-compile and the integer native-ELF
        // oracle stays byte-identical.
        let ns1: NbState = nb_expr(st, buf, ast_child0(node), params_addr, n_params, calls, lets, lcell);
        let op_id: i64 = ns1.last_id;
        let nid: i64 = ns1.next_id;
        let ndtbl: i64 = __mind_load_i64(lcell + 8);
        let op_dt: i64 = nb_node_dtype_tbl(ast_child0(node), ndtbl, lets, lcell, buf, params_addr, n_params);
        if op_dt == nb_dtype_float() {
            // FIX #173: a FLOAT LITERAL operand constant-folds to true IEEE-754 negation
            // (sign-bit flip -> ConstF64(-f)), matching the oracle (src/eval/lower.rs folds
            // Neg(float lit) to ConstF64(-f)). The runtime `0.0 - operand` path below is
            // WRONG for -0.0: 0.0 - 0.0 = +0.0 (round-to-nearest), losing the sign bit, so
            // `1.0 / -0.0` gave +inf instead of -inf. Flip bit 63 of the literal's magnitude
            // bits directly. The operand was already lowered into op_id (a dead store, kept
            // so the slot count matches nb_count_expr's ast_neg arm = operand + 1); we
            // materialize the negated const into nid. main.mind is float-free so this never
            // fires during self-compile.
            if ast_kind(ast_child0(node)) == ast_float_lit() {
                let obits: i64 = nb_float_lit_bits(buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node)));
                let sign_mask: i64 = (0 - 9223372036854775807) - 1;
                let neg_bits: i64 = obits ^ sign_mask;
                let cf0: String = nb_fp_const_xmm(ns1.code, neg_bits, 0);
                let cf1: String = nb_fp_movsd_store_xmm0(cf0, nb_slot_disp(nid));
                let _ftg: i64 = nb_dtype_tag_slot(ndtbl, nid, nb_dtype_float());
                return NbState { code: cf1, next_id: nid + 1, last_id: nid, ncalls: ns1.ncalls };
            }
            let nf1: String = nb_fp_const_xmm(ns1.code, 0, 0);
            let nf2: String = nb_fp_binop_xmm0_mem(nf1, 1, nb_slot_disp(op_id));
            let nf3: String = nb_fp_movsd_store_xmm0(nf2, nb_slot_disp(nid));
            let _ntg: i64 = nb_dtype_tag_slot(ndtbl, nid, nb_dtype_float());
            return NbState { code: nf3, next_id: nid + 1, last_id: nid, ncalls: ns1.ncalls };
        }
        // INT: mov rax,[operand] ; neg rax (48 F7 D8) ; mov [dst],rax.
        let ni1: String = nb_load_rax(ns1.code, nb_slot_disp(op_id));
        let ni2: String = nb_push(ni1, 72);
        let ni3: String = nb_push(ni2, 247);
        let ni4: String = nb_push(ni3, 216);
        let ni5: String = nb_store_rax(ni4, nb_slot_disp(nid));
        return NbState { code: ni5, next_id: nid + 1, last_id: nid, ncalls: ns1.ncalls };
    }
    if k == ast_not() {
        // FIX #172: unary logical NOT `!x` desugars to `x == 0` — exactly how the Rust
        // front-end lowers it (src/eval/lower.rs Node::Not) and the flatten_ast/mic@3 arm
        // already does. Pre-fix nb_expr had NO ast_not arm, so `!EXPR` fell through to the
        // binop tail below, which read ast_child1(node) == 0 and recursed into a NULL node
        // -> ast_kind(0) null-deref SIGSEGV. Lower the operand, materialize a const-0, and
        // emit the integer Eq (cmp/setcc-e/movzx -> i64 0/1). The result is INT (a boolean).
        // Slot count: operand ids + 1 (zero) + 1 (eq result) — matches nb_count_expr's arm.
        // main.mind's native-emitted source has no `!` in a natively-lowered body (it would
        // already have crashed here), so this arm never fires during self-compile and the
        // integer native-ELF oracle stays byte-identical.
        let nn1: NbState = nb_expr(st, buf, ast_child0(node), params_addr, n_params, calls, lets, lcell);
        let nn_op: i64 = nn1.last_id;
        let nn_zid: i64 = nn1.next_id;
        let z1: String = nb_push(nn1.code, 72);
        let z2: String = nb_push(z1, 184);
        let z3: String = nb_i64le(z2, 0);
        let z4: String = nb_store_rax(z3, nb_slot_disp(nn_zid));
        let nn_rid: i64 = nn_zid + 1;
        let e1: String = nb_load_rax(z4, nb_slot_disp(nn_op));
        let e2: String = nb_cmp_rax_mem(e1, nb_setcc_opcode(op_eq()), nb_slot_disp(nn_zid));
        let e3: String = nb_store_rax(e2, nb_slot_disp(nn_rid));
        return NbState { code: e3, next_id: nn_rid + 1, last_id: nn_rid, ncalls: nn1.ncalls };
    }
    if k == ast_if() {
        // FIX #173: a value-if used in DEEP EXPRESSION position (a call argument, a binop
        // operand, a nested initializer feeding a further op) now lowers through the real
        // branch/merge path. nb_expr has no jump-table params, so the per-fn jump/loop/
        // struct state is read from the lcell side-channel that nb_lower_fn stashed at
        // lcell+24..+64 (srt/is_entry/jmps/jcell/loops/lpcell), alongside the dtype table
        // (+8) and frt (+16). This is the exact state nb_stmt/nb_lower_let_init already
        // pass to nb_if_value for a value-if at let-init / return / assign / statement
        // position — the only gap was the deeply-nested-expression case, which structurally
        // could not reach nb_if_value.
        //
        // Fail CLOSED to a const-0 slot when no jump table is present (jmps==0 — e.g. the
        // bare-expr fp selftests' 16-byte lcell), preserving the old no-crash behaviour for
        // callers that lower an expression without a per-fn jump table. main.mind's own
        // source never nests a value-if in expression position, so this arm is never taken
        // during self-compile and the integer native-ELF oracle stays byte-identical.
        let jmps: i64 = __mind_load_i64(lcell + 40);
        if jmps == 0 {
            return nb_emit_const0(st);
        }
        let srt: i64 = __mind_load_i64(lcell + 24);
        let is_entry: i64 = __mind_load_i64(lcell + 32);
        let jcell: i64 = __mind_load_i64(lcell + 48);
        let loops: i64 = __mind_load_i64(lcell + 56);
        let lpcell: i64 = __mind_load_i64(lcell + 64);
        // Snapshot the let-env count and restore it after the value-if, dropping any
        // internal merge-phi bindings the merged path would rebind — an if-EXPRESSION
        // threads NONE of its branch bindings into the enclosing env (only the dst slot
        // escapes, via last_id), exactly as nb_stmt's let-init arm restores lcell. The
        // simple (no-merge) path binds nothing, so the restore is a no-op there.
        let pre_if_n: i64 = __mind_load_i64(lcell);
        let sv: NbState = nb_if_value(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
        __mind_store_i64(lcell, pre_if_n);
        return sv;
    }
    if k == ast_cast() {
        // NARROWING cast `EXPR as i8/i16/i32`: lower the operand, load it into rax, and
        // apply the width-matched reg-to-reg movsx (movsx rax,al / movsx rax,ax / movsxd
        // rax,eax) — a real two's-complement wrap-to-width, the exact sequence the
        // __mind_wrap_iN intrinsics emit (nb_emit_intrinsic kinds 17/18/19). One SSA id
        // for the truncated result (matching nb_count_expr's ast_cast arm: operand + 1),
        // so a downstream binop consuming the cast sees a normal integer slot. Result is
        // always INT (nb_node_dtype defaults a cast to INT). Early-return statement form
        // per width (no struct-valued if-expr — the mis-lower trap). main.mind's OWN
        // source produces no cast node (every `as iN` is in a stripped comment), so this
        // arm is never taken during self-compile and the integer native-ELF oracle stays
        // byte-identical.
        let cs1: NbState = nb_expr(st, buf, ast_child0(node), params_addr, n_params, calls, lets, lcell);
        let cop: i64 = cs1.last_id;
        let cid: i64 = cs1.next_id;
        let cw: i64 = ast_aux(node);
        let cl: String = nb_load_rax(cs1.code, nb_slot_disp(cop));
        if cw == 8 {
            let c8: String = nb_movsx_rax_al(cl);
            let c8s: String = nb_store_rax(c8, nb_slot_disp(cid));
            return NbState { code: c8s, next_id: cid + 1, last_id: cid, ncalls: cs1.ncalls };
        }
        if cw == 16 {
            let c16: String = nb_movsx_rax_ax(cl);
            let c16s: String = nb_store_rax(c16, nb_slot_disp(cid));
            return NbState { code: c16s, next_id: cid + 1, last_id: cid, ncalls: cs1.ncalls };
        }
        let c32: String = nb_movsxd_rax_eax(cl);
        let c32s: String = nb_store_rax(c32, nb_slot_disp(cid));
        return NbState { code: c32s, next_id: cid + 1, last_id: cid, ncalls: cs1.ncalls };
    }
    // ast_binop(): lower both operands, then the in-place op.
    let s1: NbState = nb_expr(st, buf, ast_child0(node), params_addr, n_params, calls, lets, lcell);
    let lhs_id: i64 = s1.last_id;
    let s2: NbState = nb_expr(s1, buf, ast_child1(node), params_addr, n_params, calls, lets, lcell);
    let rhs_id: i64 = s2.last_id;
    let id: i64 = s2.next_id;
    let op: i64 = ast_aux(node);
    // RI-B1 FLOAT-op-FLOAT arm: when BOTH operands classify FLOAT (nb_node_dtype,
    // which propagates float through paren + scalar-arith binops) and the operator
    // is scalar arithmetic (+ - * /, nb_fp_opsel >= 0), route through the SSE2 f64
    // encoders instead of the GP-integer path: load lhs slot -> xmm0 (movsd), apply
    // <op>sd xmm0,[rhs slot] (memory-operand binop), spill xmm0 -> dst slot (movsd).
    // The dst is thereby FLOAT-typed (nb_node_dtype classifies this node FLOAT), so a
    // parent binop consuming it routes float too. main.mind's OWN source contains no
    // float literals, so every operand here classifies INT during self-compile, this
    // branch is never taken, and the integer native-ELF emission stays byte-identical.
    // RI-B1 FOLLOW-UP: consult the per-fn dtype table (threaded at lcell+8, see
    // nb_lower_fn) so a FLOAT let-bound operand is classified FLOAT. A null table
    // (lcell+8 == 0 on the bare-expr fp selftests) makes nb_node_dtype_tbl fall back
    // to the pure-AST nb_node_dtype, and main.mind's float-free source keeps every
    // slot INT during self-compile, so the integer path stays byte-identical.
    let dtbl: i64 = __mind_load_i64(lcell + 8);
    let lhs_dt: i64 = nb_node_dtype_tbl(ast_child0(node), dtbl, lets, lcell, buf, params_addr, n_params);
    let rhs_dt: i64 = nb_node_dtype_tbl(ast_child1(node), dtbl, lets, lcell, buf, params_addr, n_params);
    let fsel: i64 = nb_fp_opsel(op);
    if lhs_dt == nb_dtype_float() {
        if rhs_dt == nb_dtype_float() {
            if fsel >= 0 {
                let f1: String = nb_fp_movsd_load_xmm0(s2.code, nb_slot_disp(lhs_id));
                let f2: String = nb_fp_binop_xmm0_mem(f1, fsel, nb_slot_disp(rhs_id));
                let f3: String = nb_fp_movsd_store_xmm0(f2, nb_slot_disp(id));
                // FIX #167: TAG the fp-binop dst slot FLOAT, so a later ident read of this
                // result (e.g. via a `let`/assign rebind, then a call arg) classifies FLOAT
                // and marshals in the SSE pool. dtbl (lcell+8) is loaded above. Inert for
                // main.mind's float-free source (this arm is never taken during self-compile).
                let _tg167: i64 = nb_dtype_tag_slot(dtbl, id, nb_dtype_float());
                return NbState { code: f3, next_id: id + 1, last_id: id, ncalls: s2.ncalls };
            }
            // FIX #168: FLOAT-operand COMPARISON. The SSE guard above only covers scalar
            // arithmetic (nb_fp_opsel >= 0); a relational/equality op over two FLOAT operands
            // fell through to the GP path (nb_load_rax + nb_cmp_rax_mem) — a SIGNED-INTEGER
            // compare of the raw IEEE-754 bits, which is INVERTED for two negatives (IEEE-754
            // is sign-magnitude) and wrong for -0.0/+0.0 and NaN. Route it through ucomisd +
            // an UNSIGNED setcc (comisd sets CF/ZF like an unsigned compare), materializing
            // the same i64 0/1 boolean the rest of the pipeline consumes. Correct for all
            // FINITE operands; deferred: NaN-ordering edge cases (see nb_fp_setcc_opcode).
            // main.mind is float-free, so this arm never fires during self-compile — the
            // integer native-ELF emission stays byte-identical.
            let fcc: i64 = nb_fp_setcc_opcode(op);
            if fcc >= 0 {
                let g1: String = nb_fp_movsd_load_xmm0(s2.code, nb_slot_disp(lhs_id));
                let g2: String = nb_fp_cmp_xmm0_mem(g1, fcc, nb_slot_disp(rhs_id));
                let g3: String = nb_store_rax(g2, nb_slot_disp(id));
                return NbState { code: g3, next_id: id + 1, last_id: id, ncalls: s2.ncalls };
            }
        }
    }
    // mov rax,[lhs] ; OP rax,[rhs] ; mov [dst],rax. A comparison op routes through
    // cmp+setcc+movzx (-> 0/1); Add/Sub/Mul through the in-place arith form.
    let c1: String = nb_load_rax(s2.code, nb_slot_disp(lhs_id));
    let setcc: i64 = nb_setcc_opcode(op);
    let c2: String = if setcc >= 0 {
        nb_cmp_rax_mem(c1, setcc, nb_slot_disp(rhs_id))
    } else {
        nb_arith_rax_mem(c1, op, nb_slot_disp(rhs_id))
    };
    let c3: String = nb_store_rax(c2, nb_slot_disp(id));
    NbState { code: c3, next_id: id + 1, last_id: id, ncalls: s2.ncalls }
}

// Lower each call arg in order, storing each arg's resulting slot id into ids[i] and
// its classified dtype into arg_dts[i]. The dtype is resolved AFTER the arg is lowered
// (nb_expr may have tagged its dst slot FLOAT, e.g. a float-returning call), via
// nb_node_dtype_tbl over the per-fn dtype table at lcell+8. arg_dts drives the SysV
// two-pool arg ABI in nb_emit_argregs (RI-D2 S-C2). No lex, no full-source alloc.
pub fn nb_call_args(st: NbState, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64, calls: i64, ids: i64, arg_dts: i64, lets: i64, lcell: i64) -> NbState {
    if i >= args_len {
        return st;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: NbState = nb_expr(st, buf, arg_node, params_addr, n_params, calls, lets, lcell);
    __mind_store_i64(ids + i * 8, s1.last_id);
    let dtbl: i64 = __mind_load_i64(lcell + 8);
    let adt: i64 = nb_node_dtype_tbl(arg_node, dtbl, lets, lcell, buf, params_addr, n_params);
    __mind_store_i64(arg_dts + i * 8, adt);
    nb_call_args(s1, buf, args_addr, args_len, i + 1, params_addr, n_params, calls, ids, arg_dts, lets, lcell)
}

// The struct-literal node if `init` is one, else 0 — for the let-env's slit slot.
// An if-STATEMENT (not a value-if-let) so it stays in the self-host subset.
pub fn nb_slit_or_zero(init: i64) -> i64 {
    if ast_kind(init) == ast_struct_lit() {
        return init;
    }
    0
}

// The let-env slit-slot descriptor for a `let NAME: TY = INIT`:
//   * INIT is a struct LITERAL -> bind to it directly (offset 8*field-index from
//     the literal's own field order, the Step-1 path).
//   * else, the let's declared type TY names a struct in `srt` -> bind to that
//     struct's synthetic field-offset descriptor (the Step-2 FieldAccess path:
//     `let r: P = mk(...); r.z` reads *(r + 8*idx-of-z)). This covers a struct-
//     typed let whose init is a CALL / method / any non-literal expr — the
//     dominant shape in main.mind (`let r: ParseResult = parse_...(); r.field`).
//   * else 0 (scalar let; field-offset path unchanged).
// `ty_node` = the let's type leaf (ast_child1); 0 when untyped. An if-STATEMENT
// chain (no value-if-let phis) so it stays in the self-host subset.
pub fn nb_let_descriptor(init: i64, ty_node: i64, buf: i64, srt: i64) -> i64 {
    if ast_kind(init) == ast_struct_lit() {
        return init;
    }
    if ty_node == 0 {
        return 0;
    }
    let sk: i64 = srt_find_by_name(srt, buf, ast_span_lo(ty_node), ast_span_hi(ty_node), 0);
    if sk < 0 {
        return 0;
    }
    nb_struct_decl_descriptor(srt, buf, sk)
}

// Emit a field READ at byte offset `off` through the base pointer slot `ptr_id`:
//   off==0 -> __mind_load_i64(ptr) -> dst
//   off>0  -> CONST off ; ADD(ptr,off) -> addr ; __mind_load_i64(addr) -> dst
// A standalone tail-return helper (two returns are fine at fn scope; the hazard
// was a dual-return INSIDE a value-producing if-arm of nb_expr). Returns the
// NbState whose last_id is the loaded value's slot.
pub fn nb_field_read(code: String, next_id: i64, ptr_id: i64, off: i64, ncalls: i64) -> NbState {
    if off == 0 {
        let ld_id: i64 = next_id;
        let l1: String = nb_emit_load_i64(code, nb_slot_disp(ptr_id));
        let l2: String = nb_store_rax(l1, nb_slot_disp(ld_id));
        return NbState { code: l2, next_id: ld_id + 1, last_id: ld_id, ncalls: ncalls };
    }
    let off_id: i64 = next_id;
    let o1: String = nb_push(code, 72);
    let o2: String = nb_push(o1, 184);
    let o3: String = nb_i64le(o2, off);
    let o4: String = nb_store_rax(o3, nb_slot_disp(off_id));
    let add_id: i64 = off_id + 1;
    let d1: String = nb_load_rax(o4, nb_slot_disp(ptr_id));
    let d2: String = nb_arith_rax_mem(d1, op_add(), nb_slot_disp(off_id));
    let d3: String = nb_store_rax(d2, nb_slot_disp(add_id));
    let ld_id: i64 = add_id + 1;
    let e1: String = nb_emit_load_i64(d3, nb_slot_disp(add_id));
    let e2: String = nb_store_rax(e1, nb_slot_disp(ld_id));
    NbState { code: e2, next_id: ld_id + 1, last_id: ld_id, ncalls: ncalls }
}

// Resolve a field access `recv.field`'s byte offset (8 * declared field index),
// or 0 when the shape is unsupported (non-ident receiver, unbound name, or an
// unknown field). Uses if-STATEMENTS with early returns (NOT value-if-let phis,
// which are outside the self-host mic@3 subset) so the pure-MIND compiler lowers
// this byte-identically to the Rust oracle.
pub fn nb_field_offset(recv: i64, field_node: i64, buf: i64, lets: i64, lcell: i64) -> i64 {
    if ast_kind(recv) != ast_ident() {
        return 0;
    }
    let slit: i64 = nb_lets_lookup_slit(lets, lcell, buf, ast_span_lo(recv), ast_span_hi(recv));
    if slit == 0 {
        return 0;
    }
    let fidx: i64 = nb_slit_field_index(slit, buf, ast_child1(field_node), ast_child2(field_node));
    if fidx < 0 {
        return 0;
    }
    fidx * 8
}

// RI-D2 S-D: classify a field READ `recv.field`'s dtype (FLOAT for an f64/f32 field,
// else INT). The native backend tracks structs by the LITERAL binding, not srt, so the
// field's dtype is read off the struct-literal's value node at the resolved field index
// (the value the field was constructed with — a float literal `3.5` classifies FLOAT via
// nb_node_dtype). A SYNTHETIC struct-decl descriptor (a struct-typed let/param bound to a
// call/param, built by nb_struct_decl_descriptor) stores value slot 0, so value_node==0
// falls back to INT — safe (no ast_kind(0) deref) and correct: main.mind's struct-typed
// lets are ALL these decl descriptors over float-free structs, so every self-compile
// field read classifies INT and the integer field path stays byte-identical. (Declared-
// dtype for the decl-descriptor case would extend the srt schema with per-field dtype —
// a larger follow-up, not needed for the struct-literal float-field READ this proves.)
// An if-STATEMENT chain (no value-if-let phis) so it stays in the self-host subset.
pub fn nb_field_dtype(recv: i64, field_node: i64, buf: i64, lets: i64, lcell: i64) -> i64 {
    if ast_kind(recv) != ast_ident() {
        return nb_dtype_int();
    }
    let slit: i64 = nb_lets_lookup_slit(lets, lcell, buf, ast_span_lo(recv), ast_span_hi(recv));
    if slit == 0 {
        return nb_dtype_int();
    }
    let fidx: i64 = nb_slit_field_index(slit, buf, ast_child1(field_node), ast_child2(field_node));
    if fidx < 0 {
        return nb_dtype_int();
    }
    let fields_addr: i64 = ast_child1(slit);
    let value_node: i64 = __mind_load_i64(fields_addr + (fidx * 3 + 2) * 8);
    if value_node == 0 {
        return nb_dtype_int();
    }
    nb_node_dtype(value_node)
}

// Emit a FLOAT field READ at byte offset `off` through the base-pointer slot `ptr_id`,
// TAGGING the result slot FLOAT in the per-fn dtype table `dtbl` so downstream float
// exprs route the SSE2 encoders. Byte-for-byte the SAME address computation and SSA-id
// consumption as nb_field_read (off==0 -> one id ; off>0 -> off+add+ld = three ids), but
// the final value load uses the SSE register file: mov rax,[rbp+addr] (the pointer) ;
// movsd xmm0,[rax] ; movsd [rbp+dst],xmm0. Only reached when nb_field_dtype classifies
// the field FLOAT — never during main.mind's float-free self-compile. A standalone
// tail-return helper (two returns are fine at fn scope; the dual-return hazard is INSIDE
// a value-producing if-arm).
pub fn nb_field_read_fp(code: String, next_id: i64, ptr_id: i64, off: i64, ncalls: i64, dtbl: i64) -> NbState {
    if off == 0 {
        let ld_id: i64 = next_id;
        let l1: String = nb_load_rax(code, nb_slot_disp(ptr_id));
        let l2: String = nb_fp_movsd_load_xmm0_rax(l1);
        let l3: String = nb_fp_movsd_store_xmm0(l2, nb_slot_disp(ld_id));
        let _tg: i64 = nb_dtype_tag_slot(dtbl, ld_id, nb_dtype_float());
        return NbState { code: l3, next_id: ld_id + 1, last_id: ld_id, ncalls: ncalls };
    }
    let off_id: i64 = next_id;
    let o1: String = nb_push(code, 72);
    let o2: String = nb_push(o1, 184);
    let o3: String = nb_i64le(o2, off);
    let o4: String = nb_store_rax(o3, nb_slot_disp(off_id));
    let add_id: i64 = off_id + 1;
    let d1: String = nb_load_rax(o4, nb_slot_disp(ptr_id));
    let d2: String = nb_arith_rax_mem(d1, op_add(), nb_slot_disp(off_id));
    let d3: String = nb_store_rax(d2, nb_slot_disp(add_id));
    let ld_id: i64 = add_id + 1;
    let e1: String = nb_load_rax(d3, nb_slot_disp(add_id));
    let e2: String = nb_fp_movsd_load_xmm0_rax(e1);
    let e3: String = nb_fp_movsd_store_xmm0(e2, nb_slot_disp(ld_id));
    let _tg: i64 = nb_dtype_tag_slot(dtbl, ld_id, nb_dtype_float());
    NbState { code: e3, next_id: ld_id + 1, last_id: ld_id, ncalls: ncalls }
}

// Emit each struct-literal field's store, in SOURCE order. For field i: emit the
// value expr -> val slot ; addr = (i==0 ? ptr_id : CONST(8*i)+ADD(ptr,off)) ;
// __mind_store_i64(addr, val) — the store's own dst id is consumed (the front-end
// never reads a store's result) so the SSA numbering matches the oracle exactly.
pub fn nb_struct_fields(st: NbState, buf: i64, fields_addr: i64, nfields: i64, i: i64, ptr_id: i64, params_addr: i64, n_params: i64, calls: i64, lets: i64, lcell: i64) -> NbState {
    if i >= nfields {
        return st;
    }
    let value_node: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    // Lower the field value -> its slot.
    let sv: NbState = nb_expr(st, buf, value_node, params_addr, n_params, calls, lets, lcell);
    let val_id: i64 = sv.last_id;
    let val_nc: i64 = sv.ncalls;
    // Emit the per-field store, threading the code String + next_id through a
    // single tail-return helper per offset case (NOT a two-branch NbState whose
    // fields are read afterward — that shape confuses the value tracker into
    // dropping the code handle). field 0 stores at the base ptr; field i>0 first
    // materialises addr = ptr + 8*i (CONST + ADD).
    if i == 0 {
        let s_after: NbState = nb_struct_field_store0(sv.code, sv.next_id, ptr_id, val_id, val_nc);
        return nb_struct_fields(s_after, buf, fields_addr, nfields, i + 1, ptr_id, params_addr, n_params, calls, lets, lcell);
    }
    let s_after: NbState = nb_struct_field_store_off(sv.code, sv.next_id, ptr_id, val_id, val_nc, i * 8);
    nb_struct_fields(s_after, buf, fields_addr, nfields, i + 1, ptr_id, params_addr, n_params, calls, lets, lcell)
}

// Emit field-0's store at the base pointer (offset 0), consuming the store's dst
// id. A leaf tail-return helper so the threaded code String stays live.
pub fn nb_struct_field_store0(code: String, next_id: i64, ptr_id: i64, val_id: i64, ncalls: i64) -> NbState {
    let store_dst: i64 = next_id;
    let c_st: String = nb_emit_store_i64(code, nb_slot_disp(ptr_id), nb_slot_disp(val_id));
    NbState { code: c_st, next_id: store_dst + 1, last_id: store_dst, ncalls: ncalls }
}

// Emit field-i>0's store: CONST off ; ADD(ptr, off) -> addr ; then the store at
// addr. Consumes off + add + store-dst ids. A leaf tail-return helper.
pub fn nb_struct_field_store_off(code: String, next_id: i64, ptr_id: i64, val_id: i64, ncalls: i64, off: i64) -> NbState {
    let off_id: i64 = next_id;
    let o1: String = nb_push(code, 72);
    let o2: String = nb_push(o1, 184);
    let o3: String = nb_i64le(o2, off);
    let o4: String = nb_store_rax(o3, nb_slot_disp(off_id));
    let add_id: i64 = off_id + 1;
    let a1: String = nb_load_rax(o4, nb_slot_disp(ptr_id));
    let a2: String = nb_arith_rax_mem(a1, op_add(), nb_slot_disp(off_id));
    let a3: String = nb_store_rax(a2, nb_slot_disp(add_id));
    let store_dst: i64 = add_id + 1;
    let c_st: String = nb_emit_store_i64(a3, nb_slot_disp(add_id), nb_slot_disp(val_id));
    NbState { code: c_st, next_id: store_dst + 1, last_id: store_dst, ncalls: ncalls }
}

// Load each call arg 0..n-1 into its SysV argument register, drawing from two
// INDEPENDENT register pools keyed by the arg's classified dtype (arg_dts[i]):
//   * FLOAT arg -> load slot into SSE reg xmm{sse_k} (movsd); advances sse_k only.
//   * int/ptr arg -> load slot into GP reg gp_k (nb_load_argreg); advances gp_k only.
// The 7th+ GP arg (gp_k >= 6) is stack-passed (push) by nb_emit_stackargs at the CALL
// SITE, not register-loaded here — so it advances gp_k without emitting. This mirrors
// nb_emit_params' incoming-param two-pool ABI (S-B) on the caller side (S-C2).
//
// INT-PRESERVATION (load-bearing): main.mind's own source has ZERO float call-args, so
// every arg takes the GP branch and gp_k == i for all i. In that case the register
// selection (nb_load_argreg(gp_k, ...)) and the >6-arg skip (gp_k >= 6) are IDENTICAL
// to the prior `i`-keyed code, so the all-integer emission is byte-for-byte unchanged.
// The float branch is reached only when arg_dts[i] == nb_dtype_float().
pub fn nb_emit_argregs(code: String, ids: i64, arg_dts: i64, n: i64, i: i64, gp_k: i64, sse_k: i64) -> String {
    if i >= n {
        return code;
    }
    let slot: i64 = __mind_load_i64(ids + i * 8);
    let dt: i64 = __mind_load_i64(arg_dts + i * 8);
    if dt == nb_dtype_float() {
        if sse_k >= 8 {
            // 9th+ SSE arg is stack-passed (pushed by nb_emit_stackargs at the CALL
            // SITE), not xmm-loaded here — the movsd encoders mask k & 7 with no REX.R
            // and cannot address xmm8..15, and SysV never passes args past xmm7. Advance
            // sse_k only (no bytes emitted) so it is counted as a stack arg, mirroring the
            // gp_k >= 6 skip below.
            return nb_emit_argregs(code, ids, arg_dts, n, i + 1, gp_k, sse_k + 1);
        }
        // FLOAT arg: load slot -> xmm{sse_k} via movsd. Advances sse_k only.
        let cf: String = nb_fp_movsd_load_xmmk(code, sse_k, nb_slot_disp(slot));
        return nb_emit_argregs(cf, ids, arg_dts, n, i + 1, gp_k, sse_k + 1);
    }
    if gp_k >= 6 {
        // 7th+ GP CALL args are stack-passed (push) by nb_emit_stackargs at the CALL
        // SITE, not register-loaded here. Advances gp_k only (no bytes emitted).
        return nb_emit_argregs(code, ids, arg_dts, n, i + 1, gp_k + 1, sse_k);
    }
    let c1: String = nb_load_argreg(code, gp_k, nb_slot_disp(slot));
    nb_emit_argregs(c1, ids, arg_dts, n, i + 1, gp_k + 1, sse_k)
}

// SysV AMD64 two-pool stack classification. An arg is REGISTER-passed iff ITS
// class's pool is not yet exhausted AT ITS POSITION (GP pool 6: rdi/rsi/rdx/rcx/
// r8/r9 ; SSE pool 8: xmm0..7), on INDEPENDENT counters; otherwise it is a stack
// arg. `nb_argstk_at` answers "is arg `t` stack-passed?" by walking 0..=t while
// advancing only the counter of each arg's class. INT-PRESERVATION: with every arg
// INT (main.mind's own source), gp advances 1:1 with position and sse stays 0, so
// nb_argstk_at(t) == (t >= 6) — byte-identical to the prior positional `j >= 6`.
pub fn nb_argstk_at(arg_dts: i64, t: i64, k: i64, gp: i64, sse: i64) -> i64 {
    let d: i64 = __mind_load_i64(arg_dts + k * 8);
    if d == nb_dtype_float() {
        if k == t {
            if sse >= 8 {
                return 1;
            }
            return 0;
        }
        return nb_argstk_at(arg_dts, t, k + 1, gp, sse + 1);
    }
    if k == t {
        if gp >= 6 {
            return 1;
        }
        return 0;
    }
    nb_argstk_at(arg_dts, t, k + 1, gp + 1, sse)
}

// Count stack-passed args in [0,n) under the SysV two-pool rule (int gp>=6 or
// float sse>=8). n_stack = max(n_int-6,0) + max(n_float-8,0). All-int -> max(n-6,0).
pub fn nb_count_argstk(arg_dts: i64, n: i64, k: i64, gp: i64, sse: i64, acc: i64) -> i64 {
    if k >= n {
        return acc;
    }
    let d: i64 = __mind_load_i64(arg_dts + k * 8);
    if d == nb_dtype_float() {
        let naf: i64 = if sse >= 8 {
            acc + 1
        } else {
            acc
        };
        return nb_count_argstk(arg_dts, n, k + 1, gp, sse + 1, naf);
    }
    let nai: i64 = if gp >= 6 {
        acc + 1
    } else {
        acc
    };
    nb_count_argstk(arg_dts, n, k + 1, gp + 1, sse, nai)
}

// Caller-side System-V stack-arg PAD (mirror src/native/mod.rs Call arm 935-939):
//   n_stack = SysV two-pool overflow count ; pad = (n_stack % 2) * 8.
// When pad>0 the 7th+ pushes would leave rsp 8-off-16; emit `sub rsp,8`
// (48 83 EC 08) FIRST to keep rsp 16-aligned at the `call`. n_stack even -> no-op.
// All-int -> n_stack == max(n-6,0), byte-identical to the prior positional path.
pub fn nb_emit_stack_pad(code: String, arg_dts: i64, n: i64) -> String {
    let n_stack: i64 = nb_count_argstk(arg_dts, n, 0, 0, 0, 0);
    if n_stack - (n_stack / 2) * 2 == 0 {
        return code;
    }
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 131);
    let c3: String = nb_push(c2, 236);
    nb_push(c3, 8)
}

// Push ONLY the SysV overflow args (int once gp>=6, float once sse>=8) RIGHT-TO-LEFT
// (mirror src/native Call arm 940-943), so the leftmost overflow arg ends at [rsp]
// (lowest addr) and the callee reads it at [rbp+16]. Each push is `mov rax,[slot]`
// (load_rax) + `push rax` (0x50). `j` walks DOWN from n-1 to 0; non-overflow args are
// skipped (no bytes). All-int: nb_argstk_at(j) == (j>=6), so exactly positions n-1..6
// are pushed — byte-identical to the prior positional loop. An if-STATEMENT recursion
// (no value-if phi) keeps it in the self-host subset.
pub fn nb_emit_stackargs(code: String, ids: i64, arg_dts: i64, n: i64, j: i64) -> String {
    if j < 0 {
        return code;
    }
    if nb_argstk_at(arg_dts, j, 0, 0, 0) == 0 {
        return nb_emit_stackargs(code, ids, arg_dts, n, j - 1);
    }
    let slot: i64 = __mind_load_i64(ids + j * 8);
    let c1: String = nb_load_rax(code, nb_slot_disp(slot));
    let c2: String = nb_push(c1, 80);
    nb_emit_stackargs(c2, ids, arg_dts, n, j - 1)
}

// Caller-side stack cleanup AFTER the call (mirror src/native Call arm 950-954):
//   cleanup = 8*n_stack + pad ; if cleanup>0 emit `add rsp,imm32` (48 81 C4 <le32>).
// pad = (n_stack % 2) * 8, n_stack = SysV two-pool overflow count. All-int -> no-op
// for n<=6 and byte-identical to today otherwise.
pub fn nb_emit_stack_cleanup(code: String, arg_dts: i64, n: i64) -> String {
    let n_stack: i64 = nb_count_argstk(arg_dts, n, 0, 0, 0, 0);
    if n_stack <= 0 {
        return code;
    }
    let pad: i64 = (n_stack - (n_stack / 2) * 2) * 8;
    let cleanup: i64 = 8 * n_stack + pad;
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 129);
    let c3: String = nb_push(c2, 196);
    nb_u32(c3, cleanup)
}

// Emit a synthetic `ConstI64(next_id, 0)` (a branch's leading then_result /
// else_result unit zero — the lowering pushes one at the start of every branch,
// even a diverging one; see eval/lower.rs Node::If). movabs rax,0 ; mov [slot],rax.
// Advances next_id, sets last_id to the consumed id.
pub fn nb_emit_const0(st: NbState) -> NbState {
    let id: i64 = st.next_id;
    let c1: String = nb_push(st.code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, 0);
    let c4: String = nb_store_rax(c3, nb_slot_disp(id));
    NbState { code: c4, next_id: id + 1, last_id: id, ncalls: st.ncalls }
}

// True if a statement is a terminator (diverges — control never falls through).
// Mirror src/native::branch_diverges: a `return` (the only terminator in this
// subset; break/continue are std-surface, out of scope here).
pub fn nb_stmt_diverges(node: i64) -> i64 {
    if ast_kind(node) == ast_return() {
        return 1;
    }
    0
}

// True if the LAST statement of a block (stmts_addr[0..stmts_len]) diverges.
// An empty block falls through (returns 0).
pub fn nb_block_diverges(stmts_addr: i64, stmts_len: i64) -> i64 {
    if stmts_len <= 0 {
        return 0;
    }
    nb_stmt_diverges(__mind_load_i64(stmts_addr + (stmts_len - 1) * 8))
}

// True if a body's LAST EMITTED instruction is a `Return` — i.e. control never
// falls off the end, so NO implicit tail-return is appended (mirror the Rust
// `!matches!(body.last(), Some(Instr::Return{..}))` guard in src/native::lower_fn
// at mod.rs:1155). This holds when the last statement is an explicit `return`, OR
// an if-STATEMENT with an else where BOTH branches' last-emitted instr is a Return
// (a fully-diverging if — emit_seq lays the then-Return then the else-Return, so
// the body's last instr is the else's Return). A bare tail expression does NOT
// terminate, so the implicit return fires (load ret_id -> rax ; epilogue).
pub fn nb_last_emits_return(stmts_addr: i64, stmts_len: i64) -> i64 {
    if stmts_len <= 0 {
        return 0;
    }
    let last: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    let k: i64 = ast_kind(last);
    if k == ast_return() {
        return 1;
    }
    if k == ast_if() {
        // A value-if-expr-as-statement is NOT a terminator (its branches yield
        // values, not returns); only a plain diverging if-statement is.
        if is_any_value_if_expr(last) == 1 {
            return 0;
        }
        let else_blk: i64 = ast_child2(last);
        if else_blk == 0 {
            return 0;
        }
        let then_blk: i64 = ast_child1(last);
        let then_term: i64 = nb_last_emits_return(ast_child0(then_blk), ast_aux(then_blk));
        if then_term == 0 {
            return 0;
        }
        return nb_last_emits_return(ast_child0(else_blk), ast_aux(else_blk));
    }
    0
}

// ===== WHILE-loop emit machinery (Phase 1.3 #14) =====
//
// Mirror src/native/mod.rs's emit_seq `While` arm + assign_slots' loop-carry
// coalescing + eval/lower.rs's Node::While id allocation. The let-env (name span
// -> slot) IS the loop_remap mechanism here: a carried var's let-env entry is
// rebound to its post_id slot for the cond+body emit (after a copy-in from the
// init slot), reproducing emit_seq's loop_remap.insert(init_id, post_id).
//
// ---- per-while loop-carry table ----
// One carry record = 4 i64 words: (name_lo, name_hi, init_slot, post_id). The
// init_slot is the var's pre-loop let-env slot; post_id is the SSA id of its LAST
// body Assign's RHS result (the var's dedicated working slot, == assign_slots'
// post_id). exit_id (lower.rs 4801) coalesces onto post_id (mod.rs 623), so it
// adds no slot and post-loop reads resolve to post_id directly.

// Look up a carried-var name in the carry table; return its record index or -1.
pub fn nb_carry_find(carry: i64, ccell: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    nb_carry_find_rest(carry, __mind_load_i64(ccell), buf, lo, hi, 0)
}
pub fn nb_carry_find_rest(carry: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(carry + (i * 4 + 0) * 8);
    let nhi: i64 = __mind_load_i64(carry + (i * 4 + 1) * 8);
    if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        return i;
    }
    nb_carry_find_rest(carry, n, buf, lo, hi, i + 1)
}

// Record a loop-carried var (mirror record_loop_mut @lower.rs 4608): first sighting
// of a name appends a record (capturing its pre-loop init_slot); a later sighting
// only updates post_id (mutated[pos].1 = new_id). init_slot is the var's current
// let-env slot (pre-loop binding); -1 if it is not a known let/param (a defensive
// sentinel — string_push_str's carried vars are all `let mut` so they resolve).
pub fn nb_carry_record(carry: i64, ccell: i64, buf: i64, lo: i64, hi: i64, post_id: i64, lets: i64, lcell: i64) -> i64 {
    let init_slot: i64 = nb_lets_lookup(lets, lcell, buf, lo, hi);
    nb_carry_record_slot(carry, ccell, buf, lo, hi, post_id, init_slot)
}
// As nb_carry_record but with an EXPLICIT init_slot (the var's pre-loop let-env slot),
// for callers where the shared let-env has already been transiently rebound (e.g. the
// if-region carry arm reads init_slot from the [0,entry_n) pre-loop prefix BEFORE
// nb_count_stmt's if-arm pollutes the env with slot-0 merge-name rebinds). Same
// first-sighting dedup + 256-cap fail-closed as nb_carry_record.
pub fn nb_carry_record_slot(carry: i64, ccell: i64, buf: i64, lo: i64, hi: i64, post_id: i64, init_slot: i64) -> i64 {
    let pos: i64 = nb_carry_find(carry, ccell, buf, lo, hi);
    if pos >= 0 {
        __mind_store_i64(carry + (pos * 4 + 3) * 8, post_id);
        return 0;
    }
    let n: i64 = __mind_load_i64(ccell);
    // Cap guard: the carry table is a fixed 256-entry x 4-word buffer
    // (__mind_alloc(256 * 4 * 8)). A 257th distinct carried var would store one
    // slot past the end and corrupt the adjacent arena allocation (the compiler's
    // own state) — a silent miscompile. Refuse loudly (fail-closed -1, dropping
    // the carried var so the byte-diff / keystone catches the wrong emit) instead
    // of overflowing. No current fn has >256 carried vars, so this is never taken
    // during self-compile and the loop stays byte-identical.
    if n >= 256 {
        return 0 - 1;
    }
    __mind_store_i64(carry + (n * 4 + 0) * 8, lo);
    __mind_store_i64(carry + (n * 4 + 1) * 8, hi);
    __mind_store_i64(carry + (n * 4 + 2) * 8, init_slot);
    __mind_store_i64(carry + (n * 4 + 3) * 8, post_id);
    __mind_store_i64(ccell, n + 1);
    0
}

// Pre-walk the loop body to fill the carry table AND return the post-body next_id
// (== nb_count_stmts over the body), so the working post_ids are exactly the SSA
// ids the real body emit will produce. Threads next_id like nb_count_stmts; for a
// top-level `Assign name = RHS`, records (name -> RHS-result-id = after_rhs-1).
// Non-assign statements advance next_id via nb_count_stmt (their result ids are
// consumed identically by the emit).
// deferred: nested-region (if/while-in-body) mutations of an OUTER carried var
// (lower.rs F2 4737-4777, last_region_exit_rebindings) are NOT recorded here —
// string_push_str's carried vars are all top-level body assigns. upgrade path:
// after counting a nested if/while, scan its tail for an Assign to a name already
// in the carry/let-env and record it, mirroring last_region_exit_rebindings.
pub fn nb_while_carry(carry: i64, ccell: i64, next_id: i64, buf: i64, body_sa: i64, body_sl: i64, i: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64, lets: i64, lcell: i64, entry_n: i64) -> i64 {
    if i >= body_sl {
        return next_id;
    }
    let stmt: i64 = __mind_load_i64(body_sa + i * 8);
    let after: i64 = if ast_kind(stmt) == ast_assign() {
        let arhs: i64 = nb_count_expr(next_id, buf, ast_child2(stmt), params_addr, n_params, clets, clcell);
        let name_leaf: i64 = ast_child0(stmt);
        // C2 declared-width driver (carry form): a narrow-DECLARED carried var's
        // assign consumes ONE fresh wrap slot at emit (nb_stmt assign arm mints
        // `wida = s1.next_id` = arhs, then next_id = arhs+1, last_id = arhs). So the
        // working post_id IS the wrap slot (arhs) — NOT the RHS result (arhs-1) — and
        // the threaded next_id must advance one further so a LATER carried var in the
        // same body counts from the emit's real next_id (else its post_id is one low
        // and the loop cond reads a never-updated slot → hang). Mirror both here, the
        // exact twin of nb_count_stmt's assign arm (+1 iff narrow) which sizes the
        // frame. Every carried var in main.mind is i64 → width 64 → post_id = arhs-1,
        // after = arhs (unchanged) — byte-identical self-compile.
        let cw: i64 = nb_lets_lookup_width(lets, lcell, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
        if cw < 64 {
            let _rw: i64 = nb_carry_record(carry, ccell, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), arhs, lets, lcell);
            arhs + 1
        } else {
            let _r: i64 = nb_carry_record(carry, ccell, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), arhs - 1, lets, lcell);
            arhs
        }
    } else {
        // A flat 3-way `else if` value-let is NOT in the mic@3 note-emit subset
        // (nb_build_mic3 fails closed on it); keep this a 2-way value-if and push the
        // while-vs-other decision into an early-return helper (the proven subset).
        nb_while_carry_nonassign(carry, ccell, next_id, buf, stmt, params_addr, n_params, clets, clcell, srt, lets, lcell, entry_n)
    };
    nb_while_carry(carry, ccell, after, buf, body_sa, body_sl, i + 1, params_addr, n_params, clets, clcell, srt, lets, lcell, entry_n)
}

// Non-assign statement in a loop-carry pre-walk: a nested `while` descends into the
// F2 nested-carry promotion (nb_while_carry_wnest); anything else just threads
// next_id via nb_count_stmt. Early-return form so nb_while_carry's value-if stays
// 2-way (mic@3 note-emittable).
pub fn nb_while_carry_nonassign(carry: i64, ccell: i64, next_id: i64, buf: i64, stmt: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64, lets: i64, lcell: i64, entry_n: i64) -> i64 {
    if ast_kind(stmt) == ast_while() {
        return nb_while_carry_wnest(carry, ccell, next_id, buf, stmt, params_addr, n_params, clets, clcell, srt, lets, lcell, entry_n);
    }
    if ast_kind(stmt) == ast_if() {
        return nb_while_carry_ifnest(carry, ccell, next_id, buf, stmt, params_addr, n_params, clets, clcell, srt, lets, lcell, entry_n);
    }
    nb_count_stmt(next_id, buf, stmt, params_addr, n_params, clets, clcell, srt)
}

// SUB-STEP B: an `if` in a loop body whose branch DIRECTLY (top-level) reassigns an
// OUTER (pre-loop) var carries that var across the loop (mirror lower.rs
// region_exit_rebindings threaded at the If then/else arms, 5675/5894). The var's
// post-if incarnation is the if's MERGE slot; the loop-carry copy-in seeds it and the
// exit_id coalesces onto it, so the value accumulates across iterations.
//
// The merge slot is NOT re-derived by a second hand-mirrored computation (that was the
// c27a766 / 0b5f489 desync). It is pulled from the SHARED id threading: nb_count_stmt's
// if-arm returns the if's final next_id total, and that total == the emit's
// (nb_if_stmt_merged) final next_id (the count/emit-total invariant). The merge block
// (nb_merge_assign_slots) occupies the LAST nmerged ids, so merge_base = total - nmerged
// and merged var j (nb_merged_names order) lands at merge_base + j — exactly the slot
// nb_rebind_merges binds it to on the emit side. Because nb_count_carried now delegates
// to this same nb_while_carry (Sub-step A), the COUNT sees the identical promotion, so
// count<->emit stay locked by construction.
//
// SCOPED to Sub-step B: only a var DIRECTLY assigned at a branch's top level is promoted
// (nb_branch_top_assigns). A var merged via a nested `while`/`if` inside the branch
// (`while{ if{ while{} } }`, Sub-step C) is NOT promoted here, so that shape's carry
// count/behavior is exactly as before (still fail-closed / the documented i64 gap).
pub fn nb_while_carry_ifnest(carry: i64, ccell: i64, next_id: i64, buf: i64, stmt: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64, lets: i64, lcell: i64, entry_n: i64) -> i64 {
    let names: i64 = __mind_alloc(256 * 2 * 8);
    let then_blk: i64 = ast_child1(stmt);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(stmt);
    let else_sa: i64 = if else_blk == 0 {
        0
    } else {
        ast_child0(else_blk)
    };
    let else_sl: i64 = if else_blk == 0 {
        0
    } else {
        ast_aux(else_blk)
    };
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, names);
    // Thread the if via the shared count (== emit final next_id). nb_count_stmt's if-arm
    // also transiently rebinds the merged names into clets at slot 0 — harmless, the
    // caller (nb_emit_while / nb_count_carried) snapshot/restores the env after the walk.
    let total: i64 = nb_count_stmt(next_id, buf, stmt, params_addr, n_params, clets, clcell, srt);
    let merge_base: i64 = total - nmerged;
    let _p: i64 = nb_if_carry_promote(carry, ccell, names, nmerged, 0, buf, then_sa, then_sl, else_sa, else_sl, lets, entry_n, merge_base);
    total
}

// For each merged name (nb_merged_names order j), record it carried iff it is an OUTER
// var (bound in [0,entry_n)) AND directly (top-level) assigned in a branch. post_id =
// merge_base + j (the emit merge slot). init_slot is read from the pre-loop prefix
// [0,entry_n) (nb_lets_lookup_rest), which the if-arm's transient slot-0 rebind (at an
// index >= entry_n) never shadows.
pub fn nb_if_carry_promote(carry: i64, ccell: i64, names: i64, nmerged: i64, j: i64, buf: i64, then_sa: i64, then_sl: i64, else_sa: i64, else_sl: i64, lets: i64, entry_n: i64, merge_base: i64) -> i64 {
    if j >= nmerged {
        return 0;
    }
    let lo: i64 = __mind_load_i64(names + (j * 2 + 0) * 8);
    let hi: i64 = __mind_load_i64(names + (j * 2 + 1) * 8);
    let os: i64 = nb_lets_lookup_rest(lets, entry_n, buf, lo, hi, 0, 0 - 1);
    let then_a: i64 = nb_block_top_assigns(buf, then_sa, then_sl, 0, lo, hi);
    let else_a: i64 = nb_block_top_assigns(buf, else_sa, else_sl, 0, lo, hi);
    // Promote iff OUTER and a GENUINE single-branch carry: the var is DIRECTLY (top-level)
    // assigned in exactly one branch AND the SIBLING branch does NOT write it ANYWHERE (any
    // depth — nested if/while included, nb_block_writes_rec). The sibling-write check MUST be
    // recursive: a non-recursive top-level scan misses `else { if{ x+=5 } }` and would carry
    // x as clean single-branch while DROPPING the else's nested write — a silent miscompile
    // (the blind-review XN class). When the sibling writes the var by any means we fail-closed
    // (do not promote), matching the base 41d98e7 behavior. A var written directly in BOTH
    // branches (then_a+else_a==2) also stays unpromoted — that hits a SEPARATE pre-existing
    // nb_if_stmt_merged merge-read bug (`let mut x=5; if 1<0 {x=x+1} else {x=x+2}` -> 2 not 7),
    // out of Sub-step B scope. A genuine single-branch var is read via in_outer (the carried
    // incoming value) on the other side, so it carries correctly; two DIFFERENT vars one per
    // branch each qualify independently (each sibling does not write the other's var).
    let sib_writes: i64 = if then_a == 1 {
        nb_block_writes_rec(buf, else_sa, else_sl, lo, hi, 0)
    } else {
        if else_a == 1 {
            nb_block_writes_rec(buf, then_sa, then_sl, lo, hi, 0)
        } else {
            0
        }
    };
    let direct: i64 = if os >= 0 {
        if then_a + else_a == 1 {
            if sib_writes == 0 {
                1
            } else {
                0
            }
        } else {
            0
        }
    } else {
        0
    };
    if direct == 1 {
        let _r: i64 = nb_carry_record_slot(carry, ccell, buf, lo, hi, merge_base + j, os);
        return nb_if_carry_promote(carry, ccell, names, nmerged, j + 1, buf, then_sa, then_sl, else_sa, else_sl, lets, entry_n, merge_base);
    }
    nb_if_carry_promote(carry, ccell, names, nmerged, j + 1, buf, then_sa, then_sl, else_sa, else_sl, lets, entry_n, merge_base)
}

// 1 iff name [lo,hi) is a TOP-LEVEL `Assign` target in block [sa,sl). Does NOT recurse
// into nested while/if (Sub-step B scope) — a var written only via a nested construct is
// not a direct branch assign and stays unpromoted.
pub fn nb_block_top_assigns(buf: i64, sa: i64, sl: i64, i: i64, lo: i64, hi: i64) -> i64 {
    if i >= sl {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    if ast_kind(stmt) == ast_assign() {
        let nm: i64 = ast_child0(stmt);
        if span_bytes_equal(buf, lo, hi, ast_span_lo(nm), ast_span_hi(nm)) == 1 {
            return 1;
        }
    }
    nb_block_top_assigns(buf, sa, sl, i + 1, lo, hi)
}

// 1 iff name [lo,hi) is an `Assign` target ANYWHERE in block [sa,sl), descending into
// nested `if` (both branches) and `while` bodies to ANY depth. Used to fail-close a
// "single-branch" if-region carry when the SIBLING branch also writes the var by nested
// control (`else { if{ x+=5 } }` / `else { while{ x+=1 } }`) — such a var is not a genuine
// single-branch carry and must NOT be promoted (else the sibling's nested write is dropped,
// a silent miscompile). Only `Assign` counts (a nested `let` of the same name shadows a
// DIFFERENT binding, not a write to the carried var).
pub fn nb_block_writes_rec(buf: i64, sa: i64, sl: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= sl {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_assign() {
        let nm: i64 = ast_child0(stmt);
        if span_bytes_equal(buf, lo, hi, ast_span_lo(nm), ast_span_hi(nm)) == 1 {
            return 1;
        }
    }
    if k == ast_while() {
        let wb: i64 = ast_child1(stmt);
        if nb_block_writes_rec(buf, ast_child0(wb), ast_aux(wb), lo, hi, 0) == 1 {
            return 1;
        }
    }
    if k == ast_if() {
        let tb: i64 = ast_child1(stmt);
        if nb_block_writes_rec(buf, ast_child0(tb), ast_aux(tb), lo, hi, 0) == 1 {
            return 1;
        }
        let eb: i64 = ast_child2(stmt);
        if eb != 0 {
            if nb_block_writes_rec(buf, ast_child0(eb), ast_aux(eb), lo, hi, 0) == 1 {
                return 1;
            }
        }
    }
    nb_block_writes_rec(buf, sa, sl, lo, hi, i + 1)
}

// F2 nested-loop outer-var carry (mirror lower.rs last_region_exit_rebindings +
// record_loop_mut over `env`): a nested `while` may reassign an OUTER (pre-loop)
// variable only inside its body. Descend into the inner while, compute each
// inner-carried var's post_id (the slot it lands in after the inner loop), and
// PROMOTE every one that is an OUTER var (bound in this loop's pre-loop scope
// [0, entry_n)) into the OUTER carry table with that inner post_id. Then the outer
// copy-in seeds the inner-exit slot ONCE before the header (so the value accumulates
// across outer iterations), and the inner copy-in becomes a no-op (init_slot ==
// post_id). Returns next_id threaded EXACTLY as nb_count_stmt's while arm (after_cond
// ; body ids ; +ncarry_inner exit_ids ; +1 unit) so the emit stays in lockstep with
// the frame count. Extracted to its own fn so nb_while_carry's while arm is a plain
// call (the native self-host emitter lowers a value-if branch that is a single call,
// not a deep let-block). Body-local `let mut` counters (bound at index >= entry_n)
// fail the outer test and are NOT promoted, matching lower.rs's `env.contains_key`.
pub fn nb_while_carry_wnest(carry: i64, ccell: i64, next_id: i64, buf: i64, stmt: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64, lets: i64, lcell: i64, entry_n: i64) -> i64 {
    let iw_cond: i64 = ast_child0(stmt);
    let after_iwcond: i64 = nb_count_expr(next_id, buf, iw_cond, params_addr, n_params, clets, clcell);
    let iw_body: i64 = ast_child1(stmt);
    let iw_bsa: i64 = ast_child0(iw_body);
    let iw_bsl: i64 = ast_aux(iw_body);
    let icarry: i64 = __mind_alloc(256 * 4 * 8);
    let iccell: i64 = __mind_alloc(8);
    __mind_store_i64(iccell, 0);
    // The inner loop's own pre-loop scope bound = the let-env size at THIS point
    // (params + every let bound before the inner while, incl. an outer body-local).
    let inner_entry_n: i64 = __mind_load_i64(lcell);
    let after_ibody: i64 = nb_while_carry(icarry, iccell, after_iwcond, buf, iw_bsa, iw_bsl, 0, params_addr, n_params, clets, clcell, srt, lets, lcell, inner_entry_n);
    let incarry: i64 = __mind_load_i64(iccell);
    let _pr: i64 = nb_carry_promote_inner(carry, ccell, icarry, incarry, 0, buf, lets, lcell, entry_n);
    after_ibody + incarry + 1
}

// Promote each OUTER-scope var carried by a nested inner while (icarry[0..incarry))
// into the enclosing loop's carry table (mirror record_loop_mut over the nested
// region's last_region_exit_rebindings). A var is OUTER iff its name is bound in the
// enclosing loop's pre-loop scope [0, entry_n) of the emit let-env (a body-local
// `let mut` bound at index >= entry_n fails and is skipped). post_id is the inner
// carried post_id (the inner-loop exit slot); nb_carry_record dedups by name and
// captures the pre-loop init_slot, so the outer copy-in seeds the inner-exit slot.
pub fn nb_carry_promote_inner(carry: i64, ccell: i64, icarry: i64, incarry: i64, k: i64, buf: i64, lets: i64, lcell: i64, entry_n: i64) -> i64 {
    if k >= incarry {
        return 0;
    }
    let lo: i64 = __mind_load_i64(icarry + (k * 4 + 0) * 8);
    let hi: i64 = __mind_load_i64(icarry + (k * 4 + 1) * 8);
    let post: i64 = __mind_load_i64(icarry + (k * 4 + 3) * 8);
    let outer_slot: i64 = nb_lets_lookup_rest(lets, entry_n, buf, lo, hi, 0, 0 - 1);
    if outer_slot >= 0 {
        let _r: i64 = nb_carry_record(carry, ccell, buf, lo, hi, post, lets, lcell);
        return nb_carry_promote_inner(carry, ccell, icarry, incarry, k + 1, buf, lets, lcell, entry_n);
    }
    nb_carry_promote_inner(carry, ccell, icarry, incarry, k + 1, buf, lets, lcell, entry_n)
}

// ---- loop-frame stack (header offset + break-site list) ----
// One frame = 3 i64 words: (header_offset, breaks_buf, nbreaks). breaks_buf is a
// per-loop buffer of recorded break jmp indices (`which` into the jmps table),
// patched to the loop end once known. Threaded like jmps/jcell.
pub fn nb_loops_push(loops: i64, lpcell: i64, header: i64, breaks_buf: i64) -> i64 {
    let n: i64 = __mind_load_i64(lpcell);
    // Cap guard: the loop-frame stack is a fixed 256-entry x 3-word buffer
    // (__mind_alloc(256 * 3 * 8)). A 257th nested loop frame would overflow it and
    // corrupt adjacent arena state. Refuse loudly (fail-closed -1) rather than
    // overflow; >256 nested loops is unreachable in current source, so this is
    // never taken during self-compile (byte-identical).
    if n >= 256 {
        return 0 - 1;
    }
    __mind_store_i64(loops + (n * 3 + 0) * 8, header);
    __mind_store_i64(loops + (n * 3 + 1) * 8, breaks_buf);
    __mind_store_i64(loops + (n * 3 + 2) * 8, 0);
    __mind_store_i64(lpcell, n + 1);
    0
}
pub fn nb_loops_pop(lpcell: i64) -> i64 {
    let n: i64 = __mind_load_i64(lpcell);
    __mind_store_i64(lpcell, n - 1);
    0
}
// Header offset of the innermost active loop (or -1 when none — break/continue
// outside a loop, a fail-loud sentinel mirroring mod.rs 1086-1102).
pub fn nb_loops_top_header(loops: i64, lpcell: i64) -> i64 {
    let n: i64 = __mind_load_i64(lpcell);
    if n <= 0 {
        return 0 - 1;
    }
    __mind_load_i64(loops + ((n - 1) * 3 + 0) * 8)
}
// Record a break jmp index (`which`) into the innermost loop's break list.
pub fn nb_loops_push_break(loops: i64, lpcell: i64, which: i64) -> i64 {
    let n: i64 = __mind_load_i64(lpcell);
    if n <= 0 {
        return 0 - 1;
    }
    let bb: i64 = __mind_load_i64(loops + ((n - 1) * 3 + 1) * 8);
    let nb: i64 = __mind_load_i64(loops + ((n - 1) * 3 + 2) * 8);
    __mind_store_i64(bb + nb * 8, which);
    __mind_store_i64(loops + ((n - 1) * 3 + 2) * 8, nb + 1);
    0
}

// Emit each carried var's copy-in (load init_slot; store post_slot) when the slots
// differ, and rebind its let-env name to post_id for the cond+body emit. Mirrors
// emit_seq's loop_remap (mod.rs 1042-1058). Returns the updated code String.
pub fn nb_while_copyin(code: String, carry: i64, ncarry: i64, i: i64, buf: i64, lets: i64, lcell: i64) -> String {
    if i >= ncarry {
        return code;
    }
    let init_slot: i64 = __mind_load_i64(carry + (i * 4 + 2) * 8);
    let post_id: i64 = __mind_load_i64(carry + (i * 4 + 3) * 8);
    let lo: i64 = __mind_load_i64(carry + (i * 4 + 0) * 8);
    let hi: i64 = __mind_load_i64(carry + (i * 4 + 1) * 8);
    // Copy-in only when the working slot differs from the source slot (a no-op
    // copy is skipped — mod.rs 1051). init_slot < 0 means the var was not a known
    // pre-loop binding; skip the copy (no source to read).
    let c1: String = if init_slot >= 0 {
        if init_slot != post_id {
            let a: String = nb_load_rax(code, nb_slot_disp(init_slot));
            nb_store_rax(a, nb_slot_disp(post_id))
        } else {
            code
        }
    } else {
        code
    };
    // Rebind the var's let-env to post_id (loop_remap.insert(init_id, post_id)) so
    // cond+body reads resolve to the working slot.
    // C2 declared-width driver: inherit the carried var's DECLARED width onto its
    // working post_id rebind (last-match-wins means the in-body assign arm's width
    // lookup resolves THIS binding — a 64 here would silently disable the narrow
    // re-wrap inside the loop). All-i64 carried vars (all of main.mind) look up 64
    // and the rebind is exactly what it was — heap-table only, byte-identical.
    let carryw: i64 = nb_lets_lookup_width(lets, lcell, buf, lo, hi);
    let _b: i64 = nb_lets_bind(lets, lcell, lo, hi, post_id, 0, carryw);
    // FIX #174 (loop form): inherit the carried var's FLOAT dtype onto its working post_id
    // slot, so a float accumulator (`let a: f64 = 0.0; while .. { a = a + 1.5; }`) is seen
    // as FLOAT inside the loop body and routes the SSE2 path (pre-fix post_id read INT, so
    // `a + 1.5` took the GP-integer path and returned a wrong value). init_slot is the pre-
    // loop binding; when it carries a float dtype, tag post_id with it. main.mind's carried
    // vars are all INT, so post_id stays INT (the table default) — byte-identical.
    let dtbl: i64 = __mind_load_i64(lcell + 8);
    let src_dt: i64 = if dtbl != 0 {
        if init_slot >= 0 {
            nb_dtype_get(dtbl, init_slot)
        } else {
            nb_dtype_int()
        }
    } else {
        nb_dtype_int()
    };
    let _dt: i64 = nb_dtype_tag_slot(dtbl, post_id, src_dt);
    nb_while_copyin(c1, carry, ncarry, i + 1, buf, lets, lcell)
}

// ===== If-branch merge analysis (Phase 1.3 #14) =====
//
// Mirror eval/lower.rs's Node::If merge-phi machinery (4150-4290): for each
// variable WRITTEN (let/assign/nested-region-mutated) in EITHER branch, the
// front-end allocates a fresh merge id and, on each FALL-THROUGH branch that
// does NOT define the name, a placeholder ConstI64(0). The native If arm emits
// these as `load then_val/else_val ; store merge_id` before the dst copy (mod.rs
// 989-1010). A value-if whose branch contains a `while` that mutates a body-let
// (string_push_str's `new_cap`/`new_addr`) generates exactly these merges.

// Collect the DISTINCT names a branch block WRITES (let/assign targets +
// top-level while live_vars), into the names table (lo,hi pairs). Returns the new
// count. Mirror record_then_write/record_else_write + last_region_exit_rebindings
// for a top-level while (its live_vars are the carried names).
// deferred: nested `if`-region mutations (last_region_exit_rebindings on a nested
// if) are not collected — string_push_str's branch writes are let/assign + a
// top-level while only. upgrade path: recurse into a nested if's branches.
pub fn nb_branch_writes(buf: i64, sa: i64, sl: i64, i: i64, names: i64, n: i64) -> i64 {
    if i >= sl {
        return n;
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    let k: i64 = ast_kind(stmt);
    let new_n: i64 = if k == ast_let() {
        nb_writes_add(buf, names, n, ast_child0(stmt))
    } else {
        if k == ast_assign() {
            nb_writes_add(buf, names, n, ast_child0(stmt))
        } else {
            if k == ast_while() {
                nb_while_live_writes(buf, ast_child0(ast_child1(stmt)), ast_aux(ast_child1(stmt)), 0, names, n)
            } else {
                if k == ast_if() {
                    // F2 outer-var-through-nested-region (lower.rs 4003-4013 `other =>`
                    // arm + last_region_exit_rebindings): a branch statement that is
                    // itself a nested `if` threads that if's branch_bindings — i.e. its
                    // own merged_names (lower.rs 4289 pushes one branch_binding per
                    // merged name) — up as writes of the ENCLOSING branch, so each
                    // enclosing `if` allocates a merge phi for them too. Add those names
                    // (deduped) to the enclosing names table. Recurses through
                    // nb_if_branch_merged_writes -> nb_branch_writes for nested-if tails.
                    nb_if_branch_merged_writes(buf, stmt, names, n)
                } else {
                    n
                }
            }
        }
    };
    nb_branch_writes(buf, sa, sl, i + 1, names, new_n)
}
// A nested `if` statement (the tail of an enclosing branch) exports its
// merged_names as the enclosing branch's writes (its branch_bindings, lower.rs
// 4289). merged_names = then-block writes UNION else-block writes (lower.rs
// 4203-4208), exactly nb_merged_names' union but appended (deduped) at offset `n`
// of the EXISTING enclosing names table. Both branch walks reuse nb_branch_writes,
// so a nested-if tail recurses to arbitrary depth.
pub fn nb_if_branch_merged_writes(buf: i64, ifnode: i64, names: i64, n: i64) -> i64 {
    let then_blk: i64 = ast_child1(ifnode);
    let after_then: i64 = nb_branch_writes(buf, ast_child0(then_blk), ast_aux(then_blk), 0, names, n);
    let else_blk: i64 = ast_child2(ifnode);
    let else_sa: i64 = if else_blk == 0 {
        0
    } else {
        ast_child0(else_blk)
    };
    let else_sl: i64 = if else_blk == 0 {
        0
    } else {
        ast_aux(else_blk)
    };
    nb_branch_writes(buf, else_sa, else_sl, 0, names, after_then)
}
// Add a name leaf (its span) to the names table if not already present; return
// the new count.
pub fn nb_writes_add(buf: i64, names: i64, n: i64, name_leaf: i64) -> i64 {
    let lo: i64 = ast_span_lo(name_leaf);
    let hi: i64 = ast_span_hi(name_leaf);
    if nb_name_seen(buf, names, n, lo, hi, 0) == 1 {
        return n;
    }
    let _r: i64 = nb_name_record(names, n, lo, hi);
    n + 1
}
// A while's top-level live_var (carried) names are writes of the enclosing branch
// (last_region_exit_rebindings threads them up). Add each distinct top-level
// assign target in the while body.
pub fn nb_while_live_writes(buf: i64, body_sa: i64, body_sl: i64, i: i64, names: i64, n: i64) -> i64 {
    if i >= body_sl {
        return n;
    }
    let stmt: i64 = __mind_load_i64(body_sa + i * 8);
    let new_n: i64 = if ast_kind(stmt) == ast_assign() {
        nb_writes_add(buf, names, n, ast_child0(stmt))
    } else {
        n
    };
    nb_while_live_writes(buf, body_sa, body_sl, i + 1, names, new_n)
}

// Build merged_names = then_writes ∪ else_writes (then order first, else-only
// appended). Fills `names` and returns the count.
pub fn nb_merged_names(buf: i64, then_sa: i64, then_sl: i64, else_sa: i64, else_sl: i64, names: i64) -> i64 {
    let after_then: i64 = nb_branch_writes(buf, then_sa, then_sl, 0, names, 0);
    nb_branch_writes(buf, else_sa, else_sl, 0, names, after_then)
}

// Re-bind an if's merged names into the count-lets after the branch-local lets are
// truncated away (nb_count_stmt if-arm). Mirrors eval/lower.rs's post-`if` env =
// outer env + branch_bindings: each merged name becomes visible (slot 0 / desc 0 —
// only its PRESENCE matters for an enclosing merge's `in_outer` prefix test; the
// dst-id count is independent of the bound slot/descriptor).
// C2 declared-width driver: the rebind INHERITS the merged name's true declared
// width via the count-lets lookup — the exact mirror of the emit side
// (nb_rebind_merges), which runs its lookup after the same pre-if env restore.
// Hardcoding 64 here was a latent count/emit asymmetry: a narrow var rebound by
// an if-merge then reassigned would count +0 (width 64) but emit +1 (inherited
// narrow width) — a one-slot frame undercount. Every i64 name looks up 64, so
// the count-side ids are unchanged for all-i64 modules — byte-identical.
pub fn nb_count_bind_merged(clets: i64, clcell: i64, names: i64, n: i64, i: i64, buf: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let lo: i64 = __mind_load_i64(names + (i * 2 + 0) * 8);
    let hi: i64 = __mind_load_i64(names + (i * 2 + 1) * 8);
    let mw: i64 = nb_lets_lookup_width(clets, clcell, buf, lo, hi);
    let _b: i64 = nb_lets_bind(clets, clcell, lo, hi, 0, 0, mw);
    nb_count_bind_merged(clets, clcell, names, n, i + 1, buf)
}

// Does a branch block DEFINE (let/assign/while-carry) the name at [lo,hi)?
pub fn nb_branch_defines(buf: i64, sa: i64, sl: i64, lo: i64, hi: i64) -> i64 {
    let tmp: i64 = __mind_alloc(256 * 2 * 8);
    let n: i64 = nb_branch_writes(buf, sa, sl, 0, tmp, 0);
    nb_name_seen(buf, tmp, n, lo, hi, 0)
}

// Count the EXTRA ids the merge machinery allocates (mirror lower.rs 4234-4290):
// for each merged name, a then-placeholder (if then FALLS THROUGH and lacks it),
// an else-placeholder (if else FALLS THROUGH and lacks it), and a merge id (always).
pub fn nb_merge_ids_count(buf: i64, then_sa: i64, then_sl: i64, else_sa: i64, else_sl: i64, then_falls: i64, else_falls: i64, clets: i64, outer_n: i64) -> i64 {
    let names: i64 = __mind_alloc(256 * 2 * 8);
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, names);
    nb_merge_ids_rest(buf, then_sa, then_sl, else_sa, else_sl, then_falls, else_falls, names, nmerged, 0, 0, clets, outer_n)
}
// A side HAS the name (no placeholder) iff it is in the OUTER count-lets env (only
// the first `outer_n` bindings — those that existed BEFORE the if, not branch-local
// lets appended during the branch count) OR the side writes it — mirroring
// nb_merge_fill_defs. The merge id is allocated unconditionally (lower.rs 4287).
pub fn nb_merge_ids_rest(buf: i64, then_sa: i64, then_sl: i64, else_sa: i64, else_sl: i64, then_falls: i64, else_falls: i64, names: i64, nmerged: i64, i: i64, acc: i64, clets: i64, outer_n: i64) -> i64 {
    if i >= nmerged {
        return acc;
    }
    let lo: i64 = __mind_load_i64(names + (i * 2 + 0) * 8);
    let hi: i64 = __mind_load_i64(names + (i * 2 + 1) * 8);
    let in_outer: i64 = if nb_lets_lookup_rest(clets, outer_n, buf, lo, hi, 0, 0 - 1) >= 0 {
        1
    } else {
        0
    };
    let then_has: i64 = if in_outer == 1 {
        1
    } else {
        nb_branch_defines(buf, then_sa, then_sl, lo, hi)
    };
    let else_has: i64 = if in_outer == 1 {
        1
    } else {
        nb_branch_defines(buf, else_sa, else_sl, lo, hi)
    };
    let tph: i64 = if then_falls == 1 {
        if then_has == 1 {
            0
        } else {
            1
        }
    } else {
        0
    };
    let eph: i64 = if else_falls == 1 {
        if else_has == 1 {
            0
        } else {
            1
        }
    } else {
        0
    };
    nb_merge_ids_rest(buf, then_sa, then_sl, else_sa, else_sl, then_falls, else_falls, names, nmerged, i + 1, acc + tph + eph + 1, clets, outer_n)
}

// Lower a `let`'s INIT expression: a value if-expr through nb_if_value, anything
// else through nb_expr. A plain tail-return helper (each arm `return`s the
// NbState directly) so the caller binds against a cleanly-projected .last_id —
// `let s = if c { structA } else { structB }` then reading `s.last_id` mis-reads
// the field (value-if-bound struct projection), so we never form that shape.
pub fn nb_lower_let_init(st: NbState, buf: i64, init: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    // is_native_if_value also accepts a one-diverging-branch value-if
    // (`let r = if c { return X; } else { V }`) so it routes to nb_if_value (which
    // matches the count side's generic ast_if id progression) instead of nb_expr's
    // fail-closed const-0 (which desyncs next_id — the diverging-branch mis-lower).
    if is_native_if_value(init) == 1 {
        return nb_if_value(st, buf, init, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    }
    nb_expr(st, buf, init, params_addr, n_params, calls, lets, lcell)
}

// Lower a `while COND { BODY }` statement, mirroring src/native::emit_seq's While
// arm + eval/lower.rs's Node::While lowering byte-for-byte.
//
// SSA-id order (== eval::lower Node::While + assign_slots): COND expr ids ; BODY
// stmt ids ; one exit_id per distinct top-level carried var (each define()'d at
// assign_slots mod.rs:621 BEFORE the union-coalesce, so each DOES add a frame
// slot — counted by nb_count_carried) ; trailing unit.
// Emission (mod.rs 1031-1083):
//   for each carried var: copy init_slot -> post_slot (when slots differ) ;
//   header = len(code) ; emit cond ; cmp/je-exit(cond) ; push loop frame ;
//   emit body ; pop frame ; back-edge jmp (target = header) ; end = len(code) ;
//   patch je -> end ; patch every break -> end. Then the trailing unit const0.
pub fn nb_emit_while(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let cond: i64 = ast_child0(node);
    let body_blk: i64 = ast_child1(node);
    let body_sa: i64 = ast_child0(body_blk);
    let body_sl: i64 = ast_aux(body_blk);

    // Carry analysis: pre-walk cond+body (threading next_id exactly as the emit
    // will) to find each loop-carried var's working post_id + pre-loop init slot.
    // The body walk starts at the post-cond next_id.
    let after_cond_count: i64 = nb_count_expr(st.next_id, buf, cond, params_addr, n_params, lets, lcell);
    // The carry + loop-frame scratch tables (nb_carry_record / nb_loops_push) are
    // fixed 256-cap and NOW CAP-GUARDED: at n >= 256 they fail closed (-1) instead
    // of storing one slot past the buffer and corrupting adjacent arena state
    // (gated by self_host_carry_cap_smoke.py). Not hit by any current fn.
    // deferred: the per-loop `breaks_buf` (nb_loops_push_break) is still uncapped,
    // and grow-on-overflow (vs the current fail-closed cap) remains the richer
    // upgrade — both low-priority until a >256-break or >256-carried-var fn exists.
    // deferred: nb_while_carry sets post_id = arhs-1; a bare `x = y` (ident RHS,
    // no id bump) can desync post_id from the emit last_id. Not hit (stdlib carried
    // assigns all have non-trivial RHS) — upgrade path: special-case ident RHS.
    let carry: i64 = __mind_alloc(256 * 4 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    // FIX #229: the carry pre-walk shares `lets`/`lcell` as its COUNT env (clets),
    // and nb_count_stmt's if-arm rebinds a nested if's merged names (e.g. a
    // `let value_idx` in a diverging `if matched == 1 { .. }` branch — the
    // args_flag_value_idx class in std/cli.mind) into that env. Those bindings are
    // COUNT-ONLY and must be transient: if they leak into the real emit let-env,
    // the subsequent body-emit's nb_merge_fill_defs `in_outer` test wrongly sees
    // the branch-local name as carried-from-outer and elides its else-side
    // ConstI64(0) placeholder (n_else_ph 1 -> 0). That desyncs the emitted if's
    // dst/merge ids from the carry pre-walk's post_id count by one, so the
    // loop-carried var's `i = i + 1` stores to a slot the cond never re-reads —
    // an INFINITE LOOP. Snapshot/restore lcell around the pre-walk exactly like the
    // dst-id pre-walks at nb_if_stmt_(simple|merged) already do; the carry table is
    // fully populated by nb_while_carry, only the env growth is discarded.
    let prewalk_lcell: i64 = __mind_load_i64(lcell);
    let _w: i64 = nb_while_carry(carry, ccell, after_cond_count, buf, body_sa, body_sl, 0, params_addr, n_params, lets, lcell, srt, lets, lcell, prewalk_lcell);
    __mind_store_i64(lcell, prewalk_lcell);
    let ncarry: i64 = __mind_load_i64(ccell);

    // Copy-in each carried var (init_slot -> post_slot) + rebind its let-env to the
    // post_id slot for the cond+body emit (loop_remap).
    let c_copyin: String = nb_while_copyin(st.code, carry, ncarry, 0, buf, lets, lcell);
    let s_copyin: NbState = NbState { code: c_copyin, next_id: st.next_id, last_id: st.last_id, ncalls: st.ncalls };

    // header = current code length (the back-edge target).
    let header: i64 = string_len(c_copyin);

    // cond ; cmp/je-exit(cond==0).
    let sc: NbState = nb_expr(s_copyin, buf, cond, params_addr, n_params, calls, lets, lcell);
    let cond_id: i64 = sc.last_id;
    let c_je: String = nb_emit_cmp_je_zero(sc.code, nb_slot_disp(cond_id), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    let s_je: NbState = NbState { code: c_je, next_id: sc.next_id, last_id: sc.last_id, ncalls: sc.ncalls };

    // Push a loop frame (header + per-loop break list).
    let breaks_buf: i64 = __mind_alloc(256 * 8);
    let _lp: i64 = nb_loops_push(loops, lpcell, header, breaks_buf);

    // body.
    let s_body: NbState = nb_block_stmts(s_je, buf, body_sa, body_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);

    // back-edge: jmp to header. Record + set its target immediately (backward, so
    // nb_patch_jmps computes a negative rel32 — nb_patch_rel32 handles the sign).
    let c_back: String = nb_emit_jmp(s_body.code, jmps, jcell);
    let back_which: i64 = __mind_load_i64(jcell) - 1;
    let _pb: i64 = nb_jmp_set_target(jmps, jcell, back_which, header);

    // end = current code length. Patch the je-exit and every break to here.
    let end_at: i64 = string_len(c_back);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, end_at);
    let _pbr: i64 = nb_while_patch_breaks(loops, lpcell, jmps, jcell, end_at, 0);
    let _pop: i64 = nb_loops_pop(lpcell);

    // exit_ids (lower.rs 4801): one fresh SSA id per carried var, allocated AFTER
    // the body and BEFORE the unit. They emit NO code (each coalesces onto its
    // post_id slot, so post-loop reads of the var already resolve correctly via the
    // let-env binding to post_id), but they DO occupy frame slot indices — so the
    // emit must advance next_id past them, exactly as the count arm adds ncarry, to
    // keep the unit's slot index (and every later id) aligned with the counted frame.
    let after_exit: i64 = s_body.next_id + ncarry;

    // The while-statement yields a unit i64 placeholder (lower.rs 4815) at slot
    // after_exit; post-loop reads of carried vars resolve through post_id (the
    // let-env is already bound to post_id, the exit_id's coalesced slot).
    let s_end: NbState = NbState { code: c_back, next_id: after_exit, last_id: s_je.last_id, ncalls: s_body.ncalls };
    nb_emit_const0(s_end)
}

// Patch every recorded break jmp (for the innermost loop frame) to `end_at`.
pub fn nb_while_patch_breaks(loops: i64, lpcell: i64, jmps: i64, jcell: i64, end_at: i64, i: i64) -> i64 {
    let n: i64 = __mind_load_i64(lpcell);
    if n <= 0 {
        return 0;
    }
    let nb: i64 = __mind_load_i64(loops + ((n - 1) * 3 + 2) * 8);
    if i >= nb {
        return 0;
    }
    let bb: i64 = __mind_load_i64(loops + ((n - 1) * 3 + 1) * 8);
    let which: i64 = __mind_load_i64(bb + i * 8);
    let _p: i64 = nb_jmp_set_target(jmps, jcell, which, end_at);
    nb_while_patch_breaks(loops, lpcell, jmps, jcell, end_at, i + 1)
}

// Lower one body statement: a `return EXPR` lowers EXPR then the return; an `if`
// statement lowers per the src/native If arm; any other (bare expr) lowers the
// expr. `jmps`/`jcell` are the intra-fn forward-jump scratch (used by the If arm).
pub fn nb_stmt(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let k: i64 = ast_kind(node);
    if k == ast_return() {
        // FIX #175: a value-if in RETURN position (`return if c { A } else { B }`) must
        // lower through the real branch/merge path — nb_if_value has the jmp table — NOT
        // nb_expr, whose in-expression ast_if arm fail-closes to a silent const-0 (#171), a
        // SILENT WRONG ANSWER (0 for every input, even for integers). Route it exactly as
        // nb_lower_let_init does, then apply the same dtype-keyed return-register selection
        // (#166). Early-return statement form (both branches would be NbState struct calls,
        // the mis-lower trap). main.mind's fns never `return` a value-if, so this branch is
        // inert during self-compile and the integer native-ELF oracle is byte-identical.
        let ret_operand: i64 = ast_child0(node);
        if is_any_value_if_expr(ret_operand) == 1 {
            let sv: NbState = nb_if_value(st, buf, ret_operand, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
            let rvdt: i64 = nb_node_dtype_tbl(ret_operand, __mind_load_i64(lcell + 8), lets, lcell, buf, params_addr, n_params);
            let cv: String = if rvdt == nb_dtype_float() {
                nb_fp_movsd_load_xmm0(sv.code, nb_slot_disp(sv.last_id))
            } else {
                nb_load_rax(sv.code, nb_slot_disp(sv.last_id))
            };
            // C2 return-width driver: wrap at the enclosing fn's declared return
            // width (lcell+72; 64 = no-op for every main.mind fn -> byte-identical).
            let cvw: String = nb_wrap_ret_w(cv, __mind_load_i64(lcell + 72));
            let cv2: String = nb_emit_return(cvw, is_entry);
            return NbState { code: cv2, next_id: sv.next_id, last_id: sv.last_id, ncalls: sv.ncalls };
        }
        let s1: NbState = nb_expr(st, buf, ret_operand, params_addr, n_params, calls, lets, lcell);
        // FIX #166: SysV return-register selection by the RETURNED VALUE's dtype. An
        // explicit `return <float>` must place its result in xmm0 (movsd), NOT rax — the
        // implicit tail-return path (nb_finish_body) already does this, and an explicit
        // return that loads rax leaves a stale xmm0 so the caller's xmm0 spill reads
        // garbage. Classify the return operand off the per-fn dtype table (lcell+8);
        // an INT/pointer return keeps the rax path unchanged. main.mind's fns all return
        // INT (float-free source), so ret_dt166 is always INT here and this is byte-identical.
        let ret_dt166: i64 = nb_node_dtype_tbl(ast_child0(node), __mind_load_i64(lcell + 8), lets, lcell, buf, params_addr, n_params);
        let c1: String = if ret_dt166 == nb_dtype_float() {
            nb_fp_movsd_load_xmm0(s1.code, nb_slot_disp(s1.last_id))
        } else {
            nb_load_rax(s1.code, nb_slot_disp(s1.last_id))
        };
        // C2 return-width driver: an explicit `return E` in a narrow-int-returning
        // fn (`-> i8/i16/i32 {`) wraps rax at the declared width from lcell+72
        // (stashed by nb_lower_fn). A narrow width only comes from an int
        // spelling, so it never coexists with the float branch above. 64 for every
        // main.mind fn -> nb_wrap_ret_w emits nothing, byte-identical.
        let c1w: String = nb_wrap_ret_w(c1, __mind_load_i64(lcell + 72));
        let c2: String = nb_emit_return(c1w, is_entry);
        return NbState { code: c2, next_id: s1.next_id, last_id: s1.last_id, ncalls: s1.ncalls };
    }
    if k == ast_let() {
        // `let X = INIT`: lower INIT (value-if-exprs go through the value-if path,
        // mirroring emit_mlir_stmt_env's is_mlir_value_if branch), then bind X to
        // INIT's result slot so later reads resolve to it. child0 = name leaf,
        // child1 = type leaf, child2 = init expr. The init lowering is routed
        // through nb_lower_let_init (a tail-return helper) so it reads cleanly.
        let name_leaf: i64 = ast_child0(node);
        let init: i64 = ast_child2(node);
        // Snapshot the let-env BEFORE the init: a value-if-EXPRESSION init
        // (nb_if_value_merged) rebinds its internal merged names into the shared
        // let-env, but for an if-expr used as a let-INIT eval/lower.rs threads NONE of
        // them upward (only the bound name X = dst). Restore after the init so those
        // internal phi names do not leak and pollute a later sibling's `in_outer`.
        let pre_init_n: i64 = __mind_load_i64(lcell);
        let s1: NbState = nb_lower_let_init(st, buf, init, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
        __mind_store_i64(lcell, pre_init_n);
        // Record the struct descriptor (struct-LITERAL init OR a struct-typed
        // annotation, else 0) so a later `name.field` read recovers the field's
        // declared index (8*index byte offset). The pick is a helper (if-statement
        // chain), not a value-if-let phi.
        // RI-B1 FOLLOW-UP: propagate the init's dtype onto X's SSA slot in the per-fn
        // table, so a later `x + 2.5` sees `x` as FLOAT and routes the SSE2 path.
        // Classify BEFORE binding X (X cannot reference itself; the env still holds the
        // prior bindings init's free idents resolve against). Tagging writes only to the
        // heap table (no machine code), and main.mind's float-free source makes every
        // init INT, so this is byte-identical for the integer native-ELF oracle.
        let dtbl: i64 = __mind_load_i64(lcell + 8);
        // FIX #176: prefer the let's DECLARED type annotation (child1) for the slot dtype.
        // The init was lowered then the let-env RESTORED (pre_init_n) above, so re-deriving
        // a value-if init's dtype from its then-branch tail (`if c { let t: f64 = ..; t }`)
        // FAILS — the tail ident `t` is a branch-local no longer in the env, classifying INT
        // — and a later `r + 1.0` then took the wrong GP-integer path. The annotation is
        // authoritative: an f64/f32 declaration tags the slot FLOAT directly. Fall back to
        // the init-derived dtype when there is no float annotation (an un-annotated or
        // non-float let). main.mind declares no f64/f32 lets, so ann_dt is always INT there
        // and init_dt is used unchanged — byte-identical.
        let type_leaf: i64 = ast_child1(node);
        let ann_dt: i64 = if type_leaf != 0 {
            nb_param_is_float(buf, type_leaf)
        } else {
            nb_dtype_int()
        };
        let init_dt_raw: i64 = nb_node_dtype_tbl(init, dtbl, lets, lcell, buf, params_addr, n_params);
        let init_dt: i64 = if ann_dt == nb_dtype_float() {
            nb_dtype_float()
        } else {
            init_dt_raw
        };
        // C2 declared-width AUTO-WRAP driver: a narrow-int annotation (i8/i16/i32)
        // wraps the init's full-64-bit result to its declared width AT THE BINDING —
        // load the init slot, movsx/movsxd (nb_wrap_rax_w), store to a FRESH slot
        // (never in place: an ident init aliases the source binding's slot, and an
        // in-place wrap would corrupt that binding for later readers). X binds to
        // the wrapped slot with its width recorded, so every later read sees the
        // two's-complement-wrapped value and a later `X = ...` re-wraps (assign
        // arm). The fresh id is mirrored in nb_count_stmt's let arm (+1 iff narrow)
        // so the frame is sized for it. declw == 64 for every unannotated / i64 /
        // float / struct let — the entire path below is skipped and the emission is
        // byte-for-byte what it was; main.mind declares no narrow lets, so its
        // self-compile is unchanged. Early-return statement form (mis-lower trap).
        let declw: i64 = nb_width_of_ann(buf, ast_child1(node));
        if declw < 64 {
            let wid: i64 = s1.next_id;
            let cw1: String = nb_load_rax(s1.code, nb_slot_disp(s1.last_id));
            let cw2: String = nb_wrap_rax_w(cw1, declw);
            let cw3: String = nb_store_rax(cw2, nb_slot_disp(wid));
            let _bw: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), wid, nb_let_descriptor(init, ast_child1(node), buf, srt), declw);
            let _dtw: i64 = nb_dtype_tag_slot(dtbl, wid, init_dt);
            return NbState { code: cw3, next_id: wid + 1, last_id: wid, ncalls: s1.ncalls };
        }
        let _b: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id, nb_let_descriptor(init, ast_child1(node), buf, srt), declw);
        let _dt: i64 = nb_dtype_tag_slot(dtbl, s1.last_id, init_dt);
        return s1;
    }
    if k == ast_if() {
        // A value if-EXPRESSION used as a statement goes through the value path
        // (then_result/else_result = the branch values); a plain if-statement
        // (diverging or unit) through nb_if_stmt.
        if is_any_value_if_expr(node) == 1 {
            return nb_if_value(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
        }
        return nb_if_stmt(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    }
    if k == ast_while() {
        return nb_emit_while(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    }
    if k == ast_assign() {
        // `NAME = VALUE`: lower VALUE, then rebind NAME's let-env to the result slot
        // (last-match-wins covers reassignment). The rebind is env-only — no instr,
        // no new id (mirrors body_env.insert @lower.rs 4724). next_id/last_id pass
        // through from the RHS lowering.
        let name_leaf: i64 = ast_child0(node);
        // FIX #175: a value-if RHS (`x = if c { A } else { B }`) must lower through the real
        // branch/merge path (nb_if_value has the jmp table), NOT nb_expr, whose in-expression
        // ast_if arm fail-closes to a silent const-0 (#171) — a SILENT WRONG ANSWER. Route it
        // as nb_lower_let_init does, then rebind NAME to the if's dst slot with its inherited
        // dtype. Early-return statement form (the mis-lower trap). main.mind never assigns a
        // value-if, so this branch is inert during self-compile — byte-identical.
        let rhs_node: i64 = ast_child2(node);
        if is_any_value_if_expr(rhs_node) == 1 {
            let sv: NbState = nb_if_value(st, buf, rhs_node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
            let dtblv: i64 = __mind_load_i64(lcell + 8);
            let rhsdtv: i64 = nb_node_dtype_tbl(rhs_node, dtblv, lets, lcell, buf, params_addr, n_params);
            // C2 declared-width driver: a value-if RHS assigned to a narrow-declared
            // NAME wraps the merged dst to NAME's width, exactly like the plain-RHS
            // arm below (count side adds the id unconditionally for narrow assigns,
            // so both RHS shapes stay frame-consistent). pwv == 64 for every
            // all-i64 module -> the block is skipped, byte-identical.
            let pwv: i64 = nb_lets_lookup_width(lets, lcell, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
            if pwv < 64 {
                let widv: i64 = sv.next_id;
                let cv1: String = nb_load_rax(sv.code, nb_slot_disp(sv.last_id));
                let cv2: String = nb_wrap_rax_w(cv1, pwv);
                let cv3: String = nb_store_rax(cv2, nb_slot_disp(widv));
                let _bwv: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), widv, 0, pwv);
                let _dtwv: i64 = nb_dtype_tag_slot(dtblv, widv, rhsdtv);
                return NbState { code: cv3, next_id: widv + 1, last_id: widv, ncalls: sv.ncalls };
            }
            let _bv: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), sv.last_id, 0, 64);
            let _dtv: i64 = nb_dtype_tag_slot(dtblv, sv.last_id, rhsdtv);
            return sv;
        }
        let s1: NbState = nb_expr(st, buf, ast_child2(node), params_addr, n_params, calls, lets, lcell);
        // FIX #167: propagate the RHS dtype onto the REBOUND slot, mirroring the let-INIT
        // arm (22258-22260). Without this a `y = 3.0 * 2.0` rebind leaves y's slot reading
        // INT (nb_dtype_get defaults INT), so a later `g(y)` marshals the float arg in the
        // GP pool (rdi) while the callee (nb_param_is_float) reads xmm — wrong register
        // file. Classify the RHS via the per-fn table; the rebind env already holds the
        // prior bindings the RHS resolves against. main.mind's source is float-free, so the
        // RHS is always INT here and the slot tag stays INT — byte-identical.
        let dtbl167: i64 = __mind_load_i64(lcell + 8);
        let rhs_dt167: i64 = nb_node_dtype_tbl(ast_child2(node), dtbl167, lets, lcell, buf, params_addr, n_params);
        // C2 declared-width AUTO-WRAP driver (assign form): `X = VALUE` on a
        // narrow-DECLARED X (its let recorded width 8/16/32) re-wraps the RHS to
        // X's width into a fresh slot before the rebind — so `x = x + 1` on an i8
        // wraps two's-complement each iteration. Looked up BEFORE the rebind (the
        // pre-assign binding holds the declared width; the rebind re-records it).
        // pw == 64 for every unannotated/i64 name -> skipped, byte-identical.
        // Mirrored in nb_count_stmt's assign arm (+1 iff narrow). Early-return form.
        let pw: i64 = nb_lets_lookup_width(lets, lcell, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
        if pw < 64 {
            let wida: i64 = s1.next_id;
            let ca1: String = nb_load_rax(s1.code, nb_slot_disp(s1.last_id));
            let ca2: String = nb_wrap_rax_w(ca1, pw);
            let ca3: String = nb_store_rax(ca2, nb_slot_disp(wida));
            let _bwa: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), wida, 0, pw);
            let _dtwa: i64 = nb_dtype_tag_slot(dtbl167, wida, rhs_dt167);
            return NbState { code: ca3, next_id: wida + 1, last_id: wida, ncalls: s1.ncalls };
        }
        let _b: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id, 0, 64);
        let _dt167: i64 = nb_dtype_tag_slot(dtbl167, s1.last_id, rhs_dt167);
        return s1;
    }
    if k == ast_break() {
        // `break` — emit the leading ConstI64(unit,0) (lower.rs 5967), then a jmp
        // whose target is the loop end (patched at loop close). Record its index in
        // the innermost loop frame's break list.
        let s0: NbState = nb_emit_const0(st);
        let c1: String = nb_emit_jmp(s0.code, jmps, jcell);
        let which: i64 = __mind_load_i64(jcell) - 1;
        let _pb: i64 = nb_loops_push_break(loops, lpcell, which);
        return NbState { code: c1, next_id: s0.next_id, last_id: s0.last_id, ncalls: s0.ncalls };
    }
    if k == ast_continue() {
        // `continue` — emit leading const0 then a jmp back to the innermost loop's
        // header (set immediately, a backward target).
        let s0: NbState = nb_emit_const0(st);
        let c1: String = nb_emit_jmp(s0.code, jmps, jcell);
        let which: i64 = __mind_load_i64(jcell) - 1;
        let _pc: i64 = nb_jmp_set_target(jmps, jcell, which, nb_loops_top_header(loops, lpcell));
        return NbState { code: c1, next_id: s0.next_id, last_id: s0.last_id, ncalls: s0.ncalls };
    }
    nb_expr(st, buf, node, params_addr, n_params, calls, lets, lcell)
}

// Lower an `if` STATEMENT (and synthetic-else if-expr-as-statement), mirroring
// src/native::emit_seq's `If` arm + eval/lower.rs's Node::If lowering byte-for-byte.
//
// SSA-id order (== assign_slots first-appearance order; params lowest):
//   cond expr ids ; then leading ConstI64(then_result,0) ; then-block stmt ids ;
//   else leading ConstI64(else_result,0) ; else-block stmt ids ; dst = fresh.
// Emission:
//   emit cond_instrs ; cmp je_zero(cond_id) ;
//   THEN: emit leading const0 ; emit then-stmts ; if then FALLS THROUGH (no
//     terminator): merges(none in this subset) + load then_result/store dst +
//     join jmp ; else (diverged) omit them (the branch emitted its own ret).
//   patch je -> else_at ; ELSE: emit leading const0 ; emit else-stmts ; if else
//     FALLS THROUGH: merges(none) + load else_result/store dst.
//   patch the join jmp (if any) -> end_at.
// An if-statement whose branches WRITE a variable (e.g. `if c { x = .. }`, or a
// branch with a nested while that mutates a body-let) generates merge phis — routed
// through nb_if_stmt_merged. The scalar no-write subset takes the simple path.
pub fn nb_if_stmt(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);
    let else_sa: i64 = if else_blk == 0 {
        0
    } else {
        ast_child0(else_blk)
    };
    let else_sl: i64 = if else_blk == 0 {
        0
    } else {
        ast_aux(else_blk)
    };
    let mnames: i64 = __mind_alloc(256 * 2 * 8);
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, mnames);
    if nmerged == 0 {
        return nb_if_stmt_simple(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    }
    nb_if_stmt_merged(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell)
}

// branch_bindings / merges are empty for the scalar if-statement subset (no
// let-escapes across the branch), matching the fixture's `merges: []`.
pub fn nb_if_stmt_simple(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let cond: i64 = ast_child0(node);
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);

    // cond
    let sc: NbState = nb_expr(st, buf, cond, params_addr, n_params, calls, lets, lcell);
    let cond_id: i64 = sc.last_id;
    let c_je: String = nb_emit_cmp_je_zero(sc.code, nb_slot_disp(cond_id), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    let s_je: NbState = NbState { code: c_je, next_id: sc.next_id, last_id: sc.last_id, ncalls: sc.ncalls };

    // then-block: leading const0, then the then-stmts.
    let s_t0: NbState = nb_emit_const0(s_je);
    let s_tb: NbState = nb_block_stmts(s_t0, buf, then_sa, then_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    // then_result = the value of the LAST statement in the then-block (lower.rs
    // 3915-4015: then_result starts at the leading ConstI64(0) and is re-set to
    // each statement's value as the loop walks; for a then-block whose tail is a
    // NESTED `if`/`while`/call statement-expression the `other =>` arm sets
    // then_result = lower_expr(other) = that nested region's EXIT/dst id). An EMPTY
    // then-block keeps the leading const0 (s_tb == s_t0 ⇒ s_tb.last_id == the
    // const0), so this is byte-identical for the empty/diverging-then subset the
    // earlier rungs covered, and now threads the nested-if exit id for
    // `if cond { if inner { return } } …` (is_digit @ fn#53). The merge-bearing
    // case (a let/assign tail) routes through nb_if_stmt_merged, never here.
    let then_result: i64 = s_tb.last_id;
    let then_diverges: i64 = nb_block_diverges(then_sa, then_sl);
    // If the then-branch falls through: copy then_result -> dst, then jmp to end.
    // The dst id is fresh AFTER the else-block is laid out; we therefore defer the
    // dst-copy to AFTER we know dst's id. But emission order requires the then
    // dst-copy + jmp to appear BEFORE the else block. So compute dst's id by
    // pre-walking the else-block's id count (it does not depend on emitted bytes).
    let else_sa: i64 = if else_blk == 0 {
        0
    } else {
        ast_child0(else_blk)
    };
    let else_sl: i64 = if else_blk == 0 {
        0
    } else {
        ast_aux(else_blk)
    };
    // dst id = (id after else leading const0 + else-stmt ids). next_id after then
    // = s_tb.next_id; else adds 1 (leading const0) + else-stmt id count. The emit-
    // time let-env (lets/lcell) is the count env so any struct field-read offset in
    // the else-block counts the same as it emits.
    let else_const0_id: i64 = s_tb.next_id;
    // dst-id pre-walk is count-only: snapshot/restore lcell so its transient name
    // bindings don't leak into the shared let-env (would pollute an enclosing merge's
    // `in_outer`); the real else-lowering below rebuilds the env.
    let prewalk_n_s: i64 = __mind_load_i64(lcell);
    let after_else: i64 = nb_count_stmts(else_const0_id + 1, buf, else_sa, else_sl, 0, params_addr, n_params, lets, lcell, srt);
    __mind_store_i64(lcell, prewalk_n_s);
    let dst_id: i64 = after_else;

    // then fall-through emit (dst copy + join jmp) — only when not diverging.
    // Routed through a helper fn (NOT a value-if returning a struct) to keep the
    // String-field projection robust.
    let s_tj: NbState = nb_if_then_join(s_tb, then_diverges, then_result, dst_id, jmps, jcell);
    let jmp_which: i64 = nb_last_jmp_which(then_diverges, jcell);

    // else target = current length: patch the je.
    let s_tj_code: String = s_tj.code;
    let else_at: i64 = string_len(s_tj_code);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, else_at);

    // else-block: leading const0, then the else-stmts.
    let s_e0: NbState = nb_emit_const0(s_tj);
    let s_eb: NbState = nb_block_stmts(s_e0, buf, else_sa, else_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    // else_result = the value of the LAST statement in the else-block, the exact
    // dual of then_result (lower.rs 4031-4147). Empty else keeps the leading
    // const0 (s_eb == s_e0), so byte-identical for the synthetic-else subset.
    let else_result: i64 = s_eb.last_id;
    let else_diverges: i64 = nb_block_diverges(else_sa, else_sl);
    // else fall-through: copy else_result -> dst (no jmp; it falls to end).
    let s_ej: NbState = nb_if_else_join(s_eb, else_diverges, else_result, dst_id);

    // end target = current length: patch the join jmp (if any).
    let s_ej_code: String = s_ej.code;
    let end_at: i64 = string_len(s_ej_code);
    let _pe: i64 = nb_maybe_set_jmp(jmp_which, jmps, jcell, end_at);
    // The if's value lives in dst_id; advance next_id past dst (dst = after_else).
    NbState { code: s_ej.code, next_id: dst_id + 1, last_id: dst_id, ncalls: s_ej.ncalls }
}

// If-STATEMENT with merge phis: a branch writes/carries a variable (`if c { x=.. }`
// or a branch with a nested while mutating a body-let). Mirror nb_if_value_merged
// but with divergence handling (a `return`-terminated branch emits no merge edge /
// placeholder / dst-copy) and then_result/else_result = the leading ConstI64 unit
// (an if-statement yields unit). Physical slots in walk order: cond ; then-block +
// then-placeholders (when then falls) ; else-block + else-placeholders (when else
// falls) ; dst ; merges.
pub fn nb_if_stmt_merged(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let cond: i64 = ast_child0(node);
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);
    let else_sa: i64 = if else_blk == 0 {
        0
    } else {
        ast_child0(else_blk)
    };
    let else_sl: i64 = if else_blk == 0 {
        0
    } else {
        ast_aux(else_blk)
    };
    let then_falls: i64 = if nb_block_diverges(then_sa, then_sl) == 1 {
        0
    } else {
        1
    };
    let else_falls: i64 = if nb_block_diverges(else_sa, else_sl) == 1 {
        0
    } else {
        1
    };

    // Snapshot the let-env size BEFORE the branches append branch-local lets — the
    // outer prefix for the merge "in_outer" / outer-value lookups.
    let outer_n: i64 = __mind_load_i64(lcell);
    let mt: i64 = __mind_alloc(256 * 5 * 8 + 256 * 2 * 8);
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, mt2names(mt));
    let _f: i64 = nb_merge_fill_defs(buf, mt, nmerged, 0, then_sa, then_sl, else_sa, else_sl, lets, lcell);
    // A placeholder is only needed on a branch that FALLS THROUGH and lacks the name.
    let _z: i64 = nb_merge_zero_diverged(mt, nmerged, 0, then_falls, else_falls);
    let n_then_ph: i64 = nb_merge_ph_count(mt, nmerged, 0, 0, 0);
    let n_else_ph: i64 = nb_merge_ph_count(mt, nmerged, 0, 1, 0);

    // cond ; je.
    let sc: NbState = nb_expr(st, buf, cond, params_addr, n_params, calls, lets, lcell);
    let cond_id: i64 = sc.last_id;
    let c_je: String = nb_emit_cmp_je_zero(sc.code, nb_slot_disp(cond_id), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    let s_je: NbState = NbState { code: c_je, next_id: sc.next_id, last_id: sc.last_id, ncalls: sc.ncalls };

    // then-block: leading const0 + then-stmts. then_result = the LAST statement's
    // value (lower.rs sets then_result = id after each let/assign, line 3978/3988),
    // which for `if c { x = .. }` is the assign value — NOT the leading const0.
    // Snapshot the let-env size at the branch fork (post-cond) so the else block can
    // be lowered from the SAME incoming env the then block saw — the two branches are
    // mutually exclusive, so the else's variable reads must resolve against the pre-if
    // env, NOT the then block's rebindings/local lets (which are dead on the else path).
    let branch_fork_n: i64 = __mind_load_i64(lcell);
    let s_t0: NbState = nb_emit_const0(s_je);
    let s_tb: NbState = nb_block_stmts(s_t0, buf, then_sa, then_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let then_result: i64 = s_tb.last_id;

    // Physical slot layout (walk order).
    let then_ph_base: i64 = s_tb.next_id;
    let p_t: i64 = then_ph_base + n_then_ph;
    // The dst-id pre-walk is COUNTING only; its let-env mutations must be fully
    // transient — the real else-lowering below rebuilds the env. Snapshot/restore
    // lcell around it so the pre-walk's branch-local (and merged) name bindings do
    // NOT leak into the shared let-env and pollute an INNER else-merge's `in_outer`.
    let prewalk_n_t: i64 = __mind_load_i64(lcell);
    let after_else_stmts: i64 = nb_count_stmts(p_t + 1, buf, else_sa, else_sl, 0, params_addr, n_params, lets, lcell, srt);
    __mind_store_i64(lcell, prewalk_n_t);
    let else_ph_base: i64 = after_else_stmts;
    let dst_id: i64 = after_else_stmts + n_else_ph;
    let merge_base: i64 = dst_id + 1;
    let _a: i64 = nb_merge_assign_slots(mt, nmerged, 0, then_ph_base, else_ph_base, merge_base);

    // then edge (only when then falls through): placeholders + merge stores +
    // dst-copy + join jmp.
    let s_tj: NbState = nb_if_merged_then_edge(s_tb, buf, mt, nmerged, then_falls, then_result, dst_id, jmps, jcell, lets, lcell, then_sa, then_sl, outer_n);
    let jmp_which: i64 = nb_last_jmp_which_mf(then_falls, jcell);

    // else target = je patch.
    let else_at: i64 = string_len(s_tj.code);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, else_at);

    // else-block: leading const0 (slot P_t) + else-stmts. else_result = the last
    // stmt's value (empty else keeps the leading const0).
    // Branch-isolation restore: rewind the let-env to the fork point so the else block
    // reads variables from the INCOMING env, not the then block's rebindings. Fixes the
    // both-branch-same-var else-read miscompile (`let mut x=5; if 1<0 {x=x+1} else {x=x+2}`
    // used to read x as the then's uninitialized fresh slot -> 0+2=2 instead of 5+2=7).
    // Disjoint-var ifs (all of main.mind's own) are unaffected: then's appends never
    // shadow an else read, so the emitted bytes stay identical.
    __mind_store_i64(lcell, branch_fork_n);
    let s_e_in: NbState = NbState { code: s_tj.code, next_id: p_t, last_id: s_tj.last_id, ncalls: s_tj.ncalls };
    let s_e0: NbState = nb_emit_const0(s_e_in);
    let s_eb: NbState = nb_block_stmts(s_e0, buf, else_sa, else_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let else_result: i64 = s_eb.last_id;

    // else edge (only when else falls through): placeholders + merge stores + dst-copy.
    let c_ej: String = nb_if_merged_else_edge(s_eb.code, buf, mt, nmerged, else_falls, else_result, dst_id, lets, lcell, else_sa, else_sl, outer_n);

    let end_at: i64 = string_len(c_ej);
    let _pe: i64 = nb_maybe_set_jmp(jmp_which, jmps, jcell, end_at);

    // Restore the let-env to its PRE-IF size before rebinding the merged names, so the
    // post-`if` env = incoming env + branch_bindings ONLY (the branches' own lets are
    // lexically scoped out, matching eval/lower.rs's per-branch sub-IR cloned env).
    // Prevents a later sibling if's `in_outer` from seeing this if's branch-local
    // names (which would elide the oracle's ConstI64(0) placeholders).
    __mind_store_i64(lcell, outer_n);
    let _rb: i64 = nb_rebind_merges(mt, nmerged, 0, lets, lcell, buf);
    NbState { code: c_ej, next_id: merge_base + nmerged, last_id: dst_id, ncalls: s_eb.ncalls }
}

// Zero out a side's placeholder need when that branch DIVERGES (no cf.br edge, so
// no placeholder/merge value passes — lower.rs 4265/4284 reuse the other side).
pub fn nb_merge_zero_diverged(mt: i64, nmerged: i64, i: i64, then_falls: i64, else_falls: i64) -> i64 {
    if i >= nmerged {
        return 0;
    }
    if then_falls == 0 {
        __mind_store_i64(mt + (i * 5 + 2) * 8, 0)
    }
    if else_falls == 0 {
        __mind_store_i64(mt + (i * 5 + 3) * 8, 0)
    }
    nb_merge_zero_diverged(mt, nmerged, i + 1, then_falls, else_falls)
}

// then-edge of a merging if-statement: if then falls through, emit placeholders,
// per-merge `load then_val ; store merge`, `load then_result ; store dst`, jmp.
pub fn nb_if_merged_then_edge(s_tb: NbState, buf: i64, mt: i64, nmerged: i64, then_falls: i64, then_result: i64, dst_id: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, then_sa: i64, then_sl: i64, outer_n: i64) -> NbState {
    if then_falls == 0 {
        return s_tb;
    }
    let c_ph: String = nb_emit_merge_phs(s_tb.code, mt, nmerged, 0, 0);
    let c_ms: String = nb_emit_merge_stores(c_ph, buf, mt, nmerged, 0, 0, lets, lcell, then_sa, then_sl, outer_n);
    let c1: String = nb_load_rax(c_ms, nb_slot_disp(then_result));
    let c2: String = nb_store_rax(c1, nb_slot_disp(dst_id));
    let c3: String = nb_emit_jmp(c2, jmps, jcell);
    NbState { code: c3, next_id: s_tb.next_id, last_id: s_tb.last_id, ncalls: s_tb.ncalls }
}
// Index of the join jmp record (-1 when then diverged so none was emitted).
pub fn nb_last_jmp_which_mf(then_falls: i64, jcell: i64) -> i64 {
    if then_falls == 0 {
        return 0 - 1;
    }
    __mind_load_i64(jcell) - 1
}
// else-edge of a merging if-statement: if else falls through, emit placeholders,
// per-merge `load else_val ; store merge`, `load else_result ; store dst`.
pub fn nb_if_merged_else_edge(code: String, buf: i64, mt: i64, nmerged: i64, else_falls: i64, else_result: i64, dst_id: i64, lets: i64, lcell: i64, else_sa: i64, else_sl: i64, outer_n: i64) -> String {
    if else_falls == 0 {
        return code;
    }
    let c_ph: String = nb_emit_merge_phs(code, mt, nmerged, 0, 1);
    let c_ms: String = nb_emit_merge_stores(c_ph, buf, mt, nmerged, 0, 1, lets, lcell, else_sa, else_sl, outer_n);
    let c1: String = nb_load_rax(c_ms, nb_slot_disp(else_result));
    nb_store_rax(c1, nb_slot_disp(dst_id))
}

// Lower an if-EXPRESSION used as a value (`let X = if C {A} else {B}` or a value
// if-expr-as-statement), mirroring src/native::emit_seq's `If` arm + eval/lower.rs
// Node::If lowering byte-for-byte. The crucial difference from nb_if_stmt: a value
// block's then_result/else_result is the trailing VALUE EXPRESSION's slot (A / B),
// NOT the leading ConstI64(0) — and BOTH branches fall through (a value block
// never ends in a terminator).
//
// SSA-id order (== eval::lower Node::If; params lowest):
//   cond expr ids ; then leading ConstI64(0) ; then-block stmt ids (incl. the
//   trailing value-expr's instrs) ; else leading ConstI64(0) ; else-block stmt
//   ids ; dst = fresh.
// Emission (matches the Rust If arm with then_falls && else_falls):
//   cond_instrs ; cmp/je(cond) ; then const0 ; then-stmts ;
//   load then_result; store dst; jmp(join) ; patch je->else_at ;
//   else const0 ; else-stmts ; load else_result; store dst ; patch jmp->end_at.
pub fn nb_if_value(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);

    // A value-if whose branches WRITE no variables has no merge phis (the common
    // scalar `if a > b { a } else { b }` shape) — take the simple path, byte-
    // identical to the pre-merge emitter. Otherwise route through the merge path.
    let mnames: i64 = __mind_alloc(256 * 2 * 8);
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, mnames);
    if nmerged == 0 {
        return nb_if_value_simple(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    }
    nb_if_value_merged(st, buf, node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell)
}

// Simple value-if (no merges): the original byte-exact path. Both branches fall
// through; then_result/else_result are the branch values.
pub fn nb_if_value_simple(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let cond: i64 = ast_child0(node);
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);

    // cond
    let sc: NbState = nb_expr(st, buf, cond, params_addr, n_params, calls, lets, lcell);
    let cond_id: i64 = sc.last_id;
    let c_je: String = nb_emit_cmp_je_zero(sc.code, nb_slot_disp(cond_id), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    let s_je: NbState = NbState { code: c_je, next_id: sc.next_id, last_id: sc.last_id, ncalls: sc.ncalls };

    // then-block: leading const0, then the then value-expr (its trailing slot is
    // the then_result). A value block usually falls through; but a value-if branch
    // may DIVERGE (`if c { return 0.0; } else { 2.5 }`) — its last statement is a
    // `return` that exits the fn, contributing NO merge value. FIX (diverging-branch
    // value-if): mirror nb_if_stmt_simple's divergence handling — a diverging branch
    // emits no dst-copy/join-jmp, and the non-diverging branch's value flows to dst.
    // Without this the join hardcoded then_diverges=0, laying dead dst-copy/jmp after
    // the `ret` and (worse) patching a join jmp that was never the live edge, so dst
    // read a stale/wrong slot. main.mind's value-ifs never diverge a branch, so both
    // diverges are 0 there and this is byte-identical to the integer native-ELF oracle.
    let s_t0: NbState = nb_emit_const0(s_je);
    let s_tb: NbState = nb_block_stmts(s_t0, buf, then_sa, then_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let then_result: i64 = s_tb.last_id;
    let then_diverges: i64 = nb_block_diverges(then_sa, then_sl);

    // dst id is fresh AFTER the whole else-block is laid out; pre-walk to find it
    // (a pure function of the IR id-numbering, independent of emitted bytes). next
    // after then = s_tb.next_id; else adds 1 (leading const0) + else-stmt ids.
    let else_const0_id: i64 = s_tb.next_id;
    // dst-id pre-walk is count-only: snapshot/restore lcell (see nb_if_stmt_simple).
    let prewalk_n_vs: i64 = __mind_load_i64(lcell);
    let after_else: i64 = nb_count_stmts(else_const0_id + 1, buf, else_sa, else_sl, 0, params_addr, n_params, lets, lcell, srt);
    __mind_store_i64(lcell, prewalk_n_vs);
    let dst_id: i64 = after_else;

    // then fall-through: load then_result; store dst; jmp(join) — skipped when the
    // then-branch diverges (nb_if_then_join passes through, no join jmp is recorded).
    let s_tj: NbState = nb_if_then_join(s_tb, then_diverges, then_result, dst_id, jmps, jcell);
    let jmp_which: i64 = nb_last_jmp_which(then_diverges, jcell);

    // else target = current length: patch the je.
    let s_tj_code: String = s_tj.code;
    let else_at: i64 = string_len(s_tj_code);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, else_at);

    // else-block: leading const0, then the else value-expr (trailing = else_result).
    let s_e0: NbState = nb_emit_const0(s_tj);
    let s_eb: NbState = nb_block_stmts(s_e0, buf, else_sa, else_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let else_result: i64 = s_eb.last_id;
    let else_diverges: i64 = nb_block_diverges(else_sa, else_sl);
    // else fall-through: load else_result; store dst (no jmp; it falls to end) —
    // skipped when the else-branch diverges (its `return` already exited the fn).
    let s_ej: NbState = nb_if_else_join(s_eb, else_diverges, else_result, dst_id);

    // end target = current length: patch the join jmp (if one was emitted).
    let s_ej_code: String = s_ej.code;
    let end_at: i64 = string_len(s_ej_code);
    let _pe: i64 = nb_maybe_set_jmp(jmp_which, jmps, jcell, end_at);
    // The if's value lives in dst_id; advance next_id past dst.
    NbState { code: s_ej.code, next_id: dst_id + 1, last_id: dst_id, ncalls: s_ej.ncalls }
}

// Value-if WITH merge phis (a branch writes/carries a variable). Mirror
// lower.rs's Node::If merge machinery + the native If arm's phi-forwarding
// (mod.rs 988-1011). Both branches of a value-if fall through.
//
// CRITICAL slot-ordering note: the native backend's frame slots are assigned in
// assign_slots' FIRST-APPEARANCE WALK order (mod.rs 588-595: walk cond ; walk
// then ; walk else ; define dst ; define each merge), NOT in lower.rs's SSA-id
// order (which allocates the merge placeholders/ids AFTER both branches). The
// nb_* backend uses slot == its-own running counter, so to reproduce the oracle's
// PHYSICAL slots we assign slots in WALK order: cond ; then-leading + then-stmts +
// then-placeholders ; else-leading + else-stmts + else-placeholders ; dst ; merges.
// (The placeholder ConstI64s live inside their branch's instruction list, so they
// occupy IN-BRANCH slots; dst precedes the merge ids.) The SSA ids never appear in
// the output — only these physical slots (disps) do — so slot==walk-counter is
// byte-identical to assign_slots.
//
// Merge table: 5 words per name (lo, hi, then_ph_slot, else_ph_slot, merge_slot).
// A side that LACKS the name gets a placeholder slot (>=0) emitted in that branch;
// a side that DEFINES it gets -1 (its merge val is the name's let-env slot at the
// branch exit).
pub fn nb_if_value_merged(st: NbState, buf: i64, node: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    let cond: i64 = ast_child0(node);
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_blk: i64 = ast_child2(node);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);

    // Snapshot the outer let-env size (prefix before the branches' branch-local lets).
    let outer_n: i64 = __mind_load_i64(lcell);
    // Merge table: (lo, hi, then_ph, else_ph, merge) × 64, + a stride-2 names scratch.
    let mt: i64 = __mind_alloc(256 * 5 * 8 + 256 * 2 * 8);
    let nmerged: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, mt2names(mt));
    // Per name: which side lacks it (-> needs a placeholder there). Both branches of
    // a value-if fall through. Copy (lo,hi) into the table and stamp then/else "def".
    let _f: i64 = nb_merge_fill_defs(buf, mt, nmerged, 0, then_sa, then_sl, else_sa, else_sl, lets, lcell);
    let n_then_ph: i64 = nb_merge_ph_count(mt, nmerged, 0, 0, 0);
    let n_else_ph: i64 = nb_merge_ph_count(mt, nmerged, 0, 1, 0);

    // cond ; je-exit.
    let sc: NbState = nb_expr(st, buf, cond, params_addr, n_params, calls, lets, lcell);
    let cond_id: i64 = sc.last_id;
    let c_je: String = nb_emit_cmp_je_zero(sc.code, nb_slot_disp(cond_id), jmps, jcell);
    let je_which: i64 = __mind_load_i64(jcell) - 1;
    let s_je: NbState = NbState { code: c_je, next_id: sc.next_id, last_id: sc.last_id, ncalls: sc.ncalls };

    // Snapshot the let-env size at the branch fork (post-cond) so the else block can be
    // lowered from the SAME incoming env the then block saw — the two branches are
    // mutually exclusive, so the else's variable reads must resolve against the pre-if
    // env, NOT the then block's rebindings/local lets (dead on the else path).
    let branch_fork_n: i64 = __mind_load_i64(lcell);
    // then-block: leading const0 + then-stmts.
    let s_t0: NbState = nb_emit_const0(s_je);
    let s_tb: NbState = nb_block_stmts(s_t0, buf, then_sa, then_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let then_result: i64 = s_tb.last_id;

    // PHYSICAL slot layout (walk order):
    //   then-placeholder slots = [s_tb.next_id, +n_then_ph)
    //   else block starts at P_t = s_tb.next_id + n_then_ph
    //   else-stmt slots via pre-walk from P_t+1 (leading const0 is P_t)
    //   else-placeholder slots = [after_else_stmts, +n_else_ph)
    //   dst = after_else_stmts + n_else_ph
    //   merge slots = [dst+1, +nmerged)
    let then_ph_base: i64 = s_tb.next_id;
    let p_t: i64 = then_ph_base + n_then_ph;
    // dst-id pre-walk is count-only: snapshot/restore lcell (see nb_if_stmt_merged).
    let prewalk_n_vm: i64 = __mind_load_i64(lcell);
    let after_else_stmts: i64 = nb_count_stmts(p_t + 1, buf, else_sa, else_sl, 0, params_addr, n_params, lets, lcell, srt);
    __mind_store_i64(lcell, prewalk_n_vm);
    let else_ph_base: i64 = after_else_stmts;
    let dst_id: i64 = after_else_stmts + n_else_ph;
    let merge_base: i64 = dst_id + 1;
    // Stamp the placeholder slots (per side) + merge slot into the table.
    let _a: i64 = nb_merge_assign_slots(mt, nmerged, 0, then_ph_base, else_ph_base, merge_base);

    // then side: emit then-placeholder const0s (in-branch slots), then per-merge
    // `load then_val ; store merge`. then_val = placeholder slot (then lacks) or the
    // name's let-env slot at then-exit (then defines it).
    let c_tph: String = nb_emit_merge_phs(s_tb.code, mt, nmerged, 0, 0);
    let c_tms: String = nb_emit_merge_stores(c_tph, buf, mt, nmerged, 0, 0, lets, lcell, then_sa, then_sl, outer_n);
    // then fall-through: load then_result ; store dst ; jmp(join).
    let c_tj1: String = nb_load_rax(c_tms, nb_slot_disp(then_result));
    let c_tj2: String = nb_store_rax(c_tj1, nb_slot_disp(dst_id));
    let c_tj: String = nb_emit_jmp(c_tj2, jmps, jcell);
    let jmp_which: i64 = __mind_load_i64(jcell) - 1;

    // else target = current length: patch the je.
    let else_at: i64 = string_len(c_tj);
    let _pj: i64 = nb_jmp_set_target(jmps, jcell, je_which, else_at);

    // else-block: leading const0 (slot P_t) + else-stmts.
    // Branch-isolation restore: rewind the let-env to the fork point so the else block
    // reads variables from the INCOMING env, not the then block's rebindings/locals. Fixes
    // the both-branch-same-var else-read miscompile (`let mut x=5; if 1<0 {x=x+1} else
    // {x=x+2}` -> the else used to read x as the then's uninitialized fresh slot, 0+2=2
    // instead of 5+2=7). The then-side merge stores (c_tms) above already resolved the
    // then-defined values from env-after-then, so truncating here is safe. Disjoint-var
    // value-ifs (all of main.mind's own) are unaffected: then's appends never shadow an
    // else read, so the emitted bytes stay identical.
    __mind_store_i64(lcell, branch_fork_n);
    let s_e_in: NbState = NbState { code: c_tj, next_id: p_t, last_id: s_tb.last_id, ncalls: s_tb.ncalls };
    let s_e0: NbState = nb_emit_const0(s_e_in);
    let s_eb: NbState = nb_block_stmts(s_e0, buf, else_sa, else_sl, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    let else_result: i64 = s_eb.last_id;

    // else side: emit else-placeholder const0s, then per-merge `load else_val ;
    // store merge`. else_val = placeholder slot or the name's let-env slot.
    let c_eph: String = nb_emit_merge_phs(s_eb.code, mt, nmerged, 0, 1);
    let c_ems: String = nb_emit_merge_stores(c_eph, buf, mt, nmerged, 0, 1, lets, lcell, else_sa, else_sl, outer_n);
    // else fall-through: load else_result ; store dst (falls straight to end).
    let c_ej1: String = nb_load_rax(c_ems, nb_slot_disp(else_result));
    let c_ej: String = nb_store_rax(c_ej1, nb_slot_disp(dst_id));

    // end target = current length: patch the join jmp.
    let end_at: i64 = string_len(c_ej);
    let _pe: i64 = nb_jmp_set_target(jmps, jcell, jmp_which, end_at);

    // Post-if: restore the let-env to its PRE-IF size, then rebind each merged name
    // to its merge slot. This mirrors eval/lower.rs EXACTLY: the post-`if` env =
    // incoming env + the if's branch_bindings (merged names) — the branches' OWN
    // branch-local lets are scoped OUT (lower.rs lowers each branch in a sub-IR with
    // a cloned env). Without the restore, a value-if's branch-local lets (e.g. an
    // else-branch's `z1..z9`) leak into the shared let-env; a SIBLING value-if that
    // happens to reuse the same names then sees them as carried-from-outer and elides
    // the ConstI64(0) placeholders the oracle emits. The merge stores above already
    // consumed the branch-exit slots, so truncating here is safe.
    __mind_store_i64(lcell, outer_n);
    let _rb: i64 = nb_rebind_merges(mt, nmerged, 0, lets, lcell, buf);

    // The value-if's VALUE is dst_id, but the frame also holds the nmerged merge
    // slots (merge_base..merge_base+nmerged), which sit ABOVE dst in physical order.
    // next_id must advance past them so a later sibling's slots don't collide.
    NbState { code: c_ej, next_id: merge_base + nmerged, last_id: dst_id, ncalls: s_eb.ncalls }
}

// The merge table stores 5 words per name; nb_merged_names fills a trailing
// stride-2 (lo,hi) scratch. mt2names returns that scratch base.
pub fn mt2names(mt: i64) -> i64 {
    mt + 256 * 5 * 8
}

// Fill the table's (lo,hi) from the names scratch and stamp the then/else "needs
// placeholder" flags (word2 = 1 when THEN lacks the name, word3 = 1 when ELSE
// lacks it). A side HAS the name (no placeholder) iff it is in the OUTER let-env
// (a `let` bound BEFORE the if — both branch envs clone the outer, so the side
// passes the incoming value, lower.rs's else_env/then_env = env.clone) OR the side
// WRITES it. A placeholder is synthesized only for a branch-LOCAL name the other
// side never sees. Called BEFORE the branches emit, so the let-env is the outer one.
pub fn nb_merge_fill_defs(buf: i64, mt: i64, nmerged: i64, i: i64, then_sa: i64, then_sl: i64, else_sa: i64, else_sl: i64, lets: i64, lcell: i64) -> i64 {
    if i >= nmerged {
        return 0;
    }
    let names: i64 = mt2names(mt);
    let lo: i64 = __mind_load_i64(names + (i * 2 + 0) * 8);
    let hi: i64 = __mind_load_i64(names + (i * 2 + 1) * 8);
    __mind_store_i64(mt + (i * 5 + 0) * 8, lo);
    __mind_store_i64(mt + (i * 5 + 1) * 8, hi);
    let in_outer: i64 = if nb_lets_lookup(lets, lcell, buf, lo, hi) >= 0 {
        1
    } else {
        0
    };
    let then_has: i64 = if in_outer == 1 {
        1
    } else {
        nb_branch_defines(buf, then_sa, then_sl, lo, hi)
    };
    let else_has: i64 = if in_outer == 1 {
        1
    } else {
        nb_branch_defines(buf, else_sa, else_sl, lo, hi)
    };
    let then_lacks: i64 = if then_has == 1 {
        0
    } else {
        1
    };
    let else_lacks: i64 = if else_has == 1 {
        0
    } else {
        1
    };
    __mind_store_i64(mt + (i * 5 + 2) * 8, then_lacks);
    __mind_store_i64(mt + (i * 5 + 3) * 8, else_lacks);
    nb_merge_fill_defs(buf, mt, nmerged, i + 1, then_sa, then_sl, else_sa, else_sl, lets, lcell)
}
// Count placeholders needed on a side (side 0 reads word2, side 1 word3).
pub fn nb_merge_ph_count(mt: i64, nmerged: i64, i: i64, side: i64, acc: i64) -> i64 {
    if i >= nmerged {
        return acc;
    }
    let lacks: i64 = __mind_load_i64(mt + (i * 5 + 2 + side) * 8);
    nb_merge_ph_count(mt, nmerged, i + 1, side, acc + lacks)
}
// Convert the "lacks" flags into actual PHYSICAL slots: word2 -> then placeholder
// slot (from then_ph_base, consecutively) or -1; word3 -> else placeholder slot or
// -1; word4 = merge slot (from merge_base, consecutively for every name).
pub fn nb_merge_assign_slots(mt: i64, nmerged: i64, i: i64, then_next: i64, else_next: i64, merge_next: i64) -> i64 {
    if i >= nmerged {
        return 0;
    }
    let then_lacks: i64 = __mind_load_i64(mt + (i * 5 + 2) * 8);
    let then_slot: i64 = if then_lacks == 1 {
        then_next
    } else {
        0 - 1
    };
    let then_adv: i64 = if then_lacks == 1 {
        then_next + 1
    } else {
        then_next
    };
    let else_lacks: i64 = __mind_load_i64(mt + (i * 5 + 3) * 8);
    let else_slot: i64 = if else_lacks == 1 {
        else_next
    } else {
        0 - 1
    };
    let else_adv: i64 = if else_lacks == 1 {
        else_next + 1
    } else {
        else_next
    };
    __mind_store_i64(mt + (i * 5 + 2) * 8, then_slot);
    __mind_store_i64(mt + (i * 5 + 3) * 8, else_slot);
    __mind_store_i64(mt + (i * 5 + 4) * 8, merge_next);
    nb_merge_assign_slots(mt, nmerged, i + 1, then_adv, else_adv, merge_next + 1)
}

// Emit the placeholder ConstI64(0)s for THIS branch (side 0=then, 1=else): one per
// merged name whose side slot is a real placeholder (>=0). Stores into that slot.
pub fn nb_emit_merge_phs(code: String, mt: i64, nmerged: i64, i: i64, side: i64) -> String {
    if i >= nmerged {
        return code;
    }
    let slot: i64 = __mind_load_i64(mt + (i * 5 + 2 + side) * 8);
    let c1: String = if slot >= 0 {
        nb_emit_const0_slot(code, slot)
    } else {
        code
    };
    nb_emit_merge_phs(c1, mt, nmerged, i + 1, side)
}
// `mov rax,imm0 ; mov [slot],rax` at a SPECIFIC physical slot.
pub fn nb_emit_const0_slot(code: String, slot: i64) -> String {
    let c1: String = nb_push(code, 72);
    let c2: String = nb_push(c1, 184);
    let c3: String = nb_i64le(c2, 0);
    nb_store_rax(c3, nb_slot_disp(slot))
}

// Emit the per-merge `load val ; store merge_slot` for THIS branch. The val: the
// placeholder slot (when this side lacks the name) OR the name's let-env slot at
// this branch's exit (when the side defines it).
// `sa`/`sl` = THIS side's branch block (to test whether the side WRITES the name);
// `outer_n` = the let-env count BEFORE the branches (the outer prefix). The val:
//   - placeholder slot (this side lacks the name, falls through) -> use it;
//   - this side WRITES the name -> full let-env lookup (the side's value at exit);
//   - else (has via outer, no write) -> outer-prefix lookup (the incoming value),
//     so a SIBLING branch's pollution of the shared let-env is excluded.
pub fn nb_emit_merge_stores(code: String, buf: i64, mt: i64, nmerged: i64, i: i64, side: i64, lets: i64, lcell: i64, sa: i64, sl: i64, outer_n: i64) -> String {
    if i >= nmerged {
        return code;
    }
    let slot_word: i64 = __mind_load_i64(mt + (i * 5 + 2 + side) * 8);
    let merge_slot: i64 = __mind_load_i64(mt + (i * 5 + 4) * 8);
    let lo: i64 = __mind_load_i64(mt + (i * 5 + 0) * 8);
    let hi: i64 = __mind_load_i64(mt + (i * 5 + 1) * 8);
    let val: i64 = if slot_word >= 0 {
        slot_word
    } else {
        if nb_branch_defines(buf, sa, sl, lo, hi) == 1 {
            nb_lets_lookup(lets, lcell, buf, lo, hi)
        } else {
            nb_lets_lookup_rest(lets, outer_n, buf, lo, hi, 0, 0 - 1)
        }
    };
    let c1: String = nb_load_rax(code, nb_slot_disp(val));
    let c2: String = nb_store_rax(c1, nb_slot_disp(merge_slot));
    nb_emit_merge_stores(c2, buf, mt, nmerged, i + 1, side, lets, lcell, sa, sl, outer_n)
}

// Rebind each merged name's let-env to its merge slot (post-if dominating value).
pub fn nb_rebind_merges(mt: i64, nmerged: i64, i: i64, lets: i64, lcell: i64, buf: i64) -> i64 {
    if i >= nmerged {
        return 0;
    }
    let lo: i64 = __mind_load_i64(mt + (i * 5 + 0) * 8);
    let hi: i64 = __mind_load_i64(mt + (i * 5 + 1) * 8);
    let merge_slot: i64 = __mind_load_i64(mt + (i * 5 + 4) * 8);
    // FIX #174: propagate the merged variable's FLOAT dtype onto its fresh merge slot.
    // An if-statement branch merge binds the name to a NEW slot (merge_slot); without
    // inheriting the pre-branch dtype the merged var classifies INT, so a later float op
    // over it (`x + 1.0` after `let x: f64 = 1.5; if c { x = 2.5; }`) takes the GP-integer
    // path and returns a wrong value. The outer let-env has been restored to its pre-if
    // size BEFORE this rebind (see nb_if_value_merged / nb_if_stmt_merged), so the lookup
    // resolves the PRE-branch binding; tag merge_slot with its dtype. main.mind's source is
    // float-free, so every merged slot stays INT (the table default) and the integer
    // native-ELF emission is byte-identical.
    let dtbl: i64 = __mind_load_i64(lcell + 8);
    let prior: i64 = if dtbl != 0 {
        nb_lets_lookup(lets, lcell, buf, lo, hi)
    } else {
        0 - 1
    };
    let _dt: i64 = if prior >= 0 {
        nb_dtype_tag_slot(dtbl, merge_slot, nb_dtype_get(dtbl, prior))
    } else {
        0
    };
    // C2 declared-width driver: inherit the merged var's DECLARED width onto the
    // merge_slot rebind (last-match-wins — a 64 here would disable narrow re-wrap
    // on any assign AFTER the if). All-i64 merges look up 64: heap-table only,
    // byte-identical.
    let mergew: i64 = nb_lets_lookup_width(lets, lcell, buf, lo, hi);
    let _b: i64 = nb_lets_bind(lets, lcell, lo, hi, merge_slot, 0, mergew);
    nb_rebind_merges(mt, nmerged, i + 1, lets, lcell, buf)
}

// then-branch join tail: on fall-through, copy then_result -> dst and emit the
// join jmp; on divergence, pass the state through unchanged.
pub fn nb_if_then_join(s_tb: NbState, then_diverges: i64, then_result: i64, dst_id: i64, jmps: i64, jcell: i64) -> NbState {
    if then_diverges == 1 {
        return s_tb;
    }
    let ca: String = nb_load_rax(s_tb.code, nb_slot_disp(then_result));
    let cb: String = nb_store_rax(ca, nb_slot_disp(dst_id));
    let cc: String = nb_emit_jmp(cb, jmps, jcell);
    NbState { code: cc, next_id: s_tb.next_id, last_id: s_tb.last_id, ncalls: s_tb.ncalls }
}

// else-branch join tail: on fall-through, copy else_result -> dst (no jmp; it
// falls straight into the end); on divergence, pass through.
pub fn nb_if_else_join(s_eb: NbState, else_diverges: i64, else_result: i64, dst_id: i64) -> NbState {
    if else_diverges == 1 {
        return s_eb;
    }
    let ca: String = nb_load_rax(s_eb.code, nb_slot_disp(else_result));
    let cb: String = nb_store_rax(ca, nb_slot_disp(dst_id));
    NbState { code: cb, next_id: s_eb.next_id, last_id: s_eb.last_id, ncalls: s_eb.ncalls }
}

// Index of the join jmp record (-1 when the then-branch diverged so none was
// emitted), captured right after nb_if_then_join.
pub fn nb_last_jmp_which(then_diverges: i64, jcell: i64) -> i64 {
    if then_diverges == 1 {
        return 0 - 1;
    }
    __mind_load_i64(jcell) - 1
}

// Patch the join jmp's target iff one was emitted.
pub fn nb_maybe_set_jmp(jmp_which: i64, jmps: i64, jcell: i64, end_at: i64) -> i64 {
    if jmp_which < 0 {
        return 0;
    }
    nb_jmp_set_target(jmps, jcell, jmp_which, end_at)
}

// Lower the body statement sequence.
pub fn nb_block_stmts(st: NbState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64, calls: i64, is_entry: i64, jmps: i64, jcell: i64, lets: i64, lcell: i64, srt: i64, loops: i64, lpcell: i64) -> NbState {
    if i >= stmts_len {
        return st;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: NbState = nb_stmt(st, buf, stmt_node, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);
    nb_block_stmts(s1, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell)
}

// Count the frame slots a function's IR defines (params + every body value), by
// re-walking the body with the SAME SSA numbering nb_expr uses, but emitting
// nothing. The final slot count == the next_id after the body. frame =
// round_up(8 * nslots, 16).
// `clets`/`clcell` are a COUNT-TIME let-env (name -> struct-lit node), the exact
// mirror of the emit-time `lets`/`lcell` so the field-access count can recover a
// field's byte offset (8*declared-index) the same way emission does. The scalar/
// value_if fixtures never bind a struct, so clets stays empty and their counts are
// unchanged. Reuses the 4-word nb_lets_* helpers (only the slit word is read here).
pub fn nb_count_expr(next_id: i64, buf: i64, node: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return next_id + 1;
    }
    // RI-D2 S-C1: a float literal consumes exactly ONE SSA slot, identical to an int
    // literal (nb_expr's ast_float_lit arm emits const+movsd-store into slot `id` and
    // returns id+1). Without this arm a float lit falls to the binop arm and walks a
    // leaf's absent children, faulting; and the frame slot-count would be off. main.mind
    // has no float literals, so this never fires during self-compile — frame sizes and
    // the integer native-ELF emission stay byte-identical.
    if k == ast_float_lit() {
        return next_id + 1;
    }
    if k == ast_ident() {
        return next_id;
    }
    if k == ast_paren() {
        return nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
    }
    if k == ast_struct_lit() {
        // sz + nf + mul + alloc-ptr = 4 ids, then per SOURCE-order field i:
        //   value ids + (i==0 ? 0 : 2 for CONST off + ADD) + 1 store-dst.
        let fields_addr: i64 = ast_child1(node);
        let nfields: i64 = ast_aux(node);
        let after_fields: i64 = nb_count_struct_fields(next_id + 4, buf, fields_addr, nfields, 0, params_addr, n_params, clets, clcell);
        // The struct-lit VALUE is the alloc-ptr slot (next_id+3); no extra id.
        return after_fields;
    }
    if k == ast_field() {
        // recv ids (an ident contributes 0) + (off==0 ? 1 load : 2 off+add + 1 load).
        // Offset resolved via the same helper as emission (no value-if-let phis).
        let recv: i64 = ast_child0(node);
        let after_recv: i64 = nb_count_expr(next_id, buf, recv, params_addr, n_params, clets, clcell);
        let off: i64 = nb_field_offset(recv, node, buf, clets, clcell);
        if off == 0 {
            // offset 0 (or unsupported, counted as the offset-0 single load).
            return after_recv + 1;
        }
        return after_recv + 3;
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let after_args: i64 = nb_count_args(next_id, buf, args_addr, args_len, 0, params_addr, n_params, clets, clcell);
        // RI-D2 S-E1: a `__mind_blas_dot_q16_v` call INLINES the Q16 MAC loop (nb_expr
        // ast_call), consuming 11 SSA slots (result + 10 scratch) rather than the single
        // result slot a normal call takes. The frame count MUST match emission exactly or
        // the inline body's scratch would overrun the frame — so reserve 11 here too.
        if nb_is_blas_dot_q16_v(buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node))) == 1 {
            return after_args + 11;
        }
        // RI-D2 S-E2: a `__mind_blas_dot_i16_v` call INLINES the int16 MAC loop (nb_expr
        // ast_call), consuming 10 SSA slots (result + 9 scratch — one fewer than Q16, which
        // needs a rescale constant) rather than the single result slot a normal call takes.
        // The frame count MUST match emission exactly or the inline body's scratch would
        // overrun the frame — so reserve 10 here too.
        if nb_is_blas_dot_i16_v(buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node))) == 1 {
            return after_args + 10;
        }
        return after_args + 1;
    }
    // FIX #170: unary minus consumes the operand's ids + 1 for the negated result,
    // matching nb_expr's ast_neg arm (recurse operand, then a single neg/subsd result).
    // Without this arm nb_count_expr fell to the binop tail and walked ast_child1 == 0
    // (a null node) -> the frame slot-count would be wrong (or fault). main.mind has no
    // unary-minus node in its native-emitted source, so this never fires there.
    if k == ast_neg() {
        let after_op: i64 = nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
        return after_op + 1;
    }
    // FIX #172: `!x` lowers to operand ; const-0 ; Eq — so it consumes the operand's ids
    // + 2 (the zero slot and the Eq-result slot), matching nb_expr's ast_not arm. Pre-fix
    // this fell to the binop tail and null-deref'd on ast_child1 == 0. main.mind's native
    // source has no `!` here, so this never fires during self-compile.
    if k == ast_not() {
        let nafter_op: i64 = nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
        return nafter_op + 2;
    }
    // FIX #173: a value-if in DEEP EXPRESSION position now lowers through nb_if_value
    // (nb_expr's ast_if arm), so its SSA-id consumption here must MATCH that emit exactly:
    // cond ids ; +1 then-const0 ; then-stmt ids ; +1 else-const0 ; else-stmt ids ;
    // merge-phi ids ; +1 dst — identical to nb_count_stmt's ast_if arm. Unlike a
    // STATEMENT-if, an if-EXPRESSION threads NONE of its internal merged names into the
    // enclosing env (only dst escapes), so snapshot/restore clcell around the count to
    // drop the leak WITHOUT rebinding merged names (mirrors nb_count_stmt's let-init arm).
    // srt is read from clcell+24 (nb_count_expr has no srt param — nb_lower_fn stashes it
    // there, matching the emit lcell). main.mind never nests a value-if in expression
    // position, so this arm is never taken during self-compile — frame sizing byte-identical.
    if k == ast_if() {
        let srt: i64 = __mind_load_i64(clcell + 24);
        let cond: i64 = ast_child0(node);
        let outer_n: i64 = __mind_load_i64(clcell);
        let after_cond: i64 = nb_count_expr(next_id, buf, cond, params_addr, n_params, clets, clcell);
        let then_blk: i64 = ast_child1(node);
        let after_then: i64 = nb_count_stmts(after_cond + 1, buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params, clets, clcell, srt);
        let else_blk: i64 = ast_child2(node);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        let after_else: i64 = nb_count_stmts(after_then + 1, buf, else_sa, else_sl, 0, params_addr, n_params, clets, clcell, srt);
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        let then_falls: i64 = if nb_block_diverges(then_sa, then_sl) == 1 {
            0
        } else {
            1
        };
        let else_falls: i64 = if nb_block_diverges(else_sa, else_sl) == 1 {
            0
        } else {
            1
        };
        let merge_ids: i64 = nb_merge_ids_count(buf, then_sa, then_sl, else_sa, else_sl, then_falls, else_falls, clets, outer_n);
        __mind_store_i64(clcell, outer_n);
        return after_else + merge_ids + 1;
    }
    // NARROWING cast `EXPR as iN`: operand ids + 1 for the movsx result, matching
    // nb_expr's ast_cast arm (recurse operand, then a single movsx result). Without this
    // arm a cast falls to the binop tail and walks ast_child1 == 0 (a null node) -> the
    // frame slot-count would be wrong. main.mind has no cast node in its native-emitted
    // source, so this never fires during self-compile.
    if k == ast_cast() {
        let after_c: i64 = nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
        return after_c + 1;
    }
    // binop
    let l: i64 = nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
    let r: i64 = nb_count_expr(l, buf, ast_child1(node), params_addr, n_params, clets, clcell);
    r + 1
}
// The id count of a struct field's ADDRESS computation: 0 for field 0 (stored at
// the base ptr), 2 for field i>0 (CONST off + ADD). An if-statement helper.
pub fn nb_field_addr_ids(after_val: i64, i: i64) -> i64 {
    if i == 0 {
        return after_val;
    }
    after_val + 2
}

// Count the ids each struct-literal field's store contributes (mirror
// nb_struct_fields): value ids + (i==0 ? 0 : 2) + 1 store-dst, in SOURCE order.
pub fn nb_count_struct_fields(next_id: i64, buf: i64, fields_addr: i64, nfields: i64, i: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64) -> i64 {
    if i >= nfields {
        return next_id;
    }
    let value_node: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    let after_val: i64 = nb_count_expr(next_id, buf, value_node, params_addr, n_params, clets, clcell);
    // i==0 stores at the base ptr (no addr instrs); i>0 adds CONST+ADD (2 ids).
    // Computed via a helper (if-statement) to stay in the self-host subset.
    let after_addr: i64 = nb_field_addr_ids(after_val, i);
    nb_count_struct_fields(after_addr + 1, buf, fields_addr, nfields, i + 1, params_addr, n_params, clets, clcell)
}
pub fn nb_count_args(next_id: i64, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64) -> i64 {
    if i >= args_len {
        return next_id;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let after: i64 = nb_count_expr(next_id, buf, arg_node, params_addr, n_params, clets, clcell);
    nb_count_args(after, buf, args_addr, args_len, i + 1, params_addr, n_params, clets, clcell)
}
// Count DISTINCT loop-carried variable names in a while body (each distinct carried
// var allocates one exit_id @lower.rs 4801 = one frame slot, assign_slots define
// @mod.rs 622). Handled shapes: a TOP-LEVEL `Assign`, and a var an inner DIRECT nested
// `while` reassigns that is OUTER to this loop (F2 promotion, any depth). Dedup is by
// name span (record_loop_mut first-sighting @lower.rs 4615). See the fn comment for the
// SUB-STEP A de-desync: the count is the emit carry pre-walk's own record count.
// deferred: an OUTER var mutated inside an `if`-region in the body (`while{ if{ x+=1 } }`)
// or an if-wrapped inner while is NOT yet carried (Sub-step B/C) — fail-closed today.
// SUB-STEP A (de-desync): the loop-carry frame COUNT is now DERIVED from the SAME
// traversal the emit uses (nb_while_carry), not a separate hand-mirrored count chain.
// Previously two parallel walks (this count chain + nb_while_carry) had to agree on the
// carried-var SET, and every time they drifted the frame count desynced from the emit
// carry table -> a silent miscompile (c27a766 x=1-not-3; 0b5f489 got=2-want=6, and the
// FIX #229 infinite loop). That entire class is retired by construction here: run the
// emit carry pre-walk into a SCRATCH carry table and RETURN ITS RECORD COUNT. There is
// no second computation to drift from.
//
// Byte-neutral vs the old count chain: the old top-level-assign arm recorded every
// distinct top-level assign name (no outer check) -> nb_while_carry's assign arm does
// exactly the same; the old nested arm filtered a nested while's assigns to OUTER vars
// (nb_lets_lookup_rest over [0,entry_n)) deduped -> nb_while_carry_wnest records the
// inner assigns then nb_carry_promote_inner filters to OUTER vars deduped by name, the
// identical resulting SET size. clets is BOTH the count-env and the "let-env" the walk
// reads for membership (a single env exists during counting), so lets==clets here. The
// walk's transient body-let growth (a body `let`/`if` reached via nb_count_stmt) is
// snapshot/restored around the call exactly as nb_emit_while restores prewalk_lcell, so
// clcell is unchanged on return. next_id/params/srt thread the walk identically to the
// emit pre-walk; the threaded post_ids are discarded, only the record COUNT is read.
// The caller invokes this BEFORE the body count (emit-parallel), so the walk sees the
// pre-body incremental clets state the emit pre-walk sees.
pub fn nb_count_carried(buf: i64, body_sa: i64, body_sl: i64, clets: i64, clcell: i64, entry_n: i64, next_id: i64, params_addr: i64, n_params: i64, srt: i64) -> i64 {
    let carry: i64 = __mind_alloc(256 * 4 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    let snap: i64 = __mind_load_i64(clcell);
    let _w: i64 = nb_while_carry(carry, ccell, next_id, buf, body_sa, body_sl, 0, params_addr, n_params, clets, clcell, srt, clets, clcell, entry_n);
    __mind_store_i64(clcell, snap);
    __mind_load_i64(ccell)
}
// True if name span [lo,hi) is already in the names table (0..n).
pub fn nb_name_seen(buf: i64, names: i64, n: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let nlo: i64 = __mind_load_i64(names + (i * 2 + 0) * 8);
    let nhi: i64 = __mind_load_i64(names + (i * 2 + 1) * 8);
    if span_bytes_equal(buf, lo, hi, nlo, nhi) == 1 {
        return 1;
    }
    nb_name_seen(buf, names, n, lo, hi, i + 1)
}
pub fn nb_name_record(names: i64, n: i64, lo: i64, hi: i64) -> i64 {
    __mind_store_i64(names + (n * 2 + 0) * 8, lo);
    __mind_store_i64(names + (n * 2 + 1) * 8, hi);
    0
}

pub fn nb_count_stmt(next_id: i64, buf: i64, node: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_return() {
        return nb_count_expr(next_id, buf, ast_child0(node), params_addr, n_params, clets, clcell);
    }
    if k == ast_let() {
        // `let X = INIT`: X reuses INIT's result slot (no new id), so the slot
        // count is exactly INIT's. Record the count-time name->struct-descriptor
        // binding (struct-literal init OR a struct-typed annotation, else 0) so a
        // later `X.field` read counts the same offset emission does.
        // Snapshot the count-lets BEFORE the init: a value-if-EXPRESSION init rebinds
        // its internal merged names (the `ast_if` arm below), but those are the if's
        // own phis — for an if-expr used as a let-INIT, eval/lower.rs threads NONE of
        // them into the enclosing env (only the bound name X = dst). Restoring here
        // drops that leak so a later sibling's `in_outer` never sees the if-expr's
        // internal merge names. (A statement-if reaches the `ast_if` arm directly and
        // KEEPS its rebound branch_bindings — the threaded post-if env.)
        let pre_init_n: i64 = __mind_load_i64(clcell);
        let after_init: i64 = nb_count_stmt(next_id, buf, ast_child2(node), params_addr, n_params, clets, clcell, srt);
        __mind_store_i64(clcell, pre_init_n);
        let name_leaf: i64 = ast_child0(node);
        let init: i64 = ast_child2(node);
        // C2 declared-width driver (count side): a narrow-int (i8/i16/i32) let
        // consumes ONE extra id at emit (the fresh wrapped slot) — count it here so
        // the frame is sized for it, and record the declared width in the count-lets
        // so the assign arm's count-side lookup agrees with emission. declw == 64
        // for every i64/unannotated let -> identical count, byte-identical frame.
        let declw: i64 = nb_width_of_ann(buf, ast_child1(node));
        let _b: i64 = nb_lets_bind(clets, clcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), 0, nb_let_descriptor(init, ast_child1(node), buf, srt), declw);
        if declw < 64 {
            return after_init + 1;
        }
        return after_init;
    }
    if k == ast_if() {
        // Mirror nb_if_stmt / eval::lower Node::If id assignment:
        //   cond ids ; +1 then-const0 ; then-stmt ids ; +1 else-const0 ;
        //   else-stmt ids ; +1 dst.
        let cond: i64 = ast_child0(node);
        // Snapshot the count-lets size BEFORE the branches append their branch-local
        // lets, so the merge "in_outer" check sees only bindings that existed BEFORE
        // the if (matching the emit, which fills the merge table pre-branch).
        let outer_n: i64 = __mind_load_i64(clcell);
        let after_cond: i64 = nb_count_expr(next_id, buf, cond, params_addr, n_params, clets, clcell);
        let then_blk: i64 = ast_child1(node);
        let after_then: i64 = nb_count_stmts(after_cond + 1, buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params, clets, clcell, srt);
        let else_blk: i64 = ast_child2(node);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        let after_else: i64 = nb_count_stmts(after_then + 1, buf, else_sa, else_sl, 0, params_addr, n_params, clets, clcell, srt);
        // Merge-phi ids (lower.rs 4234-4290): for each var written in either branch,
        // a merge id + a placeholder ConstI64 on each FALL-THROUGH branch lacking
        // the name. Allocated AFTER both branches, BEFORE dst. A diverging branch
        // (last stmt = return) contributes no placeholder.
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        let then_falls: i64 = if nb_block_diverges(then_sa, then_sl) == 1 {
            0
        } else {
            1
        };
        let else_falls: i64 = if nb_block_diverges(else_sa, else_sl) == 1 {
            0
        } else {
            1
        };
        let merge_ids: i64 = nb_merge_ids_count(buf, then_sa, then_sl, else_sa, else_sl, then_falls, else_falls, clets, outer_n);
        // Restore the count-lets to its PRE-IF size, then re-bind ONLY this if's
        // merged names (its branch_bindings). This mirrors eval/lower.rs's post-`if`
        // env exactly: the enclosing block's env = the incoming env + the if's
        // branch_bindings (lower.rs 4289 pushes one per merged name). WITHOUT this
        // restore the branch-LOCAL lets (e.g. an inner-if's `c`/`then_blk` that are
        // NOT exported) leak into the shared count-lets; when this if is the ELSE arm
        // of an enclosing if, the enclosing pre-walk leaves them behind and a
        // subsequent INNER merge's `in_outer` test (nb_merge_fill_defs / the count's
        // nb_merge_ids_rest, both over the outer prefix) then wrongly treats them as
        // carried-from-outer, eliding the ConstI64(0) placeholder the oracle emits.
        // Re-binding the merged names (not the raw branch-local lets) keeps case-(c)
        // tail-region threading visible while dropping the non-exported leakage.
        __mind_store_i64(clcell, outer_n);
        let cmn: i64 = __mind_alloc(256 * 2 * 8);
        let ncmn: i64 = nb_merged_names(buf, then_sa, then_sl, else_sa, else_sl, cmn);
        let _rb: i64 = nb_count_bind_merged(clets, clcell, cmn, ncmn, 0, buf);
        return after_else + merge_ids + 1;
    }
    if k == ast_while() {
        // `while COND { BODY }` id consumption (mirror eval/lower.rs Node::While +
        // assign_slots). SSA order: COND expr ids ; BODY-stmt ids ; ONE exit_id per
        // loop-carried var (lower.rs 4801) ; trailing unit-placeholder id.
        //
        // Frame-slot accounting (assign_slots, mod.rs 597-625): the union at line
        // 623 coalesces each exit_id's slot VALUE onto its post_id — so post-loop
        // reads alias the working slot — but `define(slot, exit_id)` at line 622
        // first inserts a DISTINCT HashMap entry for the exit_id, and the frame is
        // sized by slot.len() (mod.rs 1124-1125), the entry COUNT. So each exit_id
        // adds 1 to the frame even though it physically aliases post_id. NET new
        // slots = (#cond ids) + (#body ids) + (#carried vars) + 1 (unit).
        let cond: i64 = ast_child0(node);
        let after_cond: i64 = nb_count_expr(next_id, buf, cond, params_addr, n_params, clets, clcell);
        let body_blk: i64 = ast_child1(node);
        let body_sa: i64 = ast_child0(body_blk);
        let body_sl: i64 = ast_aux(body_blk);
        // Snapshot the count-lets size BEFORE the body count grows it — this loop's
        // pre-loop scope bound, the outer-membership frontier for the F2 nested-carry
        // count (== the emit pre-walk's prewalk_lcell). Body-local lets appended during
        // after_body are >= this bound and so are never miscounted as outer-carried.
        let pre_body_n: i64 = __mind_load_i64(clcell);
        // SUB-STEP A: derive ncarry from the emit carry pre-walk BEFORE the body count,
        // so the walk sees the pre-body clets state the emit pre-walk (nb_emit_while)
        // sees (nb_count_carried snapshot/restores clcell, leaving it at pre_body_n).
        let ncarry: i64 = nb_count_carried(buf, body_sa, body_sl, clets, clcell, pre_body_n, after_cond, params_addr, n_params, srt);
        let after_body: i64 = nb_count_stmts(after_cond, buf, body_sa, body_sl, 0, params_addr, n_params, clets, clcell, srt);
        return after_body + ncarry + 1;
    }
    if k == ast_assign() {
        // `NAME = VALUE`: VALUE's RHS ids; the rebind is env-only (no new id) —
        // EXCEPT a narrow-DECLARED NAME (C2 declared-width driver), whose emit-side
        // re-wrap consumes one fresh slot: count it via the count-lets width lookup
        // (recorded by the let arm above). Counted for BOTH RHS shapes (plain and
        // value-if) — the value-if emit arm wraps identically. pw == 64 on the
        // all-i64 hot path -> id count unchanged, byte-identical.
        let after_rhs: i64 = nb_count_expr(next_id, buf, ast_child2(node), params_addr, n_params, clets, clcell);
        let aname_leaf: i64 = ast_child0(node);
        let pw: i64 = nb_lets_lookup_width(clets, clcell, buf, ast_span_lo(aname_leaf), ast_span_hi(aname_leaf));
        if pw < 64 {
            return after_rhs + 1;
        }
        return after_rhs;
    }
    if k == ast_break() {
        // `break`/`continue` emit a leading ConstI64(unit,0) (1 fresh id); the
        // terminator itself has no dst (lower.rs 5967-5972).
        return next_id + 1;
    }
    if k == ast_continue() {
        return next_id + 1;
    }
    nb_count_expr(next_id, buf, node, params_addr, n_params, clets, clcell)
}
pub fn nb_count_stmts(next_id: i64, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64, clets: i64, clcell: i64, srt: i64) -> i64 {
    if i >= stmts_len {
        return next_id;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let after: i64 = nb_count_stmt(next_id, buf, stmt_node, params_addr, n_params, clets, clcell, srt);
    nb_count_stmts(after, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params, clets, clcell, srt)
}

// ---- call-site counter (size the calls/call_owner tables exactly) ----
// Walk the SAME expr/stmt tree shape as nb_count_expr / nb_count_stmt (which the
// emitter's nb_expr / nb_block_stmts mirror arm-for-arm) and bump a 1-i64 count
// cell `ccell` at every ast_call() node. This is offset-independent (no clets,
// no SSA ids), so it is a pure structural walk. The total it returns sizes the
// `calls` (3 words/record) and `call_owner` (1 word/record) tables exactly, so
// nb_calls_push / nb_set_owners can never overrun (the old fixed 256 records
// overflowed the bump arena once the module passed 256 call sites, corrupting
// nb_patch_all). Mirrors src/native/mod.rs, which sizes its Vec<CallSite> by the
// real call count rather than a fixed cap.
pub fn nb_ccount_expr(buf: i64, node: i64, ccell: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return 0;
    }
    // RI-D2 S-C1: a float literal is a call-free LEAF (like an int literal). Without
    // this arm it falls through to the binop arm and recurses into a leaf's absent
    // children, faulting on any float-bearing body. main.mind's source has no float
    // literals, so this arm never fires during self-compile; it emits nothing (this
    // walker only SIZES the calls table), so it cannot perturb any byte oracle.
    if k == ast_float_lit() {
        return 0;
    }
    if k == ast_ident() {
        return 0;
    }
    if k == ast_paren() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    if k == ast_struct_lit() {
        let fields_addr: i64 = ast_child1(node);
        let nfields: i64 = ast_aux(node);
        return nb_ccount_struct_fields(buf, fields_addr, nfields, 0, ccell);
    }
    if k == ast_field() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let _a: i64 = nb_ccount_args(buf, args_addr, args_len, 0, ccell);
        __mind_store_i64(ccell, __mind_load_i64(ccell) + 1);
        return 0;
    }
    // FIX #170: unary minus — walk the operand for call sites (a negated call is a call).
    // Pre-fix this fell to the binop tail and recursed into ast_child1 == 0 (null),
    // faulting the call-table sizing walker on any `-EXPR`. main.mind's native source has
    // no unary minus, so this never fires during self-compile.
    if k == ast_neg() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    // FIX #172: `!x` — walk the operand for call sites (a negated call is still a call).
    // Pre-fix this fell to the binop tail and recursed into ast_child1 == 0 (null),
    // faulting the call-table sizing walker on any `!EXPR`. Never fires during self-compile.
    if k == ast_not() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    // FIX #171: a value-if in EXPRESSION position — walk cond + both branch blocks for
    // call sites (over-counting is safe: it only enlarges the calls-table capacity, and
    // nb_expr fail-closes this node so it emits none). Pre-fix it fell to the binop tail
    // and null-deref'd on the block children. Never fires during self-compile (main.mind
    // nests no value-if in expression position).
    if k == ast_if() {
        let ic_cond: i64 = ast_child0(node);
        let _ic: i64 = nb_ccount_expr(buf, ic_cond, ccell);
        let it_blk: i64 = ast_child1(node);
        let _it: i64 = nb_ccount_stmts(buf, ast_child0(it_blk), ast_aux(it_blk), 0, ccell);
        let ie_blk: i64 = ast_child2(node);
        let ie_sa: i64 = if ie_blk == 0 {
            0
        } else {
            ast_child0(ie_blk)
        };
        let ie_sl: i64 = if ie_blk == 0 {
            0
        } else {
            ast_aux(ie_blk)
        };
        return nb_ccount_stmts(buf, ie_sa, ie_sl, 0, ccell);
    }
    // NARROWING cast `EXPR as iN` — walk the operand for call sites (a cast of a call
    // is still a call). Pre-arm this fell to the binop tail and recursed into
    // ast_child1 == 0 (null), faulting the call-table sizing walker on any cast node.
    // Never fires during self-compile (main.mind produces no cast node).
    if k == ast_cast() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    // binop: walk both operands.
    let _l: i64 = nb_ccount_expr(buf, ast_child0(node), ccell);
    nb_ccount_expr(buf, ast_child1(node), ccell)
}
pub fn nb_ccount_struct_fields(buf: i64, fields_addr: i64, nfields: i64, i: i64, ccell: i64) -> i64 {
    if i >= nfields {
        return 0;
    }
    let value_node: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    let _v: i64 = nb_ccount_expr(buf, value_node, ccell);
    nb_ccount_struct_fields(buf, fields_addr, nfields, i + 1, ccell)
}
pub fn nb_ccount_args(buf: i64, args_addr: i64, args_len: i64, i: i64, ccell: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let _a: i64 = nb_ccount_expr(buf, arg_node, ccell);
    nb_ccount_args(buf, args_addr, args_len, i + 1, ccell)
}
pub fn nb_ccount_stmt(buf: i64, node: i64, ccell: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_return() {
        return nb_ccount_expr(buf, ast_child0(node), ccell);
    }
    if k == ast_let() {
        return nb_ccount_stmt(buf, ast_child2(node), ccell);
    }
    if k == ast_if() {
        let cond: i64 = ast_child0(node);
        let _c: i64 = nb_ccount_expr(buf, cond, ccell);
        let then_blk: i64 = ast_child1(node);
        let _t: i64 = nb_ccount_stmts(buf, ast_child0(then_blk), ast_aux(then_blk), 0, ccell);
        let else_blk: i64 = ast_child2(node);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        return nb_ccount_stmts(buf, else_sa, else_sl, 0, ccell);
    }
    if k == ast_while() {
        // `while COND { BODY }`: call sites in the cond + the body statements.
        let cond: i64 = ast_child0(node);
        let _c: i64 = nb_ccount_expr(buf, cond, ccell);
        let body_blk: i64 = ast_child1(node);
        return nb_ccount_stmts(buf, ast_child0(body_blk), ast_aux(body_blk), 0, ccell);
    }
    if k == ast_assign() {
        // `NAME = VALUE`: call sites in the value expr (child2).
        return nb_ccount_expr(buf, ast_child2(node), ccell);
    }
    if k == ast_break() {
        return 0;
    }
    if k == ast_continue() {
        return 0;
    }
    nb_ccount_expr(buf, node, ccell)
}
pub fn nb_ccount_stmts(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, ccell: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let _s: i64 = nb_ccount_stmt(buf, stmt_node, ccell);
    nb_ccount_stmts(buf, stmts_addr, stmts_len, i + 1, ccell)
}
// Count every call site in fn_def `node`'s body.
pub fn nb_ccount_fn(buf: i64, node: i64, ccell: i64) -> i64 {
    let body: i64 = ast_child2(node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    nb_ccount_stmts(buf, stmts_addr, stmts_len, 0, ccell)
}
// Sum the call sites of all ordered fns into ccell; returns the total.
pub fn nb_count_all_calls(buf: i64, ordered: i64, n_fns: i64, k: i64, ccell: i64) -> i64 {
    if k >= n_fns {
        return __mind_load_i64(ccell);
    }
    let node: i64 = __mind_load_i64(ordered + k * 8);
    let _c: i64 = nb_ccount_fn(buf, node, ccell);
    nb_count_all_calls(buf, ordered, n_fns, k + 1, ccell)
}

// RI-C: does any REACHABLE (pruned/emitted) fn body call __mind_argc/__mind_argv?
// The entry argc/argv capture must be emitted iff an EMITTED fn actually references
// argv — NOT merely because a seeded-but-pruned std module (std.cli's args_from_os)
// mentions the intrinsic. Scanning only the pruned `ordered` fn set keeps every
// argv-free program byte-identical even when std.cli is seeded ahead of it (a raw
// whole-buffer token scan would false-trigger on the seeded-but-unreachable mention
// and shift every seeded ELF by the 34-byte capture). Mirrors the nb_ccount_* body
// walk arm-for-arm; returns 1 on the FIRST argv call (short-circuit OR).
pub fn nb_argv_expr(buf: i64, node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        return 0;
    }
    if k == ast_float_lit() {
        return 0;
    }
    if k == ast_ident() {
        return 0;
    }
    if k == ast_paren() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if k == ast_struct_lit() {
        let fields_addr: i64 = ast_child1(node);
        let nfields: i64 = ast_aux(node);
        return nb_argv_struct_fields(buf, fields_addr, nfields, 0);
    }
    if k == ast_field() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        if nb_is_argv_name(buf, ast_span_lo(callee), ast_span_hi(callee)) == 1 {
            return 1;
        }
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        return nb_argv_args(buf, args_addr, args_len, 0);
    }
    if k == ast_neg() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if k == ast_not() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if k == ast_if() {
        let ic_cond: i64 = ast_child0(node);
        if nb_argv_expr(buf, ic_cond) == 1 {
            return 1;
        }
        let it_blk: i64 = ast_child1(node);
        if nb_argv_stmts(buf, ast_child0(it_blk), ast_aux(it_blk), 0) == 1 {
            return 1;
        }
        let ie_blk: i64 = ast_child2(node);
        let ie_sa: i64 = if ie_blk == 0 {
            0
        } else {
            ast_child0(ie_blk)
        };
        let ie_sl: i64 = if ie_blk == 0 {
            0
        } else {
            ast_aux(ie_blk)
        };
        return nb_argv_stmts(buf, ie_sa, ie_sl, 0);
    }
    // NARROWING cast `EXPR as iN` — walk the operand only (child1 == 0). Pre-arm this
    // fell to the binop tail and recursed into ast_child1 == 0 (null), faulting the
    // argv scan on any cast node. Never fires during self-compile.
    if k == ast_cast() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if nb_argv_expr(buf, ast_child0(node)) == 1 {
        return 1;
    }
    nb_argv_expr(buf, ast_child1(node))
}
pub fn nb_argv_struct_fields(buf: i64, fields_addr: i64, nfields: i64, i: i64) -> i64 {
    if i >= nfields {
        return 0;
    }
    let value_node: i64 = __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    if nb_argv_expr(buf, value_node) == 1 {
        return 1;
    }
    nb_argv_struct_fields(buf, fields_addr, nfields, i + 1)
}
pub fn nb_argv_args(buf: i64, args_addr: i64, args_len: i64, i: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    if nb_argv_expr(buf, arg_node) == 1 {
        return 1;
    }
    nb_argv_args(buf, args_addr, args_len, i + 1)
}
pub fn nb_argv_stmt(buf: i64, node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_return() {
        return nb_argv_expr(buf, ast_child0(node));
    }
    if k == ast_let() {
        return nb_argv_stmt(buf, ast_child2(node));
    }
    if k == ast_if() {
        let cond: i64 = ast_child0(node);
        if nb_argv_expr(buf, cond) == 1 {
            return 1;
        }
        let then_blk: i64 = ast_child1(node);
        if nb_argv_stmts(buf, ast_child0(then_blk), ast_aux(then_blk), 0) == 1 {
            return 1;
        }
        let else_blk: i64 = ast_child2(node);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        return nb_argv_stmts(buf, else_sa, else_sl, 0);
    }
    if k == ast_while() {
        let cond: i64 = ast_child0(node);
        if nb_argv_expr(buf, cond) == 1 {
            return 1;
        }
        let body_blk: i64 = ast_child1(node);
        return nb_argv_stmts(buf, ast_child0(body_blk), ast_aux(body_blk), 0);
    }
    if k == ast_assign() {
        return nb_argv_expr(buf, ast_child2(node));
    }
    if k == ast_break() {
        return 0;
    }
    if k == ast_continue() {
        return 0;
    }
    nb_argv_expr(buf, node)
}
pub fn nb_argv_stmts(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    if nb_argv_stmt(buf, stmt_node) == 1 {
        return 1;
    }
    nb_argv_stmts(buf, stmts_addr, stmts_len, i + 1)
}
pub fn nb_argv_fn(buf: i64, node: i64) -> i64 {
    let body: i64 = ast_child2(node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    nb_argv_stmts(buf, stmts_addr, stmts_len, 0)
}
// 1 iff any of the `n_fns` pruned/emitted fns in `ordered` references argv.
pub fn nb_fns_use_argv(buf: i64, ordered: i64, n_fns: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    let node: i64 = __mind_load_i64(ordered + k * 8);
    if nb_argv_fn(buf, node) == 1 {
        return 1;
    }
    nb_fns_use_argv(buf, ordered, n_fns, k + 1)
}

// 1 iff any param in [i, n_params) is narrow-declared (nb_width_of_ann < 64).
pub fn nb_fn_has_narrow_param(buf: i64, params_addr: i64, n_params: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    if nb_width_of_ann(buf, ast_child1(pnode)) < 64 {
        return 1;
    }
    nb_fn_has_narrow_param(buf, params_addr, n_params, i + 1)
}

// 1 iff any statement in [i, n) IS or CONTAINS (inside an if branch) a while loop.
pub fn nb_stmts_have_while(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_while() {
        return 1;
    }
    if k == ast_if() {
        let then_blk: i64 = ast_child1(stmt);
        if nb_stmts_have_while(buf, ast_child0(then_blk), ast_aux(then_blk), 0) == 1 {
            return 1;
        }
        let else_blk: i64 = ast_child2(stmt);
        if else_blk != 0 {
            if nb_stmts_have_while(buf, ast_child0(else_blk), ast_aux(else_blk), 0) == 1 {
                return 1;
            }
        }
    }
    nb_stmts_have_while(buf, stmts_addr, stmts_len, i + 1)
}

// 1 iff any statement in [i, n) is an `if` whose then/else block CONTAINS (at any
// depth) a while loop — i.e. a while NESTED inside an if branch, NOT a top-level
// body while. A narrow carried var mutated by such a nested while needs the F2
// nested-region carry threading (lower.rs 4737-4777 last_region_exit_rebindings)
// which nb_while_carry does not yet record, so its post-region binding can desync;
// this sub-shape stays fail-closed. A while at the fn-body top level does NOT match
// (its carry is fully handled by nb_emit_while's local pre-walk).
pub fn nb_stmts_have_nested_while(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) == ast_if() {
        let then_blk: i64 = ast_child1(stmt);
        if nb_stmts_have_while(buf, ast_child0(then_blk), ast_aux(then_blk), 0) == 1 {
            return 1;
        }
        let else_blk: i64 = ast_child2(stmt);
        if else_blk != 0 {
            if nb_stmts_have_while(buf, ast_child0(else_blk), ast_aux(else_blk), 0) == 1 {
                return 1;
            }
        }
    }
    nb_stmts_have_nested_while(buf, stmts_addr, stmts_len, i + 1)
}

// 1 iff a top-level assign statement in this while body reassigns a narrow-declared
// (i8/i16/i32) PARAM — the shape nb_while_carry now lowers correctly (it mints the
// emit's fresh width-wrap slot for the carried narrow assign). Used to distinguish
// the SAFE "narrow param carried by a top-level while" pattern from the read-only
// "narrow param merely present while a loop runs" pattern (whose post-loop use via
// a `(x as i64)`-cast-fed binop hits a SEPARATE, still-open cast-in-binop lowering
// bug — kept fail-closed).
pub fn nb_while_assigns_narrow_param(buf: i64, body_sa: i64, body_sl: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= body_sl {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(body_sa + i * 8);
    if ast_kind(stmt) == ast_assign() {
        let nl: i64 = ast_child0(stmt);
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(nl), ast_span_hi(nl));
        if idx >= 0 {
            let pnode: i64 = __mind_load_i64(params_addr + idx * 8);
            if nb_width_of_ann(buf, ast_child1(pnode)) < 64 {
                return 1;
            }
        }
    }
    nb_while_assigns_narrow_param(buf, body_sa, body_sl, i + 1, params_addr, n_params)
}

// 1 iff some TOP-LEVEL body while loop reassigns a narrow-declared param (the SAFE,
// now-correct carry shape). A while nested inside an if is NOT considered here (it is
// separately refused by nb_stmts_have_nested_while).
pub fn nb_toplevel_while_carries_narrow(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) == ast_while() {
        let body_blk: i64 = ast_child1(stmt);
        if nb_while_assigns_narrow_param(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
    }
    nb_toplevel_while_carries_narrow(buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// 1 iff a while that REASSIGNS a narrow-declared param is reachable through a chain of
// DIRECT nested `while`s at this region level (a `while` in `stmts`, or such a while
// direct-nested to any depth inside another while's body). This is the EXACT set the
// loop-carry promotion handles: nb_while_carry -> nb_while_carry_nonassign only descends
// into a DIRECT nested `while` (nb_while_carry_wnest), which promotes the inner while's
// narrow-carried OUTER var into the enclosing loop's carry table. It has NO `if` arm on
// purpose: an inner while wrapped in an `if` inside the loop body is NOT promoted to the
// outer carry (nb_while_carry_nonassign hands a non-while stmt to nb_count_stmt, which
// does not thread the inner while's carried writes out through the `if`), so permitting
// it would silently drop the carry -> wrong result. This scanner is the fail-closed guard
// that matches nb_while_carry_wnest/nb_while_assigns_narrow_param exactly.
pub fn nb_body_while_carries_narrow_direct(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_while() {
        let body_blk: i64 = ast_child1(stmt);
        if nb_while_assigns_narrow_param(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
        if nb_body_while_carries_narrow_direct(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
    }
    nb_body_while_carries_narrow_direct(buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// 1 iff a top-level `if` in this while body has a branch that DIRECTLY (top-level)
// reassigns a narrow-declared param — the exact shape nb_while_carry_ifnest carries
// (Sub-step B). Reuses nb_while_assigns_narrow_param on each branch block (top-level
// assigns only), so it does NOT look through a nested `while` inside the branch: an
// if-wrapped inner while (`while{ if{ while{ narrow += 1 } } }`, Sub-step C) is NOT
// matched here and stays fail-closed.
pub fn nb_while_body_if_assigns_narrow(buf: i64, sa: i64, sl: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= sl {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    if ast_kind(stmt) == ast_if() {
        let then_blk: i64 = ast_child1(stmt);
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        let else_blk: i64 = ast_child2(stmt);
        let else_sa: i64 = if else_blk == 0 {
            0
        } else {
            ast_child0(else_blk)
        };
        let else_sl: i64 = if else_blk == 0 {
            0
        } else {
            ast_aux(else_blk)
        };
        // Permit ONLY a GENUINE single-branch narrow carry: a narrow param top-level assigned
        // in one branch whose SIBLING branch does not write it ANYWHERE (recursive, via
        // nb_block_writes_rec). This is exactly what nb_if_carry_promote carries. A narrow
        // param the sibling writes by nested control (`else { if{ x+=5 } }`) is NOT this shape
        // and stays fail-closed (0B) — matching base 41d98e7 — instead of emitting a wrong
        // value (the XN silent-miscompile class). Both-branch-same-var and Sub-step C
        // (if-wrapped inner while) also do not match here and stay fail-closed.
        if nb_block_narrow_single(buf, then_sa, then_sl, else_sa, else_sl, 0, params_addr, n_params) == 1 {
            return 1;
        }
        if nb_block_narrow_single(buf, else_sa, else_sl, then_sa, then_sl, 0, params_addr, n_params) == 1 {
            return 1;
        }
    }
    nb_while_body_if_assigns_narrow(buf, sa, sl, i + 1, params_addr, n_params)
}

// 1 iff block A [asa,asl) has a TOP-LEVEL `Assign` to a narrow-declared param that is NOT
// written (recursively, any depth) in the sibling block S [ssa,ssl) — the genuine
// single-branch narrow carry nb_if_carry_promote handles. A narrow param the sibling also
// writes (any means) is excluded so the fn fails closed rather than dropping the sibling write.
pub fn nb_block_narrow_single(buf: i64, asa: i64, asl: i64, ssa: i64, ssl: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= asl {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(asa + i * 8);
    if ast_kind(stmt) == ast_assign() {
        let nl: i64 = ast_child0(stmt);
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(nl), ast_span_hi(nl));
        if idx >= 0 {
            let pnode: i64 = __mind_load_i64(params_addr + idx * 8);
            if nb_width_of_ann(buf, ast_child1(pnode)) < 64 {
                if nb_block_writes_rec(buf, ssa, ssl, ast_span_lo(nl), ast_span_hi(nl), 0) == 0 {
                    return 1;
                }
            }
        }
    }
    nb_block_narrow_single(buf, asa, asl, ssa, ssl, i + 1, params_addr, n_params)
}

// 1 iff a while that REASSIGNS a narrow-declared param is reachable at this region
// level: either a `while` DIRECTLY in `stmts` whose body reassigns a narrow param,
// or such a while nested inside an `if` branch (recursing through if-nesting to any
// depth). This is the exact set of nested-while carry shapes whose rebinding threads
// correctly out through the enclosing if-region's merge exit-env (verified: the
// if-merge machinery collects the nested while's top-level live_writes as branch
// writes — nb_branch_writes' ast_while arm -> nb_while_live_writes — allocates a
// merge phi per carried name, and nb_rebind_merges binds them into the post-if
// let-env so the post-loop read resolves the carried value; the narrow width-wrap
// slot is minted+counted identically on both the nb_while_carry pre-walk and the
// nb_count_stmt assign arm via the param-width binding in the let-env).
//
// Into a `while` body it descends ONLY through DIRECT nested `while`s (via
// nb_body_while_carries_narrow_direct), which is exactly what the loop-carry promotion
// (nb_while_carry_wnest) handles — so `while{ while{ narrow += 1 } }` and deeper
// direct-nested loops are PERMITTED and run correct. It DELIBERATELY does NOT reach an
// inner while that is wrapped in an `if` inside a loop body (`while{ if{ while{ ... } } }`):
// that inner while is never promoted to the outer carry, so the narrow var is dropped
// across the outer loop — such a shape produces 0 here and stays fail-closed at the guard
// site (the pre-existing i64 `while{ if{ x += 1 } }` carry-drop gap is likewise refused).
//
// No self-host fn has a narrow param, so this never fires during self-compile and the
// byte-identical loop is unaffected.
pub fn nb_region_while_carries_narrow(buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_while() {
        let body_blk: i64 = ast_child1(stmt);
        if nb_while_assigns_narrow_param(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
        // F2 FIXED: a while DIRECT-NESTED inside this while whose body reassigns a
        // narrow param now carries correctly (nb_while_carry_wnest promotes the outer
        // var through the direct nested region). Descend into the while body via the
        // DIRECT-ONLY scanner so `while{ while{ x = x + 1 } }` (and deeper direct nests)
        // is PERMITTED. This must NOT reach through an `if` inside the body: an
        // if-wrapped inner while (`while{ if{ while{ x = x + 1 } } }`) is never promoted
        // to the outer carry, so descending through the full scanner would downgrade a
        // safe refusal to a silent carry-drop miscompile — hence nb_body_while_carries_
        // narrow_direct (no ast_if() arm), matching what the promotion actually handles.
        if nb_body_while_carries_narrow_direct(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
        // SUB-STEP B: a top-level `if` in this while body whose branch DIRECTLY assigns a
        // narrow param now carries correctly (nb_while_carry_ifnest promotes the outer var
        // via the if's merge slot). Permit `while{ if{ narrow += 1 } }`. Direct branch
        // assigns only (nb_while_body_if_assigns_narrow does not look through a nested
        // while), so `while{ if{ while{ narrow += 1 } } }` (Sub-step C) stays fail-closed.
        if nb_while_body_if_assigns_narrow(buf, ast_child0(body_blk), ast_aux(body_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
    }
    if k == ast_if() {
        let then_blk: i64 = ast_child1(stmt);
        if nb_region_while_carries_narrow(buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params) == 1 {
            return 1;
        }
        let else_blk: i64 = ast_child2(stmt);
        if else_blk != 0 {
            if nb_region_while_carries_narrow(buf, ast_child0(else_blk), ast_aux(else_blk), 0, params_addr, n_params) == 1 {
                return 1;
            }
        }
    }
    nb_region_while_carries_narrow(buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// 1 iff any BODY-having fn in the pruned `ordered` set declares a narrow-width
// (i8/i16/i32) param AND its body has a while loop that is NOT the now-correct
// "narrow param carried by a top-level while" shape — i.e. a still-broken sub-shape.
//
// FIXED (now emits + runs correct): a narrow param REASSIGNED by a TOP-LEVEL body
// while. nb_while_carry now mints the emit's fresh width-wrap slot for a narrow
// carried assign (post_id = the wrap slot, next_id advanced +1), so the carried
// var's working slot and every later carried var stay frame-consistent with the
// emit + the count (nb_count_stmt assign arm) — the value re-wraps two's-complement
// each iteration and post-loop reads resolve to the live slot.
//
// STILL REFUSED (fail-closed empty es_new()):
//   (a) an inner while wrapped in an `if` INSIDE a loop body
//       (`while{ if{ while{ narrow += 1 } } }`) — the inner while is not promoted to
//       the outer loop's carry (nb_while_carry_nonassign only descends into a DIRECT
//       nested while), so the narrow var is dropped across the outer loop. The guard's
//       while-body descent is direct-while-only (nb_body_while_carries_narrow_direct),
//       so this shape stays fail-closed (as does the pre-existing i64 `while{ if{ x += 1
//       } }` carry-drop gap). A top-level `if{ while{ narrow += 1 } }` (an if at the
//       fn-body region wrapping a while) IS permitted+correct — the if-merge machinery
//       threads it — and is unaffected.
//   (b) a narrow param merely PRESENT while a top-level loop runs but NOT reassigned
//       by it — a read-only narrow param used post-loop via a `(x as i64)`-cast fed
//       into a binop hits a SEPARATE, still-open cast-in-binop lowering bug (`as` is
//       not an infix operator in the pratt parser, so the cast mis-lowers and the
//       trailing operand becomes dead code). Refused until that cast fix lands.
//
// Body-having fns only (the narrow-typed std sigs are extern `unsafe fn`, no body).
// No self-host fn has a narrow param, so this never fires during self-compile and the
// loop stays byte-identical.
pub fn nb_fns_reassign_narrow_param(buf: i64, ordered: i64, n_fns: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    let node: i64 = __mind_load_i64(ordered + k * 8);
    if ast_child2(node) != 0 {
        let params_addr: i64 = ast_child1(node);
        let n_params: i64 = ast_aux(node) / 2;
        if nb_fn_has_narrow_param(buf, params_addr, n_params, 0) == 1 {
            let body: i64 = ast_child2(node);
            let bsa: i64 = ast_child0(body);
            let bsl: i64 = ast_aux(body);
            // A while is present (top-level or region-nested) but NO while that
            // reassigns the narrow param is reachable through the fn-body / if-region
            // exit env -> refuse. nb_region_while_carries_narrow returns 1 iff a
            // top-level while, a while nested inside an if-branch (at any if-depth), OR
            // a while DIRECT-nested inside another while (to any depth) reassigns a
            // narrow param — the shapes whose carry rebinding threads correctly out (the
            // if-merge machinery collects a nested while's live_writes as branch writes
            // and rebinds them post-if; nb_while_carry_wnest promotes a direct nested
            // while's carried OUTER var into the enclosing loop's carry table). Into a
            // while body it descends ONLY through DIRECT nested whiles, so an inner while
            // wrapped in an `if` inside a loop body (`while{ if{ while{ narrow += 1 } } }`)
            // is NOT promoted to the outer carry and stays fail-closed, as does a
            // read-only narrow param merely present while a loop runs.
            if nb_stmts_have_while(buf, bsa, bsl, 0) == 1 {
                if nb_region_while_carries_narrow(buf, bsa, bsl, 0, params_addr, n_params) == 0 {
                    return 1;
                }
            }
        }
    }
    nb_fns_reassign_narrow_param(buf, ordered, n_fns, k + 1)
}

// round_up(x, 16)
pub fn nb_round16(x: i64) -> i64 {
    let r: i64 = x - (x / 16) * 16;
    if r == 0 {
        return x;
    }
    x + (16 - r)
}

// Append the implicit tail-return to a lowered body (mirror src/native::lower_fn
// at mod.rs:1155-1162). If the body's last statement already terminates (explicit
// `return` / fully-diverging if), the load+epilogue was emitted in nb_stmt — return
// the body unchanged. Otherwise the trailing value-expression's slot (st0.last_id)
// IS the FnDef's ret_id: emit `mov rax,[ret_id]` then the epilogue. A tail-return
// helper (each arm `return`s the NbState directly) so it stays in the self-host
// mic@3 subset — NOT a struct-typed value-if (which mis-lowers).
pub fn nb_finish_body(st0: NbState, is_entry: i64, stmts_addr: i64, stmts_len: i64, ret_dt: i64, retw: i64) -> NbState {
    if nb_last_emits_return(stmts_addr, stmts_len) == 1 {
        return st0;
    }
    // RI-D2 S-C1: return-register selection by the fn's declared return dtype. A
    // FLOAT-returning fn (ret_dt == nb_dtype_float(), i.e. its declared return type is
    // f64/f32 per the frt registry) loads its tail-expr result into xmm0 (movsd), per
    // the SysV AMD64 float-return-in-xmm0 convention — so a caller's call-site xmm0
    // spill (the nb_expr call arm below) reads the value from the right register file.
    // An INT/pointer return loads rax (the UNCHANGED path). main.mind's fns all return
    // INT (frt classifies every fn INT — its float-returning matches are comments the
    // lexer strips, and std externs are `;`-terminated with no body), so ret_dt is
    // always INT during self-compile and this stays byte-for-byte identical.
    let r1: String = if ret_dt == nb_dtype_float() {
        nb_fp_movsd_load_xmm0(st0.code, nb_slot_disp(st0.last_id))
    } else {
        nb_load_rax(st0.code, nb_slot_disp(st0.last_id))
    };
    // C2 param/return width driver: a narrow-int-returning fn (`-> i8/i16/i32 {`)
    // wraps its implicit tail-return value in rax at the declared width. A narrow
    // width only ever comes from an int spelling, so it never coexists with the
    // float (xmm0) branch above — wrapping rax unconditionally is safe. retw is 64
    // for every main.mind fn -> nb_wrap_ret_w emits nothing, byte-identical.
    let r1w: String = nb_wrap_ret_w(r1, retw);
    let r2: String = nb_emit_return(r1w, is_entry);
    NbState { code: r2, next_id: st0.next_id, last_id: st0.last_id, ncalls: st0.ncalls }
}

// Build a synthetic ast_struct_lit-SHAPED descriptor node for struct `k` in the
// `srt` registry, so a struct-typed PARAMETER binds to it in the let-env exactly
// like a let-bound struct literal does. nb_slit_field_index reads only child1
// (+32 = fields_addr, 3-i64 triples) and aux (+48 = field_count), so the synthetic
// node carries the struct DECL's field-name spans as triples (name_lo, name_hi, 0)
// — the value slot is unused on the read path. This is the Step-2 path of
// eval/lower.rs's FieldAccess arm (receiver_types side-table -> ir.struct_defs):
// resolve the receiver's declared struct type, then 8*declared-index. Returns the
// descriptor node addr.
pub fn nb_struct_decl_descriptor(srt: i64, src: i64, k: i64) -> i64 {
    let nf: i64 = srt_field_count(srt, k);
    let fields_addr: i64 = __mind_alloc((nf * 3 + 1) * 8);
    let _f: i64 = nb_fill_decl_triples(srt, src, k, nf, fields_addr, 0);
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_struct_lit());
    __mind_store_i64(n + 8, 0);
    __mind_store_i64(n + 16, 0);
    __mind_store_i64(n + 24, 0);
    __mind_store_i64(n + 32, fields_addr);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, nf);
    __mind_store_i64(n + 56, 0);
    n
}

// Fill the descriptor's 3-i64 field triples (field_name_lo, field_name_hi, 0) in
// DECLARATION order from struct `k`'s field spans. Value slot stays 0 (unused on
// the field-READ path; nb_slit_field_index only matches name spans).
pub fn nb_fill_decl_triples(srt: i64, src: i64, k: i64, nf: i64, fields_addr: i64, j: i64) -> i64 {
    if j >= nf {
        return 0;
    }
    __mind_store_i64(fields_addr + (j * 3 + 0) * 8, srt_field_lo(srt, k, j));
    __mind_store_i64(fields_addr + (j * 3 + 1) * 8, srt_field_hi(srt, k, j));
    __mind_store_i64(fields_addr + (j * 3 + 2) * 8, 0);
    nb_fill_decl_triples(srt, src, k, nf, fields_addr, j + 1)
}

// Register each struct-typed PARAMETER into the let-env `lets`/`lcell` so a later
// `p.field` read recovers the field offset (8*declared-index) through the same
// Step-1 lookup (nb_lets_lookup_slit -> nb_slit_field_index) a let-bound struct
// literal uses. A param node is (name_leaf at child0, type_leaf at child1); the
// type leaf's span names the declared type. When that type resolves to a struct
// in `srt`, bind the param name -> the struct's synthetic descriptor; otherwise
// bind -> 0 (scalar param, offset path unchanged). Registered FIRST (before body
// lets), so a same-name `let` correctly shadows it (last-match-wins). MUST run on
// BOTH the count-lets (clets) and emit-lets so the frame-size count and emission
// agree byte-for-byte.
pub fn nb_register_struct_params(srt: i64, src: i64, params_addr: i64, n_params: i64, lets: i64, lcell: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let ty_leaf: i64 = ast_child1(pnode);
    let ty_lo: i64 = ast_span_lo(ty_leaf);
    let ty_hi: i64 = ast_span_hi(ty_leaf);
    let sk: i64 = srt_find_by_name(srt, src, ty_lo, ty_hi, 0);
    let desc: i64 = if sk < 0 {
        0
    } else {
        nb_struct_decl_descriptor(srt, src, sk)
    };
    // C2 param-width driver: record the param's DECLARED width (8/16/32 for an
    // i8/i16/i32 annotation, else 64) in the let-env, so the assign arm's width
    // lookup re-wraps a narrow param exactly like a narrow let. This runs on BOTH
    // the count-lets and the emit-lets (the two nb_lower_fn call sites), so the
    // count and emit assign arms always agree (+1 iff narrow — frame-consistent).
    // Every param in main.mind's own source is width 64 — heap-word only there,
    // byte-identical self-compile.
    let pw: i64 = nb_width_of_ann(src, ty_leaf);
    let _b: i64 = nb_lets_bind(lets, lcell, ast_span_lo(name_leaf), ast_span_hi(name_leaf), i, desc, pw);
    nb_register_struct_params(srt, src, params_addr, n_params, lets, lcell, i + 1)
}

// Lower one fn_def to its code String + call records. The entry (is_entry==1)
// gets the STACK_TOP rsp-switch before the prologue. The calls scratch table is
// shared; rel32 offsets are recorded RELATIVE TO THIS FUNCTION'S code start.
// Returns NbState{code = this fn's bytes, ncalls = updated count}. `srt` is the
// whole-module struct registry, used to give struct-typed params a field-offset
// descriptor in the let-env (the Step-2 FieldAccess path).
pub fn nb_lower_fn(buf: i64, node: i64, is_entry: i64, calls: i64, ncalls0: i64, srt: i64, frt: i64, uses_argv: i64) -> NbState {
    let params_addr: i64 = ast_child1(node);
    let n_params: i64 = ast_aux(node) / 2;
    let body: i64 = ast_child2(node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);

    // frame = round_up(8 * nslots, 16); nslots = next_id after walking the body
    // seeded at n_params (params occupy slots 0..n_params-1). A count-time let-env
    // (name -> struct-lit) lets the field-access count recover each field's offset.
    //
    // PHASE 1.3 status: the WHILE-loop + Assign + Break/Continue port (nb_emit_while,
    // ast_while/ast_assign count+emit, the loop-carry copy-in/exit-id coalescing, and
    // the value-if/if-stmt merge-phi machinery in nb_if_*_merged) landed the once-
    // blocked loop-bearing fns byte-identically: the seeded whole-module prefix now
    // reaches 11703 B (std.string's `string_push_str` and every now-supported
    // while/assign/value-if-merge fn match the Rust mind-native oracle exactly). The
    // earlier "ordered fn 10 frame undercount" was the missing ast_while count arm
    // (the count walked the 3 whiles + their value-if-nested whiles as bare exprs,
    // counting 0 slots) PLUS the un-counted merge-phi ids of the value-ifs whose
    // branches carry a `while`-mutated body-let — both now ported. The F2 nested-
    // region exit-MERGE floor (fn#53 is_digit, `if cond { if inner { return } } 0` @
    // 0x2ed7) is now cleared too: nb_if_stmt_simple threads the nested if/while's
    // EXIT/dst id up as the branch then_result/else_result (the value side of
    // lower.rs's `then_result = lower_expr(other)` in the `other =>` arm), so the
    // outer then-edge loads the inner if's merge slot, not the stale leading-const0.
    // Seeded whole-module prefix now reaches 23637 B. The remaining seeded-prefix
    // blocker is a downstream frame-size (slot-count) under-count @ ~0x781b.
    // deferred (next gaps): (1) F2 outer-var MUTATION — a while/if NESTED in a loop or
    // branch body that MUTATES an OUTER carried var (lower.rs 4737-4777,
    // last_region_exit_rebindings) is still not threaded by nb_while_carry /
    // nb_branch_writes (is_digit's nested if only `return`s, mutating nothing, so the
    // value-side fix above suffices for it); upgrade path: after a nested region, scan
    // its tail for an Assign to an outer-env name and record it as a branch write.
    // (2) the next frame undercount — nb_count_stmt does not yet count every SSA id of
    // some downstream fn (oracle `sub rsp,0x920` vs mind `0x890`, an 18-slot gap);
    // upgrade path: diff nb_count_stmt vs the fn's actual emitted slot walk.
    // (3) div/mod/shift binops still fall through to imul in nb_arith_rax_mem (the
    // marker there spells out the emit_div_mod_guarded + cl-shift port).
    let clets0: i64 = __mind_alloc(512 * 5 * 8);
    // clcell0 mirrors the emit lcell's srt slot at +24 (FIX #173): nb_count_expr's
    // value-if-in-expression arm calls nb_count_stmts, which needs srt, but
    // nb_count_expr has no srt param. Read it from clcell+24 — the SAME offset the
    // emit lcell uses — so both the normal count path (clcell0) and the pre-walk
    // paths that alias the emit lcell as clcell resolve srt identically. Grown 8 -> 32.
    let clcell0: i64 = __mind_alloc(32);
    __mind_store_i64(clcell0, 0);
    __mind_store_i64(clcell0 + 24, srt);
    // Register struct-typed params into the count-lets FIRST, so the field-access
    // count recovers the same 8*declared-index offset the emission does (the extra
    // CONST+ADD ids for a nonzero-offset field read must be counted into nslots).
    let _crp: i64 = nb_register_struct_params(srt, buf, params_addr, n_params, clets0, clcell0, 0);
    let nslots: i64 = nb_count_stmts(n_params, buf, stmts_addr, stmts_len, 0, params_addr, n_params, clets0, clcell0, srt);
    let frame: i64 = nb_round16(8 * nslots);

    let code0: String = string_new();
    // RI-C: an argv-using entry captures OS argc/argv as the LITERAL first bytes,
    // BEFORE the STACK_TOP rsp switch abandons the OS stack. Statement-form gate
    // (nb_entry_prefix) so an argv-free entry gets code0 unchanged — byte-identical.
    let codecap: String = nb_entry_prefix(code0, is_entry, uses_argv);
    // Entry-only stack switch: movabs rsp, STACK_TOP = 48 BC <imm64>
    let code1: String = if is_entry == 1 {
        let a1: String = nb_push(codecap, 72);
        let a2: String = nb_push(a1, 188);
        nb_i64le(a2, nb_stack_top())
    } else {
        codecap
    };
    // Prologue: 55 48 89 E5 48 81 EC <frame32>
    let p1: String = nb_push(code1, 85);
    let p2: String = nb_push(p1, 72);
    let p3: String = nb_push(p2, 137);
    let p4: String = nb_push(p3, 229);
    let p5: String = nb_push(p4, 72);
    let p6: String = nb_push(p5, 129);
    let p7: String = nb_push(p6, 236);
    let p8: String = nb_i32le_signed(p7, frame);

    // Spill incoming params into their slots (Param arms): store_argreg(i, slot i).
    // gp_k / sse_k are the SysV GP and SSE arg-register counters (both 0 to start);
    // an integer/pointer param consumes a GP register, a float param an SSE register.
    let st_params: NbState = NbState { code: p8, next_id: n_params, last_id: 0 - 1, ncalls: ncalls0 };
    let st_p0: NbState = nb_emit_params(st_params, buf, params_addr, n_params, 0, 0, 0);
    // C2 param-width driver: wrap each narrow-declared (i8/i16/i32) param in place
    // in its home slot right after the SysV spill, so every later read of the
    // param sees its two's-complement-wrapped value. Zero bytes emitted for a
    // width-64 param — all of main.mind — so the self-compile is byte-identical.
    let st_p: NbState = NbState { code: nb_wrap_params_w(st_p0.code, buf, params_addr, n_params, 0), next_id: st_p0.next_id, last_id: st_p0.last_id, ncalls: st_p0.ncalls };

    // Per-fn intra-function forward-jump scratch (je/jmp sites recorded relative
    // to THIS fn's code String; up to 512 jumps; jcell = a 1-i64 count, zeroed).
    let jmps: i64 = __mind_alloc(512 * 2 * 8);
    let jcell: i64 = __mind_alloc(8);
    __mind_store_i64(jcell, 0);

    // Per-fn let-env: name span -> (frame slot, struct-lit node, declared width),
    // for `let` bindings (up to 512, 5 i64 words each; lcell = a 2-i64 cell:
    // word0 = count, word1 = the per-fn dtype table, both threaded together like
    // the count). Empty for the scalar fixtures.
    let lets: i64 = __mind_alloc(512 * 5 * 8);
    // lcell is the per-fn side-channel: word0 = let count, +8 = dtype table,
    // +16 = frt registry, and (FIX #173) +24 = srt, +32 = is_entry, +40 = jmps,
    // +48 = jcell, +56 = loops, +64 = lpcell — the jump/loop/struct state a value-if
    // in DEEP EXPRESSION position needs. nb_expr has no jump-table params, so its
    // ast_if arm reads them from here instead of a wide signature change threaded
    // through nb_expr's ~20 call sites. Grown 24 -> 72 to hold the six new words,
    // then 72 -> 80 for the C2 declared return width at +72 (read by nb_stmt's
    // return arm; 64 = full-width no-op for every main.mind fn).
    let lcell: i64 = __mind_alloc(80);
    __mind_store_i64(lcell, 0);
    // RI-B1 FOLLOW-UP: per-fn SSA dtype table (nb_dtype_table_new, all-INT default),
    // threaded through the EXISTING lets/lcell plumbing at lcell+8 — nb_expr's binop
    // arm reads it, the `let` arm tags it. Sized nslots+64 (all SSA ids < nslots; the
    // +64 slack absorbs any residual frame-count drift so no read is ever OOB). Every
    // slot defaults INT, and main.mind's float-free source never tags one FLOAT, so the
    // integer native-ELF oracle stays byte-identical.
    __mind_store_i64(lcell + 8, nb_dtype_table_new(nslots + 64));
    // RI-D2 S-C1: stash the whole-module return-type registry (frt) at lcell+16, so the
    // body-lowering path (which already threads lcell) can classify a CALL by its callee's
    // declared return dtype without a separate frt parameter: nb_node_dtype_tbl's ast_call
    // arm and nb_expr's call-result spill both read lcell+16. frt classifies every fn in
    // main.mind's float-free source INT, so the value read here is inert for self-compile.
    __mind_store_i64(lcell + 16, frt);
    // RI-D2 S-B classifier half: tag each FLOAT (f64/f32) param's SSA slot FLOAT in the
    // per-fn dtype table (param i occupies SSA slot i). A later `x + 2.5` binop over a
    // float param then resolves `x` FLOAT (nb_node_dtype_tbl's resolve_param branch) and
    // routes the SSE2 encoders. Non-float params tag INT (the default), which writes no
    // machine code — so main.mind's float-free source leaves the table all-INT and the
    // integer native-ELF emission byte-identical.
    let _tfp: i64 = nb_tag_float_params(__mind_load_i64(lcell + 8), buf, params_addr, n_params, 0);
    // Register struct-typed params FIRST (before body lets append, so a same-name
    // let shadows last-match-wins), mirroring the count-lets registration above so
    // the emitted offsets match the counted frame size exactly.
    let _erp: i64 = nb_register_struct_params(srt, buf, params_addr, n_params, lets, lcell, 0);

    // Per-fn loop-frame stack (header offset + per-loop break list), threaded like
    // jmps/jcell. Each frame is 3 i64 words; lpcell = a 1-i64 depth count, zeroed.
    // Up to 64 nested loops.
    let loops: i64 = __mind_alloc(256 * 3 * 8);
    let lpcell: i64 = __mind_alloc(8);
    __mind_store_i64(lpcell, 0);

    // FIX #173: stash the per-fn jump/loop/struct state onto the lcell side-channel so
    // nb_expr's ast_if arm (a value-if in DEEP EXPRESSION position) can route to
    // nb_if_value without threading six params through nb_expr's ~20 call sites. srt is
    // placed at +24 to MATCH the count-side clcell0 (+24), since nb_while_carry and the
    // dst-id pre-walks alias the emit lcell as the count clcell. main.mind's own source
    // never nests a value-if in expression position, so this stash is only READ on a
    // construct main.mind lacks — the integer native-ELF oracle stays byte-identical.
    __mind_store_i64(lcell + 24, srt);
    __mind_store_i64(lcell + 32, is_entry);
    __mind_store_i64(lcell + 40, jmps);
    __mind_store_i64(lcell + 48, jcell);
    __mind_store_i64(lcell + 56, loops);
    __mind_store_i64(lcell + 64, lpcell);
    // C2 param/return width driver: stash THIS fn's declared return width (frt
    // registry, 64 unless `-> i8/i16/i32 {`) at lcell+72 so nb_stmt's explicit-
    // return arm can wrap rax at the declared width without a signature change.
    // 64 for every main.mind fn -> nb_wrap_ret_w emits nothing, byte-identical.
    __mind_store_i64(lcell + 72, frt_lookup_width(frt, buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node))));

    // Body.
    let st_body0: NbState = nb_block_stmts(st_p, buf, stmts_addr, stmts_len, 0, params_addr, n_params, calls, is_entry, jmps, jcell, lets, lcell, srt, loops, lpcell);

    // Implicit tail-return (mirror src/native::lower_fn:1155-1162). Routed through a
    // tail-return helper (NOT a `let s: NbState = if {..} else {..}` value-if — that
    // struct-typed value-if shape is outside the self-host subset and mis-lowers).
    // RI-D2 S-C1: this fn's own declared return dtype (FLOAT for f64/f32, else INT),
    // looked up by name in the frt registry, drives the return-register selection in
    // nb_finish_body (xmm0 for a float return, rax otherwise). INT for every main.mind fn.
    let ret_dt: i64 = frt_lookup_dtype(frt, buf, ast_span_lo(ast_child0(node)), ast_span_hi(ast_child0(node)));
    let st_body: NbState = nb_finish_body(st_body0, is_entry, stmts_addr, stmts_len, ret_dt, __mind_load_i64(lcell + 72));

    // Patch every recorded forward jump into this fn's assembled code IN PLACE
    // (string_addr) before nb_lower_all concatenates it into the image. Intra-fn
    // jumps are position-independent, so a fn-relative patch is exact after the
    // whole-function copy.
    let njmps: i64 = __mind_load_i64(jcell);
    let fn_code_addr: i64 = string_addr(st_body.code);
    let _pj: i64 = nb_patch_jmps(fn_code_addr, jmps, njmps, 0);
    st_body
}

// Count stack-passed params in [0,t) under the SysV two-pool rule (int gp>=6 or
// float sse>=8) — the callee twin of nb_count_argstk. A stack param's frame offset is
// [rbp + 16 + 8*stack_rank], stack args laid out in arg order at increasing addresses.
// INT-PRESERVATION: with every param INT, gp advances 1:1 with position and sse stays
// 0, so for the param at position t (gp_k==t) this returns t-6 == gp_k-6 — byte-
// identical to the prior `16 + 8*(gp_k-6)` offset.
pub fn nb_param_stk_rank(buf: i64, params_addr: i64, t: i64, k: i64, gp: i64, sse: i64, acc: i64) -> i64 {
    if k >= t {
        return acc;
    }
    let pnode: i64 = __mind_load_i64(params_addr + k * 8);
    let isf: i64 = nb_param_is_float(buf, ast_child1(pnode));
    if isf == nb_dtype_float() {
        let naf: i64 = if sse >= 8 {
            acc + 1
        } else {
            acc
        };
        return nb_param_stk_rank(buf, params_addr, t, k + 1, gp, sse + 1, naf);
    }
    let nai: i64 = if gp >= 6 {
        acc + 1
    } else {
        acc
    };
    nb_param_stk_rank(buf, params_addr, t, k + 1, gp + 1, sse, nai)
}

// Spill params 0..n_params-1 into their slots, classifying each per SysV AMD64:
// integer/pointer params draw from the GP register pool (rdi/rsi/rdx/rcx/r8/r9,
// counted by gp_k), FLOAT params from the SSE pool (xmm0..7, counted by sse_k). The
// two counters are INDEPENDENT — a float param does not advance gp_k and vice versa.
// Each param i always spills into slot i (nb_slot_disp(i)); only the SOURCE register
// file/index differs by class.
//
// INT-PRESERVATION (load-bearing): main.mind's own source has ZERO float params, so
// every param takes the GP branch and gp_k == i for all i. In that case the GP-register
// selection (nb_store_argreg(gp_k, ...)), the >6-arg stack detection (gp_k >= 6), and
// the stack offset (16 + 8*(gp_k-6)) are ALL identical to the prior `i`-keyed code —
// the all-integer emission is byte-for-byte unchanged, keeping the integer native-ELF
// oracle stable. The float branch is reached only when nb_param_is_float == nb_dtype_float().
pub fn nb_emit_params(st: NbState, buf: i64, params_addr: i64, n_params: i64, i: i64, gp_k: i64, sse_k: i64) -> NbState {
    if i >= n_params {
        return st;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let is_float: i64 = nb_param_is_float(buf, ast_child1(pnode));
    if is_float == nb_dtype_float() {
        // FLOAT param. xmm0..7 (sse_k<8) spill via movsd; a 9th+ float (sse_k>=8) was
        // stack-passed by the caller (the movsd encoders cannot address xmm8..15), so it
        // arrives on the stack at [rbp + 16 + 8*stack_rank] — the SHARED stack region
        // (int and float overflow interleaved in arg order). Its 8 raw bytes are byte-
        // copied into the float slot via rax (a float slot is just memory; downstream
        // uses re-load it with movsd). Advances sse_k only.
        let cf: String = if sse_k >= 8 {
            let rank: i64 = nb_param_stk_rank(buf, params_addr, i, 0, 0, 0, 0);
            let ldf: String = nb_load_rax(st.code, 16 + 8 * rank);
            nb_store_rax(ldf, nb_slot_disp(i))
        } else {
            nb_store_sse_argreg(st.code, sse_k, nb_slot_disp(i))
        };
        let sf: NbState = NbState { code: cf, next_id: st.next_id, last_id: st.last_id, ncalls: st.ncalls };
        return nb_emit_params(sf, buf, params_addr, n_params, i + 1, gp_k, sse_k + 1);
    }
    // GP/pointer param. Args 0..5 come from their SysV registers (store_argreg); a 7th+
    // GP arg (gp_k>=6) arrives on the stack at `[rbp + 16 + 8*stack_rank]` (above the
    // saved rbp + return address) and is copied via rax — mirror src/native::lower_fn's
    // Instr::Param arm (mod.rs 740-744). `stack_rank` = the count of stack-passed params
    // (either class) before this one; with no float overflow (n_float<=8) it equals
    // gp_k-6, so the all-integer emission is byte-for-byte unchanged.
    let c1: String = if gp_k >= 6 {
        let rank: i64 = nb_param_stk_rank(buf, params_addr, i, 0, 0, 0, 0);
        let load_stack: String = nb_load_rax(st.code, 16 + 8 * rank);
        nb_store_rax(load_stack, nb_slot_disp(i))
    } else {
        nb_store_argreg(st.code, gp_k, nb_slot_disp(i))
    };
    let s1: NbState = NbState { code: c1, next_id: st.next_id, last_id: st.last_id, ncalls: st.ncalls };
    nb_emit_params(s1, buf, params_addr, n_params, i + 1, gp_k + 1, sse_k)
}

// synth library entry stub (no `main`): xor edi,edi ; mov eax,60 ; syscall.
//   31 FF B8 3C 00 00 00 0F 05
pub fn nb_synth_entry() -> String {
    let c0: String = string_new();
    let c1: String = nb_push(c0, 49);
    let c2: String = nb_push(c1, 255);
    let c3: String = nb_push(c2, 184);
    let c4: String = nb_push(c3, 60);
    let c5: String = nb_push(c4, 0);
    let c6: String = nb_push(c5, 0);
    let c7: String = nb_push(c6, 0);
    let c8: String = nb_push(c7, 15);
    nb_push(c8, 5)
}

// No-`main` (library) modules synthesize a 9-byte entry stub at code offset 0
// (mirrors src/native/mod.rs: synth_lib_entry() is pushed as funcs[0], so the
// real fns all shift down by its length). Every recorded start offset must add
// the stub length so the inter-fn rel32 patches (callee_start - (caller_start +
// rel_off + 4)) stay exact — a uniform shift of all starts cancels in the rel32,
// and entry_off stays 0 (the stub IS the entry). Gate on the no-main case only:
// fixtures WITH a real `main` lay it first (entry_idx>=0) and add no stub, so
// their bytes are unchanged.
pub fn nb_shift_starts(starts: i64, n_fns: i64, delta: i64, k: i64) -> i64 {
    if k >= n_fns {
        return 0;
    }
    __mind_store_i64(starts + k * 8, __mind_load_i64(starts + k * 8) + delta);
    nb_shift_starts(starts, n_fns, delta, k + 1)
}

// ---- SHA-256 (trace-hash leg) — pure MIND, FIPS 180-4 ----
//
// SELF-COMPUTED trace hash (Rust-independence #14, PHASE 1.3 — TRACE-HASH).
// The Rust oracle's note is `ir_trace_hash(ir) = mini_sha256(emit_mic3(ir))`
// (src/ir/evidence.rs:72) over the SEEDED+PRUNED combined IR. This block ports
// `src/deps::mini_sha256` / `sha256_compress` byte-for-byte (it is also the exact
// twin of std/sha256.mind). It is INLINED here — rather than calling std.sha256 —
// because main.mind is a single-file cdylib: only its own lowered bodies and the
// `runtime-support/mind_intrinsics.c` weak shims link, and std.sha256's body is a
// substrate module that is NOT one of those C shims, so a `sha256(...)` call would
// stay an undefined symbol. `nb_*` prefixes keep these inside SECTION 4c and clear
// of every existing name (first-seen dedup contract preserved).
//
// 32-bit-on-i64 discipline (REQUIRED in an i64 language, and the reason the new
// path is self-flip-clean): every intermediate is masked with `& 4294967295`
// (= 0xFFFFFFFF); logical right shift is `(x >> n) & 0xffffffff`; right-rotate is
// `((x >> n) | (x << (32 - n))) & 0xffffffff`. Pure i64 +/&/^/<<,>> + mask — no
// float, no wrapping-u32 type — so it emits byte-identically under the mic@3 flip.

// mask32 — discard bits above bit 31. 4294967295 = 0xFFFF_FFFF.
pub fn nb_mask32(x: i64) -> i64 {
    x & 4294967295
}
// rotr32 — right-rotate in the 32-bit domain (shift-based, NOT subtraction).
pub fn nb_rotr32(x: i64, n: i64) -> i64 {
    ((x >> n) | (x << (32 - n))) & 4294967295
}
// shr32 — logical right-shift in the 32-bit domain.
pub fn nb_shr32(x: i64, n: i64) -> i64 {
    (x >> n) & 4294967295
}
// ch(x,y,z) = (x AND y) XOR (NOT x AND z); NOT x = 0xffffffff - (x & 0xffffffff).
pub fn nb_ch(x: i64, y: i64, z: i64) -> i64 {
    let notx: i64 = 4294967295 - (x & 4294967295);
    nb_mask32((x & y) ^ (notx & z))
}
// maj(x,y,z) = (x AND y) XOR (x AND z) XOR (y AND z).
pub fn nb_maj(x: i64, y: i64, z: i64) -> i64 {
    nb_mask32((x & y) ^ (x & z) ^ (y & z))
}
// Σ0(a) = ROTR2 ^ ROTR13 ^ ROTR22 ; Σ1(e) = ROTR6 ^ ROTR11 ^ ROTR25.
pub fn nb_bsig0(x: i64) -> i64 {
    nb_mask32(nb_rotr32(x, 2) ^ nb_rotr32(x, 13) ^ nb_rotr32(x, 22))
}
pub fn nb_bsig1(x: i64) -> i64 {
    nb_mask32(nb_rotr32(x, 6) ^ nb_rotr32(x, 11) ^ nb_rotr32(x, 25))
}
// σ0(w) = ROTR7 ^ ROTR18 ^ SHR3 ; σ1(w) = ROTR17 ^ ROTR19 ^ SHR10.
pub fn nb_ssig0(x: i64) -> i64 {
    nb_mask32(nb_rotr32(x, 7) ^ nb_rotr32(x, 18) ^ nb_shr32(x, 3))
}
pub fn nb_ssig1(x: i64) -> i64 {
    nb_mask32(nb_rotr32(x, 17) ^ nb_rotr32(x, 19) ^ nb_shr32(x, 10))
}

// K[0..63] — FIPS 180-4 §4.2.2 cube-root constants (Rust SHA256_K, decimal).
pub fn nb_k_word(i: i64) -> i64 {
