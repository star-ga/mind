// ===== Token-stream accessors =====

pub fn tok_kind(toks: Vec, i: i64) -> i64 {
    vec_get(toks, i * 3)
}
pub fn tok_lo(toks: Vec, i: i64) -> i64 {
    vec_get(toks, i * 3 + 1)
}
pub fn tok_hi(toks: Vec, i: i64) -> i64 {
    vec_get(toks, i * 3 + 2)
}

pub fn tok_count(toks: Vec) -> i64 {
    vec_len(toks) / 3
}

pub fn at_eof(toks: Vec, pos: i64) -> i64 {
    if pos >= tok_count(toks) {
        return 1;
    }
    if tok_kind(toks, pos) == tk_eof() {
        return 1;
    }
    0
}

// ===== AST node layout (7×i64 heap record, 56 bytes) =====

pub fn ast_alloc() -> i64 {
    __mind_alloc(56)
}

pub fn ast_new_leaf(kind: i64, span_lo: i64, span_hi: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, kind);
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, 0);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_binop(span_lo: i64, span_hi: i64, lhs: i64, rhs: i64, op: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_binop());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, lhs);
    __mind_store_i64(n + 32, rhs);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, op);
    n
}

pub fn ast_new_call(span_lo: i64, span_hi: i64, callee: i64, args_vec_addr: i64, args_len: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_call());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, callee);
    __mind_store_i64(n + 32, args_vec_addr);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, args_len);
    n
}

pub fn ast_new_fn_def(span_lo: i64, span_hi: i64, name: i64, params_addr: i64, body: i64, params_len: i64, is_pub: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_fn_def());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name);
    __mind_store_i64(n + 32, params_addr);
    __mind_store_i64(n + 40, body);
    __mind_store_i64(n + 48, params_len * 2 + is_pub);
    n
}

pub fn ast_new_let(span_lo: i64, span_hi: i64, name: i64, ty: i64, init: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_let());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name);
    __mind_store_i64(n + 32, ty);
    __mind_store_i64(n + 40, init);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_use(span_lo: i64, span_hi: i64, head: i64, tail: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_use());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, head);
    __mind_store_i64(n + 32, tail);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_return(span_lo: i64, span_hi: i64, value: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_return());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, value);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_param(span_lo: i64, span_hi: i64, name: i64, ty: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_param());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name);
    __mind_store_i64(n + 32, ty);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_block(span_lo: i64, span_hi: i64, stmts_addr: i64, stmts_len: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_block());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, stmts_addr);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, stmts_len);
    n
}

pub fn ast_new_program(span_lo: i64, span_hi: i64, items_addr: i64, items_len: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_program());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, items_addr);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, items_len);
    n
}

pub fn ast_new_paren(span_lo: i64, span_hi: i64, inner: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_paren());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, inner);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_neg(span_lo: i64, span_hi: i64, operand: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_neg());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, operand);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_not(span_lo: i64, span_hi: i64, operand: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_not());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, operand);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

// `receiver.field`: child0=receiver expr, child1/child2 (offsets 32/40) carry
// the field-name span (lo/hi) into the source buffer.  Mirrors the Rust
// front-end's ast::Node::FieldAccess { receiver, field, span }.  The emitter
// (emit_expr_env ast_field arm) lowers it to a single `const.i64 0` — the
// byte-identical match to lower.rs's FieldAccess `None` arm, taken whenever the
// receiver's struct type is unresolvable (the bootstrap parser tracks no
// struct field-name order, so every field access lands on that arm).
pub fn ast_new_field(span_lo: i64, span_hi: i64, receiver: i64, field_lo: i64, field_hi: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_field());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, receiver);
    __mind_store_i64(n + 32, field_lo);
    __mind_store_i64(n + 40, field_hi);
    __mind_store_i64(n + 48, 0);
    n
}

// `Name { f0: e0, f1: e1, ... }`: child0=struct-name span_lo, child1=fields
// vec addr, child2=struct-name span_hi, aux=field count. The fields vec stores
// 3×i64 per field in SOURCE ORDER: (field-name span_lo, field-name span_hi,
// value-expr node). PARSE-ONLY — flatten_ast rejects ast_struct_lit so the
// emitter fails closed (no bytes) until the desugar half lands. Mirrors the
// Rust front-end's ast::Node::StructLit { name, fields }.
pub fn ast_new_struct_lit(span_lo: i64, span_hi: i64, name_lo: i64, name_hi: i64, fields_addr: i64, field_count: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_struct_lit());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name_lo);
    __mind_store_i64(n + 32, fields_addr);
    __mind_store_i64(n + 40, name_hi);
    __mind_store_i64(n + 48, field_count);
    n
}

// `if cond { then } else { else }`: child0=cond expr, child1=then-block,
// child2=else-block (0 when no else clause).  Matches the Rust front-end's
// ast::Node::If (cond / then_branch / else_branch).
pub fn ast_new_if(span_lo: i64, span_hi: i64, cond: i64, then_blk: i64, else_blk: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_if());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, cond);
    __mind_store_i64(n + 32, then_blk);
    __mind_store_i64(n + 40, else_blk);
    __mind_store_i64(n + 48, 0);
    n
}

// ===== AST accessors =====

pub fn ast_kind(node: i64) -> i64 {
    __mind_load_i64(node + 0)
}
pub fn ast_span_lo(node: i64) -> i64 {
    __mind_load_i64(node + 8)
}
pub fn ast_span_hi(node: i64) -> i64 {
    __mind_load_i64(node + 16)
}
pub fn ast_child0(node: i64) -> i64 {
    __mind_load_i64(node + 24)
}
pub fn ast_child1(node: i64) -> i64 {
    __mind_load_i64(node + 32)
}
pub fn ast_child2(node: i64) -> i64 {
    __mind_load_i64(node + 40)
}
pub fn ast_aux(node: i64) -> i64 {
    __mind_load_i64(node + 48)
}

// ===== ParseResult =====

struct ParseResult {
    next_pos: i64,
    node: i64,
}

pub fn pr_new(next_pos: i64, node: i64) -> ParseResult {
    ParseResult { next_pos: next_pos, node: node }
}

pub fn pr_pos(r: ParseResult) -> i64 {
    r.next_pos
}
pub fn pr_node(r: ParseResult) -> i64 {
    r.node
}

// ===== Return-keyword detector =====

pub fn is_ident_return(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo) == 114 {
            if load_byte(buf, lo + 1) == 101 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 117 {
                        if load_byte(buf, lo + 4) == 114 {
                            if load_byte(buf, lo + 5) == 110 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// ===== Pratt precedence table =====

// Binding precedence (higher = tighter). The bitwise/shift ops are interleaved to
// match the Rust mindc parser exactly (verified vs --emit-mic3): multiplicative >
// additive > comparison > shift > bitand > bitxor > bitor > assignment. The
// pre-existing levels (assignment / comparison / additive / multiplicative) keep
// their relative order; the bitwise tiers are inserted between comparison and
// assignment, so the existing levels are renumbered upward (no tree-shape change
// for non-bitwise expressions — relative ordering is what the Pratt loop reads).
pub fn infix_prec(kind: i64) -> i64 {
    if kind == tk_eq() {
        return 1;
    }
    if kind == tk_pipe() {
        return 2;
    }
    if kind == tk_caret() {
        return 3;
    }
    if kind == tk_amp() {
        return 4;
    }
    if kind == tk_shl() {
        return 5;
    }
    if kind == tk_shr() {
        return 5;
    }
    if kind == tk_lt() {
        return 6;
    }
    if kind == tk_gt() {
        return 6;
    }
    if kind == tk_eqeq() {
        return 6;
    }
    if kind == tk_le() {
        return 6;
    }
    if kind == tk_ge() {
        return 6;
    }
    if kind == tk_ne() {
        return 6;
    }
    if kind == tk_plus() {
        return 7;
    }
    if kind == tk_minus() {
        return 7;
    }
    if kind == tk_star() {
        return 8;
    }
    if kind == tk_slash() {
        return 8;
    }
    0
}

pub fn tk_to_op(kind: i64) -> i64 {
    if kind == tk_plus() {
        return op_add();
    }
    if kind == tk_minus() {
        return op_sub();
    }
    if kind == tk_star() {
        return op_mul();
    }
    if kind == tk_slash() {
        return op_div();
    }
    if kind == tk_lt() {
        return op_lt();
    }
    if kind == tk_gt() {
        return op_gt();
    }
    if kind == tk_eq() {
        return op_eq();
    }
    if kind == tk_eqeq() {
        return op_eq();
    }
    if kind == tk_le() {
        return op_le();
    }
    if kind == tk_ge() {
        return op_ge();
    }
    if kind == tk_ne() {
        return op_ne();
    }
    if kind == tk_amp() {
        return op_bitand();
    }
    if kind == tk_pipe() {
        return op_bitor();
    }
    if kind == tk_caret() {
        return op_bitxor();
    }
    if kind == tk_shl() {
        return op_shl();
    }
    if kind == tk_shr() {
        return op_shr();
    }
    0
}

// ===== Primary / prefix parser =====

// Struct-literal disambiguation (mirrors the Rust front-end): an `Ident {` in
// expression position is a struct-literal CONSTRUCTION, EXCEPT in CONDITION
// position (the head of `if`/`while`/`for`/`match`), where the `{` opens the
// block, not a literal. The `no_struct` flag carries that context: it is set
// only on the condition expression and threaded down parse_expr → parse_postfix
// → parse_primary → parse_pratt. It is RESET to "allowed" inside any
// parenthesised group (parse_expr) and any call-arg list (parse_args_rest), so
// `if f(P { .. }) { }` still parses the inner literal. main.mind never uses a
// struct-literal as a condition, so the only observable effect of this rule is
// that existing `if/while/for IDENT {` parses stay byte-identical.
//
// `parse_primary` keeps its 3-arg signature (struct-lit ALLOWED) as a thin
// wrapper so every pre-existing call-site is unchanged; the threaded core lives
// in `parse_primary_ns`.
pub fn parse_primary(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_primary_ns(toks, pos, buf, 0)
}

pub fn parse_primary_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);

    if k == tk_kw_if() {
        return parse_if(toks, pos, buf);
    }

    if k == tk_minus() {
        let operand: ParseResult = parse_primary_ns(toks, pos + 1, buf, no_struct);
        let opnode: i64 = pr_node(operand);
        let neg: i64 = ast_new_neg(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), neg);
    }

    if k == tk_bang() {
        let operand: ParseResult = parse_primary_ns(toks, pos + 1, buf, no_struct);
        let opnode: i64 = pr_node(operand);
        let notn: i64 = ast_new_not(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), notn);
    }

    if k == tk_int() {
        let n: i64 = ast_new_leaf(ast_int_lit(), lo, hi);
        return pr_new(pos + 1, n);
    }

    if k == tk_lparen() {
        // Parenthesised group RESETS no_struct: `( Ident { .. } )` is a literal.
        let inner: ParseResult = parse_expr(toks, pos + 1, buf);
        let after_inner: i64 = pr_pos(inner);
        let close_hi: i64 = tok_hi(toks, after_inner);
        let after_close: i64 = if tok_kind(toks, after_inner) == tk_rparen() {
            after_inner + 1
        } else {
            after_inner
        };
        let paren: i64 = ast_new_paren(lo, close_hi, pr_node(inner));
        return pr_new(after_close, paren);
    }

    if k == tk_ident() {
        // Match-expression: `match SCRUT { ... }` desugars at parse time to an
        // ast_if. Detected via is_ident_match (match is a bare ident, not a
        // keyword token), mirroring the is_struct_kw dispatch. Checked before
        // the call/struct-lit shapes so `match c { ... }` never misreads.
        if is_ident_match(buf, lo, hi) == 1 {
            return parse_match(toks, pos, buf);
        }
        if at_eof(toks, pos + 1) == 0 {
            if tok_kind(toks, pos + 1) == tk_lparen() {
                return parse_call(toks, pos, buf);
            }
        }
        // Struct-literal: `Ident {` in non-condition expression position. Gated
        // by no_struct so condition-position `if IDENT {` keeps the `{` as the
        // block opener (byte-identical to the pre-existing parse).
        if no_struct == 0 {
            if at_eof(toks, pos + 1) == 0 {
                if tok_kind(toks, pos + 1) == tk_lbrace() {
                    return parse_struct_lit(toks, pos, buf);
                }
            }
        }
        let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
        return pr_new(pos + 1, n);
    }

    let fallback: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, fallback)
}

// Parse `Name { f0: e0, f1: e1, ... }` (optional trailing comma) into an
// ast_struct_lit. `pos` is the struct-name ident; `pos+1` is the `{`. Field
// values are full expressions (struct-lit ALLOWED inside — each value resets
// the no_struct context via parse_expr). Fields are collected in SOURCE ORDER
// as 3×i64 (name_lo, name_hi, value_node) so a later desugar can sort them to
// declared field order. PARSE-ONLY: the resulting node is rejected by
// flatten_ast, so no bytes are emitted yet.
pub fn parse_struct_lit(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let name_lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let open: i64 = pos + 1;
    let fields: Vec = vec_new();

    if tok_kind(toks, open + 1) == tk_rbrace() {
        let close_hi: i64 = tok_hi(toks, open + 1);
        let node: i64 = ast_new_struct_lit(name_lo, close_hi, name_lo, name_hi, vec_addr(fields), 0);
        return pr_new(open + 2, node);
    }

    let res: ParseResult = parse_struct_fields_rest(toks, open + 1, buf, fields);
    let after_fields: i64 = pr_pos(res);
    let fields_node: i64 = pr_node(res);
    let fields_addr: i64 = ast_child0(fields_node);
    let triples: i64 = ast_aux(fields_node);

    let close_hi: i64 = tok_hi(toks, after_fields);
    let after_close: i64 = if tok_kind(toks, after_fields) == tk_rbrace() {
        after_fields + 1
    } else {
        after_fields
    };
    let node: i64 = ast_new_struct_lit(name_lo, close_hi, name_lo, name_hi, fields_addr, triples / 3);
    pr_new(after_close, node)
}

// Collect `name: expr` field-inits (comma-separated, optional trailing comma)
// into `acc` as 3×i64 triples (name_lo, name_hi, value_node). Stops at `}` or a
// trailing comma followed by `}`. Returns a sentinel block node carrying the
// accumulated vec (child0=addr, aux=triple count), matching parse_args_rest.
pub fn parse_struct_fields_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if tok_kind(toks, pos) == tk_rbrace() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let fname_lo: i64 = tok_lo(toks, pos);
    let fname_hi: i64 = tok_hi(toks, pos);
    // pos = field-name ident, pos+1 = `:`, pos+2 = value expression.
    let val: ParseResult = parse_expr(toks, pos + 2, buf);
    let after_val: i64 = pr_pos(val);
    let a1: Vec = vec_push(acc, fname_lo);
    let a2: Vec = vec_push(a1, fname_hi);
    let a3: Vec = vec_push(a2, pr_node(val));
    if tok_kind(toks, after_val) == tk_comma() {
        return parse_struct_fields_rest(toks, after_val + 1, buf, a3);
    }
    let s: i64 = ast_new_block(0, 0, vec_addr(a3), vec_len(a3));
    pr_new(after_val, s)
}

// ===== Call parser =====

pub fn parse_call(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let callee: i64 = ast_new_leaf(ast_ident(), lo, name_hi);

    let empty_args: Vec = vec_new();
    let after_open: i64 = pos + 2;

    if tok_kind(toks, after_open) == tk_rparen() {
        let close_hi: i64 = tok_hi(toks, after_open);
        let call_node: i64 = ast_new_call(lo, close_hi, callee, vec_addr(empty_args), 0);
        return pr_new(after_open + 1, call_node);
    }

    let args_res: ParseResult = parse_args_rest(toks, after_open, buf, empty_args);
    let after_args: i64 = pr_pos(args_res);
    let args_node: i64 = pr_node(args_res);
    let args_addr: i64 = ast_child0(args_node);
    let args_len: i64 = ast_aux(args_node);

    let close_hi: i64 = tok_hi(toks, after_args);
    let after_close: i64 = if tok_kind(toks, after_args) == tk_rparen() {
        after_args + 1
    } else {
        after_args
    };

    let call_node: i64 = ast_new_call(lo, close_hi, callee, args_addr, args_len);
    pr_new(after_close, call_node)
}

pub fn parse_args_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    let one: ParseResult = parse_expr(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    let after_one: i64 = pr_pos(one);
    if tok_kind(toks, after_one) == tk_comma() {
        return parse_args_rest(toks, after_one + 1, buf, new_acc);
    }
    let sentinel: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_one, sentinel)
}

// ===== Pratt expression parser =====

pub fn parse_expr(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_expr_ns(toks, pos, buf, 0)
}

// no_struct-threaded expression entry. `parse_expr` (struct-lit ALLOWED) is the
// 3-arg wrapper; condition parsers (parse_if + the while/for/match heads) call
// this with no_struct=1 so an `Ident {` head is NOT mis-read as a struct-lit.
pub fn parse_expr_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let prim: ParseResult = parse_postfix_ns(toks, pos, buf, no_struct);
    parse_pratt_ns(toks, pr_pos(prim), buf, pr_node(prim), 1, no_struct)
}

// Postfix wrapper around parse_primary: after a primary is parsed, greedily
// consume trailing `.field` accesses so `a.b.c` chains left-associatively into
// nested ast_field nodes.  Field access binds tighter than any infix operator
// (it is applied before parse_pratt), matching the Rust front-end where
// FieldAccess is built in primary position.  Each `.field` requires the dot to
// be followed by an identifier; a bare trailing dot is left for the primary
// fallback (it simply stops the loop).
pub fn parse_postfix(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_postfix_ns(toks, pos, buf, 0)
}

pub fn parse_postfix_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let prim: ParseResult = parse_primary_ns(toks, pos, buf, no_struct);
    parse_postfix_rest(toks, pr_pos(prim), buf, pr_node(prim))
}

pub fn parse_postfix_rest(toks: Vec, pos: i64, buf: i64, recv: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, recv);
    }
    if tok_kind(toks, pos) != tk_dot() {
        return pr_new(pos, recv);
    }
    if tok_kind(toks, pos + 1) != tk_ident() {
        return pr_new(pos, recv);
    }
    let field_lo: i64 = tok_lo(toks, pos + 1);
    let field_hi: i64 = tok_hi(toks, pos + 1);
    let recv_lo: i64 = ast_span_lo(recv);
    let fa: i64 = ast_new_field(recv_lo, field_hi, recv, field_lo, field_hi);
    parse_postfix_rest(toks, pos + 2, buf, fa)
}

pub fn parse_pratt(toks: Vec, pos: i64, buf: i64, lhs: i64, min_prec: i64) -> ParseResult {
    parse_pratt_ns(toks, pos, buf, lhs, min_prec, 0)
}

// no_struct propagates to every RHS operand: in `i < n` condition position the
// `n` is still condition position, so `n { ... }` is NOT a struct-lit either.
pub fn parse_pratt_ns(toks: Vec, pos: i64, buf: i64, lhs: i64, min_prec: i64, no_struct: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, lhs);
    }
    let k: i64 = tok_kind(toks, pos);
    let prec: i64 = infix_prec(k);
    if prec == 0 {
        return pr_new(pos, lhs);
    }
    if prec < min_prec {
        return pr_new(pos, lhs);
    }

    let op_tag: i64 = tk_to_op(k);
    let rhs_prim: ParseResult = parse_postfix_ns(toks, pos + 1, buf, no_struct);
    let rhs_full: ParseResult = parse_pratt_ns(toks, pr_pos(rhs_prim), buf, pr_node(rhs_prim), prec + 1, no_struct);

    let lhs_lo: i64 = ast_span_lo(lhs);
    let rhs_hi: i64 = ast_span_hi(pr_node(rhs_full));
    let combined: i64 = ast_new_binop(lhs_lo, rhs_hi, lhs, pr_node(rhs_full), op_tag);

    parse_pratt_ns(toks, pr_pos(rhs_full), buf, combined, min_prec, no_struct)
}

// ===== Statements =====

pub fn parse_stmt(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_let() {
        return parse_let(toks, pos, buf);
    }
    if k == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_ident_return(buf, lo, hi) == 1 {
            return parse_return(toks, pos, buf);
        }
    }
    let e: ParseResult = parse_expr(toks, pos, buf);
    let after_e: i64 = pr_pos(e);
    if tok_kind(toks, after_e) == tk_semi() {
        return pr_new(after_e + 1, pr_node(e));
    }
    e
}

pub fn parse_let(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let name_lo: i64 = tok_lo(toks, pos + 1);
    let name_hi: i64 = tok_hi(toks, pos + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);
    let ty_lo: i64 = tok_lo(toks, pos + 3);
    let ty_hi: i64 = tok_hi(toks, pos + 3);
    let ty: i64 = ast_new_leaf(ast_ident(), ty_lo, ty_hi);
    let init: ParseResult = parse_expr(toks, pos + 5, buf);
    let after_init: i64 = pr_pos(init);
    let after_semi: i64 = if tok_kind(toks, after_init) == tk_semi() {
        after_init + 1
    } else {
        after_init
    };
    let init_hi: i64 = ast_span_hi(pr_node(init));
    let let_node: i64 = ast_new_let(kw_lo, init_hi, name, ty, pr_node(init));
    pr_new(after_semi, let_node)
}

pub fn parse_return(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let value: ParseResult = parse_expr(toks, pos + 1, buf);
    let after_v: i64 = pr_pos(value);
    let after_semi: i64 = if tok_kind(toks, after_v) == tk_semi() {
        after_v + 1
    } else {
        after_v
    };
    let v_hi: i64 = ast_span_hi(pr_node(value));
    let r: i64 = ast_new_return(kw_lo, v_hi, pr_node(value));
    pr_new(after_semi, r)
}

// ===== Blocks =====

pub fn parse_block(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let open_lo: i64 = tok_lo(toks, pos);
    let acc: Vec = vec_new();
    let body: ParseResult = parse_block_stmts(toks, pos + 1, buf, acc);
    let after_body: i64 = pr_pos(body);
    let stmts_node: i64 = pr_node(body);
    let stmts_addr: i64 = ast_child0(stmts_node);
    let stmts_len: i64 = ast_aux(stmts_node);

    let close_hi: i64 = tok_hi(toks, after_body);
    let after_close: i64 = if tok_kind(toks, after_body) == tk_rbrace() {
        after_body + 1
    } else {
        after_body
    };
    let blk: i64 = ast_new_block(open_lo, close_hi, stmts_addr, stmts_len);
    pr_new(after_close, blk)
}

pub fn parse_block_stmts(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_stmt(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_block_stmts(toks, pr_pos(one), buf, new_acc)
}

// ===== If-expressions =====
//
// `if COND { THEN } else { ELSE }` — COND is a full expression (parse_expr
// stops at the `{` because `{` has no infix precedence), THEN/ELSE reuse the
// function-body block parser.  The else clause is optional; when absent,
// child2 is left 0.  Mirrors the Rust front-end's ast::Node::If.
pub fn parse_if(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    // Condition position: no_struct=1 so `if IDENT {` keeps `{` as the block
    // opener (byte-identical to the pre-struct-lit parse).
    let cond: ParseResult = parse_expr_ns(toks, pos + 1, buf, 1);
    let after_cond: i64 = pr_pos(cond);

    let then_res: ParseResult = parse_block(toks, after_cond, buf);
    let after_then: i64 = pr_pos(then_res);
    let then_blk: i64 = pr_node(then_res);
    let then_hi: i64 = ast_span_hi(then_blk);

    if tok_kind(toks, after_then) == tk_kw_else() {
        let else_res: ParseResult = parse_block(toks, after_then + 1, buf);
        let after_else: i64 = pr_pos(else_res);
        let else_blk: i64 = pr_node(else_res);
        let else_hi: i64 = ast_span_hi(else_blk);
        let if_node: i64 = ast_new_if(kw_lo, else_hi, pr_node(cond), then_blk, else_blk);
        return pr_new(after_else, if_node);
    }

    let if_node: i64 = ast_new_if(kw_lo, then_hi, pr_node(cond), then_blk, 0);
    pr_new(after_then, if_node)
}

// ===== Match-expressions (parse-time desugar to if) =====
//
// `match SCRUT { PAT => VAL0, _ => VAL1 }` desugars at PARSE TIME to the
// equivalent `if SCRUT == PAT { VAL0 } else { VAL1 }`.  Both forms lower to a
// byte-IDENTICAL mic@3 stream (an OP_IF 0x1C chain) — proven against
// `mindc --emit-mic3` — so building the ast_if here reuses the existing
// if-emitter (emit_mic3_module_fndef_if and the recursive if path) with ZERO
// new emit code.  `match` is NOT a keyword token: it lexes as a bare tk_ident
// spelling "match" (detected via is_ident_match), the same disambiguation the
// struct-literal path uses for is_struct_kw.
//
// SCOPE: the minimal 2-arm shape — one int-literal pattern arm plus one
// wildcard `_` arm.  N-arm / nested patterns are a later increment.
//
// Token layout (the fat arrow `=>` lexes as the two tokens tk_eq tk_gt):
//   match SCRUT { PAT => VAL0 , _ => VAL1 }
//   ^pos         ^lbrace
// SCRUT is parsed with no_struct=1 so `match c {` keeps the `{` as the arm
// block (NOT a struct literal), byte-identical to the if-condition parse.
pub fn parse_match(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    // Scrutinee: no_struct=1 so the `{` opens the arms, not a struct literal.
    let scrut: ParseResult = parse_expr_ns(toks, pos + 1, buf, 1);
    let lbrace_pos: i64 = pr_pos(scrut);
    let scrut_node: i64 = pr_node(scrut);

    // Arm 0 pattern: int-literal token at lbrace_pos+1.
    let pat_pos: i64 = lbrace_pos + 1;
    let pat_lo: i64 = tok_lo(toks, pat_pos);
    let pat_hi: i64 = tok_hi(toks, pat_pos);
    let pat_lit: i64 = ast_new_leaf(ast_int_lit(), pat_lo, pat_hi);

    // `=>` is two tokens (tk_eq tk_gt); arm-0 value expression follows it.
    let val0_pos: i64 = pat_pos + 3;
    let val0: ParseResult = parse_expr(toks, val0_pos, buf);
    let after_val0: i64 = pr_pos(val0);

    // Optional comma, then the wildcard `_` arm.
    let wild_pos: i64 = if tok_kind(toks, after_val0) == tk_comma() {
        after_val0 + 1
    } else {
        after_val0
    };
    // wild_pos = `_` ident, wild_pos+1/+2 = `=>`, wild_pos+3 = value expr.
    let val1_pos: i64 = wild_pos + 3;
    let val1: ParseResult = parse_expr(toks, val1_pos, buf);
    let after_val1: i64 = pr_pos(val1);

    let close_hi: i64 = tok_hi(toks, after_val1);
    let after_close: i64 = if tok_kind(toks, after_val1) == tk_rbrace() {
        after_val1 + 1
    } else {
        after_val1
    };

    // cond = SCRUT == PAT.
    let cond: i64 = ast_new_binop(kw_lo, pat_hi, scrut_node, pat_lit, op_eq());

    // then = { VAL0 } (single-statement block), else = { VAL1 }.
    let then_acc: Vec = vec_new();
    let then_acc1: Vec = vec_push(then_acc, pr_node(val0));
    let then_blk: i64 = ast_new_block(val0_pos, ast_span_hi(pr_node(val0)), vec_addr(then_acc1), vec_len(then_acc1));

    let else_acc: Vec = vec_new();
    let else_acc1: Vec = vec_push(else_acc, pr_node(val1));
    let else_blk: i64 = ast_new_block(val1_pos, ast_span_hi(pr_node(val1)), vec_addr(else_acc1), vec_len(else_acc1));

    let if_node: i64 = ast_new_if(kw_lo, close_hi, cond, then_blk, else_blk);
    pr_new(after_close, if_node)
}

// ===== Function definitions =====

pub fn parse_fn_def(toks: Vec, pos: i64, buf: i64, is_pub: i64) -> ParseResult {
    let fn_lo: i64 = tok_lo(toks, pos);
    let name_lo: i64 = tok_lo(toks, pos + 1);
    let name_hi: i64 = tok_hi(toks, pos + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);

    let params_acc: Vec = vec_new();
    let params_res: ParseResult = parse_params_rest(toks, pos + 3, buf, params_acc);
    let after_params: i64 = pr_pos(params_res);
    let params_node: i64 = pr_node(params_res);
    let params_addr: i64 = ast_child0(params_node);
    let params_len: i64 = ast_aux(params_node);

    let after_rparen: i64 = if tok_kind(toks, after_params) == tk_rparen() {
        after_params + 1
    } else {
        after_params
    };
    let after_arrow: i64 = if tok_kind(toks, after_rparen) == tk_arrow() {
        after_rparen + 1
    } else {
        after_rparen
    };
    let after_ret: i64 = after_arrow + 1;

    let body_res: ParseResult = parse_block(toks, after_ret, buf);
    let body_hi: i64 = ast_span_hi(pr_node(body_res));

    let fn_node: i64 = ast_new_fn_def(fn_lo, body_hi, name, params_addr, pr_node(body_res), params_len, is_pub);
    pr_new(pr_pos(body_res), fn_node)
}

pub fn parse_params_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if tok_kind(toks, pos) == tk_rparen() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let n_lo: i64 = tok_lo(toks, pos);
    let n_hi: i64 = tok_hi(toks, pos);
    let n_name: i64 = ast_new_leaf(ast_ident(), n_lo, n_hi);
    let t_lo: i64 = tok_lo(toks, pos + 2);
    let t_hi: i64 = tok_hi(toks, pos + 2);
    let n_ty: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let p: i64 = ast_new_param(n_lo, t_hi, n_name, n_ty);
    let new_acc: Vec = vec_push(acc, p);
    let after_param: i64 = pos + 3;
    if tok_kind(toks, after_param) == tk_comma() {
        return parse_params_rest(toks, after_param + 1, buf, new_acc);
    }
    let s: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_param, s)
}

// ===== Use statements =====

pub fn parse_use(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let use_lo: i64 = tok_lo(toks, pos);
    let h_lo: i64 = tok_lo(toks, pos + 1);
    let h_hi: i64 = tok_hi(toks, pos + 1);
    let head: i64 = ast_new_leaf(ast_ident(), h_lo, h_hi);
    let t_lo: i64 = tok_lo(toks, pos + 3);
    let t_hi: i64 = tok_hi(toks, pos + 3);
    let tail: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let after_semi: i64 = if tok_kind(toks, pos + 4) == tk_semi() {
        pos + 5
    } else {
        pos + 4
    };
    let node: i64 = ast_new_use(use_lo, t_hi, head, tail);
    pr_new(after_semi, node)
}

// ===== Top-level item / program =====

pub fn parse_item(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_use() {
        return parse_use(toks, pos, buf);
    }
    if k == tk_kw_pub() {
        // `pub struct T { .. }` is a struct def (skip `pub`, parse from `struct`);
        // anything else after `pub` is a pub fn. (main.mind's own structs are bare
        // `struct`, so this never perturbs the canary fixed point.)
        if tok_kind(toks, pos + 1) == tk_ident() {
            if is_struct_kw(buf, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1)) == 1 {
                return parse_struct_def(toks, pos + 1, buf);
            }
        }
        return parse_fn_def(toks, pos + 1, buf, 1);
    }
    if k == tk_kw_fn() {
        return parse_fn_def(toks, pos, buf, 0);
    }
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);
    if k == tk_ident() {
        if is_struct_kw(buf, lo, hi) == 1 {
            return parse_struct_def(toks, pos, buf);
        }
    }
    let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, n)
}

pub fn parse_items_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_item(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_items_rest(toks, pr_pos(one), buf, new_acc)
}

// ===== Public entry: parse =====

pub fn parse(toks: Vec, buf: i64) -> i64 {
    let acc: Vec = vec_new();
    let res: ParseResult = parse_items_rest(toks, 0, buf, acc);
    let s: i64 = pr_node(res);
    let items_addr: i64 = ast_child0(s);
    let items_len: i64 = ast_aux(s);
    ast_new_program(0, 0, items_addr, items_len)
}

// ===========================================================================
// SECTION 3 — TYPE CHECKER (Phase 6.3)
// examples/typecheck/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: typecheck(ast_root: i64, buf: i64) -> String
// ===========================================================================

// ===== Type tags =====

pub fn ty_unknown() -> i64 {
    0
}
pub fn ty_i64() -> i64 {
    1
}
pub fn ty_f64() -> i64 {
    2
}
pub fn ty_bool() -> i64 {
    3
}
pub fn ty_vec() -> i64 {
    4
}
pub fn ty_string() -> i64 {
    5
}
pub fn ty_unit() -> i64 {
    6
}

// ===== Fn-def aux unpacking =====

pub fn fn_def_params_len(node: i64) -> i64 {
    ast_aux(node) / 2
}
pub fn fn_def_is_pub(node: i64) -> i64 {
    ast_aux(node) - (ast_aux(node) / 2) * 2
}

// ===== Byte-range equality =====

pub fn bytes_eq(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64, chi: i64) -> i64 {
    if hi - lo == chi - clo {
        return bytes_eq_rest(buf, lo, hi, cmp_buf, clo);
    }
    0
}

pub fn bytes_eq_rest(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64) -> i64 {
    if lo >= hi {
        return 1;
    }
    if load_byte(buf, lo) == load_byte(cmp_buf, clo) {
        return bytes_eq_rest(buf, lo + 1, hi, cmp_buf, clo + 1);
    }
    0
}

// ===== Type-name byte tables =====

pub fn make_byte_buf_3(b0: i64, b1: i64, b2: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    h
}

pub fn make_byte_buf_4(b0: i64, b1: i64, b2: i64, b3: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    h
}

pub fn make_byte_buf_6(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    __mind_store_i64(h + 4, b4);
    __mind_store_i64(h + 5, b5);
    h
}

pub fn name_buf_i64() -> i64 {
    make_byte_buf_3(105, 54, 52)
}
pub fn name_buf_f64() -> i64 {
    make_byte_buf_3(102, 54, 52)
}
pub fn name_buf_bool() -> i64 {
    make_byte_buf_4(98, 111, 111, 108)
}
pub fn name_buf_vec() -> i64 {
    make_byte_buf_3(86, 101, 99)
}
pub fn name_buf_string() -> i64 {
    make_byte_buf_6(83, 116, 114, 105, 110, 103)
}

pub fn resolve_type_ident(buf: i64, lo: i64, hi: i64) -> i64 {
    let i64_buf: i64 = name_buf_i64();
    if bytes_eq(buf, lo, hi, i64_buf, 0, 3) == 1 {
        return ty_i64();
    }
    let f64_buf: i64 = name_buf_f64();
    if bytes_eq(buf, lo, hi, f64_buf, 0, 3) == 1 {
        return ty_f64();
    }
    let bool_buf: i64 = name_buf_bool();
    if bytes_eq(buf, lo, hi, bool_buf, 0, 4) == 1 {
        return ty_bool();
    }
    let vec_buf: i64 = name_buf_vec();
    if bytes_eq(buf, lo, hi, vec_buf, 0, 3) == 1 {
        return ty_vec();
    }
    let str_buf: i64 = name_buf_string();
    if bytes_eq(buf, lo, hi, str_buf, 0, 6) == 1 {
        return ty_string();
    }
    ty_unknown()
}

// ===== Name hashing (DJB2) =====

pub fn djb2_seed() -> i64 {
    5381
}
pub fn djb2_prime() -> i64 {
    33
}

pub fn name_hash(buf: i64, lo: i64, hi: i64) -> i64 {
    name_hash_rest(buf, lo, hi, djb2_seed())
}

pub fn name_hash_rest(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    let mixed: i64 = (acc * djb2_prime()) + b;
    name_hash_rest(buf, lo + 1, hi, mixed)
}

// ===== Env helpers =====

pub fn env_new() -> Map {
    map_new()
}

pub fn env_bind(env: Map, buf: i64, lo: i64, hi: i64, ty: i64) -> Map {
    let key: i64 = name_hash(buf, lo, hi);
    map_insert(env, key, ty)
}

pub fn env_lookup(env: Map, buf: i64, lo: i64, hi: i64) -> i64 {
    let key: i64 = name_hash(buf, lo, hi);
    env_lookup_rest(env, key, 0, ty_unknown())
}

pub fn env_lookup_rest(env: Map, key: i64, i: i64, best: i64) -> i64 {
    if i >= map_len(env) {
        return best;
    }
    let new_best: i64 = if map_key_at(env, i) == key {
        map_value_at(env, i)
    } else {
        best
    };
    env_lookup_rest(env, key, i + 1, new_best)
}

// ===== String-building helpers (for type-check report) =====

pub fn push_ascii(s: String, b: i64) -> String {
    string_push_byte(s, b)
}
pub fn push_newline(s: String) -> String {
    string_push_byte(s, 10)
}
pub fn push_space(s: String) -> String {
    string_push_byte(s, 32)
}

pub fn push_bytes(s: String, buf: i64, lo: i64, hi: i64) -> String {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let next: String = string_push_byte(s, b);
    push_bytes(next, buf, lo + 1, hi)
}

pub fn push_type_name(s: String, ty: i64) -> String {
    if ty == ty_i64() {
        let s1: String = string_push_byte(s, 105);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_f64() {
        let s1: String = string_push_byte(s, 102);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_bool() {
        let s1: String = string_push_byte(s, 98);
        let s2: String = string_push_byte(s1, 111);
        let s3: String = string_push_byte(s2, 111);
        return string_push_byte(s3, 108);
    }
    if ty == ty_vec() {
        let s1: String = string_push_byte(s, 86);
        let s2: String = string_push_byte(s1, 101);
        return string_push_byte(s2, 99);
    }
    if ty == ty_string() {
        let s1: String = string_push_byte(s, 83);
        let s2: String = string_push_byte(s1, 116);
        let s3: String = string_push_byte(s2, 114);
        let s4: String = string_push_byte(s3, 105);
        let s5: String = string_push_byte(s4, 110);
        return string_push_byte(s5, 103);
    }
    if ty == ty_unit() {
        let s1: String = string_push_byte(s, 40);
        return string_push_byte(s1, 41);
    }
    string_push_byte(s, 63)
}

pub fn push_kw_let(s: String) -> String {
    let s1: String = string_push_byte(s, 108);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    string_push_byte(s3, 32)
}

pub fn push_kw_fn(s: String) -> String {
    let s1: String = string_push_byte(s, 102);
    let s2: String = string_push_byte(s1, 110);
    string_push_byte(s2, 32)
}

pub fn push_colon(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 58);
    string_push_byte(s2, 32)
}

pub fn push_arrow(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 45);
    let s3: String = string_push_byte(s2, 62);
    string_push_byte(s3, 32)
}

pub fn push_lparen(s: String) -> String {
    string_push_byte(s, 40)
}
pub fn push_rparen(s: String) -> String {
    string_push_byte(s, 41)
}

pub fn push_comma(s: String) -> String {
    let s1: String = string_push_byte(s, 44);
    string_push_byte(s1, 32)
}

pub fn push_kw_error(s: String) -> String {
    let s1: String = string_push_byte(s, 69);
    let s2: String = string_push_byte(s1, 82);
    let s3: String = string_push_byte(s2, 82);
    let s4: String = string_push_byte(s3, 79);
    let s5: String = string_push_byte(s4, 82);
    let s6: String = string_push_byte(s5, 58);
    string_push_byte(s6, 32)
}

pub fn push_at_span(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 97);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 32);
    let s5: String = string_push_byte(s4, 115);
    let s6: String = string_push_byte(s5, 112);
    let s7: String = string_push_byte(s6, 97);
    let s8: String = string_push_byte(s7, 110);
    let s9: String = string_push_byte(s8, 32);
    string_push_byte(s9, 91)
}

pub fn push_i64(s: String, n: i64) -> String {
    if n < 10 {
        return string_push_byte(s, 48 + n);
    }
    let high: String = push_i64(s, n / 10);
    string_push_byte(high, 48 + (n - (n / 10) * 10))
}

pub fn push_err_return_mismatch(s: String) -> String {
    let s1: String = string_push_byte(s, 114);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 117);
    let s5: String = string_push_byte(s4, 114);
    let s6: String = string_push_byte(s5, 110);
    let s7: String = string_push_byte(s6, 32);
    let s8: String = string_push_byte(s7, 116);
    let s9: String = string_push_byte(s8, 121);
    let s10: String = string_push_byte(s9, 112);
    let s11: String = string_push_byte(s10, 101);
    let s12: String = string_push_byte(s11, 32);
    let s13: String = string_push_byte(s12, 109);
    let s14: String = string_push_byte(s13, 105);
    let s15: String = string_push_byte(s14, 115);
    let s16: String = string_push_byte(s15, 109);
    let s17: String = string_push_byte(s16, 97);
    let s18: String = string_push_byte(s17, 116);
    let s19: String = string_push_byte(s18, 99);
    string_push_byte(s19, 104)
}

// ===== TcResult =====

struct TcResult {
    env: Map,
    report: String,
}

pub fn tc_new(env: Map, report: String) -> TcResult {
    TcResult { env: env, report: report }
}

pub fn tc_env(r: TcResult) -> Map {
    r.env
}
pub fn tc_report(r: TcResult) -> String {
    r.report
}

// ===== Expression type resolution =====

pub fn type_of_expr(node: i64, env: Map, buf: i64) -> i64 {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        return ty_i64();
    }

    if k == ast_ident() {
        let lo: i64 = ast_span_lo(node);
        let hi: i64 = ast_span_hi(node);
        return env_lookup(env, buf, lo, hi);
    }

    if k == ast_binop() {
        let op: i64 = ast_aux(node);
        if op == op_lt() {
            return ty_bool();
        }
        if op == op_gt() {
            return ty_bool();
        }
        if op == op_eq() {
            return ty_bool();
        }
        let lhs: i64 = ast_child0(node);
        return type_of_expr(lhs, env, buf);
    }

    if k == ast_paren() {
        let inner: i64 = ast_child0(node);
        return type_of_expr(inner, env, buf);
    }

    if k == ast_call() {
        return ty_unknown();
    }

    ty_unknown()
}

// ===== Statement / item walkers =====

pub fn tc_let(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let ty_node: i64 = ast_child1(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);
    let t_lo: i64 = ast_span_lo(ty_node);
    let t_hi: i64 = ast_span_hi(ty_node);

    let ty: i64 = resolve_type_ident(buf, t_lo, t_hi);
    let new_env: Map = env_bind(env, buf, n_lo, n_hi, ty);

    let s1: String = push_kw_let(report);
    let s2: String = push_bytes(s1, buf, n_lo, n_hi);
    let s3: String = push_colon(s2);
    let s4: String = push_type_name(s3, ty);
    let s5: String = push_newline(s4);

    tc_new(new_env, s5)
}

pub fn tc_return(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let value: i64 = ast_child0(node);
    let actual: i64 = type_of_expr(value, env, buf);

    if actual == expected_ret {
        return tc_new(env, report);
    }
    let lo: i64 = ast_span_lo(node);
    let hi: i64 = ast_span_hi(node);
    let s1: String = push_kw_error(report);
    let s2: String = push_err_return_mismatch(s1);
    let s3: String = push_at_span(s2);
    let s4: String = push_i64(s3, lo);
    let s5: String = push_comma(s4);
    let s6: String = push_i64(s5, hi);
    let s7: String = string_push_byte(s6, 41);
    let s8: String = push_newline(s7);
    tc_new(env, s8)
}

pub fn tc_stmt(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return tc_let(node, env, buf, report);
    }
    if k == ast_return() {
        return tc_return(node, env, buf, report, expected_ret);
    }
    let _: i64 = type_of_expr(node, env, buf);
    tc_new(env, report)
}

pub fn tc_block(block: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let stmts_addr: i64 = ast_child0(block);
    let stmts_len: i64 = ast_aux(block);
    tc_block_stmts_rest(stmts_addr, stmts_len, 0, env, buf, report, expected_ret)
}

pub fn tc_block_stmts_rest(stmts_addr: i64, stmts_len: i64, i: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    if i >= stmts_len {
        return tc_new(env, report);
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let after: TcResult = tc_stmt(stmt, env, buf, report, expected_ret);
    tc_block_stmts_rest(stmts_addr, stmts_len, i + 1, tc_env(after), buf, tc_report(after), expected_ret)
}

pub fn fn_default_ret() -> i64 {
    ty_i64()
}

pub fn tc_fn_def(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let params_addr: i64 = ast_child1(node);
    let body: i64 = ast_child2(node);
    let params_len: i64 = fn_def_params_len(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);

    let fn_env: Map = env_new();
    let after_params: TcResult = tc_params_rest(params_addr, params_len, 0, fn_env, buf, report, n_lo, n_hi, 1);

    let header1: String = push_arrow(tc_report(after_params));
    let header2: String = push_type_name(header1, fn_default_ret());
    let header3: String = push_newline(header2);

    let after_body: TcResult = tc_block(body, tc_env(after_params), buf, header3, fn_default_ret());

    tc_new(env, tc_report(after_body))
}

pub fn tc_params_rest(params_addr: i64, params_len: i64, i: i64, env: Map, buf: i64, report: String, name_lo: i64, name_hi: i64, is_first: i64) -> TcResult {
    if i >= params_len {
        if is_first == 1 {
            let s1: String = push_kw_fn(report);
            let s2: String = push_bytes(s1, buf, name_lo, name_hi);
            let s3: String = push_colon(s2);
            let s4: String = push_lparen(s3);
            let s5: String = push_rparen(s4);
            return tc_new(env, s5);
        }
        let close: String = push_rparen(report);
        return tc_new(env, close);
    }

    let p: i64 = __mind_load_i64(params_addr + i * 8);
    let p_name: i64 = ast_child0(p);
    let p_type: i64 = ast_child1(p);
    let pn_lo: i64 = ast_span_lo(p_name);
    let pn_hi: i64 = ast_span_hi(p_name);
    let pt_lo: i64 = ast_span_lo(p_type);
    let pt_hi: i64 = ast_span_hi(p_type);

    let pt: i64 = resolve_type_ident(buf, pt_lo, pt_hi);
    let new_env: Map = env_bind(env, buf, pn_lo, pn_hi, pt);

    let prefix: String = if is_first == 1 {
        let s1: String = push_kw_fn(report);
        let s2: String = push_bytes(s1, buf, name_lo, name_hi);
        let s3: String = push_colon(s2);
        push_lparen(s3)
    } else {
        push_comma(report)
    };
    let with_type: String = push_type_name(prefix, pt);

    tc_params_rest(params_addr, params_len, i + 1, new_env, buf, with_type, name_lo, name_hi, 0)
}

pub fn tc_item(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_fn_def() {
        return tc_fn_def(node, env, buf, report);
    }
    tc_new(env, report)
}

pub fn tc_items_rest(items_addr: i64, items_len: i64, i: i64, env: Map, buf: i64, report: String) -> TcResult {
    if i >= items_len {
        return tc_new(env, report);
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let after: TcResult = tc_item(item, env, buf, report);
    tc_items_rest(items_addr, items_len, i + 1, tc_env(after), buf, tc_report(after))
}

// ===== Public entry: typecheck =====

pub fn typecheck(ast_root: i64, buf: i64) -> String {
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let env: Map = env_new();
    let report: String = string_new();
    let result: TcResult = tc_items_rest(items_addr, items_len, 0, env, buf, report);
    tc_report(result)
}

// ===========================================================================
// SECTION 4 — MLIR-TEXT EMITTER (Phase 6.4)
// examples/emit_ir/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: lower_program(ast_addr: i64, buf: i64) -> EmitState
// ===========================================================================

// ===== EmitState =====

struct EmitState {
    buf: String,
    next_id: i64,
    last_id: i64,
    lets: Map,
}

pub fn es_new() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0 - 1, lets: env_new() }
}

pub fn es_buf(s: EmitState) -> String {
    s.buf
}
pub fn es_next_id(s: EmitState) -> i64 {
    s.next_id
}
pub fn es_last_id(s: EmitState) -> i64 {
    s.last_id
}

pub fn es_push(s: EmitState, b: i64) -> EmitState {
    EmitState { buf: string_push_byte(s.buf, b), next_id: s.next_id, last_id: s.last_id, lets: s.lets }
}

// ===== ASCII byte constants =====

pub fn ch_space() -> i64 {
    32
}
pub fn ch_newline() -> i64 {
    10
}
pub fn ch_percent() -> i64 {
    37
}
pub fn ch_eq_sign() -> i64 {
    61
}
pub fn ch_comma() -> i64 {
    44
}
pub fn ch_dot() -> i64 {
    46
}
pub fn ch_slash() -> i64 {
    47
}
pub fn ch_lbrace() -> i64 {
    123
}
pub fn ch_rbrace() -> i64 {
    125
}

// ===== Decimal i64 writer =====

pub fn emit_digits_collect(n: i64, acc: Vec) -> Vec {
    if n == 0 {
        return acc;
    }
    let d: i64 = n - (n / 10) * 10;
    let new_acc: Vec = vec_push(acc, 48 + d);
    emit_digits_collect(n / 10, new_acc)
}

pub fn emit_digits_flush(s: EmitState, digits: Vec, i: i64) -> EmitState {
    if i < 0 {
        return s;
    }
    let b: i64 = vec_get(digits, i);
    let s2: EmitState = es_push(s, b);
    emit_digits_flush(s2, digits, i - 1)
}

pub fn emit_i64(s: EmitState, n: i64) -> EmitState {
    if n == 0 {
        return es_push(s, 48);
    }
    let collected: Vec = emit_digits_collect(n, vec_new());
    emit_digits_flush(s, collected, vec_len(collected) - 1)
}

// ===== Byte-range writer =====

pub fn emit_byte_range(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let s2: EmitState = es_push(s, b);
    emit_byte_range(s2, buf, lo + 1, hi)
}

// ===== mic@3 encoding primitives (self-host mic@3 convergence, Phase 1) =====
//
// ULEB128 + zigzag varints — the foundation of the mic@3 wire format (mirrors
// src/ir/compact/v3/emit.rs uleb128_write / zigzag_encode). The bootstrap
// language has `&` and `/` but no `>>` / `while`, so this is arithmetic +
// recursion: the low 7 bits are `n & 127`, the shift is `n / 128`, and the
// continuation bit is `+ 128` (the kept byte is < 128, so `+` equals `|`). Pure:
// identical n yields identical bytes on every substrate (the wedge invariant).
// Verified against the Rust oracle: uleb128(300) = [172, 2] = [0xAC, 0x02].
//
// Additive + isolated from the canary mic@1 emit path (these are not yet wired
// into the keystone fixed-point; they are exercised by selftest_mic3_uleb below
// until Phase 2 builds the mic@3 section emitter on top of them).
pub fn emit_uleb128(s: EmitState, n: i64) -> EmitState {
    let low: i64 = n & 127;
    let rest: i64 = n / 128;
    if rest == 0 {
        return es_push(s, low);
    }
    let s2: EmitState = es_push(s, low + 128);
    emit_uleb128(s2, rest)
}

// zigzag: signed -> unsigned so small-magnitude values stay short.
//   zigzag(n) = n >= 0 ? 2n : -2n - 1   (== (n<<1) ^ (n>>63) for i64)
pub fn zigzag_encode(n: i64) -> i64 {
    if n < 0 {
        return (0 - n) * 2 - 1;
    }
    n * 2
}

pub fn emit_sleb_zigzag(s: EmitState, n: i64) -> EmitState {
    emit_uleb128(s, zigzag_encode(n))
}

// Selftest export (cdylib pub-fn symbol, like selftest_emit_fn_body): emit the
// ULEB128 of `n` into a fresh EmitState so the Python gate can read the bytes
// back and check them against the Rust encoder. Keeps the primitives live + gated.
pub fn selftest_mic3_uleb(n: i64) -> EmitState {
    emit_uleb128(es_new(), n)
}

// ===== mic@3 header + string-table entry (self-host mic@3 convergence, Phase 2) =====
//
// The MIC3 header: the 4-byte "MIC3" magic + the version byte (mic@3 = 2). This
// is exactly what src/ir/compact/v3/emit.rs emit_mic3 writes first (MIC3_MAGIC
// then MIC3_VERSION). Bytes: M=77 I=73 C=67 '3'=51, version=2.
pub fn emit_mic3_header(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 77);
    let s2: EmitState = es_push(s1, 73);
    let s3: EmitState = es_push(s2, 67);
    let s4: EmitState = es_push(s3, 51);
    es_push(s4, 2)
}

// One mic@3 string-table entry: uleb128(len) || the `len` raw bytes of buf[lo..hi].
// This is the per-string framing emit_mic3 uses (uleb128_write(len) then the
// bytes), and the string-table is just `uleb128(count)` followed by `count` of
// these. Composes the Phase 1 uleb128 with the existing byte-range writer.
pub fn emit_mic3_lp_bytes(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    let len: i64 = hi - lo;
    let s1: EmitState = emit_uleb128(s, len);
    emit_byte_range(s1, buf, lo, hi)
}

pub fn selftest_mic3_header() -> EmitState {
    emit_mic3_header(es_new())
}

pub fn selftest_mic3_lp_bytes(src_addr: i64, src_len: i64) -> EmitState {
    emit_mic3_lp_bytes(es_new(), src_addr, 0, src_len)
}

// ===== mic@3 instruction emitters (self-host mic@3 convergence, Phase 3) =====
//
// The per-opcode encoding of src/ir/compact/v3/emit.rs emit_instr. Operand
// encodings (emit.rs §Low-level helpers): write_vid(id) = uleb128(id);
// write_i64(v) = uleb128(zigzag(v)) — i.e. emit_sleb_zigzag above. These two
// opcodes are the foundation the other 42 reuse (every dst is a vid, every
// integer operand is a write_i64); the full set + the IRModule that feeds it is
// Phase 3b/4. Tested as mechanisms (operands -> bytes) — keystone-isolated.

// Instr::ConstI64(dst, v): OP_CONST_I64(0x01) || vid(dst) || i64(v)
pub fn emit_mic3_const_i64(s: EmitState, dst: i64, v: i64) -> EmitState {
    let s1: EmitState = es_push(s, 1);
    let s2: EmitState = emit_uleb128(s1, dst);
    emit_sleb_zigzag(s2, v)
}

// Instr::BinOp { dst, op, lhs, rhs }:
//   OP_BINOP(0x04) || vid(dst) || binop_to_byte(op) || vid(lhs) || vid(rhs)
// `op_byte` is binop_to_byte(op) — supplied by the (future) lowering; here it is
// a parameter so the framing is tested independently of the op-code mapping.
pub fn emit_mic3_binop(s: EmitState, dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    let s1: EmitState = es_push(s, 4);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = es_push(s2, op_byte);
    let s4: EmitState = emit_uleb128(s3, lhs);
    emit_uleb128(s4, rhs)
}

pub fn selftest_mic3_const_i64(dst: i64, v: i64) -> EmitState {
    emit_mic3_const_i64(es_new(), dst, v)
}

pub fn selftest_mic3_binop(dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    emit_mic3_binop(es_new(), dst, op_byte, lhs, rhs)
}

// Instr::Output(id): OP_OUTPUT(0x13) || vid(id). The function-result terminator.
pub fn emit_mic3_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 19);
    emit_uleb128(s1, id)
}

// encode_opt_vid: None -> [0]; Some(v) -> [1] || uleb(v). `has` = 0/1. Shared by
// Return and FnDef's ret_id.
pub fn emit_mic3_opt_vid(s: EmitState, has: i64, vid: i64) -> EmitState {
    if has == 0 {
        return es_push(s, 0);
    }
    let s1: EmitState = es_push(s, 1);
    emit_uleb128(s1, vid)
}

// Instr::Return { value: Option<vid> }: OP_RETURN(0x17) || encode_opt_vid(value).
pub fn emit_mic3_return(s: EmitState, has_value: i64, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 23);
    emit_mic3_opt_vid(s1, has_value, id)
}

// Instr::FnDef header (OP_FN_DEF 0x15) for a no-parameter function:
//   0x15 || uleb(name_idx) || uleb(0 params) || opt_vid(ret) || opt_f64(None) ||
//   uleb(body_len). The `body_len` body instructions follow (caller-emitted).
// Mirrors the emit_instr Instr::FnDef arm (encode_string_idx, encode_named_vids,
// encode_opt_vid, encode_opt_f64(reap_threshold=None), uleb(body.len)). For
// `fn f() -> i64 {...}` (name_idx=0, ret=%0, body_len=1) this reproduces the
// oracle FN_DEF header bytes 15 00 00 01 00 00 01 exactly.
pub fn emit_mic3_fn_def_header(s: EmitState, name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 0);
    let s4: EmitState = emit_mic3_opt_vid(s3, has_ret, ret_vid);
    let s5: EmitState = es_push(s4, 0);
    emit_uleb128(s5, body_len)
}

pub fn selftest_mic3_fn_def_header(name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    emit_mic3_fn_def_header(es_new(), name_idx, has_ret, ret_vid, body_len)
}

// Instr::Param { dst, name, index }: OP_PARAM(0x18) || vid(dst) || string_idx(name)
//   || uleb(index). The parameter-binding instruction in a function body. For
// `fn id(a)` the body holds PARAM(%0, "a"=idx1, index 0) = 18 00 01 00.
pub fn emit_mic3_param(s: EmitState, dst: i64, name_idx: i64, index: i64) -> EmitState {
    let s1: EmitState = es_push(s, 24);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    emit_uleb128(s3, index)
}

// encode_named_vids (the FN_DEF parameter list): uleb(count) || (string_idx, vid)
// per pair. `pairs` is a heap array of 2*count i64s: pairs[2i] = string_idx,
// pairs[2i+1] = vid. emit_mic3_fn_def's param list uses this.
pub fn emit_mic3_named_vids(s: EmitState, pairs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_named_vids_loop(s1, pairs, count, 0)
}

pub fn emit_mic3_named_vids_loop(s: EmitState, pairs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let sidx: i64 = __mind_load_i64(pairs + i * 16);
    let vid: i64 = __mind_load_i64(pairs + i * 16 + 8);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, vid);
    emit_mic3_named_vids_loop(s2, pairs, count, i + 1)
}

pub fn selftest_mic3_param(dst: i64, name_idx: i64, index: i64) -> EmitState {
    emit_mic3_param(es_new(), dst, name_idx, index)
}

pub fn selftest_mic3_named_vids(pairs: i64, count: i64) -> EmitState {
    emit_mic3_named_vids(es_new(), pairs, count)
}

pub fn selftest_mic3_output(id: i64) -> EmitState {
    emit_mic3_output(es_new(), id)
}

pub fn selftest_mic3_return(has_value: i64, id: i64) -> EmitState {
    emit_mic3_return(es_new(), has_value, id)
}

// ===== mic@3 string-table SECTION assembler (self-host convergence, Phase 3c) =====
//
// The complete mic@3 string table: uleb128(count) followed by `count`
// length-prefixed entries (each via emit_mic3_lp_bytes). `offs` is a heap array
// of (count+1) i64 byte-offsets into `buf`: string i is buf[offs[i] .. offs[i+1]].
// This is the same section src/ir/compact/v3/emit.rs writes after the header
// (uleb128(entries.len()) then each uleb128(len)||bytes), so a matching offsets
// array reproduces the oracle string table byte-for-byte. The offsets are what
// the (future) collect_strings pass will populate; here they are an input so the
// section assembler is tested independently of string collection.
pub fn emit_mic3_strtab(s: EmitState, buf: i64, offs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_strtab_entries(s1, buf, offs, count, 0)
}

pub fn emit_mic3_strtab_entries(s: EmitState, buf: i64, offs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    let s1: EmitState = emit_mic3_lp_bytes(s, buf, lo, hi);
    emit_mic3_strtab_entries(s1, buf, offs, count, i + 1)
}

pub fn selftest_mic3_strtab(buf_addr: i64, offs_addr: i64, count: i64) -> EmitState {
    emit_mic3_strtab(es_new(), buf_addr, offs_addr, count)
}

// ===== mic@3 exports + registries + module assembler (Phase 3d) =====
//
// Exports section: uleb128(count) || count uleb128 string-table indices. emit_mic3
// sorts the export names then writes st.get(name) for each; here `idx` is a heap
// array of (already-sorted) i64 indices (the sort belongs to collection).
pub fn emit_mic3_exports(s: EmitState, idx: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_exports_loop(s1, idx, count, 0)
}

pub fn emit_mic3_exports_loop(s: EmitState, idx: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let v: i64 = __mind_load_i64(idx + i * 8);
    let s1: EmitState = emit_uleb128(s, v);
    emit_mic3_exports_loop(s1, idx, count, i + 1)
}

// The 3 std-surface registries (struct_defs, const_array_defs, repr_c_structs)
// are each uleb128(count) || entries; for a program with none they are three
// uleb128(0). emit_mic3 writes them last.
pub fn emit_mic3_empty_registries(s: EmitState) -> EmitState {
    let s1: EmitState = emit_uleb128(s, 0);
    let s2: EmitState = emit_uleb128(s1, 0);
    emit_uleb128(s2, 0)
}

// Assemble a COMPLETE mic@3 module for the no-instruction case, in the exact
// section order emit_mic3 uses: header || strtab || uleb(next_id) || exports ||
// uleb(0 instrs) || empty registries. The instruction stream (the Phase 4
// real-body lowering) plugs in between exports and the registries.
pub fn emit_mic3_module_noinstr(s: EmitState, buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, str_count);
    let s3: EmitState = emit_uleb128(s2, next_id);
    let s4: EmitState = emit_mic3_exports(s3, idx, exp_count);
    let s5: EmitState = emit_uleb128(s4, 0);
    emit_mic3_empty_registries(s5)
}

pub fn selftest_mic3_exports(idx_addr: i64, count: i64) -> EmitState {
    emit_mic3_exports(es_new(), idx_addr, count)
}

pub fn selftest_mic3_empty_registries() -> EmitState {
    emit_mic3_empty_registries(es_new())
}

pub fn selftest_mic3_module_noinstr(buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    emit_mic3_module_noinstr(es_new(), buf, offs, str_count, next_id, idx, exp_count)
}

// ===== mic@3 COMPLETE with-body module — the const-return function family (Phase 4a) =====
//
// Assembles the full mic@3 of `pub fn <name>() -> i64 { <const_val> }`, byte-exact
// vs the Rust oracle. This is the FIRST complete WITH-BODY emit in pure-MIND. The
// section order + the exact 3-instruction module shape are what emit_mic3 + the
// lowering produce for a const-return function:
//   header || strtab(1:name) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name, ret=%0, body=[ConstI64(%0, const_val)]} ||
//     ConstI64(%0, 0) || Output(%0) ||
//   3 empty registries.
// Verified across const values (42 -> 0x54, 100 -> 0xc8 0x01), so it is a genuine
// (narrow) lowering, not a hardcoded byte blob. Generalizing to arbitrary bodies
// (the AST walk that emits these calls) is the remaining Phase 4 work; this proves
// the emit layer composes into a complete, oracle-identical module.
pub fn emit_mic3_const_fn_module(s: EmitState, buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = emit_mic3_fn_def_header(s5, name_idx, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, const_val);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    emit_mic3_empty_registries(s9)
}

pub fn selftest_mic3_const_fn(buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    emit_mic3_const_fn_module(es_new(), buf, offs, name_idx, const_val)
}

// ===== mic@3 COMPLETE MULTI-FUNCTION module — two const-return fns (Phase 5a) =====
//
// The first pure-MIND emit of a module with MORE THAN ONE function. Assembles the
// full mic@3 of `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>() -> i64 { <v1> }`
// (no export{} block -> empty exports table), byte-exact vs the Rust --emit-mic3
// oracle. The four multi-function deltas vs the single-fn const family (Phase 4a):
//   (1) ONE string table deduped in FIRST-SEEN TRAVERSAL order (n0 then n1) — the
//       offsets array carries 3 i64s (2 strings); name indices are 0 and 1.
//   (2) ONE FLAT next_id threaded across both fns + their scaffolds: the two
//       scaffold ConstI64s take %0 (fn0) and %1 (fn1), so next_id = 2.
//   (3) ONE flat top-level instruction list with a SINGLE uleb count (= 6) covering
//       both FN_DEFs and both scaffold ConstI64/Output pairs.
//   (4) exports sorted (empty here — the export-free fixture).
// The FN_DEF body vids reset to %0 per function (each body is its own vid space),
// while the module-level scaffold const/output threads the flat counter (%0, %1).
// Verified across const values (one=1->zz 0x02, two=2->zz 0x04) so it is a genuine
// narrow multi-fn lowering, not a hardcoded blob.
pub fn emit_mic3_const_fn2_module(s: EmitState, buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = emit_mic3_fn_def_header(s9, 1, 1, 0, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, 0, v1);
    let s12: EmitState = emit_mic3_const_i64(s11, 1, 0);
    let s13: EmitState = emit_mic3_output(s12, 1);
    emit_mic3_empty_registries(s13)
}

pub fn selftest_mic3_module_2fn(buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_const_fn2_module(es_new(), buf, offs, v0, v1)
}

// ===== mic@3 MULTI-FUNCTION module — const-return fn0 + arith fn1 (Phase 5b) =====
//
// `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>(<pa>,<pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust --emit-mic3 oracle. Combines a Phase 4a const-return body
// with a Phase 4c PARAM/PARAM/BINOP body under ONE module header, exercising the
// multi-function deltas where the two functions have DIFFERENT body shapes:
//   strtab[4] in FIRST-SEEN order: n0, n1, pa, pb (name indices 0,1,2,3).
//   next_id = 2 (flat scaffold consts %0, %1 — the FN_DEF bodies keep their own vid
//   spaces: fn0 body %0, fn1 body %0,%1,%2).
//   instr_count = 6: FN_DEF n0{ConstI64 %0=v0} || ConstI64 %0=0 || Output %0 ||
//     FN_DEF n1{PARAM %0, PARAM %1, BINOP %2=%0 op %1} || ConstI64 %1=0 || Output %1.
// For `one(){1}` + `add(a,b){a+b}` (op_byte 0) this reproduces the 68-byte oracle
// byte-for-byte; verified vs live --emit-mic3 in mic3_primitives_smoke.py.
pub fn emit_mic3_const_arith_module(s: EmitState, buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = es_push(s9, 21);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 2);
    let s13: EmitState = emit_uleb128(s12, 2);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_uleb128(s15, 1);
    let s17: EmitState = emit_mic3_opt_vid(s16, 1, 2);
    let s18: EmitState = es_push(s17, 0);
    let s19: EmitState = emit_uleb128(s18, 3);
    let s20: EmitState = emit_mic3_param(s19, 0, 2, 0);
    let s21: EmitState = emit_mic3_param(s20, 1, 3, 1);
    let s22: EmitState = emit_mic3_binop(s21, 2, op_byte, 0, 1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_const_arith(buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    emit_mic3_const_arith_module(es_new(), buf, offs, v0, op_byte)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const fn1 (Strategy A, let cover) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }  pub fn <n1>() -> i64 { <v1> }`,
// byte-exact vs the Rust --emit-mic3 oracle. This is the arith-FIRST ordering (the
// const-arith module is const-first); it is the module shape a 2-param fn written
// with a LET body lowers to (`f(a,b){let t=a+b; t}` == `f(a,b){a+b}` — the let-bound
// value reuses the binop vid, emitting no distinct opcode or string). strtab[4] in
// first-seen order: n0, pa, pb, n1 (indices 0,1,2,3). next_id = 2 (flat scaffold
// consts %0 fn0, %1 fn1). instr_count = 6.
//   FN_DEF n0{PARAM %0=str1, PARAM %1=str2, BINOP %2=%0 op %1} ret %2 ||
//     ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v1} ret %0 || ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_const_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: const (name idx 3).
    let s21: EmitState = emit_mic3_fn_def_header(s20, 3, 1, 0, 1);
    let s22: EmitState = emit_mic3_const_i64(s21, 0, v1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_arith_const(buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    emit_mic3_arith_const_module(es_new(), buf, offs, op_byte, v1)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const-args CALL fn1 (Strategy A) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }
//  pub fn <n1>() -> i64 { <n0>(<v0>, <v1>) }`, byte-exact vs --emit-mic3. fn1's
// body is a CALL to fn0 with two int-literal args: each arg lowers to a ConstI64
// taking the next body vid (%0, %1), then OP_CALL(0x16) %2 = name#callee(%0,%1)
// (encode_string_idx(callee) || encode_vid_vec([%0,%1])). The FN_DEF ret is %2,
// body_len 3. The callee string DEDUPS to fn0's name index (interned first during
// fn0's FnDef; the call name interns idempotently during body traversal — handled
// by collect_body_strings, so strtab[4] = n0, pa, pb, n1 in first-seen order with
// the call referencing index 0). next_id = 2 (scaffold consts %0 fn0, %1 fn1).
//   FN_DEF n0{PARAM,PARAM,BINOP} ret %2 || ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v0, ConstI64 %1=v1, CALL %2=callee(%0,%1)} ret %2 ||
//     ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_call_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: call body (name idx 3), ret %2, body_len 3.
    let s21: EmitState = es_push(s20, 21);
    let s22: EmitState = emit_uleb128(s21, 3);
    let s23: EmitState = emit_uleb128(s22, 0);
    let s24: EmitState = emit_mic3_opt_vid(s23, 1, 2);
    let s25: EmitState = es_push(s24, 0);
    let s26: EmitState = emit_uleb128(s25, 3);
    let s27: EmitState = emit_mic3_const_i64(s26, 0, v0);
    let s28: EmitState = emit_mic3_const_i64(s27, 1, v1);
    let s29: EmitState = emit_mic3_call2(s28, 2, callee_idx, 0, 1);
    let s30: EmitState = emit_mic3_const_i64(s29, 1, 0);
    let s31: EmitState = emit_mic3_output(s30, 1);
    emit_mic3_empty_registries(s31)
}

// Instr::Call { dst, name, args=[a0,a1] }:
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(2) || vid(a0) || vid(a1).
pub fn emit_mic3_call2(s: EmitState, dst: i64, name_idx: i64, a0: i64, a1: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, 2);
    let s5: EmitState = emit_uleb128(s4, a0);
    emit_uleb128(s5, a1)
}

pub fn selftest_mic3_module_arith_call(buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_arith_call_module(es_new(), buf, offs, op_byte, callee_idx, v0, v1)
}

// Instr::Call { dst, name, args=[a0] } (single-argument call):
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(1) || vid(a0).
// The field-read lowering emits exactly this for `__mind_load_i64(<addr>)`.
pub fn emit_mic3_call1(s: EmitState, dst: i64, name_idx: i64, a0: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, 1);
    emit_uleb128(s4, a0)
}

// A NON-EMPTY std-surface struct_defs registry holding ONE 2-field struct, then
// the two remaining registries empty. emit_mic3 writes the three registries last,
// each as uleb(count) || entries. For struct_defs a single entry is
// uleb(name_idx) || uleb(field_count) || uleb(field0_idx) || uleb(field1_idx).
// The wire tail for `struct S { a, b }` (name str#4, a str#5, b str#6) is therefore
//   01 04 02 05 06   00   00
// (struct_defs=1 · S · 2 fields · a · b || const_array_defs=0 || repr_c_structs=0).
// Mirrors src/ir/compact/v3/emit.rs:746-773 (BTreeMap key order — a single key is
// trivially sorted). The field indices are string-table indices, NOT field offsets.
pub fn emit_mic3_struct_defs_one(s: EmitState, name_idx: i64, f0_idx: i64, f1_idx: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, 1);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, f0_idx);
    let s5: EmitState = emit_uleb128(s4, f1_idx);
    let s6: EmitState = emit_uleb128(s5, 0);
    emit_uleb128(s6, 0)
}

// ===== mic@3 MULTI-FUNCTION module — struct decl + two FIELD-READ fns (Strategy A) =====
//
// `struct S { a: i64, b: i64 }
//  pub fn get_a(s: S) -> i64 { s.a }
//  pub fn get_b(s: S) -> i64 { s.b }`, byte-exact vs the Rust --emit-mic3 oracle.
// The FIRST pure-MIND emit of (1) a non-empty struct_defs registry and (2) the
// field-access lowering. The Rust lowering (src/eval/lower.rs FieldAccess arm)
// resolves a field READ `recv.field` via ir.struct_defs[ReceiverType] to a field
// INDEX, then lowers to a `__mind_load_i64` of the field address:
//   field idx 0 (s.a):  PARAM %0=recv ; CALL %1=__mind_load_i64([%0])
//                       — base address direct, no offset added.
//   field idx 1 (s.b):  PARAM %0=recv ; CONST %1=idx*8 (=8) ;
//                       BINOP %2 = Add(%0,%1) ; CALL %3=__mind_load_i64([%2]).
// Each top-level item (the struct decl AND each fn) emits a module-level scaffold
// ConstI64/Output pair that produces no value, threading ONE FLAT next_id: struct
// decl -> %0, get_a -> %1, get_b -> %2, so next_id = 3. The FN_DEF bodies keep
// their own vid space (reset to %0 per fn). strtab[7] in FIRST-SEEN traversal
// order (instrs walked before the struct_defs registry, per emit_mic3 lines
// 701/705): get_a, s, __mind_load_i64, get_b, S, a, b -> indices 0..6.
//   ConstI64 %0=0 || Output %0 ||                                  (struct S scaffold)
//   FN_DEF get_a(s){PARAM %0, CALL %1=load([%0])} ret %1 ||
//     ConstI64 %1=0 || Output %1 ||
//   FN_DEF get_b(s){PARAM %0, CONST %1=foff, BINOP %2=add(%0,%1),
//     CALL %3=load([%2])} ret %3 || ConstI64 %2=0 || Output %2 ||
//   struct_defs[S=[a,b]] || const_array_defs=0 || repr_c_structs=0.
// `foff` (the byte offset of field b = idx*8 = 8) is threaded as a parameter so the
// emit is a genuine narrow lowering, not a hardcoded blob; reproduces the 111-byte
// oracle for foff=8. `load_idx` = string index of "__mind_load_i64" (=2).
pub fn emit_mic3_field_module(s: EmitState, buf: i64, offs: i64, load_idx: i64, foff: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 7);
    let s3: EmitState = emit_uleb128(s2, 3);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 8);
    // struct S decl -> module-level scaffold ConstI64 %0 / Output %0.
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // get_a(s){ s.a } — name idx 0, one param "s" (str 1), ret %1, body_len 2.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, 0);
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 1);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 2);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_call1(s16, 1, load_idx, 0);
    let s18: EmitState = emit_mic3_const_i64(s17, 1, 0);
    let s19: EmitState = emit_mic3_output(s18, 1);
    // get_b(s){ s.b } — name idx 3, one param "s" (str 1), ret %3, body_len 4.
    let s20: EmitState = es_push(s19, 21);
    let s21: EmitState = emit_uleb128(s20, 3);
    let s22: EmitState = emit_uleb128(s21, 1);
    let s23: EmitState = emit_uleb128(s22, 1);
    let s24: EmitState = emit_uleb128(s23, 0);
    let s25: EmitState = emit_mic3_opt_vid(s24, 1, 3);
    let s26: EmitState = es_push(s25, 0);
    let s27: EmitState = emit_uleb128(s26, 4);
    let s28: EmitState = emit_mic3_param(s27, 0, 1, 0);
    let s29: EmitState = emit_mic3_const_i64(s28, 1, foff);
    let s30: EmitState = emit_mic3_binop(s29, 2, 0, 0, 1);
    let s31: EmitState = emit_mic3_call1(s30, 3, load_idx, 2);
    let s32: EmitState = emit_mic3_const_i64(s31, 2, 0);
    let s33: EmitState = emit_mic3_output(s32, 2);
    // Registries: struct_defs[S=[a,b]] (S str 4, a str 5, b str 6), rest empty.
    emit_mic3_struct_defs_one(s33, 4, 5, 6)
}

pub fn selftest_mic3_module_field(buf: i64, offs: i64, load_idx: i64, foff: i64) -> EmitState {
    emit_mic3_field_module(es_new(), buf, offs, load_idx, foff)
}

// ===== mic@3 AST-DRIVEN single-struct field-read load (parts 1+2 wired) =====
//
// `struct S { a: i64 }  pub fn get_a(s: S) -> i64 { s.a }` (idx 0, 71 bytes) and
// `struct S { a: i64, b: i64 } pub fn get_b(s: S) -> i64 { s.b }` (idx 1, 82
// bytes), lowered from SOURCE (not hand-fed indices) byte-exact vs the Rust
// `--emit-mic3` oracle. This is the AST-driven field-access lowering: it resolves
// the `recv.field` access by wiring SECTION 6 (the struct field table, part 1)
// and SECTION 7 (the per-fn param-type table, part 2):
//   * part 2 (ptt) binds the receiver param `s` -> its declared type span `S`;
//   * part 1 (sft) gives the ordered field-name spans of the struct, against
//     which the accessed field name resolves to a field INDEX.
// The Rust lowering (src/eval/lower.rs FieldAccess arm) computes the field byte
// offset = idx*8 and lowers a `__mind_load_i64` of the field address:
//   idx 0:  FN_DEF f(recv){ PARAM %0 ; CALL %1=load([%0]) } ret %1  (no offset);
//   idx>0:  FN_DEF f(recv){ PARAM %0 ; CONST %1=idx*8 ;
//             BINOP %2=Add(%0,%1) ; CALL %3=load([%2]) } ret %3.
// SCOPE (this slice): exactly ONE struct, ONE param, any accessed field index in
// that struct. Any other shape returns the seed state unchanged (fail-closed, no
// partial bytes). Multi-struct keying (a recv typed by the 2nd+ struct) is the
// next increment — sft_find_struct_body finds only the FIRST struct today.
//
// String table in FIRST-SEEN traversal order (emit_mic3 walks instrs before the
// struct_defs registry, src/ir/compact/v3/emit.rs:701/705): the FnDef name,
// then its param name, then the body Call name `__mind_load_i64`, then the
// struct_defs registry type name and EVERY field in declaration order -> the
// accessed field lands at string index 4+fidx. `__mind_load_i64` is synthetic
// (not in source), written into `strbuf` as a literal and interned like any
// source span (intern_load_i64_literal).
//
// ADDITIVE / canary-isolated: exported only via selftest_mic3_module_field_from_ast;
// the canary mindc_compile / emit_expr_env ast_field path (const.i64 0) is
// untouched, so the keystone fixed-point bytes are unchanged.

// Write the literal "__mind_load_i64" (15 bytes) into `strbuf` at the current
// interning cursor and register its offset/count, returning the freshly
// allocated string index. Mirrors intern_span's allocate tail exactly, but the
// source bytes are the fixed synthetic call name rather than a span of `src`.
// (No dedup scan: this name is interned exactly once, after the source spans, in
// the field-read lowering — matching the Rust collect order.)
pub fn intern_load_i64_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_load_i64" = 95 95 109 105 110 100 95 108 111 97 100 95 105 54 52.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 108);
    __mind_store_i8(strbuf + start + 8, 111);
    __mind_store_i8(strbuf + start + 9, 97);
    __mind_store_i8(strbuf + start + 10, 100);
    __mind_store_i8(strbuf + start + 11, 95);
    __mind_store_i8(strbuf + start + 12, 105);
    __mind_store_i8(strbuf + start + 13, 54);
    __mind_store_i8(strbuf + start + 14, 52);
    __mind_store_i64(offs + (n + 1) * 8, start + 15);
    __mind_store_i64(ccell, n + 1);
    n
}

// The j-th byte (0..15) of the synthetic call name "__mind_load_i64". Shared by
// the dedup-aware interner so the literal lives in exactly one place.
pub fn load_i64_name_byte(j: i64) -> i64 {
    if j == 0 {
        return 95;
    }
    if j == 1 {
        return 95;
    }
    if j == 2 {
        return 109;
    }
    if j == 3 {
        return 105;
    }
    if j == 4 {
        return 110;
    }
    if j == 5 {
        return 100;
    }
    if j == 6 {
        return 95;
    }
    if j == 7 {
        return 108;
    }
    if j == 8 {
        return 111;
    }
    if j == 9 {
        return 97;
    }
    if j == 10 {
        return 100;
    }
    if j == 11 {
        return 95;
    }
    if j == 12 {
        return 105;
    }
    if j == 13 {
        return 54;
    }
    52
}

// Does the already-interned string at index i equal "__mind_load_i64"? Raw-byte
// compare against the synthetic literal (no hashing), mirroring StringTable
// dedup on the synthetic Call name.
pub fn load_i64_name_eq_at(strbuf: i64, offs: i64, i: i64, j: i64) -> i64 {
    let elo: i64 = __mind_load_i64(offs + i * 8);
    let ehi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if ehi - elo != 15 {
        return 0;
    }
    if j >= 15 {
        return 1;
    }
    if load_byte(strbuf, elo + j) != load_i64_name_byte(j) {
        return 0;
    }
    load_i64_name_eq_at(strbuf, offs, i, j + 1)
}

// Find the string index of "__mind_load_i64" among the n already-interned
// strings, or -1. Mirrors StringTable::intern's first-seen dedup lookup.
pub fn load_i64_name_find(strbuf: i64, offs: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    if load_i64_name_eq_at(strbuf, offs, i, 0) == 1 {
        return i;
    }
    load_i64_name_find(strbuf, offs, n, i + 1)
}

// Dedup-aware intern of the synthetic "__mind_load_i64" call name: returns the
// existing index on a hit, else allocates it (via intern_load_i64_literal) and
// returns the fresh index. This is the idempotent form the COLLECTION PASS needs
// (a body with multiple field reads interns the name once), matching the Rust
// `Instr::Call { name } => st.intern(name)` first-seen behaviour. The direct
// field driver (emit_mic3_field_module_from_ast) still calls the no-dedup
// intern_load_i64_literal because that path interns the name exactly once.
pub fn intern_load_i64_name(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let hit: i64 = load_i64_name_find(strbuf, offs, n, 0);
    if hit >= 0 {
        return hit;
    }
    intern_load_i64_literal(strbuf, offs, ccell)
}

// ===== mic@3 struct-literal CONSTRUCTION synthetic-name interns =====
//
// The Rust lowering (src/eval/lower.rs StructLit arm) desugars a struct-literal
// `T { f0: e0, .. }` into an allocation + per-field stores:
//   CONST elem=8 ; CONST n_fields ; BINOP Mul -> size ;
//   CALL __mind_alloc([size]) -> ptr ;
//   per field (DECLARED order): store the field value at ptr + idx*8 via
//     __mind_store_i64([addr, val]) (idx 0 stores at ptr directly; idx>0 adds a
//     CONST(idx*8) + BINOP Add(ptr, off)).
// The FN_DEF returns the alloc ptr vid. Two synthetic call names are interned
// FIRST-SEEN right after the fn name + its param (and before the struct type
// name), matching emit.rs's instr-before-registry walk: `__mind_alloc` (12 bytes)
// then `__mind_store_i64` (16 bytes). Each mirrors intern_load_i64_literal's
// allocate tail exactly; the bytes + length are the only difference.

// Write the literal "__mind_alloc" (12 bytes) into `strbuf` at the current
// interning cursor; register its offset/count; return the fresh string index.
pub fn intern_alloc_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_alloc" = 95 95 109 105 110 100 95 97 108 108 111 99.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 97);
    __mind_store_i8(strbuf + start + 8, 108);
    __mind_store_i8(strbuf + start + 9, 108);
    __mind_store_i8(strbuf + start + 10, 111);
    __mind_store_i8(strbuf + start + 11, 99);
    __mind_store_i64(offs + (n + 1) * 8, start + 12);
    __mind_store_i64(ccell, n + 1);
    n
}

// Write the literal "__mind_store_i64" (16 bytes) into `strbuf` at the current
// interning cursor; register its offset/count; return the fresh string index.
pub fn intern_store_i64_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_store_i64" = 95 95 109 105 110 100 95 115 116 111 114 101 95 105 54 52.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 115);
    __mind_store_i8(strbuf + start + 8, 116);
    __mind_store_i8(strbuf + start + 9, 111);
    __mind_store_i8(strbuf + start + 10, 114);
    __mind_store_i8(strbuf + start + 11, 101);
    __mind_store_i8(strbuf + start + 12, 95);
    __mind_store_i8(strbuf + start + 13, 105);
    __mind_store_i8(strbuf + start + 14, 54);
    __mind_store_i8(strbuf + start + 15, 52);
    __mind_store_i64(offs + (n + 1) * 8, start + 16);
    __mind_store_i64(ccell, n + 1);
    n
}

// Scan the token stream for the first field-access `.` and return the token
// index of the dot, or -1 if none. The receiver ident is at dot-1, the field
// ident at dot+1 (mirrors the surface `recv . field`).
pub fn ffa_find_dot(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_dot() {
        return pos;
    }
    ffa_find_dot(toks, pos + 1)
}

// Resolve the accessed field-name span buf[lo..hi) to its field INDEX in the
// struct field table `t` (part 1), or -1 if not found. Linear scan + raw-byte
// span equality (no hashing) — the field order IS the layout order.
pub fn ffa_field_index(t: i64, buf: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= sft_table_count(t) {
        return 0 - 1;
    }
    if span_bytes_equal(buf, lo, hi, sft_table_name_lo(t, k), sft_table_name_hi(t, k)) == 1 {
        return k;
    }
    ffa_field_index(t, buf, lo, hi, k + 1)
}

// Intern every struct field name (part-1 table `sft`) into `strbuf` in
// declaration order, starting at field `k`. The field names follow the fn name,
// param name, `__mind_load_i64` and the type name, so field j lands at string
// index 4+j (distinct names, intern_span dedups but these never collide). Used
// for both the body (the accessed field) and the struct_defs registry tail.
pub fn ffa_intern_fields(strbuf: i64, offs: i64, ccell: i64, src: i64, sft: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 0;
    }
    let _i: i64 = intern_span(strbuf, offs, ccell, src, sft_table_name_lo(sft, k), sft_table_name_hi(sft, k));
    ffa_intern_fields(strbuf, offs, ccell, src, sft, k + 1)
}

// Emit the struct_defs registry field-index list: `count` ulebs, the field at
// declaration index j being string index `base + j` (base = 4 = first field
// slot). Mirrors emit_mic3_struct_defs_one's field tail but for N fields.
pub fn ffa_emit_field_idxs(s: EmitState, base: i64, count: i64, j: i64) -> EmitState {
    if j >= count {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, base + j);
    ffa_emit_field_idxs(s1, base, count, j + 1)
}

// Emit the struct_defs registry field-index list using each field's ACTUAL
// interned string index (re-interning is idempotent and returns the existing
// index on a hit). Required when a field name aliases an earlier-interned string
// (e.g. a field whose name equals a param name): the StringTable de-dups, so the
// field idx is the prior index, not a fresh contiguous slot.
pub fn ffa_emit_field_idxs_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, sft: i64, j: i64) -> EmitState {
    if j >= sft_table_count(sft) {
        return s;
    }
    let idx: i64 = intern_span(strbuf, offs, ccell, src, sft_table_name_lo(sft, j), sft_table_name_hi(sft, j));
    let s1: EmitState = emit_uleb128(s, idx);
    ffa_emit_field_idxs_interned(s1, strbuf, offs, ccell, src, sft, j + 1)
}

// AST-driven mic@3 module for a single-struct, single-param field read at any
// field index. Returns the seed `s` unchanged on any unexpected shape
// (fail-closed). idx==0 lowers to a direct `__mind_load_i64([recv])`; idx>0 adds
// the `CONST(idx*8) + BINOP Add + CALL([sum])` offset path (mirrors the
// src/eval/lower.rs FieldAccess arm and emit_mic3_field_module's get_b case).
pub fn emit_mic3_field_module_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    // Shape guards: at least one struct field and exactly one fn param.
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) != 1 {
        return s;
    }
    // Locate `recv.field`; resolve the field name to its struct field index.
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 1 {
        return s;
    }
    let recv_lo: i64 = tok_lo(tokens, dot - 1);
    let recv_hi: i64 = tok_hi(tokens, dot - 1);
    let fld_lo: i64 = tok_lo(tokens, dot + 1);
    let fld_hi: i64 = tok_hi(tokens, dot + 1);
    let fidx: i64 = ffa_field_index(sft, src, fld_lo, fld_hi, 0);
    if fidx < 0 {
        return s;
    }
    // Receiver-type binding (part 2): the receiver param's declared type name is
    // the struct type; confirm the receiver names param 0 (fail-closed if not).
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, 0), ptt_table_name_hi(ptt, 0)) != 1 {
        return s;
    }
    // The fn name is the ident two tokens before the param-list `(` — i.e. the
    // token right before `(`. ptt_find_param_list returns the index just past `(`
    // (params start = fn_kw+3), so the `(` is at params_start-1 and the name at
    // params_start-2.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Struct type name span (part 2 binding -> the struct_defs registry key).
    let ty_lo: i64 = ptt_table_type_lo(ptt, 0);
    let ty_hi: i64 = ptt_table_type_hi(ptt, 0);
    let n_fields: i64 = sft_table_count(sft);
    // Intern strings in FIRST-SEEN order (instrs before registry):
    //   0: fn name, 1: param name, 2: __mind_load_i64, 3: type name,
    //   4..4+n_fields: every struct field in declaration order. The accessed
    //   field's string index is therefore 4+fidx.
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let i_recv: i64 = intern_span(strbuf, offs, ccell, src, recv_lo, recv_hi);
    let i_load: i64 = intern_load_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    // String-table count = 4 fixed entries + every struct field.
    let strc: i64 = 4 + n_fields;
    // Body shape: idx==0 -> PARAM, CALL([%0]) (len 2, ret %1); idx>0 -> PARAM,
    // CONST(fidx*8), BINOP Add(%0,%1), CALL([%2]) (len 4, ret %3).
    let body_len: i64 = ffa_body_len(fidx);
    let ret_vid: i64 = ffa_ret_vid(fidx);
    // Assemble: header || strtab(strc) || next_id(2) || exports(0) ||
    //   5 instrs [ CONST %0 / OUTPUT %0  (struct scaffold)
    //             FN_DEF f(recv){ <body> } ret %ret_vid
    //             CONST %1 / OUTPUT %1  (fn scaffold) ]
    //   || struct_defs[ ty=[fields...] ] || const_array_defs=0 || repr_c_structs=0.
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 5);
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF header: name idx, 1 param (name, vid 0), ret %ret_vid, body_len.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn);
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_uleb128(s10, i_recv);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, ret_vid);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, body_len);
    let s16: EmitState = emit_mic3_param(s15, 0, i_recv, 0);
    let s17: EmitState = ffa_emit_body(s16, fidx, i_load);
    let s18: EmitState = emit_mic3_const_i64(s17, 1, 0);
    let s19: EmitState = emit_mic3_output(s18, 1);
    // Registry: one struct (ty=[field0..fieldN-1]).
    let s20: EmitState = emit_uleb128(s19, 1);
    let s21: EmitState = emit_uleb128(s20, i_ty);
    let s22: EmitState = emit_uleb128(s21, n_fields);
    let s23: EmitState = ffa_emit_field_idxs(s22, 4, n_fields, 0);
    let s24: EmitState = emit_uleb128(s23, 0);
    emit_uleb128(s24, 0)
}

// FN_DEF body_len for a field-read: idx 0 -> 2 (PARAM, CALL); idx>0 -> 4
// (PARAM, CONST, BINOP, CALL).
pub fn ffa_body_len(fidx: i64) -> i64 {
    if fidx == 0 {
        return 2;
    }
    4
}

// FN_DEF return vid for a field-read: idx 0 -> %1 (the CALL); idx>0 -> %3.
pub fn ffa_ret_vid(fidx: i64) -> i64 {
    if fidx == 0 {
        return 1;
    }
    3
}

// Emit the field-read body AFTER the PARAM (already at %0). idx 0: a single CALL
// %1 = __mind_load_i64([%0]). idx>0: CONST %1 = fidx*8, BINOP %2 = Add(%0,%1),
// CALL %3 = __mind_load_i64([%2]) — the byte offset of field `fidx` from the
// receiver base (binop_to_byte(Add) = 0, matching the get_b oracle).
pub fn ffa_emit_body(s: EmitState, fidx: i64, i_load: i64) -> EmitState {
    if fidx == 0 {
        return emit_mic3_call1(s, 1, i_load, 0);
    }
    let s1: EmitState = emit_mic3_const_i64(s, 1, fidx * 8);
    let s2: EmitState = emit_mic3_binop(s1, 2, 0, 0, 1);
    emit_mic3_call1(s2, 3, i_load, 2)
}

pub fn selftest_mic3_module_field_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_field_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// mic@3 AST-DRIVEN struct-literal CONSTRUCTION (single struct, N params)
// ===========================================================================
//
// `pub struct T { f0: i64, .. }  pub fn mk(a: i64, b: i64, ..) -> T { T { f0: e0, .. } }`,
// byte-exact vs the Rust --emit-mic3 oracle. The WRITE-side mirror of the
// field-READ driver: the fn body is a struct-literal construction, lowered (per
// src/eval/lower.rs StructLit arm) to an allocation + per-field stores. For
// n_params parameters (vids 0..n_params-1):
//   %0..%(n-1)   PARAM (one per param, in declaration order)
//   %n           CONST 8                 (element size, bytes)
//   %(n+1)       CONST n_fields
//   %(n+2)       BINOP Mul(%n,%(n+1))    (= alloc size)
//   %(n+3)       CALL __mind_alloc([%(n+2)]) (= base ptr; the FN_DEF return vid)
//   then for each field in DECLARED order (idx 0..n_fields-1):
//     [value]  int-literal     -> CONST %v = lit ; literal val_vid
//              ident==param k   -> reuse %k (no instr) ; val_vid = param index
//     [addr]   idx == 0     -> store at the base ptr directly
//              idx >  0     -> CONST %o = idx*8 ; BINOP Add(ptr,%o) ; addr = sum
//     CALL %s = __mind_store_i64([addr_vid, val_vid])
// SCOPE (this slice): EXACTLY one struct, one fn with >=1 param, the fn returns a
// single struct-literal whose every field initializer is either an int-literal or
// a param ident. Any other shape returns the seed state unchanged (fail-closed,
// no partial bytes). N==1 reduces to the original single-param oracle exactly.
//
// String table FIRST-SEEN order (instrs walked before the struct_defs registry):
//   0: fn name, 1..1+n: every param name (declaration order),
//   then __mind_alloc, __mind_store_i64, struct type name, then every field in
//   declaration order (string base 4+n_params).
// ADDITIVE / canary-isolated: reached only via
// selftest_mic3_module_structlit_from_ast and the unified dispatcher; the canary
// (mindc_compile / emit_fn_def) is untouched, so the fixed point is unchanged.

// Find the struct-literal CONSTRUCTION head token: an ident immediately followed
// by `{` whose ident bytes equal the struct type name span. Returns the ident
// token index, or -1. (Distinct from a fn body `{`, which follows `)` / `->`.)
pub fn slit_find_ctor(toks: Vec, pos: i64, src: i64, ty_lo: i64, ty_hi: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if tok_kind(toks, pos + 1) == tk_lbrace() {
            if span_bytes_equal(src, tok_lo(toks, pos), tok_hi(toks, pos), ty_lo, ty_hi) == 1 {
                // Three `T {` occurrences exist: the struct DEFINITION
                // (`struct T {`, prev tok = the `struct` ident), the RETURN
                // TYPE (`-> T {`, prev tok = `->`), and the actual struct
                // LITERAL. Skip the first two so only the ctor qualifies.
                let prev_ok: i64 = if pos == 0 {
                    1
                } else {
                    if tok_kind(toks, pos - 1) == tk_arrow() {
                        0
                    } else {
                        if is_struct_kw(src, tok_lo(toks, pos - 1), tok_hi(toks, pos - 1)) == 1 {
                            0
                        } else {
                            1
                        }
                    }
                };
                if prev_ok == 1 {
                    return pos;
                }
            }
        }
    }
    slit_find_ctor(toks, pos + 1, src, ty_lo, ty_hi)
}

// Locate, among the parsed struct-lit's SOURCE-ORDER triples (each 3xi64 at
// fields_addr: name_lo, name_hi, value_node), the value-node for the field whose
// name span equals buf[dlo..dhi) (the k-th DECLARED field). Returns the
// value-node AST address, or 0 if absent.
pub fn slit_value_for(fields_addr: i64, ntriples: i64, src: i64, dlo: i64, dhi: i64, i: i64) -> i64 {
    if i >= ntriples {
        return 0;
    }
    let nlo: i64 = __mind_load_i64(fields_addr + (i * 3) * 8);
    let nhi: i64 = __mind_load_i64(fields_addr + (i * 3 + 1) * 8);
    if span_bytes_equal(src, nlo, nhi, dlo, dhi) == 1 {
        return __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    }
    slit_value_for(fields_addr, ntriples, src, dlo, dhi, i + 1)
}

// Number of body instructions a single field's store contributes. The value is
// now an ARBITRARY expression that lowers to `vcount` non-param instrs (via the
// general tree emitter — count_nonparam_nodes), the byte offset adds CONST+Add
// (2) for idx>0, and the store itself is always 1.
pub fn slit_field_instr_count(vcount: i64, idx: i64) -> i64 {
    let ac: i64 = if idx == 0 {
        0
    } else {
        2
    };
    vcount + ac + 1
}

// Build a params_addr array (one entry per param, the form resolve_param / the
// general tree emitter expect: each entry is a param AST node whose ast_child0 is
// the name leaf) from the ptt span table. Allocated `n_params * 8`, declaration
// order preserved. Lets the struct-lit field VALUES reuse the general emitter
// (flatten_ast/tree_resolve_vids/emit_mic3_tree_body) for arbitrary expressions.
pub fn slit_build_params_addr(ptt: i64, src: i64) -> i64 {
    let n: i64 = ptt_table_count(ptt);
    let arr: i64 = __mind_alloc(n * 8 + 8);
    slit_fill_params_addr(arr, ptt, src, 0);
    arr
}

pub fn slit_fill_params_addr(arr: i64, ptt: i64, src: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0;
    }
    let lo: i64 = ptt_table_name_lo(ptt, k);
    let hi: i64 = ptt_table_name_hi(ptt, k);
    let name_leaf: i64 = ast_new_leaf(ast_ident(), lo, hi);
    let pnode: i64 = ast_new_param(lo, hi, name_leaf, 0);
    __mind_store_i64(arr + k * 8, pnode);
    slit_fill_params_addr(arr, ptt, src, k + 1)
}

// The general-emitter non-param instr count of a field VALUE expression (CONST
// leaves + BINOP + CALL nodes; params contribute 0). Returns -1 on an unsupported
// construct, which the fail-closed shape guard rejects.
pub fn slit_value_count(value_node: i64, src: i64, params_addr: i64, n_params: i64) -> i64 {
    count_nonparam_nodes(value_node, src, params_addr, n_params)
}

// CONTAINED field-access value support (Step B2): a field VALUE of the form
// `recv.field` where `recv` is a PARAM of the SAME struct being constructed (so
// `sft` gives the field offset). Returns the accessed field's INDEX in `sft`
// (offset = idx*8) when the shape qualifies, else -1. The qualification:
//   * value_node is ast_field;
//   * its receiver (child0) is an ident that resolves to a param (resolve_param);
//   * its field name (child1/child2 span) resolves in `sft` (ffa_field_index).
// This special-cases ast_field BEFORE the general flatten_ast path (which rejects
// ast_field), so the struct-type context (`sft`) need not be threaded through the
// general emitter's many call-sites.
pub fn slit_value_fa_idx(value_node: i64, src: i64, params_addr: i64, n_params: i64, sft: i64) -> i64 {
    if ast_kind(value_node) != ast_field() {
        return 0 - 1;
    }
    let recv: i64 = ast_child0(value_node);
    if ast_kind(recv) != ast_ident() {
        return 0 - 1;
    }
    let pv: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(recv), ast_span_hi(recv));
    if pv < 0 {
        return 0 - 1;
    }
    ffa_field_index(sft, src, ast_child1(value_node), ast_child2(value_node), 0)
}

// Non-param instr count of a field VALUE, unifying the general expr path with the
// CONTAINED field-access path. Field-access values do NOT go through the general
// tree emitter (count_nonparam_nodes returns -1 for ast_field); instead a
// field-READ lowers to a single CALL load when the field offset is 0, or
// CONST(off) + Add(base,off) + CALL load (3 instrs) when offset>0 — mirroring
// ffa_emit_body. Any other shape falls through to count_nonparam_nodes.
pub fn slit_value_instr_count(value_node: i64, src: i64, params_addr: i64, n_params: i64, sft: i64) -> i64 {
    let fa: i64 = slit_value_fa_idx(value_node, src, params_addr, n_params, sft);
    if fa >= 0 {
        if fa == 0 {
            return 1;
        }
        return 3;
    }
    count_nonparam_nodes(value_node, src, params_addr, n_params)
}

// Is the value-node an int-literal (1) or the param ident (0)? Fail-closed
// callers already guarantee one of the two. ast_int_lit -> 1, else 0.
pub fn slit_value_is_lit(node: i64) -> i64 {
    if ast_kind(node) == ast_int_lit() {
        return 1;
    }
    0
}

// Resolve a param-ident value node to its param index = its %SSA vid (params
// bind to vids 0..n_params-1, in declaration order). Compares the ident span
// against each ptt param-name span. Returns the param vid, or -1 if not a param
// (a fail-closed caller has already rejected that shape).
pub fn slit_param_vid(ptt: i64, src: i64, node: i64) -> i64 {
    slit_param_vid_loop(ptt, src, ast_span_lo(node), ast_span_hi(node), 0)
}

pub fn slit_param_vid_loop(ptt: i64, src: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0 - 1;
    }
    if span_bytes_equal(src, lo, hi, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k)) == 1 {
        return k;
    }
    slit_param_vid_loop(ptt, src, lo, hi, k + 1)
}

// The field VALUE's root vid (the operand the store consumes). For a CONTAINED
// field-access (fa>=0): offset 0 -> the lone load CALL at `vid`; offset>0 ->
// CONST(vid)+Add(vid+1)+load(vid+2), so the load dst is `vid+2`. For any other
// value (fa<0): flatten it through the general tree emitter, which returns its
// root vid and populates `nodes`/`cursor` for the subsequent slit_emit_value.
pub fn slit_value_val_vid(value_node: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, fa: i64, vid: i64) -> i64 {
    if fa >= 0 {
        if fa == 0 {
            return vid;
        }
        return vid + 2;
    }
    flatten_branch(value_node, src, params_addr, n_params, nodes, cursor, vidbuf, vid)
}

// Emit the field VALUE's body instrs. CONTAINED field-access (fa>=0) lowers a
// field-READ: load(base) directly for offset 0, else CONST(off)+Add(base,off)+
// load(addr) — `base` is the receiver param's vid, `i_load` the interned
// `__mind_load_i64` string index. Any other value (fa<0) emits the general tree
// body already flattened into `nodes` by slit_value_val_vid (n_nodes via cursor).
pub fn slit_emit_value(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, fa: i64, value_node: i64, vid: i64) -> EmitState {
    if fa >= 0 {
        let recv: i64 = ast_child0(value_node);
        let base_vid: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(recv), ast_span_hi(recv));
        if fa == 0 {
            return emit_mic3_call1(s, vid, i_load, base_vid);
        }
        let sa: EmitState = emit_mic3_const_i64(s, vid, fa * 8);
        let sb: EmitState = emit_mic3_binop(sa, vid + 1, 0, base_vid, vid);
        return emit_mic3_call1(sb, vid + 2, i_load, vid + 1);
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, strc, 0)
}

// Emit one field's store. `ptr_vid` is the alloc base. `vid` is the next free
// vid. The field VALUE is an ARBITRARY expression, lowered via the GENERAL tree
// emitter (flatten_branch resolves its slot vids from `vid`, returning the root
// vid; emit_mic3_tree_body emits its non-param instrs). The value's instrs come
// FIRST and consume vids, THEN the address (direct ptr for idx 0; CONST(idx*8)+Add
// for idx>0) threads from the vid past the value, THEN the store CALL — matching
// the --emit-mic3 oracle's per-field interleaving (Bound by MIND-CONSTITUTION §I).
pub fn slit_emit_field(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, ptr_vid: i64, i_store: i64, value_node: i64, idx: i64, vid: i64) -> EmitState {
    // value: lower the field-value expression to its result vid + its body instrs.
    // CONTAINED field-access (recv.field, recv a param of THIS struct) is special-
    // cased here (the general tree emitter rejects ast_field): it emits a field-READ
    // load (CALL load(base) for offset 0; CONST+Add+CALL load for offset>0), with
    // the receiver param vid as the base. Any other value goes through the general
    // tree emitter (flatten_branch + emit_mic3_tree_body).
    let fa: i64 = slit_value_fa_idx(value_node, src, params_addr, n_params, sft);
    let val_vid: i64 = slit_value_val_vid(value_node, src, params_addr, n_params, nodes, cursor, vidbuf, sft, fa, vid);
    let vcount: i64 = slit_value_instr_count(value_node, src, params_addr, n_params, sft);
    let s1: EmitState = slit_emit_value(s, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fa, value_node, vid);
    let vid1: i64 = vid + vcount;
    // address
    let addr_vid: i64 = if idx == 0 {
        ptr_vid
    } else {
        vid1 + 1
    };
    let s2: EmitState = if idx == 0 {
        s1
    } else {
        emit_mic3_const_i64(s1, vid1, idx * 8)
    };
    let s3: EmitState = if idx == 0 {
        s2
    } else {
        emit_mic3_binop(s2, vid1 + 1, 0, ptr_vid, vid1)
    };
    let vid2: i64 = if idx == 0 {
        vid1
    } else {
        vid1 + 2
    };
    // store
    emit_mic3_call2(s3, vid2, i_store, addr_vid, val_vid)
}

// Recursively emit every field's store in DECLARED order, threading the running
// vid. `sft` gives the declared field names/order; `fields_addr`/`ntriples` the
// source-order initializer triples. Returns the EmitState after all stores.
pub fn slit_emit_fields(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, fields_addr: i64, ntriples: i64, ptr_vid: i64, i_store: i64, k: i64, vid: i64) -> EmitState {
    if k >= sft_table_count(sft) {
        return s;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_value_instr_count(vnode, src, params_addr, n_params, sft);
    let s1: EmitState = slit_emit_field(s, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, ptr_vid, i_store, vnode, k, vid);
    let next_vid: i64 = vid + slit_field_instr_count(vcount, k);
    slit_emit_fields(s1, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, k + 1, next_vid)
}

// Total FN_DEF body length contributed by the per-field stores. The fixed
// prologue (n_params PARAMs + CONST elem + CONST n + Mul + alloc) is added by the
// caller; this returns only the store contribution.
pub fn slit_body_len(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64, acc: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return acc;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_value_instr_count(vnode, src, params_addr, n_params, sft);
    slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1, acc + slit_field_instr_count(vcount, k))
}

// Does ANY declared field's value lower to a field-READ (CONTAINED ast_field)?
// If so the body emits `__mind_load_i64` and its name must be interned (first-seen,
// between __mind_alloc and __mind_store_i64). Returns 1 if any, else 0.
pub fn slit_any_field_access(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 0;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if slit_value_fa_idx(vnode, src, params_addr, n_params, sft) >= 0 {
        return 1;
    }
    slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1)
}

// Locate the top-level fn_def whose body is a single statement that is a struct
// literal (`T { .. }`) — the constructor fn — among the parsed items. Returns the
// fn AST node, or 0 if none. Walks items in declaration order so the FIRST such fn
// wins (the supported module shape has exactly one).
pub fn slit_find_ctor_fn(items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let body: i64 = ast_child2(item);
        let stmts_addr: i64 = ast_child0(body);
        let stmts_len: i64 = ast_aux(body);
        if stmts_len == 1 {
            let expr: i64 = __mind_load_i64(stmts_addr + 0);
            if ast_kind(expr) == ast_struct_lit() {
                return item;
            }
        }
    }
    slit_find_ctor_fn(items_addr, items_len, i + 1)
}

// Emit the struct-literal constructor fn's FN_DEF (header + alloc/store body) using
// MODULE-WIDE string indices. Unlike the single-fn path (slit_emit_param_pairs /
// slit_emit_param_instrs, which hardcode the param string idx as 1+k), the param
// string indices come from the module-wide union table (resolved via
// module_param_str_idxs), so a ctor fn declared after helper fns binds its params to
// their actual interned slots. The body spine (PARAM* + CONST elem + CONST nfields +
// Mul + alloc, then per-field stores) is IDENTICAL to the single-fn path; field
// VALUES (incl. CALLs to helper fns) lower through the general tree emitter, whose
// call-name resolution hits the module union table. Byte-exact vs --emit-mic3.
pub fn slit_emit_ctor_fndef(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, fn_node: i64, i_fn: i64, pstr: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_load: i64, i_store: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    let ptr_vid: i64 = n_params + 3;
    let prologue_len: i64 = n_params + 4;
    let body_len: i64 = prologue_len + slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, 0, 0);
    // FN_DEF header: name || param-pairs(module idx) || ret %ptr_vid || None || body_len.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, i_fn);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, ptr_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    // Body prologue: PARAM %0..%(n-1) (module idx), CONST 8, CONST n_fields, Mul, alloc.
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_const_i64(s7, n_params, 8);
    let s9: EmitState = emit_mic3_const_i64(s8, n_params + 1, n_fields);
    let s10: EmitState = emit_mic3_binop(s9, n_params + 2, 2, n_params, n_params + 1);
    let s11: EmitState = emit_mic3_call1(s10, ptr_vid, i_alloc, n_params + 2);
    // Per-field stores (declared order); field VALUES via the general tree emitter.
    slit_emit_fields(s11, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1)
}

// ITEM-ORDER multi-fn module driver for a single-struct module that contains the
// struct-literal constructor fn PLUS one or more helper fns (e.g. a call-valued
// field `T { v: id(a) }` where `id` is a sibling fn). The module is assembled in
// SOURCE-ITEM order, threading a flat scaffold counter k:
//   * helper fn item  -> emit_mic3_module_fndef(...) + scaffold(k)
//   * struct item     -> scaffold(k) only
//   * ctor fn item    -> slit_emit_ctor_fndef(...) + scaffold(k)
// with next_id = n_fns + n_structs and instr_count = 2*(n_fns+n_structs) + n_fns.
// The module string table is the union (build_module_strtab in item order: every
// fn name + params + body call-names) THEN the ctor body intrinsics (__mind_alloc,
// optional __mind_load_i64, __mind_store_i64) and the struct type + field names —
// exactly the first-seen order the Rust oracle interns. Fail-closed (seed `s`) on
// any helper fn outside emit_mic3_module_fndef's proven shapes or any unsupported
// field value. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_mic3_module_structlit_nfn(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let sft: i64 = sft_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let n_fns: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    let n_structs: i64 = srt_count(srt);
    // Only a single struct is supported here; the registry tail emits one struct_def.
    if n_structs != 1 {
        return s;
    }
    if sft_table_count(sft) < 1 {
        return s;
    }
    // The constructor fn (body = one struct-literal). Its own params drive the spine.
    let ctor_fn: i64 = slit_find_ctor_fn(items_addr, items_len, 0);
    if ctor_fn == 0 {
        return s;
    }
    let n_params: i64 = ast_aux(ctor_fn) / 2;
    let params_addr: i64 = ast_child1(ctor_fn);
    // Recover the struct-literal field triples (source order) from the ctor body.
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    // Struct type name (the constructed type / return type) from the registry.
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Every declared field's value must lower through the general tree emitter (ident /
    // literal / arithmetic / call) or be a contained field-access. Fail-closed else.
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // String table — UNION first (every fn name + params + body call-names, item
    // order), THEN the ctor body intrinsics + struct type + field names (first-seen).
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let _u: i64 = build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_load: i64 = if slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, 0) == 1 {
        intern_load_i64_name(strbuf, offs, ccell)
    } else {
        0 - 1
    };
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    let strc: i64 = __mind_load_i64(ccell);
    // Resolve the ctor fn's param string indices against the union table.
    let pstr: i64 = __mind_alloc(n_params * 8 + 8);
    let pres: i64 = module_param_str_idxs(src, ctor_fn, strbuf, offs, ncount, pstr, 0);
    if pres != 1 {
        return s;
    }
    let i_fn: i64 = fn_name_idx(src, ctor_fn, strbuf, offs, ncount);
    if i_fn < 0 {
        return s;
    }
    // Per-field scratch for the general tree emitter (field VALUES).
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    // header || strtab || next_id(=n_fns+n_structs) || exports(0) ||
    //   instr_count(=2*(n_fns+n_structs)+n_fns).
    let n_items: i64 = n_fns + n_structs;
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, n_items);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, n_items + n_items + n_fns);
    // Per-item FN_DEF/scaffold loop, threaded through one ok_cell.
    let ok_cell: i64 = __mind_alloc(8);
    __mind_store_i64(ok_cell, 1);
    let s6: EmitState = slit_emit_items_loop(s5, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, 0, 0);
    if __mind_load_i64(ok_cell) == 0 {
        return s;
    }
    // Registry: one struct (ty=[field0..fieldN-1]) || const_array_defs=0 || repr_c=0.
    let s7: EmitState = emit_uleb128(s6, 1);
    let s8: EmitState = emit_uleb128(s7, i_ty);
    let s9: EmitState = emit_uleb128(s8, n_fields);
    let s10: EmitState = ffa_emit_field_idxs_interned(s9, strbuf, offs, ccell, src, sft, 0);
    let s11: EmitState = emit_uleb128(s10, 0);
    emit_uleb128(s11, 0)
}

pub fn dbg_structlit_nfn_stage(src: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let sft: i64 = sft_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let n_structs: i64 = srt_count(srt);
    if n_structs != 1 {
        return 1;
    }
    if sft_table_count(sft) < 1 {
        return 2;
    }
    let ctor_fn: i64 = slit_find_ctor_fn(items_addr, items_len, 0);
    if ctor_fn == 0 {
        return 3;
    }
    let n_params: i64 = ast_aux(ctor_fn) / 2;
    let params_addr: i64 = ast_child1(ctor_fn);
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return 4;
    }
    n_params * 1000 + ntriples
}

pub fn dbg_item_kind(src: i64, src_len: i64, idx: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    if idx < 0 {
        return items_len;
    }
    if idx >= items_len {
        return 0 - 99;
    }
    ast_kind(__mind_load_i64(items_addr + idx * 8))
}

pub fn dbg_structlit_items(src: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    dbg_structlit_items_loop(items_addr, items_len, 0, 0)
}
pub fn dbg_structlit_items_loop(items_addr: i64, items_len: i64, i: i64, acc: i64) -> i64 {
    if i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let kind: i64 = ast_kind(item);
    // encode per-item: kind in low digits, for fn_def add body shape info
    let info: i64 = if kind == ast_fn_def() {
        let body: i64 = ast_child2(item);
        let stmts_len: i64 = ast_aux(body);
        let stmts_addr: i64 = ast_child0(body);
        let ek: i64 = if stmts_len >= 1 {
            ast_kind(__mind_load_i64(stmts_addr + 0))
        } else {
            0 - 1
        };
        90000 + stmts_len * 100 + ek
    } else {
        kind
    };
    dbg_structlit_items_loop(items_addr, items_len, i + 1, acc * 100000 + info)
}

// Walk the items in source order emitting each item's instrs and the flat scaffold
// counter k. `k`/`item_i` advance in lockstep: k is the per-item scaffold vid (=
// item index counting BOTH fns and structs), item_i walks the raw item array.
pub fn slit_emit_items_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, strc: i64, ctor_fn: i64, i_fn: i64, pstr: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_load: i64, i_store: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    // Struct definition: scaffold only.
    if ast_kind(item) != ast_fn_def() {
        let ss: EmitState = emit_mic3_scaffold(s, k);
        return slit_emit_items_loop(ss, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1);
    }
    // The constructor fn: alloc/store spine.
    if item == ctor_fn {
        let sc: EmitState = slit_emit_ctor_fndef(s, src, strbuf, offs, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf);
        let sc2: EmitState = emit_mic3_scaffold(sc, k);
        return slit_emit_items_loop(sc2, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1);
    }
    // A helper fn: one of emit_mic3_module_fndef's proven body shapes.
    let sh: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return sh;
    }
    let sh2: EmitState = emit_mic3_scaffold(sh, k);
    slit_emit_items_loop(sh2, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1)
}

// ===========================================================================
// Step C — LET-CHAIN struct-literal constructor bodies.
//
// A ctor fn body `{ let n0 = E0; ...; T { f0: v0, ... } }` lowers BYTE-IDENTICAL
// to the same shape as a no-let ctor, with the let inits emitted FIRST (each let
// name SSA-aliases its init's root vid), THEN the alloc/store spine shifted past
// the let body instrs. A field value that names a let resolves to that let's vid
// (no instr, no string); a field value that names a param resolves to the param
// vid; an int-literal field value emits ONE CONST. Reuses the proven let-chain
// flatten (flatten_let_chain / flatten_expr_env / the slot->vid resolution) for
// the let prefix and the alloc/store spine of the no-let path for the body.
// Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I); fail-closed (returns
// seed `s`) on any field value that is not a param-ident / let-ref / int-literal.
// ===========================================================================

// Rewrite each let-env record's stored descriptor slot into its RESOLVED vid
// (read from `vidbuf` after the let prefix's tree_resolve_vids_base). After this
// the let-env maps a let name-span directly to the SSA vid its init produced, so
// a field-value let-ref resolves with no descriptor lookup. Tail-recursive.
pub fn slit_letenv_slot_to_vid(env: i64, nlets: i64, vidbuf: i64, i: i64) -> i64 {
    if i >= nlets {
        return 0;
    }
    let slot: i64 = __mind_load_i64(env + i * 24 + 16);
    __mind_store_i64(env + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    slit_letenv_slot_to_vid(env, nlets, vidbuf, i + 1)
}

// Field VALUE classification for the let-aware ctor body. Returns:
//   1  -> int-literal (emits one CONST, consumes one vid)
//   0  -> param-ident OR let-ref-ident (emits nothing, reuses an existing vid)
//  -1  -> any other shape (fail-closed; arith-over-let / call / field-access are
//         NOT yet supported on the let-chain path — reported as remaining work).
pub fn slit_letaware_value_kind(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64) -> i64 {
    let k: i64 = ast_kind(vnode);
    if k == ast_paren() {
        return slit_letaware_value_kind(ast_child0(vnode), src, params_addr, n_params, env, nlets);
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_ident() {
        let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(vnode), ast_span_hi(vnode));
        if pidx >= 0 {
            return 0;
        }
        // env records now hold VIDs (slit_letenv_slot_to_vid); a hit means let-ref.
        let lvid: i64 = letenv_lookup(src, ast_span_lo(vnode), ast_span_hi(vnode), env, nlets, 0);
        if lvid >= 0 {
            return 0;
        }
        return 0 - 1;
    }
    0 - 1
}

// The non-spine instr count contributed by ONE let-aware field value: int-literal
// = 1 (one CONST), param/let-ref ident = 0. Caller guarantees a supported shape.
pub fn slit_letaware_value_count(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64) -> i64 {
    let kind: i64 = slit_letaware_value_kind(vnode, src, params_addr, n_params, env, nlets);
    if kind == 1 {
        return 1;
    }
    0
}

// The result vid a let-aware field VALUE produces. For a param-ident: the param
// vid (= its declaration index). For a let-ref ident: the let's resolved vid (the
// env now stores vids). For an int-literal: the freshly-emitted CONST's vid =
// `vid` (the next free vid). Caller guarantees the shape (kind != -1).
pub fn slit_letaware_value_vid(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, vid: i64) -> i64 {
    let k: i64 = ast_kind(vnode);
    if k == ast_paren() {
        return slit_letaware_value_vid(ast_child0(vnode), src, params_addr, n_params, env, nlets, vid);
    }
    if k == ast_int_lit() {
        return vid;
    }
    let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(vnode), ast_span_hi(vnode));
    if pidx >= 0 {
        return pidx;
    }
    letenv_lookup(src, ast_span_lo(vnode), ast_span_hi(vnode), env, nlets, 0)
}

// Emit the let-aware field VALUE's instrs: an int-literal emits ONE CONST at
// `vid`; a param/let-ref ident emits nothing (its vid already exists). Returns
// the post-emit EmitState.
pub fn slit_emit_letaware_value(s: EmitState, vnode: i64, src: i64, vid: i64) -> EmitState {
    let v: i64 = if ast_kind(vnode) == ast_paren() {
        ast_child0(vnode)
    } else {
        vnode
    };
    if ast_kind(v) == ast_int_lit() {
        let lit: i64 = parse_int_span(src, ast_span_lo(v), ast_span_hi(v), 0);
        return emit_mic3_const_i64(s, vid, lit);
    }
    s
}

// Emit ONE field's store for the let-aware ctor body. The VALUE comes FIRST (a
// CONST for a literal, nothing for an ident), THEN the address (direct ptr for
// idx 0; CONST(idx*8)+Add(ptr,off) for idx>0), THEN the store CALL — matching the
// no-let path's per-field interleaving and the --emit-mic3 oracle.
pub fn slit_emit_letaware_field(s: EmitState, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, ptr_vid: i64, i_store: i64, vnode: i64, idx: i64, vid: i64) -> EmitState {
    let val_vid: i64 = slit_letaware_value_vid(vnode, src, params_addr, n_params, env, nlets, vid);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    let s1: EmitState = slit_emit_letaware_value(s, vnode, src, vid);
    let vid1: i64 = vid + vcount;
    let addr_vid: i64 = if idx == 0 {
        ptr_vid
    } else {
        vid1 + 1
    };
    let s2: EmitState = if idx == 0 {
        s1
    } else {
        emit_mic3_const_i64(s1, vid1, idx * 8)
    };
    let s3: EmitState = if idx == 0 {
        s2
    } else {
        emit_mic3_binop(s2, vid1 + 1, 0, ptr_vid, vid1)
    };
    let vid2: i64 = if idx == 0 {
        vid1
    } else {
        vid1 + 2
    };
    emit_mic3_call2(s3, vid2, i_store, addr_vid, val_vid)
}

// Recursively emit every declared field's store (DECLARED order) for the let-aware
// ctor body, threading the running vid. Mirrors slit_emit_fields but resolves
// field values against params AND the let-env.
pub fn slit_emit_letaware_fields(s: EmitState, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, ptr_vid: i64, i_store: i64, k: i64, vid: i64) -> EmitState {
    if k >= sft_table_count(sft) {
        return s;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    let s1: EmitState = slit_emit_letaware_field(s, src, params_addr, n_params, env, nlets, ptr_vid, i_store, vnode, k, vid);
    let next_vid: i64 = vid + slit_field_instr_count(vcount, k);
    slit_emit_letaware_fields(s1, src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, ptr_vid, i_store, k + 1, next_vid)
}

// Body length contributed by the per-field stores in the let-aware ctor body.
pub fn slit_letaware_body_len(src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64, acc: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return acc;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    slit_letaware_body_len(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, k + 1, acc + slit_field_instr_count(vcount, k))
}

// Shape guard: every DECLARED field has a let-aware-resolvable value (param-ident /
// let-ref / int-literal). 1 if all OK, 0 (fail-closed) otherwise.
pub fn slit_letaware_fields_ok(src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 1;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if vnode == 0 {
        return 0;
    }
    if slit_letaware_value_kind(vnode, src, params_addr, n_params, env, nlets) < 0 {
        return 0;
    }
    slit_letaware_fields_ok(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, k + 1)
}

// Locate the single fn_def item in the parsed module (the ctor fn). Returns the
// fn AST node or 0. Used by the let-aware from_ast path to recover the ctor body's
// let statements (the token-based slit_find_ctor finds only the `T {` literal).
pub fn slit_single_fn_def(items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        return item;
    }
    slit_single_fn_def(items_addr, items_len, i + 1)
}

// Emit the let-chain ctor fn's FN_DEF (single-fn from_ast path). `n_nodes_letp` is
// the number of descriptor slots the let prefix flattened into `nodes`, already
// vid-resolved in `vidbuf` (base n_params); `env`/`nlets` the let-env with records
// REWRITTEN to vids (slit_letenv_slot_to_vid). The body:
//   PARAM %0..%(n-1) || <let prefix body instrs> || CONST 8 || CONST n_fields ||
//   Mul || alloc(ptr) || per-field stores.
pub fn slit_emit_letchain_ctor_fndef(s: EmitState, src: i64, i_fn: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_store: i64, nodes: i64, n_nodes_letp: i64, vidbuf: i64, let_nonparam: i64, env: i64, nlets: i64) -> EmitState {
    let let_base: i64 = n_params + let_nonparam;
    let ptr_vid: i64 = let_base + 3;
    let body_len: i64 = n_params + let_nonparam + 4 + slit_letaware_body_len(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, 0, 0);
    // FN_DEF header: name || (string 1+k, vid k) pairs || ret %ptr_vid || None || len.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, i_fn);
    let s3: EmitState = emit_uleb128(s2, n_params);
    let s4: EmitState = slit_emit_param_pairs(s3, n_params, 0);
    let s5: EmitState = emit_mic3_opt_vid(s4, 1, ptr_vid);
    let s6: EmitState = es_push(s5, 0);
    let s7: EmitState = emit_uleb128(s6, body_len);
    // Body: PARAMs, then the let-prefix body instrs (tree_body over the let slots).
    let s8: EmitState = slit_emit_param_instrs(s7, n_params, 0);
    let s9: EmitState = emit_mic3_tree_body(s8, nodes, n_nodes_letp, vidbuf, src, 0, 0, 0, 0);
    // Spine: CONST 8, CONST n_fields, Mul, alloc -> ptr (shifted past the let body).
    let s10: EmitState = emit_mic3_const_i64(s9, let_base, 8);
    let s11: EmitState = emit_mic3_const_i64(s10, let_base + 1, n_fields);
    let s12: EmitState = emit_mic3_binop(s11, let_base + 2, 2, let_base, let_base + 1);
    let s13: EmitState = emit_mic3_call1(s12, ptr_vid, i_alloc, let_base + 2);
    // Per-field stores (declared order); values resolve vs params + let-env.
    slit_emit_letaware_fields(s13, src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1)
}

// AST-driven mic@3 module for a single-struct, single-fn ctor whose body is a
// LET CHAIN followed by ONE struct-literal return. Fail-closed (returns seed `s`)
// on any shape this path does not cover (so the no-let path keeps its bytes).
pub fn emit_mic3_module_structlit_letchain_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, ctor_fn: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) < 1 {
        return s;
    }
    if srt_count(srt) != 1 {
        return s;
    }
    let n_params: i64 = ptt_table_count(ptt);
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Locate the `T { .. }` construction (token scan) and recover its field triples.
    let ctor: i64 = slit_find_ctor(tokens, 0, src, ty_lo, ty_hi);
    if ctor < 0 {
        return s;
    }
    let slit: ParseResult = parse_struct_lit(tokens, ctor, src);
    let snode: i64 = pr_node(slit);
    if ast_kind(snode) != ast_struct_lit() {
        return s;
    }
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    let params_addr: i64 = slit_build_params_addr(ptt, src);
    // Recover the ctor body's leading let statements (all stmts but the last).
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len < 2 {
        return s;
    }
    // Flatten the let prefix into a fresh descriptor + let-env.
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    let env: i64 = __mind_alloc(64 * 24);
    let nlets_cell: i64 = __mind_alloc(8);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    let chain_ok: i64 = flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, 0);
    if chain_ok == 0 {
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let n_nodes_letp: i64 = __mind_load_i64(cursor);
    let let_nonparam: i64 = count_descriptor_nonparam(nodes, n_nodes_letp, 0);
    // Resolve the let-prefix slot vids (non-param base = n_params), then rewrite the
    // let-env to hold vids so field-value let-refs resolve directly.
    let _rv: i64 = tree_resolve_vids_base(nodes, n_nodes_letp, vidbuf, 0, n_params);
    let _ev: i64 = slit_letenv_slot_to_vid(env, nlets, vidbuf, 0);
    // Every declared field must be a let-aware-resolvable value (param/let-ref/lit).
    if slit_letaware_fields_ok(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // The fn name: token right before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // String table — first-seen: fn name (0), params (1..1+n), __mind_alloc,
    // __mind_store_i64, type name, then each field name. (No field-access here, so
    // __mind_load_i64 is never interned — keeping strtab identical to the no-let
    // path for the same struct/field/param names.)
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let _ip: i64 = slit_intern_params(strbuf, offs, ccell, src, ptt, 0);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    let strc: i64 = __mind_load_i64(ccell);
    // Module: header || strtab || next_id(2) || exports(0) || 5 instrs:
    //   CONST %0 / OUTPUT %0  (struct scaffold)
    //   FN_DEF ctor { let prefix + alloc/store body }
    //   CONST %1 / OUTPUT %1  (fn scaffold)
    // || struct_defs[ ty=[fields] ] || const_array_defs=0 || repr_c_structs=0.
    let h1: EmitState = emit_mic3_header(s);
    let h2: EmitState = emit_mic3_strtab(h1, strbuf, offs, strc);
    let h3: EmitState = emit_uleb128(h2, 2);
    let h4: EmitState = emit_uleb128(h3, 0);
    let h5: EmitState = emit_uleb128(h4, 5);
    let h6: EmitState = emit_mic3_const_i64(h5, 0, 0);
    let h7: EmitState = emit_mic3_output(h6, 0);
    let h8: EmitState = slit_emit_letchain_ctor_fndef(h7, src, i_fn, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_store, nodes, n_nodes_letp, vidbuf, let_nonparam, env, nlets);
    let h9: EmitState = emit_mic3_const_i64(h8, 1, 0);
    let h10: EmitState = emit_mic3_output(h9, 1);
    let h11: EmitState = emit_uleb128(h10, 1);
    let h12: EmitState = emit_uleb128(h11, i_ty);
    let h13: EmitState = emit_uleb128(h12, n_fields);
    let h14: EmitState = ffa_emit_field_idxs_interned(h13, strbuf, offs, ccell, src, sft, 0);
    let h15: EmitState = emit_uleb128(h14, 0);
    emit_uleb128(h15, 0)
}

// AST-driven mic@3 module for a single-struct, single-param fn returning ONE
// struct-literal. Fail-closed (returns seed `s`) on any other shape.
pub fn emit_mic3_module_structlit_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    // Multi-item modules (a ctor fn PLUS sibling helper fns, or >1 struct) route to
    // the item-order multi-fn assembler. The single-fn / single-struct path below
    // stays byte-identical for the 12 existing cases (its narrower shape guards keep
    // those exact bytes). The dispatch fires only when extra fns are present.
    let _mtokens: Vec = lex(src, src_len);
    let mroot: i64 = parse(_mtokens, src);
    let mitems_addr: i64 = ast_child0(mroot);
    let mitems_len: i64 = ast_aux(mroot);
    if count_fn_defs(mitems_addr, mitems_len, 0, 0) > 1 {
        return emit_mic3_module_structlit_nfn(s, src, src_len, strbuf, offs, ccell);
    }
    // Single-fn LET-CHAIN ctor body (`{ let .. ; T { .. } }`): route to the
    // let-aware driver. The no-let single-stmt path below is untouched for the
    // 14 existing cases (it sees stmts_len == 1 and falls through).
    let only_fn: i64 = slit_single_fn_def(mitems_addr, mitems_len, 0);
    if only_fn != 0 {
        let ofbody: i64 = ast_child2(only_fn);
        if ast_aux(ofbody) >= 2 {
            return emit_mic3_module_structlit_letchain_from_ast(s, src, src_len, strbuf, offs, ccell, only_fn);
        }
    }
    // Shape guards: exactly one struct (>=1 field) and at least one fn param.
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) < 1 {
        return s;
    }
    let n_params: i64 = ptt_table_count(ptt);
    // The struct type name is the CONSTRUCTED struct's own name (the ctor /
    // return type), NOT the param type — for `mk(a: i64) -> Point` the param is
    // i64 while the literal builds a Point. Take it from the struct registry.
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Locate the `T { .. }` construction.
    let ctor: i64 = slit_find_ctor(tokens, 0, src, ty_lo, ty_hi);
    if ctor < 0 {
        return s;
    }
    // Parse the struct-literal to recover its source-order field triples.
    let slit: ParseResult = parse_struct_lit(tokens, ctor, src);
    let snode: i64 = pr_node(slit);
    if ast_kind(snode) != ast_struct_lit() {
        return s;
    }
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    // Param AST-node array for the general tree emitter (resolve_param form), and
    // the per-field scratch descriptor / vid buffers.
    let params_addr: i64 = slit_build_params_addr(ptt, src);
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    // Every declared field must have an initializer the general tree emitter can
    // lower (ident / literal / arithmetic / call). Fail-closed otherwise (missing
    // field or an unsupported construct).
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // The fn name: token right before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Intern strings FIRST-SEEN: fn name (0), every param name in declaration
    // order (1..1+n_params), __mind_alloc, __mind_store_i64, type name, then every
    // field in declaration order. The alloc/store/type indices shift by n_params.
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let _ip: i64 = slit_intern_params(strbuf, offs, ccell, src, ptt, 0);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_load: i64 = if slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, 0) == 1 {
        intern_load_i64_name(strbuf, offs, ccell)
    } else {
        0 - 1
    };
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    // String count = the ACTUAL number interned (the StringTable de-dups, so a
    // field name that equals a param name does NOT add a slot). Read it from the
    // count cell after all interning rather than assuming a contiguous layout.
    let strc: i64 = __mind_load_i64(ccell);
    // The alloc pointer (= fn ret vid) sits just past the n_params PARAMs plus the
    // CONST-8 / CONST-nfields / Mul / alloc prologue: vid = n_params + 3.
    let ptr_vid: i64 = n_params + 3;
    let prologue_len: i64 = n_params + 4;
    let body_len: i64 = prologue_len + slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, 0, 0);
    // Module: header || strtab || next_id(2) || exports(0) || 5 instrs:
    //   CONST %0 / OUTPUT %0  (struct decl scaffold)
    //   FN_DEF f(params){ <body> } ret %(n_params+3)
    //   CONST %1 / OUTPUT %1  (fn scaffold)
    // || struct_defs[ ty=[fields...] ] || const_array_defs=0 || repr_c_structs=0.
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 5);
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF header: name, n_params pairs (string 1+k, vid k), ret = alloc ptr.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn);
    let s10: EmitState = emit_uleb128(s9, n_params);
    let s11: EmitState = slit_emit_param_pairs(s10, n_params, 0);
    let s13: EmitState = emit_mic3_opt_vid(s11, 1, ptr_vid);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, body_len);
    // Body prologue: PARAM %0..%(n-1), CONST 8, CONST n_fields, Mul, alloc -> ptr.
    let s16: EmitState = slit_emit_param_instrs(s15, n_params, 0);
    let s17: EmitState = emit_mic3_const_i64(s16, n_params, 8);
    let s18: EmitState = emit_mic3_const_i64(s17, n_params + 1, n_fields);
    let s19: EmitState = emit_mic3_binop(s18, n_params + 2, 2, n_params, n_params + 1);
    let s20: EmitState = emit_mic3_call1(s19, ptr_vid, i_alloc, n_params + 2);
    // Per-field stores (declared order), vids start just past the alloc ptr. Field
    // VALUES are lowered by the general tree emitter (arbitrary expressions).
    let s21: EmitState = slit_emit_fields(s20, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1);
    let s22: EmitState = emit_mic3_const_i64(s21, 1, 0);
    let s23: EmitState = emit_mic3_output(s22, 1);
    // Registry: one struct (ty=[field0..fieldN-1]). Each field's string index is
    // its ACTUAL interned index (re-intern is idempotent), so a field aliasing a
    // param name points at the prior slot.
    let s24: EmitState = emit_uleb128(s23, 1);
    let s25: EmitState = emit_uleb128(s24, i_ty);
    let s26: EmitState = emit_uleb128(s25, n_fields);
    let s27: EmitState = ffa_emit_field_idxs_interned(s26, strbuf, offs, ccell, src, sft, 0);
    let s28: EmitState = emit_uleb128(s27, 0);
    emit_uleb128(s28, 0)
}

// Intern every param NAME in declaration order (string indices 1..1+n_params,
// directly after the fn name at 0). Returns 0; the side effect is the interning.
pub fn slit_intern_params(strbuf: i64, offs: i64, ccell: i64, src: i64, ptt: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0;
    }
    let _p: i64 = intern_span(strbuf, offs, ccell, src, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k));
    slit_intern_params(strbuf, offs, ccell, src, ptt, k + 1)
}

// Emit the FN_DEF header's named-vid pairs (string_idx, vid) for every param:
// param k has string index 1+k and binds vid k. Tail-recursive over k.
pub fn slit_emit_param_pairs(s: EmitState, n_params: i64, k: i64) -> EmitState {
    if k >= n_params {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, 1 + k);
    let s2: EmitState = emit_uleb128(s1, k);
    slit_emit_param_pairs(s2, n_params, k + 1)
}

// Emit the body PARAM instrs: PARAM %k name=(1+k) index=k for every param.
pub fn slit_emit_param_instrs(s: EmitState, n_params: i64, k: i64) -> EmitState {
    if k >= n_params {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, k, 1 + k, k);
    slit_emit_param_instrs(s1, n_params, k + 1)
}

// Verify every DECLARED field has an initializer the GENERAL tree emitter can
// lower (count_nonparam_nodes returns >= 0: ident / int-literal / arithmetic /
// nested call — anything flatten_ast accepts). Fail-closed (0) on a missing field
// or an unsupported construct (field-access / if / struct-lit nesting), so no
// partial bytes are emitted. 1 if all OK.
pub fn slit_fields_ok(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 1;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if vnode == 0 {
        return 0;
    }
    if slit_value_instr_count(vnode, src, params_addr, n_params, sft) < 0 {
        return 0;
    }
    slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1)
}

pub fn selftest_mic3_module_structlit_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_module_structlit_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===== mic@3 AST-DRIVEN MULTI-STRUCT field-read load (part 1b wired) =====
//
// Extends the single-struct field read to N structs in declaration order, so a
// receiver declared as the 2nd+ struct resolves its field against the CORRECT
// struct. Reuses SECTION 6b's registry (srt_*): the receiver param's declared
// type name (part 2, ptt) keys srt_find_by_name -> the struct index k; the field
// name resolves within struct k via srt_field_index; the accessed field's string
// index is srt_field_strbase(k) + fidx.
//
// Module shape for N structs + 1 fn (verified vs `mindc --emit-mic3`):
//   * string table (FIRST-SEEN order): fn name, param name, __mind_load_i64, then
//     per struct in declaration order [type name][field0..fieldM-1];
//   * instrs: N module-level CONST/OUTPUT placeholder pairs (one per struct, "a
//     struct decl produces no value"), then the FN_DEF, then ONE more CONST/OUTPUT
//     pair (the fn placeholder). next_id = N + 1, instr_count = 2*(N+1) + 1;
//   * struct_defs registry lists ALL N structs with their field string-idx lists.
// ADDITIVE / canary-isolated (exported only via the selftest below). N==1 is a
// strict subset and reproduces the single-struct oracle byte-for-byte.

// Intern every struct's type name then its fields, in declaration order. Mirrors
// the Rust collect order: type name first, then each field, per struct.
pub fn srt_intern_all(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0;
    }
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    srt_intern_all(strbuf, offs, ccell, src, t, k + 1)
}

pub fn srt_intern_fields(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64, j: i64) -> i64 {
    if j >= srt_field_count(t, k) {
        return 0;
    }
    let _i: i64 = intern_span(strbuf, offs, ccell, src, srt_field_lo(t, k, j), srt_field_hi(t, k, j));
    srt_intern_fields(strbuf, offs, ccell, src, t, k, j + 1)
}

// Total interned string count = 3 fixed (fn,param,load) + per struct (1 type +
// its fields). Equals 3 + N + sum(field_counts).
pub fn srt_total_strings(t: i64) -> i64 {
    3 + srt_count(t) + srt_cumulative_fields(t, srt_count(t), 0)
}

// Emit the N module-level struct placeholder pairs CONST %k=0 / OUTPUT %k for
// struct indices [k, N). Each struct decl, like a fn def, produces no value.
pub fn srt_emit_struct_placeholders(s: EmitState, n: i64, k: i64) -> EmitState {
    if k >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_const_i64(s, k, 0);
    let s2: EmitState = emit_mic3_output(s1, k);
    srt_emit_struct_placeholders(s2, n, k + 1)
}

// Emit the struct_defs registry for ALL N structs: each entry is
// uleb(type_str_idx) || uleb(field_count) || field string idxs. The field string
// idxs of struct k are srt_field_strbase(k) .. +field_count.
pub fn srt_emit_registry(s: EmitState, t: i64, k: i64) -> EmitState {
    if k >= srt_count(t) {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, srt_type_strbase(t, k));
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = ffa_emit_field_idxs(s2, srt_field_strbase(t, k), fc, 0);
    srt_emit_registry(s3, t, k + 1)
}

// AST-driven mic@3 module for an N-struct, single-param field read at any field
// index, the receiver declared as ANY of the N structs (keyed by type name).
// Returns the seed `s` unchanged on any unexpected shape (fail-closed).
pub fn emit_mic3_field_module_multi(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let n_structs: i64 = srt_count(srt);
    // Shape guards: at least one struct and exactly one fn param.
    if n_structs < 1 {
        return s;
    }
    if ptt_table_count(ptt) != 1 {
        return s;
    }
    // Locate `recv.field`.
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 1 {
        return s;
    }
    let recv_lo: i64 = tok_lo(tokens, dot - 1);
    let recv_hi: i64 = tok_hi(tokens, dot - 1);
    let fld_lo: i64 = tok_lo(tokens, dot + 1);
    let fld_hi: i64 = tok_hi(tokens, dot + 1);
    // Confirm the receiver names param 0.
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, 0), ptt_table_name_hi(ptt, 0)) != 1 {
        return s;
    }
    // Part 2 -> declared type name of the receiver param.
    let ty_lo: i64 = ptt_table_type_lo(ptt, 0);
    let ty_hi: i64 = ptt_table_type_hi(ptt, 0);
    // Multi-struct key: select the struct whose NAME equals the receiver type.
    let sk: i64 = srt_find_by_name(srt, src, ty_lo, ty_hi, 0);
    if sk < 0 {
        return s;
    }
    // Resolve the accessed field within THAT struct.
    let fidx: i64 = srt_field_index(srt, sk, src, fld_lo, fld_hi, 0);
    if fidx < 0 {
        return s;
    }
    // Fn name = the ident two tokens before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Intern strings in FIRST-SEEN order: fn name, param name, __mind_load_i64,
    // then per struct [type name][fields].
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let i_recv: i64 = intern_span(strbuf, offs, ccell, src, recv_lo, recv_hi);
    let i_load: i64 = intern_load_i64_literal(strbuf, offs, ccell);
    // Registry strings intern in BTreeMap-sorted (struct-name) order to match the
    // canonical full string table (cutover fold step 3).
    let _all: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src, srt, 0);
    let strc: i64 = srt_total_strings(srt);
    let body_len: i64 = ffa_body_len(fidx);
    let ret_vid: i64 = ffa_ret_vid(fidx);
    // Header || strtab || next_id(N+1) || exports(0) || instr_count(2*(N+1)+1).
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, n_structs + 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 2 * (n_structs + 1) + 1);
    // N struct placeholders (CONST %k / OUTPUT %k for k in 0..N).
    let s6: EmitState = srt_emit_struct_placeholders(s5, n_structs, 0);
    // FN_DEF header: name idx, 1 param (recv, vid 0), ret %ret_vid, body_len.
    let s7: EmitState = es_push(s6, 21);
    let s8: EmitState = emit_uleb128(s7, i_fn);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, i_recv);
    let s11: EmitState = emit_uleb128(s10, 0);
    let s12: EmitState = emit_mic3_opt_vid(s11, 1, ret_vid);
    let s13: EmitState = es_push(s12, 0);
    let s14: EmitState = emit_uleb128(s13, body_len);
    let s15: EmitState = emit_mic3_param(s14, 0, i_recv, 0);
    let s16: EmitState = ffa_emit_body(s15, fidx, i_load);
    // The fn's own module-level placeholder pair (vid N).
    let s17: EmitState = emit_mic3_const_i64(s16, n_structs, 0);
    let s18: EmitState = emit_mic3_output(s17, n_structs);
    // Registry: all N structs in BTreeMap-sorted order, sorted-rank strbases.
    let s19: EmitState = emit_uleb128(s18, n_structs);
    let s20: EmitState = srt_emit_registry_sorted(s19, srt, src, 0);
    // const_array_defs = 0, repr_c_structs = 0.
    let s21: EmitState = emit_uleb128(s20, 0);
    emit_uleb128(s21, 0)
}

pub fn selftest_mic3_module_field_multi(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_field_module_multi(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// SECTION 9b — METHOD-CALL LOWERING -> UFCS CALL mic@3 BYTE-OUTPUT (part 3)
//
// ADDITIVE / canary-isolated (exported only via selftest_mic3_module_method_from_ast
// below); the canary mindc_compile / emit_fn_def / emit_expr_env path is untouched,
// so the fixed point stays byte-identical (Bound by MIND-CONSTITUTION §I).
//
// Emits the COMPLETE mic@3 module for the genuine method-call fixture
//   struct Point { x: i64, y: i64 }
//   pub fn point_dist(p: Point, k: i64) -> i64 { k }
//   pub fn use_it(p: Point) -> i64 { p.dist(7) }
// byte-for-byte vs `mindc --emit-mic3`. The payoff of parts 1+2: the parsed method
// call (mc_parse_first) and the resolved UFCS callee name (part 2) now drive a real
// Instr::Call. The Rust oracle (src/eval/lower.rs MethodCall arm) desugars
// `recv.method(args)` to a plain Call named `{lowercase(ReceiverType)}_{method}`
// with the RECEIVER threaded as the FIRST call arg, the int-literal args following:
//   use_it body: PARAM %0=p ; CONST %1=7 ; CALL %2 = point_dist([%0, %1]) ; ret %2.
// The callee fn (point_dist) returns its `k` param directly: body = the two PARAM
// bindings, ret = the k param vid (no explicit Output in the body).
//
// String table FIRST-SEEN order mirrors Rust collect_strings walking module.instrs
// (src/ir/compact/v3/emit.rs:492-525): for the callee FnDef intern name then each
// param name; for the caller FnDef intern name, its param, then the body CALL's
// callee name (a dedup HIT since `point_dist` already interned at 0); finally the
// struct_defs registry interns the type name then each field. Yields the 7-entry
// table: point_dist(0) p(1) k(2) use_it(3) Point(4) x(5) y(6).
//
// SCOPE (smallest byte-verifiable slice): exactly one struct, one receiver param,
// one method call with N int-literal args lowering to CALL callee([recv,args...]).
// Any other shape returns the seed state unchanged (fail-closed, no partial bytes).

// Emit an N-argument Instr::Call:
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(nargs) || vid(arg0..N-1).
// `args` is a heap array of `nargs` i64 vids. Generalises emit_mic3_call1.
pub fn emit_mic3_calln(s: EmitState, dst: i64, name_idx: i64, args: i64, nargs: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, nargs);
    emit_mic3_calln_args(s4, args, nargs, 0)
}

pub fn emit_mic3_calln_args(s: EmitState, args: i64, nargs: i64, i: i64) -> EmitState {
    if i >= nargs {
        return s;
    }
    let v: i64 = __mind_load_i64(args + i * 8);
    let s1: EmitState = emit_uleb128(s, v);
    emit_mic3_calln_args(s1, args, nargs, i + 1)
}

// Emit one CONST_I64 per int-literal method-call argument, vids starting at
// `vid0`. `argvals` is a heap array of `nargs` i64 literal values. Each arg lowers
// to a CONST whose vid is consumed (in order) as the corresponding CALL arg vid.
pub fn emit_mic3_method_arg_consts(s: EmitState, argvals: i64, nargs: i64, vid0: i64, i: i64) -> EmitState {
    if i >= nargs {
        return s;
    }
    let v: i64 = __mind_load_i64(argvals + i * 8);
    let s1: EmitState = emit_mic3_const_i64(s, vid0 + i, v);
    emit_mic3_method_arg_consts(s1, argvals, nargs, vid0, i + 1)
}

// Collect the int-literal VALUES of the first method call's args into `argvals`
// (a caller-provided heap array of >= nargs i64s); returns nargs, or -1 if there
// is no parseable method call. Re-parses the args at the call's `(` to recover the
// literal spans (the ast_method node retains only the arg COUNT, not the values).
pub fn mc_collect_arg_values(src_addr: i64, src_len: i64, argvals: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let rpos: i64 = mc_find_method_call(tokens, 0);
    if rpos < 0 {
        return 0 - 1;
    }
    let after_open: i64 = rpos + 4;
    if tok_kind(tokens, after_open) == tk_rparen() {
        return 0;
    }
    let args_res: ParseResult = parse_args_rest(tokens, after_open, src_addr, vec_new());
    let args_node: i64 = pr_node(args_res);
    let nargs: i64 = ast_aux(args_node);
    let args_addr: i64 = ast_child0(args_node);
    let _w: i64 = mc_write_arg_values(argvals, src_addr, args_addr, nargs, 0);
    nargs
}

// Walk the parsed arg nodes; for each int-literal write its parsed value into
// `argvals[i]`. (Smallest slice: args are int literals; mirrors the oracle's
// per-arg CONST lowering.) Returns the number written.
pub fn mc_write_arg_values(argvals: i64, src: i64, args_addr: i64, nargs: i64, i: i64) -> i64 {
    if i >= nargs {
        return i;
    }
    let node: i64 = __mind_load_i64(args_addr + i * 8);
    let v: i64 = parse_int_span(src, ast_span_lo(node), ast_span_hi(node), 0);
    __mind_store_i64(argvals + i * 8, v);
    mc_write_arg_values(argvals, src, args_addr, nargs, i + 1)
}

// Assemble the full mic@3 module for the method-call fixture, AST-driven. The
// caller provides scratch buffers: `strbuf`/`offs`/`ccell` (the string-table
// interner), `cbuf` (a >= 64-byte scratch for the synthesized UFCS callee name),
// `argbuf` (a >= 8*nargs scratch for the const arg vids), `valbuf` (>= 8*nargs for
// the literal values). Returns the seed `s` unchanged on any unexpected shape.
pub fn emit_mic3_method_module_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    // Shape guards: exactly one struct; a parseable method call resolving to a
    // known receiver-param type.
    if srt_count(srt) != 1 {
        return s;
    }
    let m: i64 = mc_parse_first(src, src_len);
    if m == 0 {
        return s;
    }
    let callee_len: i64 = selftest_method_callee_name_into(src, src_len, cbuf);
    if callee_len < 0 {
        return s;
    }
    let nargs: i64 = mc_collect_arg_values(src, src_len, valbuf);
    if nargs < 0 {
        return s;
    }
    // Locate the two fns. fn0 = the callee def (parsed first), fn1 = the caller.
    // pstart0/pstart1 = the index just past each fn's `(` (params start).
    let pstart0: i64 = ptt_find_param_list(tokens, 0);
    if pstart0 < 3 {
        return s;
    }
    let fn0_lo: i64 = tok_lo(tokens, pstart0 - 2);
    let fn0_hi: i64 = tok_hi(tokens, pstart0 - 2);
    let pstart1: i64 = ptt_find_param_list(tokens, pstart0);
    if pstart1 < 3 {
        return s;
    }
    let fn1_lo: i64 = tok_lo(tokens, pstart1 - 2);
    let fn1_hi: i64 = tok_hi(tokens, pstart1 - 2);
    // Callee (fn0) params: name0 : Type0 , name1 : Type1 . The two param NAME spans
    // (the callee returns its 2nd param `k`, so we need both names interned and the
    // 2nd as the ret vid).
    let p0a_lo: i64 = tok_lo(tokens, pstart0);
    let p0a_hi: i64 = tok_hi(tokens, pstart0);
    let p0b_lo: i64 = tok_lo(tokens, pstart0 + 4);
    let p0b_hi: i64 = tok_hi(tokens, pstart0 + 4);
    // Caller (fn1) single param name (the receiver).
    let p1_lo: i64 = tok_lo(tokens, pstart1);
    let p1_hi: i64 = tok_hi(tokens, pstart1);
    // Intern strings in FIRST-SEEN order (mirrors collect_strings over module.instrs):
    //   fn0 name, fn0 param0, fn0 param1, fn1 name, fn1 param (dedup), callee (dedup
    //   to fn0 name), then struct type name + each field.
    let i_fn0: i64 = intern_span(strbuf, offs, ccell, src, fn0_lo, fn0_hi);
    let i_p0a: i64 = intern_span(strbuf, offs, ccell, src, p0a_lo, p0a_hi);
    let i_p0b: i64 = intern_span(strbuf, offs, ccell, src, p0b_lo, p0b_hi);
    let i_fn1: i64 = intern_span(strbuf, offs, ccell, src, fn1_lo, fn1_hi);
    let i_p1: i64 = intern_span(strbuf, offs, ccell, src, p1_lo, p1_hi);
    let i_callee: i64 = intern_span(strbuf, offs, ccell, cbuf, 0, callee_len);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(srt, 0), srt_name_hi(srt, 0));
    let _fld: i64 = srt_intern_fields(strbuf, offs, ccell, src, srt, 0, 0);
    let fc: i64 = srt_field_count(srt, 0);
    let i_f0: i64 = i_ty + 1;
    let strc: i64 = i_ty + 1 + fc;
    // The caller's CALL arg-vid list: receiver param (%0) FIRST, then the const-arg
    // vids %1..%nargs.
    let _r0: i64 = mc_build_call_arg_vids(argbuf, nargs);
    // Header || strtab || next_id(3) || exports(0) || instr_count(8).
    // Flat module-level next_id = one id per top-level item: struct decl -> %0,
    // point_dist -> %1, use_it -> %2, so next_id = 3. instr_count = 8 (3 scaffold
    // CONST/OUTPUT pairs interleaved with the 2 FN_DEFs).
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    // 3 top-level items (struct + 2 fns), each a module-level CONST/OUTPUT pair.
    let s3: EmitState = emit_uleb128(s2, 3);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 8);
    // struct Point decl -> scaffold CONST %0 / OUTPUT %0.
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF point_dist(p=%0, k=%1) ret %1, body = PARAM %0 p, PARAM %1 k (body_len 2).
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn0);
    let s10: EmitState = emit_uleb128(s9, 2);
    let s11: EmitState = emit_uleb128(s10, i_p0a);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_uleb128(s12, i_p0b);
    let s14: EmitState = emit_uleb128(s13, 1);
    let s15: EmitState = emit_mic3_opt_vid(s14, 1, 1);
    let s16: EmitState = es_push(s15, 0);
    let s17: EmitState = emit_uleb128(s16, 2);
    let s18: EmitState = emit_mic3_param(s17, 0, i_p0a, 0);
    let s19: EmitState = emit_mic3_param(s18, 1, i_p0b, 1);
    // fn0 module-level scaffold pair CONST %1 / OUTPUT %1.
    let s20: EmitState = emit_mic3_const_i64(s19, 1, 0);
    let s21: EmitState = emit_mic3_output(s20, 1);
    // FN_DEF use_it(p=%0) ret %(1+nargs), body = PARAM %0 p, CONST args, CALL.
    let ret_vid: i64 = 1 + nargs;
    let body_len: i64 = 2 + nargs;
    let s22: EmitState = es_push(s21, 21);
    let s23: EmitState = emit_uleb128(s22, i_fn1);
    let s24: EmitState = emit_uleb128(s23, 1);
    let s25: EmitState = emit_uleb128(s24, i_p1);
    let s26: EmitState = emit_uleb128(s25, 0);
    let s27: EmitState = emit_mic3_opt_vid(s26, 1, ret_vid);
    let s28: EmitState = es_push(s27, 0);
    let s29: EmitState = emit_uleb128(s28, body_len);
    let s30: EmitState = emit_mic3_param(s29, 0, i_p1, 0);
    let s31: EmitState = emit_mic3_method_arg_consts(s30, valbuf, nargs, 1, 0);
    let s32: EmitState = emit_mic3_calln(s31, ret_vid, i_callee, argbuf, nargs + 1);
    // fn1 module-level scaffold pair CONST %2 / OUTPUT %2.
    let s33: EmitState = emit_mic3_const_i64(s32, 2, 0);
    let s34: EmitState = emit_mic3_output(s33, 2);
    // struct_defs registry: Point=[fields], const_array_defs=0, repr_c_structs=0.
    let s35: EmitState = emit_uleb128(s34, 1);
    let s36: EmitState = emit_uleb128(s35, i_ty);
    let s37: EmitState = emit_uleb128(s36, fc);
    let s38: EmitState = ffa_emit_field_idxs(s37, i_f0, fc, 0);
    let s39: EmitState = emit_uleb128(s38, 0);
    emit_uleb128(s39, 0)
}

// Build the CALL arg-vid list for the caller: argbuf[0] = receiver vid (%0), then
// argbuf[1..nargs+1] = the const-arg vids %1..%nargs (matching the emit order of
// emit_mic3_method_arg_consts). Returns nargs+1 (the total arg count).
pub fn mc_build_call_arg_vids(argbuf: i64, nargs: i64) -> i64 {
    __mind_store_i64(argbuf + 0, 0);
    let _r: i64 = mc_fill_const_arg_vids(argbuf, nargs, 0);
    nargs + 1
}

pub fn mc_fill_const_arg_vids(argbuf: i64, nargs: i64, i: i64) -> i64 {
    if i >= nargs {
        return i;
    }
    __mind_store_i64(argbuf + (i + 1) * 8, i + 1);
    mc_fill_const_arg_vids(argbuf, nargs, i + 1)
}

pub fn selftest_mic3_module_method_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    emit_mic3_method_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell, cbuf, argbuf, valbuf)
}

// ===========================================================================
// UNIFIED AST-driven mic@3 module dispatcher (Strategy A — cutover prep)
// ===========================================================================
//
// A SINGLE entry that, given only the source bytes, detects which construct
// class the module uses and routes to the correct ALREADY-PROVEN driver. This
// is a pure DISPATCHER over the three byte-verified emitters — NO new lowering,
// NO canary touch (mindc_compile / emit_fn_def / emit_expr_env are untouched, so
// the fixed point stays byte-identical; Bound by MIND-CONSTITUTION §I).
//
// Detection (token + struct-table driven):
//   1. Build the part-1 struct field table. If no struct is present
//      (sft_table_count < 1) the body uses only const/binop/let/call/if shapes ->
//      the AST-flatten N-function driver (selftest_mic3_module_from_ast).
//   2. A struct IS present -> scan the token stream for the first field-access
//      dot (ffa_find_dot). The receiver is at dot-1, the accessed ident at dot+1.
//      - If the token AFTER the accessed ident (dot+2) is `(`, it is a METHOD
//        call `recv.method(args)` -> the UFCS method driver
//        (emit_mic3_method_module_from_ast).
//      - Otherwise it is a plain FIELD read `recv.field` -> the field driver
//        (emit_mic3_field_module_from_ast).
//      - No dot at all (struct declared but unused in a body) falls back to the
//        N-function driver (defensive; the field/method drivers would fail-closed).
// Each routed driver already fails closed (returns an empty buf) on any shape it
// does not recognize, so the dispatcher inherits that fail-closed contract.
//
// The signature is the UNION of the three drivers' params: the method driver
// needs the extra cbuf / argbuf / valbuf scratch; the field and N-fn drivers
// ignore them.
pub fn selftest_mic3_module_unified_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    if sft_table_count(sft) < 1 {
        return selftest_mic3_module_from_ast(src, src_len, strbuf, offs, ccell);
    }
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 0 {
        return selftest_mic3_module_from_ast(src, src_len, strbuf, offs, ccell);
    }
    if tok_kind(tokens, dot + 2) == tk_lparen() {
        return emit_mic3_method_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell, cbuf, argbuf, valbuf);
    }
    emit_mic3_field_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// Phase 5c — AST-DRIVEN full-module COLLECTION PASS (the hand-feeding removal)
// ===========================================================================
//
// Phases 5a/5b proved the two multi-function module assemblers
// (emit_mic3_const_fn2_module / emit_mic3_const_arith_module) reproduce the
// 50-byte and 68-byte Rust --emit-mic3 oracles byte-for-byte — but with the
// string table / offsets / const-values / op-byte HAND-FED by the test harness.
// Phase 5c removes the hand-feeding: a pure-MIND COLLECTION PASS that, given
// only the parsed multi-function AST, automatically (a) builds the deduped
// FIRST-SEEN-traversal contiguous string table + offsets array, and (b)
// extracts the const-body values / arith op-byte from the live AST node
// descriptors, then drives the proven assemblers. The result: a whole small
// `.mind` source lowers to a complete mic@3 module with ZERO hand-fed offsets,
// byte-identical to the Rust oracle (Bound by MIND-CONSTITUTION §I).
//
// The string collection mirrors Rust collect_strings / collect_instr_strings
// (src/ir/compact/v3/emit.rs ~492-586) EXACTLY: for each top-level FnDef in
// sequence, intern fn name -> each param name -> recurse body strings (for the
// const / param-arith body shapes here the body carries no strings — int
// literals and binops intern nothing; param idents are resolved positionally,
// not by name interning). StringTable::intern is idempotent (first-seen dedup),
// mirrored by intern_span's span-equality scan over already-interned entries.
//
// ADDITIVE / canary-isolated: exported only via selftest_mic3_module_from_ast;
// the canary mindc_compile / emit_fn_def mic@1 path is untouched, so the
// fixed point stays byte-identical. The actual cutover (routing mindc_compile
// through this pass) is a SEPARATE, deliberately-reviewed step.
//
// SCOPE: the two proven module shapes — (1) two zero-arg const-return fns, and
// (2) a zero-arg const-return fn0 + a 2-param single-binop arith fn1. Any other
// shape returns the seed state unchanged (fail-closed, no partial bytes).

// Append the source span src[lo..hi) to the contiguous string buffer `strbuf`,
// deduping against the strings already interned (first-seen, idempotent — mirrors
// Rust StringTable::intern). `offs` is the offset array (offs[k] = start of
// string k; offs[count] = current write cursor / end of last string). `ccell`
// is a 1-i64 cell holding the live interned-string count. Returns the string
// index (existing on a dedup hit, or the freshly allocated index). Single bytes
// are written with __mind_store_i8 so the buffer is byte-contiguous, exactly as
// emit_mic3_strtab/emit_mic3_lp_bytes expect.
pub fn intern_span(strbuf: i64, offs: i64, ccell: i64, src: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let hit: i64 = intern_find(strbuf, offs, n, src, lo, hi, 0);
    if hit >= 0 {
        return hit;
    }
    let start: i64 = __mind_load_i64(offs + n * 8);
    let end: i64 = intern_copy(strbuf, start, src, lo, hi);
    __mind_store_i64(offs + (n + 1) * 8, end);
    __mind_store_i64(ccell, n + 1);
    n
}

// Scan the n already-interned strings for one whose bytes equal src[lo..hi);
// return its index or -1. Mirrors StringTable dedup (span_bytes_equal compares
// raw bytes — no hashing, so no collision risk).
pub fn intern_find(strbuf: i64, offs: i64, n: i64, src: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(offs + i * 8);
    let ehi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if span_bytes_equal2(src, lo, hi, strbuf, elo, ehi) == 1 {
        return i;
    }
    intern_find(strbuf, offs, n, src, lo, hi, i + 1)
}

// Copy src[lo..hi) into strbuf starting at `dst`; return the new write cursor.
pub fn intern_copy(strbuf: i64, dst: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return dst;
    }
    __mind_store_i8(strbuf + dst, load_byte(src, lo));
    intern_copy(strbuf, dst + 1, src, lo + 1, hi)
}

// Intern one fn_def's strings in Rust collect_strings order: fn name first,
// then each param name. Body strings (int literals, binops, param-ident leaves)
// intern nothing for the const / param-arith shapes, mirroring the oracle.
pub fn collect_fn_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, fn_node: i64) -> i64 {
    let name_leaf: i64 = ast_child0(fn_node);
    let n0: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let rp: i64 = collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, 0);
    // Recurse the body in statement order, interning any CALL callee names — the
    // Rust collect_instr_strings(Instr::Call) interns the call name during the
    // body traversal (verified: a forward call interns the callee BEFORE the
    // callee fn's own params). Const/int/binop/param/ident bodies intern nothing.
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, 0)
}

// Intern call-callee names appearing in a fn body, in statement+expression order,
// mirroring Rust collect_strings -> collect_instr_strings recursion. Only the
// constructs the AST-driven path emits are walked (let-init, call); other leaves
// intern nothing. Idempotent via intern_span's first-seen dedup.
pub fn collect_body_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, stmt);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

pub fn collect_expr_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child2(node));
    }
    if k == ast_call() {
        // Intern the callee name (call lowers to Instr::Call whose name interns).
        let callee: i64 = ast_child0(node);
        let nm: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(callee), ast_span_hi(callee));
        // Then recurse args left-to-right (their own const lowerings precede the
        // Call instr; int-literal args intern nothing, matching the oracle).
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        return collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, 0);
    }
    if k == ast_binop() {
        let rl: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child1(node));
    }
    if k == ast_field() {
        // FieldAccess lowers (src/eval/lower.rs ast::Node::FieldAccess resolved arm)
        // to: receiver instrs, optional CONST(idx*8), optional BINOP Add, then
        // Call("__mind_load_i64", [addr]). Mirror the Rust collect order: recurse
        // the receiver first (its own Call names, if any, intern before this one),
        // then intern the synthetic load-call name. CONST/BINOP intern nothing.
        let rr: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        return intern_load_i64_name(strbuf, offs, ccell);
    }
    if k == ast_if() {
        // Recurse cond -> then-block stmts -> else-block stmts, in SOURCE order, so
        // call names (and field-loads) inside an if-body intern at their oracle
        // first-seen position. Byte-identical for if-bodies that carry no strings
        // (constants/params); enables fns whose if-returns call other fns (e.g.
        // classify_ident's `return tk_kw_fn()`). Then intern the then-block's leading
        // `let` NAMES (the OP_IF branch_bindings) — AFTER all cond/then/else strings,
        // mirroring Rust collect_instr_strings (branch_bindings interned last). A let
        // that escapes the then-block as a merge binds its name into the strtab; the
        // 2-let oracle decode confirmed source order (x before y), branch-bindings-last
        // (a call after the let interns BEFORE the let name). No-let blocks: no-op.
        let rc: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        let then_blk: i64 = ast_child1(node);
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        let rt: i64 = collect_block_strings(strbuf, offs, ccell, src, then_sa, then_sl, 0);
        let else_blk: i64 = ast_child2(node);
        if else_blk != 0 {
            let re: i64 = collect_block_strings(strbuf, offs, ccell, src, ast_child0(else_blk), ast_aux(else_blk), 0);
        }
        return intern_leading_let_names(strbuf, offs, ccell, src, then_sa, then_sl, 0);
    }
    if k == ast_return() {
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
    }
    0
}

// Collect strings from a block's statements in source order (each stmt via
// collect_expr_strings: a let recurses its init, an if recurses cond/then/else,
// a return its value). Used by the ast_if arm to walk if-body sub-statements.
pub fn collect_block_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, stmt);
    collect_block_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

// Intern the NAMES of the leading `let` statements of a then-block (its OP_IF
// branch_bindings), in source order. Stops at the first non-let (bounded
// recursion). Called by the ast_if arm AFTER the cond/then/else strings, matching
// Rust collect_instr_strings's branch_bindings-last interning. No-op (byte-
// identical) for then-blocks with no leading lets.
pub fn intern_leading_let_names(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return 0;
    }
    let name: i64 = ast_child0(stmt);
    let ni: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name), ast_span_hi(name));
    intern_leading_let_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

pub fn collect_args_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, args_addr: i64, args_len: i64, i: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, arg);
    collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, i + 1)
}

pub fn collect_param_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, params_addr: i64, n_params: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let idx: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, i + 1)
}

// Walk the top-level item list and collect every fn_def's strings in sequence —
// the module-wide first-seen traversal order Rust collect_strings produces.
pub fn build_module_strtab(strbuf: i64, offs: i64, ccell: i64, src: i64, items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let r: i64 = collect_fn_strings(strbuf, offs, ccell, src, item);
        return build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1);
    }
    build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1)
}

// Extract the i64 value a zero-arg const-return fn returns: its body's trailing
// statement must be an int literal. Returns the literal, or -1 if the body is
// not a single int-literal return (fail-closed shape guard).
pub fn const_fn_value(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    if ast_kind(expr) != ast_int_lit() {
        return 0 - 1;
    }
    parse_int_span(src, ast_span_lo(expr), ast_span_hi(expr), 0)
}

// Extract the mic@3 op-byte of a 2-param single-binop arith fn (body = one
// `pa OP pb` binop whose leaves are the two params, in order). Returns the
// op-byte, or -1 if the shape does not match (fail-closed).
pub fn arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(expr);
    let r: i64 = ast_child1(expr);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(expr))
}

// Extract the mic@3 op-byte of a 2-param arith fn whose body is written as a
// LET binding then a use of it: `{ let t: i64 = pa OP pb; t }`. The Rust lowering
// produces a body BYTE-IDENTICAL to the direct `{ pa OP pb }` form — the let-bound
// value simply takes the binop's vid (%2) and the trailing `t` resolves to it, so
// no distinct opcode and no extra string is emitted (verified vs --emit-mic3 on
// `f(a,b){let t=a+b; t}` == `f(a,b){a+b}`). Returns the op-byte, or -1 on shape
// mismatch (fail-closed). Two body stmts required: a let with a 2-ident binop init,
// then a trailing ident referencing the let name.
pub fn let_arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 2 {
        return 0 - 1;
    }
    let s0: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(s0) != ast_let() {
        return 0 - 1;
    }
    let s1: i64 = __mind_load_i64(stmts_addr + 8);
    if ast_kind(s1) != ast_ident() {
        return 0 - 1;
    }
    // The trailing use must name the let-bound variable.
    let let_name: i64 = ast_child0(s0);
    if span_bytes_equal2(src, ast_span_lo(s1), ast_span_hi(s1), src, ast_span_lo(let_name), ast_span_hi(let_name)) != 1 {
        return 0 - 1;
    }
    let init: i64 = ast_child2(s0);
    if ast_kind(init) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(init);
    let r: i64 = ast_child1(init);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(init))
}

// Extract the two int-literal argument values of a zero-arg fn whose body is a
// single call with exactly two int-literal arguments: `{ callee(<v0>, <v1>) }`.
// Writes v0 -> out[0], v1 -> out[1] and returns 1 on a match, 0 otherwise
// (fail-closed). The callee name is resolved separately to its string index.
pub fn call_fn_args2(src: i64, fn_node: i64, out: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_call() {
        return 0;
    }
    if ast_aux(expr) != 2 {
        return 0;
    }
    let args_addr: i64 = ast_child1(expr);
    let a0: i64 = __mind_load_i64(args_addr);
    let a1: i64 = __mind_load_i64(args_addr + 8);
    if ast_kind(a0) != ast_int_lit() {
        return 0;
    }
    if ast_kind(a1) != ast_int_lit() {
        return 0;
    }
    let v0: i64 = parse_int_span(src, ast_span_lo(a0), ast_span_hi(a0), 0);
    let v1: i64 = parse_int_span(src, ast_span_lo(a1), ast_span_hi(a1), 0);
    __mind_store_i64(out + 0, v0);
    __mind_store_i64(out + 8, v1);
    1
}

// Resolve the string index of a zero-arg call-fn's callee name within the already
// built string table (offs/n hold the interned strings). Returns the index, or -1.
pub fn call_fn_callee_idx(src: i64, fn_node: i64, strbuf: i64, offs: i64, n_strings: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let expr: i64 = __mind_load_i64(stmts_addr);
    let callee: i64 = ast_child0(expr);
    intern_find(strbuf, offs, n_strings, src, ast_span_lo(callee), ast_span_hi(callee), 0)
}

// AST-DRIVEN full-module driver: lex+parse `src`, build the deduped first-seen
// string table into caller-supplied scratch (strbuf/offs/ccell), detect which of
// the two proven module shapes the source is, extract its const values / op-byte
// from the live AST, and emit the complete mic@3 module byte-exact vs the Rust
// --emit-mic3 oracle — with ZERO hand-fed offsets. Fails closed (returns es_new()
// unchanged, empty buf) on any other shape, so the harness can detect non-emission.
//
//   strbuf : contiguous byte buffer for the string table (>= total name bytes + 8)
//   offs   : offset array ((n_strings + 1) i64s; offs[0] must be pre-zeroed)
//   ccell  : 1-i64 interned-count cell (pre-zeroed)
pub fn selftest_mic3_module_from_ast(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Build the string table from the live AST (the hand-feeding removal).
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    // Require exactly two top-level fn_defs.
    let f0: i64 = nth_fn_def(items_addr, items_len, 0);
    let f1: i64 = nth_fn_def(items_addr, items_len, 1);
    let f2: i64 = nth_fn_def(items_addr, items_len, 2);
    if f0 == 0 {
        return es_new();
    }
    if f1 == 0 {
        return es_new();
    }
    if f2 != 0 {
        return es_new();
    }
    // Shape (1): two zero-arg const-return fns.
    let v0: i64 = const_fn_value(src_addr, f0);
    if v0 >= 0 {
        let v1: i64 = const_fn_value(src_addr, f1);
        if v1 >= 0 {
            return emit_mic3_const_fn2_module(es_new(), strbuf, offs, v0, v1);
        }
        // Shape (2): const-return fn0 + 2-param arith fn1.
        let ob: i64 = arith_fn_opbyte(src_addr, f1);
        if ob >= 0 {
            return emit_mic3_const_arith_module(es_new(), strbuf, offs, v0, ob);
        }
    }
    // fn0 = a 2-param arith fn (direct `pa OP pb`, or `let t=pa OP pb; t`).
    let ob0_direct: i64 = arith_fn_opbyte(src_addr, f0);
    let ob0_let: i64 = let_arith_fn_opbyte(src_addr, f0);
    let ob0: i64 = if ob0_direct >= 0 {
        ob0_direct
    } else {
        ob0_let
    };
    if ob0 >= 0 {
        // Shape (3): arith fn0 + const fn1 (the LET-body ordering — arith first).
        let cv1: i64 = const_fn_value(src_addr, f1);
        if cv1 >= 0 {
            return emit_mic3_arith_const_module(es_new(), strbuf, offs, ob0, cv1);
        }
        // Shape (4): arith fn0 + const-args CALL fn1.
        let scratch: i64 = __mind_alloc(16);
        let ok: i64 = call_fn_args2(src_addr, f1, scratch);
        if ok == 1 {
            let ncount: i64 = __mind_load_i64(ccell);
            let cidx: i64 = call_fn_callee_idx(src_addr, f1, strbuf, offs, ncount);
            if cidx >= 0 {
                let cva: i64 = __mind_load_i64(scratch + 0);
                let cvb: i64 = __mind_load_i64(scratch + 8);
                return emit_mic3_arith_call_module(es_new(), strbuf, offs, ob0, cidx, cva, cvb);
            }
        }
    }
    es_new()
}

// Return the j-th top-level fn_def node (0-based), or 0 if fewer than j+1 exist.
pub fn nth_fn_def(items_addr: i64, items_len: i64, j: i64) -> i64 {
    nth_fn_def_loop(items_addr, items_len, j, 0, 0)
}
pub fn nth_fn_def_loop(items_addr: i64, items_len: i64, j: i64, seen: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        if seen == j {
            return item;
        }
        return nth_fn_def_loop(items_addr, items_len, j, seen + 1, i + 1);
    }
    nth_fn_def_loop(items_addr, items_len, j, seen, i + 1)
}

// Count the top-level fn_defs in the item list.
pub fn count_fn_defs(items_addr: i64, items_len: i64, i: i64, acc: i64) -> i64 {
    if i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        return count_fn_defs(items_addr, items_len, i + 1, acc + 1);
    }
    count_fn_defs(items_addr, items_len, i + 1, acc)
}

// ===========================================================================
// Phase 5d — N-FUNCTION mic@3 module assembly (Strategy A increment 5)
// ===========================================================================
//
// Generalizes the fixed 2-function module driver to an ARBITRARY function count
// (3, 4, .. N). Verified vs the Rust --emit-mic3 oracle, the module is a flat
// sequence (decoded from 3-fn / 4-fn / mixed oracles):
//   header || strtab(N+ in first-seen order) || next_id(=N) || exports(0) ||
//   uleb(instr_count = 3*N) ||
//   [ per fn k (0-based) : FN_DEF{body} || ConstI64(%k, 0) || Output(%k) ]*N ||
//   3 empty registries.
// The four module-wide invariants the 2-fn path already verifies are preserved
// for all N: (1) ONE union string table in first-seen TRAVERSAL order across all
// N fns (build_module_strtab is already N-general); (2) ONE flat next_id = N
// threaded across the N scaffold ConstI64/Output pairs (scaffold vid == the fn
// index k); (3) ONE flat top-level instr count = 3*N; (4) registries trailing.
// Each FN_DEF body keeps its OWN vid space (params %0.., binop/call vids follow),
// exactly as the per-shape 2-fn emitters do — only the module-level scaffold
// threads the flat counter. ADDITIVE: exported via selftest_mic3_module_nfn only,
// the canary mindc_compile / emit_fn_def mic@1 path is untouched (Bound by
// MIND-CONSTITUTION §I — fixed point byte-identical).
//
// SCOPE: each fn must be one of the four proven body shapes — (a) zero-arg
// const-return, (b) 2-param single-binop arith (direct `pa OP pb` or the
// byte-identical `let t = pa OP pb; t`), (c) zero-arg CALL with two int-literal
// args. Any fn outside these shapes makes the whole module fail closed (es_new(),
// empty buf) so the harness detects non-emission — no partial bytes.

// Emit the FN_DEF for a zero-arg const-return fn: name_idx, ret %0, body =
// [ConstI64(%0, const_val)].
pub fn emit_mic3_fndef_const(s: EmitState, name_idx: i64, const_val: i64) -> EmitState {
    let s1: EmitState = emit_mic3_fn_def_header(s, name_idx, 1, 0, 1);
    emit_mic3_const_i64(s1, 0, const_val)
}

// Emit the FN_DEF for a 2-param single-binop arith fn: name_idx, params str
// (p0_str,%0)/(p1_str,%1), ret %2, body = [PARAM %0, PARAM %1, BINOP %2=%0 op %1].
pub fn emit_mic3_fndef_arith(s: EmitState, name_idx: i64, p0_str: i64, p1_str: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, p0_str);
    let s5: EmitState = emit_uleb128(s4, 0);
    let s6: EmitState = emit_uleb128(s5, p1_str);
    let s7: EmitState = emit_uleb128(s6, 1);
    let s8: EmitState = emit_mic3_opt_vid(s7, 1, 2);
    let s9: EmitState = es_push(s8, 0);
    let s10: EmitState = emit_uleb128(s9, 3);
    let s11: EmitState = emit_mic3_param(s10, 0, p0_str, 0);
    let s12: EmitState = emit_mic3_param(s11, 1, p1_str, 1);
    emit_mic3_binop(s12, 2, op_byte, 0, 1)
}

// Emit the FN_DEF for a zero-arg fn whose body is a CALL to `callee_idx` with two
// int-literal args: name_idx, ret %2, body = [ConstI64 %0=v0, ConstI64 %1=v1,
// CALL %2 = callee(%0,%1)].
pub fn emit_mic3_fndef_call(s: EmitState, name_idx: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 0);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, 2);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, 3);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 1, v1);
    emit_mic3_call2(s8, 2, callee_idx, 0, 1)
}

// Module-level scaffold for fn k: ConstI64(%k, 0) || Output(%k). The flat next_id
// counter is realized by passing the fn's own index k.
pub fn emit_mic3_scaffold(s: EmitState, k: i64) -> EmitState {
    let s1: EmitState = emit_mic3_const_i64(s, k, 0);
    emit_mic3_output(s1, k)
}

// Resolve a 2-param arith fn's two param-name string indices into out[0]/out[1]
// (the FN_DEF param list and body PARAM instrs reference them). Returns 1 on a
// 2-param fn, 0 otherwise (fail-closed).
pub fn arith_param_str_idxs(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, out: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0;
    }
    let params_addr: i64 = ast_child1(fn_node);
    let p0: i64 = __mind_load_i64(params_addr + 0);
    let p1: i64 = __mind_load_i64(params_addr + 8);
    let n0_leaf: i64 = ast_child0(p0);
    let n1_leaf: i64 = ast_child0(p1);
    let i0: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(n0_leaf), ast_span_hi(n0_leaf), 0);
    let i1: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(n1_leaf), ast_span_hi(n1_leaf), 0);
    if i0 < 0 {
        return 0;
    }
    if i1 < 0 {
        return 0;
    }
    __mind_store_i64(out + 0, i0);
    __mind_store_i64(out + 8, i1);
    1
}

// Resolve a fn's own name string index in the already-built string table.
pub fn fn_name_idx(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64) -> i64 {
    let name_leaf: i64 = ast_child0(fn_node);
    intern_find(strbuf, offs, ncount, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf), 0)
}

// ===========================================================================
// Strategy A increment 6 — ARBITRARY expression-tree / if bodies in the N-fn
// module path. WIRING (not new lowering): each fn's FN_DEF body dispatches to
// the already-proven 4f tree emitter (emit_mic3_tree_body) or the 4j OP_IF body
// emitter (emit_mic3_if_instr). The only module-specific concern is the FN_DEF
// param list / body PARAM instrs, which must use the MODULE-WIDE union string
// indices (not the fresh-table `i+1` the standalone single-fn drivers hardcode).
// ADDITIVE: the canary mindc_compile / emit_fn_def mic@1 path is untouched, and
// the existing a/b/c shape branches in emit_mic3_module_fndef stay byte-identical
// (Bound by MIND-CONSTITUTION §I — fixed point byte-identical).
// ===========================================================================

// Resolve every param of `fn_node` to its MODULE string index, writing out[i] for
// i in 0..n_params. Returns 1 on success, 0 if any param name is not interned
// (fail-closed). Generalizes arith_param_str_idxs to an arbitrary param count.
pub fn module_param_str_idxs(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, out: i64, i: i64) -> i64 {
    let n_params: i64 = ast_aux(fn_node) / 2;
    if i >= n_params {
        return 1;
    }
    let params_addr: i64 = ast_child1(fn_node);
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let idx: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf), 0);
    if idx < 0 {
        return 0;
    }
    __mind_store_i64(out + i * 8, idx);
    module_param_str_idxs(src, fn_node, strbuf, offs, ncount, out, i + 1)
}

// FN_DEF param-pair list using MODULE string indices: uleb(n) || (pstr[i], %i)*n.
// Mirrors emit_mic3_chain_param_pairs but reads the resolved module string idx
// from `pstr` instead of assuming the fresh-table `i+1`.
pub fn emit_mic3_param_pairs_mod(s: EmitState, pstr: i64, n: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, n);
    emit_mic3_param_pairs_mod_loop(s1, pstr, n, 0)
}
pub fn emit_mic3_param_pairs_mod_loop(s: EmitState, pstr: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(pstr + i * 8));
    let s2: EmitState = emit_uleb128(s1, i);
    emit_mic3_param_pairs_mod_loop(s2, pstr, n, i + 1)
}

// Body PARAM instrs using MODULE string indices: PARAM(%i, pstr[i], index=i).
// Mirrors emit_mic3_chain_params but reads the resolved module string idx.
pub fn emit_mic3_params_mod(s: EmitState, pstr: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, i, __mind_load_i64(pstr + i * 8), i);
    emit_mic3_params_mod(s1, pstr, n, i + 1)
}

// Emit ONE fn's FN_DEF whose body is an arbitrary param/const/binop expression
// tree, using module string indices. Returns the post-FN_DEF state; writes 1 to
// ok_cell on success, 0 (fail-closed, returns seed `s`) on a non-tree body. This
// is the FN_DEF-only counterpart of emit_mic3_tree_fn_module (no header/scaffold/
// registries — the caller frames the module).
pub fn emit_mic3_module_fndef_tree(s: EmitState, src: i64, strbuf: i64, offs: i64, ncount: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, expr: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast(expr, src, params_addr, n_params, nodes, cursor);
    if root_slot < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    let root_vid: i64 = tree_resolve_vids(nodes, n_nodes, n_params, vidbuf, 0, n_params);
    // body_len = n_params PARAM instrs + the non-param nodes (CONST leaves + BINOPs).
    // n_nodes over-counts when a param appears more than once (each occurrence is a
    // descriptor node but emits NO instr — emit_mic3_params_mod writes ONE PARAM per
    // distinct param, tree_body skips every param leaf), so derive body_len from the
    // non-param count, mirroring the Rust oracle's de-duplicated PARAM emission.
    let nonparam: i64 = count_nonparam_nodes(expr, src, params_addr, n_params);
    if nonparam < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let body_len: i64 = n_params + nonparam;
    // FN_DEF: name || param-pairs(module idx) || ret Some %root || reap None ||
    // body_len || body PARAMs(module idx) || tree body.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, root_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_tree_body(s7, nodes, n_nodes, vidbuf, src, strbuf, offs, ncount, 0);
    __mind_store_i64(ok_cell, 1);
    s8
}

// Emit ONE fn's FN_DEF whose body is a single `if cond { then } else { else }`
// value (single-expression branches, empty branch-bindings + merges), using
// module string indices. Returns the post-FN_DEF state; writes 1 to ok_cell on
// success, 0 (fail-closed, returns seed `s`) on any wall. FN_DEF-only counterpart
// of emit_mic3_if_fn_module — body is n PARAM instrs then one OP_IF (body_len =
// n + 1), ret_vid = the if's dst.
pub fn emit_mic3_module_fndef_if(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, cond_expr: i64, then_expr: i64, else_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    // Emit the OP_IF into a SCRATCH state first to learn dst (the ret_vid).
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_mic3_if_instr(es_new(), cond_expr, then_expr, else_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, dst);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, n_params + 1);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s8: EmitState = emit_mic3_if_instr(s7, cond_expr, then_expr, else_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    __mind_store_i64(ok_cell, 1);
    s8
}

// ===========================================================================
// IF-STATEMENT early-return — the final cutover construct
// ===========================================================================
//
// A body `{ if cond { return E; } TRAIL }` (two statements: an else-less if whose
// then-block's only statement is `return E`, then a trailing value expr TRAIL).
// Decoded byte-for-byte from --emit-mic3 (`pub fn s(b){ if b==1 { return 1; } 0 }`):
// the if lowers to ONE OP_IF whose then-block carries the synth const, the return
// value's tree, and a Return(then_root) instr; the else-block (empty) carries only
// the synth const; branch_bindings + merges are both empty; dst is the next free
// vid. The trailing expr is then lowered AFTER the OP_IF, and the FN_DEF ret_vid is
// the TRAILING expr's root vid (NOT dst). This path is ISOLATED from the canary —
// reached only via case (g) in emit_mic3_module_fndef (flatten_ast still rejects
// ast_if at the expression level, so the fixed point stays byte-identical; Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Emit the OP_IF body instruction for an else-less if whose then-block is a single
// `return E`. cond / E are each a param/const/binop tree. then-block = synth const
// + E's tree + Return(E_root); else-block = synth const only (empty else_result =
// the else synth vid). branch_bindings + merges empty. Writes dst to `okcell` on
// success (-1 on a wall). `base0` is the starting vid counter (= n_params).
pub fn emit_mic3_if_stmt_instr(s: EmitState, cond_expr: i64, ret_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    // --- cond ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then: synth ConstI64(after_cond, 0), the return expr tree, Return(root) ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(ret_expr, buf, params_addr, n_params);
    // then_instrs.len = synth(1) + ret-expr non-param instrs + the Return instr(1).
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 2);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_mic3_return(s7, 1, then_root);
    // then_result is the RETURNED value vid (not the Return instr).
    let s9: EmitState = emit_uleb128(s8, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else (EMPTY): just the synth ConstI64(after_then, 0); else_result = synth ---
    let else_synth: i64 = after_then;
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    let after_else: i64 = after_then + 1;

    // --- dst (the if's value) + empty branch_bindings + empty merges ---
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// Emit ONE fn's FN_DEF whose body is `{ if cond { return E; } TRAIL }`, using
// module string indices. Body = n PARAM instrs + the OP_IF + the TRAIL expr tree;
// FN_DEF ret_vid = TRAIL's root vid (the trailing expr is lowered AFTER the OP_IF,
// its non-param vids starting at dst+1). Writes 1 to ok_cell on success, 0
// (fail-closed, returns seed `s`) on any wall.
pub fn emit_mic3_module_fndef_ifstmt(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, cond_expr: i64, ret_expr: i64, trail_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, t_nodes: i64, t_cursor: i64, t_vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    // Emit the OP_IF into a SCRATCH state first to learn dst (the trailing base-1).
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_mic3_if_stmt_instr(es_new(), cond_expr, ret_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    // Trailing expr: its non-param vids start at dst + 1 (the next free vid after
    // the OP_IF). Resolve its root vid (= FN_DEF ret) and node count.
    let trail_root: i64 = flatten_branch(trail_expr, src, params_addr, n_params, t_nodes, t_cursor, t_vidbuf, dst + 1);
    if trail_root < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_n: i64 = __mind_load_i64(t_cursor);
    let trail_nonparam: i64 = count_nonparam_nodes(trail_expr, src, params_addr, n_params);
    // body_len = n PARAM instrs + 1 OP_IF + the trailing expr's non-param instrs.
    let body_len: i64 = n_params + 1 + trail_nonparam;
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, trail_root);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s8: EmitState = emit_mic3_if_stmt_instr(s7, cond_expr, ret_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let s9: EmitState = emit_mic3_tree_body(s8, t_nodes, trail_n, t_vidbuf, 0, 0, 0, 0, 0);
    __mind_store_i64(ok_cell, 1);
    s9
}

// Recursively emit an OP_IF chain `if c1 { if c2 { ... if cN { return E } } }` — each
// else-less, then-block = a SINGLE stmt that is either the next nested if or the
// terminal `return E`. Subsumes the depth-1 (flat) + depth-2 cases at ARBITRARY depth.
// Byte-exact vs --emit-mic3 (vid layout verified vs the depth-3 decode, 115B ret_vid=17).
// base0 = starting vid; writes the OP_IF dst to okcell (-1 on a wall).
pub fn emit_if_chain_instr(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let inner: i64 = branch_single_expr(then_blk);
    if inner < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // base case: then-block is `return E`.
    if ast_kind(inner) == ast_return() {
        let ret_expr: i64 = ast_child0(inner);
        let then_root: i64 = flatten_branch(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
        if then_root < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let then_n: i64 = __mind_load_i64(cursor);
        let then_nonparam: i64 = count_nonparam_nodes(ret_expr, buf, params_addr, n_params);
        let s5: EmitState = emit_uleb128(s4, then_nonparam + 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
        let s8: EmitState = emit_mic3_return(s7, 1, then_root);
        let s9: EmitState = emit_uleb128(s8, then_root);
        let after_then: i64 = after_cond + 1 + then_nonparam;
        let else_synth: i64 = after_then;
        let s10: EmitState = emit_uleb128(s9, 1);
        let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
        let s12: EmitState = emit_uleb128(s11, else_synth);
        let dst: i64 = after_then + 1;
        let s13: EmitState = emit_uleb128(s12, dst);
        let s14: EmitState = emit_uleb128(s13, 0);
        let s15: EmitState = emit_uleb128(s14, 0);
        __mind_store_i64(okcell, dst);
        return s15;
    }
    // recursive case: then-block is the next nested if.
    if ast_kind(inner) == ast_if() {
        let s5: EmitState = emit_uleb128(s4, 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let inner_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_cell, 0 - 1);
        let s7: EmitState = emit_if_chain_instr(s6, inner, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, inner_cell);
        let inner_dst: i64 = __mind_load_i64(inner_cell);
        if inner_dst < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let s8: EmitState = emit_uleb128(s7, inner_dst);
        let else_synth: i64 = inner_dst + 1;
        let s9: EmitState = emit_uleb128(s8, 1);
        let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
        let s11: EmitState = emit_uleb128(s10, else_synth);
        let dst: i64 = inner_dst + 2;
        let s12: EmitState = emit_uleb128(s11, dst);
        let s13: EmitState = emit_uleb128(s12, 0);
        let s14: EmitState = emit_uleb128(s13, 0);
        __mind_store_i64(okcell, dst);
        return s14;
    }
    __mind_store_i64(okcell, 0 - 1);
    s
}

// Emit a SEQUENCE of if-segments (the then-block of a type-3 if), each an
// arbitrary-depth nested if-return chain, threading the running vid base. Returns
// the post-emit EmitState; writes the LAST segment's dst (the sequence's value vid)
// to `dst_cell`, or -1 on any wall. Each segment is one top-level OP_IF instr,
// emitted by emit_if_chain_instr (which self-flattens its cond/ret trees into the
// shared scratch via flatten_branch — cursor-resetting, so segments are isolated).
pub fn emit_if_seq_segments(s: EmitState, stmts_addr: i64, stmts_len: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, last_dst: i64, dst_cell: i64, i: i64) -> EmitState {
    if i >= stmts_len {
        __mind_store_i64(dst_cell, last_dst);
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    let seg_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seg_cell, 0 - 1);
    let s1: EmitState = emit_if_chain_instr(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, seg_cell);
    let seg_dst: i64 = __mind_load_i64(seg_cell);
    if seg_dst < 0 {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    emit_if_seq_segments(s1, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_dst + 1, seg_dst, dst_cell, i + 1)
}

// Emit the OP_IF body instruction for a type-3 if: an else-less `if COND { <SEQ of
// if-return / nested-if-chain statements, NO lets, NO trailing value> }`. The
// then-block is a sequence of if-segments emitted in order, each one top-level
// OP_IF; the then-result is the LAST segment's dst (the block falls through to the
// next outer statement). Mirrors emit_if_chain_instr's outer framing but with a
// multi-segment then-branch. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_if_seq_then_instr(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    if stmts_len < 2 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // then_len = leading synth + 1 OP_IF per then-segment.
    let s5: EmitState = emit_uleb128(s4, stmts_len + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let s7: EmitState = emit_if_seq_segments(s6, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, after_cond, seq_cell, 0);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // then-result = last segment dst.
    let s8: EmitState = emit_uleb128(s7, last_dst);
    let else_synth: i64 = last_dst + 1;
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_uleb128(s10, else_synth);
    let dst: i64 = last_dst + 2;
    let s12: EmitState = emit_uleb128(s11, dst);
    let s13: EmitState = emit_uleb128(s12, 0);
    let s14: EmitState = emit_uleb128(s13, 0);
    __mind_store_i64(okcell, dst);
    s14
}

// ===========================================================================
// LET-VID-aware if-chain / if-seq emit (6c prep) — thread an lv-env
// ===========================================================================
//
// _lv mirrors of emit_if_chain_instr / emit_if_seq_segments / emit_if_seq_then_instr
// that thread an lv-environment (lvenv/nlv) down to the flatten + count helpers so a
// then-block let reference resolves to its value vid. With nlv == 0 the _lv variants
// are BYTE-FOR-BYTE equivalent to the non-lv ones (lvenv_lookup never matches), so
// routing the type-3 if-with-SEQ-then-block through them with an empty lv-env changes
// NO bytes (Bound by MIND-CONSTITUTION §I). 6c-2 populates the lv-env to deliver the
// lets-in-then capability.

// Emit ValueId(usize::MAX) — the SSA POISON / undef marker the Rust lowering uses
// for a merge's then_val when the then-branch RETURNS (does not fall through, so the
// variable has no then-edge value). u64::MAX as uleb128 = nine 0xFF bytes then 0x01.
pub fn emit_poison_vid(s: EmitState) -> EmitState {
    let a: EmitState = es_push(s, 255);
    let b: EmitState = es_push(a, 255);
    let c: EmitState = es_push(b, 255);
    let d: EmitState = es_push(c, 255);
    let e: EmitState = es_push(d, 255);
    let f: EmitState = es_push(e, 255);
    let g: EmitState = es_push(f, 255);
    let h: EmitState = es_push(g, 255);
    let i9: EmitState = es_push(h, 255);
    es_push(i9, 1)
}

// `binds` is an array of 32-byte escaping-binding records: [0]=name_lo, [8]=name_hi,
// [16]=this-level merge_id, [24]=then_val (the value on the then-edge, or -1 = poison
// when the then-branch returns). These three helpers fill + emit the OP_IF merge tail.

// CASE A fill: each leading then-block let escapes with then_val = POISON (-1) because
// the then-block ends in `return` (no then-edge). merge_id = else_synth+2+2*i.
pub fn fill_binds_caseA(binds: i64, then_sa: i64, nlets: i64, else_synth: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    let stmt: i64 = __mind_load_i64(then_sa + i * 8);
    let name: i64 = ast_child0(stmt);
    __mind_store_i64(binds + i * 32 + 0, ast_span_lo(name));
    __mind_store_i64(binds + i * 32 + 8, ast_span_hi(name));
    __mind_store_i64(binds + i * 32 + 16, else_synth + 2 + 2 * i);
    __mind_store_i64(binds + i * 32 + 24, 0 - 1);
    fill_binds_caseA(binds, then_sa, nlets, else_synth, i + 1)
}

// CASE B fill: the inner if's escaping bindings (24-byte name_lo/name_hi/merge_id
// triples) re-merge at THIS level with then_val = the inner merge_id (the value of the
// name after the inner if, which the then-block falls through to). merge_id = else_synth+2+2*i.
pub fn fill_binds_caseB(binds: i64, inner_bind: i64, n: i64, else_synth: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(binds + i * 32 + 0, __mind_load_i64(inner_bind + i * 24 + 0));
    __mind_store_i64(binds + i * 32 + 8, __mind_load_i64(inner_bind + i * 24 + 8));
    __mind_store_i64(binds + i * 32 + 16, else_synth + 2 + 2 * i);
    __mind_store_i64(binds + i * 32 + 24, __mind_load_i64(inner_bind + i * 24 + 16));
    fill_binds_caseB(binds, inner_bind, n, else_synth, i + 1)
}

// Emit the n_bindings list: (name_idx, merge_id) per escaping binding.
pub fn emit_chain_bindings(s: EmitState, binds: i64, n: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let lo: i64 = __mind_load_i64(binds + i * 32 + 0);
    let hi: i64 = __mind_load_i64(binds + i * 32 + 8);
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, lo, hi, 0);
    let mid: i64 = __mind_load_i64(binds + i * 32 + 16);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_chain_bindings(s2, binds, n, strbuf, offs, ncount, src, i + 1)
}

// Emit the n_merges list: (merge_id, then_val, else_val=placeholder) per binding.
// then_val == -1 emits the poison vid; placeholder_i = else_synth+1+2*i.
pub fn emit_chain_merges(s: EmitState, binds: i64, n: i64, else_synth: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let mid: i64 = __mind_load_i64(binds + i * 32 + 16);
    let tv: i64 = __mind_load_i64(binds + i * 32 + 24);
    let ph: i64 = else_synth + 1 + 2 * i;
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = if tv == 0 - 1 {
        emit_poison_vid(s1)
    } else {
        emit_uleb128(s1, tv)
    };
    let s3: EmitState = emit_uleb128(s2, ph);
    emit_chain_merges(s3, binds, n, else_synth, i + 1)
}

// Copy the binds (32-byte records) into the caller's 24-byte bindout (name_lo,
// name_hi, this-level merge_id) so the enclosing if can re-merge them (bubble up).
pub fn binds_to_bindout(binds: i64, bindout: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(binds + i * 32 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(binds + i * 32 + 8));
    __mind_store_i64(bindout + i * 24 + 16, __mind_load_i64(binds + i * 32 + 16));
    binds_to_bindout(binds, bindout, n, i + 1)
}

// Recursive nested-if-CHAIN segment emitter WITH SSA binding bubble-up. The then-block
// is `let* + (return E | single nested-if)`. Every then-block let escapes its OP_IF as a
// branch_binding + merge (mirrors src/eval/lower.rs F2): when the then-block returns,
// then_val = POISON (no then-edge); when it falls through to a nested if, the inner if's
// escaping bindings re-merge here with then_val = the inner merge_id (bubble up). The
// escaping bindings are written to `bindout` (24-byte name_lo/name_hi/merge_id records)
// and counted in `nbind_cell` so the enclosing level re-merges them. okcell <- dst (-1
// on a wall). When no lets / no bubbled bindings (N==0) the tail is `0,0` —
// BYTE-IDENTICAL to the pre-6f emitter (all existing if-chain callers unaffected).
pub fn emit_if_chain_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_blk: i64 = ast_child1(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let nlets_then: i64 = count_leading_lets(then_sa, then_sl, 0);
    if then_sl - nlets_then != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let final_stmt: i64 = __mind_load_i64(then_sa + nlets_then * 8);
    let fk: i64 = ast_kind(final_stmt);
    let cond_expr: i64 = ast_child0(if_node);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // Local lv-env = the incoming lv-env (nlv) plus this then-block's leading lets.
    let lvbuf: i64 = __mind_alloc((nlv + nlets_then + 2) * 24);
    let _cp: i64 = lvenv_copy(lvbuf, lvenv, nlv, 0);
    if fk == ast_return() {
        // CASE A — `let* + return E`. Lets escape with POISON then_val.
        let let_instrs: i64 = sum_let_init_nonparam(then_sa, nlets_then, 0, buf, params_addr, n_params, lvbuf, nlv);
        let ret_expr: i64 = ast_child0(final_stmt);
        let nlv_total: i64 = nlv + nlets_then;
        let ret_nonparam: i64 = count_nonparam_nodes_lv(ret_expr, buf, params_addr, n_params, lvbuf, nlv_total);
        let then_len: i64 = 1 + let_instrs + ret_nonparam + 1;
        let s5: EmitState = emit_uleb128(s4, then_len);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let base_cell: i64 = __mind_alloc(8);
        __mind_store_i64(base_cell, after_cond + 1);
        let li_ok: i64 = __mind_alloc(8);
        __mind_store_i64(li_ok, 1);
        let s7: EmitState = emit_let_inits_lv(s6, then_sa, nlets_then, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv, li_ok, strbuf, offs, ncount);
        if __mind_load_i64(li_ok) == 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let seg_base: i64 = after_cond + 1 + let_instrs;
        let ret_root: i64 = flatten_branch_lv(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_base, lvbuf, nlv_total);
        if ret_root < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let ret_n: i64 = __mind_load_i64(cursor);
        let s8: EmitState = emit_mic3_tree_body(s7, nodes, ret_n, vidbuf, buf, strbuf, offs, ncount, 0);
        let s9: EmitState = emit_mic3_return(s8, 1, ret_root);
        let s10: EmitState = emit_uleb128(s9, ret_root);
        let else_synth: i64 = seg_base + ret_nonparam;
        let nb: i64 = nlets_then;
        let binds: i64 = __mind_alloc((nb + 1) * 32);
        let _fa: i64 = fill_binds_caseA(binds, then_sa, nb, else_synth, 0);
        let s11: EmitState = emit_uleb128(s10, 1 + nb);
        let s12: EmitState = emit_mic3_const_i64(s11, else_synth, 0);
        let s13: EmitState = emit_merge_placeholders(s12, else_synth + 1, nb, 0);
        let s14: EmitState = emit_uleb128(s13, else_synth);
        let dst: i64 = else_synth + 1 + 2 * nb;
        let s15: EmitState = emit_uleb128(s14, dst);
        let s16: EmitState = emit_uleb128(s15, nb);
        let s17: EmitState = emit_chain_bindings(s16, binds, nb, strbuf, offs, ncount, buf, 0);
        let s18: EmitState = emit_uleb128(s17, nb);
        let s19: EmitState = emit_chain_merges(s18, binds, nb, else_synth, 0);
        let _bo: i64 = binds_to_bindout(binds, bindout, nb, 0);
        __mind_store_i64(nbind_cell, nb);
        __mind_store_i64(okcell, dst);
        return s19;
    }
    if fk == ast_if() {
        if nlets_then != 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        // CASE B — single nested if. Recurse; the inner's escaping bindings bubble up.
        let s5: EmitState = emit_uleb128(s4, 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let inner_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_cell, 0 - 1);
        let inner_bind: i64 = __mind_alloc((then_sl + 8) * 24);
        let inner_nb_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_nb_cell, 0);
        let s7: EmitState = emit_if_chain_instr_lv(s6, final_stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, inner_cell, lvenv, nlv, strbuf, offs, ncount, inner_bind, inner_nb_cell);
        let inner_dst: i64 = __mind_load_i64(inner_cell);
        if inner_dst < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let inner_nb: i64 = __mind_load_i64(inner_nb_cell);
        let s8: EmitState = emit_uleb128(s7, inner_dst);
        let else_synth: i64 = inner_dst + 1;
        let binds: i64 = __mind_alloc((inner_nb + 1) * 32);
        let _fb: i64 = fill_binds_caseB(binds, inner_bind, inner_nb, else_synth, 0);
        let s9: EmitState = emit_uleb128(s8, 1 + inner_nb);
        let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
        let s11: EmitState = emit_merge_placeholders(s10, else_synth + 1, inner_nb, 0);
        let s12: EmitState = emit_uleb128(s11, else_synth);
        let dst: i64 = else_synth + 1 + 2 * inner_nb;
        let s13: EmitState = emit_uleb128(s12, dst);
        let s14: EmitState = emit_uleb128(s13, inner_nb);
        let s15: EmitState = emit_chain_bindings(s14, binds, inner_nb, strbuf, offs, ncount, buf, 0);
        let s16: EmitState = emit_uleb128(s15, inner_nb);
        let s17: EmitState = emit_chain_merges(s16, binds, inner_nb, else_synth, 0);
        let _bo2: i64 = binds_to_bindout(binds, bindout, inner_nb, 0);
        __mind_store_i64(nbind_cell, inner_nb);
        __mind_store_i64(okcell, dst);
        return s17;
    }
    __mind_store_i64(okcell, 0 - 1);
    s
}

pub fn emit_if_seq_segments_lv(s: EmitState, stmts_addr: i64, stmts_len: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, last_dst: i64, dst_cell: i64, i: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if i >= stmts_len {
        __mind_store_i64(dst_cell, last_dst);
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    let seg_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seg_cell, 0 - 1);
    // A segment's escaping bindings bubble to its own OP_IF tail (emitted there); the
    // enclosing then-block sequence does not re-merge them (scan's segments are single
    // nested chains). Throwaway bindout.
    let seg_bindout: i64 = __mind_alloc(64 * 24);
    let seg_nbind: i64 = __mind_alloc(8);
    let s1: EmitState = emit_if_chain_instr_lv(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, seg_cell, lvenv, nlv, strbuf, offs, ncount, seg_bindout, seg_nbind);
    let seg_dst: i64 = __mind_load_i64(seg_cell);
    if seg_dst < 0 {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    emit_if_seq_segments_lv(s1, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_dst + 1, seg_dst, dst_cell, i + 1, lvenv, nlv, strbuf, offs, ncount)
}

pub fn emit_if_seq_then_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    if stmts_len < 2 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let s5: EmitState = emit_uleb128(s4, stmts_len + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let s7: EmitState = emit_if_seq_segments_lv(s6, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, after_cond, seq_cell, 0, lvenv, nlv, strbuf, offs, ncount);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let s8: EmitState = emit_uleb128(s7, last_dst);
    let else_synth: i64 = last_dst + 1;
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_uleb128(s10, else_synth);
    let dst: i64 = last_dst + 2;
    let s12: EmitState = emit_uleb128(s11, dst);
    let s13: EmitState = emit_uleb128(s12, 0);
    let s14: EmitState = emit_uleb128(s13, 0);
    __mind_store_i64(okcell, dst);
    s14
}

// ===========================================================================
// 6c-2b — if-with-LET-then-block + MERGE TAIL. The outer if's then-block is a
// SEQUENCE of leading `let NAME = INIT` bindings followed by >=1 if-segment(s)
// (each an arbitrary-depth nested if-return). Decoded byte-for-byte from
// --emit-mic3 on `g(b){ if b>=5 { let x=b+1; if x>=9 {return x} } 9 }` (106B) and
// the 2-let variant (121B). The outer OP_IF carries a non-empty MERGE TAIL: each
// then-block let escapes as a `branch_binding` (name -> merge_id) plus a
// `merge` triple (merge_id, then_val=let's value vid, else_val=a placeholder
// ConstI64(0) emitted in the else block). VID layout after the inner segments'
// last dst: else_synth, then PER let (placeholder, merge_id) interleaved, then
// dst. else_len = 1 + nlets (synth + placeholders; merge_ids are named, NOT
// emitted as instrs). Mirrors src/ir/compact/v3/emit.rs Instr::If encoding
// (encode_named_vids branch_bindings then encode_vid_triples merges) and the
// strtab order (collect_instr_strings interns branch_binding names AFTER all
// cond/then/else strings — verified vs the oracle). Bound by MIND-CONSTITUTION §I:
// additive, fail-closed, canary untouched.
// ===========================================================================

// Number of leading `let` statements in stmts[0..stmts_len). Bounded recursion
// (i strictly increases to stmts_len) — returns the index of the first non-let.
pub fn count_leading_lets(stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return i;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return i;
    }
    count_leading_lets(stmts_addr, stmts_len, i + 1)
}

// Emit each leading let's INIT tree into the THEN block, recording NAME -> its
// value (root) vid in the lv-env (lvbuf at slot nlv0+idx). cur_base (in base_cell)
// threads the running vid base; each init consumes count_nonparam_nodes_lv vids.
// A let init may reference an EARLIER let (lvbuf already holds nlv0+idx entries).
// Writes 0 to okcell + returns the seed on any flatten wall (defensive; the probe
// already validated, so this should not trigger).
pub fn emit_let_inits_lv(s: EmitState, stmts_addr: i64, nlets: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base_cell: i64, lvbuf: i64, nlv0: i64, okcell: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if idx >= nlets {
        return s;
    }
    if __mind_load_i64(okcell) == 0 {
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    let name: i64 = ast_child0(stmt);
    let init: i64 = ast_child2(stmt);
    let cur_base: i64 = __mind_load_i64(base_cell);
    let nlv_now: i64 = nlv0 + idx;
    let root: i64 = flatten_branch_lv(init, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, lvbuf, nlv_now);
    if root < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let init_n: i64 = __mind_load_i64(cursor);
    let s1: EmitState = emit_mic3_tree_body(s, nodes, init_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let nn: i64 = count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv_now);
    __mind_store_i64(lvbuf + nlv_now * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + nlv_now * 24 + 8, ast_span_hi(name));
    __mind_store_i64(lvbuf + nlv_now * 24 + 16, root);
    __mind_store_i64(base_cell, cur_base + nn);
    emit_let_inits_lv(s1, stmts_addr, nlets, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv0, okcell, strbuf, offs, ncount)
}

// Emit the per-let MERGE PLACEHOLDER consts in the else block: ConstI64(0) at
// vid base+2*i for i in 0..nlets (base = else_synth+1; merge_ids interleave at
// base+1+2*i and are NOT emitted).
pub fn emit_merge_placeholders(s: EmitState, base: i64, nlets: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let s1: EmitState = emit_mic3_const_i64(s, base + 2 * i, 0);
    emit_merge_placeholders(s1, base, nlets, i + 1)
}

// Emit the branch_bindings list: per let (name_str_idx, merge_id). merge_id =
// else_synth+2+2*i. name_str_idx via intern_find over the strtab.
pub fn emit_merge_bindings(s: EmitState, lvbuf: i64, nlv0: i64, nlets: i64, else_synth: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let lo: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 0);
    let hi: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 8);
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, lo, hi, 0);
    let merge_id: i64 = else_synth + 2 + 2 * i;
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, merge_id);
    emit_merge_bindings(s2, lvbuf, nlv0, nlets, else_synth, strbuf, offs, ncount, src, i + 1)
}

// Emit the merges list: per let (merge_id, then_val=let value vid, else_val=
// placeholder). merge_id=else_synth+2+2*i, placeholder=else_synth+1+2*i.
pub fn emit_merge_triples(s: EmitState, lvbuf: i64, nlv0: i64, nlets: i64, else_synth: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let merge_id: i64 = else_synth + 2 + 2 * i;
    let val_vid: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 16);
    let placeholder: i64 = else_synth + 1 + 2 * i;
    let s1: EmitState = emit_uleb128(s, merge_id);
    let s2: EmitState = emit_uleb128(s1, val_vid);
    let s3: EmitState = emit_uleb128(s2, placeholder);
    emit_merge_triples(s3, lvbuf, nlv0, nlets, else_synth, i + 1)
}

// Outer OP_IF whose then-block = leading lets + if-segments, WITH the merge tail.
// Generalises emit_if_seq_then_instr_lv (no-let) to lets-in-then. base0 = the vid
// base for the cond. okcell <- dst on success, -1 on any wall. lvbuf is a private
// scratch (>= (nlv0+nlets)*24 bytes); strbuf/offs/ncount resolve binding names.
pub fn emit_if_let_seq_then_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv0: i64, nlv0: i64, lvbuf: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    let nlets: i64 = count_leading_lets(stmts_addr, stmts_len, 0);
    let n_segs: i64 = stmts_len - nlets;
    // Require >=1 let (else the no-let path owns it) and >=1 trailing if-segment,
    // all of which must be if-statements.
    if nlets < 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    if n_segs < 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let segs_addr: i64 = stmts_addr + nlets * 8;
    if seq_then_all_ifs(segs_addr, n_segs, 0) != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // Seed the lv-env with the outer lets (nlv0 entries) so a let init can refer to
    // them; the leading lets append at slots nlv0..nlv0+nlets.
    let copy_ok: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    // OP_IF cond.
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvbuf, nlv0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvbuf, nlv0);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // THEN length = 1 (synth) + sum(let init nonparam) + n_segs (one OP_IF each).
    let let_instrs: i64 = sum_let_init_nonparam(stmts_addr, nlets, 0, buf, params_addr, n_params, lvbuf, nlv0);
    let s5: EmitState = emit_uleb128(s4, 1 + let_instrs + n_segs);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    // Emit the let init trees, building the lv-env (nlv0..nlv0+nlets).
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, after_cond + 1);
    let li_ok: i64 = __mind_alloc(8);
    __mind_store_i64(li_ok, 1);
    let s7: EmitState = emit_let_inits_lv(s6, stmts_addr, nlets, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv0, li_ok, strbuf, offs, ncount);
    if __mind_load_i64(li_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let nlv_total: i64 = nlv0 + nlets;
    let seg_base: i64 = after_cond + 1 + let_instrs;
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let s8: EmitState = emit_if_seq_segments_lv(s7, segs_addr, n_segs, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_base, seg_base - 1, seq_cell, 0, lvbuf, nlv_total, strbuf, offs, ncount);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // then_result = last segment's dst.
    let s9: EmitState = emit_uleb128(s8, last_dst);
    // MERGE TAIL — else block: else_synth + per-let placeholders.
    let else_synth: i64 = last_dst + 1;
    let s10: EmitState = emit_uleb128(s9, 1 + nlets);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_merge_placeholders(s11, else_synth + 1, nlets, 0);
    let s13: EmitState = emit_uleb128(s12, else_synth);
    let dst: i64 = else_synth + 1 + 2 * nlets;
    let s14: EmitState = emit_uleb128(s13, dst);
    let s15: EmitState = emit_uleb128(s14, nlets);
    let s16: EmitState = emit_merge_bindings(s15, lvbuf, nlv0, nlets, else_synth, strbuf, offs, ncount, buf, 0);
    let s17: EmitState = emit_uleb128(s16, nlets);
    let s18: EmitState = emit_merge_triples(s17, lvbuf, nlv0, nlets, else_synth, 0);
    __mind_store_i64(okcell, dst);
    s18
}

// Copy `n` 24-byte lv-env entries from src to dst. Returns 1.
pub fn lvenv_copy(dst: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 1;
    }
    __mind_store_i64(dst + i * 24 + 0, __mind_load_i64(src + i * 24 + 0));
    __mind_store_i64(dst + i * 24 + 8, __mind_load_i64(src + i * 24 + 8));
    __mind_store_i64(dst + i * 24 + 16, __mind_load_i64(src + i * 24 + 16));
    lvenv_copy(dst, src, n, i + 1)
}

// Sum the nonparam (vid-consuming) node counts of the leading lets' inits. Each
// let i resolves against the lv-env built from the prior lets (nlv0+i entries),
// matching emit_let_inits_lv's per-let base advance. Populates each let's NAME
// into lvbuf (with a placeholder vid 0) BEFORE measuring the next, so a later
// let's init that references an earlier let resolves (the real vids are written
// by emit_let_inits_lv afterwards; only the name spans matter for counting).
pub fn sum_let_init_nonparam(stmts_addr: i64, nlets: i64, i: i64, buf: i64, params_addr: i64, n_params: i64, lvbuf: i64, nlv0: i64) -> i64 {
    if i >= nlets {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let init: i64 = ast_child2(stmt);
    let nn: i64 = count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv0 + i);
    let name: i64 = ast_child0(stmt);
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 8, ast_span_hi(name));
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 16, 0);
    nn + sum_let_init_nonparam(stmts_addr, nlets, i + 1, buf, params_addr, n_params, lvbuf, nlv0)
}

// FN_DEF whose body is `{ <if-chain>; TRAIL }` — one arbitrary-depth nested if-return
// then a trailing value. Mirrors emit_mic3_module_fndef_nested_if but for the recursive
// chain (any depth >= 1). Supersedes the depth-2 dedicated case byte-identically.
pub fn emit_mic3_module_fndef_if_chain(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, if_node: i64, trail_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, t_nodes: i64, t_cursor: i64, t_vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_if_chain_instr(es_new(), if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_root: i64 = flatten_branch(trail_expr, src, params_addr, n_params, t_nodes, t_cursor, t_vidbuf, dst + 1);
    if trail_root < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_n: i64 = __mind_load_i64(t_cursor);
    let trail_nonparam: i64 = count_nonparam_nodes(trail_expr, src, params_addr, n_params);
    let body_len: i64 = n_params + 1 + trail_nonparam;
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, trail_root);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_if_chain_instr(s7, if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let s9: EmitState = emit_mic3_tree_body(s8, t_nodes, trail_n, t_vidbuf, 0, 0, 0, 0, 0);
    __mind_store_i64(ok_cell, 1);
    s9
}

// ===========================================================================
// GENERAL statement sequencing — lets + if-early-returns in arbitrary order
// ===========================================================================
//
// Generalises cases (f) [let-chain] and (g) [single if-early-return then trail]
// into ONE recursive statement walker: a body is an arbitrary sequence of
//   `let NAME: TYPE = INIT`           (binds NAME -> its init's root descriptor slot)
//   `if COND { return E; }`           (else-less if; then-block ends in `return E`)
// then a trailing value expression (the FN_DEF result). Decoded byte-for-byte from
// --emit-mic3 on `fn foo(a,b){ let t=a+b; if t==0 {return 0;} let u=t*2; u }`:
//   PARAM%0 PARAM%1
//   BINOP%2 = %0 add %1                 (let t)
//   OP_IF{ cond: CONST%3=0, BINOP%4=%2 eq %3 ;
//          then: CONST%5=0(synth), CONST%6=0(ret literal), RETURN%6 ; then_res %6 ;
//          else: CONST%7=0(synth) ; else_res %7 ; dst %8 ; bindings0 merges0 }
//   CONST%9=2 BINOP%10=%2 mul %9        (let u)  -> ret_vid %10 (= trailing `u`)
// All let-inits, every if cond/ret expr, and the trailing flatten into ONE shared
// descriptor array carrying the let-env, so let-refs in a later cond / init / the
// trailing reuse the earlier slot's vid with no new node. Vids are assigned in
// SOURCE order per segment (a let segment, then the OP_IF block which injects the
// synth/dst vids, then the next segment), threading a running base — matching the
// Rust SSA numbering exactly. ISOLATED from the canary (flatten_ast still rejects
// ast_if/ast_let at expression level, so the fixed point stays byte-identical;
// Bound by MIND-CONSTITUTION §I — additive, canary untouched).

// Count the body-instr (non-structural) descriptor slots in nodes[lo..hi). Mirrors
// count_descriptor_nonparam but over a half-open sub-range, used to size per-segment
// vid blocks and the cond/ret OP_IF lengths.
pub fn count_descriptor_nonparam_range(nodes: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return 0;
    }
    let kind: i64 = __mind_load_i64(nodes + lo * 32);
    if kind == 0 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    if kind == 4 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    if kind == 5 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    1 + count_descriptor_nonparam_range(nodes, lo + 1, hi)
}

// Resolve vids for nodes[lo..hi) starting the non-param counter at `base`. Reuses
// tree_resolve_vids_base's logic but bounded to a sub-range (so a let segment, the
// trailing, or an OP_IF cond/ret tree each resolve against a private base while
// referring to already-resolved earlier slots). Returns the next free vid.
pub fn seq_resolve_range(nodes: i64, lo: i64, hi: i64, vidbuf: i64, base: i64) -> i64 {
    if lo >= hi {
        return base;
    }
    let kind: i64 = __mind_load_i64(nodes + lo * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + lo * 32 + 8);
        __mind_store_i64(vidbuf + lo * 8, pidx);
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    if kind == 4 {
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    if kind == 5 {
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    __mind_store_i64(vidbuf + lo * 8, base);
    seq_resolve_range(nodes, lo + 1, hi, vidbuf, base + 1)
}

// Walk the statements [0..stmts_len-1) (everything before the trailing value),
// flattening each into the SHARED descriptor array and recording a plan entry
// (64-byte record) per statement. Plan record layout:
//   [0]=type (0=let, 1=if-return)
//   let:  [8]=slot_start, [16]=slot_end
//   if :  [8]=cond_start, [16]=cond_end, [24]=cond_root_slot,
//         [32]=ret_start,  [40]=ret_end,  [48]=ret_root_slot
// Returns 1 on success (plan/env/nodes filled), 0 on any wall (unsupported stmt or
// init/cond/ret the flatten rejects). `nplan_cell` accumulates the plan length;
// `nlets_cell` the let-env length. Threaded through recursion.
// True (1) iff every statement in stmts[0..len) is an if-statement — the precondition
// for a type-3 if-with-SEQ-then-block (each becomes one if-segment).
pub fn seq_then_all_ifs(stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        return 0;
    }
    seq_then_all_ifs(stmts_addr, stmts_len, i + 1)
}

// lv-aware if-EXPRESSION emitter: `if C { A } else { B }` as a VALUE (the OP_IF dst).
// Mirrors emit_mic3_if_instr but resolves seq-level lets in the cond/branches via the
// lv-env, and resolves call name_idx via strbuf/offs/ncount. then_result = then-value,
// else_result = else-value, dst = the merged value; 0 bindings / 0 merges (an
// if-expression value, not a variable merge). okcell <- dst (-1 on a wall).
pub fn emit_if_expr_lv(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch_lv(then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, lvenv, nlv);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes_lv(then_expr, buf, params_addr, n_params, lvenv, nlv);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let s8: EmitState = emit_uleb128(s7, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch_lv(else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_then + 1, lvenv, nlv);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(cursor);
    let else_nonparam: i64 = count_nonparam_nodes_lv(else_expr, buf, params_addr, n_params, lvenv, nlv);
    let s9: EmitState = emit_uleb128(s8, else_nonparam + 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_mic3_tree_body(s10, nodes, else_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let s12: EmitState = emit_uleb128(s11, else_root);
    let after_else: i64 = after_then + 1 + else_nonparam;
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// True iff `node` is an if-EXPRESSION usable as a value: an else-ful if whose then
// and else blocks are each a single value-expression (branch_single_expr).
pub fn is_value_if_expr(node: i64) -> i64 {
    if ast_kind(node) != ast_if() {
        return 0;
    }
    if ast_child2(node) == 0 {
        return 0;
    }
    if branch_single_expr(ast_child1(node)) < 0 {
        return 0;
    }
    if branch_single_expr(ast_child2(node)) < 0 {
        return 0;
    }
    1
}

pub fn flatten_stmt_seq(src: i64, stmts_addr: i64, stmts_len: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets_cell: i64, plan: i64, nplan_cell: i64, i: i64) -> i64 {
    if i >= stmts_len - 1 {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let p: i64 = __mind_load_i64(nplan_cell);
    if ast_kind(stmt) == ast_let() {
        let name: i64 = ast_child0(stmt);
        let init: i64 = ast_child2(stmt);
        // (type 7) let bound to an if-EXPRESSION value: `let X = if C {A} else {B}`.
        // Emit the OP_IF (then_result/else_result = the branch values, dst = the merged
        // value); bind X -> a synthetic dst-slot whose vid is set to the OP_IF dst in
        // Pass B, so later refs to X resolve to the merged value.
        if is_value_if_expr(init) == 1 {
            let q7_nodes: i64 = __mind_alloc(256 * 32);
            let q7_cursor: i64 = __mind_alloc(8);
            let q7_vidbuf: i64 = __mind_alloc(256 * 8);
            let q7_cell: i64 = __mind_alloc(8);
            __mind_store_i64(q7_cell, 0 - 1);
            let q7_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
            let _q7lv: i64 = seq_env_to_lvenv(env, nlets, 0, q7_lvenv, 0, 0);
            let q7_cond: i64 = ast_child0(init);
            let q7_then: i64 = branch_single_expr(ast_child1(init));
            let q7_else: i64 = branch_single_expr(ast_child2(init));
            let q7: EmitState = emit_if_expr_lv(es_new(), q7_cond, q7_then, q7_else, src, params_addr, n_params, q7_nodes, q7_cursor, q7_vidbuf, 0, q7_cell, q7_lvenv, nlets, 0, 0, 0);
            let q7_dst: i64 = __mind_load_i64(q7_cell);
            if q7_dst >= 0 {
                let dst_slot: i64 = __mind_load_i64(cursor);
                __mind_store_i64(nodes + dst_slot * 32 + 0, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 8, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 16, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 24, 0);
                __mind_store_i64(cursor, dst_slot + 1);
                __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
                __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
                __mind_store_i64(env + nlets * 24 + 16, dst_slot);
                __mind_store_i64(nlets_cell, nlets + 1);
                __mind_store_i64(plan + p * 64 + 0, 7);
                __mind_store_i64(plan + p * 64 + 8, init);
                __mind_store_i64(plan + p * 64 + 16, q7_dst + 1);
                __mind_store_i64(plan + p * 64 + 24, params_addr);
                __mind_store_i64(plan + p * 64 + 32, n_params);
                __mind_store_i64(plan + p * 64 + 40, dst_slot);
                __mind_store_i64(nplan_cell, p + 1);
                return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
            }
        }
        let start: i64 = __mind_load_i64(cursor);
        let root_slot: i64 = flatten_expr_env(init, src, params_addr, n_params, nodes, cursor, env, nlets);
        if root_slot < 0 {
            return 0;
        }
        let end: i64 = __mind_load_i64(cursor);
        __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
        __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
        __mind_store_i64(env + nlets * 24 + 16, root_slot);
        __mind_store_i64(nlets_cell, nlets + 1);
        __mind_store_i64(plan + p * 64 + 0, 0);
        __mind_store_i64(plan + p * 64 + 8, start);
        __mind_store_i64(plan + p * 64 + 16, end);
        __mind_store_i64(nplan_cell, p + 1);
        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
    }
    if ast_kind(stmt) == ast_if() {
        // else-less if whose then-block's single statement is `return E`.
        if ast_child2(stmt) != 0 {
            return 0;
        }
        let then_blk: i64 = ast_child1(stmt);
        // (type 3) if-with-SEQ-then-block: the then-block is a SEQUENCE (>=2 stmts)
        // of if-segments (each an arbitrary-depth nested if-return chain), no lets,
        // no trailing value. The outer OP_IF's then-branch emits those segments in
        // order; the then-result is the last segment's dst. Probe the self-contained
        // emitter once (base0=0) to learn the vid delta, store it + the stmt node.
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        // (type 4) if-with-LET-then-block: the then-block is leading `let` bindings
        // then >=1 if-segment(s), carrying a merge tail. Probe the let-aware emitter
        // (base0=0, empty outer lv-env) to learn the vid delta. Takes priority over
        // type 3 when leading lets are present (type 3 requires 0 lets).
        if then_sl >= 2 {
            let t4_nlets: i64 = count_leading_lets(then_sa, then_sl, 0);
            if t4_nlets >= 1 {
                let t4_segs: i64 = then_sl - t4_nlets;
                if t4_segs >= 1 {
                    if seq_then_all_ifs(then_sa + t4_nlets * 8, t4_segs, 0) == 1 {
                        let p4_nodes: i64 = __mind_alloc(256 * 32);
                        let p4_cursor: i64 = __mind_alloc(8);
                        let p4_vidbuf: i64 = __mind_alloc(256 * 8);
                        let p4_cell: i64 = __mind_alloc(8);
                        __mind_store_i64(p4_cell, 0 - 1);
                        // Name-only seq lv-env (vids unresolved at probe time) so the
                        // cond / then-lets can reference sequence-level lets.
                        let p4_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                        let _p4lv: i64 = seq_env_to_lvenv(env, nlets, 0, p4_lvenv, 0, 0);
                        let p4_lvbuf: i64 = __mind_alloc((nlets + t4_nlets + 8) * 24);
                        let p4: EmitState = emit_if_let_seq_then_instr_lv(es_new(), stmt, src, params_addr, n_params, p4_nodes, p4_cursor, p4_vidbuf, 0, p4_cell, p4_lvenv, nlets, p4_lvbuf, 0, 0, 0);
                        let p4_dst: i64 = __mind_load_i64(p4_cell);
                        if p4_dst >= 0 {
                            __mind_store_i64(plan + p * 64 + 0, 4);
                            __mind_store_i64(plan + p * 64 + 8, stmt);
                            __mind_store_i64(plan + p * 64 + 16, p4_dst + 1);
                            __mind_store_i64(plan + p * 64 + 24, params_addr);
                            __mind_store_i64(plan + p * 64 + 32, n_params);
                            __mind_store_i64(nplan_cell, p + 1);
                            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                        }
                    }
                }
                // (type 5, case A in a sequence) leading lets + a single final `return E`
                // (the block DIVERGES, so the lets merge with POISON). type-4 above only
                // takes lets + if-SEGMENTS (fall-through); this takes lets + return. e.g.
                // scan's `if is_alpha(b) { let hi=..; let kind=..; let nt=..; return scan(..) }`.
                if then_sl - t4_nlets == 1 {
                    let t5a_fin: i64 = __mind_load_i64(then_sa + t4_nlets * 8);
                    if ast_kind(t5a_fin) == ast_return() {
                        let q5_nodes: i64 = __mind_alloc(256 * 32);
                        let q5_cursor: i64 = __mind_alloc(8);
                        let q5_vidbuf: i64 = __mind_alloc(256 * 8);
                        let q5_cell: i64 = __mind_alloc(8);
                        __mind_store_i64(q5_cell, 0 - 1);
                        let q5_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                        let _q5lv: i64 = seq_env_to_lvenv(env, nlets, 0, q5_lvenv, 0, 0);
                        let q5_bindout: i64 = __mind_alloc(64 * 24);
                        let q5_nbind: i64 = __mind_alloc(8);
                        let q5: EmitState = emit_if_chain_instr_lv(es_new(), stmt, src, params_addr, n_params, q5_nodes, q5_cursor, q5_vidbuf, 0, q5_cell, q5_lvenv, nlets, 0, 0, 0, q5_bindout, q5_nbind);
                        let q5_dst: i64 = __mind_load_i64(q5_cell);
                        if q5_dst >= 0 {
                            __mind_store_i64(plan + p * 64 + 0, 5);
                            __mind_store_i64(plan + p * 64 + 8, stmt);
                            __mind_store_i64(plan + p * 64 + 16, q5_dst + 1);
                            __mind_store_i64(plan + p * 64 + 24, params_addr);
                            __mind_store_i64(plan + p * 64 + 32, n_params);
                            __mind_store_i64(nplan_cell, p + 1);
                            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                        }
                    }
                }
            }
            if seq_then_all_ifs(then_sa, then_sl, 0) == 1 {
                let pr_nodes: i64 = __mind_alloc(256 * 32);
                let pr_cursor: i64 = __mind_alloc(8);
                let pr_vidbuf: i64 = __mind_alloc(256 * 8);
                let pr_cell: i64 = __mind_alloc(8);
                __mind_store_i64(pr_cell, 0 - 1);
                let pr_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _prlv: i64 = seq_env_to_lvenv(env, nlets, 0, pr_lvenv, 0, 0);
                let pr: EmitState = emit_if_seq_then_instr_lv(es_new(), stmt, src, params_addr, n_params, pr_nodes, pr_cursor, pr_vidbuf, 0, pr_cell, pr_lvenv, nlets, 0, 0, 0);
                let pr_dst: i64 = __mind_load_i64(pr_cell);
                if pr_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 3);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, pr_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
            }
        }
        let ret_stmt: i64 = branch_single_expr(then_blk);
        if ret_stmt < 0 {
            return 0;
        }
        // (type 2) NESTED if-return segment: the outer then-block's single stmt is
        // ITSELF an else-less if whose then-block is `return E`. Flatten the 3 trees
        // (outer cond, inner cond, inner ret) CONSECUTIVELY into the shared array and
        // store the contiguous range + 2 split points + 3 roots (fits the 64B entry).
        if ast_kind(ret_stmt) == ast_if() {
            if ast_child2(ret_stmt) != 0 {
                return 0;
            }
            let inner_then: i64 = ast_child1(ret_stmt);
            let inner_ret: i64 = branch_single_expr(inner_then);
            // CLEAN depth-2 = the inner then-block is a SINGLE bare `return E`. That
            // stays on the proven type-2 emit (byte-preserved, e.g. is_alpha). ANYTHING
            // else — a deeper nested if, OR a `let* + return` bottom block (inner_ret<0,
            // multi-stmt) — routes through the recursive chain emitter (type 5), which
            // handles arbitrary depth + then-block lets with SSA binding bubble-up.
            let clean_d2: i64 = if inner_ret < 0 {
                0
            } else {
                if ast_kind(inner_ret) == ast_return() {
                    1
                } else {
                    0
                }
            };
            if clean_d2 == 0 {
                let p5_nodes: i64 = __mind_alloc(256 * 32);
                let p5_cursor: i64 = __mind_alloc(8);
                let p5_vidbuf: i64 = __mind_alloc(256 * 8);
                let p5_cell: i64 = __mind_alloc(8);
                __mind_store_i64(p5_cell, 0 - 1);
                let p5_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _p5lv: i64 = seq_env_to_lvenv(env, nlets, 0, p5_lvenv, 0, 0);
                let p5_bindout: i64 = __mind_alloc(64 * 24);
                let p5_nbind: i64 = __mind_alloc(8);
                let p5: EmitState = emit_if_chain_instr_lv(es_new(), stmt, src, params_addr, n_params, p5_nodes, p5_cursor, p5_vidbuf, 0, p5_cell, p5_lvenv, nlets, 0, 0, 0, p5_bindout, p5_nbind);
                let p5_dst: i64 = __mind_load_i64(p5_cell);
                if p5_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 5);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, p5_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
                return 0;
            }
            let n2_rs: i64 = __mind_load_i64(cursor);
            let n2_ocr: i64 = flatten_expr_env(ast_child0(stmt), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_ocr < 0 {
                return 0;
            }
            let n2_s1: i64 = __mind_load_i64(cursor);
            let n2_icr: i64 = flatten_expr_env(ast_child0(ret_stmt), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_icr < 0 {
                return 0;
            }
            let n2_s2: i64 = __mind_load_i64(cursor);
            let n2_irr: i64 = flatten_expr_env(ast_child0(inner_ret), src, params_addr, n_params, nodes, cursor, env, nlets);
            if n2_irr < 0 {
                return 0;
            }
            let n2_re: i64 = __mind_load_i64(cursor);
            __mind_store_i64(plan + p * 64 + 0, 2);
            __mind_store_i64(plan + p * 64 + 8, n2_rs);
            __mind_store_i64(plan + p * 64 + 16, n2_re);
            __mind_store_i64(plan + p * 64 + 24, n2_ocr);
            __mind_store_i64(plan + p * 64 + 32, n2_icr);
            __mind_store_i64(plan + p * 64 + 40, n2_irr);
            __mind_store_i64(plan + p * 64 + 48, n2_s1);
            __mind_store_i64(plan + p * 64 + 56, n2_s2);
            __mind_store_i64(nplan_cell, p + 1);
            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
        }
        if ast_kind(ret_stmt) != ast_return() {
            return 0;
        }
        let cond_expr: i64 = ast_child0(stmt);
        let ret_expr: i64 = ast_child0(ret_stmt);
        let cstart: i64 = __mind_load_i64(cursor);
        let cond_root: i64 = flatten_expr_env(cond_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
        if cond_root < 0 {
            return 0;
        }
        let cend: i64 = __mind_load_i64(cursor);
        let rstart: i64 = __mind_load_i64(cursor);
        let ret_root: i64 = flatten_expr_env(ret_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
        if ret_root < 0 {
            return 0;
        }
        let rend: i64 = __mind_load_i64(cursor);
        __mind_store_i64(plan + p * 64 + 0, 1);
        __mind_store_i64(plan + p * 64 + 8, cstart);
        __mind_store_i64(plan + p * 64 + 16, cend);
        __mind_store_i64(plan + p * 64 + 24, cond_root);
        __mind_store_i64(plan + p * 64 + 32, rstart);
        __mind_store_i64(plan + p * 64 + 40, rend);
        __mind_store_i64(plan + p * 64 + 48, ret_root);
        __mind_store_i64(nplan_cell, p + 1);
        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
    }
    // BARE EXPRESSION STATEMENT (a call/expr emitted for side-effect; its result vid
    // is allocated then discarded, e.g. `__mind_store_i64(n, kind);` in ast_new_leaf).
    // Flatten it like a let-init but bind NO name — Pass B/C treat it as a type-0
    // segment (resolve the [start,end) range, emit its tree). Fails closed if
    // flatten_expr_env rejects the stmt (then this fn / seq is unsupported).
    let bstart: i64 = __mind_load_i64(cursor);
    let broot: i64 = flatten_expr_env(stmt, src, params_addr, n_params, nodes, cursor, env, nlets);
    if broot < 0 {
        return 0;
    }
    let bend: i64 = __mind_load_i64(cursor);
    __mind_store_i64(plan + p * 64 + 0, 0);
    __mind_store_i64(plan + p * 64 + 8, bstart);
    __mind_store_i64(plan + p * 64 + 16, bend);
    __mind_store_i64(nplan_cell, p + 1);
    flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1)
}

// Pass B — assign vids across the plan in source order, threading `base`. A let
// segment resolves its [start,end) slots from base. An if-return block resolves the
// cond tree from base, then injects the OP_IF synth/dst vids: then-synth, the ret
// tree (from then-synth+1), the else-synth, and dst — advancing base past the whole
// block, exactly as emit_mic3_if_stmt_instr lays them out. Returns the final base.
// Convert the seq let-env (name_lo, name_hi, root_SLOT) into an lv-env (name_lo,
// name_hi, VID) for the _lv segment emitters, so a segment cond/init that refers
// to a sequence-level let (e.g. `if n == 2` where `let n = ...` precedes it)
// resolves it. When resolve==1, vid = vidbuf[root_slot] (Pass-B-resolved); when 0
// (probe, vids not yet assigned) vid = 0 (only the NAME matters — let-refs are
// 0-count leaves whose vid does not affect the dst delta). Returns nlets.
pub fn seq_env_to_lvenv(env: i64, nlets: i64, vidbuf: i64, lvbuf: i64, resolve: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    __mind_store_i64(lvbuf + i * 24 + 0, __mind_load_i64(env + i * 24 + 0));
    __mind_store_i64(lvbuf + i * 24 + 8, __mind_load_i64(env + i * 24 + 8));
    let v: i64 = if resolve == 1 {
        __mind_load_i64(vidbuf + __mind_load_i64(env + i * 24 + 16) * 8)
    } else {
        0
    };
    __mind_store_i64(lvbuf + i * 24 + 16, v);
    seq_env_to_lvenv(env, nlets, vidbuf, lvbuf, resolve, i + 1)
}

pub fn seq_assign_vids(nodes: i64, vidbuf: i64, plan: i64, nplan: i64, base: i64, i: i64) -> i64 {
    if i >= nplan {
        return base;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        let nb: i64 = seq_resolve_range(nodes, start, end, vidbuf, base);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, nb, i + 1);
    }
    if ty == 3 {
        // if-with-SEQ-then-block. The whole OP_IF (cond + segments + else + dst)
        // consumes `next_delta` vids relative to `base` (probed at flatten time,
        // base-relative). Advance past it.
        let next_delta: i64 = __mind_load_i64(plan + i * 64 + 16);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta, i + 1);
    }
    if ty == 4 {
        // if-with-LET-then-block (merge tail). Same base-relative delta convention
        // as type 3 — the whole OP_IF (cond + let inits + segments + merge tail)
        // consumes `next_delta` vids relative to `base`.
        let next_delta4: i64 = __mind_load_i64(plan + i * 64 + 16);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta4, i + 1);
    }
    if ty == 5 {
        // single nested-if-chain segment (arbitrary depth). Base-relative delta.
        let next_delta5: i64 = __mind_load_i64(plan + i * 64 + 16);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta5, i + 1);
    }
    if ty == 7 {
        // let = if-EXPRESSION. The OP_IF consumes `next_delta` vids; its dst (the let's
        // value) = base + next_delta - 1. Bind the dst-slot to it so later refs resolve.
        let next_delta7: i64 = __mind_load_i64(plan + i * 64 + 16);
        let dst_slot7: i64 = __mind_load_i64(plan + i * 64 + 40);
        __mind_store_i64(vidbuf + dst_slot7 * 8, base + next_delta7 - 1);
        return seq_assign_vids(nodes, vidbuf, plan, nplan, base + next_delta7, i + 1);
    }
    if ty == 2 {
        // NESTED if-return segment. Same vid layout as emit_mic3_nested_if_instr,
        // base-threaded: outer cond -> then-synth -> inner cond -> inner-then-synth ->
        // inner ret -> inner-else-synth -> inner-dst -> outer-else-synth -> outer-dst.
        let n2_rs: i64 = __mind_load_i64(plan + i * 64 + 8);
        let n2_re: i64 = __mind_load_i64(plan + i * 64 + 16);
        let n2_s1: i64 = __mind_load_i64(plan + i * 64 + 48);
        let n2_s2: i64 = __mind_load_i64(plan + i * 64 + 56);
        let n2_after_oc: i64 = seq_resolve_range(nodes, n2_rs, n2_s1, vidbuf, base);
        let n2_after_ic: i64 = seq_resolve_range(nodes, n2_s1, n2_s2, vidbuf, n2_after_oc + 1);
        let n2_after_ir: i64 = seq_resolve_range(nodes, n2_s2, n2_re, vidbuf, n2_after_ic + 1);
        let n2_next: i64 = n2_after_ir + 4;
        return seq_assign_vids(nodes, vidbuf, plan, nplan, n2_next, i + 1);
    }
    // if-return block.
    let cstart: i64 = __mind_load_i64(plan + i * 64 + 8);
    let cend: i64 = __mind_load_i64(plan + i * 64 + 16);
    let rstart: i64 = __mind_load_i64(plan + i * 64 + 32);
    let rend: i64 = __mind_load_i64(plan + i * 64 + 40);
    let after_cond: i64 = seq_resolve_range(nodes, cstart, cend, vidbuf, base);
    // then-synth at after_cond; ret tree resolves from after_cond+1; else-synth and
    // dst follow.
    let after_ret: i64 = seq_resolve_range(nodes, rstart, rend, vidbuf, after_cond + 1);
    let next_base: i64 = after_ret + 2;
    seq_assign_vids(nodes, vidbuf, plan, nplan, next_base, i + 1)
}

// Pass C — emit the body instrs for the plan in source order. A let segment emits
// its [start,end) tree. An if-return block emits ONE OP_IF (0x1C): cond tree, then
// (synth const + ret tree + Return(ret_root_vid)), else (synth const), dst, empty
// bindings/merges — reading every vid from the shared vidbuf resolved in Pass B.
pub fn emit_stmt_seq(s: EmitState, nodes: i64, vidbuf: i64, src: i64, strbuf: i64, offs: i64, ncount: i64, plan: i64, nplan: i64, base: i64, i: i64, seq_lvbuf: i64, seq_nlv: i64) -> EmitState {
    if i >= nplan {
        return s;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        let nb: i64 = seq_resolve_range(nodes, start, end, vidbuf, base);
        let s1: EmitState = emit_mic3_tree_body(s, nodes, end, vidbuf, src, strbuf, offs, ncount, start);
        return emit_stmt_seq(s1, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, nb, i + 1, seq_lvbuf, seq_nlv);
    }
    if ty == 3 {
        // if-with-SEQ-then-block -> ONE outer OP_IF whose then-branch is a sequence
        // of if-segments. Self-contained (own scratch so the shared nodes/vidbuf used
        // by other segments are untouched); base-threaded. dst = base + next_delta - 1.
        // The seq lv-env lets the cond reference sequence-level lets (`if n == 2`).
        let if_node3: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta3: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa3: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np3: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e3_nodes: i64 = __mind_alloc(256 * 32);
        let e3_cursor: i64 = __mind_alloc(8);
        let e3_vidbuf: i64 = __mind_alloc(256 * 8);
        let e3_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e3_cell, 0 - 1);
        let s3i: EmitState = emit_if_seq_then_instr_lv(s, if_node3, src, pa3, np3, e3_nodes, e3_cursor, e3_vidbuf, base, e3_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount);
        return emit_stmt_seq(s3i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta3, i + 1, seq_lvbuf, seq_nlv);
    }
    if ty == 4 {
        // if-with-LET-then-block (merge tail) -> ONE outer OP_IF. Self-contained
        // scratch; base-threaded. strbuf/offs/ncount resolve the binding names. The
        // seq lv-env (seq_lvbuf/seq_nlv) seeds lvenv0 so the cond + then-lets resolve
        // sequence-level lets; the then-block lets append after seq_nlv.
        let if_node4: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta4: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa4: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np4: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e4_nodes: i64 = __mind_alloc(256 * 32);
        let e4_cursor: i64 = __mind_alloc(8);
        let e4_vidbuf: i64 = __mind_alloc(256 * 8);
        let e4_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e4_cell, 0 - 1);
        let e4_then_blk: i64 = ast_child1(if_node4);
        let e4_nlets: i64 = count_leading_lets(ast_child0(e4_then_blk), ast_aux(e4_then_blk), 0);
        let e4_lvbuf: i64 = __mind_alloc((seq_nlv + e4_nlets + 8) * 24);
        let s4i: EmitState = emit_if_let_seq_then_instr_lv(s, if_node4, src, pa4, np4, e4_nodes, e4_cursor, e4_vidbuf, base, e4_cell, seq_lvbuf, seq_nlv, e4_lvbuf, strbuf, offs, ncount);
        return emit_stmt_seq(s4i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta4, i + 1, seq_lvbuf, seq_nlv);
    }
    if ty == 5 {
        // single nested-if-chain segment of ARBITRARY depth -> ONE OP_IF via the
        // recursive chain emitter (subsumes the depth-2 type-2). Self-contained
        // scratch; base-threaded; seq lv-env lets the cond reference sequence lets.
        let if_node5: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta5: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa5: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np5: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e5_nodes: i64 = __mind_alloc(256 * 32);
        let e5_cursor: i64 = __mind_alloc(8);
        let e5_vidbuf: i64 = __mind_alloc(256 * 8);
        let e5_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e5_cell, 0 - 1);
        let e5_bindout: i64 = __mind_alloc(64 * 24);
        let e5_nbind: i64 = __mind_alloc(8);
        let s5i: EmitState = emit_if_chain_instr_lv(s, if_node5, src, pa5, np5, e5_nodes, e5_cursor, e5_vidbuf, base, e5_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount, e5_bindout, e5_nbind);
        return emit_stmt_seq(s5i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta5, i + 1, seq_lvbuf, seq_nlv);
    }
    if ty == 7 {
        // let = if-EXPRESSION -> ONE OP_IF (value). Self-contained scratch; the seq
        // lv-env resolves sequence-let refs in the cond/branches. dst = base+delta-1.
        let init7: i64 = __mind_load_i64(plan + i * 64 + 8);
        let next_delta7: i64 = __mind_load_i64(plan + i * 64 + 16);
        let pa7: i64 = __mind_load_i64(plan + i * 64 + 24);
        let np7: i64 = __mind_load_i64(plan + i * 64 + 32);
        let e7_nodes: i64 = __mind_alloc(256 * 32);
        let e7_cursor: i64 = __mind_alloc(8);
        let e7_vidbuf: i64 = __mind_alloc(256 * 8);
        let e7_cell: i64 = __mind_alloc(8);
        __mind_store_i64(e7_cell, 0 - 1);
        let c7: i64 = ast_child0(init7);
        let t7: i64 = branch_single_expr(ast_child1(init7));
        let l7: i64 = branch_single_expr(ast_child2(init7));
        let s7i: EmitState = emit_if_expr_lv(s, c7, t7, l7, src, pa7, np7, e7_nodes, e7_cursor, e7_vidbuf, base, e7_cell, seq_lvbuf, seq_nlv, strbuf, offs, ncount);
        return emit_stmt_seq(s7i, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, base + next_delta7, i + 1, seq_lvbuf, seq_nlv);
    }
    if ty == 2 {
        // NESTED if-return segment -> ONE outer OP_IF whose then-branch is `synth +
        // inner OP_IF`. Reads vids from the shared vidbuf (resolved in Pass B), trees
        // from the shared node ranges. Mirrors emit_mic3_nested_if_instr, base-threaded.
        let n2_rs: i64 = __mind_load_i64(plan + i * 64 + 8);
        let n2_re: i64 = __mind_load_i64(plan + i * 64 + 16);
        let n2_ocr: i64 = __mind_load_i64(plan + i * 64 + 24);
        let n2_icr: i64 = __mind_load_i64(plan + i * 64 + 32);
        let n2_irr: i64 = __mind_load_i64(plan + i * 64 + 40);
        let n2_s1: i64 = __mind_load_i64(plan + i * 64 + 48);
        let n2_s2: i64 = __mind_load_i64(plan + i * 64 + 56);
        let n2_oc_n: i64 = count_descriptor_nonparam_range(nodes, n2_rs, n2_s1);
        let n2_after_oc: i64 = base + n2_oc_n;
        let n2_ic_n: i64 = count_descriptor_nonparam_range(nodes, n2_s1, n2_s2);
        let n2_after_ic: i64 = n2_after_oc + 1 + n2_ic_n;
        let n2_ir_n: i64 = count_descriptor_nonparam_range(nodes, n2_s2, n2_re);
        let n2_after_ir: i64 = n2_after_ic + 1 + n2_ir_n;
        let n2_inner_dst: i64 = n2_after_ir + 1;
        let n2_outer_else: i64 = n2_after_ir + 2;
        let n2_outer_dst: i64 = n2_after_ir + 3;
        let n2_oc_vid: i64 = __mind_load_i64(vidbuf + n2_ocr * 8);
        let n2_ic_vid: i64 = __mind_load_i64(vidbuf + n2_icr * 8);
        let n2_ir_vid: i64 = __mind_load_i64(vidbuf + n2_irr * 8);
        // outer OP_IF: cond
        let q1: EmitState = es_push(s, 28);
        let q2: EmitState = emit_uleb128(q1, n2_oc_vid);
        let q3: EmitState = emit_uleb128(q2, n2_oc_n);
        let q4: EmitState = emit_mic3_tree_body(q3, nodes, n2_s1, vidbuf, src, strbuf, offs, ncount, n2_rs);
        // outer then = synth + inner OP_IF (2 instrs)
        let q5: EmitState = emit_uleb128(q4, 2);
        let q6: EmitState = emit_mic3_const_i64(q5, n2_after_oc, 0);
        // inner OP_IF: cond
        let q7: EmitState = es_push(q6, 28);
        let q8: EmitState = emit_uleb128(q7, n2_ic_vid);
        let q9: EmitState = emit_uleb128(q8, n2_ic_n);
        let q10: EmitState = emit_mic3_tree_body(q9, nodes, n2_s2, vidbuf, src, strbuf, offs, ncount, n2_s1);
        // inner then = synth + ret tree + Return
        let q11: EmitState = emit_uleb128(q10, n2_ir_n + 2);
        let q12: EmitState = emit_mic3_const_i64(q11, n2_after_ic, 0);
        let q13: EmitState = emit_mic3_tree_body(q12, nodes, n2_re, vidbuf, src, strbuf, offs, ncount, n2_s2);
        let q14: EmitState = emit_mic3_return(q13, 1, n2_ir_vid);
        let q15: EmitState = emit_uleb128(q14, n2_ir_vid);
        // inner else = synth
        let q16: EmitState = emit_uleb128(q15, 1);
        let q17: EmitState = emit_mic3_const_i64(q16, n2_after_ir, 0);
        let q18: EmitState = emit_uleb128(q17, n2_after_ir);
        // inner dst + bindings + merges
        let q19: EmitState = emit_uleb128(q18, n2_inner_dst);
        let q20: EmitState = emit_uleb128(q19, 0);
        let q21: EmitState = emit_uleb128(q20, 0);
        // outer then-result = inner dst
        let q22: EmitState = emit_uleb128(q21, n2_inner_dst);
        // outer else = synth
        let q23: EmitState = emit_uleb128(q22, 1);
        let q24: EmitState = emit_mic3_const_i64(q23, n2_outer_else, 0);
        let q25: EmitState = emit_uleb128(q24, n2_outer_else);
        // outer dst + bindings + merges
        let q26: EmitState = emit_uleb128(q25, n2_outer_dst);
        let q27: EmitState = emit_uleb128(q26, 0);
        let q28: EmitState = emit_uleb128(q27, 0);
        return emit_stmt_seq(q28, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, n2_outer_dst + 1, i + 1, seq_lvbuf, seq_nlv);
    }
    // if-return block. Recompute the same vid layout as Pass B to learn synth/dst.
    let cstart: i64 = __mind_load_i64(plan + i * 64 + 8);
    let cend: i64 = __mind_load_i64(plan + i * 64 + 16);
    let cond_root: i64 = __mind_load_i64(plan + i * 64 + 24);
    let rstart: i64 = __mind_load_i64(plan + i * 64 + 32);
    let rend: i64 = __mind_load_i64(plan + i * 64 + 40);
    let ret_root: i64 = __mind_load_i64(plan + i * 64 + 48);
    let after_cond: i64 = base + count_descriptor_nonparam_range(nodes, cstart, cend);
    let then_synth: i64 = after_cond;
    let ret_n: i64 = count_descriptor_nonparam_range(nodes, rstart, rend);
    let after_ret: i64 = after_cond + 1 + ret_n;
    let else_synth: i64 = after_ret;
    let dst: i64 = after_ret + 1;
    let cond_vid: i64 = __mind_load_i64(vidbuf + cond_root * 8);
    let ret_vid: i64 = __mind_load_i64(vidbuf + ret_root * 8);
    // OP_IF: cond.
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_vid);
    let cond_n: i64 = count_descriptor_nonparam_range(nodes, cstart, cend);
    let s3: EmitState = emit_uleb128(s2, cond_n);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cend, vidbuf, src, strbuf, offs, ncount, cstart);
    // then: synth const + ret tree + Return(ret_vid). length = ret_n + 2.
    let s5: EmitState = emit_uleb128(s4, ret_n + 2);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, rend, vidbuf, src, strbuf, offs, ncount, rstart);
    let s8: EmitState = emit_mic3_return(s7, 1, ret_vid);
    let s9: EmitState = emit_uleb128(s8, ret_vid);
    // else: synth const only.
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    // dst + empty bindings + empty merges.
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    emit_stmt_seq(s15, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, dst + 1, i + 1, seq_lvbuf, seq_nlv)
}

// Emit ONE fn's FN_DEF whose body is a general statement sequence (lets and
// if-early-returns in any order, then a trailing value expr). Generalises cases
// (f)+(g). Writes 1 to ok_cell on success, 0 (fail-closed, returns seed `s`) on any
// wall. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_mic3_module_fndef_seq(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, env: i64, nlets_cell: i64, plan: i64, nplan_cell: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    __mind_store_i64(nplan_cell, 0);
    let plan_ok: i64 = flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, 0);
    if plan_ok == 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let nplan: i64 = __mind_load_i64(nplan_cell);
    // Trailing value expr (the final statement) -> the FN_DEF ret vid.
    let trail_start: i64 = __mind_load_i64(cursor);
    let final_expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    let trail_root: i64 = flatten_expr_env(final_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
    if trail_root < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_end: i64 = __mind_load_i64(cursor);
    // Pass B — assign vids across statement segments (lets + OP_IF blocks).
    let trail_base: i64 = seq_assign_vids(nodes, vidbuf, plan, nplan, n_params, 0);
    // Trailing segment resolves last, from trail_base.
    seq_resolve_range(nodes, trail_start, trail_end, vidbuf, trail_base);
    let ret_vid: i64 = __mind_load_i64(vidbuf + trail_root * 8);
    // body_len = n_params PARAMs + per-segment non-param body instrs + 1 per OP_IF.
    let seg_instrs: i64 = seq_body_len(nodes, plan, nplan, 0);
    let trail_instrs: i64 = count_descriptor_nonparam_range(nodes, trail_start, trail_end);
    let body_len: i64 = n_params + seg_instrs + trail_instrs;
    // Build the RESOLVED seq lv-env (sequence-level lets -> their vids) so type-3/4/5
    // segment conds/inits can reference earlier sequence lets (e.g. `if n == 2`).
    let seq_lvbuf: i64 = __mind_alloc((nlets + 1) * 24);
    let seq_nlv: i64 = seq_env_to_lvenv(env, nlets, vidbuf, seq_lvbuf, 1, 0);
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, ret_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_stmt_seq(s7, nodes, vidbuf, src, strbuf, offs, ncount, plan, nplan, n_params, 0, seq_lvbuf, seq_nlv);
    let s9: EmitState = emit_mic3_tree_body(s8, nodes, trail_end, vidbuf, src, strbuf, offs, ncount, trail_start);
    __mind_store_i64(ok_cell, 1);
    s9
}

// body_len contribution of the statement segments: each let segment's non-param
// descriptor instrs, plus 1 OP_IF instr per if-return block (its cond/then/else
// trees live INSIDE the OP_IF, so they do NOT count as top-level body instrs).
pub fn seq_body_len(nodes: i64, plan: i64, nplan: i64, i: i64) -> i64 {
    if i >= nplan {
        return 0;
    }
    let ty: i64 = __mind_load_i64(plan + i * 64 + 0);
    if ty == 0 {
        let start: i64 = __mind_load_i64(plan + i * 64 + 8);
        let end: i64 = __mind_load_i64(plan + i * 64 + 16);
        return count_descriptor_nonparam_range(nodes, start, end) + seq_body_len(nodes, plan, nplan, i + 1);
    }
    1 + seq_body_len(nodes, plan, nplan, i + 1)
}

// ===========================================================================
// FIELD-READ PRE-RESOLVE (call-fold) — rewrite `recv.field` AST nodes into the
// equivalent `__mind_load_i64(field_addr)` Call subtree BEFORE flatten_ast runs.
// flatten_ast/flatten_expr_env/count_nonparam_nodes already lower calls (kind
// 3/4/5) with zero threading, so this is a PURE in-place AST rewrite — no new
// params on flatten_ast and no dedicated shape-case. Mirrors lower.rs's
// FieldAccess resolved arm: idx==0 -> addr is the receiver vid directly; idx>0
// -> ConstI64(idx*8) + BinOp Add(recv, off); then Call("__mind_load_i64",[addr]).
// Fail-closed: an unresolvable field read is left as ast_field (flatten rejects
// it), so the module simply fails to emit — never partial/wrong bytes.
// ===========================================================================

// Match the 15-byte literal "__mind_load_i64" in `src` starting at offset `at`.
pub fn load_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 15 {
        return 1;
    }
    let want: i64 = load_i64_name_byte(j);
    if load_byte(src, at + j) != want {
        return 0;
    }
    load_name_matches_at(src, at + 0, j + 1)
}

// Scan `src[0..len)` for the literal "__mind_load_i64"; store [lo,hi) of the
// first occurrence into the 2-i64 cell and return 1, else 0. Used so the
// pre-fold's synthetic callee leaf carries a REAL source span (whose interned
// bytes equal the oracle's "__mind_load_i64" string-table entry).
pub fn find_load_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 15 > len {
        return 0;
    }
    if load_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 15);
        return 1;
    }
    find_load_name_span(src, len, i + 1, cell)
}

// Build a synthetic int-literal leaf carrying `value` DIRECTLY (no source decimal
// to parse): child0(+24)=value, child1(+32)=1 SENTINEL (flatten reads child0 when
// child1==1; real source int-lits have child1==0). Used for the idx*8 field offset.
pub fn mk_syn_intlit(value: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_int_lit());
    __mind_store_i64(n + 8, 0);
    __mind_store_i64(n + 16, 0);
    __mind_store_i64(n + 24, value);
    __mind_store_i64(n + 32, 1);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

// Resolve `recv.field` (recv an ast_ident param of struct type) to the field
// index. `fn_node` supplies the params; `srt` the struct registry. Returns the
// 0-based field index, or -1 on any failure (unknown param / non-struct type /
// unknown field) — fail-closed.
pub fn field_recv_field_idx(fn_node: i64, src: i64, srt: i64, recv_lo: i64, recv_hi: i64, fld_lo: i64, fld_hi: i64) -> i64 {
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let pidx: i64 = resolve_param(params_addr, n_params, src, recv_lo, recv_hi);
    if pidx < 0 {
        return 0 - 1;
    }
    let pnode: i64 = __mind_load_i64(params_addr + pidx * 8);
    let ty: i64 = ast_child1(pnode);
    let k: i64 = srt_find_by_name(srt, src, ast_span_lo(ty), ast_span_hi(ty), 0);
    if k < 0 {
        return 0 - 1;
    }
    srt_field_index(srt, k, src, fld_lo, fld_hi, 0)
}

// Build the `__mind_load_i64(field_addr)` Call subtree for `recv.field` at field
// index `fidx`. idx==0 -> addr is the receiver node directly; idx>0 -> Add(recv,
// const idx*8). callee = ast_ident leaf spanning the source "__mind_load_i64".
pub fn field_build_load_call(recv_node: i64, fidx: i64, load_lo: i64, load_hi: i64) -> i64 {
    let addr: i64 = if fidx == 0 {
        recv_node
    } else {
        ast_new_binop(0, 0, recv_node, mk_syn_intlit(fidx * 8), op_add())
    };
    let callee: i64 = ast_new_leaf(ast_ident(), load_lo, load_hi);
    let args: i64 = __mind_alloc(8);
    __mind_store_i64(args + 0, addr);
    ast_new_call(0, 0, callee, args, 1)
}

// Recursively rewrite every resolvable `recv.field` node under `node` into the
// load-call subtree, in place. Returns the (possibly new) node to store back.
// ast_field with an ast_ident receiver that resolves -> the load call; otherwise
// the node is returned unchanged (fail-closed). Recurses through paren / binop /
// neg / not / call args, storing rewritten children back into their slots.
pub fn field_rewrite_expr(node: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if node == 0 {
        return 0;
    }
    let k: i64 = ast_kind(node);
    if k == ast_field() {
        let recv: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, recv);
        if ast_kind(recv) != ast_ident() {
            return node;
        }
        let fidx: i64 = field_recv_field_idx(fn_node, src, srt, ast_span_lo(recv), ast_span_hi(recv), ast_child1(node), ast_child2(node));
        if fidx < 0 {
            return node;
        }
        return field_build_load_call(recv, fidx, load_lo, load_hi);
    }
    if k == ast_paren() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_neg() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_not() {
        let inner: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, inner);
        return node;
    }
    if k == ast_binop() {
        let l: i64 = field_rewrite_expr(ast_child0(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 24, l);
        let r: i64 = field_rewrite_expr(ast_child1(node), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(node + 32, r);
        return node;
    }
    if k == ast_call() {
        let _a: i64 = field_rewrite_args(ast_child1(node), ast_aux(node), 0, src, srt, fn_node, load_lo, load_hi);
        return node;
    }
    node
}

// Rewrite each arg of a call's args vec in place.
pub fn field_rewrite_args(args_addr: i64, args_len: i64, i: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + i * 8);
    let na: i64 = field_rewrite_expr(arg, src, srt, fn_node, load_lo, load_hi);
    __mind_store_i64(args_addr + i * 8, na);
    field_rewrite_args(args_addr, args_len, i + 1, src, srt, fn_node, load_lo, load_hi)
}

// Rewrite each statement of a fn body block in place: let -> rewrite init
// (child2/+40); return -> rewrite value (child0/+24); if -> cond + then/else
// blocks; block -> recurse its stmts; else -> rewrite the stmt expr in place.
pub fn field_rewrite_stmts(stmts_addr: i64, stmts_len: i64, i: i64, src: i64, srt: i64, fn_node: i64, load_lo: i64, load_hi: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let init: i64 = field_rewrite_expr(ast_child2(stmt), src, srt, fn_node, load_lo, load_hi);
        __mind_store_i64(stmt + 40, init);
    } else {
        if k == ast_return() {
            let v: i64 = field_rewrite_expr(ast_child0(stmt), src, srt, fn_node, load_lo, load_hi);
            __mind_store_i64(stmt + 24, v);
        } else {
            if k == ast_if() {
                let c: i64 = field_rewrite_expr(ast_child0(stmt), src, srt, fn_node, load_lo, load_hi);
                __mind_store_i64(stmt + 24, c);
                let then_blk: i64 = ast_child1(stmt);
                if ast_kind(then_blk) == ast_block() {
                    let _t: i64 = field_rewrite_stmts(ast_child0(then_blk), ast_aux(then_blk), 0, src, srt, fn_node, load_lo, load_hi);
                }
                let else_blk: i64 = ast_child2(stmt);
                if else_blk != 0 {
                    if ast_kind(else_blk) == ast_block() {
                        let _e: i64 = field_rewrite_stmts(ast_child0(else_blk), ast_aux(else_blk), 0, src, srt, fn_node, load_lo, load_hi);
                    }
                }
            } else {
                let e: i64 = field_rewrite_expr(stmt, src, srt, fn_node, load_lo, load_hi);
                __mind_store_i64(stmts_addr + i * 8, e);
            }
        }
    }
    field_rewrite_stmts(stmts_addr, stmts_len, i + 1, src, srt, fn_node, load_lo, load_hi)
}

// Pre-fold one fn's body. Guard: at least one struct in the registry AND the
// literal "__mind_load_i64" present in source (else no fold can resolve and the
// callee span would be invalid). Rewrites the body block's statements in place.
pub fn field_prefold_body(src: i64, src_len: i64, fn_node: i64, srt: i64) -> i64 {
    if srt_count(srt) < 1 {
        return 0;
    }
    let cell: i64 = __mind_alloc(16);
    if find_load_name_span(src, src_len, 0, cell) == 0 {
        return 0;
    }
    let load_lo: i64 = __mind_load_i64(cell + 0);
    let load_hi: i64 = __mind_load_i64(cell + 8);
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    field_rewrite_stmts(stmts_addr, stmts_len, 0, src, srt, fn_node, load_lo, load_hi)
}

// Iterate every top-level fn_def, pre-folding its body. Other items are skipped.
pub fn field_prefold_module(src: i64, src_len: i64, items_addr: i64, items_len: i64, i: i64, srt: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let _r: i64 = field_prefold_body(src, src_len, item, srt);
    }
    field_prefold_module(src, src_len, items_addr, items_len, i + 1, srt)
}

// ===========================================================================
// STRUCT-LIT CONSTRUCTION DESUGAR — pre-resolve `T { a: x, b: y }` into the
// alloc+stores+ret let-chain the oracle lowers it to (src/eval/lower.rs StructLit
// arm; see the intern_*_literal comment block): `let __sl = __mind_alloc(8 *
// nfields); __mind_store_i64(__sl (+ idx*8), val) per field in DECLARED order; __sl`.
// Run in the prefold pass BEFORE build_module_strtab so __mind_alloc / __mind_store_i64
// intern in body order, and the resulting let-chain emits via the proven case (f).
// Synthetic let names reuse the `__mind_alloc` (ptr) / `__mind_store_i64` (throwaway)
// source spans — letenv resolves by source-byte span, and those literals are present
// in the module (they are the call callees). NO threading; flatten_ast unchanged.
// ===========================================================================

// "__mind_alloc" (12 bytes) per-index byte source.
pub fn alloc_name_byte(j: i64) -> i64 {
    if j == 0 { return 95; }
    if j == 1 { return 95; }
    if j == 2 { return 109; }
    if j == 3 { return 105; }
    if j == 4 { return 110; }
    if j == 5 { return 100; }
    if j == 6 { return 95; }
    if j == 7 { return 97; }
    if j == 8 { return 108; }
    if j == 9 { return 108; }
    if j == 10 { return 111; }
    99
}

pub fn alloc_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 12 {
        return 1;
    }
    if load_byte(src, at + j) != alloc_name_byte(j) {
        return 0;
    }
    alloc_name_matches_at(src, at, j + 1)
}

pub fn find_alloc_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 12 > len {
        return 0;
    }
    if alloc_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 12);
        return 1;
    }
    find_alloc_name_span(src, len, i + 1, cell)
}

// "__mind_store_i64" (16 bytes) per-index byte source.
pub fn store_name_byte(j: i64) -> i64 {
    if j == 0 { return 95; }
    if j == 1 { return 95; }
    if j == 2 { return 109; }
    if j == 3 { return 105; }
    if j == 4 { return 110; }
    if j == 5 { return 100; }
    if j == 6 { return 95; }
    if j == 7 { return 115; }
    if j == 8 { return 116; }
    if j == 9 { return 111; }
    if j == 10 { return 114; }
    if j == 11 { return 101; }
    if j == 12 { return 95; }
    if j == 13 { return 105; }
    if j == 14 { return 54; }
    52
}

pub fn store_name_matches_at(src: i64, at: i64, j: i64) -> i64 {
    if j >= 16 {
        return 1;
    }
    if load_byte(src, at + j) != store_name_byte(j) {
        return 0;
    }
    store_name_matches_at(src, at, j + 1)
}

pub fn find_store_name_span(src: i64, len: i64, i: i64, cell: i64) -> i64 {
    if i + 16 > len {
        return 0;
    }
    if store_name_matches_at(src, i, 0) == 1 {
        __mind_store_i64(cell + 0, i);
        __mind_store_i64(cell + 8, i + 16);
        return 1;
    }
    find_store_name_span(src, len, i + 1, cell)
}

// Value node for CANONICAL field `j` of struct `k` (match its declared name span
// against the source-order triples). Returns the value AST node, or 0 if absent.
pub fn slit_canon_value(fields_addr: i64, ntriples: i64, src: i64, srt: i64, k: i64, j: i64) -> i64 {
    let clo: i64 = srt_field_lo(srt, k, j);
    let chi: i64 = srt_field_hi(srt, k, j);
    slit_value_for(fields_addr, ntriples, src, clo, chi, 0)
}

// Build `let __sN = __mind_store_i64(addr, val)` for canonical field index `j`:
// addr = ptr ref (j==0) or Add(ptr, idx*8). The let name + ptr ref reuse the
// `__mind_alloc` span (alo/ahi); the store callee + let name reuse `__mind_store_i64`.
pub fn slit_build_store_let(alo: i64, ahi: i64, slo: i64, shi: i64, j: i64, val: i64) -> i64 {
    let sl_ref: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let addr: i64 = if j == 0 {
        sl_ref
    } else {
        ast_new_binop(0, 0, sl_ref, mk_syn_intlit(j * 8), op_add())
    };
    let callee: i64 = ast_new_leaf(ast_ident(), slo, shi);
    let args: i64 = __mind_alloc(16);
    __mind_store_i64(args + 0, addr);
    __mind_store_i64(args + 8, val);
    let call: i64 = ast_new_call(0, 0, callee, args, 2);
    let name: i64 = ast_new_leaf(ast_ident(), slo, shi);
    ast_new_let(0, 0, name, 0, call)
}

// Fill new_stmts[1 .. 1+nfields] with per-canonical-field store-lets. Returns 1, or
// 0 if any canonical field is missing from the literal (fail-closed).
pub fn slit_fill_stores(new_stmts: i64, fields_addr: i64, ntriples: i64, src: i64, srt: i64, k: i64, nfields: i64, alo: i64, ahi: i64, slo: i64, shi: i64, j: i64) -> i64 {
    if j >= nfields {
        return 1;
    }
    let val: i64 = slit_canon_value(fields_addr, ntriples, src, srt, k, j);
    if val == 0 {
        return 0;
    }
    let slet: i64 = slit_build_store_let(alo, ahi, slo, shi, j, val);
    __mind_store_i64(new_stmts + (1 + j) * 8, slet);
    slit_fill_stores(new_stmts, fields_addr, ntriples, src, srt, k, nfields, alo, ahi, slo, shi, j + 1)
}

// Desugar a single-stmt struct-lit-bodied fn body in place into the let-chain.
// Returns 1 if rewritten, 0 if not applicable (body left intact, fails closed later).
pub fn slit_desugar_body(fn_node: i64, src: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0;
    }
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    if ast_kind(snode) != ast_struct_lit() {
        return 0;
    }
    let ty_lo: i64 = ast_child0(snode);
    let ty_hi: i64 = ast_child2(snode);
    let k: i64 = srt_find_by_name(srt, src, ty_lo, ty_hi, 0);
    if k < 0 {
        return 0;
    }
    let nfields: i64 = srt_field_count(srt, k);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    if ntriples != nfields {
        return 0;
    }
    let new_len: i64 = nfields + 2;
    let new_stmts: i64 = __mind_alloc(new_len * 8);
    // (0) `let __sl = __mind_alloc(8 * nfields)`.
    let size: i64 = ast_new_binop(0, 0, mk_syn_intlit(8), mk_syn_intlit(nfields), op_mul());
    let acallee: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let aargs: i64 = __mind_alloc(8);
    __mind_store_i64(aargs + 0, size);
    let acall: i64 = ast_new_call(0, 0, acallee, aargs, 1);
    let aname: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    let alet: i64 = ast_new_let(0, 0, aname, 0, acall);
    __mind_store_i64(new_stmts + 0, alet);
    // (1..nfields) per-field stores in canonical order.
    let okf: i64 = slit_fill_stores(new_stmts, fields_addr, ntriples, src, srt, k, nfields, alo, ahi, slo, shi, 0);
    if okf == 0 {
        return 0;
    }
    // (last) trailing ptr ref -> ret vid = alloc vid.
    let tref: i64 = ast_new_leaf(ast_ident(), alo, ahi);
    __mind_store_i64(new_stmts + (nfields + 1) * 8, tref);
    // Replace the body block's statements (child0 = stmts_addr, aux = stmts_len).
    __mind_store_i64(body + 24, new_stmts);
    __mind_store_i64(body + 48, new_len);
    1
}

// Module pass: desugar struct-lit ctors in every top-level fn_def.
pub fn slit_desugar_module(src: i64, src_len: i64, items_addr: i64, items_len: i64, srt: i64, alo: i64, ahi: i64, slo: i64, shi: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let _r: i64 = slit_desugar_body(item, src, srt, alo, ahi, slo, shi);
    }
    slit_desugar_module(src, src_len, items_addr, items_len, srt, alo, ahi, slo, shi, i + 1)
}

// Emit the FN_DEF (body) for one function, dispatching on its proven shape. Does
// NOT emit the module-level scaffold (the caller appends emit_mic3_scaffold(k)).
// Writes a 1 into ok_cell on a matched shape, 0 (fail-closed) otherwise; on a
// miss the returned state is unspecified (the caller discards the whole module).
pub fn emit_mic3_module_fndef(s: EmitState, src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let nidx: i64 = fn_name_idx(src, fn_node, strbuf, offs, ncount);
    if nidx < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    // (a) zero-arg const-return.
    let cv: i64 = const_fn_value(src, fn_node);
    if cv >= 0 {
        __mind_store_i64(ok_cell, 1);
        return emit_mic3_fndef_const(s, nidx, cv);
    }
    // (b) 2-param arith (direct `pa OP pb`, or `let t = pa OP pb; t`).
    let ob_direct: i64 = arith_fn_opbyte(src, fn_node);
    let ob_let: i64 = let_arith_fn_opbyte(src, fn_node);
    let ob: i64 = if ob_direct >= 0 {
        ob_direct
    } else {
        ob_let
    };
    if ob >= 0 {
        let pscratch: i64 = __mind_alloc(16);
        let pok: i64 = arith_param_str_idxs(src, fn_node, strbuf, offs, ncount, pscratch);
        if pok == 1 {
            __mind_store_i64(ok_cell, 1);
            let p0i: i64 = __mind_load_i64(pscratch + 0);
            let p1i: i64 = __mind_load_i64(pscratch + 8);
            return emit_mic3_fndef_arith(s, nidx, p0i, p1i, ob);
        }
    }
    // (c) zero-arg CALL with two int-literal args.
    let ascratch: i64 = __mind_alloc(16);
    let aok: i64 = call_fn_args2(src, fn_node, ascratch);
    if aok == 1 {
        let cidx: i64 = call_fn_callee_idx(src, fn_node, strbuf, offs, ncount);
        if cidx >= 0 {
            __mind_store_i64(ok_cell, 1);
            let cva: i64 = __mind_load_i64(ascratch + 0);
            let cvb: i64 = __mind_load_i64(ascratch + 8);
            return emit_mic3_fndef_call(s, nidx, cidx, cva, cvb);
        }
    }
    // Beyond the three narrow shapes: an arbitrary expression-tree body OR a single
    // if-expression body, both wired to the already-proven per-fn emitters. Both
    // need the module-wide param string indices and per-fn tree scratch.
    let n_params: i64 = ast_aux(fn_node) / 2;
    let pstr: i64 = __mind_alloc(n_params * 8 + 8);
    let pres: i64 = module_param_str_idxs(src, fn_node, strbuf, offs, ncount, pstr, 0);
    if pres == 1 {
        let body: i64 = ast_child2(fn_node);
        let stmts_addr: i64 = ast_child0(body);
        let stmts_len: i64 = ast_aux(body);
        if stmts_len == 1 {
            let expr: i64 = __mind_load_i64(stmts_addr + 0);
            let nodes: i64 = __mind_alloc(256 * 32);
            let cursor: i64 = __mind_alloc(8);
            let vidbuf: i64 = __mind_alloc(256 * 8);
            // (e) single if-expression value: if cond { then } else { else }, each
            // branch a single param/const/binop expression (empty merges/bindings).
            if ast_kind(expr) == ast_if() {
                let else_blk: i64 = ast_child2(expr);
                if else_blk != 0 {
                    let cond_expr: i64 = ast_child0(expr);
                    let then_expr: i64 = branch_single_expr(ast_child1(expr));
                    let else_expr: i64 = branch_single_expr(else_blk);
                    if then_expr >= 0 {
                        if else_expr >= 0 {
                            let sif: EmitState = emit_mic3_module_fndef_if(s, src, fn_node, nidx, pstr, n_params, cond_expr, then_expr, else_expr, nodes, cursor, vidbuf, ok_cell);
                            if __mind_load_i64(ok_cell) == 1 {
                                return sif;
                            }
                        }
                    }
                }
            }
            // (d) arbitrary param/const/binop expression tree.
            if ast_kind(expr) != ast_if() {
                let stree: EmitState = emit_mic3_module_fndef_tree(s, src, strbuf, offs, ncount, fn_node, nidx, pstr, n_params, expr, nodes, cursor, vidbuf, ok_cell);
                if __mind_load_i64(ok_cell) == 1 {
                    return stree;
                }
            }
        }
        // (f) multi-statement let chain: >1 stmts, a sequence of `let NAME = INIT`
        // bindings then a trailing value expression (every init/expr a param /
        // const / binop / let-ref tree). Substitution-equivalent to the nested
        // expression, so byte-exact vs --emit-mic3.
        if stmts_len >= 2 {
            let nodes2: i64 = __mind_alloc(256 * 32);
            let cursor2: i64 = __mind_alloc(8);
            let vidbuf2: i64 = __mind_alloc(256 * 8);
            let env: i64 = __mind_alloc(64 * 24);
            let nlets_cell: i64 = __mind_alloc(8);
            let slet: EmitState = emit_mic3_module_fndef_letchain(s, src, fn_node, nidx, pstr, n_params, stmts_addr, stmts_len, nodes2, cursor2, vidbuf2, env, nlets_cell, strbuf, offs, ncount, ok_cell);
            if __mind_load_i64(ok_cell) == 1 {
                return slet;
            }
        }
        // (g) if-statement early-return: exactly 2 stmts where stmt[0] is an
        // else-less if whose then-block's single statement is `return E`, and
        // stmt[1] is a trailing param/const/binop value expr. Byte-exact vs
        // --emit-mic3 (additive; the canary path is untouched).
        if stmts_len == 2 {
            let if_stmt: i64 = __mind_load_i64(stmts_addr + 0);
            if ast_kind(if_stmt) == ast_if() {
                if ast_child2(if_stmt) == 0 {
                    let then_blk: i64 = ast_child1(if_stmt);
                    let ret_stmt: i64 = branch_single_expr(then_blk);
                    if ret_stmt >= 0 {
                        // (g2) NESTED if-return: the then-block's single stmt is ITSELF
                        // an else-less if whose then-block is `return E` -> nested OP_IF.
                        if ast_kind(ret_stmt) == ast_if() {
                            // RECURSIVE if-chain (any depth): then-block's single stmt is
                            // itself an else-less if. The chain emitter validates + emits
                            // arbitrary depth; supersedes the depth-2 dedicated case.
                            let ntrail: i64 = __mind_load_i64(stmts_addr + 8);
                            let cnodes: i64 = __mind_alloc(256 * 32);
                            let ccursor: i64 = __mind_alloc(8);
                            let cvidbuf: i64 = __mind_alloc(256 * 8);
                            let ctnodes: i64 = __mind_alloc(256 * 32);
                            let ctcursor: i64 = __mind_alloc(8);
                            let ctvidbuf: i64 = __mind_alloc(256 * 8);
                            let snif: EmitState = emit_mic3_module_fndef_if_chain(s, src, fn_node, nidx, pstr, n_params, if_stmt, ntrail, cnodes, ccursor, cvidbuf, ctnodes, ctcursor, ctvidbuf, ok_cell);
                            if __mind_load_i64(ok_cell) == 1 {
                                return snif;
                            }
                        }
                        if ast_kind(ret_stmt) == ast_return() {
                            let cond_expr: i64 = ast_child0(if_stmt);
                            let ret_expr: i64 = ast_child0(ret_stmt);
                            let trail_expr: i64 = __mind_load_i64(stmts_addr + 8);
                            let gnodes: i64 = __mind_alloc(256 * 32);
                            let gcursor: i64 = __mind_alloc(8);
                            let gvidbuf: i64 = __mind_alloc(256 * 8);
                            let tnodes: i64 = __mind_alloc(256 * 32);
                            let tcursor: i64 = __mind_alloc(8);
                            let tvidbuf: i64 = __mind_alloc(256 * 8);
                            let sif: EmitState = emit_mic3_module_fndef_ifstmt(s, src, fn_node, nidx, pstr, n_params, cond_expr, ret_expr, trail_expr, gnodes, gcursor, gvidbuf, tnodes, tcursor, tvidbuf, ok_cell);
                            if __mind_load_i64(ok_cell) == 1 {
                                return sif;
                            }
                        }
                    }
                }
            }
        }
        // (h) GENERAL statement sequence: >1 stmts mixing `let NAME = INIT` and
        // `if COND { return E; }` in arbitrary order, then a trailing value expr.
        // Strict superset of (f)+(g); reached only when those narrow shapes miss.
        // Byte-exact vs --emit-mic3 (additive; canary untouched).
        if stmts_len >= 2 {
            let hnodes: i64 = __mind_alloc(512 * 32);
            let hcursor: i64 = __mind_alloc(8);
            let hvidbuf: i64 = __mind_alloc(512 * 8);
            let henv: i64 = __mind_alloc(64 * 24);
            let hnlets: i64 = __mind_alloc(8);
            let hplan: i64 = __mind_alloc(64 * 64);
            let hnplan: i64 = __mind_alloc(8);
            let sseq: EmitState = emit_mic3_module_fndef_seq(s, src, fn_node, nidx, pstr, n_params, stmts_addr, stmts_len, hnodes, hcursor, hvidbuf, henv, hnlets, hplan, hnplan, strbuf, offs, ncount, ok_cell);
            if __mind_load_i64(ok_cell) == 1 {
                return sseq;
            }
        }
    }
    __mind_store_i64(ok_cell, 0);
    s
}

// Loop over the N top-level fn_defs (k = 0..n_fns), emitting each FN_DEF then its
// scaffold ConstI64(%k,0)/Output(%k). If any fn's shape is unmatched, ok_cell is
// left 0 and the caller fails the whole module closed. `k`/`item_i` advance in
// lockstep: k counts fn_defs seen, item_i walks the raw item array.
pub fn emit_mic3_module_fns_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return emit_mic3_module_fns_loop(s, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k, item_i + 1);
    }
    let s1: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return s1;
    }
    let s2: EmitState = emit_mic3_scaffold(s1, k);
    emit_mic3_module_fns_loop(s2, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1)
}

// ITEM-ORDER N-ITEM module loop: walk EVERY top-level item in declaration order,
// emitting one module-level scaffold per item at the running vid `k` (which counts
// BOTH struct decls and fn defs, matching the oracle's flat module-level vid space).
// A struct decl emits only its CONST/OUTPUT placeholder pair; a fn def emits its
// FN_DEF body then its placeholder pair. Fails closed via ok_cell on any unmatched
// fn shape. Generalizes emit_mic3_module_fns_loop (fns only) to struct-containing
// modules so the scaffold vids interleave exactly as --emit-mic3 produces them.
pub fn emit_mic3_module_items_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        // Struct (or other non-fn) decl: scaffold-only placeholder at vid k.
        let ss: EmitState = emit_mic3_scaffold(s, k);
        return emit_mic3_module_items_loop(ss, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1);
    }
    let s1: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return s1;
    }
    let s2: EmitState = emit_mic3_scaffold(s1, k);
    emit_mic3_module_items_loop(s2, src, items_addr, items_len, strbuf, offs, ncount, ok_cell, k + 1, item_i + 1)
}

// AST-DRIVEN N-FUNCTION module driver: lex+parse `src`, build the deduped
// first-seen string table, then assemble a complete mic@3 module for ANY number
// of functions whose bodies are the proven shapes, byte-exact vs --emit-mic3.
// Fails closed (es_new(), empty buf) when fewer than 1 fn is present or any fn's
// shape is unmatched.
pub fn selftest_mic3_module_nfn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Multi-struct registry (declaration order with per-struct field spans). N==0
    // for struct-less modules, in which case the registry/strtab tail stays empty
    // and the bytes are unchanged from the original fns-only path.
    let srt: i64 = srt_build(src_addr, src_len);
    let n_structs: i64 = srt_count(srt);
    // STRUCT-LIT CONSTRUCTION DESUGAR: rewrite `T{..}` ctors into the
    // alloc+stores+ret let-chain BEFORE the strtab pass (so __mind_alloc /
    // __mind_store_i64 intern in body order) and BEFORE the field-read prefold (so
    // field-read values inside store args still fold). No-op when those literals are
    // absent from source or no fn constructs a struct (fails closed downstream).
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, slit_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, slit_scell) == 1 {
            let _sl: i64 = slit_desugar_module(src_addr, src_len, items_addr, items_len, srt, __mind_load_i64(slit_acell + 0), __mind_load_i64(slit_acell + 8), __mind_load_i64(slit_scell + 0), __mind_load_i64(slit_scell + 8), 0);
        }
    }
    // FIELD-READ PRE-RESOLVE: rewrite every resolvable `recv.field` into the
    // equivalent `__mind_load_i64(field_addr)` Call subtree, IN PLACE, BEFORE the
    // strtab pass. Order is load-bearing: the oracle interns "__mind_load_i64" at
    // the field-read's first-seen position, so the strtab must walk the rewritten
    // calls (not ast_field) to match the oracle's first-seen string order.
    let _pf: i64 = field_prefold_module(src_addr, src_len, items_addr, items_len, 0, srt);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    // Append every struct's TYPE + FIELD names to the strtab in BTreeMap-sorted
    // (struct-name) order, matching the oracle's collect_struct_def_strings pass
    // (registry strings come AFTER all instruction strings). intern_span dedups, so
    // a struct/field name that already appeared as a fn/param name reuses its slot.
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let n_fns: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    if n_fns < 1 {
        return es_new();
    }
    // header || strtab || next_id(=n_structs+n_fns) || exports(0) ||
    //   instr_count(=2*n_structs + 3*n_fns: each struct const+output, each fn
    //   FN_DEF+const+output).
    let n_items: i64 = n_structs + n_fns;
    let s1: EmitState = emit_mic3_header(es_new());
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, ncount);
    let s3: EmitState = emit_uleb128(s2, n_items);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, n_structs + n_structs + n_fns + n_fns + n_fns);
    // Per-item placeholder + per-fn FN_DEF, in declaration order, threaded through
    // one ok_cell. The running vid counts both structs and fns (flat module space).
    let ok_cell: i64 = __mind_alloc(8);
    __mind_store_i64(ok_cell, 1);
    let s6: EmitState = emit_mic3_module_items_loop(s5, src_addr, items_addr, items_len, strbuf, offs, ncount, ok_cell, 0, 0);
    if __mind_load_i64(ok_cell) == 0 {
        return es_new();
    }
    // Registries: populated struct_defs (BTreeMap-sorted, sorted-rank strbases)
    // when structs exist, else the empty triple. const_array_defs / repr_c = 0.
    if n_structs == 0 {
        return emit_mic3_empty_registries(s6);
    }
    let s7: EmitState = emit_uleb128(s6, n_structs);
    let s8: EmitState = srt_emit_registry_sorted_interned(s7, strbuf, offs, ccell, src_addr, srt, 0);
    let s9: EmitState = emit_uleb128(s8, 0);
    emit_uleb128(s9, 0)
}

// DIAGNOSTIC (cutover tooling): walk every fn_def, emit_mic3_module_fndef each, and
// return the SOURCE span_lo (fn-name byte offset) of the FIRST fn that fails closed
// (ok_cell==0), or -1 if all fns emit. Locates the next nfn-driver wall on main.mind.
pub fn nfn_first_fail_loop(src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, item_i: i64) -> i64 {
    if item_i >= items_len {
        return 0 - 1;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    if ast_kind(item) != ast_fn_def() {
        return nfn_first_fail_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1);
    }
    let ok: i64 = __mind_alloc(8);
    __mind_store_i64(ok, 1);
    let _s: EmitState = emit_mic3_module_fndef(es_new(), src, item, strbuf, offs, ncount, ok);
    if __mind_load_i64(ok) == 0 {
        let nm: i64 = ast_child0(item);
        return ast_span_lo(nm);
    }
    nfn_first_fail_loop(src, items_addr, items_len, strbuf, offs, ncount, item_i + 1)
}

pub fn selftest_nfn_fail_span(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let srt: i64 = srt_build(src_addr, src_len);
    let slit_acell: i64 = __mind_alloc(16);
    let slit_scell: i64 = __mind_alloc(16);
    if find_alloc_name_span(src_addr, src_len, 0, slit_acell) == 1 {
        if find_store_name_span(src_addr, src_len, 0, slit_scell) == 1 {
            let _sl: i64 = slit_desugar_module(src_addr, src_len, items_addr, items_len, srt, __mind_load_i64(slit_acell + 0), __mind_load_i64(slit_acell + 8), __mind_load_i64(slit_scell + 0), __mind_load_i64(slit_scell + 8), 0);
        }
    }
    let _pf: i64 = field_prefold_module(src_addr, src_len, items_addr, items_len, 0, srt);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let _sall: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src_addr, srt, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    nfn_first_fail_loop(src_addr, items_addr, items_len, strbuf, offs, ncount, 0)
}

// ===== mic@3 COMPLETE with-body module — the 2-param arithmetic function family (Phase 4c) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>, <pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust oracle. Extends Phase 4a (const-return) to functions with
// PARAMETERS and a real BINOP body. `buf`/`offs` carry 3 strings (name, pa, pb);
// `op_byte` is binop_to_byte(op) (0 = Add, as `a + b`). The exact shape emit_mic3 +
// the lowering produce (decoded from the oracle):
//   header || strtab(3:name,pa,pb) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0),(2,%1)], ret=%2, body=[PARAM %0, PARAM %1,
//            BINOP %2 = %0 op %1]} || ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// For add(a,b){a+b} (op_byte=0) this reproduces the 49-byte oracle byte-for-byte.
pub fn emit_mic3_arith_fn_module(s: EmitState, buf: i64, offs: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 3);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    emit_mic3_empty_registries(s20)
}

pub fn selftest_mic3_arith_fn(buf: i64, offs: i64, op_byte: i64) -> EmitState {
    emit_mic3_arith_fn_module(es_new(), buf, offs, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the single-param identity family (Phase 4d) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>) -> i64 { <pa> }`, byte-exact vs
// the Rust oracle. This is the FIRST function whose RETURN is a PARAMETER directly:
// the FN_DEF ret_vid is the param's own vid (%0) and the body is a single PARAM
// instruction — no BINOP, no body ConstI64 (distinct from Phase 4a const-return,
// where the body is a ConstI64, and Phase 4c arith, where the body is PARAM,PARAM,
// BINOP). `buf`/`offs` carry 2 strings (name, pa). The exact shape emit_mic3 + the
// lowering produce (decoded from the oracle for `ident(a){a}`, 38 bytes):
//   header || strtab(2:name,pa) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)], ret=%0, body=[PARAM %0]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_ident_fn_module(s: EmitState, buf: i64, offs: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_mic3_opt_vid(s10, 1, 0);
    let s12: EmitState = es_push(s11, 0);
    let s13: EmitState = emit_uleb128(s12, 1);
    let s14: EmitState = emit_mic3_param(s13, 0, 1, 0);
    let s15: EmitState = emit_mic3_const_i64(s14, 0, 0);
    let s16: EmitState = emit_mic3_output(s15, 0);
    emit_mic3_empty_registries(s16)
}

pub fn selftest_mic3_ident_fn(buf: i64, offs: i64) -> EmitState {
    emit_mic3_ident_fn_module(es_new(), buf, offs)
}

// ===== mic@3 COMPLETE with-body module — the N-param chained-binop family (Phase 4e) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { p0 OP p1 OP .. }`,
// byte-exact vs the Rust oracle, for N >= 2 left-associated binops of one op. This is
// the FIRST body that emits MORE THAN ONE BINOP where each consumes the previous
// binop's result: params take %0..%(n-1), then %n = %0 op %1, %(n+1) = %n op %2,
// %(n+2) = %(n+1) op %3, ... — the second operand of binop k (k>=1) is param %(k+1)
// and the first operand is the running accumulator %(n+k-1). The FN_DEF ret_vid is
// the FINAL binop's vid (2n-2) and body_len = n PARAMs + (n-1) BINOPs = 2n-1.
// `buf`/`offs` carry (n+1) strings (name then the n params, str_idx i+1 -> vid i);
// `op_byte` is binop_to_byte(op) (0 = Add). Decoded from the oracle for
// chain(a,b,c){a+b+c} (n=3, 64 bytes: ret %4, body_len 5) and
// chain4(a,b,c,d){a+b+c+d} (n=4, 78 bytes: ret %6, body_len 7). Generalizes the
// Phase 4c 2-param arith module (n=2 collapses to a single binop, identical shape).
//   header || strtab(n+1) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%(2n-2),
//            body=[PARAM %0..PARAM %(n-1), BINOP %n=%0 op %1,
//                  BINOP %(n+1)=%n op %2, ..]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_chain_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header (inline: name_idx=0, then encode_named_vids param list).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    // ret = Some %(2n-2) (final binop vid); reap None; body_len = 2n-1.
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, n + n - 2);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + n - 1);
    // Body: n PARAM instrs (%i, str i+1, index i), then the binop chain.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_chain_binops(s12, n, op_byte, 1);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// FN_DEF param list (encode_named_vids): uleb(n) then n pairs (str_idx i+1, vid i).
pub fn emit_mic3_chain_param_pairs(s: EmitState, n: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, n);
    emit_mic3_chain_param_pairs_loop(s1, n, 0)
}

pub fn emit_mic3_chain_param_pairs_loop(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, i + 1);
    let s2: EmitState = emit_uleb128(s1, i);
    emit_mic3_chain_param_pairs_loop(s2, n, i + 1)
}

// Body PARAM instrs: PARAM(%i, name=i+1, index=i) for i in 0..n.
pub fn emit_mic3_chain_params(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, i, i + 1, i);
    emit_mic3_chain_params(s1, n, i + 1)
}

// Body BINOP chain: for k in 1..n emit BINOP(dst=%(n+k-1), op, lhs, rhs):
//   k == 1: lhs=%0, rhs=%1 (the first add of the two leading params);
//   k  > 1: lhs=%(n+k-2) (running accumulator), rhs=%k (next param).
// Caller passes k starting at 1; there are n-1 binops.
pub fn emit_mic3_chain_binops(s: EmitState, n: i64, op_byte: i64, k: i64) -> EmitState {
    if k >= n {
        return s;
    }
    let dst: i64 = n + k - 1;
    if k == 1 {
        let s1: EmitState = emit_mic3_binop(s, dst, op_byte, 0, 1);
        return emit_mic3_chain_binops(s1, n, op_byte, k + 1);
    }
    let s2: EmitState = emit_mic3_binop(s, dst, op_byte, n + k - 2, k);
    emit_mic3_chain_binops(s2, n, op_byte, k + 1)
}

pub fn selftest_mic3_chain_fn(buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    emit_mic3_chain_fn_module(es_new(), buf, offs, n, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the mixed-operator expression-tree family (Phase 4f) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { <expr-tree> }`,
// byte-exact vs the Rust oracle, for an ARBITRARY binary-expression tree of MIXED
// operators — the first body that is NOT a left-spine accumulator. Examples:
//   mixed(a,b,c,d){a*b+c*d}  (tree +(*(a,b),*(c,d)), 77-byte oracle)
//   f(a,b,c){(a+b)*c}        (tree *(+(a,b),c),       60-byte oracle)
//
// The tree is supplied as a flat POST-ORDER node array (the standard flattening of
// a recursive post-order walk — the lowering emits each subtree, allocates a fresh
// vid, then references the two child vids). `nodes` is a heap array of `n_nodes`
// 4-i64 records (32 bytes each):
//   record[0] = kind: 0 = LEAF (param), 1 = BINOP.
//   LEAF :  record[1] = param index (its vid IS the index, since param i -> vid i).
//   BINOP:  record[1] = op_byte, record[2] = left child slot, record[3] = right slot.
// Nodes are in post-order, so a binop's child slots always precede it. The vid of a
// LEAF slot is its param index; the vid of a BINOP slot is allocated n, n+1, .. in
// post-order array order (== emission order). The FN_DEF ret_vid is the LAST node's
// vid (the tree root). body_len = n PARAMs + (#BINOP nodes). Decoded from the oracle:
//   header || strtab(n+1: name,p0..p(n-1)) || next_id(1) || exports(0) || uleb(3) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%root,
//            body=[PARAM %0..%(n-1), then BINOP per binop-node in post-order with
//                  the two child slot vids]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// Generalizes Phase 4e (the left-spine chain is the special case where every binop's
// left child is the previous binop and right child is the next leaf).
//
// `vidbuf` is a caller-supplied heap scratch array of `n_nodes` i64s used to record
// each slot's resolved vid (a binop references children by slot, so the slot->vid map
// must be materialized before the binops emit). It is filled by the first pass below.
pub fn emit_mic3_tree_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    // Pass 1: resolve every slot's vid into vidbuf (post-order, binops from %n).
    let root: i64 = tree_resolve_vids(nodes, n_nodes, n, vidbuf, 0, n);
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, encode_named_vids param list, ret Some %root, reap
    // None, body_len = n PARAMs + nbinops.
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, root);
    let s10: EmitState = es_push(s9, 0);
    // body_len = one instr per node: n PARAMs + every non-param node (binops and
    // const leaves). Since params are slots 0..(some) and ALL n_nodes nodes emit
    // exactly one body instr, body_len == n_nodes. For a param-only tree this is
    // identical to the former `n + nbinops` (every leaf is a param) — byte-exact.
    let s11: EmitState = emit_uleb128(s10, n_nodes);
    // Body: n PARAM instrs (reuse the chain param-body writer), then every
    // non-param node in post-order — binops with resolved child vids, const leaves
    // as their own ConstI64 at the interleaved slot.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_tree_body(s12, nodes, n_nodes, vidbuf, 0, 0, 0, 0, 0);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Pass 1: walk slots 0..n_nodes in order and record each slot's vid in vidbuf.
//   kind 0 (PARAM leaf): vid = param index (params own vids 0..n-1).
//   kind 1 (BINOP) and kind 2 (CONST leaf): vid = the running counter `nxt`
//     (starts at n). Const leaves and binops SHARE the post-order vid counter —
//     the Rust --emit-mic3 oracle interleaves them (e.g. h(a){a*2+1} resolves
//     PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4). Since both non-param
//     kinds fall through to the same `nxt++` branch, the post-order slot order
//     IS the oracle's interleaved vid order. Returns the LAST slot's vid (root).
// `i` is the current slot, `nxt` the next free non-param vid.
pub fn tree_resolve_vids(nodes: i64, n_nodes: i64, n: i64, vidbuf: i64, i: i64, nxt: i64) -> i64 {
    if i >= n_nodes {
        return __mind_load_i64(vidbuf + (n_nodes - 1) * 8);
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL — they emit no instr
    // and consume NO vid (mirror the param-leaf skip). The call node (kind 3) and the
    // value-producing kinds (1 binop / 2 const / 3 call) take the running counter.
    if kind == 4 {
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    if kind == 5 {
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    __mind_store_i64(vidbuf + i * 8, nxt);
    tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt + 1)
}

// Pass 2: emit one body instr per NON-PARAM slot, in post-order array order.
//   kind 0 (PARAM leaf): emit nothing (its PARAM was written in the param pass).
//   kind 1 (BINOP): dst = vidbuf[slot]; lhs/rhs = vidbuf[left]/vidbuf[right].
//   kind 2 (CONST leaf): record[1] holds the RAW literal value; emit a ConstI64
//     at vidbuf[slot] (emit_mic3_const_i64 zigzag-encodes it, so lit 2 -> the
//     oracle's CONST 4). Const slots are interleaved with binops by post-order.
// For a param-only tree no kind-2 slot exists, so this is byte-identical to the
// former emit_mic3_tree_binops (Bound by MIND-CONSTITUTION §I — param-only path
// unchanged).
pub fn emit_mic3_tree_body(s: EmitState, nodes: i64, n_nodes: i64, vidbuf: i64, src: i64, strbuf: i64, offs: i64, n_strings: i64, i: i64) -> EmitState {
    if i >= n_nodes {
        return s;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL metadata — emit
    // nothing (their vids were never assigned; the call node walks them).
    if kind == 4 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    if kind == 5 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    let dst: i64 = __mind_load_i64(vidbuf + i * 8);
    if kind == 2 {
        let lit: i64 = __mind_load_i64(nodes + i * 32 + 8);
        let sc: EmitState = emit_mic3_const_i64(s, dst, lit);
        return emit_mic3_tree_body(sc, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    if kind == 3 {
        // CALL: child0 = callee leaf slot (its span -> strtab index), child1 = first
        // arg-cons slot. nargs is the chain length; arg vids are each cons node's
        // child0 arg-root-slot's vid (vidbuf). OP_CALL (0x16): dst || name_idx ||
        // nargs || arg_vids — matches --emit-mic3 (Bound by MIND-CONSTITUTION §I).
        let cleaf: i64 = __mind_load_i64(nodes + i * 32 + 16);
        let lo: i64 = __mind_load_i64(nodes + cleaf * 32 + 8);
        let hi: i64 = __mind_load_i64(nodes + cleaf * 32 + 16);
        let name_idx: i64 = intern_find(strbuf, offs, n_strings, src, lo, hi, 0);
        let first_cons: i64 = __mind_load_i64(nodes + i * 32 + 24);
        let nargs: i64 = argcons_len(nodes, first_cons, 0);
        let s1: EmitState = es_push(s, 22);
        let s2: EmitState = emit_uleb128(s1, dst);
        let s3: EmitState = emit_uleb128(s2, name_idx);
        let s4: EmitState = emit_uleb128(s3, nargs);
        let s5: EmitState = emit_argcons_vids(s4, nodes, vidbuf, first_cons);
        return emit_mic3_tree_body(s5, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1);
    }
    let op_byte: i64 = __mind_load_i64(nodes + i * 32 + 8);
    let lslot: i64 = __mind_load_i64(nodes + i * 32 + 16);
    let rslot: i64 = __mind_load_i64(nodes + i * 32 + 24);
    let lvid: i64 = __mind_load_i64(vidbuf + lslot * 8);
    let rvid: i64 = __mind_load_i64(vidbuf + rslot * 8);
    let s1: EmitState = emit_mic3_binop(s, dst, op_byte, lvid, rvid);
    emit_mic3_tree_body(s1, nodes, n_nodes, vidbuf, src, strbuf, offs, n_strings, i + 1)
}

// Count the arg-cons chain length starting at cons slot `c` (0 = end).
pub fn argcons_len(nodes: i64, c: i64, acc: i64) -> i64 {
    if c == 0 {
        return acc;
    }
    let next: i64 = __mind_load_i64(nodes + c * 32 + 24);
    argcons_len(nodes, next, acc + 1)
}

// Emit each arg's resolved vid by walking the arg-cons chain in order. Each cons
// node's child0 (offset 16) is the arg-root descriptor slot; its vid is vidbuf[slot].
pub fn emit_argcons_vids(s: EmitState, nodes: i64, vidbuf: i64, c: i64) -> EmitState {
    if c == 0 {
        return s;
    }
    let arg_root: i64 = __mind_load_i64(nodes + c * 32 + 16);
    let vid: i64 = __mind_load_i64(vidbuf + arg_root * 8);
    let s1: EmitState = emit_uleb128(s, vid);
    let next: i64 = __mind_load_i64(nodes + c * 32 + 24);
    emit_argcons_vids(s1, nodes, vidbuf, next)
}

pub fn selftest_mic3_tree_fn(buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    emit_mic3_tree_fn_module(es_new(), buf, offs, n, nodes, n_nodes, vidbuf)
}

// ===========================================================================
// Phase 4g/4h — AST-DRIVEN mic@3 expression emission (the bootstrap-parser bridge)
// ===========================================================================
//
// Phase 4f drove emit_mic3_tree_fn_module from a SYNTHETIC hand-built 4-i64 node
// descriptor. Phase 4g closed the gap to self-compilation: it walks the LIVE
// bootstrap-parser AST (real 56-byte ast_binop / ast_ident nodes — see
// ast_new_binop at line ~621, ast_child0=lhs+24, ast_child1=rhs+32, ast_aux=op+48)
// and FLATTENS it into the same post-order descriptor the proven 4f emitter
// consumes. The byte-exact emitter is reused, so the param-only path is byte-exact-
// by-construction with the Phase 4f path AND the Rust oracle.
//
// Phase 4h adds CONST LEAVES (ast_int_lit). The descriptor gains a third record
// kind (kind 2 = const, record[1] = raw literal). A const leaf gets its own
// post-order slot whose vid is allocated INTERLEAVED with the binops (the oracle
// does NOT batch consts with params): e.g. h(a){a*2+1} resolves
//   PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4
// and the const value is zigzag-encoded at emit (lit 2 -> CONST 4, lit 3 -> CONST
// 6) by the existing emit_mic3_const_i64. Pass 1 (tree_resolve_vids) already routes
// every non-param node through the shared `nxt++` counter, and Pass 2
// (emit_mic3_tree_body) emits a ConstI64 at a const slot — so param-only trees keep
// the exact former bytes (no kind-2 slot fires) while const leaves now lower
// byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
//
// SCOPE: ast_binop trees whose leaves are ast_ident PARAM references and/or
// ast_int_lit CONST literals. field access / calls / if / let are later-phase
// walls (flatten_ast returns -1, the driver fails closed — no partial bytes).

// AST binop op-tag (op_add()=1, op_sub()=2, op_mul()=3, op_div()=4,
// op_lt()=5, op_gt()=6, op_eq()=7, op_le()=8, op_ge()=9, op_ne()=10) -> the
// mic@3 op_byte the oracle stores. The arithmetic ops map op_byte = op_tag - 1
// (add=0, sub=1, mul=2, div=3 — verified vs --emit-mic3). The comparison ops do
// NOT share that offset: the MIND op-tag order (lt,gt,eq,le,ge,ne) differs from
// the Rust BinOp byte order (Lt=0x05, Le=0x06, Gt=0x07, Ge=0x08, Eq=0x09,
// Ne=0x0A — src/ir/compact/v3/emit.rs binop_to_byte), so each is mapped
// explicitly. Verified byte-exact vs --emit-mic3 on lt/gt/eq/le/ge/ne fns.
pub fn binop_to_byte(op_tag: i64) -> i64 {
    if op_tag == op_lt() {
        return 5;
    }
    if op_tag == op_gt() {
        return 7;
    }
    if op_tag == op_eq() {
        return 9;
    }
    if op_tag == op_le() {
        return 6;
    }
    if op_tag == op_ge() {
        return 8;
    }
    if op_tag == op_ne() {
        return 10;
    }
    // Bitwise / shift ops. The MIND op-tag order (bitand=11, bitor=12, bitxor=13,
    // shl=14, shr=15) matches the Rust BinOp byte order (BitAnd=0x0B, BitOr=0x0C,
    // BitXor=0x0D, Shl=0x0E, Shr=0x0F — src/ir/compact/v3/emit.rs binop_to_byte),
    // so the offset is op_tag - 0 = op_tag here. Verified byte-exact vs --emit-mic3.
    if op_tag == op_bitand() {
        return 11;
    }
    if op_tag == op_bitor() {
        return 12;
    }
    if op_tag == op_bitxor() {
        return 13;
    }
    if op_tag == op_shl() {
        return 14;
    }
    if op_tag == op_shr() {
        return 15;
    }
    op_tag - 1
}

// Recursive post-order flatten of a param-only binary-expression AST sub-tree into
// the 4-i64 descriptor array `nodes` (kind,a,b,c per record, 32 bytes). `cursor` is
// a 1-i64 heap cell holding the next free slot. Returns the slot index of `node`'s
// emitted record, or -1 if the sub-tree contains an unsupported construct (a
// const/int leaf, or anything that is not ast_ident / ast_binop). On -1 the caller
// MUST abort (the descriptor is then partial/invalid) — fail-closed, never a
// byte-mismatched emit (Bound by MIND-CONSTITUTION §I).
pub fn flatten_ast(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        // Parentheses are purely structural — the mic@3 oracle carries no paren
        // node (verified vs --emit-mic3 on (a+b)*c). Recurse transparently.
        return flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 0);
        __mind_store_i64(nodes + slot * 32 + 8, idx);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_int_lit() {
        // Phase 4h: const leaf. The int-literal node carries no stored value, only
        // its source span [lo,hi) — parse the decimal digits to the raw literal.
        // Descriptor kind=2, record[1]=raw literal (emit_mic3_const_i64 zigzag-
        // encodes it at emission, matching the oracle's CONST lit*2). A const leaf
        // gets its own post-order slot (vid allocated interleaved with binops).
        // SYNTHETIC int-lit (field-read offset idx*8): child1==1 sentinel carries the
        // value DIRECT in child0 (no source decimal); real source int-lits have
        // child1==0 so this never fires for them.
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_ast(ast_child1(node), buf, params_addr, n_params, nodes, cursor);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        // Strategy-A cutover: a call with arbitrary expression arguments, encoded as
        // an ARG-CONS CHAIN inside the existing 32B descriptor array — no separate
        // arglist buffer, no flatten-param threading. Post-order is preserved: each
        // arg EXPRESSION sub-tree is flattened first (so its vids are assigned before
        // the call), then the structural callee-leaf (kind=5) + arg-cons (kind=4)
        // nodes (which emit NOTHING and consume NO vid), then the call node (kind=3)
        // LAST so it takes the final vid (matching the --emit-mic3 oracle).
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        // (1)+(2): flatten each arg expr post-order + build the arg-cons chain.
        let first_cons: i64 = flatten_argcons(args_addr, args_len, 0, buf, params_addr, n_params, nodes, cursor);
        if first_cons < 0 {
            return 0 - 1;
        }
        // (3): callee leaf — stores the callee NAME span (resolved to a strtab index
        // at emit time). kind=5, [span_lo, span_hi], emits nothing.
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        // (4): the call node, LAST in post-order. child0=callee leaf, child1=first
        // arg-cons slot (0 when zero-arg).
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_struct_lit() {
        // PARSE-ONLY frontier: struct-literal CONSTRUCTION is parsed but not yet
        // lowered. Fail closed (no bytes) — the desugar/emit half lands later.
        return 0 - 1;
    }
    // Every other kind (field access, if, ...) = a later-phase wall — reject.
    0 - 1
}

// Flatten the args of a call into the descriptor array as an arg-cons chain. Arg
// `i`'s EXPRESSION sub-tree is flattened first (post-order — its vids are assigned
// before any later arg and before the call), then this arg's cons node (kind=4,
// child0=arg-root-slot, child1=next-cons-slot) is written. Returns the slot of the
// FIRST cons node (the head the call node points at), 0 when args_len == 0, or -1 if
// any arg sub-tree contains an unsupported construct (fail-closed, no partial bytes).
pub fn flatten_argcons(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_ast(arg, buf, params_addr, n_params, nodes, cursor);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons(args_addr, args_len, idx + 1, buf, params_addr, n_params, nodes, cursor);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// Count the slots a param-only AST sub-tree flattens to (= total nodes in the tree),
// so the caller can size the descriptor / vidbuf scratch. Returns -1 on an
// unsupported construct (mirrors flatten_ast's rejection set exactly).
pub fn count_ast_nodes(node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_ast_nodes(ast_child0(node));
    }
    if k == ast_ident() {
        return 1;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_ast_nodes(ast_child0(node));
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_ast_nodes(ast_child1(node));
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    0 - 1
}

// AST-driven driver: flatten a real param-only binary-expression AST `expr` into the
// 4f descriptor, then emit byte-exact via the proven emit_mic3_tree_fn_module. Two
// buffers: `src` (source bytes, holds the scattered param-name spans used by
// flatten_ast for param-index resolution) and `strbuf`/`offs` (a CONTIGUOUS name
// buffer + offset array — string i spans strbuf[offs[i]..offs[i+1]] — for the mic@3
// string table; emit_mic3_strtab requires contiguous packing, the source spans are
// not). `n` is the param count, `params_addr`/`n_params` the parsed param block.
// `nodes`/`cursor`/`vidbuf` are caller-supplied heap scratch (nodes: n_nodes*32
// bytes; cursor: 1 i64; vidbuf: n_nodes i64). On an unsupported body (const leaf /
// non-arith) it returns the unmodified seed state `s` so the caller can detect
// non-emission — fail-closed, no partial bytes (Bound by MIND-CONSTITUTION §I.4).
pub fn emit_mic3_ast_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, expr: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    let root: i64 = flatten_ast(expr, src, params_addr, n_params, nodes, cursor);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4g): lex+parse `src`, find the first fn_def, take its
// trailing body expression, flatten the REAL AST, and emit mic@3 — byte-exact vs
// the Rust --emit-mic3 oracle for param-only bodies (e.g. mixed(a,b,c,d){a*b+c*d}).
// `strbuf`/`offs` are the caller-supplied CONTIGUOUS string-table name buffer +
// offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf` are caller-supplied heap
// scratch sized to the body's node count. Returns the EmitState (Python harness
// decodes EmitState.buf); for a const-leaf body it returns es_new() unchanged (empty
// buf) — the Phase 4h deferral, detectable by the harness.
pub fn selftest_mic3_ast_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    emit_mic3_ast_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, expr, nodes, cursor, vidbuf)
}

// ===========================================================================
// Phase 4i — LET-BOUND LOCALS / multi-statement bodies (the let-env bridge)
// ===========================================================================
//
// Phase 4g/4h emitted a SINGLE trailing-expression body. Phase 4i extends the
// AST walk to a STATEMENT SEQUENCE: zero or more `let name: ty = init;` bindings
// feeding a final expression. The oracle (--emit-mic3) rule, decoded byte-for-byte
// from f(a,b){let t=a*b; t+1}, g(a){let x=a+1; let y=x*2; y}, h(a,b){let s=a+b; s*s}:
//
//   * Each `let name = init` flattens `init` post-order into the SAME descriptor
//     array; the resulting ROOT slot's vid is bound to `name`. No instruction and
//     no string-table entry is emitted for the let-name — it is a pure vid ALIAS
//     (strtab carries only the fn name + params; t/x/y/s are absent).
//   * A later ast_ident referencing a let-name returns that bound SLOT (an alias,
//     emits no new node) — exactly as a param ident returns its param slot. So
//     `t+1` -> BINOP whose lhs is the let-init's slot; `s*s` reuses ONE slot twice.
//   * The trailing expression flattens normally; its root slot vid = the FN_DEF
//     ret_vid. body_len = total descriptor nodes (PARAMs + every CONST/BINOP);
//     let-name aliases contribute nothing (Bound by MIND-CONSTITUTION §I —
//     verified byte-exact: letf 55B / letg 50B / leth 52B).
//
// The single-expression path (selftest_mic3_ast_fn) is UNTOUCHED below this point;
// flatten_ast / emit_mic3_ast_fn_module stay byte-identical for param/const bodies.
//
// SCOPE: bodies whose statements are `let` bindings (param/const/binop inits, the
// 4g/4h expr grammar) plus a trailing expression. A let whose init contains a
// non-arith construct, or any statement that is not a let / final expr, is a
// later-phase wall (flatten returns -1, the driver fails closed — no partial bytes).

// Let-env: parallel heap array. Entry j at `lenv + j*24` = [name_lo, name_hi, slot].
// `lcount` is a 1-i64 cell holding the live entry count. Look up the ident span
// buf[lo..hi): return the bound descriptor slot, or -1 if not a let-name. Span
// comparison (span_bytes_equal) mirrors resolve_param exactly — no hashing, so no
// collision risk on fresh let names.
pub fn resolve_let(lenv: i64, lcount: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_let_loop(lenv, __mind_load_i64(lcount), buf, lo, hi, 0)
}
pub fn resolve_let_loop(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    resolve_let_loop(lenv, n, buf, lo, hi, i + 1)
}

// Let-env-aware post-order flatten. Identical to flatten_ast (Phase 4g/4h) except
// the ast_ident branch first tries params, THEN let-names (alias to the bound slot,
// no new node). Threads lenv/lcount through paren/binop recursion. Returns the
// node's slot index, or -1 on an unsupported construct (fail-closed).
pub fn flatten_ast_le(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            let slot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + slot * 32 + 0, 0);
            __mind_store_i64(nodes + slot * 32 + 8, idx);
            __mind_store_i64(nodes + slot * 32 + 16, 0);
            __mind_store_i64(nodes + slot * 32 + 24, 0);
            __mind_store_i64(cursor, slot + 1);
            return slot;
        }
        // Not a param: a let-bound local resolves to its init's already-emitted
        // slot (an alias — emit no new node, return the bound slot directly).
        let lslot: i64 = resolve_let(lenv, lcount, buf, ast_span_lo(node), ast_span_hi(node));
        if lslot >= 0 {
            return lslot;
        }
        return 0 - 1;
    }
    if k == ast_int_lit() {
        let lit: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let ls: i64 = flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if ls < 0 {
            return 0 - 1;
        }
        let rs: i64 = flatten_ast_le(ast_child1(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if rs < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, ls);
        __mind_store_i64(nodes + slot * 32 + 24, rs);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_struct_lit() {
        // PARSE-ONLY frontier: reject struct-literal construction (fail closed).
        return 0 - 1;
    }
    0 - 1
}

// Walk a block's statement list: each `let` flattens its init and binds the
// let-name span -> the init's root slot in the let-env; the FINAL statement is the
// trailing expression, flattened and its root slot returned (the fn ret slot).
// Returns the trailing expr's root slot, or -1 on any wall (a non-let / non-final
// statement, a let-init that doesn't flatten, or an unsupported trailing expr).
pub fn flatten_stmts(stmts_addr: i64, stmts_len: i64, i: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if i + 1 >= stmts_len {
        // Final statement = the trailing value expression.
        return flatten_ast_le(stmt, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    // Non-final statements must be `let` bindings.
    if ast_kind(stmt) != ast_let() {
        return 0 - 1;
    }
    let init: i64 = ast_child2(stmt);
    let slot: i64 = flatten_ast_le(init, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if slot < 0 {
        return 0 - 1;
    }
    let name_leaf: i64 = ast_child0(stmt);
    let j: i64 = __mind_load_i64(lcount);
    __mind_store_i64(lenv + j * 24 + 0, ast_span_lo(name_leaf));
    __mind_store_i64(lenv + j * 24 + 8, ast_span_hi(name_leaf));
    __mind_store_i64(lenv + j * 24 + 16, slot);
    __mind_store_i64(lcount, j + 1);
    flatten_stmts(stmts_addr, stmts_len, i + 1, buf, params_addr, n_params, nodes, cursor, lenv, lcount)
}

// AST-driven driver for multi-statement (let-bound) bodies: flatten the whole
// statement sequence into the 4f descriptor, then emit byte-exact via the proven
// emit_mic3_tree_fn_module. Fails closed (returns the seed state `s`) on any wall.
pub fn emit_mic3_let_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let root: i64 = flatten_stmts(stmts_addr, stmts_len, 0, src, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4i): lex+parse `src`, find the first fn_def, walk its full
// body statement list (let bindings + trailing expr), and emit mic@3 — byte-exact
// vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied CONTIGUOUS
// string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf`
// are heap scratch sized to the body node count; `lenv`/`lcount` are the let-env
// scratch (lenv: n_lets*24 bytes; lcount: 1 i64).
pub fn selftest_mic3_let_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    emit_mic3_let_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, stmts_addr, stmts_len, nodes, cursor, vidbuf, lenv, lcount)
}

// ===========================================================================
// Phase 4j — IF-EXPRESSION as a value (the control-flow frontier)
// ===========================================================================
//
// `if cond { then } else { else }` used as a value lowers to ONE top-level body
// instruction: OP_IF (0x1C). Decoded byte-for-byte from the Rust --emit-mic3
// oracle (src/ir/compact/v3/emit.rs Instr::If arm + src/eval/lower.rs):
//
//   OP_IF(0x1C)
//     vid(cond_id)
//     uleb(cond_instrs.len) || cond_instrs...
//     uleb(then_instrs.len) || then_instrs...
//     vid(then_result)
//     uleb(else_instrs.len) || else_instrs...
//     vid(else_result)
//     vid(dst)
//     encode_named_vids(branch_bindings)   // uleb(count) || (str,vid)*
//     encode_vid_triples(merges)           // uleb(count) || (vid,vid,vid)*
//
// VID THREADING (decoded; params own vids 0..n-1, the counter starts at n):
//   * cond: its NON-param nodes take vids n, n+1, ... (params re-use their own
//     vid, emit NO sub-instr). cond_id = cond's root vid. No synth const.
//   * then: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1406),
//     then the then-expr's non-param nodes. then_result = then-expr's root vid.
//   * else: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1476),
//     then the else-expr's non-param nodes. else_result = else-expr's root vid.
//   * dst = the next free vid after both branches (the if's value / ret_vid).
//
// SCOPE (the SMALLEST canary-safe increment): cond / then-expr / else-expr are
// each a param/const/binop tree (the same construct flatten_ast already lowers),
// the else clause is PRESENT, and neither branch writes an outer var or binds a
// branch-local let — so branch_bindings and merges are BOTH empty (count 0).
// Let-in-branch, no-else, and nested if are later 4j sub-steps. This path is
// ISOLATED from the canary (exported only via selftest_mic3_if_fn); the
// AST-driven body emitter still rejects ast_if (flatten_ast/flatten_ast_le
// return -1), so the fixed point stays byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Count the non-param nodes a param/const/binop tree flattens to (= CONST leaves
// + BINOP nodes). Params contribute 0 (they re-use their own vid, no sub-instr).
// Returns -1 on any unsupported construct (mirrors flatten_ast's rejection set).
pub fn count_nonparam_nodes(node: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        return 0;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_nonparam_nodes(ast_child1(node), buf, params_addr, n_params);
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    if k == ast_call() {
        // The call emits ONE instr (the OP_CALL). The structural callee-leaf and
        // arg-cons descriptor nodes emit nothing. Each arg contributes its own
        // non-param instrs (consts/binops/nested calls).
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let a: i64 = count_nonparam_args(args_addr, args_len, 0, buf, params_addr, n_params);
        if a < 0 {
            return 0 - 1;
        }
        return 1 + a;
    }
    0 - 1
}

// Sum the non-param instr counts of a call's arguments (left-to-right).
pub fn count_nonparam_args(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let c: i64 = count_nonparam_nodes(arg, buf, params_addr, n_params);
    if c < 0 {
        return 0 - 1;
    }
    let rest: i64 = count_nonparam_args(args_addr, args_len, idx + 1, buf, params_addr, n_params);
    if rest < 0 {
        return 0 - 1;
    }
    c + rest
}

// ===========================================================================
// LET-VID-aware flatten (6c prep) — then-block let bindings via kind-0 leaves
// ===========================================================================
//
// A then-block local `let NAME = INIT` resolves a later reference to NAME to the
// let's value VID. We carry an lv-environment: a scratch buffer of 24-byte records
// [name_lo, name_hi, vid]; `nlv` holds the count. A reference span that matches a
// recorded name (lvenv_lookup >= 0) emits a KIND-0 LEAF whose +8 field = the let's
// recorded vid — exactly how flatten_ast emits a param leaf (kind-0, +8=pidx), but
// carrying the let's vid instead of the param index. A kind-0 leaf emits NO
// instruction and contributes its +8 value as the vid in tree_resolve_vids_base /
// emit_mic3_tree_body. Every other arm is IDENTICAL to flatten_ast and recurses via
// flatten_ast_lv. With nlv == 0 lvenv_lookup never matches, so flatten_ast_lv,
// flatten_argcons_lv, flatten_branch_lv, count_nonparam_nodes_lv and
// count_nonparam_args_lv are BYTE-FOR-BYTE equivalent to their non-lv counterparts
// (Bound by MIND-CONSTITUTION §I — this prep is byte-identical until an lv-env is
// actually populated by 6c-2).

// Resolve an ident span against the lv-environment. Returns the bound vid, or -1 if
// the name is not an lv-bound variable. Records are [name_lo, name_hi, vid] (24B).
pub fn lvenv_lookup(src: i64, lo: i64, hi: i64, lvenv: i64, nlv: i64, i: i64) -> i64 {
    if i >= nlv {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(lvenv + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(lvenv + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return __mind_load_i64(lvenv + i * 24 + 16);
    }
    lvenv_lookup(src, lo, hi, lvenv, nlv, i + 1)
}

// Exactly flatten_ast, except an ident found in the lv-env (lvenv_lookup >= 0) emits
// a KIND-0 leaf carrying the let's vid in +8 (mirroring the param-leaf shape). All
// other arms identical, recursing via flatten_ast_lv.
pub fn flatten_ast_lv(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_ast_lv(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            // Not a param: try the lv-env (a then-block let). lvenv_lookup returns the
            // let's vid; emit a kind-0 leaf carrying that vid (like a param leaf).
            let lvid: i64 = lvenv_lookup(buf, ast_span_lo(node), ast_span_hi(node), lvenv, nlv, 0);
            if lvid < 0 {
                return 0 - 1;
            }
            let lslot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + lslot * 32 + 0, 0);
            __mind_store_i64(nodes + lslot * 32 + 8, lvid);
            __mind_store_i64(nodes + lslot * 32 + 16, 0);
            __mind_store_i64(nodes + lslot * 32 + 24, 0);
            __mind_store_i64(cursor, lslot + 1);
            return lslot;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 0);
        __mind_store_i64(nodes + slot * 32 + 8, idx);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_int_lit() {
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_ast_lv(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_ast_lv(ast_child1(node), buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let first_cons: i64 = flatten_argcons_lv(args_addr, args_len, 0, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
        if first_cons < 0 {
            return 0 - 1;
        }
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_struct_lit() {
        return 0 - 1;
    }
    0 - 1
}

// flatten_argcons, recursing via flatten_ast_lv.
pub fn flatten_argcons_lv(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lvenv: i64, nlv: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_ast_lv(arg, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons_lv(args_addr, args_len, idx + 1, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// flatten_branch, flattening via flatten_ast_lv (resets cursor, resolves vids).
pub fn flatten_branch_lv(expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64, lvenv: i64, nlv: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast_lv(expr, buf, params_addr, n_params, nodes, cursor, lvenv, nlv);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// count_nonparam_nodes, where an lv-env ident counts as 0 (kind-0 leaf, like a param).
pub fn count_nonparam_nodes_lv(node: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_nonparam_nodes_lv(ast_child0(node), buf, params_addr, n_params, lvenv, nlv);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            let lvid: i64 = lvenv_lookup(buf, ast_span_lo(node), ast_span_hi(node), lvenv, nlv, 0);
            if lvid < 0 {
                return 0 - 1;
            }
            return 0;
        }
        return 0;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_nonparam_nodes_lv(ast_child0(node), buf, params_addr, n_params, lvenv, nlv);
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_nonparam_nodes_lv(ast_child1(node), buf, params_addr, n_params, lvenv, nlv);
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let a: i64 = count_nonparam_args_lv(args_addr, args_len, 0, buf, params_addr, n_params, lvenv, nlv);
        if a < 0 {
            return 0 - 1;
        }
        return 1 + a;
    }
    0 - 1
}

// count_nonparam_args, recursing via count_nonparam_nodes_lv.
pub fn count_nonparam_args_lv(args_addr: i64, args_len: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let c: i64 = count_nonparam_nodes_lv(arg, buf, params_addr, n_params, lvenv, nlv);
    if c < 0 {
        return 0 - 1;
    }
    let rest: i64 = count_nonparam_args_lv(args_addr, args_len, idx + 1, buf, params_addr, n_params, lvenv, nlv);
    if rest < 0 {
        return 0 - 1;
    }
    c + rest
}

// ===========================================================================
// Multi-statement LET CHAINS — substitution-based flatten (cutover construct)
// ===========================================================================
//
// A body `{ let n0: i64 = E0; let n1: i64 = E1; ... ; FINAL }` lowers BYTE-
// IDENTICAL to the fully-substituted nested expression (verified vs --emit-mic3:
// `f(x){let a=x+1; let b=a*2; b}` == `f(x){(x+1)*2}`). The Rust front-end treats
// sequential let-bindings as pure SSA aliasing — each let name takes the vid of
// its init expression's ROOT, and a later reference to that name reuses that vid
// with no extra instruction or string. We reproduce that by flattening every let
// init and the trailing expression into ONE shared post-order descriptor array,
// carrying a let-environment (name-span -> root descriptor slot). An ident that
// names a previously-bound let resolves to that slot (reused, no new node) exactly
// as a param leaf is reused; params still resolve first. The resulting descriptor
// feeds the SAME proven tree_resolve_vids + emit_mic3_tree_body pair, so the body
// is byte-exact by construction (Bound by MIND-CONSTITUTION §I).
//
// The let-environment is a scratch buffer of 24-byte records [name_lo, name_hi,
// slot]; `nlets`-cell holds the count. Lookup compares the reference span to each
// recorded name span (both in `src`, via span_bytes_equal2), latest-first is not
// required — let names within one body are distinct (the Rust checker rejects
// shadowing in this subset), so first-match is unambiguous.

// Resolve an ident span against the let-environment. Returns the bound descriptor
// slot, or -1 if the name is not a let-bound variable.
pub fn letenv_lookup(src: i64, lo: i64, hi: i64, env: i64, nlets: i64, i: i64) -> i64 {
    if i >= nlets {
        return 0 - 1;
    }
    let nlo: i64 = __mind_load_i64(env + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(env + i * 24 + 8);
    if span_bytes_equal2(src, lo, hi, src, nlo, nhi) == 1 {
        return __mind_load_i64(env + i * 24 + 16);
    }
    letenv_lookup(src, lo, hi, env, nlets, i + 1)
}

// Flatten ONE expression tree into the shared descriptor, resolving idents against
// (a) params, then (b) the let-environment. A param ident emits a kind-0 leaf (as
// flatten_ast). A let-bound ident emits NO node — it returns the let's recorded
// root slot (SSA-aliased reuse, matching the oracle). Returns the node's slot, or
// -1 on an unsupported construct (fail-closed, identical rejection set to
// flatten_ast plus an unbound ident).
pub fn flatten_expr_env(node: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_expr_env(ast_child0(node), src, params_addr, n_params, nodes, cursor, env, nlets);
    }
    if k == ast_ident() {
        let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(node), ast_span_hi(node));
        if pidx >= 0 {
            let slot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + slot * 32 + 0, 0);
            __mind_store_i64(nodes + slot * 32 + 8, pidx);
            __mind_store_i64(nodes + slot * 32 + 16, 0);
            __mind_store_i64(nodes + slot * 32 + 24, 0);
            __mind_store_i64(cursor, slot + 1);
            return slot;
        }
        // Not a param: must be a previously-bound let name (reuse its slot).
        let lslot: i64 = letenv_lookup(src, ast_span_lo(node), ast_span_hi(node), env, nlets, 0);
        return lslot;
    }
    if k == ast_int_lit() {
        // SYNTHETIC int-lit (field-read offset): child1==1 sentinel -> value in
        // child0 direct; real source int-lits have child1==0.
        let lit: i64 = if ast_child1(node) == 1 {
            ast_child0(node)
        } else {
            parse_int_span(src, ast_span_lo(node), ast_span_hi(node), 0)
        };
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_expr_env(ast_child0(node), src, params_addr, n_params, nodes, cursor, env, nlets);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_expr_env(ast_child1(node), src, params_addr, n_params, nodes, cursor, env, nlets);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_call() {
        // Let-env-aware CALL fold — mirrors flatten_ast's ast_call arm exactly (the
        // call-cons pattern: each arg sub-tree post-order, then the arg-cons chain
        // [kind=4], then the callee leaf [kind=5], then the call node [kind=3] LAST
        // so it takes the final vid). Args resolve idents against params THEN the
        // let-env, so a let-ref flowing into a later call (e.g. `let a = g(x);
        // h(a, k)`) reuses the earlier call's vid with no new node — byte-exact vs
        // --emit-mic3 (Bound by MIND-CONSTITUTION §I).
        let callee: i64 = ast_child0(node);
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let first_cons: i64 = flatten_argcons_env(args_addr, args_len, 0, src, params_addr, n_params, nodes, cursor, env, nlets);
        if first_cons < 0 {
            return 0 - 1;
        }
        let cslot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + cslot * 32 + 0, 5);
        __mind_store_i64(nodes + cslot * 32 + 8, ast_span_lo(callee));
        __mind_store_i64(nodes + cslot * 32 + 16, ast_span_hi(callee));
        __mind_store_i64(nodes + cslot * 32 + 24, 0);
        __mind_store_i64(cursor, cslot + 1);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 3);
        __mind_store_i64(nodes + slot * 32 + 8, 0);
        __mind_store_i64(nodes + slot * 32 + 16, cslot);
        __mind_store_i64(nodes + slot * 32 + 24, first_cons);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    0 - 1
}

// Let-env-aware arg-cons builder — the flatten_argcons counterpart that resolves a
// let-ref arg to its bound slot. Arg `i`'s expression flattens first (post-order),
// then this arg's cons node (kind=4, child0=arg-root-slot, child1=next-cons-slot).
// Returns the FIRST cons slot, 0 when args_len == 0, or -1 on an unsupported
// construct (fail-closed, no partial bytes).
pub fn flatten_argcons_env(args_addr: i64, args_len: i64, idx: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets: i64) -> i64 {
    if idx >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + idx * 8);
    let arg_root: i64 = flatten_expr_env(arg, src, params_addr, n_params, nodes, cursor, env, nlets);
    if arg_root < 0 {
        return 0 - 1;
    }
    let next_cons: i64 = flatten_argcons_env(args_addr, args_len, idx + 1, src, params_addr, n_params, nodes, cursor, env, nlets);
    if next_cons < 0 {
        return 0 - 1;
    }
    let slot: i64 = __mind_load_i64(cursor);
    __mind_store_i64(nodes + slot * 32 + 0, 4);
    __mind_store_i64(nodes + slot * 32 + 8, 0);
    __mind_store_i64(nodes + slot * 32 + 16, arg_root);
    __mind_store_i64(nodes + slot * 32 + 24, next_cons);
    __mind_store_i64(cursor, slot + 1);
    return slot;
}

// Walk the body's let-statement sequence (stmts 0..stmts_len-1), flattening each
// let's init expression into the shared descriptor and recording its name -> root
// slot in the let-env. Each stmt before the last must be `let NAME: TYPE = INIT`
// where INIT is a param/const/binop/let-ref tree. Returns 1 on success (env and
// nodes filled, cursor advanced), 0 on any wall (a non-let stmt, or an init the
// flatten rejects). Threads through recursion; `nlets_cell` accumulates the count.
pub fn flatten_let_chain(src: i64, stmts_addr: i64, stmts_len: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets_cell: i64, i: i64) -> i64 {
    if i >= stmts_len - 1 {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return 0;
    }
    let name: i64 = ast_child0(stmt);
    let init: i64 = ast_child2(stmt);
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let root_slot: i64 = flatten_expr_env(init, src, params_addr, n_params, nodes, cursor, env, nlets);
    if root_slot < 0 {
        return 0;
    }
    __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
    __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
    __mind_store_i64(env + nlets * 24 + 16, root_slot);
    __mind_store_i64(nlets_cell, nlets + 1);
    flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, i + 1)
}

// Emit ONE fn's FN_DEF whose body is a multi-statement let chain (>1 stmts: a
// sequence of `let NAME = INIT` bindings then a trailing value expression, every
// init/expr a param/const/binop/let-ref tree). Substitution-equivalent to the
// nested expression, so byte-exact vs --emit-mic3. Writes 1 to ok_cell on success,
// 0 (fail-closed, returns seed `s`) on any wall.
pub fn emit_mic3_module_fndef_letchain(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, env: i64, nlets_cell: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    let chain_ok: i64 = flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, 0);
    if chain_ok == 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let final_expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    let root_slot: i64 = flatten_expr_env(final_expr, src, params_addr, n_params, nodes, cursor, env, nlets);
    if root_slot < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    // tree_resolve_vids FILLS vidbuf (side effect) and returns vidbuf[last]. Take
    // root_vid from the FINAL EXPR's resolved slot instead: they coincide when the
    // trailing expr builds a node (its root IS the last node), but a BARE let-ref
    // trailing (e.g. the struct-lit desugar's `__sl` -> alloc ptr) reuses an earlier
    // slot and creates NO node, so vidbuf[last] would be the wrong (last-store) vid.
    let _fill: i64 = tree_resolve_vids(nodes, n_nodes, n_params, vidbuf, 0, n_params);
    let root_vid: i64 = __mind_load_i64(vidbuf + root_slot * 8);
    // body_len = n_params PARAM instrs + every non-param descriptor node (every
    // kind-1 BINOP + kind-2 CONST; kind-0 param leaves emit no body instr — they
    // are mirrored by the de-duplicated PARAM emission). Count non-param slots.
    let body_len: i64 = n_params + count_descriptor_nonparam(nodes, n_nodes, 0);
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, root_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_tree_body(s7, nodes, n_nodes, vidbuf, src, strbuf, offs, ncount, 0);
    __mind_store_i64(ok_cell, 1);
    s8
}

// Count the BODY-INSTR descriptor slots in nodes[0..n_nodes) — the number of body
// instrs the tree emits (each CONST / BINOP / CALL). Mirrors the body_len
// derivation. Param leaves (kind 0) emit via the PARAM pass, and the structural
// arg-cons (kind 4) / callee-leaf (kind 5) nodes of a call emit NOTHING (they are
// walked by the call node), so both are excluded — matching tree_resolve_vids's
// vid-skip. Without the 4/5 skip a call body over-counts body_len by 2 per call.
pub fn count_descriptor_nonparam(nodes: i64, n_nodes: i64, i: i64) -> i64 {
    if i >= n_nodes {
        return 0;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    if kind == 4 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    if kind == 5 {
        return count_descriptor_nonparam(nodes, n_nodes, i + 1);
    }
    1 + count_descriptor_nonparam(nodes, n_nodes, i + 1)
}

// Pass-1 vid resolution with an arbitrary non-param base. Identical to
// tree_resolve_vids except the non-param counter starts at `base` (instead of n):
// param leaf -> param index; CONST/BINOP -> base, base+1, .. in post-order.
// Returns the next free vid after this tree (so the caller can thread it onward).
pub fn tree_resolve_vids_base(nodes: i64, n_nodes: i64, vidbuf: i64, i: i64, base: i64) -> i64 {
    if i >= n_nodes {
        return base;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    // kind 4 (arg-cons) and kind 5 (callee leaf) are STRUCTURAL — they emit no instr
    // and consume NO vid (mirror tree_resolve_vids). Without this, a call value in a
    // struct-lit field shifts the call's dst vid by +2 (callee-leaf + arg-cons).
    if kind == 4 {
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    if kind == 5 {
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    __mind_store_i64(vidbuf + i * 8, base);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base + 1)
}

// Flatten ONE branch/cond expression tree into a fresh descriptor (resets cursor),
// resolve its slot vids from `base`, and return the root slot's resolved vid (or
// -1 on a wall). On success `cursor` holds n_nodes and `vidbuf` is filled — the
// caller emits the branch's non-param instrs via emit_mic3_tree_body.
pub fn flatten_branch(expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast(expr, buf, params_addr, n_params, nodes, cursor);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Extract a block's single trailing expression. The minimal 4j branch is a block
// whose only statement is the value expression (stmts_len == 1). Returns the
// expr node, or -1 if the block has != 1 statement (a later 4j sub-step).
pub fn branch_single_expr(blk: i64) -> i64 {
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len != 1 {
        return 0 - 1;
    }
    __mind_load_i64(stmts_addr + 0)
}

// Emit the OP_IF body instruction (0x1C) for the simplest if-expression: cond /
// then-expr / else-expr are each a param/const/binop tree, else present, no
// branch writes (branch_bindings + merges both empty). Threads the vid counter
// through cond -> then(synth + tree) -> else(synth + tree) -> dst, byte-exact vs
// the oracle. Returns the post-OP_IF EmitState; the if's result vid is `dst`
// (the caller uses it as the FN_DEF ret_vid). On a wall returns the seed `s`
// unchanged and writes -1 to `okcell` so the caller fails closed.
pub fn emit_mic3_if_instr(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    // --- cond ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then: synth ConstI64(after_cond, 0) FIRST, then the then-expr tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(then_expr, buf, params_addr, n_params);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_uleb128(s7, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else: synth ConstI64(after_then, 0) FIRST, then the else-expr tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch(else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(cursor);
    let else_nonparam: i64 = count_nonparam_nodes(else_expr, buf, params_addr, n_params);
    let s9: EmitState = emit_uleb128(s8, else_nonparam + 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_mic3_tree_body(s10, nodes, else_n, vidbuf, 0, 0, 0, 0, 0);
    let s12: EmitState = emit_uleb128(s11, else_root);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- dst (the if's value) + empty branch_bindings + empty merges ---
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// Assemble the full mic@3 module of
//   pub fn <name>(p0,..,p(n-1)) -> i64 { if cond { then } else { else } }
// byte-exact vs the Rust --emit-mic3 oracle. The body is n PARAM instrs then the
// single OP_IF instr (body_len = n + 1); ret_vid = the if's dst. Mirrors
// emit_mic3_tree_fn_module's framing (header/strtab/next_id/exports/FN_DEF/tail).
// Fails closed (returns the seed `s`) on any wall.
pub fn emit_mic3_if_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, cond_expr: i64, then_expr: i64, else_expr: i64, src: i64, params_addr: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, param-pair list, ret Some %dst, reap None, body_len.
    // The ret_vid (dst) is only known after the OP_IF is emitted, so emit the body
    // into a SCRATCH EmitState first to learn dst + body bytes, then frame it.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_instr(es_new(), cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_instr(s12, cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j): lex+parse `src`, find the first fn_def whose body is
// a single `if cond { then } else { else }` expression, and emit its mic@3 module
// byte-exact vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied
// CONTIGUOUS string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/
// `cursor`/`vidbuf` are heap scratch sized to the LARGEST single branch's node
// count; `okcell` is a 1-i64 cell (holds dst on success, -1 on a wall).
pub fn selftest_mic3_if_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    // The fn body block's single trailing statement must be the if-expression.
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    let then_expr: i64 = branch_single_expr(then_blk);
    let else_expr: i64 = branch_single_expr(else_blk);
    if then_expr < 0 {
        return es_new();
    }
    if else_expr < 0 {
        return es_new();
    }
    emit_mic3_if_fn_module(es_new(), strbuf, offs, n_params, cond_expr, then_expr, else_expr, src_addr, params_addr, nodes, cursor, vidbuf, okcell)
}

// ===========================================================================
// Phase 4j+ — IF with MULTI-STATEMENT branch blocks + NON-EMPTY merges
// ===========================================================================
//
// The 4j path above handles `if cond { expr } else { expr }` where each branch is a
// SINGLE value expression — no branch writes, so branch_bindings and merges are
// empty. This step extends a branch to a STATEMENT SEQUENCE `{ let n: ty = init; ..;
// trailing }` (the same grammar Phase 4i already lowers for fn bodies). A branch-local
// `let` is a WRITE of that name, which the Rust oracle (src/eval/lower.rs ~1399-1611)
// turns into a NON-EMPTY merge phi set. Decoded byte-for-byte from --emit-mic3:
//
//   * Each branch flattens its statement list (lets + trailing) into its OWN
//     post-order descriptor with its OWN let-env (reusing flatten_stmts/flatten_ast_le).
//     The branch's non-param vids resolve from its per-branch base; a `let` records the
//     name -> its init's resolved vid (the merge "value" for that branch).
//   * VID THREADING: params 0..n-1; cond non-param from n; then = synth ConstI64(0)
//     then then-tree; else = synth ConstI64(0) then else-tree. AFTER both branches,
//     for each merged name (then-writes then else-writes, deduped first-seen): if a
//     branch does NOT define the name, a placeholder ConstI64(fresh, 0) is appended to
//     THAT branch's body (its vid allocated from the running parent counter), in the
//     order then-placeholder, else-placeholder, then merge_id. dst is the final fresh.
//   * branch_bindings = (name_strtab_idx, merge_id) per merged name; merges =
//     (merge_id, then_val, else_val) per merged name. The strtab carries the let-names
//     (after name+params, in encounter order). Verified byte-exact vs --emit-mic3:
//     f(a,b){if a{let t=a*b; t+1}else{b}}=81B, both-let=75B, else-let=73B, two-name=88B.
//
// ISOLATED from the canary (exported only via selftest_mic3_if_let_fn); the AST-driven
// body emitter still rejects ast_if, so the fixed point is byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Flatten ONE branch block (a statement list) into a fresh per-branch descriptor with
// its own let-env, resolve its non-param vids from `base`, and return the trailing
// expression's resolved vid (or -1 on a wall). On success: `cursor` holds n_nodes,
// `vidbuf` is filled, and the let-env (`lenv`/`lcount`) holds each let-name's span +
// its RESOLVED vid (slot rewritten to vid). The caller reads writes from the let-env.
pub fn flatten_branch_block(blk: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let root_slot: i64 = flatten_stmts(stmts_addr, stmts_len, 0, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    // Rewrite each let-env entry's stored SLOT to its resolved VID so the merge pass
    // can read a branch's per-name value directly.
    lenv_slots_to_vids(lenv, __mind_load_i64(lcount), vidbuf, 0);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Rewrite let-env entry slots (offset +16) in place from descriptor slot -> resolved
// vid (vidbuf[slot]). Called once after tree_resolve_vids_base fills vidbuf.
pub fn lenv_slots_to_vids(lenv: i64, n: i64, vidbuf: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let slot: i64 = __mind_load_i64(lenv + i * 24 + 16);
    __mind_store_i64(lenv + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    lenv_slots_to_vids(lenv, n, vidbuf, i + 1)
}

// Look up a name span in a branch's let-env: return its resolved vid (entry +16) or -1.
pub fn lenv_lookup_vid(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    lenv_lookup_vid(lenv, n, buf, lo, hi, i + 1)
}

// Find a name span's string-table index. The contiguous name buffer `strbuf`/`offs`
// holds [name, p0..p(n-1), let-names..]; entry j spans buf[offs[j]..offs[j+1]).
// Returns the matching index, or -1. (Used to fill branch_bindings' name_strtab_idx.)
pub fn strtab_index_of(strbuf: i64, offs: i64, count: i64, buf: i64, lo: i64, hi: i64, j: i64) -> i64 {
    if j >= count {
        return 0 - 1;
    }
    let slo: i64 = __mind_load_i64(offs + j * 8);
    let shi: i64 = __mind_load_i64(offs + (j + 1) * 8);
    if span_bytes_equal2(strbuf, slo, shi, buf, lo, hi) == 1 {
        return j;
    }
    strtab_index_of(strbuf, offs, count, buf, lo, hi, j + 1)
}

// Span-equality across TWO distinct buffers (span_bytes_equal compares within one buf).
pub fn span_bytes_equal2(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, bhi: i64) -> i64 {
    if ahi - alo != bhi - blo {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, 0)
}
pub fn span_bytes_equal2_loop(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        return 1;
    }
    if load_byte(a, alo + k) != load_byte(b, blo + k) {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, k + 1)
}

// Build the merged-name list as spans into `buf`: then-lenv entries first, then
// else-lenv entries not already present (first-seen dedup). `outspans` is a heap array
// of (lo,hi) i64 pairs; returns the merged count. Each branch's lenv holds name spans.
pub fn build_merged_names(t_lenv: i64, t_n: i64, e_lenv: i64, e_n: i64, buf: i64, outspans: i64) -> i64 {
    let c1: i64 = copy_lenv_spans(t_lenv, t_n, buf, outspans, 0, 0);
    merge_else_spans(e_lenv, e_n, buf, outspans, c1, 0)
}
pub fn copy_lenv_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return copy_lenv_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    copy_lenv_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn merge_else_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return merge_else_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    merge_else_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn span_in_list(buf: i64, lo: i64, hi: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= oc {
        return 0;
    }
    let elo: i64 = __mind_load_i64(outspans + i * 16 + 0);
    let ehi: i64 = __mind_load_i64(outspans + i * 16 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return 1;
    }
    span_in_list(buf, lo, hi, outspans, oc, i + 1)
}

// Emit the OP_IF body instruction with NON-EMPTY merges. Threads cond -> then(synth
// +block) -> else(synth+block) -> [per-name then/else placeholders + merge_ids] -> dst,
// byte-exact vs the oracle. The two branch blocks carry their own let-envs (already
// resolved to vids). `mspans`/`mcount` are filled with the merged-name spans. Writes
// dst to `okcell` on success; -1 on a wall (caller fails closed). `extra` is a heap
// scratch of i64s: per merged name we store (then_extra_vid, else_extra_vid, merge_id)
// = 3 i64 at extra + k*24, with -1 where a branch already defines the name.
pub fn emit_mic3_if_block_instr(s: EmitState, cond_expr: i64, then_blk: i64, else_blk: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, params_addr: i64, n_params: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let base0: i64 = n_params;
    // --- cond (single value expr; reuse flatten_branch into the cond descriptor) ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, c_nodes, c_cur, c_vid, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(c_cur);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then block: synth ConstI64(after_cond, 0), then the block tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch_block(then_blk, buf, params_addr, n_params, t_nodes, t_cur, t_vid, t_lenv, t_lc, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(t_cur);
    let then_nonparam: i64 = nonparam_count_desc(t_nodes, then_n, 0);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else block: synth ConstI64(after_then, 0), then the block tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch_block(else_blk, buf, params_addr, n_params, e_nodes, e_cur, e_vid, e_lenv, e_lc, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(e_cur);
    let else_nonparam: i64 = nonparam_count_desc(e_nodes, else_n, 0);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- merge pass: merged names, per-name placeholders + merge_ids from after_else ---
    let t_lcount: i64 = __mind_load_i64(t_lc);
    let e_lcount: i64 = __mind_load_i64(e_lc);
    let mn: i64 = build_merged_names(t_lenv, t_lcount, e_lenv, e_lcount, buf, mspans);
    __mind_store_i64(mcount, mn);
    let final_ctr: i64 = assign_merge_vids(mspans, mn, buf, t_lenv, t_lcount, e_lenv, e_lcount, extra, after_else, 0);
    let dst: i64 = final_ctr;

    // --- emit OP_IF ---
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, c_nodes, cond_n, c_vid, 0, 0, 0, 0, 0);
    // then: synth + tree + then-edge placeholders.
    let then_extra_count: i64 = count_then_extras(extra, mn, 0);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1 + then_extra_count);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, t_nodes, then_n, t_vid, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_extra_consts(s7, extra, mn, 0, 0);
    let s9: EmitState = emit_uleb128(s8, then_root);
    // else: synth + tree + else-edge placeholders.
    let else_extra_count: i64 = count_else_extras(extra, mn, 0);
    let s10: EmitState = emit_uleb128(s9, else_nonparam + 1 + else_extra_count);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_mic3_tree_body(s11, e_nodes, else_n, e_vid, 0, 0, 0, 0, 0);
    let s13: EmitState = emit_extra_consts(s12, extra, mn, 1, 0);
    let s14: EmitState = emit_uleb128(s13, else_root);
    // dst, branch_bindings, merges.
    let s15: EmitState = emit_uleb128(s14, dst);
    let s16: EmitState = emit_uleb128(s15, mn);
    let s17: EmitState = emit_branch_bindings(s16, mspans, mn, buf, strbuf, offs, strcount, extra, 0);
    let s18: EmitState = emit_uleb128(s17, mn);
    let s19: EmitState = emit_merges(s18, extra, mn, 0);
    __mind_store_i64(okcell, dst);
    s19
}

// Count non-param nodes in an already-flattened descriptor (kind != 0).
pub fn nonparam_count_desc(nodes: i64, n_nodes: i64, i: i64) -> i64 {
    if i >= n_nodes {
        return 0;
    }
    let k: i64 = __mind_load_i64(nodes + i * 32);
    if k == 0 {
        return nonparam_count_desc(nodes, n_nodes, i + 1);
    }
    1 + nonparam_count_desc(nodes, n_nodes, i + 1)
}

// For each merged name allocate (then_extra, else_extra, merge_id) from the running
// counter `ctr`. A branch that DEFINES the name contributes -1 for its extra slot (no
// placeholder); otherwise a fresh vid is allocated (the per-branch placeholder). Order
// per name: then_extra, else_extra, merge_id. Returns the next free vid (= dst).
pub fn assign_merge_vids(mspans: i64, mn: i64, buf: i64, t_lenv: i64, t_lc: i64, e_lenv: i64, e_lc: i64, extra: i64, ctr: i64, k: i64) -> i64 {
    if k >= mn {
        return ctr;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let in_then: i64 = lenv_lookup_vid(t_lenv, t_lc, buf, lo, hi, 0);
    let in_else: i64 = lenv_lookup_vid(e_lenv, e_lc, buf, lo, hi, 0);
    // then_extra (placeholder vid, or -1 if the then-branch defines the name)
    let c1: i64 = ctr;
    if in_then >= 0 {
        __mind_store_i64(extra + k * 40 + 0, 0 - 1)
    }
    if in_then < 0 {
        __mind_store_i64(extra + k * 40 + 0, c1)
    }
    let c2: i64 = next_ctr(c1, in_then);
    // else_extra
    if in_else >= 0 {
        __mind_store_i64(extra + k * 40 + 8, 0 - 1)
    }
    if in_else < 0 {
        __mind_store_i64(extra + k * 40 + 8, c2)
    }
    let c3: i64 = next_ctr(c2, in_else);
    // merge_id (always fresh)
    __mind_store_i64(extra + k * 40 + 16, c3);
    // +24/+32 = the DEFINED-branch let-vid (used by emit_merges when extra slot is -1).
    __mind_store_i64(extra + k * 40 + 24, in_then);
    __mind_store_i64(extra + k * 40 + 32, in_else);
    assign_merge_vids(mspans, mn, buf, t_lenv, t_lc, e_lenv, e_lc, extra, c3 + 1, k + 1)
}
// ctr advances by 1 only when the branch did NOT define the name (in_branch < 0).
pub fn next_ctr(ctr: i64, in_branch: i64) -> i64 {
    if in_branch < 0 {
        return ctr + 1;
    }
    ctr
}

// Count then-edge / else-edge placeholders (extra slots != -1).
pub fn count_then_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 0);
    if v < 0 {
        return count_then_extras(extra, mn, k + 1);
    }
    1 + count_then_extras(extra, mn, k + 1)
}
pub fn count_else_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 8);
    if v < 0 {
        return count_else_extras(extra, mn, k + 1);
    }
    1 + count_else_extras(extra, mn, k + 1)
}

// Emit the placeholder ConstI64(vid, 0) for each merged name on the given edge
// (edge 0 = then-extra at +0, edge 1 = else-extra at +8), in merged-name order.
pub fn emit_extra_consts(s: EmitState, extra: i64, mn: i64, edge: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let off: i64 = edge * 8;
    let v: i64 = __mind_load_i64(extra + k * 40 + off);
    if v < 0 {
        return emit_extra_consts(s, extra, mn, edge, k + 1);
    }
    let s1: EmitState = emit_mic3_const_i64(s, v, 0);
    emit_extra_consts(s1, extra, mn, edge, k + 1)
}

// branch_bindings: per merged name (string_idx, merge_id). The name span is looked up
// in the contiguous strtab buffer to find its index.
pub fn emit_branch_bindings(s: EmitState, mspans: i64, mn: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, extra: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let sidx: i64 = strtab_index_of(strbuf, offs, strcount, buf, lo, hi, 0);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_branch_bindings(s2, mspans, mn, buf, strbuf, offs, strcount, extra, k + 1)
}

// merges: per merged name (merge_id, then_val, else_val). then_val = the then-branch's
// value (its let-vid if defined, else the then-placeholder); symmetric for else_val.
pub fn emit_merges(s: EmitState, extra: i64, mn: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let then_extra: i64 = __mind_load_i64(extra + k * 40 + 0);
    let else_extra: i64 = __mind_load_i64(extra + k * 40 + 8);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    // then_val: placeholder vid if extra set, else the resolved let-vid (stored at +24).
    let then_val: i64 = merge_val(then_extra, extra, k, 24);
    let else_val: i64 = merge_val(else_extra, extra, k, 32);
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = emit_uleb128(s1, then_val);
    let s3: EmitState = emit_uleb128(s2, else_val);
    emit_merges(s3, extra, mn, k + 1)
}
pub fn merge_val(extra_vid: i64, extra: i64, k: i64, off: i64) -> i64 {
    if extra_vid >= 0 {
        return extra_vid;
    }
    __mind_load_i64(extra + k * 40 + off)
}

// Assemble the full mic@3 module for
//   pub fn <name>(p0,..) -> i64 { if cond { <block> } else { <block> } }
// with non-empty merges, byte-exact vs --emit-mic3. `strcount` = n+1+n_letnames (the
// full string-table count: name, params, then branch-local let-names in encounter
// order). The body is n PARAM instrs then ONE OP_IF (body_len = n + 1).
pub fn emit_mic3_if_block_fn_module(s: EmitState, buf: i64, offs: i64, strcount: i64, n: i64, cond_expr: i64, then_blk: i64, else_blk: i64, src: i64, params_addr: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, strcount);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // Scratch pass to learn dst (the FN_DEF ret_vid) before framing.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_block_instr(es_new(), cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_block_instr(s12, cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j+): lex+parse `src`, find the first fn whose body is a
// single `if cond { block } else { block }` where a branch may be a multi-statement
// (let-bound) block, and emit its mic@3 module byte-exact vs --emit-mic3. `strbuf`/
// `offs`/`strcount` are the caller-supplied CONTIGUOUS string table (name, params,
// branch let-names in encounter order). All `*_nodes`/`*_cur`/`*_vid`/`*_lenv`/`*_lc`
// are per-branch heap scratch; `mspans` (merged-name spans), `mcount`, `extra`
// (per-name vid triples + values), `okcell` are merge scratch.
pub fn selftest_mic3_if_block_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, strcount: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    // Record the merge name-values into extra +24/+32 from the resolved let-envs: we
    // need a branch's per-name value (its let-vid). emit_mic3_if_block_instr fills
    // extra +0/+8/+16; the +24/+32 (then_val/else_val for defined names) are filled
    // by the binding pass via the let-envs. To keep merge_val simple, stash them here
    // after the scratch emit re-runs the merge — done inside the module emitter.
    emit_mic3_if_block_fn_module(es_new(), strbuf, offs, strcount, n_params, cond_expr, then_blk, else_blk, src_addr, params_addr, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell)
}

// ===== Fixed-literal writers =====

pub fn emit_lit_module_open(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 109);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 100);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 108);
    let s6: EmitState = es_push(s5, 101);
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, ch_lbrace());
    es_push(s8, ch_newline())
}

pub fn emit_lit_fn_comment_head(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_slash());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, 102);
    let s7: EmitState = es_push(s6, 110);
    es_push(s7, ch_space())
}

pub fn emit_lit_const_i64_head(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_percent());
    let s4: EmitState = emit_i64(s3, id);
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, ch_eq_sign());
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, 99);
    let s9: EmitState = es_push(s8, 111);
    let s10: EmitState = es_push(s9, 110);
    let s11: EmitState = es_push(s10, 115);
    let s12: EmitState = es_push(s11, 116);
    let s13: EmitState = es_push(s12, ch_dot());
    let s14: EmitState = es_push(s13, 105);
    let s15: EmitState = es_push(s14, 54);
    let s16: EmitState = es_push(s15, 52);
    es_push(s16, ch_space())
}

pub fn emit_lit_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, 111);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 116);
    let s6: EmitState = es_push(s5, 112);
    let s7: EmitState = es_push(s6, 117);
    let s8: EmitState = es_push(s7, 116);
    let s9: EmitState = es_push(s8, ch_space());
    let s10: EmitState = es_push(s9, ch_percent());
    let s11: EmitState = emit_i64(s10, id);
    es_push(s11, ch_newline())
}

// If-line literal fragments — the mic@1 text spelling of the flat If op
// `%dst = if cond=%c then=%t else=%e` (matches src/ir/print.rs).
pub fn emit_if_kw(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 105);
    es_push(s1, 102)
}
pub fn emit_cond_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 99);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 110);
    let s4: EmitState = es_push(s3, 100);
    es_push(s4, ch_eq_sign())
}
pub fn emit_then_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 116);
    let s2: EmitState = es_push(s1, 104);
    let s3: EmitState = es_push(s2, 101);
    let s4: EmitState = es_push(s3, 110);
    es_push(s4, ch_eq_sign())
}
pub fn emit_else_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 101);
    let s2: EmitState = es_push(s1, 108);
    let s3: EmitState = es_push(s2, 115);
    let s4: EmitState = es_push(s3, 101);
    es_push(s4, ch_eq_sign())
}

pub fn emit_lit_module_close(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_rbrace());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_slash());
    let s6: EmitState = es_push(s5, ch_space());
    let s7: EmitState = es_push(s6, 110);
    let s8: EmitState = es_push(s7, 101);
    let s9: EmitState = es_push(s8, 120);
    let s10: EmitState = es_push(s9, 116);
    let s11: EmitState = es_push(s10, 95);
    let s12: EmitState = es_push(s11, 105);
    let s13: EmitState = es_push(s12, 100);
    let s14: EmitState = es_push(s13, ch_space());
    let s15: EmitState = es_push(s14, ch_eq_sign());
    let s16: EmitState = es_push(s15, ch_space());
    let s17: EmitState = emit_i64(s16, s.next_id);
    es_push(s17, ch_newline())
}

pub fn emit_op_mnemonic(s: EmitState, op: i64) -> EmitState {
    if op == op_add() {
        let s1: EmitState = es_push(s, 97);
        let s2: EmitState = es_push(s1, 100);
        return es_push(s2, 100);
    }
    if op == op_sub() {
        let s1: EmitState = es_push(s, 115);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 98);
    }
    if op == op_mul() {
        let s1: EmitState = es_push(s, 109);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 108);
    }
    if op == op_div() {
        let s1: EmitState = es_push(s, 100);
        let s2: EmitState = es_push(s1, 105);
        return es_push(s2, 118);
    }
    if op == op_lt() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 116);
    }
    if op == op_gt() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 116);
    }
    if op == op_eq() {
        let s1: EmitState = es_push(s, 101);
        return es_push(s1, 113);
    }
    if op == op_le() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 101);
    }
    if op == op_ge() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 101);
    }
    if op == op_ne() {
        let s1: EmitState = es_push(s, 110);
        return es_push(s1, 101);
    }
    let s1: EmitState = es_push(s, 63);
    es_push(s1, 63)
}

// ===== Integer-literal value parsing =====

pub fn parse_int_span(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    parse_int_span(buf, lo + 1, hi, acc * 10 + (b - 48))
}

// ===== Expression lowering =====

pub fn emit_expr(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_ident() {
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_binop() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr(s1, buf, ast_child1(node));
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }

    if k == ast_paren() {
        return emit_expr(s, buf, ast_child0(node));
    }

    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args(s, buf, args_addr, args_len, 0);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

pub fn emit_call_args(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr(s, buf, arg_node);
    emit_call_args(s1, buf, args_addr, args_len, i + 1)
}

// ===== Statement lowering =====

pub fn emit_stmt(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return emit_expr(s, buf, ast_child2(node));
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let s2: EmitState = emit_lit_output(s1, s1.last_id);
        return s2;
    }
    emit_expr(s, buf, node)
}

pub fn emit_block_stmts(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt(s, buf, stmt_node);
    emit_block_stmts(s1, buf, stmts_addr, stmts_len, i + 1)
}

// ===== Function definition lowering =====

pub fn emit_fn_def(s: EmitState, buf: i64, node: i64) -> EmitState {
    let name_node: i64 = ast_child0(node);
    let name_lo: i64 = ast_span_lo(name_node);
    let name_hi: i64 = ast_span_hi(name_node);
    let s1: EmitState = emit_lit_fn_comment_head(s);
    let s2: EmitState = emit_byte_range(s1, buf, name_lo, name_hi);
    let s3: EmitState = es_push(s2, ch_newline());

    let id: i64 = s3.next_id;
    let s4: EmitState = emit_lit_const_i64_head(s3, id);
    let s5: EmitState = es_push(s4, 48);
    let s6: EmitState = es_push(s5, ch_newline());
    let s7: EmitState = EmitState { buf: s6.buf, next_id: id + 1, last_id: id, lets: s6.lets };
    emit_lit_output(s7, id)
}

// ===== Real-body lowering (param-resolving) — additive, isolated from the
//       canary path (mindc_compile->lower_program->emit_fn_def stays stubbed).
//       Resolves a parameter NAME to its SSA id (param i == %i), so function
//       bodies emit real ops (`%2 = add %0, %1` / `output %2`) instead of a
//       const.i64-0 placeholder. =====

// 1 if buf[alo..ahi] equals buf[blo..bhi] byte-for-byte, else 0.
pub fn span_bytes_equal(buf: i64, alo: i64, ahi: i64, blo: i64, bhi: i64) -> i64 {
    if (ahi - alo) == (bhi - blo) {
        span_bytes_equal_loop(buf, alo, ahi, blo, 0)
    } else {
        0
    }
}
pub fn span_bytes_equal_loop(buf: i64, alo: i64, ahi: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        1
    } else {
        if load_byte(buf, alo + k) == load_byte(buf, blo + k) {
            span_bytes_equal_loop(buf, alo, ahi, blo, k + 1)
        } else {
            0
        }
    }
}

// Return the SSA id (== param index) for the identifier buf[lo..hi] if it names
// a parameter of `params` (a block of ast_param nodes), else -1.
pub fn resolve_param(params_addr: i64, n_params: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_param_loop(buf, lo, hi, params_addr, n_params, 0)
}
pub fn resolve_param_loop(buf: i64, lo: i64, hi: i64, addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0 - 1
    } else {
        let pnode: i64 = __mind_load_i64(addr + i * 8);
        let name_leaf: i64 = ast_child0(pnode);
        if span_bytes_equal(buf, lo, hi, ast_span_lo(name_leaf), ast_span_hi(name_leaf)) == 1 {
            i
        } else {
            resolve_param_loop(buf, lo, hi, addr, n, i + 1)
        }
    }
}

// Expression lowering with a parameter environment. Identical to emit_expr
// except the ident branch resolves a param to its %SSA id (no instruction).
// Lower an if's else-branch into a scratch EmitState seeded at `else_seed`
// (the seed const id, consumed by Rust's else_ir.fresh()).  When there is no
// else clause (`else_blk == 0`) the seed const IS the else result, so we just
// return a scratch state whose last_id is the seed.  Otherwise we lower the
// else-block statements and return their trailing-value state.  The scratch
// buffer is discarded by the caller (the sub-stream ops are not printed in
// mic@1 text — see src/ir/print.rs Instr::If).
pub fn emit_if_else_branch(else_blk: i64, buf: i64, else_seed: i64, params_addr: i64, n_params: i64, lets: Map) -> EmitState {
    let sc: EmitState = EmitState { buf: string_new(), next_id: else_seed + 1, last_id: else_seed, lets: lets };
    if else_blk == 0 {
        return sc;
    }
    emit_block_stmts_env(sc, buf, ast_child0(else_blk), ast_aux(else_blk), 0, params_addr, n_params)
}

pub fn emit_expr_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: idx, lets: s.lets };
        }
        let lid: i64 = env_lookup(s.lets, buf, ast_span_lo(node), ast_span_hi(node));
        if lid != ty_unknown() {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: lid - 1, lets: s.lets };
        }
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_binop() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr_env(s1, buf, ast_child1(node), params_addr, n_params);
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_paren() {
        return emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    }
    if k == ast_neg() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_sub());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, c0);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, operand_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_not() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_eq());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, operand_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, c0);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_if() {
        // mic@1 If lowering — matches the Rust front-end (src/eval/lower.rs
        // ast::Node::If) and its print.rs text form: the condition, then-branch
        // and else-branch each lower into a hidden sub-stream, so the only
        // VISIBLE instruction in mic@1 text is the flat
        //   %dst = if cond=%c then=%t else=%e
        // line.  The sub-streams still consume SSA ids (each branch begins with
        // a `const.i64 0` seed via ir.fresh()), so we thread next_id through
        // scratch EmitStates to keep the dst id byte-identical to Rust, but we
        // discard their buffers (the sub-stream ops are not printed).
        let cond_node: i64 = ast_child0(node);
        let then_blk: i64 = ast_child1(node);
        let else_blk: i64 = ast_child2(node);

        // 1. Condition: lower into a scratch buffer seeded at the current id.
        let sc_cond: EmitState = EmitState { buf: string_new(), next_id: s.next_id, last_id: 0 - 1, lets: s.lets };
        let r_cond: EmitState = emit_expr_env(sc_cond, buf, cond_node, params_addr, n_params);
        let cond_id: i64 = r_cond.last_id;

        // 2. Then-branch: ir.fresh() seed const (consumed, not printed), then
        //    lower the block; then_result is the trailing value.
        let then_seed: i64 = r_cond.next_id;
        let sc_then: EmitState = EmitState { buf: string_new(), next_id: then_seed + 1, last_id: then_seed, lets: s.lets };
        let r_then: EmitState = emit_block_stmts_env(sc_then, buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params);
        let then_id: i64 = r_then.last_id;

        // 3. Else-branch: ir.fresh() seed const, then lower the block (or, when
        //    there is no else clause, the seed const IS the else result).
        let else_seed: i64 = r_then.next_id;
        let r_else: EmitState = emit_if_else_branch(else_blk, buf, else_seed, params_addr, n_params, s.lets);
        let else_id: i64 = r_else.last_id;

        // 4. dst = ir.fresh().
        let dst: i64 = r_else.next_id;

        // 5. Emit the single visible flat If line into the real buffer.
        let e1: EmitState = es_push(s, ch_space());
        let e2: EmitState = es_push(e1, ch_space());
        let e3: EmitState = es_push(e2, ch_percent());
        let e4: EmitState = emit_i64(e3, dst);
        let e5: EmitState = es_push(e4, ch_space());
        let e6: EmitState = es_push(e5, ch_eq_sign());
        let e7: EmitState = es_push(e6, ch_space());
        let e8: EmitState = emit_if_kw(e7);
        let e9: EmitState = es_push(e8, ch_space());
        let e10: EmitState = emit_cond_eq(e9);
        let e11: EmitState = es_push(e10, ch_percent());
        let e12: EmitState = emit_i64(e11, cond_id);
        let e13: EmitState = es_push(e12, ch_space());
        let e14: EmitState = emit_then_eq(e13);
        let e15: EmitState = es_push(e14, ch_percent());
        let e16: EmitState = emit_i64(e15, then_id);
        let e17: EmitState = es_push(e16, ch_space());
        let e18: EmitState = emit_else_eq(e17);
        let e19: EmitState = es_push(e18, ch_percent());
        let e20: EmitState = emit_i64(e19, else_id);
        let e21: EmitState = es_push(e20, ch_newline());
        return EmitState { buf: e21.buf, next_id: dst + 1, last_id: dst, lets: e21.lets };
    }
    if k == ast_field() {
        // mic@1 FieldAccess lowering — matches the Rust front-end
        // (src/eval/lower.rs ast::Node::FieldAccess) `None` arm: when the
        // receiver's struct type is unresolvable, the whole access lowers to a
        // single `const.i64 0` (the receiver is NOT re-lowered on that arm).
        // The bootstrap parser tracks no struct field-name order, so every
        // field access lands on the `None` arm and lowers to exactly one const.
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args_env(s, buf, args_addr, args_len, 0, params_addr, n_params);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

// Env-aware call-argument lowering: like emit_call_args but threads the
// parameter environment so an argument that names a parameter resolves to
// its %SSA id (and nested binops/consts lower to real ops). The call result
// itself stays a const.i64-0 placeholder (the canary/oracle does not surface
// a real call op in mic@1 text — only the arguments gain real lowering).
pub fn emit_call_args_env(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr_env(s, buf, arg_node, params_addr, n_params);
    emit_call_args_env(s1, buf, args_addr, args_len, i + 1, params_addr, n_params)
}

pub fn emit_stmt_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child2(node), params_addr, n_params);
        let name_leaf: i64 = ast_child0(node);
        let new_lets: Map = env_bind(s1.lets, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id + 1);
        return EmitState { buf: s1.buf, next_id: s1.next_id, last_id: s1.last_id, lets: new_lets };
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        return emit_lit_output(s1, s1.last_id);
    }
    emit_expr_env(s, buf, node, params_addr, n_params)
}

pub fn emit_block_stmts_env(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt_env(s, buf, stmt_node, params_addr, n_params);
    emit_block_stmts_env(s1, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// Real-body function lowering: params occupy SSA ids 0..n-1; the body emits
// real ops starting at %n, then the trailing value is `output`-ed.
pub fn emit_fn_def_with_body(s: EmitState, buf: i64, node: i64) -> EmitState {
    let params_addr: i64 = ast_child1(node);
    let n_params: i64 = ast_aux(node) / 2;
    let body: i64 = ast_child2(node);
    let s0: EmitState = EmitState { buf: s.buf, next_id: n_params, last_id: 0, lets: s.lets };
    let s1: EmitState = emit_block_stmts_env(s0, buf, ast_child0(body), ast_aux(body), 0, params_addr, n_params);
    emit_lit_output(s1, s1.last_id)
}

// Self-test entry: lex+parse `src`, find the first fn_def, lower its body with
// param resolution, return the EmitState (Python harness decodes EmitState.buf).
pub fn selftest_emit_fn_body(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    emit_fn_def_with_body(es_new(), src_addr, fn_node)
}
pub fn find_first_fn(addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0
    } else {
        let item: i64 = __mind_load_i64(addr + i * 8);
        if ast_kind(item) == ast_fn_def() {
            item
        } else {
            find_first_fn(addr, n, i + 1)
        }
    }
}

// ===== Program-level lowering =====

// Emit a single const.i64 0 / output stub for items that lower to a placeholder
// (UseDecl and StructDef — matches mindc-Rust lower_to_ir behaviour).
pub fn emit_item_stub(s: EmitState) -> EmitState {
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    let s4: EmitState = EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    emit_lit_output(s4, id)
}

pub fn emit_program_items(s: EmitState, buf: i64, items_addr: i64, items_len: i64, i: i64) -> EmitState {
    if i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let k: i64 = ast_kind(item);
    let s1: EmitState = if k == ast_fn_def() {
        emit_fn_def(s, buf, item)
    } else {
        if k == ast_use() {
            emit_item_stub(s)
        } else {
            if k == ast_struct_def() {
                emit_item_stub(s)
            } else {
                s
            }
        }
    };
    emit_program_items(s1, buf, items_addr, items_len, i + 1)
}

// ===== Public entry: lower_program =====

pub fn lower_program(ast_addr: i64, buf: i64) -> EmitState {
    let items_addr: i64 = ast_child0(ast_addr);
    let items_len: i64 = ast_aux(ast_addr);
    let s0: EmitState = es_new();
    let s1: EmitState = emit_lit_module_open(s0);
    let s2: EmitState = emit_program_items(s1, buf, items_addr, items_len, 0);
    emit_lit_module_close(s2)
}

pub fn flush_to_stdout(s: EmitState) -> i64 {
    print_bytes(string_addr(s.buf), string_len(s.buf))
}

// ===========================================================================
// SECTION 5 — COMBINED DRIVER (Phase 6.5 Stage 5 APEX)
// ===========================================================================

// mindc_compile(src_addr, src_len) -> i64
//
// Runs the full compilation pipeline:
//   1. lex(src_addr, src_len)         -> Vec (token stream)
//   2. parse(tokens, src_addr)         -> i64 (AST root / ast_program)
//   3. typecheck(ast_root, src_addr)   -> String (type-check report, unused)
//   4. lower_program(ast_root, src_addr) -> EmitState (MLIR text accumulator)
//
// Returns the i64 heap-record address of the EmitState.  The caller
// reads EmitState fields at the returned address:
//   offset  0 : buf     (String handle — addr/len/cap)
//   offset  8 : next_id (SSA value counter)
//   offset 16 : last_id (most-recently allocated SSA id)
//
// The Python harness (bootstrap_smoke.py) reads the EmitState via
// ctypes and compares the decoded String bytes to EXPECTED.md.

// mindc_compile returns EmitState (heap-record address in Option-C ABI).
// The Python harness calls it with c_int64 restype and reads the
// EmitState fields at the returned address:
//   offset  0 : buf     (String handle)
//   offset  8 : next_id (SSA counter)
//   offset 16 : last_id (last allocated SSA id)
pub fn mindc_compile(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let _tc: String = typecheck(ast_root, src_addr);
    lower_program(ast_root, src_addr)
}

// ===========================================================================
// SECTION 6 — STRUCT FIELD-NAME RETENTION (field-access groundwork, part 1)
//
// ADDITIVE / canary-isolated. The canonical parse_struct_def (above) still
// discards field names and emits exactly one stub leaf, so this code does NOT
// touch the mic@1/mic@3 emit path, EmitState, or the fixed-point bytes. It only
// PARSES the `name: type` field pairs of a struct and RETAINS the ordered
// field-name spans in a heap table, exposed via the selftests below. The table
// is the prerequisite for part 2 (param-type resolution + registry emit +
// flatten_ast field-idx); nothing here is reached through mindc_compile.
//
// Heap field-table layout (a single __mind_alloc block):
//   word[0]              : field count (n)
//   word[1 + 2*k + 0]    : span_lo of field k's name
//   word[1 + 2*k + 1]    : span_hi of field k's name
// Capacity is fixed at 64 fields (table = 8 * (1 + 2*64) = 1032 bytes), which
// comfortably covers any struct in main.mind's own grammar.
// ===========================================================================

pub fn sft_table_cap() -> i64 {
    64
}

pub fn sft_table_alloc() -> i64 {
    // 1 count word + cap*2 span words, 8 bytes each.
    let t: i64 = __mind_alloc((1 + sft_table_cap() * 2) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn sft_table_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

pub fn sft_table_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 2 + 0) * 8)
}

pub fn sft_table_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 2 + 1) * 8)
}

// Append one field-name span (lo, hi) to the table, bumping the count. Silently
// drops fields beyond sft_table_cap() (no struct in the grammar reaches it).
pub fn sft_table_push(t: i64, name_lo: i64, name_hi: i64) -> i64 {
    let n: i64 = sft_table_count(t);
    if n >= sft_table_cap() {
        return t;
    }
    __mind_store_i64(t + (1 + n * 2 + 0) * 8, name_lo);
    __mind_store_i64(t + (1 + n * 2 + 1) * 8, name_hi);
    __mind_store_i64(t + 0, n + 1);
    t
}

// Scan the token stream for the `{` that opens the first struct body. Returns
// the token index of the field-list start (just past `{`), or -1 if no struct.
// Mirrors parse_item's dispatch: a tk_ident whose span spells "struct" is the
// struct keyword; the next token is the name, then `{`.
pub fn sft_find_struct_body(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_struct_kw(buf, lo, hi) == 1 {
            // pos = struct kw, pos+1 = Name, pos+2 = `{`, fields start at pos+3.
            return pos + 3;
        }
    }
    sft_find_struct_body(toks, buf, pos + 1)
}

// Parse the `name: type` field pairs of a struct body into the table `t`.
// `pos` points just past `{`. Each field is `ident : type [,]`; the body ends at
// `}`. Retains only the field-NAME span (the ident before `:`). Tail-recursive.
pub fn sft_parse_fields(toks: Vec, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        return t;
    }
    // Expect: ident(name) colon ident(type). Retain the name span.
    if tok_kind(toks, pos) == tk_ident() {
        let _t: i64 = sft_table_push(t, tok_lo(toks, pos), tok_hi(toks, pos));
        // Skip `: type`. If the next token is a colon, step over colon + type.
        if tok_kind(toks, pos + 1) == tk_colon() {
            // After the type token may come a `,` separator; the loop's rbrace /
            // ident checks handle both the trailing-comma and no-comma cases.
            if tok_kind(toks, pos + 3) == tk_comma() {
                return sft_parse_fields(toks, pos + 4, t);
            }
            return sft_parse_fields(toks, pos + 3, t);
        }
    }
    // Defensive: unexpected token — advance one to avoid a non-terminating scan.
    sft_parse_fields(toks, pos + 1, t)
}

// Build (and return) a fresh field table for the first struct in `src`.
pub fn sft_build_table(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = sft_table_alloc();
    let body: i64 = sft_find_struct_body(tokens, src_addr, 0);
    if body < 0 {
        return t;
    }
    sft_parse_fields(tokens, body, t)
}

// Selftest export: number of fields parsed for the (first) struct in `src`.
pub fn selftest_struct_field_count(src_addr: i64, src_len: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    sft_table_count(t)
}

// Selftest export: the span_lo of field `i`'s name (or -1 if out of range).
pub fn selftest_struct_field_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_lo(t, i)
}

// Selftest export: the span_hi of field `i`'s name (or -1 if out of range).
pub fn selftest_struct_field_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_hi(t, i)
}

// Selftest export: the length (in bytes) of field `i`'s name span (hi - lo),
// or -1 if out of range. Lets a harness verify the right ident was retained
// without dealing in absolute source offsets.
pub fn selftest_struct_field_name_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = sft_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= sft_table_count(t) {
        return 0 - 1;
    }
    sft_table_name_hi(t, i) - sft_table_name_lo(t, i)
}

// ===========================================================================
// SECTION 6c — RECURSIVE-EMIT STRTAB COLLECTION FOR FIELD STRINGS (cutover
// fold, step 1). COLLECTION ONLY — no mic@3 byte-output, no canary touch.
//
// The recursive emit (selftest_mic3_module_from_ast) builds its string table via
// a SEPARATE collection pass (build_module_strtab -> collect_fn_strings ->
// collect_body_strings -> collect_expr_strings), mirroring Rust collect_strings /
// collect_instr_strings (src/ir/compact/v3/emit.rs ~492-586). Step 1 extends that
// pass so an ast_field (kind 17) anywhere in a body interns the synthetic
// "__mind_load_i64" call name in the EXACT first-seen order the oracle's
// collect_instr_strings(Instr::Call) produces (receiver strings first, then the
// load name; the CONST/BINOP offset path interns nothing; struct type/field names
// come from the registry pass, NOT the body traversal).
//
// These selftest exports run the collection pass over a parsed module into
// internally-allocated scratch and expose the interned table by index, so a unit
// smoke can assert names + first-seen order WITHOUT any byte emission.
// ===========================================================================

// Allocate scratch, lex+parse `src`, run build_module_strtab over the top-level
// item list, and return the strtab triple packed into a 4-i64 cell:
//   cell[0] = strbuf, cell[1] = offs, cell[2] = ccell, cell[3] = interned count.
// Returns the cell pointer. Scratch is sized for any small field-using module in
// the test grammar (4 KiB names, 256 offset slots).
pub fn cfs_run(src_addr: i64, src_len: i64) -> i64 {
    let strbuf: i64 = __mind_alloc(4096);
    let offs: i64 = __mind_alloc(256 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let cell: i64 = __mind_alloc(4 * 8);
    __mind_store_i64(cell + 0, strbuf);
    __mind_store_i64(cell + 8, offs);
    __mind_store_i64(cell + 16, ccell);
    __mind_store_i64(cell + 24, __mind_load_i64(ccell));
    cell
}

// Selftest export: number of strings interned by the collection pass for `src`.
pub fn selftest_collect_field_strings_count(src_addr: i64, src_len: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    __mind_load_i64(cell + 24)
}

// Selftest export: byte length of interned string `i` (offs[i+1]-offs[i]), or -1
// if out of range. Lets the smoke verify e.g. "__mind_load_i64" landed (len 15).
pub fn selftest_collect_field_strings_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let offs: i64 = __mind_load_i64(cell + 8);
    __mind_load_i64(offs + (i + 1) * 8) - __mind_load_i64(offs + i * 8)
}

// Selftest export: the j-th byte of interned string `i`, or -1 if out of range.
// The smoke reconstructs each interned name to assert first-seen order exactly.
pub fn selftest_collect_field_strings_byte(src_addr: i64, src_len: i64, i: i64, j: i64) -> i64 {
    let cell: i64 = cfs_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let strbuf: i64 = __mind_load_i64(cell + 0);
    let offs: i64 = __mind_load_i64(cell + 8);
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if j < 0 {
        return 0 - 1;
    }
    if j >= hi - lo {
        return 0 - 1;
    }
    load_byte(strbuf, lo + j)
}

// ---------------------------------------------------------------------------
// SECTION 6c (step 2) — RECURSIVE-EMIT REGISTRY-STRTAB COLLECTION.
// COLLECTION ONLY — no mic@3 byte-output, no canary touch. Purely additive.
//
// After the body-traversal pass (build_module_strtab, step 1) interns the instr
// strings, the canonical full string table APPENDS the struct_defs registry
// strings. The Rust oracle (src/ir/compact/v3/emit.rs collect_struct_def_strings,
// ~600-609) iterates module.struct_defs, which is a BTreeMap<String, Vec<String>>
// — so structs are visited in NAME-SORTED (alphabetical) order, NOT declaration
// order, and for each struct its TYPE name is interned first, then each FIELD name
// in declared order. Verified vs real --emit-mic3 on an out-of-declaration-order
// pair (declared Zeta, Alpha -> interned Alpha,p,q then Zeta,x,y).
//
// SECTION 6b's srt_* registry stores structs in DECLARATION order, so this pass
// drives a sorted traversal: srt_sorted_kth picks the k-th-smallest struct name,
// then srt_intern_all-style interning runs in that order. intern_span dedups, so
// re-interning is idempotent; struct/field names are distinct from instr strings.
// ---------------------------------------------------------------------------

// Lexicographic comparison of src[alo..ahi) vs src[blo..bhi): -1 if a<b, 0 if
// equal, 1 if a>b. Byte-wise compare to the shorter length; on a tie the shorter
// span is smaller. Mirrors Rust String Ord (BTreeMap key ordering) for ASCII
// identifier names. Both spans index the SAME source buffer.
pub fn span_cmp(src: i64, alo: i64, ahi: i64, blo: i64, bhi: i64) -> i64 {
    span_cmp_loop(src, alo, ahi, blo, bhi, 0)
}
pub fn span_cmp_loop(src: i64, alo: i64, ahi: i64, blo: i64, bhi: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        if blo + k >= bhi {
            return 0;
        }
        return 0 - 1;
    }
    if blo + k >= bhi {
        return 1;
    }
    let ca: i64 = load_byte(src, alo + k);
    let cb: i64 = load_byte(src, blo + k);
    if ca < cb {
        return 0 - 1;
    }
    if ca > cb {
        return 1;
    }
    span_cmp_loop(src, alo, ahi, blo, bhi, k + 1)
}

// Count how many struct names in registry `t` are strictly less than struct k's
// name (lexicographically). This is k's rank in sorted order — a selection-sort
// position without mutating the registry. (Struct names are distinct, so rank is
// unique.)
pub fn srt_rank_of(t: i64, src: i64, k: i64) -> i64 {
    srt_rank_loop(t, src, k, 0, 0)
}
pub fn srt_rank_loop(t: i64, src: i64, k: i64, j: i64, acc: i64) -> i64 {
    if j >= srt_count(t) {
        return acc;
    }
    if j == k {
        return srt_rank_loop(t, src, k, j + 1, acc);
    }
    if span_cmp(src, srt_name_lo(t, j), srt_name_hi(t, j), srt_name_lo(t, k), srt_name_hi(t, k)) < 0 {
        return srt_rank_loop(t, src, k, j + 1, acc + 1);
    }
    srt_rank_loop(t, src, k, j + 1, acc)
}

// Return the DECLARATION-order index of the struct whose name has sorted rank
// `r` (i.e. the r-th-smallest name), or -1 if none. Used to walk the registry in
// the BTreeMap order the oracle interns.
pub fn srt_sorted_kth(t: i64, src: i64, r: i64) -> i64 {
    srt_sorted_kth_loop(t, src, r, 0)
}
pub fn srt_sorted_kth_loop(t: i64, src: i64, r: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0 - 1;
    }
    if srt_rank_of(t, src, k) == r {
        return k;
    }
    srt_sorted_kth_loop(t, src, r, k + 1)
}

// Append the registry strings (struct type names + field names) to the strtab in
// BTreeMap-sorted order, reusing srt_intern_all's per-struct interning (type name
// then each field). `r` is the current sorted rank. Idempotent / additive.
pub fn build_module_registry_strtab(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> i64 {
    if r >= srt_count(t) {
        return 0;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    build_module_registry_strtab(strbuf, offs, ccell, src, t, r + 1)
}

// Run the FULL strtab collection for a field-using module: the step-1 body pass
// (instr strings) THEN the step-2 registry pass (struct type+field names, sorted),
// into internally-allocated scratch. Returns a 4-i64 cell:
//   cell[0]=strbuf, cell[1]=offs, cell[2]=ccell, cell[3]=interned count.
// This is the recursive-emit equivalent of emit_mic3's pre-pass
// (collect_strings ; collect_struct_def_strings). COLLECTION ONLY.
pub fn cfs_full_run(src_addr: i64, src_len: i64) -> i64 {
    let strbuf: i64 = __mind_alloc(4096);
    let offs: i64 = __mind_alloc(256 * 8);
    let ccell: i64 = __mind_alloc(8);
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let r0: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    let srt: i64 = srt_build(src_addr, src_len);
    let r1: i64 = build_module_registry_strtab(strbuf, offs, ccell, src_addr, srt, 0);
    let cell: i64 = __mind_alloc(4 * 8);
    __mind_store_i64(cell + 0, strbuf);
    __mind_store_i64(cell + 8, offs);
    __mind_store_i64(cell + 16, ccell);
    __mind_store_i64(cell + 24, __mind_load_i64(ccell));
    cell
}

// Selftest export: total strings interned by the FULL (instr + registry) pass.
pub fn selftest_full_strtab_count(src_addr: i64, src_len: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    __mind_load_i64(cell + 24)
}

// Selftest export: byte length of FULL-pass interned string `i`, or -1.
pub fn selftest_full_strtab_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let offs: i64 = __mind_load_i64(cell + 8);
    __mind_load_i64(offs + (i + 1) * 8) - __mind_load_i64(offs + i * 8)
}

// Selftest export: the j-th byte of FULL-pass interned string `i`, or -1.
pub fn selftest_full_strtab_byte(src_addr: i64, src_len: i64, i: i64, j: i64) -> i64 {
    let cell: i64 = cfs_full_run(src_addr, src_len);
    let n: i64 = __mind_load_i64(cell + 24);
    if i < 0 {
        return 0 - 1;
    }
    if i >= n {
        return 0 - 1;
    }
    let strbuf: i64 = __mind_load_i64(cell + 0);
    let offs: i64 = __mind_load_i64(cell + 8);
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if j < 0 {
        return 0 - 1;
    }
    if j >= hi - lo {
        return 0 - 1;
    }
    load_byte(strbuf, lo + j)
}

// ===========================================================================
// SECTION 6b — MULTI-STRUCT REGISTRY TABLE (field-access groundwork, part 1b)
//
// ADDITIVE / canary-isolated. Extends SECTION 6 from "the FIRST struct" to "ALL
// structs in declaration order", so a `recv.field` whose receiver is declared as
// the 2nd+ struct resolves against the CORRECT struct's field list. Mirrors how
// the Rust struct_defs registry (src/ir/compact/v3/emit.rs) lists every struct,
// and how emit_mic3 interns each struct's type name + fields in source order.
//
// Heap registry-table layout (a single __mind_alloc block):
//   word[0]                       : struct count (N)
//   per struct k, a fixed slot at  base = 1 + k * srt_slot_words():
//     slot[0]                     : span_lo of struct k's NAME
//     slot[1]                     : span_hi of struct k's NAME
//     slot[2]                     : field count of struct k (fc)
//     slot[3 + 2*j + 0]           : span_lo of field j's name
//     slot[3 + 2*j + 1]           : span_hi of field j's name
// Capacity is fixed at 16 structs * 16 fields each, comfortably covering any
// source in main.mind's own grammar.
// ===========================================================================

pub fn srt_struct_cap() -> i64 {
    16
}

pub fn srt_field_cap() -> i64 {
    16
}

// Words per struct slot: name_lo + name_hi + field_count + field_cap*2 spans.
pub fn srt_slot_words() -> i64 {
    3 + srt_field_cap() * 2
}

pub fn srt_alloc() -> i64 {
    // 1 count word + struct_cap slots, 8 bytes each.
    let t: i64 = __mind_alloc((1 + srt_struct_cap() * srt_slot_words()) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn srt_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

// Base WORD index of struct k's slot.
pub fn srt_slot_base(k: i64) -> i64 {
    1 + k * srt_slot_words()
}

pub fn srt_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 0) * 8)
}

pub fn srt_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 1) * 8)
}

pub fn srt_field_count(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 2) * 8)
}

pub fn srt_field_lo(t: i64, k: i64, j: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 3 + j * 2 + 0) * 8)
}

pub fn srt_field_hi(t: i64, k: i64, j: i64) -> i64 {
    __mind_load_i64(t + (srt_slot_base(k) + 3 + j * 2 + 1) * 8)
}

// Append a struct with name span (nlo, nhi) and zero fields, returning its index.
pub fn srt_push_struct(t: i64, nlo: i64, nhi: i64) -> i64 {
    let n: i64 = srt_count(t);
    if n >= srt_struct_cap() {
        return n;
    }
    __mind_store_i64(t + (srt_slot_base(n) + 0) * 8, nlo);
    __mind_store_i64(t + (srt_slot_base(n) + 1) * 8, nhi);
    __mind_store_i64(t + (srt_slot_base(n) + 2) * 8, 0);
    __mind_store_i64(t + 0, n + 1);
    n
}

// Append a field span (flo, fhi) to struct k, bumping its field count.
pub fn srt_push_field(t: i64, k: i64, flo: i64, fhi: i64) -> i64 {
    let fc: i64 = srt_field_count(t, k);
    if fc >= srt_field_cap() {
        return t;
    }
    __mind_store_i64(t + (srt_slot_base(k) + 3 + fc * 2 + 0) * 8, flo);
    __mind_store_i64(t + (srt_slot_base(k) + 3 + fc * 2 + 1) * 8, fhi);
    __mind_store_i64(t + (srt_slot_base(k) + 2) * 8, fc + 1);
    t
}

// Parse the `name: type` field pairs of struct k's body into the registry `t`.
// `pos` points just past `{`; ends at `}`. Retains each field-NAME span. Mirrors
// sft_parse_fields exactly but writes into struct k's slot. Tail-recursive.
pub fn srt_parse_fields(toks: Vec, pos: i64, t: i64, k: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let _t: i64 = srt_push_field(t, k, tok_lo(toks, pos), tok_hi(toks, pos));
        if tok_kind(toks, pos + 1) == tk_colon() {
            if tok_kind(toks, pos + 3) == tk_comma() {
                return srt_parse_fields(toks, pos + 4, t, k);
            }
            return srt_parse_fields(toks, pos + 3, t, k);
        }
    }
    srt_parse_fields(toks, pos + 1, t, k)
}

// Scan the token stream collecting EVERY `struct Name { fields }` into the
// registry `t` in declaration order. `pos` is the current token index. Mirrors
// sft_find_struct_body's struct-keyword detection but does not stop at the first.
pub fn srt_collect(toks: Vec, buf: i64, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_struct_kw(buf, lo, hi) == 1 {
            // pos = struct kw, pos+1 = Name, pos+2 = `{`, fields start at pos+3.
            let k: i64 = srt_push_struct(t, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1));
            let _t: i64 = srt_parse_fields(toks, pos + 3, t, k);
            // Skip past this struct body to avoid re-scanning its inner idents.
            let after: i64 = skip_to_rbrace(toks, pos + 3);
            return srt_collect(toks, buf, after, t);
        }
    }
    srt_collect(toks, buf, pos + 1, t)
}

// Build (and return) a fresh registry covering every struct in `src`.
pub fn srt_build(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = srt_alloc();
    srt_collect(tokens, src_addr, 0, t)
}

// Find the struct index whose NAME span equals src[tlo..thi), or -1. This is the
// multi-struct key: the receiver's declared type name selects the right struct.
pub fn srt_find_by_name(t: i64, src: i64, tlo: i64, thi: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0 - 1;
    }
    if span_bytes_equal(src, tlo, thi, srt_name_lo(t, k), srt_name_hi(t, k)) == 1 {
        return k;
    }
    srt_find_by_name(t, src, tlo, thi, k + 1)
}

// Resolve field name src[flo..fhi) to its index within struct k, or -1.
pub fn srt_field_index(t: i64, k: i64, src: i64, flo: i64, fhi: i64, j: i64) -> i64 {
    if j >= srt_field_count(t, k) {
        return 0 - 1;
    }
    if span_bytes_equal(src, flo, fhi, srt_field_lo(t, k, j), srt_field_hi(t, k, j)) == 1 {
        return j;
    }
    srt_field_index(t, k, src, flo, fhi, j + 1)
}

// Sum of field counts across structs 0..k (exclusive). The accessed field's
// string index = 4 (fn,param,load,struct0-type) ... actually each struct k
// contributes (1 type-name + its fields) strings in order, so the base string
// index of struct k's FIRST field is 3 + (k+1) + cumulative_fields(k); see
// srt_field_strbase below.
pub fn srt_cumulative_fields(t: i64, k: i64, acc: i64) -> i64 {
    if k <= 0 {
        return acc;
    }
    srt_cumulative_fields(t, k - 1, acc + srt_field_count(t, k - 1))
}

// String index of the FIRST field of struct k. Strings are interned in order:
//   0: fn name, 1: param name, 2: __mind_load_i64,
//   then per struct in declaration order: [type name] [field0..fieldN-1].
// So struct k's type name is at  3 + k + cumulative_fields(k); its first field
// at one past that.
pub fn srt_field_strbase(t: i64, k: i64) -> i64 {
    3 + k + srt_cumulative_fields(t, k, 0) + 1
}

// String index of struct k's TYPE name.
pub fn srt_type_strbase(t: i64, k: i64) -> i64 {
    3 + k + srt_cumulative_fields(t, k, 0)
}

// ---- SORTED-ORDER strbase math (cutover fold step 3) ----
// The canonical full string table appends registry strings in BTreeMap-sorted
// (struct-name) order, so a struct's string indices are keyed on its SORTED RANK,
// not its declaration index. These mirror srt_cumulative_fields / *_strbase but
// walk the first `r` SORTED-rank structs. cumulative_fields_sorted(r) sums the
// field counts of the r smallest-named structs; type_strbase_sorted(r) =
// 3 + r + that; field_strbase_sorted(r) = one past the type name.

// Sum of field counts across the structs of sorted rank 0..r (exclusive).
pub fn srt_cumulative_fields_sorted(t: i64, src: i64, r: i64, acc: i64) -> i64 {
    if r <= 0 {
        return acc;
    }
    let kp: i64 = srt_sorted_kth(t, src, r - 1);
    srt_cumulative_fields_sorted(t, src, r - 1, acc + srt_field_count(t, kp))
}

// String index of the TYPE name of the struct at sorted rank r.
pub fn srt_type_strbase_sorted(t: i64, src: i64, r: i64) -> i64 {
    3 + r + srt_cumulative_fields_sorted(t, src, r, 0)
}

// String index of the FIRST field of the struct at sorted rank r.
pub fn srt_field_strbase_sorted(t: i64, src: i64, r: i64) -> i64 {
    srt_type_strbase_sorted(t, src, r) + 1
}

// Intern every struct's strings in BTreeMap-sorted (name) order: for each sorted
// rank r, intern the type name then each field in declared order. Mirrors the
// Rust oracle's collect_struct_def_strings BTreeMap traversal (step 2's
// build_module_registry_strtab) but into the byte-emitter's own strbuf, so the
// emitted string indices match the sorted strtab. intern_span dedups.
pub fn srt_intern_all_sorted(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> i64 {
    if r >= srt_count(t) {
        return 0;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    srt_intern_all_sorted(strbuf, offs, ccell, src, t, r + 1)
}

// Emit the struct_defs registry for ALL N structs in BTreeMap-sorted (name) order:
// each entry is uleb(type_str_idx) || uleb(field_count) || field string idxs, the
// idxs computed against SORTED rank. Mirrors srt_emit_registry but sorted.
pub fn srt_emit_registry_sorted(s: EmitState, t: i64, src: i64, r: i64) -> EmitState {
    if r >= srt_count(t) {
        return s;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let s1: EmitState = emit_uleb128(s, srt_type_strbase_sorted(t, src, r));
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = ffa_emit_field_idxs(s2, srt_field_strbase_sorted(t, src, r), fc, 0);
    srt_emit_registry_sorted(s3, t, src, r + 1)
}

// Emit the struct_defs registry for ALL N structs in BTreeMap-sorted (name) order,
// resolving each string index by RE-INTERNING its span (intern_span is idempotent
// and dedup-aware, so it returns the slot already assigned by the strtab pass —
// independent of how many instruction strings preceded it). This is the dedup- and
// base-offset-correct variant of srt_emit_registry_sorted (which assumes the fixed
// 3-string field-read instr base); used by the general N-fn nfn driver where the
// instruction-string base varies per module. Each entry =
// uleb(type_str_idx) || uleb(field_count) || field string idxs.
pub fn srt_emit_registry_sorted_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, r: i64) -> EmitState {
    if r >= srt_count(t) {
        return s;
    }
    let k: i64 = srt_sorted_kth(t, src, r);
    let ty_idx: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let s1: EmitState = emit_uleb128(s, ty_idx);
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = srt_emit_field_idxs_interned(s2, strbuf, offs, ccell, src, t, k, 0);
    srt_emit_registry_sorted_interned(s3, strbuf, offs, ccell, src, t, r + 1)
}

// Emit struct k's field string indices by re-interning each field-name span
// (idempotent), in declared field order. Mirrors ffa_emit_field_idxs_interned but
// keyed on the multi-struct registry's per-struct field spans.
pub fn srt_emit_field_idxs_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64, j: i64) -> EmitState {
    if j >= srt_field_count(t, k) {
        return s;
    }
    let idx: i64 = intern_span(strbuf, offs, ccell, src, srt_field_lo(t, k, j), srt_field_hi(t, k, j));
    let s1: EmitState = emit_uleb128(s, idx);
    srt_emit_field_idxs_interned(s1, strbuf, offs, ccell, src, t, k, j + 1)
}

// ===========================================================================
// SECTION 7 — PER-FUNCTION PARAM-TYPE TABLE (field-access groundwork, part 2)
//
// ADDITIVE / canary-isolated. Mirrors SECTION 6's heap-table idiom exactly. The
// canonical parse_fn_def / parse_params_rest (above) are UNCHANGED: this code
// only re-scans a fn signature's `name: Type` param list and RETAINS the ordered
// (param-name span, type-name span) pairs in a heap table, exposed via the
// selftests below. It does NOT touch the mic@1/mic@3 emit path, EmitState, or the
// fixed-point bytes; nothing here is reached through mindc_compile.
//
// The (param-name -> declared type-name) binding is the receiver-type info a
// later `recv.field` access needs: resolve recv -> its declared struct type
// (part 2, this table) -> the field index in that struct (part 1's field table).
//
// Heap param-type-table layout (a single __mind_alloc block):
//   word[0]              : param count (n)
//   word[1 + 4*k + 0]    : span_lo of param k's NAME
//   word[1 + 4*k + 1]    : span_hi of param k's NAME
//   word[1 + 4*k + 2]    : span_lo of param k's declared TYPE name
//   word[1 + 4*k + 3]    : span_hi of param k's declared TYPE name
// Capacity is fixed at 32 params (table = 8 * (1 + 4*32) = 1032 bytes), which
// comfortably covers any fn signature in main.mind's own grammar.
// ===========================================================================

pub fn ptt_table_cap() -> i64 {
    32
}

pub fn ptt_table_alloc() -> i64 {
    // 1 count word + cap*4 span words, 8 bytes each.
    let t: i64 = __mind_alloc((1 + ptt_table_cap() * 4) * 8);
    __mind_store_i64(t + 0, 0);
    t
}

pub fn ptt_table_count(t: i64) -> i64 {
    __mind_load_i64(t + 0)
}

pub fn ptt_table_name_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 0) * 8)
}

pub fn ptt_table_name_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 1) * 8)
}

pub fn ptt_table_type_lo(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 2) * 8)
}

pub fn ptt_table_type_hi(t: i64, k: i64) -> i64 {
    __mind_load_i64(t + (1 + k * 4 + 3) * 8)
}

// Append one (param-name span, type-name span) row to the table, bumping the
// count. Silently drops params beyond ptt_table_cap() (no fn in the grammar
// reaches it).
pub fn ptt_table_push(t: i64, name_lo: i64, name_hi: i64, type_lo: i64, type_hi: i64) -> i64 {
    let n: i64 = ptt_table_count(t);
    if n >= ptt_table_cap() {
        return t;
    }
    __mind_store_i64(t + (1 + n * 4 + 0) * 8, name_lo);
    __mind_store_i64(t + (1 + n * 4 + 1) * 8, name_hi);
    __mind_store_i64(t + (1 + n * 4 + 2) * 8, type_lo);
    __mind_store_i64(t + (1 + n * 4 + 3) * 8, type_hi);
    __mind_store_i64(t + 0, n + 1);
    t
}

// Scan the token stream for the first fn signature's param-list start. Returns
// the token index just past `(`, or -1 if no fn. Mirrors parse_item's dispatch:
// a tk_kw_pub is skipped, a tk_kw_fn marks the signature; then pos+1 = name,
// pos+2 = `(`, params start at pos+3 (exactly parse_fn_def's layout).
pub fn ptt_find_param_list(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_kw_fn() {
        // pos = fn kw, pos+1 = Name, pos+2 = `(`, params start at pos+3.
        return pos + 3;
    }
    ptt_find_param_list(toks, pos + 1)
}

// Parse the `name: Type [,]` params of a fn signature into the table `t`.
// `pos` points just past `(`. Each param is `ident : Type`; the list ends at
// `)`. Retains both the param-NAME span and the declared TYPE-name span. Mirrors
// parse_params_rest's token layout exactly: name(pos), `:`(pos+1), Type(pos+2),
// then pos+3 is `,` (advance +4) or `)` (end). Tail-recursive.
pub fn ptt_parse_params(toks: Vec, pos: i64, t: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return t;
    }
    if tok_kind(toks, pos) == tk_rparen() {
        return t;
    }
    if tok_kind(toks, pos) == tk_ident() {
        // Expect: ident(name) colon ident(Type). Retain name + type spans.
        if tok_kind(toks, pos + 1) == tk_colon() {
            let _t: i64 = ptt_table_push(t, tok_lo(toks, pos), tok_hi(toks, pos), tok_lo(toks, pos + 2), tok_hi(toks, pos + 2));
            if tok_kind(toks, pos + 3) == tk_comma() {
                return ptt_parse_params(toks, pos + 4, t);
            }
            return ptt_parse_params(toks, pos + 3, t);
        }
    }
    // Defensive: unexpected token — advance one to avoid a non-terminating scan.
    ptt_parse_params(toks, pos + 1, t)
}

// Build (and return) a fresh param-type table for the first fn in `src`.
pub fn ptt_build_table(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let t: i64 = ptt_table_alloc();
    let plist: i64 = ptt_find_param_list(tokens, 0);
    if plist < 0 {
        return t;
    }
    ptt_parse_params(tokens, plist, t)
}

// Selftest export: number of params parsed for the (first) fn in `src`.
pub fn selftest_param_type_count(src_addr: i64, src_len: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_count(t)
}

// Selftest export: the span_lo of param `i`'s declared TYPE name (or -1).
pub fn selftest_param_type_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_lo(t, i)
}

// Selftest export: the span_hi of param `i`'s declared TYPE name (or -1).
pub fn selftest_param_type_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_hi(t, i)
}

// Selftest export: the length (bytes) of param `i`'s declared TYPE name span
// (hi - lo), or -1 if out of range.
pub fn selftest_param_type_name_len(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_type_hi(t, i) - ptt_table_type_lo(t, i)
}

// Selftest export: the span_lo of param `i`'s NAME (or -1). Lets a harness
// confirm the receiver binding (param-name -> declared type) is intact.
pub fn selftest_param_name_lo(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_name_lo(t, i)
}

// Selftest export: the span_hi of param `i`'s NAME (or -1).
pub fn selftest_param_name_hi(src_addr: i64, src_len: i64, i: i64) -> i64 {
    let t: i64 = ptt_build_table(src_addr, src_len);
    if i < 0 {
        return 0 - 1;
    }
    if i >= ptt_table_count(t) {
        return 0 - 1;
    }
    ptt_table_name_hi(t, i)
}

// ===========================================================================
// SECTION 8 — METHOD-CALL PARSER (UFCS groundwork, part 1)
//
// ADDITIVE / canary-isolated. A pure PARSER step — NO mic@3 byte-output, NO
// EmitState — so it cannot perturb the canary fixed point and cannot hit the
// EmitState segfault. It proves the pure-MIND front-end can PARSE a method call
// `recv.method(args...)` into a distinct node, retaining the method-NAME span,
// the receiver, and the argument count.
//
// The Rust oracle (src/eval/lower.rs MethodCall arm) lowers `recv.method(args)`
// via UFCS desugar to a plain Instr::Call named `{lowercase(ReceiverType)}_{method}`
// with the receiver threaded as the FIRST call arg: call_args = [recv, args...].
// Confirmed live: `p.dist(7)` on `p: Point` interns + calls `point_dist` in the
// mic@3 string table (130-byte artifact). Capturing the method-name span + arg
// count here is the prerequisite for that desugar; the receiver-type resolution
// (already built in SECTION 7's param-type table) supplies the `{lowercase(T)}_`
// prefix in a later, byte-output part.
//
// `ast_method` node layout (reuses the 7xi64 ast record):
//   [kind=ast_method, span_lo, span_hi, receiver(child0),
//    method_lo(child1), method_hi(child2), arg_count(aux)]
//
// This helper is self-contained: it token-scans for the first `ident . ident (`
// method-call shape (mirroring sft_find_struct_body's scan), parses the receiver
// as an ident leaf, and counts args via the existing parse_args_rest. It does
// NOT touch parse_postfix_rest (the shared parser), so the canary parse of
// main.mind's own source — which contains zero `recv.method(...)` calls — is
// byte-identical.
// ===========================================================================

// Build an ast_method node from an already-resolved receiver + method span +
// arg count.
pub fn mc_new_method(span_lo: i64, span_hi: i64, receiver: i64, method_lo: i64, method_hi: i64, arg_count: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_method());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, receiver);
    __mind_store_i64(n + 32, method_lo);
    __mind_store_i64(n + 40, method_hi);
    __mind_store_i64(n + 48, arg_count);
    n
}

// Scan the token stream for the first `ident . ident (` method-call shape.
// Returns the token index of the RECEIVER ident, or -1 if none. (`recv` at pos,
// `.` at pos+1, `method` ident at pos+2, `(` at pos+3.)
pub fn mc_find_method_call(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if tok_kind(toks, pos + 1) == tk_dot() {
            if tok_kind(toks, pos + 2) == tk_ident() {
                if tok_kind(toks, pos + 3) == tk_lparen() {
                    return pos;
                }
            }
        }
    }
    mc_find_method_call(toks, pos + 1)
}

// Parse the first method call in `src` into an ast_method node, or 0 if none.
pub fn mc_parse_first(src_addr: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let rpos: i64 = mc_find_method_call(tokens, 0);
    if rpos < 0 {
        return 0;
    }
    let recv_lo: i64 = tok_lo(tokens, rpos);
    let recv_hi: i64 = tok_hi(tokens, rpos);
    let receiver: i64 = ast_new_leaf(ast_ident(), recv_lo, recv_hi);
    let method_lo: i64 = tok_lo(tokens, rpos + 2);
    let method_hi: i64 = tok_hi(tokens, rpos + 2);
    // pos+3 = `(`. Zero-arg fast path: `(` immediately followed by `)`.
    let after_open: i64 = rpos + 4;
    if tok_kind(tokens, after_open) == tk_rparen() {
        let close_hi: i64 = tok_hi(tokens, after_open);
        return mc_new_method(recv_lo, close_hi, receiver, method_lo, method_hi, 0);
    }
    let args_res: ParseResult = parse_args_rest(tokens, after_open, src_addr, vec_new());
    let after_args: i64 = pr_pos(args_res);
    let args_node: i64 = pr_node(args_res);
    let arg_count: i64 = ast_aux(args_node);
    let close_hi: i64 = tok_hi(tokens, after_args);
    mc_new_method(recv_lo, close_hi, receiver, method_lo, method_hi, arg_count)
}

// Selftest export: 1 if `src` contains a parseable method call, else 0.
pub fn selftest_method_present(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0;
    }
    1
}

// Selftest export: the span_lo of the method NAME (or -1 if no method call).
pub fn selftest_method_name_lo(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child1(m)
}

// Selftest export: the span_hi of the method NAME (or -1 if no method call).
pub fn selftest_method_name_hi(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child2(m)
}

// Selftest export: the length (bytes) of the method NAME span, or -1.
pub fn selftest_method_name_len(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_child2(m) - ast_child1(m)
}

// Selftest export: the number of arguments parsed in the method call, or -1.
pub fn selftest_method_arg_count(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_aux(m)
}

// Selftest export: the AST kind of the receiver node (proves the receiver
// parsed as an ident leaf), or -1.
pub fn selftest_method_recv_kind(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_kind(ast_child0(m))
}

// PARSE-ONLY struct-literal probes (additive, canary-isolated — reached only via
// these exports, never through mindc_compile). Parse the WHOLE source buffer as a
// single expression with struct-lit ALLOWED (no_struct=0) starting at token 0;
// `selftest_struct_lit_kind` returns the root AST kind (ast_struct_lit()==19 for
// `Name { .. }`), `selftest_struct_lit_field_count` the field count. These prove
// the parse half landed; the emit half still fails closed (flatten_ast rejects
// ast_struct_lit), so no bytes are produced for a struct-lit body yet.
pub fn selftest_struct_lit_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let e: ParseResult = parse_expr_ns(toks, 0, src_addr, 0);
    ast_kind(pr_node(e))
}

pub fn selftest_struct_lit_field_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let e: ParseResult = parse_expr_ns(toks, 0, src_addr, 0);
    let n: i64 = pr_node(e);
    if ast_kind(n) != ast_struct_lit() {
        return 0 - 1;
    }
    ast_aux(n)
}

// Selftest export: the span_lo of the RECEIVER (or -1). Lets a harness confirm
// the receiver binding is intact for the later UFCS type-prefix resolution.
pub fn selftest_method_recv_lo(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    ast_span_lo(ast_child0(m))
}

// ===========================================================================
// SECTION 9 — METHOD-CALL RECEIVER-TYPE RESOLUTION -> UFCS CALLEE (part 2)
//
// ADDITIVE / canary-isolated. PARSER + RESOLUTION + STRING-BUILDING only — NO
// mic@3 byte-output, NO EmitState, NO touch of the canary. It cannot perturb the
// fixed point and cannot hit the EmitState segfault. It computes the UFCS callee
// NAME for a `recv.method(args)` call so part 3 (the byte-output) can intern it.
//
// The Rust oracle (src/eval/lower.rs MethodCall arm) desugars `recv.method(args)`
// to a plain Instr::Call named `{lowercase(ReceiverType)}_{method}`, receiver
// threaded as the FIRST call arg. Example: `p: Point`, `p.dist(7)` -> callee
// "point_dist". This part resolves recv -> its declared struct type T (reusing
// SECTION 7's param-type table ptt_*), then builds the callee string
// `{lowercase(T)}_{method}` into a caller-provided byte buffer.
//
// Resolution: ptt_build_table parses the (first) fn's params into the
// param-name -> declared-type-name table; mcr_find_param_by_name scans it for
// the param whose NAME bytes equal the receiver ident, yielding the param row
// (and thus its declared TYPE span). The lowercase transform maps ASCII A-Z
// (65..90) to a-z (+32); all other bytes pass through unchanged (mirrors the
// Rust to_lowercase on the leading type segment used by the UFCS desugar).
// ===========================================================================

// Lowercase one ASCII byte: A-Z (65..90) -> +32, all else unchanged.
pub fn mcr_lower_byte(b: i64) -> i64 {
    if b >= 65 {
        if b <= 90 {
            return b + 32;
        }
    }
    b
}

// Find the param index whose NAME span equals the receiver ident src[recv_lo..
// recv_hi); returns the index or -1. Tail-recursive over the ptt rows.
pub fn mcr_find_param_by_name(ptt: i64, src: i64, recv_lo: i64, recv_hi: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0 - 1;
    }
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k)) == 1 {
        return k;
    }
    mcr_find_param_by_name(ptt, src, recv_lo, recv_hi, k + 1)
}

// Write the lowercased bytes of src[lo..hi) into outbuf at cursor `j`; return the
// new cursor. Single-byte writes (__mind_store_i8), byte-contiguous.
pub fn mcr_write_lowered(outbuf: i64, j: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return j;
    }
    __mind_store_i8(outbuf + j, mcr_lower_byte(load_byte(src, lo)));
    mcr_write_lowered(outbuf, j + 1, src, lo + 1, hi)
}

// Write the raw (unmodified) bytes of src[lo..hi) into outbuf at cursor `j`;
// return the new cursor.
pub fn mcr_write_raw(outbuf: i64, j: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return j;
    }
    __mind_store_i8(outbuf + j, load_byte(src, lo));
    mcr_write_raw(outbuf, j + 1, src, lo + 1, hi)
}

// Resolve the receiver of the first method call in `src` to its declared struct
// type span. Returns a packed 1-i64 cell address holding [type_lo, type_hi] is
// awkward without tuples, so we expose the spans via dedicated selftests below
// and centralize the resolution here returning the matched ptt param index
// (-1 = no method call / receiver not a known param).
pub fn mcr_resolve_recv_param(src_addr: i64, src_len: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    let recv_lo: i64 = ast_span_lo(ast_child0(m));
    let recv_hi: i64 = ast_span_hi(ast_child0(m));
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    mcr_find_param_by_name(ptt, src_addr, recv_lo, recv_hi, 0)
}

// Selftest export: the ptt param index the receiver resolves to, or -1.
pub fn selftest_method_recv_param_idx(src_addr: i64, src_len: i64) -> i64 {
    mcr_resolve_recv_param(src_addr, src_len)
}

// Selftest export: span_lo of the receiver's resolved declared TYPE name, or -1.
pub fn selftest_method_recv_type_lo(src_addr: i64, src_len: i64) -> i64 {
    let k: i64 = mcr_resolve_recv_param(src_addr, src_len);
    if k < 0 {
        return 0 - 1;
    }
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_type_lo(ptt, k)
}

// Selftest export: span_hi of the receiver's resolved declared TYPE name, or -1.
pub fn selftest_method_recv_type_hi(src_addr: i64, src_len: i64) -> i64 {
    let k: i64 = mcr_resolve_recv_param(src_addr, src_len);
    if k < 0 {
        return 0 - 1;
    }
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    ptt_table_type_hi(ptt, k)
}

// Build the UFCS callee name `{lowercase(ReceiverType)}_{method}` for the first
// method call in `src`, writing the bytes into the caller-provided `outbuf`.
// Returns the callee length in bytes, or -1 if there is no parseable method call
// whose receiver resolves to a known param type (fail-closed; writes nothing on
// failure). The buffer is byte-contiguous (one __mind_store_i8 per byte).
pub fn selftest_method_callee_name_into(src_addr: i64, src_len: i64, outbuf: i64) -> i64 {
    let m: i64 = mc_parse_first(src_addr, src_len);
    if m == 0 {
        return 0 - 1;
    }
    let recv_lo: i64 = ast_span_lo(ast_child0(m));
    let recv_hi: i64 = ast_span_hi(ast_child0(m));
    let method_lo: i64 = ast_child1(m);
    let method_hi: i64 = ast_child2(m);
    let ptt: i64 = ptt_build_table(src_addr, src_len);
    let k: i64 = mcr_find_param_by_name(ptt, src_addr, recv_lo, recv_hi, 0);
    if k < 0 {
        return 0 - 1;
    }
    let ty_lo: i64 = ptt_table_type_lo(ptt, k);
    let ty_hi: i64 = ptt_table_type_hi(ptt, k);
    // {lowercase(T)} then `_` (95) then {method}.
    let j1: i64 = mcr_write_lowered(outbuf, 0, src_addr, ty_lo, ty_hi);
    __mind_store_i8(outbuf + j1, 95);
    let j2: i64 = j1 + 1;
    let j3: i64 = mcr_write_raw(outbuf, j2, src_addr, method_lo, method_hi);
    j3
}

// ===========================================================================
// SECTION 10 — WHILE-LOOP STRUCTURE SELFTEST (loops part 1)
//
// ADDITIVE / canary-isolated. PARSER + STRUCTURE-READING only — NO mic@3
// byte-output, NO EmitState, NO touch of the canary mindc_compile path. It
// cannot perturb the fixed point and cannot hit the EmitState segfault.
//
// The bootstrap dispatch (parse_stmt / parse_primary) does NOT recognise the
// `while` keyword — main.mind's own source uses no while loops — so a `while`
// spelling lexes as a bare tk_ident. This selftest therefore locates the loop
// by scanning the token stream for an ident-token spelling "while", then reads
// its structure by REUSING the existing parse_expr (condition) and parse_block
// (body) helpers. It never adds `while` to the shared statement dispatch, so the
// canary parse path — and the byte-identical fixed point — is unchanged.
//
// Token shape: `while COND { BODY }` — the `while` ident at `wp`, COND is a full
// expression (parse_expr stops at `{`, which has no infix precedence), then the
// `{` opens the body block which parse_block consumes. Mirrors the Rust
// front-end's parse_while (src/parser/mod.rs): consume "while", parse_expr cond,
// expect '{', parse body stmts, expect '}'.
// ===========================================================================

// Returns 1 if the bytes buf[lo..hi) spell "while" (5 bytes:
// w=119,h=104,i=105,l=108,e=101), else 0.
pub fn is_ident_while(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo) == 119 {
            if load_byte(buf, lo + 1) == 104 {
                if load_byte(buf, lo + 2) == 105 {
                    if load_byte(buf, lo + 3) == 108 {
                        if load_byte(buf, lo + 4) == 101 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// Scan the token stream for the first ident-token spelling "while". Returns the
// token index of that `while` token, or -1 if none. Tail-recursive.
pub fn wl_find_while(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if is_ident_while(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
            return pos;
        }
    }
    wl_find_while(toks, buf, pos + 1)
}

// Selftest export: 1 if `src` contains a `while` loop, else 0.
pub fn selftest_while_present(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0;
    }
    1
}

// Selftest export: the AST kind of the while CONDITION expression, or -1 if no
// while loop. Reuses parse_expr starting just after the `while` token; for a
// comparison condition (e.g. `i < n`) this is ast_binop().
pub fn selftest_while_cond_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0 - 1;
    }
    let cond: ParseResult = parse_expr_ns(toks, wp + 1, src_addr, 1);
    ast_kind(pr_node(cond))
}

// Selftest export: the number of statements in the while BODY block, or -1 if no
// while loop. parse_expr consumes the condition (stopping at `{`), then
// parse_block consumes the body and ast_aux yields its statement count.
pub fn selftest_while_body_stmt_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let wp: i64 = wl_find_while(toks, src_addr, 0);
    if wp < 0 {
        return 0 - 1;
    }
    let cond: ParseResult = parse_expr_ns(toks, wp + 1, src_addr, 1);
    let after_cond: i64 = pr_pos(cond);
    let body: ParseResult = parse_block(toks, after_cond, src_addr);
    ast_aux(pr_node(body))
}

// ===========================================================================
// SECTION 11 — WHILE-LOOP mic@3 BYTE-OUTPUT (0x1b While) (loops part 2)
//
// ADDITIVE / canary-isolated. Emits the mic@3 byte stream of a while-loop
// counter function, byte-identical to `mindc --emit-mic3`. Reached ONLY via
// the selftest_ export below — never through the canary mindc_compile path —
// so it cannot perturb the fixed point. EmitState idiom only (es_new/es_push,
// immutable threading); no raw es field reads.
//
// Instr::While layout (src/ir/compact/v3/emit.rs:1040, mirrored here):
//   OP_WHILE(0x1b) || vid(cond_id) || uleb(cond_instrs.len) || cond_instrs...
//     || uleb(body.len) || body... || encode_named_vids(live_vars)
//     || encode_vid_vec(init_ids) || encode_vid_vec(exit_ids)
//
// The oracle target is `pub fn count(n: i64) -> i64 {
//     let mut s: i64 = 0; while s < n { s = s + 1; } return s; }`
// whose FN_DEF body (5 instrs) is:
//   Param  %0 = n#1 idx 0
//   Const  %1 = 0                         (let mut s = 0)
//   While: cond_id=%2, cond=[Binop %2 = op_byte(%1,%0)]   (s < n)
//          body=[Const %3 = incr, Binop %4 = Add(%1,%3)]   (s = s + incr)
//          live_vars=[(s#2, %4)], init_ids=[%1], exit_ids=[%5]
//   Const  %6 = 0                         (while-stmt unit placeholder)
//   Return %5                             (return s -> the exit_id)
// The FN_DEF ret_id is %5 (the loop-carried exit id). The module-level scaffold
// (ConstI64 %0=0, Output %0) threads the FLAT next_id (= 1) — the body's vids
// %0..%6 live in the nested SSA namespace, not the flat module counter.
//
// Parametrised by `op_byte` (the comparison, 5 = Lt) and `incr` (the body
// increment constant). Verified incr=1 -> 73-byte oracle and incr=2 -> 71-byte
// oracle (the two differ ONLY in the single zigzag(incr) body-const byte), so
// this is a genuine narrow lowering, not a hardcoded blob.
// strtab[3] in first-seen order: count(#0), n(#1), s(#2). exports empty.
// ===========================================================================

// Instr::While { cond_id, cond_instrs=[Binop], body=[Const,Binop],
//   live_vars=[(s, %4)], init_ids=[%1], exit_ids=[%5] } — the loop node for the
// counter shape `while s < n { s = s + incr }`. cond %1<%0, body s+incr -> %4.
pub fn emit_mic3_while_counter(s: EmitState, op_byte: i64, incr: i64, s_name_idx: i64) -> EmitState {
    let s1: EmitState = es_push(s, 27);
    let s2: EmitState = emit_uleb128(s1, 2);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_mic3_binop(s3, 2, op_byte, 1, 0);
    let s5: EmitState = emit_uleb128(s4, 2);
    let s6: EmitState = emit_mic3_const_i64(s5, 3, incr);
    let s7: EmitState = emit_mic3_binop(s6, 4, 0, 1, 3);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, s_name_idx);
    let s10: EmitState = emit_uleb128(s9, 4);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_uleb128(s12, 1);
    emit_uleb128(s13, 5)
}

// Assemble the COMPLETE mic@3 module for the while-loop counter function,
// byte-exact vs the Rust --emit-mic3 oracle. Section order: header || strtab ||
// uleb(next_id=1) || exports(0) || uleb(instr_count=3) || FN_DEF count{...} ||
// ConstI64 %0=0 || Output %0 || empty registries.
pub fn emit_mic3_while_count_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, incr: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 3);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF count: name#0, params=[(n#1, %0)], ret_id=%5, body_len=5.
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_mic3_opt_vid(s10, 1, 5);
    let s12: EmitState = es_push(s11, 0);
    let s13: EmitState = emit_uleb128(s12, 5);
    let s14: EmitState = emit_mic3_param(s13, 0, 1, 0);
    let s15: EmitState = emit_mic3_const_i64(s14, 1, 0);
    let s16: EmitState = emit_mic3_while_counter(s15, op_byte, incr, 2);
    let s17: EmitState = emit_mic3_const_i64(s16, 6, 0);
    let s18: EmitState = emit_mic3_return(s17, 1, 5);
    // module-level scaffold: ConstI64 %0=0, Output %0 (flat next_id = 1).
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    emit_mic3_empty_registries(s20)
}

pub fn selftest_mic3_while_count(buf: i64, offs: i64, op_byte: i64, incr: i64) -> EmitState {
    emit_mic3_while_count_module(es_new(), buf, offs, op_byte, incr)
}

// ===========================================================================
// SECTION 12 — MATCH STRUCTURE (the match frontier, part 1)
//
// ADDITIVE / canary-isolated. PARSER + STRUCTURE-READING only — NO mic@3
// byte-output, NO EmitState, NO touch of the canary mindc_compile path. It
// cannot perturb the fixed point and cannot hit the EmitState segfault.
//
// The Rust front-end lowers `match` as a PURE AST-level desugar to a nested
// if/else chain (src/eval/lower.rs desugar_match_to_if): each test arm becomes
// a `<scrutinee> == <pat>` comparison feeding the keystone-protected If
// lowering, and a `_` / bare-ident arm becomes the terminal else. There is NO
// dedicated match/switch opcode — `match k { 0 => 10, 1 => 20, _ => 99 }` and
// the hand-written `if k == 0 { 10 } else if k == 1 { 20 } else { 99 }` emit
// byte-IDENTICAL mic@3 (both end in OP_IF 0x1c chains). So match byte-output,
// when it lands (part 2), reuses the OP_IF machinery — no new opcode.
//
// The bootstrap dispatch (parse_stmt / parse_primary) does NOT recognise the
// `match` keyword — main.mind's own source uses NO surface `match` (it
// dispatches AST node kinds with `if kind == X` chains) — so a `match`
// spelling lexes as a bare tk_ident. These selftests therefore locate the
// match by scanning the token stream for an ident-token spelling "match",
// parse the scrutinee with the existing parse_expr (which stops at `{`), then
// read the arm structure directly off the token stream. They never add `match`
// to the shared statement dispatch, so the canary parse path — and the
// byte-identical fixed point — is unchanged.
//
// Token shape: `match SCRUT { PAT => BODY , PAT => BODY , _ => BODY }`. The
// fat arrow `=>` is NOT a bootstrap token: byte `=` (61) fails the `==`
// peek-ahead and byte `>` (62) fails the `>=` peek-ahead, so `=>` lexes as the
// two-token sequence tk_eq() then tk_gt(). Each arm has exactly one `=>`, so
// the arm count is the number of `tk_eq tk_gt` pairs at brace-depth 0 inside
// the match body. A wildcard arm is a bare `_` (a single tk_ident spelling
// "_", byte 95 is alpha) immediately preceding a `=>` at depth 0.
// ===========================================================================

// Returns 1 if the bytes buf[lo..hi) spell "match" (5 bytes:
// m=109,a=97,t=116,c=99,h=104), else 0.
pub fn is_ident_match(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo) == 109 {
            if load_byte(buf, lo + 1) == 97 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 99 {
                        if load_byte(buf, lo + 4) == 104 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// Returns 1 if the bytes buf[lo..hi) spell "_" (1 byte: underscore=95), else 0.
pub fn is_ident_underscore(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 1 {
        if load_byte(buf, lo) == 95 {
            return 1;
        }
    }
    0
}

// Scan the token stream for the first ident-token spelling "match". Returns the
// token index of that `match` token, or -1 if none. Tail-recursive.
pub fn mt_find_match(toks: Vec, buf: i64, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if is_ident_match(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
            return pos;
        }
    }
    mt_find_match(toks, buf, pos + 1)
}

// Count the `=>` fat arrows (tk_eq immediately followed by tk_gt) at brace
// depth 0 between the match body's opening `{` and its matching `}`. `pos` is
// the token index just AFTER the opening `{`; `depth` is the open-brace nesting
// (0 at the arm level). Each arm contributes exactly one depth-0 `=>`, so the
// returned count is the arm count. Tail-recursive with an accumulator.
pub fn mt_count_arrows(toks: Vec, pos: i64, depth: i64, acc: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return acc;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return mt_count_arrows(toks, pos + 1, depth + 1, acc);
    }
    if k == tk_rbrace() {
        if depth == 0 {
            return acc;
        }
        return mt_count_arrows(toks, pos + 1, depth - 1, acc);
    }
    if depth == 0 {
        if k == tk_eq() {
            if tok_kind(toks, pos + 1) == tk_gt() {
                return mt_count_arrows(toks, pos + 2, depth, acc + 1);
            }
        }
    }
    mt_count_arrows(toks, pos + 1, depth + 0, acc)
}

// Scan the arm region for a wildcard arm: a bare `_` ident token immediately
// followed by a `=>` (tk_eq tk_gt) at brace depth 0. Returns 1 if found, else
// 0. `pos` is just after the opening `{`. Tail-recursive.
pub fn mt_find_wildcard(toks: Vec, buf: i64, pos: i64, depth: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0;
    }
    let k: i64 = tok_kind(toks, pos);
    if k == tk_lbrace() {
        return mt_find_wildcard(toks, buf, pos + 1, depth + 1);
    }
    if k == tk_rbrace() {
        if depth == 0 {
            return 0;
        }
        return mt_find_wildcard(toks, buf, pos + 1, depth - 1);
    }
    if depth == 0 {
        if k == tk_ident() {
            if is_ident_underscore(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
                if tok_kind(toks, pos + 1) == tk_eq() {
                    if tok_kind(toks, pos + 2) == tk_gt() {
                        return 1;
                    }
                }
            }
        }
    }
    mt_find_wildcard(toks, buf, pos + 1, depth + 0)
}

// Selftest export: 1 if `src` contains a `match` expression, else 0.
pub fn selftest_match_present(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0;
    }
    1
}

// Selftest export: the number of arms in the match, or -1 if no match. The
// scrutinee is parsed with the existing parse_expr (it stops at `{`), then the
// arm count is the number of depth-0 `=>` arrows in the match body.
pub fn selftest_match_arm_count(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    let lbrace_pos: i64 = pr_pos(scrut);
    mt_count_arrows(toks, lbrace_pos + 1, 0, 0)
}

// Selftest export: the AST kind of the match SCRUTINEE expression, or -1 if no
// match. Reuses parse_expr starting just after the `match` token; for a bare
// identifier scrutinee (e.g. `match k`) this is ast_ident().
pub fn selftest_match_scrut_kind(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    ast_kind(pr_node(scrut))
}

// Selftest export: 1 if the match has a wildcard `_` arm, 0 if not, -1 if no
// match.
pub fn selftest_match_has_wildcard(src_addr: i64, src_len: i64) -> i64 {
    let toks: Vec = lex(src_addr, src_len);
    let mp: i64 = mt_find_match(toks, src_addr, 0);
    if mp < 0 {
        return 0 - 1;
    }
    let scrut: ParseResult = parse_expr_ns(toks, mp + 1, src_addr, 1);
    let lbrace_pos: i64 = pr_pos(scrut);
    mt_find_wildcard(toks, src_addr, lbrace_pos + 1, 0)
}
