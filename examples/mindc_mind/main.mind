pub fn ast_new_program(span_lo: i64, span_hi: i64, items_addr: i64, items_len: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_program());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, items_addr);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, items_len);
    n
}

pub fn ast_new_paren(span_lo: i64, span_hi: i64, inner: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_paren());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, inner);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_neg(span_lo: i64, span_hi: i64, operand: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_neg());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, operand);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

pub fn ast_new_not(span_lo: i64, span_hi: i64, operand: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_not());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, operand);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

// `EXPR as i8/i16/i32`: child0 = operand expr, aux (offset 48) = target bit width
// (8/16/32). child1/child2 are 0 (a unary node — mirrors ast_new_neg's layout).
pub fn ast_new_cast(span_lo: i64, span_hi: i64, operand: i64, width: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_cast());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, operand);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, width);
    n
}

// `receiver.field`: child0=receiver expr, child1/child2 (offsets 32/40) carry
// the field-name span (lo/hi) into the source buffer.  Mirrors the Rust
// front-end's ast::Node::FieldAccess { receiver, field, span }.  The emitter
// (emit_expr_env ast_field arm) lowers it to a single `const.i64 0` — the
// byte-identical match to lower.rs's FieldAccess `None` arm, taken whenever the
// receiver's struct type is unresolvable (the bootstrap parser tracks no
// struct field-name order, so every field access lands on that arm).
pub fn ast_new_field(span_lo: i64, span_hi: i64, receiver: i64, field_lo: i64, field_hi: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_field());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, receiver);
    __mind_store_i64(n + 32, field_lo);
    __mind_store_i64(n + 40, field_hi);
    __mind_store_i64(n + 48, 0);
    n
}

// `Name { f0: e0, f1: e1, ... }`: child0=struct-name span_lo, child1=fields
// vec addr, child2=struct-name span_hi, aux=field count. The fields vec stores
// 3×i64 per field in SOURCE ORDER: (field-name span_lo, field-name span_hi,
// value-expr node). PARSE-ONLY — flatten_ast rejects ast_struct_lit so the
// emitter fails closed (no bytes) until the desugar half lands. Mirrors the
// Rust front-end's ast::Node::StructLit { name, fields }.
pub fn ast_new_struct_lit(span_lo: i64, span_hi: i64, name_lo: i64, name_hi: i64, fields_addr: i64, field_count: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_struct_lit());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name_lo);
    __mind_store_i64(n + 32, fields_addr);
    __mind_store_i64(n + 40, name_hi);
    __mind_store_i64(n + 48, field_count);
    // +56 = struct-lit annotation slot (0 until the prefold resolves it; 0 => flatten_ast
    // fails closed on this struct-lit, keeping the canary/oracle path).
    __mind_store_i64(n + 56, 0);
    n
}

// `if cond { then } else { else }`: child0=cond expr, child1=then-block,
// child2=else-block (0 when no else clause).  Matches the Rust front-end's
// ast::Node::If (cond / then_branch / else_branch).
pub fn ast_new_if(span_lo: i64, span_hi: i64, cond: i64, then_blk: i64, else_blk: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_if());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, cond);
    __mind_store_i64(n + 32, then_blk);
    __mind_store_i64(n + 40, else_blk);
    __mind_store_i64(n + 48, 0);
    n
}

// `while cond { body }`: child0 = cond expr, child1 = body block, child2 = 0.
// Mirrors the Rust front-end's ast::Node::While { cond, body }.
pub fn ast_new_while(span_lo: i64, span_hi: i64, cond: i64, body: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_while());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, cond);
    __mind_store_i64(n + 32, body);
    __mind_store_i64(n + 40, 0);
    __mind_store_i64(n + 48, 0);
    n
}

// `name = value`: child0 = name leaf (ast_ident), child2 = value expr. The
// value lives at +40 (child2) so the count/emit arms reuse `let`'s slot layout
// (init at child2). Mirrors ast::Node::Assign { name, value }.
pub fn ast_new_assign(span_lo: i64, span_hi: i64, name: i64, value: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_assign());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, name);
    __mind_store_i64(n + 32, 0);
    __mind_store_i64(n + 40, value);
    __mind_store_i64(n + 48, 0);
    n
}

// ===== AST accessors =====

pub fn ast_kind(node: i64) -> i64 {
    __mind_load_i64(node + 0)
}
pub fn ast_span_lo(node: i64) -> i64 {
    __mind_load_i64(node + 8)
}
pub fn ast_span_hi(node: i64) -> i64 {
    __mind_load_i64(node + 16)
}
pub fn ast_child0(node: i64) -> i64 {
    __mind_load_i64(node + 24)
}
pub fn ast_child1(node: i64) -> i64 {
    __mind_load_i64(node + 32)
}
pub fn ast_child2(node: i64) -> i64 {
    __mind_load_i64(node + 40)
}
pub fn ast_aux(node: i64) -> i64 {
    __mind_load_i64(node + 48)
}

// ===== ParseResult =====

struct ParseResult {
    next_pos: i64,
    node: i64,
}

pub fn pr_new(next_pos: i64, node: i64) -> ParseResult {
    ParseResult { next_pos: next_pos, node: node }
}

pub fn pr_pos(r: ParseResult) -> i64 {
    r.next_pos
}
pub fn pr_node(r: ParseResult) -> i64 {
    r.node
}

// ===== Return-keyword detector =====

pub fn is_ident_return(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo) == 114 {
            if load_byte(buf, lo + 1) == 101 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 117 {
                        if load_byte(buf, lo + 4) == 114 {
                            if load_byte(buf, lo + 5) == 110 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// `while` is detected via the pre-existing `is_ident_while` (defined alongside
// the wl_* while-scanner further down) — the same byte-compare disambiguation
// the parser uses for `return`.

// `break` (98,114,101,97,107).
pub fn is_ident_break(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo + 0) == 98 {
            if load_byte(buf, lo + 1) == 114 {
                if load_byte(buf, lo + 2) == 101 {
                    if load_byte(buf, lo + 3) == 97 {
                        if load_byte(buf, lo + 4) == 107 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// `continue` (99,111,110,116,105,110,117,101).
pub fn is_ident_continue(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 8 {
        if load_byte(buf, lo + 0) == 99 {
            if load_byte(buf, lo + 1) == 111 {
                if load_byte(buf, lo + 2) == 110 {
                    if load_byte(buf, lo + 3) == 116 {
                        if load_byte(buf, lo + 4) == 105 {
                            if load_byte(buf, lo + 5) == 110 {
                                if load_byte(buf, lo + 6) == 117 {
                                    if load_byte(buf, lo + 7) == 101 {
                                        return 1;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// `mut` (109,117,116): the optional mutability marker after `let`.
pub fn is_ident_mut(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 3 {
        if load_byte(buf, lo + 0) == 109 {
            if load_byte(buf, lo + 1) == 117 {
                if load_byte(buf, lo + 2) == 116 {
                    return 1;
                }
            }
        }
    }
    0
}

// `as` (the cast keyword) lexes as a bare 2-byte ident: 'a'=97, 's'=115. The cast
// keyword is reserved, so no MIND identifier can spell `as`; matching by content is
// unambiguous (mirrors is_ident_mut / is_ident_while).
pub fn is_ident_as(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 2 {
        if load_byte(buf, lo + 0) == 97 {
            if load_byte(buf, lo + 1) == 115 {
                return 1;
            }
        }
    }
    0
}

// The type name `i64` (3 bytes: 'i'=105, '6'=54, '4'=52). Used to gate the `as`
// cast to the WIDENING-to-i64 target, whose value passthrough is exact for every
// integer source width. Narrowing targets (i8/i16/i32) would need a real
// two's-complement truncation and are deliberately NOT matched here — they stay
// fail-closed rather than passthrough-miscompile.
pub fn is_ident_i64(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 3 {
        if load_byte(buf, lo + 0) == 105 {
            if load_byte(buf, lo + 1) == 54 {
                if load_byte(buf, lo + 2) == 52 {
                    return 1;
                }
            }
        }
    }
    0
}

// The NARROWING integer cast targets: `i8`->8, `i16`->16, `i32`->32, else 0.
// Bytes: 'i'=105, '8'=56, '1'=49, '6'=54, '3'=51, '2'=50. `i64` is NOT matched here
// (it is the widening passthrough gated by is_ident_i64). Used by parse_postfix_rest
// to wrap `EXPR as iN` in an ast_cast node carrying the target width.
pub fn narrow_cast_width(buf: i64, lo: i64, hi: i64) -> i64 {
    // `i8` (2 bytes: i 8)
    if hi - lo == 2 {
        if load_byte(buf, lo + 0) == 105 {
            if load_byte(buf, lo + 1) == 56 {
                return 8;
            }
        }
        return 0;
    }
    // `i16` / `i32` (3 bytes: i 1 6 | i 3 2)
    if hi - lo == 3 {
        if load_byte(buf, lo + 0) == 105 {
            if load_byte(buf, lo + 1) == 49 {
                if load_byte(buf, lo + 2) == 54 {
                    return 16;
                }
            }
            if load_byte(buf, lo + 1) == 51 {
                if load_byte(buf, lo + 2) == 50 {
                    return 32;
                }
            }
        }
    }
    0
}

// ===== Pratt precedence table =====

// Binding precedence (higher = tighter). The bitwise/shift ops are interleaved to
// match the Rust mindc parser exactly (verified vs --emit-mic3): multiplicative >
// additive > comparison > shift > bitand > bitxor > bitor > assignment. The
// pre-existing levels (assignment / comparison / additive / multiplicative) keep
// their relative order; the bitwise tiers are inserted between comparison and
// assignment, so the existing levels are renumbered upward (no tree-shape change
// for non-bitwise expressions — relative ordering is what the Pratt loop reads).
pub fn infix_prec(kind: i64) -> i64 {
    if kind == tk_eq() {
        return 1;
    }
    // Logical `||` (loosest, above assignment) < `&&` < all bitwise/comparison.
    // Only the relative ordering matters to the Pratt loop, so inserting these two
    // levels between assignment and bitor and renumbering the tighter levels upward
    // leaves every pre-existing (non-logical) expression's parse tree UNCHANGED —
    // main.mind uses no `&&`/`||`, so its self-compile stays byte-identical.
    if kind == tk_oror() {
        return 2;
    }
    if kind == tk_andand() {
        return 3;
    }
    if kind == tk_pipe() {
        return 4;
    }
    if kind == tk_caret() {
        return 5;
    }
    if kind == tk_amp() {
        return 6;
    }
    if kind == tk_shl() {
        return 7;
    }
    if kind == tk_shr() {
        return 7;
    }
    if kind == tk_lt() {
        return 8;
    }
    if kind == tk_gt() {
        return 8;
    }
    if kind == tk_eqeq() {
        return 8;
    }
    if kind == tk_le() {
        return 8;
    }
    if kind == tk_ge() {
        return 8;
    }
    if kind == tk_ne() {
        return 8;
    }
    if kind == tk_plus() {
        return 9;
    }
    if kind == tk_minus() {
        return 9;
    }
    if kind == tk_star() {
        return 10;
    }
    if kind == tk_slash() {
        return 10;
    }
    if kind == tk_percent() {
        return 10;
    }
    0
}

pub fn tk_to_op(kind: i64) -> i64 {
    if kind == tk_plus() {
        return op_add();
    }
    if kind == tk_minus() {
        return op_sub();
    }
    if kind == tk_star() {
        return op_mul();
    }
    if kind == tk_slash() {
        return op_div();
    }
    if kind == tk_percent() {
        return op_mod();
    }
    if kind == tk_lt() {
        return op_lt();
    }
    if kind == tk_gt() {
        return op_gt();
    }
    if kind == tk_eq() {
        return op_eq();
    }
    if kind == tk_eqeq() {
        return op_eq();
    }
    if kind == tk_le() {
        return op_le();
    }
    if kind == tk_ge() {
        return op_ge();
    }
    if kind == tk_ne() {
        return op_ne();
    }
    if kind == tk_amp() {
        return op_bitand();
    }
    if kind == tk_pipe() {
        return op_bitor();
    }
    if kind == tk_caret() {
        return op_bitxor();
    }
    if kind == tk_shl() {
        return op_shl();
    }
    if kind == tk_shr() {
        return op_shr();
    }
    0
}

// ===== Primary / prefix parser =====

// Struct-literal disambiguation (mirrors the Rust front-end): an `Ident {` in
// expression position is a struct-literal CONSTRUCTION, EXCEPT in CONDITION
// position (the head of `if`/`while`/`for`/`match`), where the `{` opens the
// block, not a literal. The `no_struct` flag carries that context: it is set
// only on the condition expression and threaded down parse_expr → parse_postfix
// → parse_primary → parse_pratt. It is RESET to "allowed" inside any
// parenthesised group (parse_expr) and any call-arg list (parse_args_rest), so
// `if f(P { .. }) { }` still parses the inner literal. main.mind never uses a
// struct-literal as a condition, so the only observable effect of this rule is
// that existing `if/while/for IDENT {` parses stay byte-identical.
//
// `parse_primary` keeps its 3-arg signature (struct-lit ALLOWED) as a thin
// wrapper so every pre-existing call-site is unchanged; the threaded core lives
// in `parse_primary_ns`.
pub fn parse_primary(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_primary_ns(toks, pos, buf, 0)
}

pub fn parse_primary_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);

    if k == tk_kw_if() {
        return parse_if(toks, pos, buf);
    }

    if k == tk_minus() {
        let operand: ParseResult = parse_primary_ns(toks, pos + 1, buf, no_struct);
        let opnode: i64 = pr_node(operand);
        let neg: i64 = ast_new_neg(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), neg);
    }

    if k == tk_bang() {
        let operand: ParseResult = parse_primary_ns(toks, pos + 1, buf, no_struct);
        let opnode: i64 = pr_node(operand);
        let notn: i64 = ast_new_not(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), notn);
    }

    if k == tk_int() {
        let n: i64 = ast_new_leaf(ast_int_lit(), lo, hi);
        return pr_new(pos + 1, n);
    }

    if k == tk_float() {
        // Float literal leaf: [lo, hi) spans the raw `<digits>.<digits>` source
        // text. Lowering is deferred (see ast_float_lit): the parser only
        // produces the node this pass.
        let fnode: i64 = ast_new_leaf(ast_float_lit(), lo, hi);
        return pr_new(pos + 1, fnode);
    }

    if k == tk_lparen() {
        // Parenthesised group RESETS no_struct: `( Ident { .. } )` is a literal.
        let inner: ParseResult = parse_expr(toks, pos + 1, buf);
        let after_inner: i64 = pr_pos(inner);
        let close_hi: i64 = tok_hi(toks, after_inner);
        let after_close: i64 = if tok_kind(toks, after_inner) == tk_rparen() {
            after_inner + 1
        } else {
            after_inner
        };
        let paren: i64 = ast_new_paren(lo, close_hi, pr_node(inner));
        return pr_new(after_close, paren);
    }

    if k == tk_ident() {
        // Match-expression: `match SCRUT { ... }` desugars at parse time to an
        // ast_if. Detected via is_ident_match (match is a bare ident, not a
        // keyword token), mirroring the is_struct_kw dispatch. Checked before
        // the call/struct-lit shapes so `match c { ... }` never misreads.
        if is_ident_match(buf, lo, hi) == 1 {
            return parse_match(toks, pos, buf);
        }
        if at_eof(toks, pos + 1) == 0 {
            if tok_kind(toks, pos + 1) == tk_lparen() {
                return parse_call(toks, pos, buf);
            }
        }
        // Struct-literal: `Ident {` in non-condition expression position. Gated
        // by no_struct so condition-position `if IDENT {` keeps the `{` as the
        // block opener (byte-identical to the pre-existing parse).
        if no_struct == 0 {
            if at_eof(toks, pos + 1) == 0 {
                if tok_kind(toks, pos + 1) == tk_lbrace() {
                    return parse_struct_lit(toks, pos, buf);
                }
            }
        }
        let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
        return pr_new(pos + 1, n);
    }

    let fallback: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, fallback)
}

// Parse `Name { f0: e0, f1: e1, ... }` (optional trailing comma) into an
// ast_struct_lit. `pos` is the struct-name ident; `pos+1` is the `{`. Field
// values are full expressions (struct-lit ALLOWED inside — each value resets
// the no_struct context via parse_expr). Fields are collected in SOURCE ORDER
// as 3×i64 (name_lo, name_hi, value_node) so a later desugar can sort them to
// declared field order. PARSE-ONLY: the resulting node is rejected by
// flatten_ast, so no bytes are emitted yet.
pub fn parse_struct_lit(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let name_lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let open: i64 = pos + 1;
    let fields: Vec = vec_new();

    if tok_kind(toks, open + 1) == tk_rbrace() {
        let close_hi: i64 = tok_hi(toks, open + 1);
        let node: i64 = ast_new_struct_lit(name_lo, close_hi, name_lo, name_hi, vec_addr(fields), 0);
        return pr_new(open + 2, node);
    }

    let res: ParseResult = parse_struct_fields_rest(toks, open + 1, buf, fields);
    let after_fields: i64 = pr_pos(res);
    let fields_node: i64 = pr_node(res);
    let fields_addr: i64 = ast_child0(fields_node);
    let triples: i64 = ast_aux(fields_node);

    let close_hi: i64 = tok_hi(toks, after_fields);
    let after_close: i64 = if tok_kind(toks, after_fields) == tk_rbrace() {
        after_fields + 1
    } else {
        after_fields
    };
    let node: i64 = ast_new_struct_lit(name_lo, close_hi, name_lo, name_hi, fields_addr, triples / 3);
    pr_new(after_close, node)
}

// Collect `name: expr` field-inits (comma-separated, optional trailing comma)
// into `acc` as 3×i64 triples (name_lo, name_hi, value_node). Stops at `}` or a
// trailing comma followed by `}`. Returns a sentinel block node carrying the
// accumulated vec (child0=addr, aux=triple count), matching parse_args_rest.
pub fn parse_struct_fields_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if tok_kind(toks, pos) == tk_rbrace() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let fname_lo: i64 = tok_lo(toks, pos);
    let fname_hi: i64 = tok_hi(toks, pos);
    // pos = field-name ident, pos+1 = `:`, pos+2 = value expression.
    let val: ParseResult = parse_expr(toks, pos + 2, buf);
    let after_val: i64 = pr_pos(val);
    let a1: Vec = vec_push(acc, fname_lo);
    let a2: Vec = vec_push(a1, fname_hi);
    let a3: Vec = vec_push(a2, pr_node(val));
    if tok_kind(toks, after_val) == tk_comma() {
        return parse_struct_fields_rest(toks, after_val + 1, buf, a3);
    }
    let s: i64 = ast_new_block(0, 0, vec_addr(a3), vec_len(a3));
    pr_new(after_val, s)
}

// ===== Call parser =====

pub fn parse_call(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let callee: i64 = ast_new_leaf(ast_ident(), lo, name_hi);

    let empty_args: Vec = vec_new();
    let after_open: i64 = pos + 2;

    if tok_kind(toks, after_open) == tk_rparen() {
        let close_hi: i64 = tok_hi(toks, after_open);
        let call_node: i64 = ast_new_call(lo, close_hi, callee, vec_addr(empty_args), 0);
        return pr_new(after_open + 1, call_node);
    }

    let args_res: ParseResult = parse_args_rest(toks, after_open, buf, empty_args);
    let after_args: i64 = pr_pos(args_res);
    let args_node: i64 = pr_node(args_res);
    let args_addr: i64 = ast_child0(args_node);
    let args_len: i64 = ast_aux(args_node);

    let close_hi: i64 = tok_hi(toks, after_args);
    let after_close: i64 = if tok_kind(toks, after_args) == tk_rparen() {
        after_args + 1
    } else {
        after_args
    };

    let call_node: i64 = ast_new_call(lo, close_hi, callee, args_addr, args_len);
    pr_new(after_close, call_node)
}

pub fn parse_args_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    let one: ParseResult = parse_expr(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    let after_one: i64 = pr_pos(one);
    if tok_kind(toks, after_one) == tk_comma() {
        return parse_args_rest(toks, after_one + 1, buf, new_acc);
    }
    let sentinel: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_one, sentinel)
}

// ===== Pratt expression parser =====

pub fn parse_expr(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_expr_ns(toks, pos, buf, 0)
}

// no_struct-threaded expression entry. `parse_expr` (struct-lit ALLOWED) is the
// 3-arg wrapper; condition parsers (parse_if + the while/for/match heads) call
// this with no_struct=1 so an `Ident {` head is NOT mis-read as a struct-lit.
pub fn parse_expr_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let prim: ParseResult = parse_postfix_ns(toks, pos, buf, no_struct);
    parse_pratt_ns(toks, pr_pos(prim), buf, pr_node(prim), 1, no_struct)
}

// Postfix wrapper around parse_primary: after a primary is parsed, greedily
// consume trailing `.field` accesses so `a.b.c` chains left-associatively into
// nested ast_field nodes.  Field access binds tighter than any infix operator
// (it is applied before parse_pratt), matching the Rust front-end where
// FieldAccess is built in primary position.  Each `.field` requires the dot to
// be followed by an identifier; a bare trailing dot is left for the primary
// fallback (it simply stops the loop).
pub fn parse_postfix(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    parse_postfix_ns(toks, pos, buf, 0)
}

pub fn parse_postfix_ns(toks: Vec, pos: i64, buf: i64, no_struct: i64) -> ParseResult {
    let prim: ParseResult = parse_primary_ns(toks, pos, buf, no_struct);
    parse_postfix_rest(toks, pr_pos(prim), buf, pr_node(prim))
}

pub fn parse_postfix_rest(toks: Vec, pos: i64, buf: i64, recv: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, recv);
    }
    // `EXPR as i64` cast. `as` lexes as a bare ident; the cast binds tighter than
    // any infix operator (consumed here in postfix position, BEFORE parse_pratt),
    // matching the Rust front-end where `x as i64 + 1` parses `(x as i64) + 1`. A
    // widening-to-i64 cast is a value passthrough for every integer source width, so
    // the operand node is kept UNCHANGED (its span still resolves the param/local
    // name) and the trailing binop operand is lowered instead of becoming dead code
    // after the cast. A NARROWING target (i8/i16/i32) wraps recv in an ast_cast node
    // carrying the target bit width; the native emitter (nb_expr's ast_cast arm)
    // truncates via a reg-to-reg movsx (the same two's-complement wrap the
    // __mind_wrap_iN intrinsics use), so `(y as i8)` of 300 -> 44 and composes as a
    // binop operand. Continue postfix from the wrapped node so a trailing `.field` /
    // chained cast still binds. `as` is reserved, so a 2-byte "as" ident here is never
    // a variable — no postfix shape is shadowed.
    if tok_kind(toks, pos) == tk_ident() {
        if is_ident_as(buf, tok_lo(toks, pos), tok_hi(toks, pos)) == 1 {
            if tok_kind(toks, pos + 1) == tk_ident() {
                let cty_lo: i64 = tok_lo(toks, pos + 1);
                let cty_hi: i64 = tok_hi(toks, pos + 1);
                if is_ident_i64(buf, cty_lo, cty_hi) == 1 {
                    return parse_postfix_rest(toks, pos + 2, buf, recv);
                }
                let cw: i64 = narrow_cast_width(buf, cty_lo, cty_hi);
                if cw > 0 {
                    let cnode: i64 = ast_new_cast(ast_span_lo(recv), cty_hi, recv, cw);
                    return parse_postfix_rest(toks, pos + 2, buf, cnode);
                }
            }
        }
    }
    if tok_kind(toks, pos) != tk_dot() {
        return pr_new(pos, recv);
    }
    if tok_kind(toks, pos + 1) != tk_ident() {
        return pr_new(pos, recv);
    }
    let field_lo: i64 = tok_lo(toks, pos + 1);
    let field_hi: i64 = tok_hi(toks, pos + 1);
    let recv_lo: i64 = ast_span_lo(recv);
    let fa: i64 = ast_new_field(recv_lo, field_hi, recv, field_lo, field_hi);
    parse_postfix_rest(toks, pos + 2, buf, fa)
}

// `A && B` short-circuit lowering: desugar (at PARSE time) to the value-if
// `if A { B } else { 0 }` — B is evaluated ONLY when A is true, and the whole
// expression is 0 (false) when A is false. Both branches are one-statement blocks
// (tail-expression form), so the existing value-if lowering (nb_if_value / the
// mic@3 OP_IF path / MLIR) evaluates them with zero new emit code. 0 = false; the
// else-block's `mk_syn_intlit(0)` carries the constant directly. Mirrors the Rust
// front-end / the else-if & match parse-time desugars already in this file.
pub fn desugar_andand(span_lo: i64, span_hi: i64, lhs: i64, rhs: i64) -> i64 {
    let then_acc0: Vec = vec_new();
    let then_acc: Vec = vec_push(then_acc0, rhs);
    let then_blk: i64 = ast_new_block(span_lo, span_hi, vec_addr(then_acc), vec_len(then_acc));
    let else_acc0: Vec = vec_new();
    let else_acc: Vec = vec_push(else_acc0, mk_syn_intlit(0));
    let else_blk: i64 = ast_new_block(span_lo, span_hi, vec_addr(else_acc), vec_len(else_acc));
    ast_new_if(span_lo, span_hi, lhs, then_blk, else_blk)
}

// `A || B` short-circuit lowering: desugar to `if A { 1 } else { B }` — B is
// evaluated ONLY when A is false, and the whole expression is 1 (true) when A is
// true. Dual of desugar_andand; the then-block's `mk_syn_intlit(1)` carries the 1.
pub fn desugar_oror(span_lo: i64, span_hi: i64, lhs: i64, rhs: i64) -> i64 {
    let then_acc0: Vec = vec_new();
    let then_acc: Vec = vec_push(then_acc0, mk_syn_intlit(1));
    let then_blk: i64 = ast_new_block(span_lo, span_hi, vec_addr(then_acc), vec_len(then_acc));
    let else_acc0: Vec = vec_new();
    let else_acc: Vec = vec_push(else_acc0, rhs);
    let else_blk: i64 = ast_new_block(span_lo, span_hi, vec_addr(else_acc), vec_len(else_acc));
    ast_new_if(span_lo, span_hi, lhs, then_blk, else_blk)
}

pub fn parse_pratt(toks: Vec, pos: i64, buf: i64, lhs: i64, min_prec: i64) -> ParseResult {
    parse_pratt_ns(toks, pos, buf, lhs, min_prec, 0)
}

// no_struct propagates to every RHS operand: in `i < n` condition position the
// `n` is still condition position, so `n { ... }` is NOT a struct-lit either.
pub fn parse_pratt_ns(toks: Vec, pos: i64, buf: i64, lhs: i64, min_prec: i64, no_struct: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, lhs);
    }
    let k: i64 = tok_kind(toks, pos);
    let prec: i64 = infix_prec(k);
    if prec == 0 {
        return pr_new(pos, lhs);
    }
    if prec < min_prec {
        return pr_new(pos, lhs);
    }

    let rhs_prim: ParseResult = parse_postfix_ns(toks, pos + 1, buf, no_struct);
    let rhs_full: ParseResult = parse_pratt_ns(toks, pr_pos(rhs_prim), buf, pr_node(rhs_prim), prec + 1, no_struct);

    let lhs_lo: i64 = ast_span_lo(lhs);
    let rhs_hi: i64 = ast_span_hi(pr_node(rhs_full));

    // Logical `&&` / `||` are NOT binops: desugar to a short-circuit value-if here,
    // then continue the Pratt loop with the if-node as the new lhs. `prec + 1` for the
    // RHS gives LEFT associativity (`a && b && c` == `(a && b) && c`), and the
    // precedence table makes `&&` bind tighter than `||` and both looser than
    // comparison (`a > 0 && b > 0` == `(a>0) && (b>0)`).
    if k == tk_andand() {
        let comb_a: i64 = desugar_andand(lhs_lo, rhs_hi, lhs, pr_node(rhs_full));
        return parse_pratt_ns(toks, pr_pos(rhs_full), buf, comb_a, min_prec, no_struct);
    }
    if k == tk_oror() {
        let comb_o: i64 = desugar_oror(lhs_lo, rhs_hi, lhs, pr_node(rhs_full));
        return parse_pratt_ns(toks, pr_pos(rhs_full), buf, comb_o, min_prec, no_struct);
    }

    let op_tag: i64 = tk_to_op(k);
    let combined: i64 = ast_new_binop(lhs_lo, rhs_hi, lhs, pr_node(rhs_full), op_tag);

    parse_pratt_ns(toks, pr_pos(rhs_full), buf, combined, min_prec, no_struct)
}

// ===== Statements =====

pub fn parse_stmt(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_let() {
        return parse_let(toks, pos, buf);
    }
    if k == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_ident_return(buf, lo, hi) == 1 {
            return parse_return(toks, pos, buf);
        }
        // `while`, `break`, `continue` lex as bare idents — detected by spelling.
        if is_ident_while(buf, lo, hi) == 1 {
            return parse_while(toks, pos, buf);
        }
        if is_ident_break(buf, lo, hi) == 1 {
            return parse_break_continue(toks, pos, buf, ast_break());
        }
        if is_ident_continue(buf, lo, hi) == 1 {
            return parse_break_continue(toks, pos, buf, ast_continue());
        }
        // `NAME = VALUE` assignment statement: an ident immediately followed by a
        // single `=` (NOT `==`, which is a comparison expr). Mirrors the Rust
        // parser's bare-ident `x = expr` -> Node::Assign disambiguation.
        if tok_kind(toks, pos + 1) == tk_eq() {
            return parse_assign(toks, pos, buf);
        }
    }
    let e: ParseResult = parse_expr(toks, pos, buf);
    let after_e: i64 = pr_pos(e);
    if tok_kind(toks, after_e) == tk_semi() {
        return pr_new(after_e + 1, pr_node(e));
    }
    e
}

// `while COND { BODY }` — COND is a full expression parsed with no_struct=1 so a
// trailing `{` opens the body block (byte-identical to parse_if's cond handling).
// Mirrors the Rust front-end's Node::While { cond, body }.
pub fn parse_while(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let cond: ParseResult = parse_expr_ns(toks, pos + 1, buf, 1);
    let after_cond: i64 = pr_pos(cond);
    let body_res: ParseResult = parse_block(toks, after_cond, buf);
    let after_body: i64 = pr_pos(body_res);
    let body_blk: i64 = pr_node(body_res);
    let body_hi: i64 = ast_span_hi(body_blk);
    let w: i64 = ast_new_while(kw_lo, body_hi, pr_node(cond), body_blk);
    pr_new(after_body, w)
}

// `NAME = VALUE ;` assignment statement. `pos` is the name ident; `pos+1` is the
// `=`; the value expression follows. Mirrors Node::Assign { name, value }.
pub fn parse_assign(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let name_lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);
    let value: ParseResult = parse_expr(toks, pos + 2, buf);
    let after_v: i64 = pr_pos(value);
    let after_semi: i64 = if tok_kind(toks, after_v) == tk_semi() {
        after_v + 1
    } else {
        after_v
    };
    let v_hi: i64 = ast_span_hi(pr_node(value));
    let a: i64 = ast_new_assign(name_lo, v_hi, name, pr_node(value));
    pr_new(after_semi, a)
}

// `break ;` / `continue ;` — bare leaf statements (`kind` selects which).
pub fn parse_break_continue(toks: Vec, pos: i64, buf: i64, kind: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);
    let after_semi: i64 = if tok_kind(toks, pos + 1) == tk_semi() {
        pos + 2
    } else {
        pos + 1
    };
    let n: i64 = ast_new_leaf(kind, lo, hi);
    pr_new(after_semi, n)
}

pub fn parse_let(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    // Optional `mut` marker: `let mut X : T = INIT` shifts the name/type/init
    // token offsets by one. `mut` lexes as a bare ident (not a keyword token).
    let mp: i64 = if is_ident_mut(buf, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1)) == 1 {
        pos + 1
    } else {
        pos
    };
    let name_lo: i64 = tok_lo(toks, mp + 1);
    let name_hi: i64 = tok_hi(toks, mp + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);
    let ty_lo: i64 = tok_lo(toks, mp + 3);
    let ty_hi: i64 = tok_hi(toks, mp + 3);
    let ty: i64 = ast_new_leaf(ast_ident(), ty_lo, ty_hi);
    let init: ParseResult = parse_expr(toks, mp + 5, buf);
    let after_init: i64 = pr_pos(init);
    let after_semi: i64 = if tok_kind(toks, after_init) == tk_semi() {
        after_init + 1
    } else {
        after_init
    };
    let init_hi: i64 = ast_span_hi(pr_node(init));
    let let_node: i64 = ast_new_let(kw_lo, init_hi, name, ty, pr_node(init));
    pr_new(after_semi, let_node)
}

pub fn parse_return(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let value: ParseResult = parse_expr(toks, pos + 1, buf);
    let after_v: i64 = pr_pos(value);
    let after_semi: i64 = if tok_kind(toks, after_v) == tk_semi() {
        after_v + 1
    } else {
        after_v
    };
    let v_hi: i64 = ast_span_hi(pr_node(value));
    let r: i64 = ast_new_return(kw_lo, v_hi, pr_node(value));
    pr_new(after_semi, r)
}

// ===== Blocks =====

pub fn parse_block(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let open_lo: i64 = tok_lo(toks, pos);
    let acc: Vec = vec_new();
    let body: ParseResult = parse_block_stmts(toks, pos + 1, buf, acc);
    let after_body: i64 = pr_pos(body);
    let stmts_node: i64 = pr_node(body);
    let stmts_addr: i64 = ast_child0(stmts_node);
    let stmts_len: i64 = ast_aux(stmts_node);

    let close_hi: i64 = tok_hi(toks, after_body);
    let after_close: i64 = if tok_kind(toks, after_body) == tk_rbrace() {
        after_body + 1
    } else {
        after_body
    };
    let blk: i64 = ast_new_block(open_lo, close_hi, stmts_addr, stmts_len);
    pr_new(after_close, blk)
}

pub fn parse_block_stmts(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_stmt(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_block_stmts(toks, pr_pos(one), buf, new_acc)
}

// ===== If-expressions =====
//
// `if COND { THEN } else { ELSE }` — COND is a full expression (parse_expr
// stops at the `{` because `{` has no infix precedence), THEN/ELSE reuse the
// function-body block parser.  The else clause is optional; when absent,
// child2 is left 0.  Mirrors the Rust front-end's ast::Node::If.
pub fn parse_if(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    // Condition position: no_struct=1 so `if IDENT {` keeps `{` as the block
    // opener (byte-identical to the pre-struct-lit parse).
    let cond: ParseResult = parse_expr_ns(toks, pos + 1, buf, 1);
    let after_cond: i64 = pr_pos(cond);

    let then_res: ParseResult = parse_block(toks, after_cond, buf);
    let after_then: i64 = pr_pos(then_res);
    let then_blk: i64 = pr_node(then_res);
    let then_hi: i64 = ast_span_hi(then_blk);

    if tok_kind(toks, after_then) == tk_kw_else() {
        return parse_if_else_tail(toks, after_then, buf, kw_lo, pr_node(cond), then_blk);
    }

    let if_node: i64 = ast_new_if(kw_lo, then_hi, pr_node(cond), then_blk, 0);
    pr_new(after_then, if_node)
}

// Parse an `else` tail: either `else { block }` or the `else if …` sugar.  Kept
// as its own function (called from parse_if) so that BOTH parse_if and this
// helper stay a SINGLE-LEVEL `if <cond> { …; return } …` shape — the same shape
// the pre-existing parse_if had, which the self-host mic@3 emitter reproduces
// byte-identically.  Inlining the `else if` branch as a nested if-with-return
// inside parse_if's else-branch instead created a DOUBLE-nested if-return shape
// the self-host emitter over-emits by 72 B (mic@3 FLIP drift); this flattening
// avoids that.
//
// `else if …` desugars to the explicit `else { if … }` form: parse the trailing
// `if` recursively (handles arbitrary-depth chains) and wrap the single if-node
// in a one-statement block — byte-identical in AST shape to what parse_block
// produces for an explicit `else { if … }` (child0 = a 1-element stmts vec
// holding the if-node, aux = 1), so the shared if-emit path lowers both forms to
// the same bytes with ZERO new emit code.  emit reads child0/child1/child2 and
// stmts_addr/aux only — never a block's or if-node's span — so the nested-if span
// assigned to the wrapper block does not perturb byte-identity.
pub fn parse_if_else_tail(toks: Vec, after_then: i64, buf: i64, kw_lo: i64, cond_node: i64, then_blk: i64) -> ParseResult {
    if tok_kind(toks, after_then + 1) == tk_kw_if() {
        let nested: ParseResult = parse_if(toks, after_then + 1, buf);
        let after_else: i64 = pr_pos(nested);
        let nested_if: i64 = pr_node(nested);
        let else_hi: i64 = ast_span_hi(nested_if);
        let else_lo: i64 = ast_span_lo(nested_if);
        let one_acc0: Vec = vec_new();
        let one_acc: Vec = vec_push(one_acc0, nested_if);
        let else_blk: i64 = ast_new_block(else_lo, else_hi, vec_addr(one_acc), vec_len(one_acc));
        let if_node: i64 = ast_new_if(kw_lo, else_hi, cond_node, then_blk, else_blk);
        return pr_new(after_else, if_node);
    }
    let else_res: ParseResult = parse_block(toks, after_then + 1, buf);
    let after_else: i64 = pr_pos(else_res);
    let else_blk: i64 = pr_node(else_res);
    let else_hi: i64 = ast_span_hi(else_blk);
    let if_node: i64 = ast_new_if(kw_lo, else_hi, cond_node, then_blk, else_blk);
    pr_new(after_else, if_node)
}

// ===== Match-expressions (parse-time desugar to if) =====
//
// `match SCRUT { PAT => VAL0, _ => VAL1 }` desugars at PARSE TIME to the
// equivalent `if SCRUT == PAT { VAL0 } else { VAL1 }`.  Both forms lower to a
// byte-IDENTICAL mic@3 stream (an OP_IF 0x1C chain) — proven against
// `mindc --emit-mic3` — so building the ast_if here reuses the existing
// if-emitter (emit_mic3_module_fndef_if and the recursive if path) with ZERO
// new emit code.  `match` is NOT a keyword token: it lexes as a bare tk_ident
// spelling "match" (detected via is_ident_match), the same disambiguation the
// struct-literal path uses for is_struct_kw.
//
// SCOPE: N int-literal pattern arms plus a trailing wildcard `_` arm.  The
// desugar builds the else-if chain
//   if SCRUT == P0 { V0 } else if SCRUT == P1 { V1 } … else { Vwild }
// reusing the PROVEN-correct parse_if / parse_if_else_tail AST shape: each
// non-wildcard arm becomes an ast_if whose else child is the recursive rest,
// wrapped in a one-statement block when that rest is itself an if (exactly the
// `else if` desugar in parse_if_else_tail), and the wildcard arm becomes the
// terminal else block.  For the 2-arm shape the recursion bottoms out to the
// same if(cond, {V0}, {Vwild}) tree the old hand-written path produced, so it
// stays byte-identical; 3+ arms extend the same chain.  BOTH arm forms are
// handled by parse_arm_value: a `{ … }` block arm (statement form, with
// return/assign) is taken verbatim (== parse_if's then/else block); a bare
// value expression (`1 => 10`) is wrapped in a one-statement block (== the old
// expr-arm wrapping).  Arm separators may be `,` or `;` or absent (block arms
// self-terminate on `}`).  The scrutinee is RE-PARSED for each arm's condition
// (rather than sharing one node) so each `SCRUT == Pi` is a fresh subtree,
// byte-identical to what the hand-written else-if chain would parse.
//
// Token layout (the fat arrow `=>` lexes as the two tokens tk_eq tk_gt):
//   match SCRUT { P0 => V0 , P1 => V1 , … , _ => Vwild }
//   ^pos         ^lbrace
// SCRUT is parsed with no_struct=1 so `match c {` keeps the `{` as the arm
// block (NOT a struct literal), byte-identical to the if-condition parse.
pub fn parse_match(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    // Scrutinee: no_struct=1 so the `{` opens the arms, not a struct literal.
    // Parsed once here only to find the `{` position; each arm's condition
    // re-parses it from pos+1 for a fresh, distinct condition subtree.
    let scrut: ParseResult = parse_expr_ns(toks, pos + 1, buf, 1);
    let lbrace_pos: i64 = pr_pos(scrut);

    let chain: ParseResult = parse_match_chain(toks, lbrace_pos + 1, buf, pos + 1, kw_lo);
    let after_arms: i64 = pr_pos(chain);
    let after_close: i64 = if tok_kind(toks, after_arms) == tk_rbrace() {
        after_arms + 1
    } else {
        after_arms
    };
    pr_new(after_close, pr_node(chain))
}

// Parse ONE match arm value at `pos` (the token just after `=>`) into a BLOCK
// node.  A `{ … }` arm (statement form) is parsed with parse_block and taken
// verbatim; a bare value expression is parsed with parse_expr (struct-lit
// allowed) and wrapped in a one-statement block — byte-identical to the old
// expr-arm wrapping and to what parse_if's parse_block produces for `{ EXPR }`.
pub fn parse_arm_value(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    if tok_kind(toks, pos) == tk_lbrace() {
        return parse_block(toks, pos, buf);
    }
    let v: ParseResult = parse_expr(toks, pos, buf);
    let vn: i64 = pr_node(v);
    let acc: Vec = vec_new();
    let acc1: Vec = vec_push(acc, vn);
    let blk: i64 = ast_new_block(pos, ast_span_hi(vn), vec_addr(acc1), vec_len(acc1));
    pr_new(pr_pos(v), blk)
}

// Wrap a recursive-rest node as an else block: if it is an ast_if (more arms
// follow — the `else if` case) wrap it in a one-statement block, exactly like
// parse_if_else_tail; otherwise it is already the wildcard's terminal block and
// is used directly (the `else { block }` case).
pub fn mt_wrap_else(node: i64) -> i64 {
    if ast_kind(node) == ast_if() {
        let acc: Vec = vec_new();
        let acc1: Vec = vec_push(acc, node);
        return ast_new_block(ast_span_lo(node), ast_span_hi(node), vec_addr(acc1), vec_len(acc1));
    }
    node
}

// Recursively parse the arm list starting at pattern token `pat_pos`, returning
// the else-if chain node (an ast_if for a pattern arm, or the terminal block for
// the wildcard arm).  `scrut_start` is the token just after `match` (the
// scrutinee start), re-parsed per condition; `kw_lo` is the `match` span_lo.
pub fn parse_match_chain(toks: Vec, pat_pos: i64, buf: i64, scrut_start: i64, kw_lo: i64) -> ParseResult {
    let pat_lo: i64 = tok_lo(toks, pat_pos);
    let pat_hi: i64 = tok_hi(toks, pat_pos);
    let is_wild: i64 = if tok_kind(toks, pat_pos) == tk_ident() {
        is_ident_underscore(buf, pat_lo, pat_hi)
    } else {
        0
    };

    // `=>` is two tokens (tk_eq tk_gt); the arm value follows at pat_pos+3.
    let val_res: ParseResult = parse_arm_value(toks, pat_pos + 3, buf);
    let after_val: i64 = pr_pos(val_res);
    let val_blk: i64 = pr_node(val_res);

    // Optional `,` or `;` arm separator (block arms usually have none).
    let next_pos: i64 = if tok_kind(toks, after_val) == tk_comma() {
        after_val + 1
    } else {
        if tok_kind(toks, after_val) == tk_semi() {
            after_val + 1
        } else {
            after_val
        }
    };

    if is_wild == 1 {
        // Terminal else: the wildcard block itself.
        return pr_new(next_pos, val_blk);
    }

    // Pattern arm: cond = SCRUT == PAT, then = arm block, else = recursive rest.
    let scrut_i: ParseResult = parse_expr_ns(toks, scrut_start, buf, 1);
    let pat_lit: i64 = ast_new_leaf(ast_int_lit(), pat_lo, pat_hi);
    let cond: i64 = ast_new_binop(kw_lo, pat_hi, pr_node(scrut_i), pat_lit, op_eq());

    let rest: ParseResult = parse_match_chain(toks, next_pos, buf, scrut_start, kw_lo);
    let else_blk: i64 = mt_wrap_else(pr_node(rest));

    let if_node: i64 = ast_new_if(kw_lo, ast_span_hi(pr_node(rest)), cond, val_blk, else_blk);
    pr_new(pr_pos(rest), if_node)
}

// ===== Function definitions =====

pub fn parse_fn_def(toks: Vec, pos: i64, buf: i64, is_pub: i64) -> ParseResult {
    let fn_lo: i64 = tok_lo(toks, pos);
    let name_lo: i64 = tok_lo(toks, pos + 1);
    let name_hi: i64 = tok_hi(toks, pos + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);

    let params_acc: Vec = vec_new();
    let params_res: ParseResult = parse_params_rest(toks, pos + 3, buf, params_acc);
    let after_params: i64 = pr_pos(params_res);
    let params_node: i64 = pr_node(params_res);
    let params_addr: i64 = ast_child0(params_node);
    let params_len: i64 = ast_aux(params_node);

    let after_rparen: i64 = if tok_kind(toks, after_params) == tk_rparen() {
        after_params + 1
    } else {
        after_params
    };
    let after_arrow: i64 = if tok_kind(toks, after_rparen) == tk_arrow() {
        after_rparen + 1
    } else {
        after_rparen
    };
    let after_ret: i64 = after_arrow + 1;

    let body_res: ParseResult = parse_block(toks, after_ret, buf);
    let body_hi: i64 = ast_span_hi(pr_node(body_res));

    let fn_node: i64 = ast_new_fn_def(fn_lo, body_hi, name, params_addr, pr_node(body_res), params_len, is_pub);
    pr_new(pr_pos(body_res), fn_node)
}

// Skip a generic argument list `<...>` while balancing nested brackets, so a
// generic param/return TYPE consumes the right number of tokens. `pos` points AT
// the token to consume next; `depth` is the count of still-open `<`. A closing
// `>>` of a doubly-nested generic (`Vec<Vec<i64>>`) lexes as ONE tk_shr, so it
// closes two levels; likewise a `<<` opens two (never appears in a type, handled
// for completeness). Commas inside the list are consumed like any other token.
// Returns the position of the first token AFTER the balanced list.
pub fn skip_generic_args(toks: Vec, pos: i64, depth: i64) -> i64 {
    if depth <= 0 {
        return pos;
    }
    let k: i64 = tok_kind(toks, pos);
    let nd: i64 = if k == tk_lt() {
        depth + 1
    } else {
        if k == tk_shl() {
            depth + 2
        } else {
            if k == tk_gt() {
                depth - 1
            } else {
                if k == tk_shr() {
                    depth - 2
                } else {
                    depth
                }
            }
        }
    };
    skip_generic_args(toks, pos + 1, nd)
}

pub fn parse_params_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if tok_kind(toks, pos) == tk_rparen() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let n_lo: i64 = tok_lo(toks, pos);
    let n_hi: i64 = tok_hi(toks, pos);
    let n_name: i64 = ast_new_leaf(ast_ident(), n_lo, n_hi);
    let t_lo: i64 = tok_lo(toks, pos + 2);
    let t_hi: i64 = tok_hi(toks, pos + 2);
    let n_ty: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let p: i64 = ast_new_param(n_lo, t_hi, n_name, n_ty);
    let new_acc: Vec = vec_push(acc, p);
    // A generic param type (`xs: array<i64>`, `m: map<i64, Value>`) spans more than
    // one token: the base type is at pos+2 and, when the next token is `<`, the
    // `<...>` list must be skipped with nested balancing so the token stream does
    // NOT desync (a desync mis-parses the fn body from inside the angle brackets and
    // crashes the downstream struct-lit desugar / field-prefold pass). Non-generic
    // types (every param in main.mind and std today) take the pos+3 path unchanged,
    // so the canary / seeded self-host stay byte-identical.
    let after_param: i64 = if tok_kind(toks, pos + 3) == tk_lt() {
        skip_generic_args(toks, pos + 4, 1)
    } else {
        pos + 3
    };
    if tok_kind(toks, after_param) == tk_comma() {
        return parse_params_rest(toks, after_param + 1, buf, new_acc);
    }
    let s: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_param, s)
}

// ===== Use statements =====

pub fn parse_use(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let use_lo: i64 = tok_lo(toks, pos);
    let h_lo: i64 = tok_lo(toks, pos + 1);
    let h_hi: i64 = tok_hi(toks, pos + 1);
    let head: i64 = ast_new_leaf(ast_ident(), h_lo, h_hi);
    let t_lo: i64 = tok_lo(toks, pos + 3);
    let t_hi: i64 = tok_hi(toks, pos + 3);
    let tail: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let after_semi: i64 = if tok_kind(toks, pos + 4) == tk_semi() {
        pos + 5
    } else {
        pos + 4
    };
    let node: i64 = ast_new_use(use_lo, t_hi, head, tail);
    pr_new(after_semi, node)
}

// ===== Top-level item / program =====

pub fn parse_item(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_use() {
        return parse_use(toks, pos, buf);
    }
    if k == tk_kw_pub() {
        // `pub struct T { .. }` is a struct def (skip `pub`, parse from `struct`);
        // anything else after `pub` is a pub fn. (main.mind's own structs are bare
        // `struct`, so this never perturbs the canary fixed point.)
        if tok_kind(toks, pos + 1) == tk_ident() {
            if is_struct_kw(buf, tok_lo(toks, pos + 1), tok_hi(toks, pos + 1)) == 1 {
                return parse_struct_def(toks, pos + 1, buf);
            }
        }
        return parse_fn_def(toks, pos + 1, buf, 1);
    }
    if k == tk_kw_fn() {
        return parse_fn_def(toks, pos, buf, 0);
    }
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);
    if k == tk_ident() {
        if is_struct_kw(buf, lo, hi) == 1 {
            return parse_struct_def(toks, pos, buf);
        }
        if is_enum_kw(buf, lo, hi) == 1 {
            return parse_struct_def(toks, pos, buf);
        }
        if is_extern_kw(buf, lo, hi) == 1 {
            return parse_extern_block(toks, pos, buf);
        }
        if is_module_kw(buf, lo, hi) == 1 {
            // `module NAME { .. }` consumes the whole block to one stub, same
            // block-skipping shape as an extern block.
            return parse_extern_block(toks, pos, buf);
        }
        if is_const_kw(buf, lo, hi) == 1 {
            return parse_const_decl(toks, pos, buf);
        }
    }
    let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, n)
}

pub fn parse_items_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_item(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_items_rest(toks, pr_pos(one), buf, new_acc)
}

// True iff the whole token stream is a single bare top-level EXPRESSION (no
// items): it begins with an expression-start token (int literal, `(`, or unary
// `-`). A real program begins with an item keyword (use/import/fn/struct/const/
// enum/extern/module), so this never misfires — main.mind starts with `import`,
// keeping its self-host flip byte-identical.
pub fn is_bare_expr_program(toks: Vec) -> i64 {
    if at_eof(toks, 0) == 1 {
        return 0;
    }
    let k: i64 = tok_kind(toks, 0);
    if k == tk_int() {
        return 1;
    }
    if k == tk_lparen() {
        return 1;
    }
    if k == tk_minus() {
        return 1;
    }
    0
}

// ===== Public entry: parse =====

pub fn parse(toks: Vec, buf: i64) -> i64 {
    // A bare top-level expression (`1 + 2 * 3`) IS the whole program: parse it as
    // one expression so lower_program const-folds it (emit_bare_expr), matching
    // mindc-Rust. Otherwise parse a sequence of items as usual.
    if is_bare_expr_program(toks) == 1 {
        let e: ParseResult = parse_expr(toks, 0, buf);
        let one: Vec = vec_push(vec_new(), pr_node(e));
        return ast_new_program(0, 0, vec_addr(one), vec_len(one));
    }
    let acc: Vec = vec_new();
    let res: ParseResult = parse_items_rest(toks, 0, buf, acc);
    let s: i64 = pr_node(res);
    let items_addr: i64 = ast_child0(s);
    let items_len: i64 = ast_aux(s);
    ast_new_program(0, 0, items_addr, items_len)
}

// ===========================================================================
// SECTION 3 — TYPE CHECKER (Phase 6.3)
// examples/typecheck/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: typecheck(ast_root: i64, buf: i64) -> String
// ===========================================================================

// ===== Type tags =====

pub fn ty_unknown() -> i64 {
    0
}
pub fn ty_i64() -> i64 {
    1
}
pub fn ty_f64() -> i64 {
    2
}
pub fn ty_bool() -> i64 {
    3
}
pub fn ty_vec() -> i64 {
    4
}
pub fn ty_string() -> i64 {
    5
}
pub fn ty_unit() -> i64 {
    6
}
// Narrow signed-int scalar (i32). Ported to mirror the Rust type-checker's
// ScalarI32 (src/type_checker/mod.rs int_scalar_bits: i32=32, i64=64). Distinct
// tag so the E2004 implicit-narrowing rule (i64 -> i32) can be modelled in pure
// MIND; main.mind's own source uses no i32 annotations, so this is additive.
pub fn ty_i32() -> i64 {
    7
}

// ===== Fn-def aux unpacking =====

pub fn fn_def_params_len(node: i64) -> i64 {
    ast_aux(node) / 2
}
pub fn fn_def_is_pub(node: i64) -> i64 {
    ast_aux(node) - (ast_aux(node) / 2) * 2
}

// ===== Byte-range equality =====

pub fn bytes_eq(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64, chi: i64) -> i64 {
    if hi - lo == chi - clo {
        return bytes_eq_rest(buf, lo, hi, cmp_buf, clo);
    }
    0
}

pub fn bytes_eq_rest(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64) -> i64 {
    if lo >= hi {
        return 1;
    }
    if load_byte(buf, lo) == load_byte(cmp_buf, clo) {
        return bytes_eq_rest(buf, lo + 1, hi, cmp_buf, clo + 1);
    }
    0
}

// ===== Type-name byte tables =====

pub fn make_byte_buf_3(b0: i64, b1: i64, b2: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    h
}

pub fn make_byte_buf_4(b0: i64, b1: i64, b2: i64, b3: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    h
}

pub fn make_byte_buf_6(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    __mind_store_i64(h + 4, b4);
    __mind_store_i64(h + 5, b5);
    h
}

pub fn make_byte_buf_7(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64, b6: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    __mind_store_i64(h + 4, b4);
    __mind_store_i64(h + 5, b5);
    __mind_store_i64(h + 6, b6);
    h
}

pub fn make_byte_buf_8(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64, b6: i64, b7: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    __mind_store_i64(h + 4, b4);
    __mind_store_i64(h + 5, b5);
    __mind_store_i64(h + 6, b6);
    __mind_store_i64(h + 7, b7);
    h
}

pub fn name_buf_i64() -> i64 {
    make_byte_buf_3(105, 54, 52)
}
pub fn name_buf_i32() -> i64 {
    make_byte_buf_3(105, 51, 50)
}
pub fn name_buf_f64() -> i64 {
    make_byte_buf_3(102, 54, 52)
}
pub fn name_buf_bool() -> i64 {
    make_byte_buf_4(98, 111, 111, 108)
}
pub fn name_buf_vec() -> i64 {
    make_byte_buf_3(86, 101, 99)
}
pub fn name_buf_string() -> i64 {
    make_byte_buf_6(83, 116, 114, 105, 110, 103)
}

pub fn resolve_type_ident(buf: i64, lo: i64, hi: i64) -> i64 {
    let i64_buf: i64 = name_buf_i64();
    if bytes_eq(buf, lo, hi, i64_buf, 0, 3) == 1 {
        return ty_i64();
    }
    let i32_buf: i64 = name_buf_i32();
    if bytes_eq(buf, lo, hi, i32_buf, 0, 3) == 1 {
        return ty_i32();
    }
    let f64_buf: i64 = name_buf_f64();
    if bytes_eq(buf, lo, hi, f64_buf, 0, 3) == 1 {
        return ty_f64();
    }
    let bool_buf: i64 = name_buf_bool();
    if bytes_eq(buf, lo, hi, bool_buf, 0, 4) == 1 {
        return ty_bool();
    }
    let vec_buf: i64 = name_buf_vec();
    if bytes_eq(buf, lo, hi, vec_buf, 0, 3) == 1 {
        return ty_vec();
    }
    let str_buf: i64 = name_buf_string();
    if bytes_eq(buf, lo, hi, str_buf, 0, 6) == 1 {
        return ty_string();
    }
    ty_unknown()
}

// ===== Narrow-int type rules (E2004 implicit-narrowing) =====
//
// Pure-MIND port of src/type_checker/mod.rs {int_scalar_bits, is_implicit_narrowing}.
// The Rust reference models exactly two int-scalar widths (i32=32, i64=64;
// bool/float are NOT int scalars) and flags an ASSIGNMENT `let x: TO = <FROM>`
// as an implicit integer narrowing (E2004) iff both TO and FROM are int scalars
// and TO is strictly narrower than FROM. Widening (i32 -> i64) and same-width
// are value-preserving and NOT flagged. No literal-fits-width / mixed-width
// result-type rules are ported: those do not exist in the Rust oracle (the
// parser routes u8/u16/u64/i8/i16 to opaque Named strings with no width), so
// porting them would invent semantics rather than replicate the oracle.

// Bit-width of an int-scalar type tag; 0 means "not an int scalar" (mirrors the
// Rust `Option<u32>` None arm: bool/f64/vec/string/unit -> 0).
pub fn tc_int_scalar_bits(ty: i64) -> i64 {
    if ty == ty_i32() {
        return 32;
    }
    if ty == ty_i64() {
        return 64;
    }
    0
}

// E2004: true (1) when assigning a value of type `from_ty` into a slot declared
// `to_ty` is an implicit integer narrowing (both int scalars, dest strictly
// narrower than source). Byte-exact twin of Rust `is_implicit_narrowing`.
pub fn tc_is_implicit_narrowing(to_ty: i64, from_ty: i64) -> i64 {
    let tb: i64 = tc_int_scalar_bits(to_ty);
    if tb == 0 {
        return 0;
    }
    let fb: i64 = tc_int_scalar_bits(from_ty);
    if fb == 0 {
        return 0;
    }
    if tb < fb {
        return 1;
    }
    0
}

// Isolated selftest entry (ADDITIVE — never reached through mindc_compile, so
// the mic@1 canary / self-host loop are untouched by its logic). Resolves two
// type NAMES chosen by selector through the real resolve_type_ident path, then
// applies the narrowing rule — exercising name -> tag -> width -> E2004 verdict
// end to end. Selectors: 0=i32, 1=i64, 2=f64, 3=bool. Returns 1 if the pair
// (let dst: TO = <FROM>) is an implicit narrowing, else 0.
pub fn tc_name_by_sel(sel: i64) -> i64 {
    if sel == 0 {
        return name_buf_i32();
    }
    if sel == 1 {
        return name_buf_i64();
    }
    if sel == 2 {
        return name_buf_f64();
    }
    name_buf_bool()
}
pub fn tc_len_by_sel(sel: i64) -> i64 {
    if sel == 3 {
        return 4;
    }
    3
}
pub fn selftest_tc_narrowing(to_sel: i64, from_sel: i64) -> i64 {
    let to_buf: i64 = tc_name_by_sel(to_sel);
    let to_len: i64 = tc_len_by_sel(to_sel);
    let from_buf: i64 = tc_name_by_sel(from_sel);
    let from_len: i64 = tc_len_by_sel(from_sel);
    let to_ty: i64 = resolve_type_ident(to_buf, 0, to_len);
    let from_ty: i64 = resolve_type_ident(from_buf, 0, from_len);
    tc_is_implicit_narrowing(to_ty, from_ty)
}

// E2015 (RFC 0011 — no implicit int<->float conversion): scalar CLASS of a
// type tag. 1 = Int (i32/i64/bool), 2 = Float (f64), 0 = None. Byte-exact twin
// of Rust `scalar_class_of_ann` (bool is Int-class here, unlike E2004 where
// bool has width 0).
pub fn tc_scalar_class(ty: i64) -> i64 {
    if ty == ty_i32() {
        return 1;
    }
    if ty == ty_i64() {
        return 1;
    }
    if ty == ty_bool() {
        return 1;
    }
    if ty == ty_f64() {
        return 2;
    }
    0
}

// E2015: true (1) when `let dst: to_ty = <value: from_ty>` crosses the int/float
// class boundary (both classes known and different). Twin of the Rust
// `ann_class != val_class` guard in the Node::Let class-check arm.
pub fn tc_is_class_mismatch(to_ty: i64, from_ty: i64) -> i64 {
    let tc: i64 = tc_scalar_class(to_ty);
    if tc == 0 {
        return 0;
    }
    let fc: i64 = tc_scalar_class(from_ty);
    if fc == 0 {
        return 0;
    }
    if tc != fc {
        return 1;
    }
    0
}

// Isolated selftest entry (ADDITIVE — never reached through mindc_compile).
// Selectors: 0=i32, 1=i64, 2=f64, 3=bool. Returns 1 if the pair
// (let dst: TO = <FROM>) is an int<->float class mismatch, else 0.
pub fn selftest_tc_class_mismatch(to_sel: i64, from_sel: i64) -> i64 {
    let to_buf: i64 = tc_name_by_sel(to_sel);
    let to_len: i64 = tc_len_by_sel(to_sel);
    let from_buf: i64 = tc_name_by_sel(from_sel);
    let from_len: i64 = tc_len_by_sel(from_sel);
    let to_ty: i64 = resolve_type_ident(to_buf, 0, to_len);
    let from_ty: i64 = resolve_type_ident(from_buf, 0, from_len);
    tc_is_class_mismatch(to_ty, from_ty)
}

// ===== Return/cond/binop/cast class rules (E2010/E2011/E2013/E2016) =====
//
// Pure-MIND ports of the remaining scalar-class diagnostics from
// src/type_checker/mod.rs. All four are ADDITIVE: defined + exported via the
// isolated selftest_* wrappers below, never reached through mindc_compile, so
// the mic@1 canary / self-host loop stay byte-identical.

// True (1) for an integer-family scalar tag (i32/i64/bool) — twin of Rust
// `is_int_scalar` (ScalarI32 | ScalarI64 | ScalarBool).
pub fn tc_is_int_scalar(ty: i64) -> i64 {
    if ty == ty_i32() {
        return 1;
    }
    if ty == ty_i64() {
        return 1;
    }
    if ty == ty_bool() {
        return 1;
    }
    0
}

// True (1) for a float-family scalar tag — twin of Rust `is_float_scalar`
// (ScalarF32 | ScalarF64; only f64 exists in this tag universe).
pub fn tc_is_float_scalar(ty: i64) -> i64 {
    if ty == ty_f64() {
        return 1;
    }
    0
}

// E2010: return-type mismatch. Two directions, exactly as the Rust oracle:
//   1. int-declared return + float value (the infer-based pass:
//      `is_int_scalar(rt)` + `is_float_scalar(vt)` in check_return_and_cond_node);
//   2. float-declared return + Int-class value (the confidence-gated NEW
//      direction: `ret_class == Float && class(v) == Int` in the Return arm of
//      check_scalar_class_stmt).
// Returns 1 when `return <val_ty>` inside a fn declared `-> ret_ty` mismatches.
pub fn tc_is_return_mismatch(ret_ty: i64, val_ty: i64) -> i64 {
    if tc_is_int_scalar(ret_ty) == 1 {
        return tc_is_float_scalar(val_ty);
    }
    if tc_is_float_scalar(ret_ty) == 0 {
        return 0;
    }
    if tc_scalar_class(val_ty) == 1 {
        return 1;
    }
    0
}

// E2011: float used directly as an if/while condition. Twin of Rust
// check_cond_type: a boolean-intent condition (comparison / logical / `!`) is
// exempt (`cond_is_boolean_intent` early return); otherwise the diagnostic
// fires iff the condition's type is a float scalar. `bool_intent` is 1 when
// the condition node is a comparison/logical/negation, else 0.
pub fn tc_is_cond_mismatch(cond_ty: i64, bool_intent: i64) -> i64 {
    if bool_intent == 1 {
        return 0;
    }
    tc_is_float_scalar(cond_ty)
}

// E2013: mixed-class binary op (`1 + 2.0`). Twin of the Rust Node::Binary arm
// in walk_expr_class_checks: fires iff the operand classes are exactly
// (Int, Float) or (Float, Int) — both confidently known; any None class keeps
// the pair silent.
pub fn tc_is_mixed_binop(lhs_ty: i64, rhs_ty: i64) -> i64 {
    let lc: i64 = tc_scalar_class(lhs_ty);
    if lc == 0 {
        return 0;
    }
    let rc: i64 = tc_scalar_class(rhs_ty);
    if rc == 0 {
        return 0;
    }
    if lc != rc {
        return 1;
    }
    0
}

// E2016: `as bool` cast reject. Twin of the Rust Node::As arm in
// walk_expr_class_checks: the rule is TARGET-driven and source-agnostic —
// `is_bool_ann(ty)` alone decides ("cast to `bool` is not permitted; use
// `x != 0`"); the source expression's class is never consulted.
pub fn tc_is_as_bool_reject(target_ty: i64) -> i64 {
    if target_ty == ty_bool() {
        return 1;
    }
    0
}

// Isolated selftest entries (ADDITIVE — never reached through mindc_compile).
// Selectors: 0=i32, 1=i64, 2=f64, 3=bool (tc_name_by_sel/tc_len_by_sel).

// E2010: 1 iff `fn f() -> RET { return <VAL>; }` is a return-type mismatch.
pub fn selftest_tc_return_mismatch(ret_sel: i64, val_sel: i64) -> i64 {
    let ret_buf: i64 = tc_name_by_sel(ret_sel);
    let ret_len: i64 = tc_len_by_sel(ret_sel);
    let val_buf: i64 = tc_name_by_sel(val_sel);
    let val_len: i64 = tc_len_by_sel(val_sel);
    let ret_ty: i64 = resolve_type_ident(ret_buf, 0, ret_len);
    let val_ty: i64 = resolve_type_ident(val_buf, 0, val_len);
    tc_is_return_mismatch(ret_ty, val_ty)
}

// E2011: 1 iff a condition of type COND (bool_intent: 1 = comparison/logical/
// negation node, 0 = direct value) is rejected in if/while position.
pub fn selftest_tc_cond_mismatch(cond_sel: i64, bool_intent: i64) -> i64 {
    let cond_buf: i64 = tc_name_by_sel(cond_sel);
    let cond_len: i64 = tc_len_by_sel(cond_sel);
    let cond_ty: i64 = resolve_type_ident(cond_buf, 0, cond_len);
    tc_is_cond_mismatch(cond_ty, bool_intent)
}

// E2013: 1 iff `<LHS> op <RHS>` mixes the int and float scalar classes.
pub fn selftest_tc_mixed_binop(lhs_sel: i64, rhs_sel: i64) -> i64 {
    let lhs_buf: i64 = tc_name_by_sel(lhs_sel);
    let lhs_len: i64 = tc_len_by_sel(lhs_sel);
    let rhs_buf: i64 = tc_name_by_sel(rhs_sel);
    let rhs_len: i64 = tc_len_by_sel(rhs_sel);
    let lhs_ty: i64 = resolve_type_ident(lhs_buf, 0, lhs_len);
    let rhs_ty: i64 = resolve_type_ident(rhs_buf, 0, rhs_len);
    tc_is_mixed_binop(lhs_ty, rhs_ty)
}

// E2016: 1 iff `<expr> as TARGET` is the rejected bool-cast (target-driven;
// the Rust rule never consults the source class, so neither does this).
pub fn selftest_tc_as_bool(target_sel: i64) -> i64 {
    let target_buf: i64 = tc_name_by_sel(target_sel);
    let target_len: i64 = tc_len_by_sel(target_sel);
    let target_ty: i64 = resolve_type_ident(target_buf, 0, target_len);
    tc_is_as_bool_reject(target_ty)
}

// ===== Arity / shape rules (E2005/E2101/E2102/E2103) =====
//
// Pure-MIND ports of the remaining oracle-backed type-checker guards that are
// reachable without AST context. All ADDITIVE: defined + exported via the
// isolated selftest_* wrappers below, never reached through mindc_compile, so
// the mic@1 canary / self-host loop stay byte-identical. The shape guards take
// concrete ranks/dims hoisted to scalar inputs (the same hoisting E2011 uses
// for its syntactic bool_intent flag); the predicates themselves are exact
// twins of the Rust bodies.
// E2023: the `__mind_` prefix is reserved for compiler intrinsics — a user `fn`
// with that prefix would shadow the intrinsic on the interpreter fn-table oracle
// (a silent miscompile), so it is rejected fail-loud. Twin of the Rust guard in
// src/type_checker/mod.rs (`name.starts_with("__mind_")`, exact 7-byte prefix
// 95 95 109 105 110 100 95 = "__mind_"). starts_with is: len >= 7 AND the first
// 7 bytes equal the prefix. (Earlier dropped when the frozen stage1 self-compile
// hit the shared arena cliff; re-landed on the lex-dedup headroom — the byte-
// table + 6-arg-bytes_eq-behind-if shape is the SAME one resolve_type_ident
// already uses at HEAD, so it was never the crash cause. Additive: reached only
// through selftest_tc_reserved_name, never mindc_compile, so byte-identity holds.)
pub fn tc_reserved_prefix_buf() -> i64 {
    make_byte_buf_7(95, 95, 109, 105, 110, 100, 95)
}

pub fn tc_is_reserved_intrinsic_name(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo < 7 {
        return 0;
    }
    let pfx: i64 = tc_reserved_prefix_buf();
    if bytes_eq(buf, lo, lo + 7, pfx, 0, 7) == 1 {
        return 1;
    }
    0
}

// E2005: intra-module call arity mismatch. Twin of the Rust guard in
// check_intra_fn_call: `args.len() != sig.param_count` alone decides (arity is
// always knowable from the AST regardless of the loose i64 ABI).
pub fn tc_is_arity_mismatch(expected: i64, got: i64) -> i64 {
    if expected != got {
        return 1;
    }
    0
}

// E2101: one right-aligned dim pair under numpy-style broadcasting. Twin of
// the src/shapes/engine.rs broadcast_shapes loop body: dims must be equal or
// 1 (`a == b || a == 1` -> b, `b == 1` -> a); returns the broadcast dim, or
// -1 for the BroadcastError arm.
pub fn tc_broadcast_dim(a: i64, b: i64) -> i64 {
    if a == b {
        return b;
    }
    if a == 1 {
        return b;
    }
    if b == 1 {
        return a;
    }
    0 - 1
}

// E2101: rank-2 x rank-2 elementwise broadcast. Equal ranks right-align
// positionally: pairs (a1,b1) then (a0,b0) — the engine loop unrolled for
// max_rank == 2. 1 iff any pair hits the BroadcastError arm.
pub fn tc_is_broadcast_mismatch_2x2(a0: i64, a1: i64, b0: i64, b1: i64) -> i64 {
    let d1: i64 = tc_broadcast_dim(a1, b1);
    if d1 < 0 {
        return 1;
    }
    let d0: i64 = tc_broadcast_dim(a0, b0);
    if d0 < 0 {
        return 1;
    }
    0
}

// E2101: rank-2 x rank-1 broadcast. The rhs's missing leading dim reads as 1
// (the engine's `.unwrap_or(1)`), so the pairs are (a1,b0) then (a0,1).
pub fn tc_is_broadcast_mismatch_2x1(a0: i64, a1: i64, b0: i64) -> i64 {
    let d1: i64 = tc_broadcast_dim(a1, b0);
    if d1 < 0 {
        return 1;
    }
    let d0: i64 = tc_broadcast_dim(a0, 1);
    if d0 < 0 {
        return 1;
    }
    0
}

// E2102 (matmul rank guard): MatMul2D requires two rank-2 tensors. Twin of
// the engine `lhs.len() != 2 || rhs.len() != 2` RankMismatch arm.
pub fn tc_is_matmul_rank_mismatch(lhs_rank: i64, rhs_rank: i64) -> i64 {
    if lhs_rank != 2 {
        return 1;
    }
    if rhs_rank != 2 {
        return 1;
    }
    0
}

// E2103: matmul inner-dimension mismatch. Twin of the engine `lhs[1] != rhs[0]`
// arm (surfaced by the `@` guard in mod.rs as lhs inner dim vs rhs outer dim).
pub fn tc_is_matmul_inner_mismatch(lhs_k: i64, rhs_k: i64) -> i64 {
    if lhs_k != rhs_k {
        return 1;
    }
    0
}

// Isolated selftest entries (ADDITIVE — never reached through mindc_compile).

// E2005: 1 iff a call passing GOT args to a fn declared with EXPECTED params
// is an arity mismatch.
pub fn selftest_tc_arity_mismatch(expected: i64, got: i64) -> i64 {
    tc_is_arity_mismatch(expected, got)
}

// E2101: 1 iff elementwise [a0,a1] .op [b0,b1] cannot broadcast.
pub fn selftest_tc_broadcast_2x2(a0: i64, a1: i64, b0: i64, b1: i64) -> i64 {
    tc_is_broadcast_mismatch_2x2(a0, a1, b0, b1)
}

// E2101: 1 iff elementwise [a0,a1] .op [b0] cannot broadcast.
pub fn selftest_tc_broadcast_2x1(a0: i64, a1: i64, b0: i64) -> i64 {
    tc_is_broadcast_mismatch_2x1(a0, a1, b0)
}

// E2102/E2103 combined, in engine order: 1 = rank mismatch (E2102, checked
// first), 2 = inner-dimension mismatch (E2103), 0 = shapes accepted.
pub fn selftest_tc_matmul_shape(lhs_rank: i64, lhs_k: i64, rhs_rank: i64, rhs_k: i64) -> i64 {
    if tc_is_matmul_rank_mismatch(lhs_rank, rhs_rank) == 1 {
        return 1;
    }
    if tc_is_matmul_inner_mismatch(lhs_k, rhs_k) == 1 {
        return 2;
    }
    0
}

// E2023: 1 iff a fn name (first 7 bytes b0..b6, true byte-length `len`) starts
// with the reserved "__mind_" prefix. The Python oracle recomputes the exact
// Rust rule name.starts_with("__mind_"). Only the first 7 name bytes matter to
// starts_with, so passing them + the true length faithfully models it (a name
// shorter than 7 bytes can never start with the 7-byte prefix -> the len gate).
pub fn selftest_tc_reserved_name(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64, b6: i64, len: i64) -> i64 {
    let buf: i64 = make_byte_buf_7(b0, b1, b2, b3, b4, b5, b6);
    tc_is_reserved_intrinsic_name(buf, 0, len)
}

// ===== Name hashing (DJB2) =====

pub fn djb2_seed() -> i64 {
    5381
}
pub fn djb2_prime() -> i64 {
    33
}

pub fn name_hash(buf: i64, lo: i64, hi: i64) -> i64 {
    name_hash_rest(buf, lo, hi, djb2_seed())
}

pub fn name_hash_rest(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    let mixed: i64 = (acc * djb2_prime()) + b;
    name_hash_rest(buf, lo + 1, hi, mixed)
}

// ===== Env helpers =====

pub fn env_new() -> Map {
    map_new()
}

pub fn env_bind(env: Map, buf: i64, lo: i64, hi: i64, ty: i64) -> Map {
    let key: i64 = name_hash(buf, lo, hi);
    map_insert(env, key, ty)
}

pub fn env_lookup(env: Map, buf: i64, lo: i64, hi: i64) -> i64 {
    let key: i64 = name_hash(buf, lo, hi);
    env_lookup_rest(env, key, 0, ty_unknown())
}

pub fn env_lookup_rest(env: Map, key: i64, i: i64, best: i64) -> i64 {
    if i >= map_len(env) {
        return best;
    }
    let new_best: i64 = if map_key_at(env, i) == key {
        map_value_at(env, i)
    } else {
        best
    };
    env_lookup_rest(env, key, i + 1, new_best)
}

// ===== String-building helpers (for type-check report) =====

pub fn push_ascii(s: String, b: i64) -> String {
    string_push_byte(s, b)
}
pub fn push_newline(s: String) -> String {
    string_push_byte(s, 10)
}
pub fn push_space(s: String) -> String {
    string_push_byte(s, 32)
}

pub fn push_bytes(s: String, buf: i64, lo: i64, hi: i64) -> String {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let next: String = string_push_byte(s, b);
    push_bytes(next, buf, lo + 1, hi)
}

pub fn push_type_name(s: String, ty: i64) -> String {
    if ty == ty_i64() {
        let s1: String = string_push_byte(s, 105);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_i32() {
        let s1: String = string_push_byte(s, 105);
        let s2: String = string_push_byte(s1, 51);
        return string_push_byte(s2, 50);
    }
    if ty == ty_f64() {
        let s1: String = string_push_byte(s, 102);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_bool() {
        let s1: String = string_push_byte(s, 98);
        let s2: String = string_push_byte(s1, 111);
        let s3: String = string_push_byte(s2, 111);
        return string_push_byte(s3, 108);
    }
    if ty == ty_vec() {
        let s1: String = string_push_byte(s, 86);
        let s2: String = string_push_byte(s1, 101);
        return string_push_byte(s2, 99);
    }
    if ty == ty_string() {
        let s1: String = string_push_byte(s, 83);
        let s2: String = string_push_byte(s1, 116);
        let s3: String = string_push_byte(s2, 114);
        let s4: String = string_push_byte(s3, 105);
        let s5: String = string_push_byte(s4, 110);
        return string_push_byte(s5, 103);
    }
    if ty == ty_unit() {
        let s1: String = string_push_byte(s, 40);
        return string_push_byte(s1, 41);
    }
    string_push_byte(s, 63)
}

pub fn push_kw_let(s: String) -> String {
    let s1: String = string_push_byte(s, 108);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    string_push_byte(s3, 32)
}

pub fn push_kw_fn(s: String) -> String {
    let s1: String = string_push_byte(s, 102);
    let s2: String = string_push_byte(s1, 110);
    string_push_byte(s2, 32)
}

pub fn push_colon(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 58);
    string_push_byte(s2, 32)
}

pub fn push_arrow(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 45);
    let s3: String = string_push_byte(s2, 62);
    string_push_byte(s3, 32)
}

pub fn push_lparen(s: String) -> String {
    string_push_byte(s, 40)
}
pub fn push_rparen(s: String) -> String {
    string_push_byte(s, 41)
}

pub fn push_comma(s: String) -> String {
    let s1: String = string_push_byte(s, 44);
    string_push_byte(s1, 32)
}

pub fn push_kw_error(s: String) -> String {
    let s1: String = string_push_byte(s, 69);
    let s2: String = string_push_byte(s1, 82);
    let s3: String = string_push_byte(s2, 82);
    let s4: String = string_push_byte(s3, 79);
    let s5: String = string_push_byte(s4, 82);
    let s6: String = string_push_byte(s5, 58);
    string_push_byte(s6, 32)
}

pub fn push_at_span(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 97);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 32);
    let s5: String = string_push_byte(s4, 115);
    let s6: String = string_push_byte(s5, 112);
    let s7: String = string_push_byte(s6, 97);
    let s8: String = string_push_byte(s7, 110);
    let s9: String = string_push_byte(s8, 32);
    string_push_byte(s9, 91)
}

pub fn push_i64(s: String, n: i64) -> String {
    if n < 10 {
        return string_push_byte(s, 48 + n);
    }
    let high: String = push_i64(s, n / 10);
    string_push_byte(high, 48 + (n - (n / 10) * 10))
}

pub fn push_err_return_mismatch(s: String) -> String {
    let s1: String = string_push_byte(s, 114);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 117);
    let s5: String = string_push_byte(s4, 114);
    let s6: String = string_push_byte(s5, 110);
    let s7: String = string_push_byte(s6, 32);
    let s8: String = string_push_byte(s7, 116);
    let s9: String = string_push_byte(s8, 121);
    let s10: String = string_push_byte(s9, 112);
    let s11: String = string_push_byte(s10, 101);
    let s12: String = string_push_byte(s11, 32);
    let s13: String = string_push_byte(s12, 109);
    let s14: String = string_push_byte(s13, 105);
    let s15: String = string_push_byte(s14, 115);
    let s16: String = string_push_byte(s15, 109);
    let s17: String = string_push_byte(s16, 97);
    let s18: String = string_push_byte(s17, 116);
    let s19: String = string_push_byte(s18, 99);
    string_push_byte(s19, 104)
}

// ===== TcResult =====

struct TcResult {
    env: Map,
    report: String,
}

pub fn tc_new(env: Map, report: String) -> TcResult {
    TcResult { env: env, report: report }
}

pub fn tc_env(r: TcResult) -> Map {
    r.env
}
pub fn tc_report(r: TcResult) -> String {
    r.report
}

// ===== Expression type resolution =====

pub fn type_of_expr(node: i64, env: Map, buf: i64) -> i64 {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        return ty_i64();
    }

    if k == ast_ident() {
        let lo: i64 = ast_span_lo(node);
        let hi: i64 = ast_span_hi(node);
        return env_lookup(env, buf, lo, hi);
    }

    if k == ast_binop() {
        let op: i64 = ast_aux(node);
        if op == op_lt() {
            return ty_bool();
        }
        if op == op_gt() {
            return ty_bool();
        }
        if op == op_eq() {
            return ty_bool();
        }
        let lhs: i64 = ast_child0(node);
        return type_of_expr(lhs, env, buf);
    }

    if k == ast_paren() {
        let inner: i64 = ast_child0(node);
        return type_of_expr(inner, env, buf);
    }

    if k == ast_call() {
        return ty_unknown();
    }

    ty_unknown()
}

// ===== Statement / item walkers =====

pub fn tc_let(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let ty_node: i64 = ast_child1(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);
    let t_lo: i64 = ast_span_lo(ty_node);
    let t_hi: i64 = ast_span_hi(ty_node);

    let ty: i64 = resolve_type_ident(buf, t_lo, t_hi);
    let new_env: Map = env_bind(env, buf, n_lo, n_hi, ty);

    let s1: String = push_kw_let(report);
    let s2: String = push_bytes(s1, buf, n_lo, n_hi);
    let s3: String = push_colon(s2);
    let s4: String = push_type_name(s3, ty);
    let s5: String = push_newline(s4);

    tc_new(new_env, s5)
}

pub fn tc_return(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let value: i64 = ast_child0(node);
    let actual: i64 = type_of_expr(value, env, buf);

    if actual == expected_ret {
        return tc_new(env, report);
    }
    let lo: i64 = ast_span_lo(node);
    let hi: i64 = ast_span_hi(node);
    let s1: String = push_kw_error(report);
    let s2: String = push_err_return_mismatch(s1);
    let s3: String = push_at_span(s2);
    let s4: String = push_i64(s3, lo);
    let s5: String = push_comma(s4);
    let s6: String = push_i64(s5, hi);
    let s7: String = string_push_byte(s6, 41);
    let s8: String = push_newline(s7);
    tc_new(env, s8)
}

pub fn tc_stmt(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return tc_let(node, env, buf, report);
    }
    if k == ast_return() {
        return tc_return(node, env, buf, report, expected_ret);
    }
    let _: i64 = type_of_expr(node, env, buf);
    tc_new(env, report)
}

pub fn tc_block(block: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let stmts_addr: i64 = ast_child0(block);
    let stmts_len: i64 = ast_aux(block);
    tc_block_stmts_rest(stmts_addr, stmts_len, 0, env, buf, report, expected_ret)
}

pub fn tc_block_stmts_rest(stmts_addr: i64, stmts_len: i64, i: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    if i >= stmts_len {
        return tc_new(env, report);
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let after: TcResult = tc_stmt(stmt, env, buf, report, expected_ret);
    tc_block_stmts_rest(stmts_addr, stmts_len, i + 1, tc_env(after), buf, tc_report(after), expected_ret)
}

pub fn fn_default_ret() -> i64 {
    ty_i64()
}

pub fn tc_fn_def(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let params_addr: i64 = ast_child1(node);
    let body: i64 = ast_child2(node);
    let params_len: i64 = fn_def_params_len(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);

    let fn_env: Map = env_new();
    let after_params: TcResult = tc_params_rest(params_addr, params_len, 0, fn_env, buf, report, n_lo, n_hi, 1);

    let header1: String = push_arrow(tc_report(after_params));
    let header2: String = push_type_name(header1, fn_default_ret());
    let header3: String = push_newline(header2);

    let after_body: TcResult = tc_block(body, tc_env(after_params), buf, header3, fn_default_ret());

    tc_new(env, tc_report(after_body))
}

pub fn tc_params_rest(params_addr: i64, params_len: i64, i: i64, env: Map, buf: i64, report: String, name_lo: i64, name_hi: i64, is_first: i64) -> TcResult {
    if i >= params_len {
        if is_first == 1 {
            let s1: String = push_kw_fn(report);
            let s2: String = push_bytes(s1, buf, name_lo, name_hi);
            let s3: String = push_colon(s2);
            let s4: String = push_lparen(s3);
            let s5: String = push_rparen(s4);
            return tc_new(env, s5);
        }
        let close: String = push_rparen(report);
        return tc_new(env, close);
    }

    let p: i64 = __mind_load_i64(params_addr + i * 8);
    let p_name: i64 = ast_child0(p);
    let p_type: i64 = ast_child1(p);
    let pn_lo: i64 = ast_span_lo(p_name);
    let pn_hi: i64 = ast_span_hi(p_name);
    let pt_lo: i64 = ast_span_lo(p_type);
    let pt_hi: i64 = ast_span_hi(p_type);

    let pt: i64 = resolve_type_ident(buf, pt_lo, pt_hi);
    let new_env: Map = env_bind(env, buf, pn_lo, pn_hi, pt);

    let prefix: String = if is_first == 1 {
        let s1: String = push_kw_fn(report);
        let s2: String = push_bytes(s1, buf, name_lo, name_hi);
        let s3: String = push_colon(s2);
        push_lparen(s3)
    } else {
        push_comma(report)
    };
    let with_type: String = push_type_name(prefix, pt);

    tc_params_rest(params_addr, params_len, i + 1, new_env, buf, with_type, name_lo, name_hi, 0)
}

pub fn tc_item(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_fn_def() {
        return tc_fn_def(node, env, buf, report);
    }
    tc_new(env, report)
}

pub fn tc_items_rest(items_addr: i64, items_len: i64, i: i64, env: Map, buf: i64, report: String) -> TcResult {
    if i >= items_len {
        return tc_new(env, report);
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let after: TcResult = tc_item(item, env, buf, report);
    tc_items_rest(items_addr, items_len, i + 1, tc_env(after), buf, tc_report(after))
}

// ===== Public entry: typecheck =====

pub fn typecheck(ast_root: i64, buf: i64) -> String {
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let env: Map = env_new();
    let report: String = string_new();
    let result: TcResult = tc_items_rest(items_addr, items_len, 0, env, buf, report);
    tc_report(result)
}

// ===========================================================================
// SECTION 4 — MLIR-TEXT EMITTER (Phase 6.4)
// examples/emit_ir/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: lower_program(ast_addr: i64, buf: i64) -> EmitState
// ===========================================================================

// ===== EmitState =====

struct EmitState {
    buf: String,
    next_id: i64,
    last_id: i64,
    lets: Map,
}

pub fn es_new() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0 - 1, lets: env_new() }
}

pub fn es_buf(s: EmitState) -> String {
    s.buf
}
pub fn es_next_id(s: EmitState) -> i64 {
    s.next_id
}
pub fn es_last_id(s: EmitState) -> i64 {
    s.last_id
}

pub fn es_push(s: EmitState, b: i64) -> EmitState {
    EmitState { buf: string_push_byte(s.buf, b), next_id: s.next_id, last_id: s.last_id, lets: s.lets }
}

// ===== ASCII byte constants =====

pub fn ch_space() -> i64 {
    32
}
pub fn ch_newline() -> i64 {
    10
}
pub fn ch_percent() -> i64 {
    37
}
pub fn ch_eq_sign() -> i64 {
    61
}
pub fn ch_comma() -> i64 {
    44
}
pub fn ch_dot() -> i64 {
    46
}
pub fn ch_slash() -> i64 {
    47
}
pub fn ch_lbrace() -> i64 {
    123
}
pub fn ch_rbrace() -> i64 {
    125
}

// ===== Decimal i64 writer =====

pub fn emit_digits_collect(n: i64, acc: Vec) -> Vec {
    if n == 0 {
        return acc;
    }
    let d: i64 = n - (n / 10) * 10;
    let new_acc: Vec = vec_push(acc, 48 + d);
    emit_digits_collect(n / 10, new_acc)
}

pub fn emit_digits_flush(s: EmitState, digits: Vec, i: i64) -> EmitState {
    if i < 0 {
        return s;
    }
    let b: i64 = vec_get(digits, i);
    let s2: EmitState = es_push(s, b);
    emit_digits_flush(s2, digits, i - 1)
}

pub fn emit_i64(s: EmitState, n: i64) -> EmitState {
    if n == 0 {
        return es_push(s, 48);
    }
    let collected: Vec = emit_digits_collect(n, vec_new());
    emit_digits_flush(s, collected, vec_len(collected) - 1)
}

// ===== Byte-range writer =====

pub fn emit_byte_range(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let s2: EmitState = es_push(s, b);
    emit_byte_range(s2, buf, lo + 1, hi)
}

// ===== mic@3 encoding primitives (self-host mic@3 convergence, Phase 1) =====
//
// ULEB128 + zigzag varints — the foundation of the mic@3 wire format (mirrors
// src/ir/compact/v3/emit.rs uleb128_write / zigzag_encode). The bootstrap
// language has `&` and `/` but no `>>` / `while`, so this is arithmetic +
// recursion: the low 7 bits are `n & 127`, the shift is `n / 128`, and the
// continuation bit is `+ 128` (the kept byte is < 128, so `+` equals `|`). Pure:
// identical n yields identical bytes on every substrate (the wedge invariant).
// Verified against the Rust oracle: uleb128(300) = [172, 2] = [0xAC, 0x02].
//
// Additive + isolated from the canary mic@1 emit path (these are not yet wired
// into the keystone fixed-point; they are exercised by selftest_mic3_uleb below
// until Phase 2 builds the mic@3 section emitter on top of them).
// Logical (unsigned) right-shift by 7 of the 64-bit pattern of `n`, matching the
// Rust codec's `value >>= 7` on u64 (src/ir/compact/v2/varint.rs uleb128_write).
// MIND's `/` truncates toward zero, so for a negative i64 (bit 63 set) `n / 128`
// diverges from the u64 logical shift. Here we clear bit 63, shift the low 63
// bits, then re-insert the top bit shifted down (2^63 >> 7 == 2^56) so the full
// 64-bit value uleb128-encodes byte-identically to the Rust oracle (up to 10
// bytes). For non-negative `n` this is exactly `n / 128`, so every existing
// (length/index/zigzag) caller is unchanged.
pub fn emit_uleb128_rest(n: i64) -> i64 {
    if n < 0 {
        let low63: i64 = n & 9223372036854775807;
        return low63 / 128 + 72057594037927936;
    }
    n / 128
}

pub fn emit_uleb128(s: EmitState, n: i64) -> EmitState {
    let low: i64 = n & 127;
    let rest: i64 = emit_uleb128_rest(n);
    if rest == 0 {
        return es_push(s, low);
    }
    let s2: EmitState = es_push(s, low + 128);
    emit_uleb128(s2, rest)
}

// zigzag: signed -> unsigned so small-magnitude values stay short.
//   zigzag(n) = n >= 0 ? 2n : -2n - 1   (== (n<<1) ^ (n>>63) for i64)
pub fn zigzag_encode(n: i64) -> i64 {
    if n < 0 {
        return (0 - n) * 2 - 1;
    }
    n * 2
}

pub fn emit_sleb_zigzag(s: EmitState, n: i64) -> EmitState {
    emit_uleb128(s, zigzag_encode(n))
}

// Selftest export (cdylib pub-fn symbol, like selftest_emit_fn_body): emit the
// ULEB128 of `n` into a fresh EmitState so the Python gate can read the bytes
// back and check them against the Rust encoder. Keeps the primitives live + gated.
pub fn selftest_mic3_uleb(n: i64) -> EmitState {
    emit_uleb128(es_new(), n)
}

// ===== mic@3 header + string-table entry (self-host mic@3 convergence, Phase 2) =====
//
// The MIC3 header: the 4-byte "MIC3" magic + the version byte (mic@3 = 2). This
// is exactly what src/ir/compact/v3/emit.rs emit_mic3 writes first (MIC3_MAGIC
// then MIC3_VERSION). Bytes: M=77 I=73 C=67 '3'=51, version=2.
pub fn emit_mic3_header(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 77);
    let s2: EmitState = es_push(s1, 73);
    let s3: EmitState = es_push(s2, 67);
    let s4: EmitState = es_push(s3, 51);
    es_push(s4, 2)
}

// One mic@3 string-table entry: uleb128(len) || the `len` raw bytes of buf[lo..hi].
// This is the per-string framing emit_mic3 uses (uleb128_write(len) then the
// bytes), and the string-table is just `uleb128(count)` followed by `count` of
// these. Composes the Phase 1 uleb128 with the existing byte-range writer.
pub fn emit_mic3_lp_bytes(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    let len: i64 = hi - lo;
    let s1: EmitState = emit_uleb128(s, len);
    emit_byte_range(s1, buf, lo, hi)
}

pub fn selftest_mic3_header() -> EmitState {
    emit_mic3_header(es_new())
}

pub fn selftest_mic3_lp_bytes(src_addr: i64, src_len: i64) -> EmitState {
    emit_mic3_lp_bytes(es_new(), src_addr, 0, src_len)
}

// ===== mic@3 instruction emitters (self-host mic@3 convergence, Phase 3) =====
//
// The per-opcode encoding of src/ir/compact/v3/emit.rs emit_instr. Operand
// encodings (emit.rs §Low-level helpers): write_vid(id) = uleb128(id);
// write_i64(v) = uleb128(zigzag(v)) — i.e. emit_sleb_zigzag above. These two
// opcodes are the foundation the other 42 reuse (every dst is a vid, every
// integer operand is a write_i64); the full set + the IRModule that feeds it is
// Phase 3b/4. Tested as mechanisms (operands -> bytes) — keystone-isolated.

// Instr::ConstI64(dst, v): OP_CONST_I64(0x01) || vid(dst) || i64(v)
pub fn emit_mic3_const_i64(s: EmitState, dst: i64, v: i64) -> EmitState {
    let s1: EmitState = es_push(s, 1);
    let s2: EmitState = emit_uleb128(s1, dst);
    emit_sleb_zigzag(s2, v)
}

// Instr::BinOp { dst, op, lhs, rhs }:
//   OP_BINOP(0x04) || vid(dst) || binop_to_byte(op) || vid(lhs) || vid(rhs)
// `op_byte` is binop_to_byte(op) — supplied by the (future) lowering; here it is
// a parameter so the framing is tested independently of the op-code mapping.
pub fn emit_mic3_binop(s: EmitState, dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    let s1: EmitState = es_push(s, 4);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = es_push(s2, op_byte);
    let s4: EmitState = emit_uleb128(s3, lhs);
    emit_uleb128(s4, rhs)
}

pub fn selftest_mic3_const_i64(dst: i64, v: i64) -> EmitState {
    emit_mic3_const_i64(es_new(), dst, v)
}

pub fn selftest_mic3_binop(dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    emit_mic3_binop(es_new(), dst, op_byte, lhs, rhs)
}

// Instr::Output(id): OP_OUTPUT(0x13) || vid(id). The function-result terminator.
pub fn emit_mic3_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 19);
    emit_uleb128(s1, id)
}

// encode_opt_vid: None -> [0]; Some(v) -> [1] || uleb(v). `has` = 0/1. Shared by
// Return and FnDef's ret_id.
pub fn emit_mic3_opt_vid(s: EmitState, has: i64, vid: i64) -> EmitState {
    if has == 0 {
        return es_push(s, 0);
    }
    let s1: EmitState = es_push(s, 1);
    emit_uleb128(s1, vid)
}

// Instr::Return { value: Option<vid> }: OP_RETURN(0x17) || encode_opt_vid(value).
pub fn emit_mic3_return(s: EmitState, has_value: i64, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 23);
    emit_mic3_opt_vid(s1, has_value, id)
}

// Instr::FnDef header (OP_FN_DEF 0x15) for a no-parameter function:
//   0x15 || uleb(name_idx) || uleb(0 params) || opt_vid(ret) || opt_f64(None) ||
//   uleb(body_len). The `body_len` body instructions follow (caller-emitted).
// Mirrors the emit_instr Instr::FnDef arm (encode_string_idx, encode_named_vids,
// encode_opt_vid, encode_opt_f64(reap_threshold=None), uleb(body.len)). For
// `fn f() -> i64 {...}` (name_idx=0, ret=%0, body_len=1) this reproduces the
// oracle FN_DEF header bytes 15 00 00 01 00 00 01 exactly.
pub fn emit_mic3_fn_def_header(s: EmitState, name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 0);
    let s4: EmitState = emit_mic3_opt_vid(s3, has_ret, ret_vid);
    let s5: EmitState = es_push(s4, 0);
    emit_uleb128(s5, body_len)
}

pub fn selftest_mic3_fn_def_header(name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    emit_mic3_fn_def_header(es_new(), name_idx, has_ret, ret_vid, body_len)
}

// Instr::Param { dst, name, index }: OP_PARAM(0x18) || vid(dst) || string_idx(name)
//   || uleb(index). The parameter-binding instruction in a function body. For
// `fn id(a)` the body holds PARAM(%0, "a"=idx1, index 0) = 18 00 01 00.
pub fn emit_mic3_param(s: EmitState, dst: i64, name_idx: i64, index: i64) -> EmitState {
    let s1: EmitState = es_push(s, 24);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    emit_uleb128(s3, index)
}

// encode_named_vids (the FN_DEF parameter list): uleb(count) || (string_idx, vid)
// per pair. `pairs` is a heap array of 2*count i64s: pairs[2i] = string_idx,
// pairs[2i+1] = vid. emit_mic3_fn_def's param list uses this.
pub fn emit_mic3_named_vids(s: EmitState, pairs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_named_vids_loop(s1, pairs, count, 0)
}

pub fn emit_mic3_named_vids_loop(s: EmitState, pairs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let sidx: i64 = __mind_load_i64(pairs + i * 16);
    let vid: i64 = __mind_load_i64(pairs + i * 16 + 8);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, vid);
    emit_mic3_named_vids_loop(s2, pairs, count, i + 1)
}

pub fn selftest_mic3_param(dst: i64, name_idx: i64, index: i64) -> EmitState {
    emit_mic3_param(es_new(), dst, name_idx, index)
}

pub fn selftest_mic3_named_vids(pairs: i64, count: i64) -> EmitState {
    emit_mic3_named_vids(es_new(), pairs, count)
}

pub fn selftest_mic3_output(id: i64) -> EmitState {
    emit_mic3_output(es_new(), id)
}

pub fn selftest_mic3_return(has_value: i64, id: i64) -> EmitState {
    emit_mic3_return(es_new(), has_value, id)
}

// ===== mic@3 string-table SECTION assembler (self-host convergence, Phase 3c) =====
//
// The complete mic@3 string table: uleb128(count) followed by `count`
// length-prefixed entries (each via emit_mic3_lp_bytes). `offs` is a heap array
// of (count+1) i64 byte-offsets into `buf`: string i is buf[offs[i] .. offs[i+1]].
// This is the same section src/ir/compact/v3/emit.rs writes after the header
// (uleb128(entries.len()) then each uleb128(len)||bytes), so a matching offsets
// array reproduces the oracle string table byte-for-byte. The offsets are what
// the (future) collect_strings pass will populate; here they are an input so the
// section assembler is tested independently of string collection.
pub fn emit_mic3_strtab(s: EmitState, buf: i64, offs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_strtab_entries(s1, buf, offs, count, 0)
}

pub fn emit_mic3_strtab_entries(s: EmitState, buf: i64, offs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    let s1: EmitState = emit_mic3_lp_bytes(s, buf, lo, hi);
    emit_mic3_strtab_entries(s1, buf, offs, count, i + 1)
}

pub fn selftest_mic3_strtab(buf_addr: i64, offs_addr: i64, count: i64) -> EmitState {
    emit_mic3_strtab(es_new(), buf_addr, offs_addr, count)
}

// ===== mic@3 exports + registries + module assembler (Phase 3d) =====
//
// Exports section: uleb128(count) || count uleb128 string-table indices. emit_mic3
// sorts the export names then writes st.get(name) for each; here `idx` is a heap
// array of (already-sorted) i64 indices (the sort belongs to collection).
pub fn emit_mic3_exports(s: EmitState, idx: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_exports_loop(s1, idx, count, 0)
}

pub fn emit_mic3_exports_loop(s: EmitState, idx: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let v: i64 = __mind_load_i64(idx + i * 8);
    let s1: EmitState = emit_uleb128(s, v);
    emit_mic3_exports_loop(s1, idx, count, i + 1)
}

// The 3 std-surface registries (struct_defs, const_array_defs, repr_c_structs)
// are each uleb128(count) || entries; for a program with none they are three
// uleb128(0). emit_mic3 writes them last.
pub fn emit_mic3_empty_registries(s: EmitState) -> EmitState {
    let s1: EmitState = emit_uleb128(s, 0);
    let s2: EmitState = emit_uleb128(s1, 0);
    emit_uleb128(s2, 0)
}

// Assemble a COMPLETE mic@3 module for the no-instruction case, in the exact
// section order emit_mic3 uses: header || strtab || uleb(next_id) || exports ||
// uleb(0 instrs) || empty registries. The instruction stream (the Phase 4
// real-body lowering) plugs in between exports and the registries.
pub fn emit_mic3_module_noinstr(s: EmitState, buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, str_count);
    let s3: EmitState = emit_uleb128(s2, next_id);
    let s4: EmitState = emit_mic3_exports(s3, idx, exp_count);
    let s5: EmitState = emit_uleb128(s4, 0);
    emit_mic3_empty_registries(s5)
}

pub fn selftest_mic3_exports(idx_addr: i64, count: i64) -> EmitState {
    emit_mic3_exports(es_new(), idx_addr, count)
}

pub fn selftest_mic3_empty_registries() -> EmitState {
    emit_mic3_empty_registries(es_new())
}

pub fn selftest_mic3_module_noinstr(buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    emit_mic3_module_noinstr(es_new(), buf, offs, str_count, next_id, idx, exp_count)
}

// ===== mic@3 COMPLETE with-body module — the const-return function family (Phase 4a) =====
//
// Assembles the full mic@3 of `pub fn <name>() -> i64 { <const_val> }`, byte-exact
// vs the Rust oracle. This is the FIRST complete WITH-BODY emit in pure-MIND. The
// section order + the exact 3-instruction module shape are what emit_mic3 + the
// lowering produce for a const-return function:
//   header || strtab(1:name) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name, ret=%0, body=[ConstI64(%0, const_val)]} ||
//     ConstI64(%0, 0) || Output(%0) ||
//   3 empty registries.
// Verified across const values (42 -> 0x54, 100 -> 0xc8 0x01), so it is a genuine
// (narrow) lowering, not a hardcoded byte blob. Generalizing to arbitrary bodies
// (the AST walk that emits these calls) is the remaining Phase 4 work; this proves
// the emit layer composes into a complete, oracle-identical module.
pub fn emit_mic3_const_fn_module(s: EmitState, buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = emit_mic3_fn_def_header(s5, name_idx, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, const_val);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    emit_mic3_empty_registries(s9)
}

pub fn selftest_mic3_const_fn(buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    emit_mic3_const_fn_module(es_new(), buf, offs, name_idx, const_val)
}

// ===== mic@3 COMPLETE MULTI-FUNCTION module — two const-return fns (Phase 5a) =====
//
// The first pure-MIND emit of a module with MORE THAN ONE function. Assembles the
// full mic@3 of `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>() -> i64 { <v1> }`
// (no export{} block -> empty exports table), byte-exact vs the Rust --emit-mic3
// oracle. The four multi-function deltas vs the single-fn const family (Phase 4a):
//   (1) ONE string table deduped in FIRST-SEEN TRAVERSAL order (n0 then n1) — the
//       offsets array carries 3 i64s (2 strings); name indices are 0 and 1.
//   (2) ONE FLAT next_id threaded across both fns + their scaffolds: the two
//       scaffold ConstI64s take %0 (fn0) and %1 (fn1), so next_id = 2.
//   (3) ONE flat top-level instruction list with a SINGLE uleb count (= 6) covering
//       both FN_DEFs and both scaffold ConstI64/Output pairs.
//   (4) exports sorted (empty here — the export-free fixture).
// The FN_DEF body vids reset to %0 per function (each body is its own vid space),
// while the module-level scaffold const/output threads the flat counter (%0, %1).
// Verified across const values (one=1->zz 0x02, two=2->zz 0x04) so it is a genuine
// narrow multi-fn lowering, not a hardcoded blob.
pub fn emit_mic3_const_fn2_module(s: EmitState, buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = emit_mic3_fn_def_header(s9, 1, 1, 0, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, 0, v1);
    let s12: EmitState = emit_mic3_const_i64(s11, 1, 0);
    let s13: EmitState = emit_mic3_output(s12, 1);
    emit_mic3_empty_registries(s13)
}

pub fn selftest_mic3_module_2fn(buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_const_fn2_module(es_new(), buf, offs, v0, v1)
}

// ===== mic@3 MULTI-FUNCTION module — const-return fn0 + arith fn1 (Phase 5b) =====
//
// `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>(<pa>,<pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust --emit-mic3 oracle. Combines a Phase 4a const-return body
// with a Phase 4c PARAM/PARAM/BINOP body under ONE module header, exercising the
// multi-function deltas where the two functions have DIFFERENT body shapes:
//   strtab[4] in FIRST-SEEN order: n0, n1, pa, pb (name indices 0,1,2,3).
//   next_id = 2 (flat scaffold consts %0, %1 — the FN_DEF bodies keep their own vid
//   spaces: fn0 body %0, fn1 body %0,%1,%2).
//   instr_count = 6: FN_DEF n0{ConstI64 %0=v0} || ConstI64 %0=0 || Output %0 ||
//     FN_DEF n1{PARAM %0, PARAM %1, BINOP %2=%0 op %1} || ConstI64 %1=0 || Output %1.
// For `one(){1}` + `add(a,b){a+b}` (op_byte 0) this reproduces the 68-byte oracle
// byte-for-byte; verified vs live --emit-mic3 in mic3_primitives_smoke.py.
pub fn emit_mic3_const_arith_module(s: EmitState, buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = es_push(s9, 21);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 2);
    let s13: EmitState = emit_uleb128(s12, 2);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_uleb128(s15, 1);
    let s17: EmitState = emit_mic3_opt_vid(s16, 1, 2);
    let s18: EmitState = es_push(s17, 0);
    let s19: EmitState = emit_uleb128(s18, 3);
    let s20: EmitState = emit_mic3_param(s19, 0, 2, 0);
    let s21: EmitState = emit_mic3_param(s20, 1, 3, 1);
    let s22: EmitState = emit_mic3_binop(s21, 2, op_byte, 0, 1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_const_arith(buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    emit_mic3_const_arith_module(es_new(), buf, offs, v0, op_byte)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const fn1 (Strategy A, let cover) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }  pub fn <n1>() -> i64 { <v1> }`,
// byte-exact vs the Rust --emit-mic3 oracle. This is the arith-FIRST ordering (the
// const-arith module is const-first); it is the module shape a 2-param fn written
// with a LET body lowers to (`f(a,b){let t=a+b; t}` == `f(a,b){a+b}` — the let-bound
// value reuses the binop vid, emitting no distinct opcode or string). strtab[4] in
// first-seen order: n0, pa, pb, n1 (indices 0,1,2,3). next_id = 2 (flat scaffold
// consts %0 fn0, %1 fn1). instr_count = 6.
//   FN_DEF n0{PARAM %0=str1, PARAM %1=str2, BINOP %2=%0 op %1} ret %2 ||
//     ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v1} ret %0 || ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_const_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: const (name idx 3).
    let s21: EmitState = emit_mic3_fn_def_header(s20, 3, 1, 0, 1);
    let s22: EmitState = emit_mic3_const_i64(s21, 0, v1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_arith_const(buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    emit_mic3_arith_const_module(es_new(), buf, offs, op_byte, v1)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const-args CALL fn1 (Strategy A) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }
//  pub fn <n1>() -> i64 { <n0>(<v0>, <v1>) }`, byte-exact vs --emit-mic3. fn1's
// body is a CALL to fn0 with two int-literal args: each arg lowers to a ConstI64
// taking the next body vid (%0, %1), then OP_CALL(0x16) %2 = name#callee(%0,%1)
// (encode_string_idx(callee) || encode_vid_vec([%0,%1])). The FN_DEF ret is %2,
// body_len 3. The callee string DEDUPS to fn0's name index (interned first during
// fn0's FnDef; the call name interns idempotently during body traversal — handled
// by collect_body_strings, so strtab[4] = n0, pa, pb, n1 in first-seen order with
// the call referencing index 0). next_id = 2 (scaffold consts %0 fn0, %1 fn1).
//   FN_DEF n0{PARAM,PARAM,BINOP} ret %2 || ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v0, ConstI64 %1=v1, CALL %2=callee(%0,%1)} ret %2 ||
//     ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_call_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: call body (name idx 3), ret %2, body_len 3.
    let s21: EmitState = es_push(s20, 21);
    let s22: EmitState = emit_uleb128(s21, 3);
    let s23: EmitState = emit_uleb128(s22, 0);
    let s24: EmitState = emit_mic3_opt_vid(s23, 1, 2);
    let s25: EmitState = es_push(s24, 0);
    let s26: EmitState = emit_uleb128(s25, 3);
    let s27: EmitState = emit_mic3_const_i64(s26, 0, v0);
    let s28: EmitState = emit_mic3_const_i64(s27, 1, v1);
    let s29: EmitState = emit_mic3_call2(s28, 2, callee_idx, 0, 1);
    let s30: EmitState = emit_mic3_const_i64(s29, 1, 0);
    let s31: EmitState = emit_mic3_output(s30, 1);
    emit_mic3_empty_registries(s31)
}

// Instr::Call { dst, name, args=[a0,a1] }:
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(2) || vid(a0) || vid(a1).
pub fn emit_mic3_call2(s: EmitState, dst: i64, name_idx: i64, a0: i64, a1: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, 2);
    let s5: EmitState = emit_uleb128(s4, a0);
    emit_uleb128(s5, a1)
}

pub fn selftest_mic3_module_arith_call(buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_arith_call_module(es_new(), buf, offs, op_byte, callee_idx, v0, v1)
}

// Instr::Call { dst, name, args=[a0] } (single-argument call):
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(1) || vid(a0).
// The field-read lowering emits exactly this for `__mind_load_i64(<addr>)`.
pub fn emit_mic3_call1(s: EmitState, dst: i64, name_idx: i64, a0: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, 1);
    emit_uleb128(s4, a0)
}

// A NON-EMPTY std-surface struct_defs registry holding ONE 2-field struct, then
// the two remaining registries empty. emit_mic3 writes the three registries last,
// each as uleb(count) || entries. For struct_defs a single entry is
// uleb(name_idx) || uleb(field_count) || uleb(field0_idx) || uleb(field1_idx).
// The wire tail for `struct S { a, b }` (name str#4, a str#5, b str#6) is therefore
//   01 04 02 05 06   00   00
// (struct_defs=1 · S · 2 fields · a · b || const_array_defs=0 || repr_c_structs=0).
// Mirrors src/ir/compact/v3/emit.rs:746-773 (BTreeMap key order — a single key is
// trivially sorted). The field indices are string-table indices, NOT field offsets.
pub fn emit_mic3_struct_defs_one(s: EmitState, name_idx: i64, f0_idx: i64, f1_idx: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, 1);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, f0_idx);
    let s5: EmitState = emit_uleb128(s4, f1_idx);
    let s6: EmitState = emit_uleb128(s5, 0);
    emit_uleb128(s6, 0)
}

// ===== mic@3 MULTI-FUNCTION module — struct decl + two FIELD-READ fns (Strategy A) =====
//
// `struct S { a: i64, b: i64 }
//  pub fn get_a(s: S) -> i64 { s.a }
//  pub fn get_b(s: S) -> i64 { s.b }`, byte-exact vs the Rust --emit-mic3 oracle.
// The FIRST pure-MIND emit of (1) a non-empty struct_defs registry and (2) the
// field-access lowering. The Rust lowering (src/eval/lower.rs FieldAccess arm)
// resolves a field READ `recv.field` via ir.struct_defs[ReceiverType] to a field
// INDEX, then lowers to a `__mind_load_i64` of the field address:
//   field idx 0 (s.a):  PARAM %0=recv ; CALL %1=__mind_load_i64([%0])
//                       — base address direct, no offset added.
//   field idx 1 (s.b):  PARAM %0=recv ; CONST %1=idx*8 (=8) ;
//                       BINOP %2 = Add(%0,%1) ; CALL %3=__mind_load_i64([%2]).
// Each top-level item (the struct decl AND each fn) emits a module-level scaffold
// ConstI64/Output pair that produces no value, threading ONE FLAT next_id: struct
// decl -> %0, get_a -> %1, get_b -> %2, so next_id = 3. The FN_DEF bodies keep
// their own vid space (reset to %0 per fn). strtab[7] in FIRST-SEEN traversal
// order (instrs walked before the struct_defs registry, per emit_mic3 lines
// 701/705): get_a, s, __mind_load_i64, get_b, S, a, b -> indices 0..6.
//   ConstI64 %0=0 || Output %0 ||                                  (struct S scaffold)
//   FN_DEF get_a(s){PARAM %0, CALL %1=load([%0])} ret %1 ||
//     ConstI64 %1=0 || Output %1 ||
//   FN_DEF get_b(s){PARAM %0, CONST %1=foff, BINOP %2=add(%0,%1),
//     CALL %3=load([%2])} ret %3 || ConstI64 %2=0 || Output %2 ||
//   struct_defs[S=[a,b]] || const_array_defs=0 || repr_c_structs=0.
// `foff` (the byte offset of field b = idx*8 = 8) is threaded as a parameter so the
// emit is a genuine narrow lowering, not a hardcoded blob; reproduces the 111-byte
// oracle for foff=8. `load_idx` = string index of "__mind_load_i64" (=2).
pub fn emit_mic3_field_module(s: EmitState, buf: i64, offs: i64, load_idx: i64, foff: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 7);
    let s3: EmitState = emit_uleb128(s2, 3);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 8);
    // struct S decl -> module-level scaffold ConstI64 %0 / Output %0.
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // get_a(s){ s.a } — name idx 0, one param "s" (str 1), ret %1, body_len 2.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, 0);
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 1);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 2);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_call1(s16, 1, load_idx, 0);
    let s18: EmitState = emit_mic3_const_i64(s17, 1, 0);
    let s19: EmitState = emit_mic3_output(s18, 1);
    // get_b(s){ s.b } — name idx 3, one param "s" (str 1), ret %3, body_len 4.
    let s20: EmitState = es_push(s19, 21);
    let s21: EmitState = emit_uleb128(s20, 3);
    let s22: EmitState = emit_uleb128(s21, 1);
    let s23: EmitState = emit_uleb128(s22, 1);
    let s24: EmitState = emit_uleb128(s23, 0);
    let s25: EmitState = emit_mic3_opt_vid(s24, 1, 3);
    let s26: EmitState = es_push(s25, 0);
    let s27: EmitState = emit_uleb128(s26, 4);
    let s28: EmitState = emit_mic3_param(s27, 0, 1, 0);
    let s29: EmitState = emit_mic3_const_i64(s28, 1, foff);
    let s30: EmitState = emit_mic3_binop(s29, 2, 0, 0, 1);
    let s31: EmitState = emit_mic3_call1(s30, 3, load_idx, 2);
    let s32: EmitState = emit_mic3_const_i64(s31, 2, 0);
    let s33: EmitState = emit_mic3_output(s32, 2);
    // Registries: struct_defs[S=[a,b]] (S str 4, a str 5, b str 6), rest empty.
    emit_mic3_struct_defs_one(s33, 4, 5, 6)
}

pub fn selftest_mic3_module_field(buf: i64, offs: i64, load_idx: i64, foff: i64) -> EmitState {
    emit_mic3_field_module(es_new(), buf, offs, load_idx, foff)
}

// ===== mic@3 AST-DRIVEN single-struct field-read load (parts 1+2 wired) =====
//
// `struct S { a: i64 }  pub fn get_a(s: S) -> i64 { s.a }` (idx 0, 71 bytes) and
// `struct S { a: i64, b: i64 } pub fn get_b(s: S) -> i64 { s.b }` (idx 1, 82
// bytes), lowered from SOURCE (not hand-fed indices) byte-exact vs the Rust
// `--emit-mic3` oracle. This is the AST-driven field-access lowering: it resolves
// the `recv.field` access by wiring SECTION 6 (the struct field table, part 1)
// and SECTION 7 (the per-fn param-type table, part 2):
//   * part 2 (ptt) binds the receiver param `s` -> its declared type span `S`;
//   * part 1 (sft) gives the ordered field-name spans of the struct, against
//     which the accessed field name resolves to a field INDEX.
// The Rust lowering (src/eval/lower.rs FieldAccess arm) computes the field byte
// offset = idx*8 and lowers a `__mind_load_i64` of the field address:
//   idx 0:  FN_DEF f(recv){ PARAM %0 ; CALL %1=load([%0]) } ret %1  (no offset);
//   idx>0:  FN_DEF f(recv){ PARAM %0 ; CONST %1=idx*8 ;
//             BINOP %2=Add(%0,%1) ; CALL %3=load([%2]) } ret %3.
// SCOPE (this slice): exactly ONE struct, ONE param, any accessed field index in
// that struct. Any other shape returns the seed state unchanged (fail-closed, no
// partial bytes). Multi-struct keying (a recv typed by the 2nd+ struct) is the
// next increment — sft_find_struct_body finds only the FIRST struct today.
//
// String table in FIRST-SEEN traversal order (emit_mic3 walks instrs before the
// struct_defs registry, src/ir/compact/v3/emit.rs:701/705): the FnDef name,
// then its param name, then the body Call name `__mind_load_i64`, then the
// struct_defs registry type name and EVERY field in declaration order -> the
// accessed field lands at string index 4+fidx. `__mind_load_i64` is synthetic
// (not in source), written into `strbuf` as a literal and interned like any
// source span (intern_load_i64_literal).
//
// ADDITIVE / canary-isolated: exported only via selftest_mic3_module_field_from_ast;
// the canary mindc_compile / emit_expr_env ast_field path (const.i64 0) is
// untouched, so the keystone fixed-point bytes are unchanged.

// Write the literal "__mind_load_i64" (15 bytes) into `strbuf` at the current
// interning cursor and register its offset/count, returning the freshly
// allocated string index. Mirrors intern_span's allocate tail exactly, but the
// source bytes are the fixed synthetic call name rather than a span of `src`.
// (No dedup scan: this name is interned exactly once, after the source spans, in
// the field-read lowering — matching the Rust collect order.)
pub fn intern_load_i64_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_load_i64" = 95 95 109 105 110 100 95 108 111 97 100 95 105 54 52.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 108);
    __mind_store_i8(strbuf + start + 8, 111);
    __mind_store_i8(strbuf + start + 9, 97);
    __mind_store_i8(strbuf + start + 10, 100);
    __mind_store_i8(strbuf + start + 11, 95);
    __mind_store_i8(strbuf + start + 12, 105);
    __mind_store_i8(strbuf + start + 13, 54);
    __mind_store_i8(strbuf + start + 14, 52);
    __mind_store_i64(offs + (n + 1) * 8, start + 15);
    __mind_store_i64(ccell, n + 1);
    n
}

// The j-th byte (0..15) of the synthetic call name "__mind_load_i64". Shared by
// the dedup-aware interner so the literal lives in exactly one place.
pub fn load_i64_name_byte(j: i64) -> i64 {
    if j == 0 {
        return 95;
    }
    if j == 1 {
        return 95;
    }
    if j == 2 {
        return 109;
    }
    if j == 3 {
        return 105;
    }
    if j == 4 {
        return 110;
    }
    if j == 5 {
        return 100;
    }
    if j == 6 {
        return 95;
    }
    if j == 7 {
        return 108;
    }
    if j == 8 {
        return 111;
    }
    if j == 9 {
        return 97;
    }
    if j == 10 {
        return 100;
    }
    if j == 11 {
        return 95;
    }
    if j == 12 {
        return 105;
    }
    if j == 13 {
        return 54;
    }
    52
}

// Does the already-interned string at index i equal "__mind_load_i64"? Raw-byte
// compare against the synthetic literal (no hashing), mirroring StringTable
// dedup on the synthetic Call name.
pub fn load_i64_name_eq_at(strbuf: i64, offs: i64, i: i64, j: i64) -> i64 {
    let elo: i64 = __mind_load_i64(offs + i * 8);
    let ehi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if ehi - elo != 15 {
        return 0;
    }
    if j >= 15 {
        return 1;
    }
    if load_byte(strbuf, elo + j) != load_i64_name_byte(j) {
        return 0;
    }
    load_i64_name_eq_at(strbuf, offs, i, j + 1)
}

// Find the string index of "__mind_load_i64" among the n already-interned
// strings, or -1. Mirrors StringTable::intern's first-seen dedup lookup.
pub fn load_i64_name_find(strbuf: i64, offs: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    if load_i64_name_eq_at(strbuf, offs, i, 0) == 1 {
        return i;
    }
    load_i64_name_find(strbuf, offs, n, i + 1)
}

// Dedup-aware intern of the synthetic "__mind_load_i64" call name: returns the
// existing index on a hit, else allocates it (via intern_load_i64_literal) and
// returns the fresh index. This is the idempotent form the COLLECTION PASS needs
// (a body with multiple field reads interns the name once), matching the Rust
// `Instr::Call { name } => st.intern(name)` first-seen behaviour. The direct
// field driver (emit_mic3_field_module_from_ast) still calls the no-dedup
// intern_load_i64_literal because that path interns the name exactly once.
pub fn intern_load_i64_name(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let hit: i64 = load_i64_name_find(strbuf, offs, n, 0);
    if hit >= 0 {
        return hit;
    }
    intern_load_i64_literal(strbuf, offs, ccell)
}

// ===== mic@3 struct-literal CONSTRUCTION synthetic-name interns =====
//
// The Rust lowering (src/eval/lower.rs StructLit arm) desugars a struct-literal
// `T { f0: e0, .. }` into an allocation + per-field stores:
//   CONST elem=8 ; CONST n_fields ; BINOP Mul -> size ;
//   CALL __mind_alloc([size]) -> ptr ;
//   per field (DECLARED order): store the field value at ptr + idx*8 via
//     __mind_store_i64([addr, val]) (idx 0 stores at ptr directly; idx>0 adds a
//     CONST(idx*8) + BINOP Add(ptr, off)).
// The FN_DEF returns the alloc ptr vid. Two synthetic call names are interned
// FIRST-SEEN right after the fn name + its param (and before the struct type
// name), matching emit.rs's instr-before-registry walk: `__mind_alloc` (12 bytes)
// then `__mind_store_i64` (16 bytes). Each mirrors intern_load_i64_literal's
// allocate tail exactly; the bytes + length are the only difference.

// Write the literal "__mind_alloc" (12 bytes) into `strbuf` at the current
// interning cursor; register its offset/count; return the fresh string index.
pub fn intern_alloc_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_alloc" = 95 95 109 105 110 100 95 97 108 108 111 99.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 97);
    __mind_store_i8(strbuf + start + 8, 108);
    __mind_store_i8(strbuf + start + 9, 108);
    __mind_store_i8(strbuf + start + 10, 111);
    __mind_store_i8(strbuf + start + 11, 99);
    __mind_store_i64(offs + (n + 1) * 8, start + 12);
    __mind_store_i64(ccell, n + 1);
    n
}

// Write the literal "__mind_store_i64" (16 bytes) into `strbuf` at the current
// interning cursor; register its offset/count; return the fresh string index.
pub fn intern_store_i64_literal(strbuf: i64, offs: i64, ccell: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let start: i64 = __mind_load_i64(offs + n * 8);
    // "__mind_store_i64" = 95 95 109 105 110 100 95 115 116 111 114 101 95 105 54 52.
    __mind_store_i8(strbuf + start + 0, 95);
    __mind_store_i8(strbuf + start + 1, 95);
    __mind_store_i8(strbuf + start + 2, 109);
    __mind_store_i8(strbuf + start + 3, 105);
    __mind_store_i8(strbuf + start + 4, 110);
    __mind_store_i8(strbuf + start + 5, 100);
    __mind_store_i8(strbuf + start + 6, 95);
    __mind_store_i8(strbuf + start + 7, 115);
    __mind_store_i8(strbuf + start + 8, 116);
    __mind_store_i8(strbuf + start + 9, 111);
    __mind_store_i8(strbuf + start + 10, 114);
    __mind_store_i8(strbuf + start + 11, 101);
    __mind_store_i8(strbuf + start + 12, 95);
    __mind_store_i8(strbuf + start + 13, 105);
    __mind_store_i8(strbuf + start + 14, 54);
    __mind_store_i8(strbuf + start + 15, 52);
    __mind_store_i64(offs + (n + 1) * 8, start + 16);
    __mind_store_i64(ccell, n + 1);
    n
}

// Scan the token stream for the first field-access `.` and return the token
// index of the dot, or -1 if none. The receiver ident is at dot-1, the field
// ident at dot+1 (mirrors the surface `recv . field`).
pub fn ffa_find_dot(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_dot() {
        return pos;
    }
    ffa_find_dot(toks, pos + 1)
}

// Resolve the accessed field-name span buf[lo..hi) to its field INDEX in the
// struct field table `t` (part 1), or -1 if not found. Linear scan + raw-byte
// span equality (no hashing) — the field order IS the layout order.
pub fn ffa_field_index(t: i64, buf: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= sft_table_count(t) {
        return 0 - 1;
    }
    if span_bytes_equal(buf, lo, hi, sft_table_name_lo(t, k), sft_table_name_hi(t, k)) == 1 {
        return k;
    }
    ffa_field_index(t, buf, lo, hi, k + 1)
}

// Intern every struct field name (part-1 table `sft`) into `strbuf` in
// declaration order, starting at field `k`. The field names follow the fn name,
// param name, `__mind_load_i64` and the type name, so field j lands at string
// index 4+j (distinct names, intern_span dedups but these never collide). Used
// for both the body (the accessed field) and the struct_defs registry tail.
pub fn ffa_intern_fields(strbuf: i64, offs: i64, ccell: i64, src: i64, sft: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 0;
    }
    let _i: i64 = intern_span(strbuf, offs, ccell, src, sft_table_name_lo(sft, k), sft_table_name_hi(sft, k));
    ffa_intern_fields(strbuf, offs, ccell, src, sft, k + 1)
}

// Emit the struct_defs registry field-index list: `count` ulebs, the field at
// declaration index j being string index `base + j` (base = 4 = first field
// slot). Mirrors emit_mic3_struct_defs_one's field tail but for N fields.
pub fn ffa_emit_field_idxs(s: EmitState, base: i64, count: i64, j: i64) -> EmitState {
    if j >= count {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, base + j);
    ffa_emit_field_idxs(s1, base, count, j + 1)
}

// Emit the struct_defs registry field-index list using each field's ACTUAL
// interned string index (re-interning is idempotent and returns the existing
// index on a hit). Required when a field name aliases an earlier-interned string
// (e.g. a field whose name equals a param name): the StringTable de-dups, so the
// field idx is the prior index, not a fresh contiguous slot.
pub fn ffa_emit_field_idxs_interned(s: EmitState, strbuf: i64, offs: i64, ccell: i64, src: i64, sft: i64, j: i64) -> EmitState {
    if j >= sft_table_count(sft) {
        return s;
    }
    let idx: i64 = intern_span(strbuf, offs, ccell, src, sft_table_name_lo(sft, j), sft_table_name_hi(sft, j));
    let s1: EmitState = emit_uleb128(s, idx);
    ffa_emit_field_idxs_interned(s1, strbuf, offs, ccell, src, sft, j + 1)
}

// AST-driven mic@3 module for a single-struct, single-param field read at any
// field index. Returns the seed `s` unchanged on any unexpected shape
// (fail-closed). idx==0 lowers to a direct `__mind_load_i64([recv])`; idx>0 adds
// the `CONST(idx*8) + BINOP Add + CALL([sum])` offset path (mirrors the
// src/eval/lower.rs FieldAccess arm and emit_mic3_field_module's get_b case).
pub fn emit_mic3_field_module_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    // Shape guards: at least one struct field and exactly one fn param.
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) != 1 {
        return s;
    }
    // Locate `recv.field`; resolve the field name to its struct field index.
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 1 {
        return s;
    }
    let recv_lo: i64 = tok_lo(tokens, dot - 1);
    let recv_hi: i64 = tok_hi(tokens, dot - 1);
    let fld_lo: i64 = tok_lo(tokens, dot + 1);
    let fld_hi: i64 = tok_hi(tokens, dot + 1);
    let fidx: i64 = ffa_field_index(sft, src, fld_lo, fld_hi, 0);
    if fidx < 0 {
        return s;
    }
    // Receiver-type binding (part 2): the receiver param's declared type name is
    // the struct type; confirm the receiver names param 0 (fail-closed if not).
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, 0), ptt_table_name_hi(ptt, 0)) != 1 {
        return s;
    }
    // The fn name is the ident two tokens before the param-list `(` — i.e. the
    // token right before `(`. ptt_find_param_list returns the index just past `(`
    // (params start = fn_kw+3), so the `(` is at params_start-1 and the name at
    // params_start-2.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Struct type name span (part 2 binding -> the struct_defs registry key).
    let ty_lo: i64 = ptt_table_type_lo(ptt, 0);
    let ty_hi: i64 = ptt_table_type_hi(ptt, 0);
    let n_fields: i64 = sft_table_count(sft);
    // Intern strings in FIRST-SEEN order (instrs before registry):
    //   0: fn name, 1: param name, 2: __mind_load_i64, 3: type name,
    //   4..4+n_fields: every struct field in declaration order. The accessed
    //   field's string index is therefore 4+fidx.
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let i_recv: i64 = intern_span(strbuf, offs, ccell, src, recv_lo, recv_hi);
    let i_load: i64 = intern_load_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    // String-table count = 4 fixed entries + every struct field.
    let strc: i64 = 4 + n_fields;
    // Body shape: idx==0 -> PARAM, CALL([%0]) (len 2, ret %1); idx>0 -> PARAM,
    // CONST(fidx*8), BINOP Add(%0,%1), CALL([%2]) (len 4, ret %3).
    let body_len: i64 = ffa_body_len(fidx);
    let ret_vid: i64 = ffa_ret_vid(fidx);
    // Assemble: header || strtab(strc) || next_id(2) || exports(0) ||
    //   5 instrs [ CONST %0 / OUTPUT %0  (struct scaffold)
    //             FN_DEF f(recv){ <body> } ret %ret_vid
    //             CONST %1 / OUTPUT %1  (fn scaffold) ]
    //   || struct_defs[ ty=[fields...] ] || const_array_defs=0 || repr_c_structs=0.
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 5);
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF header: name idx, 1 param (name, vid 0), ret %ret_vid, body_len.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn);
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_uleb128(s10, i_recv);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, ret_vid);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, body_len);
    let s16: EmitState = emit_mic3_param(s15, 0, i_recv, 0);
    let s17: EmitState = ffa_emit_body(s16, fidx, i_load);
    let s18: EmitState = emit_mic3_const_i64(s17, 1, 0);
    let s19: EmitState = emit_mic3_output(s18, 1);
    // Registry: one struct (ty=[field0..fieldN-1]).
    let s20: EmitState = emit_uleb128(s19, 1);
    let s21: EmitState = emit_uleb128(s20, i_ty);
    let s22: EmitState = emit_uleb128(s21, n_fields);
    let s23: EmitState = ffa_emit_field_idxs(s22, 4, n_fields, 0);
    let s24: EmitState = emit_uleb128(s23, 0);
    emit_uleb128(s24, 0)
}

// FN_DEF body_len for a field-read: idx 0 -> 2 (PARAM, CALL); idx>0 -> 4
// (PARAM, CONST, BINOP, CALL).
pub fn ffa_body_len(fidx: i64) -> i64 {
    if fidx == 0 {
        return 2;
    }
    4
}

// FN_DEF return vid for a field-read: idx 0 -> %1 (the CALL); idx>0 -> %3.
pub fn ffa_ret_vid(fidx: i64) -> i64 {
    if fidx == 0 {
        return 1;
    }
    3
}

// Emit the field-read body AFTER the PARAM (already at %0). idx 0: a single CALL
// %1 = __mind_load_i64([%0]). idx>0: CONST %1 = fidx*8, BINOP %2 = Add(%0,%1),
// CALL %3 = __mind_load_i64([%2]) — the byte offset of field `fidx` from the
// receiver base (binop_to_byte(Add) = 0, matching the get_b oracle).
pub fn ffa_emit_body(s: EmitState, fidx: i64, i_load: i64) -> EmitState {
    if fidx == 0 {
        return emit_mic3_call1(s, 1, i_load, 0);
    }
    let s1: EmitState = emit_mic3_const_i64(s, 1, fidx * 8);
    let s2: EmitState = emit_mic3_binop(s1, 2, 0, 0, 1);
    emit_mic3_call1(s2, 3, i_load, 2)
}

pub fn selftest_mic3_module_field_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_field_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// mic@3 AST-DRIVEN struct-literal CONSTRUCTION (single struct, N params)
// ===========================================================================
//
// `pub struct T { f0: i64, .. }  pub fn mk(a: i64, b: i64, ..) -> T { T { f0: e0, .. } }`,
// byte-exact vs the Rust --emit-mic3 oracle. The WRITE-side mirror of the
// field-READ driver: the fn body is a struct-literal construction, lowered (per
// src/eval/lower.rs StructLit arm) to an allocation + per-field stores. For
// n_params parameters (vids 0..n_params-1):
//   %0..%(n-1)   PARAM (one per param, in declaration order)
//   %n           CONST 8                 (element size, bytes)
//   %(n+1)       CONST n_fields
//   %(n+2)       BINOP Mul(%n,%(n+1))    (= alloc size)
//   %(n+3)       CALL __mind_alloc([%(n+2)]) (= base ptr; the FN_DEF return vid)
//   then for each field in DECLARED order (idx 0..n_fields-1):
//     [value]  int-literal     -> CONST %v = lit ; literal val_vid
//              ident==param k   -> reuse %k (no instr) ; val_vid = param index
//     [addr]   idx == 0     -> store at the base ptr directly
//              idx >  0     -> CONST %o = idx*8 ; BINOP Add(ptr,%o) ; addr = sum
//     CALL %s = __mind_store_i64([addr_vid, val_vid])
// SCOPE (this slice): EXACTLY one struct, one fn with >=1 param, the fn returns a
// single struct-literal whose every field initializer is either an int-literal or
// a param ident. Any other shape returns the seed state unchanged (fail-closed,
// no partial bytes). N==1 reduces to the original single-param oracle exactly.
//
// String table FIRST-SEEN order (instrs walked before the struct_defs registry):
//   0: fn name, 1..1+n: every param name (declaration order),
//   then __mind_alloc, __mind_store_i64, struct type name, then every field in
//   declaration order (string base 4+n_params).
// ADDITIVE / canary-isolated: reached only via
// selftest_mic3_module_structlit_from_ast and the unified dispatcher; the canary
// (mindc_compile / emit_fn_def) is untouched, so the fixed point is unchanged.

// Find the struct-literal CONSTRUCTION head token: an ident immediately followed
// by `{` whose ident bytes equal the struct type name span. Returns the ident
// token index, or -1. (Distinct from a fn body `{`, which follows `)` / `->`.)
pub fn slit_find_ctor(toks: Vec, pos: i64, src: i64, ty_lo: i64, ty_hi: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return 0 - 1;
    }
    if tok_kind(toks, pos) == tk_ident() {
        if tok_kind(toks, pos + 1) == tk_lbrace() {
            if span_bytes_equal(src, tok_lo(toks, pos), tok_hi(toks, pos), ty_lo, ty_hi) == 1 {
                // Three `T {` occurrences exist: the struct DEFINITION
                // (`struct T {`, prev tok = the `struct` ident), the RETURN
                // TYPE (`-> T {`, prev tok = `->`), and the actual struct
                // LITERAL. Skip the first two so only the ctor qualifies.
                let prev_ok: i64 = if pos == 0 {
                    1
                } else {
                    if tok_kind(toks, pos - 1) == tk_arrow() {
                        0
                    } else {
                        if is_struct_kw(src, tok_lo(toks, pos - 1), tok_hi(toks, pos - 1)) == 1 {
                            0
                        } else {
                            1
                        }
                    }
                };
                if prev_ok == 1 {
                    return pos;
                }
            }
        }
    }
    slit_find_ctor(toks, pos + 1, src, ty_lo, ty_hi)
}

// Locate, among the parsed struct-lit's SOURCE-ORDER triples (each 3xi64 at
// fields_addr: name_lo, name_hi, value_node), the value-node for the field whose
// name span equals buf[dlo..dhi) (the k-th DECLARED field). Returns the
// value-node AST address, or 0 if absent.
pub fn slit_value_for(fields_addr: i64, ntriples: i64, src: i64, dlo: i64, dhi: i64, i: i64) -> i64 {
    if i >= ntriples {
        return 0;
    }
    let nlo: i64 = __mind_load_i64(fields_addr + (i * 3) * 8);
    let nhi: i64 = __mind_load_i64(fields_addr + (i * 3 + 1) * 8);
    if span_bytes_equal(src, nlo, nhi, dlo, dhi) == 1 {
        return __mind_load_i64(fields_addr + (i * 3 + 2) * 8);
    }
    slit_value_for(fields_addr, ntriples, src, dlo, dhi, i + 1)
}

// Number of body instructions a single field's store contributes. The value is
// now an ARBITRARY expression that lowers to `vcount` non-param instrs (via the
// general tree emitter — count_nonparam_nodes), the byte offset adds CONST+Add
// (2) for idx>0, and the store itself is always 1.
pub fn slit_field_instr_count(vcount: i64, idx: i64) -> i64 {
    let ac: i64 = if idx == 0 {
        0
    } else {
        2
    };
    vcount + ac + 1
}

// Build a params_addr array (one entry per param, the form resolve_param / the
// general tree emitter expect: each entry is a param AST node whose ast_child0 is
// the name leaf) from the ptt span table. Allocated `n_params * 8`, declaration
// order preserved. Lets the struct-lit field VALUES reuse the general emitter
// (flatten_ast/tree_resolve_vids/emit_mic3_tree_body) for arbitrary expressions.
pub fn slit_build_params_addr(ptt: i64, src: i64) -> i64 {
    let n: i64 = ptt_table_count(ptt);
    let arr: i64 = __mind_alloc(n * 8 + 8);
    slit_fill_params_addr(arr, ptt, src, 0);
    arr
}

pub fn slit_fill_params_addr(arr: i64, ptt: i64, src: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0;
    }
    let lo: i64 = ptt_table_name_lo(ptt, k);
    let hi: i64 = ptt_table_name_hi(ptt, k);
    let name_leaf: i64 = ast_new_leaf(ast_ident(), lo, hi);
    let pnode: i64 = ast_new_param(lo, hi, name_leaf, 0);
    __mind_store_i64(arr + k * 8, pnode);
    slit_fill_params_addr(arr, ptt, src, k + 1)
}

// The general-emitter non-param instr count of a field VALUE expression (CONST
// leaves + BINOP + CALL nodes; params contribute 0). Returns -1 on an unsupported
// construct, which the fail-closed shape guard rejects.
pub fn slit_value_count(value_node: i64, src: i64, params_addr: i64, n_params: i64) -> i64 {
    count_nonparam_nodes(value_node, src, params_addr, n_params)
}

// CONTAINED field-access value support (Step B2): a field VALUE of the form
// `recv.field` where `recv` is a PARAM of the SAME struct being constructed (so
// `sft` gives the field offset). Returns the accessed field's INDEX in `sft`
// (offset = idx*8) when the shape qualifies, else -1. The qualification:
//   * value_node is ast_field;
//   * its receiver (child0) is an ident that resolves to a param (resolve_param);
//   * its field name (child1/child2 span) resolves in `sft` (ffa_field_index).
// This special-cases ast_field BEFORE the general flatten_ast path (which rejects
// ast_field), so the struct-type context (`sft`) need not be threaded through the
// general emitter's many call-sites.
pub fn slit_value_fa_idx(value_node: i64, src: i64, params_addr: i64, n_params: i64, sft: i64) -> i64 {
    if ast_kind(value_node) != ast_field() {
        return 0 - 1;
    }
    let recv: i64 = ast_child0(value_node);
    if ast_kind(recv) != ast_ident() {
        return 0 - 1;
    }
    let pv: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(recv), ast_span_hi(recv));
    if pv < 0 {
        return 0 - 1;
    }
    ffa_field_index(sft, src, ast_child1(value_node), ast_child2(value_node), 0)
}

// Non-param instr count of a field VALUE, unifying the general expr path with the
// CONTAINED field-access path. Field-access values do NOT go through the general
// tree emitter (count_nonparam_nodes returns -1 for ast_field); instead a
// field-READ lowers to a single CALL load when the field offset is 0, or
// CONST(off) + Add(base,off) + CALL load (3 instrs) when offset>0 — mirroring
// ffa_emit_body. Any other shape falls through to count_nonparam_nodes.
pub fn slit_value_instr_count(value_node: i64, src: i64, params_addr: i64, n_params: i64, sft: i64) -> i64 {
    let fa: i64 = slit_value_fa_idx(value_node, src, params_addr, n_params, sft);
    if fa >= 0 {
        if fa == 0 {
            return 1;
        }
        return 3;
    }
    count_nonparam_nodes(value_node, src, params_addr, n_params)
}

// Is the value-node an int-literal (1) or the param ident (0)? Fail-closed
// callers already guarantee one of the two. ast_int_lit -> 1, else 0.
pub fn slit_value_is_lit(node: i64) -> i64 {
    if ast_kind(node) == ast_int_lit() {
        return 1;
    }
    0
}

// Resolve a param-ident value node to its param index = its %SSA vid (params
// bind to vids 0..n_params-1, in declaration order). Compares the ident span
// against each ptt param-name span. Returns the param vid, or -1 if not a param
// (a fail-closed caller has already rejected that shape).
pub fn slit_param_vid(ptt: i64, src: i64, node: i64) -> i64 {
    slit_param_vid_loop(ptt, src, ast_span_lo(node), ast_span_hi(node), 0)
}

pub fn slit_param_vid_loop(ptt: i64, src: i64, lo: i64, hi: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0 - 1;
    }
    if span_bytes_equal(src, lo, hi, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k)) == 1 {
        return k;
    }
    slit_param_vid_loop(ptt, src, lo, hi, k + 1)
}

// The field VALUE's root vid (the operand the store consumes). For a CONTAINED
// field-access (fa>=0): offset 0 -> the lone load CALL at `vid`; offset>0 ->
// CONST(vid)+Add(vid+1)+load(vid+2), so the load dst is `vid+2`. For any other
// value (fa<0): flatten it through the general tree emitter, which returns its
// root vid and populates `nodes`/`cursor` for the subsequent slit_emit_value.
pub fn slit_value_val_vid(value_node: i64, src: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, fa: i64, vid: i64) -> i64 {
    if fa >= 0 {
        if fa == 0 {
            return vid;
        }
        return vid + 2;
    }
    flatten_branch(value_node, src, params_addr, n_params, nodes, cursor, vidbuf, vid)
}

// Emit the field VALUE's body instrs. CONTAINED field-access (fa>=0) lowers a
// field-READ: load(base) directly for offset 0, else CONST(off)+Add(base,off)+
// load(addr) — `base` is the receiver param's vid, `i_load` the interned
// `__mind_load_i64` string index. Any other value (fa<0) emits the general tree
// body already flattened into `nodes` by slit_value_val_vid (n_nodes via cursor).
pub fn slit_emit_value(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, fa: i64, value_node: i64, vid: i64) -> EmitState {
    if fa >= 0 {
        let recv: i64 = ast_child0(value_node);
        let base_vid: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(recv), ast_span_hi(recv));
        if fa == 0 {
            return emit_mic3_call1(s, vid, i_load, base_vid);
        }
        let sa: EmitState = emit_mic3_const_i64(s, vid, fa * 8);
        let sb: EmitState = emit_mic3_binop(sa, vid + 1, 0, base_vid, vid);
        return emit_mic3_call1(sb, vid + 2, i_load, vid + 1);
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, src, strbuf, offs, strc, 0)
}

// Emit one field's store. `ptr_vid` is the alloc base. `vid` is the next free
// vid. The field VALUE is an ARBITRARY expression, lowered via the GENERAL tree
// emitter (flatten_branch resolves its slot vids from `vid`, returning the root
// vid; emit_mic3_tree_body emits its non-param instrs). The value's instrs come
// FIRST and consume vids, THEN the address (direct ptr for idx 0; CONST(idx*8)+Add
// for idx>0) threads from the vid past the value, THEN the store CALL — matching
// the --emit-mic3 oracle's per-field interleaving (Bound by MIND-CONSTITUTION §I).
pub fn slit_emit_field(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, ptr_vid: i64, i_store: i64, value_node: i64, idx: i64, vid: i64) -> EmitState {
    // value: lower the field-value expression to its result vid + its body instrs.
    // CONTAINED field-access (recv.field, recv a param of THIS struct) is special-
    // cased here (the general tree emitter rejects ast_field): it emits a field-READ
    // load (CALL load(base) for offset 0; CONST+Add+CALL load for offset>0), with
    // the receiver param vid as the base. Any other value goes through the general
    // tree emitter (flatten_branch + emit_mic3_tree_body).
    let fa: i64 = slit_value_fa_idx(value_node, src, params_addr, n_params, sft);
    let val_vid: i64 = slit_value_val_vid(value_node, src, params_addr, n_params, nodes, cursor, vidbuf, sft, fa, vid);
    let vcount: i64 = slit_value_instr_count(value_node, src, params_addr, n_params, sft);
    let s1: EmitState = slit_emit_value(s, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fa, value_node, vid);
    let vid1: i64 = vid + vcount;
    // address
    let addr_vid: i64 = if idx == 0 {
        ptr_vid
    } else {
        vid1 + 1
    };
    let s2: EmitState = if idx == 0 {
        s1
    } else {
        emit_mic3_const_i64(s1, vid1, idx * 8)
    };
    let s3: EmitState = if idx == 0 {
        s2
    } else {
        emit_mic3_binop(s2, vid1 + 1, 0, ptr_vid, vid1)
    };
    let vid2: i64 = if idx == 0 {
        vid1
    } else {
        vid1 + 2
    };
    // store
    emit_mic3_call2(s3, vid2, i_store, addr_vid, val_vid)
}

// Recursively emit every field's store in DECLARED order, threading the running
// vid. `sft` gives the declared field names/order; `fields_addr`/`ntriples` the
// source-order initializer triples. Returns the EmitState after all stores.
pub fn slit_emit_fields(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, sft: i64, i_load: i64, fields_addr: i64, ntriples: i64, ptr_vid: i64, i_store: i64, k: i64, vid: i64) -> EmitState {
    if k >= sft_table_count(sft) {
        return s;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_value_instr_count(vnode, src, params_addr, n_params, sft);
    let s1: EmitState = slit_emit_field(s, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, ptr_vid, i_store, vnode, k, vid);
    let next_vid: i64 = vid + slit_field_instr_count(vcount, k);
    slit_emit_fields(s1, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, k + 1, next_vid)
}

// Total FN_DEF body length contributed by the per-field stores. The fixed
// prologue (n_params PARAMs + CONST elem + CONST n + Mul + alloc) is added by the
// caller; this returns only the store contribution.
pub fn slit_body_len(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64, acc: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return acc;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_value_instr_count(vnode, src, params_addr, n_params, sft);
    slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1, acc + slit_field_instr_count(vcount, k))
}

// Does ANY declared field's value lower to a field-READ (CONTAINED ast_field)?
// If so the body emits `__mind_load_i64` and its name must be interned (first-seen,
// between __mind_alloc and __mind_store_i64). Returns 1 if any, else 0.
pub fn slit_any_field_access(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 0;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if slit_value_fa_idx(vnode, src, params_addr, n_params, sft) >= 0 {
        return 1;
    }
    slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1)
}

// Locate the top-level fn_def whose body is a single statement that is a struct
// literal (`T { .. }`) — the constructor fn — among the parsed items. Returns the
// fn AST node, or 0 if none. Walks items in declaration order so the FIRST such fn
// wins (the supported module shape has exactly one).
pub fn slit_find_ctor_fn(items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let body: i64 = ast_child2(item);
        let stmts_addr: i64 = ast_child0(body);
        let stmts_len: i64 = ast_aux(body);
        if stmts_len == 1 {
            let expr: i64 = __mind_load_i64(stmts_addr + 0);
            if ast_kind(expr) == ast_struct_lit() {
                return item;
            }
        }
    }
    slit_find_ctor_fn(items_addr, items_len, i + 1)
}

// Emit the struct-literal constructor fn's FN_DEF (header + alloc/store body) using
// MODULE-WIDE string indices. Unlike the single-fn path (slit_emit_param_pairs /
// slit_emit_param_instrs, which hardcode the param string idx as 1+k), the param
// string indices come from the module-wide union table (resolved via
// module_param_str_idxs), so a ctor fn declared after helper fns binds its params to
// their actual interned slots. The body spine (PARAM* + CONST elem + CONST nfields +
// Mul + alloc, then per-field stores) is IDENTICAL to the single-fn path; field
// VALUES (incl. CALLs to helper fns) lower through the general tree emitter, whose
// call-name resolution hits the module union table. Byte-exact vs --emit-mic3.
pub fn slit_emit_ctor_fndef(s: EmitState, src: i64, strbuf: i64, offs: i64, strc: i64, fn_node: i64, i_fn: i64, pstr: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_load: i64, i_store: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    let ptr_vid: i64 = n_params + 3;
    let prologue_len: i64 = n_params + 4;
    let body_len: i64 = prologue_len + slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, 0, 0);
    // FN_DEF header: name || param-pairs(module idx) || ret %ptr_vid || None || body_len.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, i_fn);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, ptr_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    // Body prologue: PARAM %0..%(n-1) (module idx), CONST 8, CONST n_fields, Mul, alloc.
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_const_i64(s7, n_params, 8);
    let s9: EmitState = emit_mic3_const_i64(s8, n_params + 1, n_fields);
    let s10: EmitState = emit_mic3_binop(s9, n_params + 2, 2, n_params, n_params + 1);
    let s11: EmitState = emit_mic3_call1(s10, ptr_vid, i_alloc, n_params + 2);
    // Per-field stores (declared order); field VALUES via the general tree emitter.
    slit_emit_fields(s11, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1)
}

// ITEM-ORDER multi-fn module driver for a single-struct module that contains the
// struct-literal constructor fn PLUS one or more helper fns (e.g. a call-valued
// field `T { v: id(a) }` where `id` is a sibling fn). The module is assembled in
// SOURCE-ITEM order, threading a flat scaffold counter k:
//   * helper fn item  -> emit_mic3_module_fndef(...) + scaffold(k)
//   * struct item     -> scaffold(k) only
//   * ctor fn item    -> slit_emit_ctor_fndef(...) + scaffold(k)
// with next_id = n_fns + n_structs and instr_count = 2*(n_fns+n_structs) + n_fns.
// The module string table is the union (build_module_strtab in item order: every
// fn name + params + body call-names) THEN the ctor body intrinsics (__mind_alloc,
// optional __mind_load_i64, __mind_store_i64) and the struct type + field names —
// exactly the first-seen order the Rust oracle interns. Fail-closed (seed `s`) on
// any helper fn outside emit_mic3_module_fndef's proven shapes or any unsupported
// field value. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_mic3_module_structlit_nfn(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let sft: i64 = sft_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let n_fns: i64 = count_fn_defs(items_addr, items_len, 0, 0);
    let n_structs: i64 = srt_count(srt);
    // Only a single struct is supported here; the registry tail emits one struct_def.
    if n_structs != 1 {
        return s;
    }
    if sft_table_count(sft) < 1 {
        return s;
    }
    // The constructor fn (body = one struct-literal). Its own params drive the spine.
    let ctor_fn: i64 = slit_find_ctor_fn(items_addr, items_len, 0);
    if ctor_fn == 0 {
        return s;
    }
    let n_params: i64 = ast_aux(ctor_fn) / 2;
    let params_addr: i64 = ast_child1(ctor_fn);
    // Recover the struct-literal field triples (source order) from the ctor body.
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    // Struct type name (the constructed type / return type) from the registry.
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Every declared field's value must lower through the general tree emitter (ident /
    // literal / arithmetic / call) or be a contained field-access. Fail-closed else.
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // String table — UNION first (every fn name + params + body call-names, item
    // order), THEN the ctor body intrinsics + struct type + field names (first-seen).
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let _u: i64 = build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, 0);
    let ncount: i64 = __mind_load_i64(ccell);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_load: i64 = if slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, 0) == 1 {
        intern_load_i64_name(strbuf, offs, ccell)
    } else {
        0 - 1
    };
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    let strc: i64 = __mind_load_i64(ccell);
    // Resolve the ctor fn's param string indices against the union table.
    let pstr: i64 = __mind_alloc(n_params * 8 + 8);
    let pres: i64 = module_param_str_idxs(src, ctor_fn, strbuf, offs, ncount, pstr, 0);
    if pres != 1 {
        return s;
    }
    let i_fn: i64 = fn_name_idx(src, ctor_fn, strbuf, offs, ncount);
    if i_fn < 0 {
        return s;
    }
    // Per-field scratch for the general tree emitter (field VALUES).
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    // header || strtab || next_id(=n_fns+n_structs) || exports(0) ||
    //   instr_count(=2*(n_fns+n_structs)+n_fns).
    let n_items: i64 = n_fns + n_structs;
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, n_items);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, n_items + n_items + n_fns);
    // Per-item FN_DEF/scaffold loop, threaded through one ok_cell.
    let ok_cell: i64 = __mind_alloc(8);
    __mind_store_i64(ok_cell, 1);
    let s6: EmitState = slit_emit_items_loop(s5, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, 0, 0);
    if __mind_load_i64(ok_cell) == 0 {
        return s;
    }
    // Registry: one struct (ty=[field0..fieldN-1]) || const_array_defs=0 || repr_c=0.
    let s7: EmitState = emit_uleb128(s6, 1);
    let s8: EmitState = emit_uleb128(s7, i_ty);
    let s9: EmitState = emit_uleb128(s8, n_fields);
    let s10: EmitState = ffa_emit_field_idxs_interned(s9, strbuf, offs, ccell, src, sft, 0);
    let s11: EmitState = emit_uleb128(s10, 0);
    emit_uleb128(s11, 0)
}

pub fn dbg_structlit_nfn_stage(src: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let sft: i64 = sft_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let n_structs: i64 = srt_count(srt);
    if n_structs != 1 {
        return 1;
    }
    if sft_table_count(sft) < 1 {
        return 2;
    }
    let ctor_fn: i64 = slit_find_ctor_fn(items_addr, items_len, 0);
    if ctor_fn == 0 {
        return 3;
    }
    let n_params: i64 = ast_aux(ctor_fn) / 2;
    let params_addr: i64 = ast_child1(ctor_fn);
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let snode: i64 = __mind_load_i64(stmts_addr + 0);
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return 4;
    }
    n_params * 1000 + ntriples
}

pub fn dbg_item_kind(src: i64, src_len: i64, idx: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    if idx < 0 {
        return items_len;
    }
    if idx >= items_len {
        return 0 - 99;
    }
    ast_kind(__mind_load_i64(items_addr + idx * 8))
}

pub fn dbg_structlit_items(src: i64, src_len: i64) -> i64 {
    let tokens: Vec = lex(src, src_len);
    let ast_root: i64 = parse(tokens, src);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    dbg_structlit_items_loop(items_addr, items_len, 0, 0)
}
pub fn dbg_structlit_items_loop(items_addr: i64, items_len: i64, i: i64, acc: i64) -> i64 {
    if i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let kind: i64 = ast_kind(item);
    // encode per-item: kind in low digits, for fn_def add body shape info
    let info: i64 = if kind == ast_fn_def() {
        let body: i64 = ast_child2(item);
        let stmts_len: i64 = ast_aux(body);
        let stmts_addr: i64 = ast_child0(body);
        let ek: i64 = if stmts_len >= 1 {
            ast_kind(__mind_load_i64(stmts_addr + 0))
        } else {
            0 - 1
        };
        90000 + stmts_len * 100 + ek
    } else {
        kind
    };
    dbg_structlit_items_loop(items_addr, items_len, i + 1, acc * 100000 + info)
}

// Walk the items in source order emitting each item's instrs and the flat scaffold
// counter k. `k`/`item_i` advance in lockstep: k is the per-item scaffold vid (=
// item index counting BOTH fns and structs), item_i walks the raw item array.
pub fn slit_emit_items_loop(s: EmitState, src: i64, items_addr: i64, items_len: i64, strbuf: i64, offs: i64, ncount: i64, strc: i64, ctor_fn: i64, i_fn: i64, pstr: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_load: i64, i_store: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64, k: i64, item_i: i64) -> EmitState {
    if item_i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + item_i * 8);
    // Struct definition: scaffold only.
    if ast_kind(item) != ast_fn_def() {
        let ss: EmitState = emit_mic3_scaffold(s, k);
        return slit_emit_items_loop(ss, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1);
    }
    // The constructor fn: alloc/store spine.
    if item == ctor_fn {
        let sc: EmitState = slit_emit_ctor_fndef(s, src, strbuf, offs, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf);
        let sc2: EmitState = emit_mic3_scaffold(sc, k);
        return slit_emit_items_loop(sc2, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1);
    }
    // A helper fn: one of emit_mic3_module_fndef's proven body shapes.
    let sh: EmitState = emit_mic3_module_fndef(s, src, item, strbuf, offs, ncount, ok_cell);
    if __mind_load_i64(ok_cell) == 0 {
        return sh;
    }
    let sh2: EmitState = emit_mic3_scaffold(sh, k);
    slit_emit_items_loop(sh2, src, items_addr, items_len, strbuf, offs, ncount, strc, ctor_fn, i_fn, pstr, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_load, i_store, nodes, cursor, vidbuf, ok_cell, k + 1, item_i + 1)
}

// ===========================================================================
// Step C — LET-CHAIN struct-literal constructor bodies.
//
// A ctor fn body `{ let n0 = E0; ...; T { f0: v0, ... } }` lowers BYTE-IDENTICAL
// to the same shape as a no-let ctor, with the let inits emitted FIRST (each let
// name SSA-aliases its init's root vid), THEN the alloc/store spine shifted past
// the let body instrs. A field value that names a let resolves to that let's vid
// (no instr, no string); a field value that names a param resolves to the param
// vid; an int-literal field value emits ONE CONST. Reuses the proven let-chain
// flatten (flatten_let_chain / flatten_expr_env / the slot->vid resolution) for
// the let prefix and the alloc/store spine of the no-let path for the body.
// Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I); fail-closed (returns
// seed `s`) on any field value that is not a param-ident / let-ref / int-literal.
// ===========================================================================

// Rewrite each let-env record's stored descriptor slot into its RESOLVED vid
// (read from `vidbuf` after the let prefix's tree_resolve_vids_base). After this
// the let-env maps a let name-span directly to the SSA vid its init produced, so
// a field-value let-ref resolves with no descriptor lookup. Tail-recursive.
pub fn slit_letenv_slot_to_vid(env: i64, nlets: i64, vidbuf: i64, i: i64) -> i64 {
    if i >= nlets {
        return 0;
    }
    let slot: i64 = __mind_load_i64(env + i * 24 + 16);
    __mind_store_i64(env + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    slit_letenv_slot_to_vid(env, nlets, vidbuf, i + 1)
}

// Field VALUE classification for the let-aware ctor body. Returns:
//   1  -> int-literal (emits one CONST, consumes one vid)
//   0  -> param-ident OR let-ref-ident (emits nothing, reuses an existing vid)
//  -1  -> any other shape (fail-closed; arith-over-let / call / field-access are
//         NOT yet supported on the let-chain path — reported as remaining work).
pub fn slit_letaware_value_kind(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64) -> i64 {
    let k: i64 = ast_kind(vnode);
    if k == ast_paren() {
        return slit_letaware_value_kind(ast_child0(vnode), src, params_addr, n_params, env, nlets);
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_ident() {
        let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(vnode), ast_span_hi(vnode));
        if pidx >= 0 {
            return 0;
        }
        // env records now hold VIDs (slit_letenv_slot_to_vid); a hit means let-ref.
        let lvid: i64 = letenv_lookup(src, ast_span_lo(vnode), ast_span_hi(vnode), env, nlets, 0);
        if lvid >= 0 {
            return 0;
        }
        return 0 - 1;
    }
    0 - 1
}

// The non-spine instr count contributed by ONE let-aware field value: int-literal
// = 1 (one CONST), param/let-ref ident = 0. Caller guarantees a supported shape.
pub fn slit_letaware_value_count(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64) -> i64 {
    let kind: i64 = slit_letaware_value_kind(vnode, src, params_addr, n_params, env, nlets);
    if kind == 1 {
        return 1;
    }
    0
}

// The result vid a let-aware field VALUE produces. For a param-ident: the param
// vid (= its declaration index). For a let-ref ident: the let's resolved vid (the
// env now stores vids). For an int-literal: the freshly-emitted CONST's vid =
// `vid` (the next free vid). Caller guarantees the shape (kind != -1).
pub fn slit_letaware_value_vid(vnode: i64, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, vid: i64) -> i64 {
    let k: i64 = ast_kind(vnode);
    if k == ast_paren() {
        return slit_letaware_value_vid(ast_child0(vnode), src, params_addr, n_params, env, nlets, vid);
    }
    if k == ast_int_lit() {
        return vid;
    }
    let pidx: i64 = resolve_param(params_addr, n_params, src, ast_span_lo(vnode), ast_span_hi(vnode));
    if pidx >= 0 {
        return pidx;
    }
    letenv_lookup(src, ast_span_lo(vnode), ast_span_hi(vnode), env, nlets, 0)
}

// Emit the let-aware field VALUE's instrs: an int-literal emits ONE CONST at
// `vid`; a param/let-ref ident emits nothing (its vid already exists). Returns
// the post-emit EmitState.
pub fn slit_emit_letaware_value(s: EmitState, vnode: i64, src: i64, vid: i64) -> EmitState {
    let v: i64 = if ast_kind(vnode) == ast_paren() {
        ast_child0(vnode)
    } else {
        vnode
    };
    if ast_kind(v) == ast_int_lit() {
        let lit: i64 = parse_int_span(src, ast_span_lo(v), ast_span_hi(v), 0);
        return emit_mic3_const_i64(s, vid, lit);
    }
    s
}

// Emit ONE field's store for the let-aware ctor body. The VALUE comes FIRST (a
// CONST for a literal, nothing for an ident), THEN the address (direct ptr for
// idx 0; CONST(idx*8)+Add(ptr,off) for idx>0), THEN the store CALL — matching the
// no-let path's per-field interleaving and the --emit-mic3 oracle.
pub fn slit_emit_letaware_field(s: EmitState, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, ptr_vid: i64, i_store: i64, vnode: i64, idx: i64, vid: i64) -> EmitState {
    let val_vid: i64 = slit_letaware_value_vid(vnode, src, params_addr, n_params, env, nlets, vid);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    let s1: EmitState = slit_emit_letaware_value(s, vnode, src, vid);
    let vid1: i64 = vid + vcount;
    let addr_vid: i64 = if idx == 0 {
        ptr_vid
    } else {
        vid1 + 1
    };
    let s2: EmitState = if idx == 0 {
        s1
    } else {
        emit_mic3_const_i64(s1, vid1, idx * 8)
    };
    let s3: EmitState = if idx == 0 {
        s2
    } else {
        emit_mic3_binop(s2, vid1 + 1, 0, ptr_vid, vid1)
    };
    let vid2: i64 = if idx == 0 {
        vid1
    } else {
        vid1 + 2
    };
    emit_mic3_call2(s3, vid2, i_store, addr_vid, val_vid)
}

// Recursively emit every declared field's store (DECLARED order) for the let-aware
// ctor body, threading the running vid. Mirrors slit_emit_fields but resolves
// field values against params AND the let-env.
pub fn slit_emit_letaware_fields(s: EmitState, src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, ptr_vid: i64, i_store: i64, k: i64, vid: i64) -> EmitState {
    if k >= sft_table_count(sft) {
        return s;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    let s1: EmitState = slit_emit_letaware_field(s, src, params_addr, n_params, env, nlets, ptr_vid, i_store, vnode, k, vid);
    let next_vid: i64 = vid + slit_field_instr_count(vcount, k);
    slit_emit_letaware_fields(s1, src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, ptr_vid, i_store, k + 1, next_vid)
}

// Body length contributed by the per-field stores in the let-aware ctor body.
pub fn slit_letaware_body_len(src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64, acc: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return acc;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    let vcount: i64 = slit_letaware_value_count(vnode, src, params_addr, n_params, env, nlets);
    slit_letaware_body_len(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, k + 1, acc + slit_field_instr_count(vcount, k))
}

// Shape guard: every DECLARED field has a let-aware-resolvable value (param-ident /
// let-ref / int-literal). 1 if all OK, 0 (fail-closed) otherwise.
pub fn slit_letaware_fields_ok(src: i64, params_addr: i64, n_params: i64, env: i64, nlets: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 1;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if vnode == 0 {
        return 0;
    }
    if slit_letaware_value_kind(vnode, src, params_addr, n_params, env, nlets) < 0 {
        return 0;
    }
    slit_letaware_fields_ok(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, k + 1)
}

// Locate the single fn_def item in the parsed module (the ctor fn). Returns the
// fn AST node or 0. Used by the let-aware from_ast path to recover the ctor body's
// let statements (the token-based slit_find_ctor finds only the `T {` literal).
pub fn slit_single_fn_def(items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        return item;
    }
    slit_single_fn_def(items_addr, items_len, i + 1)
}

// Emit the let-chain ctor fn's FN_DEF (single-fn from_ast path). `n_nodes_letp` is
// the number of descriptor slots the let prefix flattened into `nodes`, already
// vid-resolved in `vidbuf` (base n_params); `env`/`nlets` the let-env with records
// REWRITTEN to vids (slit_letenv_slot_to_vid). The body:
//   PARAM %0..%(n-1) || <let prefix body instrs> || CONST 8 || CONST n_fields ||
//   Mul || alloc(ptr) || per-field stores.
pub fn slit_emit_letchain_ctor_fndef(s: EmitState, src: i64, i_fn: i64, n_params: i64, params_addr: i64, sft: i64, n_fields: i64, fields_addr: i64, ntriples: i64, i_alloc: i64, i_store: i64, nodes: i64, n_nodes_letp: i64, vidbuf: i64, let_nonparam: i64, env: i64, nlets: i64) -> EmitState {
    let let_base: i64 = n_params + let_nonparam;
    let ptr_vid: i64 = let_base + 3;
    let body_len: i64 = n_params + let_nonparam + 4 + slit_letaware_body_len(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, 0, 0);
    // FN_DEF header: name || (string 1+k, vid k) pairs || ret %ptr_vid || None || len.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, i_fn);
    let s3: EmitState = emit_uleb128(s2, n_params);
    let s4: EmitState = slit_emit_param_pairs(s3, n_params, 0);
    let s5: EmitState = emit_mic3_opt_vid(s4, 1, ptr_vid);
    let s6: EmitState = es_push(s5, 0);
    let s7: EmitState = emit_uleb128(s6, body_len);
    // Body: PARAMs, then the let-prefix body instrs (tree_body over the let slots).
    let s8: EmitState = slit_emit_param_instrs(s7, n_params, 0);
    let s9: EmitState = emit_mic3_tree_body(s8, nodes, n_nodes_letp, vidbuf, src, 0, 0, 0, 0);
    // Spine: CONST 8, CONST n_fields, Mul, alloc -> ptr (shifted past the let body).
    let s10: EmitState = emit_mic3_const_i64(s9, let_base, 8);
    let s11: EmitState = emit_mic3_const_i64(s10, let_base + 1, n_fields);
    let s12: EmitState = emit_mic3_binop(s11, let_base + 2, 2, let_base, let_base + 1);
    let s13: EmitState = emit_mic3_call1(s12, ptr_vid, i_alloc, let_base + 2);
    // Per-field stores (declared order); values resolve vs params + let-env.
    slit_emit_letaware_fields(s13, src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1)
}

// AST-driven mic@3 module for a single-struct, single-fn ctor whose body is a
// LET CHAIN followed by ONE struct-literal return. Fail-closed (returns seed `s`)
// on any shape this path does not cover (so the no-let path keeps its bytes).
pub fn emit_mic3_module_structlit_letchain_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, ctor_fn: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) < 1 {
        return s;
    }
    if srt_count(srt) != 1 {
        return s;
    }
    let n_params: i64 = ptt_table_count(ptt);
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Locate the `T { .. }` construction (token scan) and recover its field triples.
    let ctor: i64 = slit_find_ctor(tokens, 0, src, ty_lo, ty_hi);
    if ctor < 0 {
        return s;
    }
    let slit: ParseResult = parse_struct_lit(tokens, ctor, src);
    let snode: i64 = pr_node(slit);
    if ast_kind(snode) != ast_struct_lit() {
        return s;
    }
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    let params_addr: i64 = slit_build_params_addr(ptt, src);
    // Recover the ctor body's leading let statements (all stmts but the last).
    let body: i64 = ast_child2(ctor_fn);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len < 2 {
        return s;
    }
    // Flatten the let prefix into a fresh descriptor + let-env.
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    let env: i64 = __mind_alloc(64 * 24);
    let nlets_cell: i64 = __mind_alloc(8);
    __mind_store_i64(cursor, 0);
    __mind_store_i64(nlets_cell, 0);
    let chain_ok: i64 = flatten_let_chain(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, 0);
    if chain_ok == 0 {
        return s;
    }
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let n_nodes_letp: i64 = __mind_load_i64(cursor);
    let let_nonparam: i64 = count_descriptor_nonparam(nodes, n_nodes_letp, 0);
    // Resolve the let-prefix slot vids (non-param base = n_params), then rewrite the
    // let-env to hold vids so field-value let-refs resolve directly.
    let _rv: i64 = tree_resolve_vids_base(nodes, n_nodes_letp, vidbuf, 0, n_params);
    let _ev: i64 = slit_letenv_slot_to_vid(env, nlets, vidbuf, 0);
    // Every declared field must be a let-aware-resolvable value (param/let-ref/lit).
    if slit_letaware_fields_ok(src, params_addr, n_params, env, nlets, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // The fn name: token right before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // String table — first-seen: fn name (0), params (1..1+n), __mind_alloc,
    // __mind_store_i64, type name, then each field name. (No field-access here, so
    // __mind_load_i64 is never interned — keeping strtab identical to the no-let
    // path for the same struct/field/param names.)
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let _ip: i64 = slit_intern_params(strbuf, offs, ccell, src, ptt, 0);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    let strc: i64 = __mind_load_i64(ccell);
    // Module: header || strtab || next_id(2) || exports(0) || 5 instrs:
    //   CONST %0 / OUTPUT %0  (struct scaffold)
    //   FN_DEF ctor { let prefix + alloc/store body }
    //   CONST %1 / OUTPUT %1  (fn scaffold)
    // || struct_defs[ ty=[fields] ] || const_array_defs=0 || repr_c_structs=0.
    let h1: EmitState = emit_mic3_header(s);
    let h2: EmitState = emit_mic3_strtab(h1, strbuf, offs, strc);
    let h3: EmitState = emit_uleb128(h2, 2);
    let h4: EmitState = emit_uleb128(h3, 0);
    let h5: EmitState = emit_uleb128(h4, 5);
    let h6: EmitState = emit_mic3_const_i64(h5, 0, 0);
    let h7: EmitState = emit_mic3_output(h6, 0);
    let h8: EmitState = slit_emit_letchain_ctor_fndef(h7, src, i_fn, n_params, params_addr, sft, n_fields, fields_addr, ntriples, i_alloc, i_store, nodes, n_nodes_letp, vidbuf, let_nonparam, env, nlets);
    let h9: EmitState = emit_mic3_const_i64(h8, 1, 0);
    let h10: EmitState = emit_mic3_output(h9, 1);
    let h11: EmitState = emit_uleb128(h10, 1);
    let h12: EmitState = emit_uleb128(h11, i_ty);
    let h13: EmitState = emit_uleb128(h12, n_fields);
    let h14: EmitState = ffa_emit_field_idxs_interned(h13, strbuf, offs, ccell, src, sft, 0);
    let h15: EmitState = emit_uleb128(h14, 0);
    emit_uleb128(h15, 0)
}

// AST-driven mic@3 module for a single-struct, single-param fn returning ONE
// struct-literal. Fail-closed (returns seed `s`) on any other shape.
pub fn emit_mic3_module_structlit_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    // Multi-item modules (a ctor fn PLUS sibling helper fns, or >1 struct) route to
    // the item-order multi-fn assembler. The single-fn / single-struct path below
    // stays byte-identical for the 12 existing cases (its narrower shape guards keep
    // those exact bytes). The dispatch fires only when extra fns are present.
    let _mtokens: Vec = lex(src, src_len);
    let mroot: i64 = parse(_mtokens, src);
    let mitems_addr: i64 = ast_child0(mroot);
    let mitems_len: i64 = ast_aux(mroot);
    if count_fn_defs(mitems_addr, mitems_len, 0, 0) > 1 {
        return emit_mic3_module_structlit_nfn(s, src, src_len, strbuf, offs, ccell);
    }
    // Single-fn LET-CHAIN ctor body (`{ let .. ; T { .. } }`): route to the
    // let-aware driver. The no-let single-stmt path below is untouched for the
    // 14 existing cases (it sees stmts_len == 1 and falls through).
    let only_fn: i64 = slit_single_fn_def(mitems_addr, mitems_len, 0);
    if only_fn != 0 {
        let ofbody: i64 = ast_child2(only_fn);
        if ast_aux(ofbody) >= 2 {
            return emit_mic3_module_structlit_letchain_from_ast(s, src, src_len, strbuf, offs, ccell, only_fn);
        }
    }
    // Shape guards: exactly one struct (>=1 field) and at least one fn param.
    if sft_table_count(sft) < 1 {
        return s;
    }
    if ptt_table_count(ptt) < 1 {
        return s;
    }
    let n_params: i64 = ptt_table_count(ptt);
    // The struct type name is the CONSTRUCTED struct's own name (the ctor /
    // return type), NOT the param type — for `mk(a: i64) -> Point` the param is
    // i64 while the literal builds a Point. Take it from the struct registry.
    let ty_lo: i64 = srt_name_lo(srt, 0);
    let ty_hi: i64 = srt_name_hi(srt, 0);
    // Locate the `T { .. }` construction.
    let ctor: i64 = slit_find_ctor(tokens, 0, src, ty_lo, ty_hi);
    if ctor < 0 {
        return s;
    }
    // Parse the struct-literal to recover its source-order field triples.
    let slit: ParseResult = parse_struct_lit(tokens, ctor, src);
    let snode: i64 = pr_node(slit);
    if ast_kind(snode) != ast_struct_lit() {
        return s;
    }
    let fields_addr: i64 = ast_child1(snode);
    let ntriples: i64 = ast_aux(snode);
    let n_fields: i64 = sft_table_count(sft);
    // Param AST-node array for the general tree emitter (resolve_param form), and
    // the per-field scratch descriptor / vid buffers.
    let params_addr: i64 = slit_build_params_addr(ptt, src);
    let nodes: i64 = __mind_alloc(256 * 32);
    let cursor: i64 = __mind_alloc(8);
    let vidbuf: i64 = __mind_alloc(256 * 8);
    // Every declared field must have an initializer the general tree emitter can
    // lower (ident / literal / arithmetic / call). Fail-closed otherwise (missing
    // field or an unsupported construct).
    if slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, 0) != 1 {
        return s;
    }
    // The fn name: token right before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Intern strings FIRST-SEEN: fn name (0), every param name in declaration
    // order (1..1+n_params), __mind_alloc, __mind_store_i64, type name, then every
    // field in declaration order. The alloc/store/type indices shift by n_params.
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let _ip: i64 = slit_intern_params(strbuf, offs, ccell, src, ptt, 0);
    let i_alloc: i64 = intern_alloc_literal(strbuf, offs, ccell);
    let i_load: i64 = if slit_any_field_access(src, params_addr, n_params, sft, fields_addr, ntriples, 0) == 1 {
        intern_load_i64_name(strbuf, offs, ccell)
    } else {
        0 - 1
    };
    let i_store: i64 = intern_store_i64_literal(strbuf, offs, ccell);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, ty_lo, ty_hi);
    let _f: i64 = ffa_intern_fields(strbuf, offs, ccell, src, sft, 0);
    // String count = the ACTUAL number interned (the StringTable de-dups, so a
    // field name that equals a param name does NOT add a slot). Read it from the
    // count cell after all interning rather than assuming a contiguous layout.
    let strc: i64 = __mind_load_i64(ccell);
    // The alloc pointer (= fn ret vid) sits just past the n_params PARAMs plus the
    // CONST-8 / CONST-nfields / Mul / alloc prologue: vid = n_params + 3.
    let ptr_vid: i64 = n_params + 3;
    let prologue_len: i64 = n_params + 4;
    let body_len: i64 = prologue_len + slit_body_len(src, params_addr, n_params, sft, fields_addr, ntriples, 0, 0);
    // Module: header || strtab || next_id(2) || exports(0) || 5 instrs:
    //   CONST %0 / OUTPUT %0  (struct decl scaffold)
    //   FN_DEF f(params){ <body> } ret %(n_params+3)
    //   CONST %1 / OUTPUT %1  (fn scaffold)
    // || struct_defs[ ty=[fields...] ] || const_array_defs=0 || repr_c_structs=0.
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 5);
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF header: name, n_params pairs (string 1+k, vid k), ret = alloc ptr.
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn);
    let s10: EmitState = emit_uleb128(s9, n_params);
    let s11: EmitState = slit_emit_param_pairs(s10, n_params, 0);
    let s13: EmitState = emit_mic3_opt_vid(s11, 1, ptr_vid);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, body_len);
    // Body prologue: PARAM %0..%(n-1), CONST 8, CONST n_fields, Mul, alloc -> ptr.
    let s16: EmitState = slit_emit_param_instrs(s15, n_params, 0);
    let s17: EmitState = emit_mic3_const_i64(s16, n_params, 8);
    let s18: EmitState = emit_mic3_const_i64(s17, n_params + 1, n_fields);
    let s19: EmitState = emit_mic3_binop(s18, n_params + 2, 2, n_params, n_params + 1);
    let s20: EmitState = emit_mic3_call1(s19, ptr_vid, i_alloc, n_params + 2);
    // Per-field stores (declared order), vids start just past the alloc ptr. Field
    // VALUES are lowered by the general tree emitter (arbitrary expressions).
    let s21: EmitState = slit_emit_fields(s20, src, strbuf, offs, strc, params_addr, n_params, nodes, cursor, vidbuf, sft, i_load, fields_addr, ntriples, ptr_vid, i_store, 0, ptr_vid + 1);
    let s22: EmitState = emit_mic3_const_i64(s21, 1, 0);
    let s23: EmitState = emit_mic3_output(s22, 1);
    // Registry: one struct (ty=[field0..fieldN-1]). Each field's string index is
    // its ACTUAL interned index (re-intern is idempotent), so a field aliasing a
    // param name points at the prior slot.
    let s24: EmitState = emit_uleb128(s23, 1);
    let s25: EmitState = emit_uleb128(s24, i_ty);
    let s26: EmitState = emit_uleb128(s25, n_fields);
    let s27: EmitState = ffa_emit_field_idxs_interned(s26, strbuf, offs, ccell, src, sft, 0);
    let s28: EmitState = emit_uleb128(s27, 0);
    emit_uleb128(s28, 0)
}

// Intern every param NAME in declaration order (string indices 1..1+n_params,
// directly after the fn name at 0). Returns 0; the side effect is the interning.
pub fn slit_intern_params(strbuf: i64, offs: i64, ccell: i64, src: i64, ptt: i64, k: i64) -> i64 {
    if k >= ptt_table_count(ptt) {
        return 0;
    }
    let _p: i64 = intern_span(strbuf, offs, ccell, src, ptt_table_name_lo(ptt, k), ptt_table_name_hi(ptt, k));
    slit_intern_params(strbuf, offs, ccell, src, ptt, k + 1)
}

// Emit the FN_DEF header's named-vid pairs (string_idx, vid) for every param:
// param k has string index 1+k and binds vid k. Tail-recursive over k.
pub fn slit_emit_param_pairs(s: EmitState, n_params: i64, k: i64) -> EmitState {
    if k >= n_params {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, 1 + k);
    let s2: EmitState = emit_uleb128(s1, k);
    slit_emit_param_pairs(s2, n_params, k + 1)
}

// Emit the body PARAM instrs: PARAM %k name=(1+k) index=k for every param.
pub fn slit_emit_param_instrs(s: EmitState, n_params: i64, k: i64) -> EmitState {
    if k >= n_params {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, k, 1 + k, k);
    slit_emit_param_instrs(s1, n_params, k + 1)
}

// Verify every DECLARED field has an initializer the GENERAL tree emitter can
// lower (count_nonparam_nodes returns >= 0: ident / int-literal / arithmetic /
// nested call — anything flatten_ast accepts). Fail-closed (0) on a missing field
// or an unsupported construct (field-access / if / struct-lit nesting), so no
// partial bytes are emitted. 1 if all OK.
pub fn slit_fields_ok(src: i64, params_addr: i64, n_params: i64, sft: i64, fields_addr: i64, ntriples: i64, k: i64) -> i64 {
    if k >= sft_table_count(sft) {
        return 1;
    }
    let dlo: i64 = sft_table_name_lo(sft, k);
    let dhi: i64 = sft_table_name_hi(sft, k);
    let vnode: i64 = slit_value_for(fields_addr, ntriples, src, dlo, dhi, 0);
    if vnode == 0 {
        return 0;
    }
    if slit_value_instr_count(vnode, src, params_addr, n_params, sft) < 0 {
        return 0;
    }
    slit_fields_ok(src, params_addr, n_params, sft, fields_addr, ntriples, k + 1)
}

pub fn selftest_mic3_module_structlit_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_module_structlit_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===== mic@3 AST-DRIVEN MULTI-STRUCT field-read load (part 1b wired) =====
//
// Extends the single-struct field read to N structs in declaration order, so a
// receiver declared as the 2nd+ struct resolves its field against the CORRECT
// struct. Reuses SECTION 6b's registry (srt_*): the receiver param's declared
// type name (part 2, ptt) keys srt_find_by_name -> the struct index k; the field
// name resolves within struct k via srt_field_index; the accessed field's string
// index is srt_field_strbase(k) + fidx.
//
// Module shape for N structs + 1 fn (verified vs `mindc --emit-mic3`):
//   * string table (FIRST-SEEN order): fn name, param name, __mind_load_i64, then
//     per struct in declaration order [type name][field0..fieldM-1];
//   * instrs: N module-level CONST/OUTPUT placeholder pairs (one per struct, "a
//     struct decl produces no value"), then the FN_DEF, then ONE more CONST/OUTPUT
//     pair (the fn placeholder). next_id = N + 1, instr_count = 2*(N+1) + 1;
//   * struct_defs registry lists ALL N structs with their field string-idx lists.
// ADDITIVE / canary-isolated (exported only via the selftest below). N==1 is a
// strict subset and reproduces the single-struct oracle byte-for-byte.

// Intern every struct's type name then its fields, in declaration order. Mirrors
// the Rust collect order: type name first, then each field, per struct.
pub fn srt_intern_all(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64) -> i64 {
    if k >= srt_count(t) {
        return 0;
    }
    let _ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(t, k), srt_name_hi(t, k));
    let _f: i64 = srt_intern_fields(strbuf, offs, ccell, src, t, k, 0);
    srt_intern_all(strbuf, offs, ccell, src, t, k + 1)
}

pub fn srt_intern_fields(strbuf: i64, offs: i64, ccell: i64, src: i64, t: i64, k: i64, j: i64) -> i64 {
    if j >= srt_field_count(t, k) {
        return 0;
    }
    let _i: i64 = intern_span(strbuf, offs, ccell, src, srt_field_lo(t, k, j), srt_field_hi(t, k, j));
    srt_intern_fields(strbuf, offs, ccell, src, t, k, j + 1)
}

// Total interned string count = 3 fixed (fn,param,load) + per struct (1 type +
// its fields). Equals 3 + N + sum(field_counts).
pub fn srt_total_strings(t: i64) -> i64 {
    3 + srt_count(t) + srt_cumulative_fields(t, srt_count(t), 0)
}

// Emit the N module-level struct placeholder pairs CONST %k=0 / OUTPUT %k for
// struct indices [k, N). Each struct decl, like a fn def, produces no value.
pub fn srt_emit_struct_placeholders(s: EmitState, n: i64, k: i64) -> EmitState {
    if k >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_const_i64(s, k, 0);
    let s2: EmitState = emit_mic3_output(s1, k);
    srt_emit_struct_placeholders(s2, n, k + 1)
}

// Emit the struct_defs registry for ALL N structs: each entry is
// uleb(type_str_idx) || uleb(field_count) || field string idxs. The field string
// idxs of struct k are srt_field_strbase(k) .. +field_count.
pub fn srt_emit_registry(s: EmitState, t: i64, k: i64) -> EmitState {
    if k >= srt_count(t) {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, srt_type_strbase(t, k));
    let fc: i64 = srt_field_count(t, k);
    let s2: EmitState = emit_uleb128(s1, fc);
    let s3: EmitState = ffa_emit_field_idxs(s2, srt_field_strbase(t, k), fc, 0);
    srt_emit_registry(s3, t, k + 1)
}

// AST-driven mic@3 module for an N-struct, single-param field read at any field
// index, the receiver declared as ANY of the N structs (keyed by type name).
// Returns the seed `s` unchanged on any unexpected shape (fail-closed).
pub fn emit_mic3_field_module_multi(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    let ptt: i64 = ptt_build_table(src, src_len);
    let n_structs: i64 = srt_count(srt);
    // Shape guards: at least one struct and exactly one fn param.
    if n_structs < 1 {
        return s;
    }
    if ptt_table_count(ptt) != 1 {
        return s;
    }
    // Locate `recv.field`.
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 1 {
        return s;
    }
    let recv_lo: i64 = tok_lo(tokens, dot - 1);
    let recv_hi: i64 = tok_hi(tokens, dot - 1);
    let fld_lo: i64 = tok_lo(tokens, dot + 1);
    let fld_hi: i64 = tok_hi(tokens, dot + 1);
    // Confirm the receiver names param 0.
    if span_bytes_equal(src, recv_lo, recv_hi, ptt_table_name_lo(ptt, 0), ptt_table_name_hi(ptt, 0)) != 1 {
        return s;
    }
    // Part 2 -> declared type name of the receiver param.
    let ty_lo: i64 = ptt_table_type_lo(ptt, 0);
    let ty_hi: i64 = ptt_table_type_hi(ptt, 0);
    // Multi-struct key: select the struct whose NAME equals the receiver type.
    let sk: i64 = srt_find_by_name(srt, src, ty_lo, ty_hi, 0);
    if sk < 0 {
        return s;
    }
    // Resolve the accessed field within THAT struct.
    let fidx: i64 = srt_field_index(srt, sk, src, fld_lo, fld_hi, 0);
    if fidx < 0 {
        return s;
    }
    // Fn name = the ident two tokens before the param-list `(`.
    let pstart: i64 = ptt_find_param_list(tokens, 0);
    if pstart < 2 {
        return s;
    }
    let fn_lo: i64 = tok_lo(tokens, pstart - 2);
    let fn_hi: i64 = tok_hi(tokens, pstart - 2);
    // Intern strings in FIRST-SEEN order: fn name, param name, __mind_load_i64,
    // then per struct [type name][fields].
    let i_fn: i64 = intern_span(strbuf, offs, ccell, src, fn_lo, fn_hi);
    let i_recv: i64 = intern_span(strbuf, offs, ccell, src, recv_lo, recv_hi);
    let i_load: i64 = intern_load_i64_literal(strbuf, offs, ccell);
    // Registry strings intern in BTreeMap-sorted (struct-name) order to match the
    // canonical full string table (cutover fold step 3).
    let _all: i64 = srt_intern_all_sorted(strbuf, offs, ccell, src, srt, 0);
    let strc: i64 = srt_total_strings(srt);
    let body_len: i64 = ffa_body_len(fidx);
    let ret_vid: i64 = ffa_ret_vid(fidx);
    // Header || strtab || next_id(N+1) || exports(0) || instr_count(2*(N+1)+1).
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    let s3: EmitState = emit_uleb128(s2, n_structs + 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 2 * (n_structs + 1) + 1);
    // N struct placeholders (CONST %k / OUTPUT %k for k in 0..N).
    let s6: EmitState = srt_emit_struct_placeholders(s5, n_structs, 0);
    // FN_DEF header: name idx, 1 param (recv, vid 0), ret %ret_vid, body_len.
    let s7: EmitState = es_push(s6, 21);
    let s8: EmitState = emit_uleb128(s7, i_fn);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, i_recv);
    let s11: EmitState = emit_uleb128(s10, 0);
    let s12: EmitState = emit_mic3_opt_vid(s11, 1, ret_vid);
    let s13: EmitState = es_push(s12, 0);
    let s14: EmitState = emit_uleb128(s13, body_len);
    let s15: EmitState = emit_mic3_param(s14, 0, i_recv, 0);
    let s16: EmitState = ffa_emit_body(s15, fidx, i_load);
    // The fn's own module-level placeholder pair (vid N).
    let s17: EmitState = emit_mic3_const_i64(s16, n_structs, 0);
    let s18: EmitState = emit_mic3_output(s17, n_structs);
    // Registry: all N structs in BTreeMap-sorted order, sorted-rank strbases.
    let s19: EmitState = emit_uleb128(s18, n_structs);
    let s20: EmitState = srt_emit_registry_sorted(s19, srt, src, 0);
    // const_array_defs = 0, repr_c_structs = 0.
    let s21: EmitState = emit_uleb128(s20, 0);
    emit_uleb128(s21, 0)
}

pub fn selftest_mic3_module_field_multi(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    emit_mic3_field_module_multi(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// SECTION 9b — METHOD-CALL LOWERING -> UFCS CALL mic@3 BYTE-OUTPUT (part 3)
//
// ADDITIVE / canary-isolated (exported only via selftest_mic3_module_method_from_ast
// below); the canary mindc_compile / emit_fn_def / emit_expr_env path is untouched,
// so the fixed point stays byte-identical (Bound by MIND-CONSTITUTION §I).
//
// Emits the COMPLETE mic@3 module for the genuine method-call fixture
//   struct Point { x: i64, y: i64 }
//   pub fn point_dist(p: Point, k: i64) -> i64 { k }
//   pub fn use_it(p: Point) -> i64 { p.dist(7) }
// byte-for-byte vs `mindc --emit-mic3`. The payoff of parts 1+2: the parsed method
// call (mc_parse_first) and the resolved UFCS callee name (part 2) now drive a real
// Instr::Call. The Rust oracle (src/eval/lower.rs MethodCall arm) desugars
// `recv.method(args)` to a plain Call named `{lowercase(ReceiverType)}_{method}`
// with the RECEIVER threaded as the FIRST call arg, the int-literal args following:
//   use_it body: PARAM %0=p ; CONST %1=7 ; CALL %2 = point_dist([%0, %1]) ; ret %2.
// The callee fn (point_dist) returns its `k` param directly: body = the two PARAM
// bindings, ret = the k param vid (no explicit Output in the body).
//
// String table FIRST-SEEN order mirrors Rust collect_strings walking module.instrs
// (src/ir/compact/v3/emit.rs:492-525): for the callee FnDef intern name then each
// param name; for the caller FnDef intern name, its param, then the body CALL's
// callee name (a dedup HIT since `point_dist` already interned at 0); finally the
// struct_defs registry interns the type name then each field. Yields the 7-entry
// table: point_dist(0) p(1) k(2) use_it(3) Point(4) x(5) y(6).
//
// SCOPE (smallest byte-verifiable slice): exactly one struct, one receiver param,
// one method call with N int-literal args lowering to CALL callee([recv,args...]).
// Any other shape returns the seed state unchanged (fail-closed, no partial bytes).

// Emit an N-argument Instr::Call:
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(nargs) || vid(arg0..N-1).
// `args` is a heap array of `nargs` i64 vids. Generalises emit_mic3_call1.
pub fn emit_mic3_calln(s: EmitState, dst: i64, name_idx: i64, args: i64, nargs: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, nargs);
    emit_mic3_calln_args(s4, args, nargs, 0)
}

pub fn emit_mic3_calln_args(s: EmitState, args: i64, nargs: i64, i: i64) -> EmitState {
    if i >= nargs {
        return s;
    }
    let v: i64 = __mind_load_i64(args + i * 8);
    let s1: EmitState = emit_uleb128(s, v);
    emit_mic3_calln_args(s1, args, nargs, i + 1)
}

// Emit one CONST_I64 per int-literal method-call argument, vids starting at
// `vid0`. `argvals` is a heap array of `nargs` i64 literal values. Each arg lowers
// to a CONST whose vid is consumed (in order) as the corresponding CALL arg vid.
pub fn emit_mic3_method_arg_consts(s: EmitState, argvals: i64, nargs: i64, vid0: i64, i: i64) -> EmitState {
    if i >= nargs {
        return s;
    }
    let v: i64 = __mind_load_i64(argvals + i * 8);
    let s1: EmitState = emit_mic3_const_i64(s, vid0 + i, v);
    emit_mic3_method_arg_consts(s1, argvals, nargs, vid0, i + 1)
}

// Collect the int-literal VALUES of the first method call's args into `argvals`
// (a caller-provided heap array of >= nargs i64s); returns nargs, or -1 if there
// is no parseable method call. Re-parses the args at the call's `(` to recover the
// literal spans (the ast_method node retains only the arg COUNT, not the values).
pub fn mc_collect_arg_values(src_addr: i64, src_len: i64, argvals: i64) -> i64 {
    let tokens: Vec = lex(src_addr, src_len);
    let rpos: i64 = mc_find_method_call(tokens, 0);
    if rpos < 0 {
        return 0 - 1;
    }
    let after_open: i64 = rpos + 4;
    if tok_kind(tokens, after_open) == tk_rparen() {
        return 0;
    }
    let args_res: ParseResult = parse_args_rest(tokens, after_open, src_addr, vec_new());
    let args_node: i64 = pr_node(args_res);
    let nargs: i64 = ast_aux(args_node);
    let args_addr: i64 = ast_child0(args_node);
    let _w: i64 = mc_write_arg_values(argvals, src_addr, args_addr, nargs, 0);
    nargs
}

// Walk the parsed arg nodes; for each int-literal write its parsed value into
// `argvals[i]`. (Smallest slice: args are int literals; mirrors the oracle's
// per-arg CONST lowering.) Returns the number written.
pub fn mc_write_arg_values(argvals: i64, src: i64, args_addr: i64, nargs: i64, i: i64) -> i64 {
    if i >= nargs {
        return i;
    }
    let node: i64 = __mind_load_i64(args_addr + i * 8);
    let v: i64 = parse_int_span(src, ast_span_lo(node), ast_span_hi(node), 0);
    __mind_store_i64(argvals + i * 8, v);
    mc_write_arg_values(argvals, src, args_addr, nargs, i + 1)
}

// Assemble the full mic@3 module for the method-call fixture, AST-driven. The
// caller provides scratch buffers: `strbuf`/`offs`/`ccell` (the string-table
// interner), `cbuf` (a >= 64-byte scratch for the synthesized UFCS callee name),
// `argbuf` (a >= 8*nargs scratch for the const arg vids), `valbuf` (>= 8*nargs for
// the literal values). Returns the seed `s` unchanged on any unexpected shape.
pub fn emit_mic3_method_module_from_ast(s: EmitState, src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let srt: i64 = srt_build(src, src_len);
    // Shape guards: exactly one struct; a parseable method call resolving to a
    // known receiver-param type.
    if srt_count(srt) != 1 {
        return s;
    }
    let m: i64 = mc_parse_first(src, src_len);
    if m == 0 {
        return s;
    }
    let callee_len: i64 = selftest_method_callee_name_into(src, src_len, cbuf);
    if callee_len < 0 {
        return s;
    }
    let nargs: i64 = mc_collect_arg_values(src, src_len, valbuf);
    if nargs < 0 {
        return s;
    }
    // Locate the two fns. fn0 = the callee def (parsed first), fn1 = the caller.
    // pstart0/pstart1 = the index just past each fn's `(` (params start).
    let pstart0: i64 = ptt_find_param_list(tokens, 0);
    if pstart0 < 3 {
        return s;
    }
    let fn0_lo: i64 = tok_lo(tokens, pstart0 - 2);
    let fn0_hi: i64 = tok_hi(tokens, pstart0 - 2);
    let pstart1: i64 = ptt_find_param_list(tokens, pstart0);
    if pstart1 < 3 {
        return s;
    }
    let fn1_lo: i64 = tok_lo(tokens, pstart1 - 2);
    let fn1_hi: i64 = tok_hi(tokens, pstart1 - 2);
    // Callee (fn0) params: name0 : Type0 , name1 : Type1 . The two param NAME spans
    // (the callee returns its 2nd param `k`, so we need both names interned and the
    // 2nd as the ret vid).
    let p0a_lo: i64 = tok_lo(tokens, pstart0);
    let p0a_hi: i64 = tok_hi(tokens, pstart0);
    let p0b_lo: i64 = tok_lo(tokens, pstart0 + 4);
    let p0b_hi: i64 = tok_hi(tokens, pstart0 + 4);
    // Caller (fn1) single param name (the receiver).
    let p1_lo: i64 = tok_lo(tokens, pstart1);
    let p1_hi: i64 = tok_hi(tokens, pstart1);
    // Intern strings in FIRST-SEEN order (mirrors collect_strings over module.instrs):
    //   fn0 name, fn0 param0, fn0 param1, fn1 name, fn1 param (dedup), callee (dedup
    //   to fn0 name), then struct type name + each field.
    let i_fn0: i64 = intern_span(strbuf, offs, ccell, src, fn0_lo, fn0_hi);
    let i_p0a: i64 = intern_span(strbuf, offs, ccell, src, p0a_lo, p0a_hi);
    let i_p0b: i64 = intern_span(strbuf, offs, ccell, src, p0b_lo, p0b_hi);
    let i_fn1: i64 = intern_span(strbuf, offs, ccell, src, fn1_lo, fn1_hi);
    let i_p1: i64 = intern_span(strbuf, offs, ccell, src, p1_lo, p1_hi);
    let i_callee: i64 = intern_span(strbuf, offs, ccell, cbuf, 0, callee_len);
    let i_ty: i64 = intern_span(strbuf, offs, ccell, src, srt_name_lo(srt, 0), srt_name_hi(srt, 0));
    let _fld: i64 = srt_intern_fields(strbuf, offs, ccell, src, srt, 0, 0);
    let fc: i64 = srt_field_count(srt, 0);
    let i_f0: i64 = i_ty + 1;
    let strc: i64 = i_ty + 1 + fc;
    // The caller's CALL arg-vid list: receiver param (%0) FIRST, then the const-arg
    // vids %1..%nargs.
    let _r0: i64 = mc_build_call_arg_vids(argbuf, nargs);
    // Header || strtab || next_id(3) || exports(0) || instr_count(8).
    // Flat module-level next_id = one id per top-level item: struct decl -> %0,
    // point_dist -> %1, use_it -> %2, so next_id = 3. instr_count = 8 (3 scaffold
    // CONST/OUTPUT pairs interleaved with the 2 FN_DEFs).
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, strbuf, offs, strc);
    // 3 top-level items (struct + 2 fns), each a module-level CONST/OUTPUT pair.
    let s3: EmitState = emit_uleb128(s2, 3);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 8);
    // struct Point decl -> scaffold CONST %0 / OUTPUT %0.
    let s6: EmitState = emit_mic3_const_i64(s5, 0, 0);
    let s7: EmitState = emit_mic3_output(s6, 0);
    // FN_DEF point_dist(p=%0, k=%1) ret %1, body = PARAM %0 p, PARAM %1 k (body_len 2).
    let s8: EmitState = es_push(s7, 21);
    let s9: EmitState = emit_uleb128(s8, i_fn0);
    let s10: EmitState = emit_uleb128(s9, 2);
    let s11: EmitState = emit_uleb128(s10, i_p0a);
    let s12: EmitState = emit_uleb128(s11, 0);
    let s13: EmitState = emit_uleb128(s12, i_p0b);
    let s14: EmitState = emit_uleb128(s13, 1);
    let s15: EmitState = emit_mic3_opt_vid(s14, 1, 1);
    let s16: EmitState = es_push(s15, 0);
    let s17: EmitState = emit_uleb128(s16, 2);
    let s18: EmitState = emit_mic3_param(s17, 0, i_p0a, 0);
    let s19: EmitState = emit_mic3_param(s18, 1, i_p0b, 1);
    // fn0 module-level scaffold pair CONST %1 / OUTPUT %1.
    let s20: EmitState = emit_mic3_const_i64(s19, 1, 0);
    let s21: EmitState = emit_mic3_output(s20, 1);
    // FN_DEF use_it(p=%0) ret %(1+nargs), body = PARAM %0 p, CONST args, CALL.
    let ret_vid: i64 = 1 + nargs;
    let body_len: i64 = 2 + nargs;
    let s22: EmitState = es_push(s21, 21);
    let s23: EmitState = emit_uleb128(s22, i_fn1);
    let s24: EmitState = emit_uleb128(s23, 1);
    let s25: EmitState = emit_uleb128(s24, i_p1);
    let s26: EmitState = emit_uleb128(s25, 0);
    let s27: EmitState = emit_mic3_opt_vid(s26, 1, ret_vid);
    let s28: EmitState = es_push(s27, 0);
    let s29: EmitState = emit_uleb128(s28, body_len);
    let s30: EmitState = emit_mic3_param(s29, 0, i_p1, 0);
    let s31: EmitState = emit_mic3_method_arg_consts(s30, valbuf, nargs, 1, 0);
    let s32: EmitState = emit_mic3_calln(s31, ret_vid, i_callee, argbuf, nargs + 1);
    // fn1 module-level scaffold pair CONST %2 / OUTPUT %2.
    let s33: EmitState = emit_mic3_const_i64(s32, 2, 0);
    let s34: EmitState = emit_mic3_output(s33, 2);
    // struct_defs registry: Point=[fields], const_array_defs=0, repr_c_structs=0.
    let s35: EmitState = emit_uleb128(s34, 1);
    let s36: EmitState = emit_uleb128(s35, i_ty);
    let s37: EmitState = emit_uleb128(s36, fc);
    let s38: EmitState = ffa_emit_field_idxs(s37, i_f0, fc, 0);
    let s39: EmitState = emit_uleb128(s38, 0);
    emit_uleb128(s39, 0)
}

// Build the CALL arg-vid list for the caller: argbuf[0] = receiver vid (%0), then
// argbuf[1..nargs+1] = the const-arg vids %1..%nargs (matching the emit order of
// emit_mic3_method_arg_consts). Returns nargs+1 (the total arg count).
pub fn mc_build_call_arg_vids(argbuf: i64, nargs: i64) -> i64 {
    __mind_store_i64(argbuf + 0, 0);
    let _r: i64 = mc_fill_const_arg_vids(argbuf, nargs, 0);
    nargs + 1
}

pub fn mc_fill_const_arg_vids(argbuf: i64, nargs: i64, i: i64) -> i64 {
    if i >= nargs {
        return i;
    }
    __mind_store_i64(argbuf + (i + 1) * 8, i + 1);
    mc_fill_const_arg_vids(argbuf, nargs, i + 1)
}

pub fn selftest_mic3_module_method_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    emit_mic3_method_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell, cbuf, argbuf, valbuf)
}

// ===========================================================================
// UNIFIED AST-driven mic@3 module dispatcher (Strategy A — cutover prep)
// ===========================================================================
//
// A SINGLE entry that, given only the source bytes, detects which construct
// class the module uses and routes to the correct ALREADY-PROVEN driver. This
// is a pure DISPATCHER over the three byte-verified emitters — NO new lowering,
// NO canary touch (mindc_compile / emit_fn_def / emit_expr_env are untouched, so
// the fixed point stays byte-identical; Bound by MIND-CONSTITUTION §I).
//
// Detection (token + struct-table driven):
//   1. Build the part-1 struct field table. If no struct is present
//      (sft_table_count < 1) the body uses only const/binop/let/call/if shapes ->
//      the AST-flatten N-function driver (selftest_mic3_module_from_ast).
//   2. A struct IS present -> scan the token stream for the first field-access
//      dot (ffa_find_dot). The receiver is at dot-1, the accessed ident at dot+1.
//      - If the token AFTER the accessed ident (dot+2) is `(`, it is a METHOD
//        call `recv.method(args)` -> the UFCS method driver
//        (emit_mic3_method_module_from_ast).
//      - Otherwise it is a plain FIELD read `recv.field` -> the field driver
//        (emit_mic3_field_module_from_ast).
//      - No dot at all (struct declared but unused in a body) falls back to the
//        N-function driver (defensive; the field/method drivers would fail-closed).
// Each routed driver already fails closed (returns an empty buf) on any shape it
// does not recognize, so the dispatcher inherits that fail-closed contract.
//
// The signature is the UNION of the three drivers' params: the method driver
// needs the extra cbuf / argbuf / valbuf scratch; the field and N-fn drivers
// ignore them.
pub fn selftest_mic3_module_unified_from_ast(src: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64, cbuf: i64, argbuf: i64, valbuf: i64) -> EmitState {
    let tokens: Vec = lex(src, src_len);
    let sft: i64 = sft_build_table(src, src_len);
    if sft_table_count(sft) < 1 {
        return selftest_mic3_module_from_ast(src, src_len, strbuf, offs, ccell);
    }
    let dot: i64 = ffa_find_dot(tokens, 0);
    if dot < 0 {
        return selftest_mic3_module_from_ast(src, src_len, strbuf, offs, ccell);
    }
    if tok_kind(tokens, dot + 2) == tk_lparen() {
        return emit_mic3_method_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell, cbuf, argbuf, valbuf);
    }
    emit_mic3_field_module_from_ast(es_new(), src, src_len, strbuf, offs, ccell)
}

// ===========================================================================
// Phase 5c — AST-DRIVEN full-module COLLECTION PASS (the hand-feeding removal)
// ===========================================================================
//
// Phases 5a/5b proved the two multi-function module assemblers
// (emit_mic3_const_fn2_module / emit_mic3_const_arith_module) reproduce the
// 50-byte and 68-byte Rust --emit-mic3 oracles byte-for-byte — but with the
// string table / offsets / const-values / op-byte HAND-FED by the test harness.
// Phase 5c removes the hand-feeding: a pure-MIND COLLECTION PASS that, given
// only the parsed multi-function AST, automatically (a) builds the deduped
// FIRST-SEEN-traversal contiguous string table + offsets array, and (b)
// extracts the const-body values / arith op-byte from the live AST node
// descriptors, then drives the proven assemblers. The result: a whole small
// `.mind` source lowers to a complete mic@3 module with ZERO hand-fed offsets,
// byte-identical to the Rust oracle (Bound by MIND-CONSTITUTION §I).
//
// The string collection mirrors Rust collect_strings / collect_instr_strings
// (src/ir/compact/v3/emit.rs ~492-586) EXACTLY: for each top-level FnDef in
// sequence, intern fn name -> each param name -> recurse body strings (for the
// const / param-arith body shapes here the body carries no strings — int
// literals and binops intern nothing; param idents are resolved positionally,
// not by name interning). StringTable::intern is idempotent (first-seen dedup),
// mirrored by intern_span's span-equality scan over already-interned entries.
//
// ADDITIVE / canary-isolated: exported only via selftest_mic3_module_from_ast;
// the canary mindc_compile / emit_fn_def mic@1 path is untouched, so the
// fixed point stays byte-identical. The actual cutover (routing mindc_compile
// through this pass) is a SEPARATE, deliberately-reviewed step.
//
// SCOPE: the two proven module shapes — (1) two zero-arg const-return fns, and
// (2) a zero-arg const-return fn0 + a 2-param single-binop arith fn1. Any other
// shape returns the seed state unchanged (fail-closed, no partial bytes).

// Append the source span src[lo..hi) to the contiguous string buffer `strbuf`,
// deduping against the strings already interned (first-seen, idempotent — mirrors
// Rust StringTable::intern). `offs` is the offset array (offs[k] = start of
// string k; offs[count] = current write cursor / end of last string). `ccell`
// is a 1-i64 cell holding the live interned-string count. Returns the string
// index (existing on a dedup hit, or the freshly allocated index). Single bytes
// are written with __mind_store_i8 so the buffer is byte-contiguous, exactly as
// emit_mic3_strtab/emit_mic3_lp_bytes expect.
pub fn intern_span(strbuf: i64, offs: i64, ccell: i64, src: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let hit: i64 = intern_find(strbuf, offs, n, src, lo, hi, 0);
    if hit >= 0 {
        return hit;
    }
    let start: i64 = __mind_load_i64(offs + n * 8);
    let end: i64 = intern_copy(strbuf, start, src, lo, hi);
    __mind_store_i64(offs + (n + 1) * 8, end);
    __mind_store_i64(ccell, n + 1);
    n
}

// Scan the n already-interned strings for one whose bytes equal src[lo..hi);
// return its index or -1. Mirrors StringTable dedup (span_bytes_equal compares
// raw bytes — no hashing, so no collision risk).
pub fn intern_find(strbuf: i64, offs: i64, n: i64, src: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(offs + i * 8);
    let ehi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if span_bytes_equal2(src, lo, hi, strbuf, elo, ehi) == 1 {
        return i;
    }
    intern_find(strbuf, offs, n, src, lo, hi, i + 1)
}

// Copy src[lo..hi) into strbuf starting at `dst`; return the new write cursor.
pub fn intern_copy(strbuf: i64, dst: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return dst;
    }
    __mind_store_i8(strbuf + dst, load_byte(src, lo));
    intern_copy(strbuf, dst + 1, src, lo + 1, hi)
}

// Intern one fn_def's strings in Rust collect_strings order: fn name first,
// then each param name. Body strings (int literals, binops, param-ident leaves)
// intern nothing for the const / param-arith shapes, mirroring the oracle.
pub fn collect_fn_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, fn_node: i64) -> i64 {
    let name_leaf: i64 = ast_child0(fn_node);
    let n0: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let rp: i64 = collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, 0);
    // Recurse the body in statement order, interning any CALL callee names — the
    // Rust collect_instr_strings(Instr::Call) interns the call name during the
    // body traversal (verified: a forward call interns the callee BEFORE the
    // callee fn's own params). Const/int/binop/param/ident bodies intern nothing.
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, 0)
}

// Intern call-callee names appearing in a fn body, in statement+expression order,
// mirroring Rust collect_strings -> collect_instr_strings recursion. Only the
// constructs the AST-driven path emits are walked (let-init, call); other leaves
// intern nothing. Idempotent via intern_span's first-seen dedup.
pub fn collect_body_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, stmt);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

pub fn collect_expr_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child2(node));
    }
    if k == ast_call() {
        // A call `f(a, b)` lowers to [a's instrs, b's instrs, CALL f] — the CALL instr's
        // name interns AFTER the arg instrs. So recurse the ARGS first (left-to-right,
        // interning any nested-call callee names), THEN the outer callee. (For simple
        // args — params / literals — this is identical to callee-first; it only differs,
        // and matches the oracle, when an arg is itself a call, e.g. ast_new_leaf(ast_struct_def(),..).)
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let _a: i64 = collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, 0);
        let callee: i64 = ast_child0(node);
        return intern_span(strbuf, offs, ccell, src, ast_span_lo(callee), ast_span_hi(callee));
    }
    if k == ast_binop() {
        let rl: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child1(node));
    }
    if k == ast_field() {
        // FieldAccess lowers (src/eval/lower.rs ast::Node::FieldAccess resolved arm)
        // to: receiver instrs, optional CONST(idx*8), optional BINOP Add, then
        // Call("__mind_load_i64", [addr]). Mirror the Rust collect order: recurse
        // the receiver first (its own Call names, if any, intern before this one),
        // then intern the synthetic load-call name. CONST/BINOP intern nothing.
        let rr: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        return intern_load_i64_name(strbuf, offs, ccell);
    }
    if k == ast_if() {
        // Recurse cond -> then-block stmts -> else-block stmts, in SOURCE order, so
        // call names (and field-loads) inside an if-body intern at their oracle
        // first-seen position. Byte-identical for if-bodies that carry no strings
        // (constants/params); enables fns whose if-returns call other fns (e.g.
        // classify_ident's `return tk_kw_fn()`). Then intern the then-block's leading
        // `let` NAMES (the OP_IF branch_bindings) — AFTER all cond/then/else strings,
        // mirroring Rust collect_instr_strings (branch_bindings interned last). A let
        // that escapes the then-block as a merge binds its name into the strtab; the
        // 2-let oracle decode confirmed source order (x before y), branch-bindings-last
        // (a call after the let interns BEFORE the let name). No-let blocks: no-op.
        let rc: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        let then_blk: i64 = ast_child1(node);
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        let rt: i64 = collect_block_strings(strbuf, offs, ccell, src, then_sa, then_sl, 0);
        let else_blk: i64 = ast_child2(node);
        if else_blk != 0 {
            let re: i64 = collect_block_strings(strbuf, offs, ccell, src, ast_child0(else_blk), ast_aux(else_blk), 0);
        }
        // branch_bindings names = merged_names = then-WRITES ++ else-WRITES (deduped,
        // first-occurrence order; lower.rs 4203-4208). A "write" is a branch-local `let`
        // OR an `Assign` to an outer var (in source order). The old pass interned only
        // leading LETS; an if-else STATEMENT whose branches ASSIGN loop-carried vars (the
        // `if C { i=i+1 } else { ok=0; i=n }` shape inside a while) also merges those
        // assign-targets, so their names must intern here too (matching Rust's
        // branch_bindings). Superset of the let-only behavior: for let-only branches it
        // interns exactly then-lets ++ else-lets (identical bytes).
        let wn_buf: i64 = __mind_alloc((then_sl + 1) * 24);
        let wn_cell: i64 = __mind_alloc(8);
        __mind_store_i64(wn_cell, 0);
        let _w1: i64 = collect_branch_write_names(then_sa, then_sl, src, wn_buf, wn_cell, 0);
        let then_wn: i64 = __mind_load_i64(wn_cell);
        let _it: i64 = intern_name_span_buf(strbuf, offs, ccell, src, wn_buf, then_wn, 0);
        if else_blk != 0 {
            let else_sa2: i64 = ast_child0(else_blk);
            let else_sl2: i64 = ast_aux(else_blk);
            let wn_buf2: i64 = __mind_alloc((then_sl + else_sl2 + 1) * 24);
            let wn_cell2: i64 = __mind_alloc(8);
            __mind_store_i64(wn_cell2, 0);
            // Rebuild then-writes into wn_buf2 first so else-writes dedup against them,
            // then append else-writes; intern ONLY the new (else) names in order.
            let _w2a: i64 = collect_branch_write_names(then_sa, then_sl, src, wn_buf2, wn_cell2, 0);
            let base_wn: i64 = __mind_load_i64(wn_cell2);
            let _w2b: i64 = collect_branch_write_names(else_sa2, else_sl2, src, wn_buf2, wn_cell2, 0);
            let total_wn: i64 = __mind_load_i64(wn_cell2);
            return intern_name_span_buf(strbuf, offs, ccell, src, wn_buf2, total_wn, base_wn);
        }
        return 0;
    }
    if k == ast_return() {
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
    }
    if k == ast_while() {
        // Mirror Rust collect_instr_strings Instr::While: cond strings, then body
        // strings (each stmt in source order), then the loop-carried (live_var) NAMES.
        let rc: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        let body_blk: i64 = ast_child1(node);
        let body_sa: i64 = ast_child0(body_blk);
        let body_sl: i64 = ast_aux(body_blk);
        let rb: i64 = collect_block_strings(strbuf, offs, ccell, src, body_sa, body_sl, 0);
        // live_var names = assign-targets NOT declared by a `let` earlier in this body
        // (loop-carried = pre-loop vars), in first-assign source order.
        return intern_while_live_names(strbuf, offs, ccell, src, body_sa, body_sl, 0);
    }
    if k == ast_assign() {
        // An assign statement's RHS supplies its strings (the target name is interned by
        // the enclosing while's live_var pass, not here).
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child2(node));
    }
    if k == ast_struct_lit() {
        // Mirror flatten_struct_lit_lv's emit order so the oracle strtab matches: intern
        // __mind_alloc once, then PER FIELD (declared order) [field value's strings, then
        // __mind_store_i64]. Spans + def-ordered values come from the +56 annotation; an
        // unannotated struct-lit interns nothing (it will also fail flatten -> oracle path).
        let ann: i64 = __mind_load_i64(node + 56);
        if ann == 0 {
            return 0;
        }
        let _ia: i64 = intern_span(strbuf, offs, ccell, src, __mind_load_i64(ann + 0), __mind_load_i64(ann + 8));
        return slit_collect_field_strings(strbuf, offs, ccell, src, __mind_load_i64(ann + 32), ast_aux(node), __mind_load_i64(ann + 16), __mind_load_i64(ann + 24), 0);
    }
    0
}
// Per struct-lit field (declared order): the field VALUE's strings then __mind_store_i64.
pub fn slit_collect_field_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, values: i64, nf: i64, slo: i64, shi: i64, j: i64) -> i64 {
    if j >= nf {
        return 0;
    }
    let _v: i64 = collect_expr_strings(strbuf, offs, ccell, src, __mind_load_i64(values + j * 8));
    let _is: i64 = intern_span(strbuf, offs, ccell, src, slo, shi);
    slit_collect_field_strings(strbuf, offs, ccell, src, values, nf, slo, shi, j + 1)
}

// Collect strings from a block's statements in source order (each stmt via
// collect_expr_strings: a let recurses its init, an if recurses cond/then/else,
// a return its value). Used by the ast_if arm to walk if-body sub-statements.
pub fn collect_block_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, stmt);
    collect_block_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

// Intern the NAMES of ALL `let` statements of a then-block (its OP_IF
// branch_bindings), in source order, SKIPPING non-let stmts (a mixed block's lets
// come after its if-segments; every then-block let escapes as a binding). Called
// by the ast_if arm AFTER the cond/then/else strings, matching Rust
// collect_instr_strings's branch_bindings-last interning (segment-bubbled names
// already interned during the then recursion, deduped). No-op (byte-identical)
// for let-less then-blocks.
pub fn intern_leading_let_names(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return intern_leading_let_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1);
    }
    let name: i64 = ast_child0(stmt);
    let ni: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name), ast_span_hi(name));
    intern_leading_let_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

// Collect a branch's WRITE-target names (each `let` name AND each `Assign` target) in
// source order, deduped against names already in the 24-byte `out` buffer (span records
// [lo,hi]); `ncell` holds the running count. Mirrors lower.rs then_writes/else_writes.
pub fn collect_branch_write_names(sa: i64, sl: i64, src: i64, out: i64, ncell: i64, i: i64) -> i64 {
    if i >= sl {
        return __mind_load_i64(ncell);
    }
    let stmt: i64 = __mind_load_i64(sa + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let _a: i64 = collect_bwn_add(out, ncell, src, ast_child0(stmt));
    }
    if k == ast_assign() {
        let _a: i64 = collect_bwn_add(out, ncell, src, ast_child0(stmt));
    }
    collect_branch_write_names(sa, sl, src, out, ncell, i + 1)
}

// Append name-node's (lo,hi) span to `out` if not already present (dedup).
pub fn collect_bwn_add(out: i64, ncell: i64, src: i64, name: i64) -> i64 {
    let lo: i64 = ast_span_lo(name);
    let hi: i64 = ast_span_hi(name);
    let n: i64 = __mind_load_i64(ncell);
    if while_if_name_find(out, n, src, lo, hi, 0) < 0 {
        __mind_store_i64(out + n * 24 + 0, lo);
        __mind_store_i64(out + n * 24 + 8, hi);
        __mind_store_i64(ncell, n + 1)
    }
    0
}

// Intern span records out[start..n) (24-byte [lo,hi] records) in order.
pub fn intern_name_span_buf(strbuf: i64, offs: i64, ccell: i64, src: i64, out: i64, n: i64, start: i64) -> i64 {
    if start >= n {
        return 0;
    }
    let _ni: i64 = intern_span(strbuf, offs, ccell, src, __mind_load_i64(out + start * 24 + 0), __mind_load_i64(out + start * 24 + 8));
    intern_name_span_buf(strbuf, offs, ccell, src, out, n, start + 1)
}

// Intern the loop-carried (live_var) NAMES of a while body: each Assign target that is
// NOT declared by a `let` earlier in the SAME body (so it is a pre-loop var), in
// first-assign source order, deduped against an earlier assign of the same name and
// against body-local lets. Mirrors Rust collect_instr_strings's While live_vars pass.
pub fn intern_while_live_names(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_assign() {
        return intern_while_live_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1);
    }
    let name: i64 = ast_child0(stmt);
    let lo: i64 = ast_span_lo(name);
    let hi: i64 = ast_span_hi(name);
    // Skip if a body-local `let` declares this name earlier (then it is NOT loop-carried),
    // or an earlier assign of the same name already interned it (dedup -> first sight only).
    if while_name_let_or_assigned_before(src, stmts_addr, lo, hi, i, 0) == 1 {
        return intern_while_live_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1);
    }
    let _ni: i64 = intern_span(strbuf, offs, ccell, src, lo, hi);
    intern_while_live_names(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

// 1 if NAME (lo,hi) is declared by a body-local `let` OR assigned by an earlier Assign in
// stmts[0..before). Used to dedup/skip non-loop-carried (let-shadowed) and repeat assigns.
pub fn while_name_let_or_assigned_before(src: i64, stmts_addr: i64, lo: i64, hi: i64, before: i64, i: i64) -> i64 {
    if i >= before {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        let nm: i64 = ast_child0(stmt);
        if span_bytes_equal2(src, lo, hi, src, ast_span_lo(nm), ast_span_hi(nm)) == 1 {
            return 1;
        }
    }
    if k == ast_assign() {
        let nm: i64 = ast_child0(stmt);
        if span_bytes_equal2(src, lo, hi, src, ast_span_lo(nm), ast_span_hi(nm)) == 1 {
            return 1;
        }
    }
    while_name_let_or_assigned_before(src, stmts_addr, lo, hi, before, i + 1)
}

pub fn collect_args_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, args_addr: i64, args_len: i64, i: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, arg);
    collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, i + 1)
}

pub fn collect_param_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, params_addr: i64, n_params: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let idx: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, i + 1)
}

// Walk the top-level item list and collect every fn_def's strings in sequence —
// the module-wide first-seen traversal order Rust collect_strings produces.
pub fn build_module_strtab(strbuf: i64, offs: i64, ccell: i64, src: i64, items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let r: i64 = collect_fn_strings(strbuf, offs, ccell, src, item);
        return build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1);
    }
    build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1)
}

// Extract the i64 value a zero-arg const-return fn returns: its body's trailing
// statement must be an int literal. Returns the literal, or -1 if the body is
// not a single int-literal return (fail-closed shape guard).
pub fn const_fn_value(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    if ast_kind(expr) != ast_int_lit() {
        return 0 - 1;
    }
    parse_int_span(src, ast_span_lo(expr), ast_span_hi(expr), 0)
}

// Extract the mic@3 op-byte of a 2-param single-binop arith fn (body = one
// `pa OP pb` binop whose leaves are the two params, in order). Returns the
// op-byte, or -1 if the shape does not match (fail-closed).
pub fn arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(expr);
    let r: i64 = ast_child1(expr);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(expr))
}

// Extract the mic@3 op-byte of a 2-param arith fn whose body is written as a
// LET binding then a use of it: `{ let t: i64 = pa OP pb; t }`. The Rust lowering
// produces a body BYTE-IDENTICAL to the direct `{ pa OP pb }` form — the let-bound
// value simply takes the binop's vid (%2) and the trailing `t` resolves to it, so
// no distinct opcode and no extra string is emitted (verified vs --emit-mic3 on
// `f(a,b){let t=a+b; t}` == `f(a,b){a+b}`). Returns the op-byte, or -1 on shape
// mismatch (fail-closed). Two body stmts required: a let with a 2-ident binop init,
// then a trailing ident referencing the let name.
pub fn let_arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 2 {
        return 0 - 1;
    }
    let s0: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(s0) != ast_let() {
        return 0 - 1;
    }
    let s1: i64 = __mind_load_i64(stmts_addr + 8);
    if ast_kind(s1) != ast_ident() {
        return 0 - 1;
    }
    // The trailing use must name the let-bound variable.
    let let_name: i64 = ast_child0(s0);
    if span_bytes_equal2(src, ast_span_lo(s1), ast_span_hi(s1), src, ast_span_lo(let_name), ast_span_hi(let_name)) != 1 {
        return 0 - 1;
    }
    let init: i64 = ast_child2(s0);
    if ast_kind(init) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(init);
    let r: i64 = ast_child1(init);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(init))
}

// Extract the two int-literal argument values of a zero-arg fn whose body is a
// single call with exactly two int-literal arguments: `{ callee(<v0>, <v1>) }`.
// Writes v0 -> out[0], v1 -> out[1] and returns 1 on a match, 0 otherwise
// (fail-closed). The callee name is resolved separately to its string index.
pub fn call_fn_args2(src: i64, fn_node: i64, out: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_call() {
        return 0;
    }
    if ast_aux(expr) != 2 {
        return 0;
    }
    let args_addr: i64 = ast_child1(expr);
    let a0: i64 = __mind_load_i64(args_addr);
    let a1: i64 = __mind_load_i64(args_addr + 8);
    if ast_kind(a0) != ast_int_lit() {
        return 0;
    }
    if ast_kind(a1) != ast_int_lit() {
        return 0;
    }
    let v0: i64 = parse_int_span(src, ast_span_lo(a0), ast_span_hi(a0), 0);
    let v1: i64 = parse_int_span(src, ast_span_lo(a1), ast_span_hi(a1), 0);
    __mind_store_i64(out + 0, v0);
    __mind_store_i64(out + 8, v1);
    1
}

// Resolve the string index of a zero-arg call-fn's callee name within the already
// built string table (offs/n hold the interned strings). Returns the index, or -1.
pub fn call_fn_callee_idx(src: i64, fn_node: i64, strbuf: i64, offs: i64, n_strings: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let expr: i64 = __mind_load_i64(stmts_addr);
    let callee: i64 = ast_child0(expr);
    intern_find(strbuf, offs, n_strings, src, ast_span_lo(callee), ast_span_hi(callee), 0)
}

// AST-DRIVEN full-module driver: lex+parse `src`, build the deduped first-seen
// string table into caller-supplied scratch (strbuf/offs/ccell), detect which of
// the two proven module shapes the source is, extract its const values / op-byte
// from the live AST, and emit the complete mic@3 module byte-exact vs the Rust
// --emit-mic3 oracle — with ZERO hand-fed offsets. Fails closed (returns es_new()
// unchanged, empty buf) on any other shape, so the harness can detect non-emission.
//
//   strbuf : contiguous byte buffer for the string table (>= total name bytes + 8)
//   offs   : offset array ((n_strings + 1) i64s; offs[0] must be pre-zeroed)
//   ccell  : 1-i64 interned-count cell (pre-zeroed)
pub fn selftest_mic3_module_from_ast(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Build the string table from the live AST (the hand-feeding removal).
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    // Require exactly two top-level fn_defs.
    let f0: i64 = nth_fn_def(items_addr, items_len, 0);
    let f1: i64 = nth_fn_def(items_addr, items_len, 1);
    let f2: i64 = nth_fn_def(items_addr, items_len, 2);
    if f0 == 0 {
        return es_new();
    }
    if f1 == 0 {
        return es_new();
    }
    if f2 != 0 {
        return es_new();
    }
    // Shape (1): two zero-arg const-return fns.
    let v0: i64 = const_fn_value(src_addr, f0);
    if v0 >= 0 {
        let v1: i64 = const_fn_value(src_addr, f1);
        if v1 >= 0 {
            return emit_mic3_const_fn2_module(es_new(), strbuf, offs, v0, v1);
        }
        // Shape (2): const-return fn0 + 2-param arith fn1.
        let ob: i64 = arith_fn_opbyte(src_addr, f1);
        if ob >= 0 {
            return emit_mic3_const_arith_module(es_new(), strbuf, offs, v0, ob);
        }
    }
    // fn0 = a 2-param arith fn (direct `pa OP pb`, or `let t=pa OP pb; t`).
    let ob0_direct: i64 = arith_fn_opbyte(src_addr, f0);
    let ob0_let: i64 = let_arith_fn_opbyte(src_addr, f0);
    let ob0: i64 = if ob0_direct >= 0 {
        ob0_direct
    } else {
        ob0_let
    };
    if ob0 >= 0 {
        // Shape (3): arith fn0 + const fn1 (the LET-body ordering — arith first).
        let cv1: i64 = const_fn_value(src_addr, f1);
        if cv1 >= 0 {
            return emit_mic3_arith_const_module(es_new(), strbuf, offs, ob0, cv1);
        }
        // Shape (4): arith fn0 + const-args CALL fn1.
        let scratch: i64 = __mind_alloc(16);
        let ok: i64 = call_fn_args2(src_addr, f1, scratch);
        if ok == 1 {
            let ncount: i64 = __mind_load_i64(ccell);
            let cidx: i64 = call_fn_callee_idx(src_addr, f1, strbuf, offs, ncount);
            if cidx >= 0 {
                let cva: i64 = __mind_load_i64(scratch + 0);
                let cvb: i64 = __mind_load_i64(scratch + 8);
                return emit_mic3_arith_call_module(es_new(), strbuf, offs, ob0, cidx, cva, cvb);
            }
        }
    }
    es_new()
}

// Return the j-th top-level fn_def node (0-based), or 0 if fewer than j+1 exist.
pub fn nth_fn_def(items_addr: i64, items_len: i64, j: i64) -> i64 {
    nth_fn_def_loop(items_addr, items_len, j, 0, 0)
}
pub fn nth_fn_def_loop(items_addr: i64, items_len: i64, j: i64, seen: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        if seen == j {
            return item;
        }
        return nth_fn_def_loop(items_addr, items_len, j, seen + 1, i + 1);
    }
    nth_fn_def_loop(items_addr, items_len, j, seen, i + 1)
}

// Count the top-level fn_defs in the item list.
pub fn count_fn_defs(items_addr: i64, items_len: i64, i: i64, acc: i64) -> i64 {
    if i >= items_len {
        return acc;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        return count_fn_defs(items_addr, items_len, i + 1, acc + 1);
    }
    count_fn_defs(items_addr, items_len, i + 1, acc)
}

// ===========================================================================
// Phase 5d — N-FUNCTION mic@3 module assembly (Strategy A increment 5)
// ===========================================================================
//
// Generalizes the fixed 2-function module driver to an ARBITRARY function count
// (3, 4, .. N). Verified vs the Rust --emit-mic3 oracle, the module is a flat
// sequence (decoded from 3-fn / 4-fn / mixed oracles):
//   header || strtab(N+ in first-seen order) || next_id(=N) || exports(0) ||
//   uleb(instr_count = 3*N) ||
//   [ per fn k (0-based) : FN_DEF{body} || ConstI64(%k, 0) || Output(%k) ]*N ||
//   3 empty registries.
// The four module-wide invariants the 2-fn path already verifies are preserved
// for all N: (1) ONE union string table in first-seen TRAVERSAL order across all
// N fns (build_module_strtab is already N-general); (2) ONE flat next_id = N
// threaded across the N scaffold ConstI64/Output pairs (scaffold vid == the fn
// index k); (3) ONE flat top-level instr count = 3*N; (4) registries trailing.
// Each FN_DEF body keeps its OWN vid space (params %0.., binop/call vids follow),
// exactly as the per-shape 2-fn emitters do — only the module-level scaffold
// threads the flat counter. ADDITIVE: exported via selftest_mic3_module_nfn only,
// the canary mindc_compile / emit_fn_def mic@1 path is untouched (Bound by
// MIND-CONSTITUTION §I — fixed point byte-identical).
//
// SCOPE: each fn must be one of the four proven body shapes — (a) zero-arg
// const-return, (b) 2-param single-binop arith (direct `pa OP pb` or the
// byte-identical `let t = pa OP pb; t`), (c) zero-arg CALL with two int-literal
// args. Any fn outside these shapes makes the whole module fail closed (es_new(),
// empty buf) so the harness detects non-emission — no partial bytes.

// Emit the FN_DEF for a zero-arg const-return fn: name_idx, ret %0, body =
// [ConstI64(%0, const_val)].
pub fn emit_mic3_fndef_const(s: EmitState, name_idx: i64, const_val: i64) -> EmitState {
    let s1: EmitState = emit_mic3_fn_def_header(s, name_idx, 1, 0, 1);
    emit_mic3_const_i64(s1, 0, const_val)
}

// Emit the FN_DEF for a 2-param single-binop arith fn: name_idx, params str
// (p0_str,%0)/(p1_str,%1), ret %2, body = [PARAM %0, PARAM %1, BINOP %2=%0 op %1].
pub fn emit_mic3_fndef_arith(s: EmitState, name_idx: i64, p0_str: i64, p1_str: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, p0_str);
    let s5: EmitState = emit_uleb128(s4, 0);
    let s6: EmitState = emit_uleb128(s5, p1_str);
    let s7: EmitState = emit_uleb128(s6, 1);
    let s8: EmitState = emit_mic3_opt_vid(s7, 1, 2);
    let s9: EmitState = es_push(s8, 0);
    let s10: EmitState = emit_uleb128(s9, 3);
    let s11: EmitState = emit_mic3_param(s10, 0, p0_str, 0);
    let s12: EmitState = emit_mic3_param(s11, 1, p1_str, 1);
    emit_mic3_binop(s12, 2, op_byte, 0, 1)
}

// Emit the FN_DEF for a zero-arg fn whose body is a CALL to `callee_idx` with two
// int-literal args: name_idx, ret %2, body = [ConstI64 %0=v0, ConstI64 %1=v1,
// CALL %2 = callee(%0,%1)].
pub fn emit_mic3_fndef_call(s: EmitState, name_idx: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 0);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, 2);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, 3);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 1, v1);
    emit_mic3_call2(s8, 2, callee_idx, 0, 1)
}

// Module-level scaffold for fn k: ConstI64(%k, 0) || Output(%k). The flat next_id
// counter is realized by passing the fn's own index k.
pub fn emit_mic3_scaffold(s: EmitState, k: i64) -> EmitState {
    let s1: EmitState = emit_mic3_const_i64(s, k, 0);
    emit_mic3_output(s1, k)
}

// Resolve a 2-param arith fn's two param-name string indices into out[0]/out[1]
// (the FN_DEF param list and body PARAM instrs reference them). Returns 1 on a
// 2-param fn, 0 otherwise (fail-closed).
pub fn arith_param_str_idxs(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, out: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0;
    }
    let params_addr: i64 = ast_child1(fn_node);
    let p0: i64 = __mind_load_i64(params_addr + 0);
    let p1: i64 = __mind_load_i64(params_addr + 8);
    let n0_leaf: i64 = ast_child0(p0);
    let n1_leaf: i64 = ast_child0(p1);
    let i0: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(n0_leaf), ast_span_hi(n0_leaf), 0);
    let i1: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(n1_leaf), ast_span_hi(n1_leaf), 0);
    if i0 < 0 {
        return 0;
    }
    if i1 < 0 {
        return 0;
    }
    __mind_store_i64(out + 0, i0);
    __mind_store_i64(out + 8, i1);
    1
}

// Resolve a fn's own name string index in the already-built string table.
pub fn fn_name_idx(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64) -> i64 {
    let name_leaf: i64 = ast_child0(fn_node);
    intern_find(strbuf, offs, ncount, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf), 0)
}

// ===========================================================================
// Strategy A increment 6 — ARBITRARY expression-tree / if bodies in the N-fn
// module path. WIRING (not new lowering): each fn's FN_DEF body dispatches to
// the already-proven 4f tree emitter (emit_mic3_tree_body) or the 4j OP_IF body
// emitter (emit_mic3_if_instr). The only module-specific concern is the FN_DEF
// param list / body PARAM instrs, which must use the MODULE-WIDE union string
// indices (not the fresh-table `i+1` the standalone single-fn drivers hardcode).
// ADDITIVE: the canary mindc_compile / emit_fn_def mic@1 path is untouched, and
// the existing a/b/c shape branches in emit_mic3_module_fndef stay byte-identical
// (Bound by MIND-CONSTITUTION §I — fixed point byte-identical).
// ===========================================================================

// Resolve every param of `fn_node` to its MODULE string index, writing out[i] for
// i in 0..n_params. Returns 1 on success, 0 if any param name is not interned
// (fail-closed). Generalizes arith_param_str_idxs to an arbitrary param count.
pub fn module_param_str_idxs(src: i64, fn_node: i64, strbuf: i64, offs: i64, ncount: i64, out: i64, i: i64) -> i64 {
    let n_params: i64 = ast_aux(fn_node) / 2;
    if i >= n_params {
        return 1;
    }
    let params_addr: i64 = ast_child1(fn_node);
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let idx: i64 = intern_find(strbuf, offs, ncount, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf), 0);
    if idx < 0 {
        return 0;
    }
    __mind_store_i64(out + i * 8, idx);
    module_param_str_idxs(src, fn_node, strbuf, offs, ncount, out, i + 1)
}

// FN_DEF param-pair list using MODULE string indices: uleb(n) || (pstr[i], %i)*n.
// Mirrors emit_mic3_chain_param_pairs but reads the resolved module string idx
// from `pstr` instead of assuming the fresh-table `i+1`.
pub fn emit_mic3_param_pairs_mod(s: EmitState, pstr: i64, n: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, n);
    emit_mic3_param_pairs_mod_loop(s1, pstr, n, 0)
}
pub fn emit_mic3_param_pairs_mod_loop(s: EmitState, pstr: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(pstr + i * 8));
    let s2: EmitState = emit_uleb128(s1, i);
    emit_mic3_param_pairs_mod_loop(s2, pstr, n, i + 1)
}

// Body PARAM instrs using MODULE string indices: PARAM(%i, pstr[i], index=i).
// Mirrors emit_mic3_chain_params but reads the resolved module string idx.
pub fn emit_mic3_params_mod(s: EmitState, pstr: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, i, __mind_load_i64(pstr + i * 8), i);
    emit_mic3_params_mod(s1, pstr, n, i + 1)
}

// Emit ONE fn's FN_DEF whose body is an arbitrary param/const/binop expression
// tree, using module string indices. Returns the post-FN_DEF state; writes 1 to
// ok_cell on success, 0 (fail-closed, returns seed `s`) on a non-tree body. This
// is the FN_DEF-only counterpart of emit_mic3_tree_fn_module (no header/scaffold/
// registries — the caller frames the module).
pub fn emit_mic3_module_fndef_tree(s: EmitState, src: i64, strbuf: i64, offs: i64, ncount: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, expr: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast(expr, src, params_addr, n_params, nodes, cursor);
    if root_slot < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    let root_vid: i64 = tree_resolve_vids(nodes, n_nodes, n_params, vidbuf, 0, n_params);
    // body_len = n_params PARAM instrs + the non-param nodes (CONST leaves + BINOPs).
    // n_nodes over-counts when a param appears more than once (each occurrence is a
    // descriptor node but emits NO instr — emit_mic3_params_mod writes ONE PARAM per
    // distinct param, tree_body skips every param leaf), so derive body_len from the
    // non-param count, mirroring the Rust oracle's de-duplicated PARAM emission.
    let nonparam: i64 = count_nonparam_nodes(expr, src, params_addr, n_params);
    if nonparam < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let body_len: i64 = n_params + nonparam;
    // FN_DEF: name || param-pairs(module idx) || ret Some %root || reap None ||
    // body_len || body PARAMs(module idx) || tree body.
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, root_vid);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_mic3_tree_body(s7, nodes, n_nodes, vidbuf, src, strbuf, offs, ncount, 0);
    __mind_store_i64(ok_cell, 1);
    s8
}

// Emit ONE fn's FN_DEF whose body is a single `if cond { then } else { else }`
// value (single-expression branches, empty branch-bindings + merges), using
// module string indices. Returns the post-FN_DEF state; writes 1 to ok_cell on
// success, 0 (fail-closed, returns seed `s`) on any wall. FN_DEF-only counterpart
// of emit_mic3_if_fn_module — body is n PARAM instrs then one OP_IF (body_len =
// n + 1), ret_vid = the if's dst.
pub fn emit_mic3_module_fndef_if(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, cond_expr: i64, then_expr: i64, else_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    // Emit the OP_IF into a SCRATCH state first to learn dst (the ret_vid).
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_mic3_if_instr(es_new(), cond_expr, then_expr, else_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, dst);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, n_params + 1);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s8: EmitState = emit_mic3_if_instr(s7, cond_expr, then_expr, else_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    __mind_store_i64(ok_cell, 1);
    s8
}

// FN_DEF whose body is a GENERAL value if-EXPRESSION (block branches with leading lets,
// nested else-if chains) — routed through the lv-aware emit_if_expr_any_lv (which itself
// dispatches single-expr branches to emit_if_expr_lv, byte-identical to the narrow path,
// and block/nested-if branches to emit_if_expr_block_lv). Mirrors emit_mic3_module_fndef_if's
// probe-then-reframe pattern. Fails closed (ok_cell=0, returns seed s) on any wall.
pub fn emit_mic3_module_fndef_ifany(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, if_node: i64, nodes: i64, cursor: i64, vidbuf: i64, strbuf: i64, offs: i64, ncount: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_if_expr_any_lv(es_new(), if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell, 0, 0, strbuf, offs, ncount, 0, 0);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, dst);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, n_params + 1);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_if_expr_any_lv(s7, if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell, 0, 0, strbuf, offs, ncount, 0, 0);
    __mind_store_i64(ok_cell, 1);
    s8
}

// ===========================================================================
// IF-STATEMENT early-return — the final cutover construct
// ===========================================================================
//
// A body `{ if cond { return E; } TRAIL }` (two statements: an else-less if whose
// then-block's only statement is `return E`, then a trailing value expr TRAIL).
// Decoded byte-for-byte from --emit-mic3 (`pub fn s(b){ if b==1 { return 1; } 0 }`):
// the if lowers to ONE OP_IF whose then-block carries the synth const, the return
// value's tree, and a Return(then_root) instr; the else-block (empty) carries only
// the synth const; branch_bindings + merges are both empty; dst is the next free
// vid. The trailing expr is then lowered AFTER the OP_IF, and the FN_DEF ret_vid is
// the TRAILING expr's root vid (NOT dst). This path is ISOLATED from the canary —
// reached only via case (g) in emit_mic3_module_fndef (flatten_ast still rejects
// ast_if at the expression level, so the fixed point stays byte-identical; Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Emit the OP_IF body instruction for an else-less if whose then-block is a single
// `return E`. cond / E are each a param/const/binop tree. then-block = synth const
// + E's tree + Return(E_root); else-block = synth const only (empty else_result =
// the else synth vid). branch_bindings + merges empty. Writes dst to `okcell` on
// success (-1 on a wall). `base0` is the starting vid counter (= n_params).
pub fn emit_mic3_if_stmt_instr(s: EmitState, cond_expr: i64, ret_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    // --- cond ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then: synth ConstI64(after_cond, 0), the return expr tree, Return(root) ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(ret_expr, buf, params_addr, n_params);
    // then_instrs.len = synth(1) + ret-expr non-param instrs + the Return instr(1).
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 2);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
    let s8: EmitState = emit_mic3_return(s7, 1, then_root);
    // then_result is the RETURNED value vid (not the Return instr).
    let s9: EmitState = emit_uleb128(s8, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else (EMPTY): just the synth ConstI64(after_then, 0); else_result = synth ---
    let else_synth: i64 = after_then;
    let s10: EmitState = emit_uleb128(s9, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    let after_else: i64 = after_then + 1;

    // --- dst (the if's value) + empty branch_bindings + empty merges ---
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// Emit ONE fn's FN_DEF whose body is `{ if cond { return E; } TRAIL }`, using
// module string indices. Body = n PARAM instrs + the OP_IF + the TRAIL expr tree;
// FN_DEF ret_vid = TRAIL's root vid (the trailing expr is lowered AFTER the OP_IF,
// its non-param vids starting at dst+1). Writes 1 to ok_cell on success, 0
// (fail-closed, returns seed `s`) on any wall.
pub fn emit_mic3_module_fndef_ifstmt(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, cond_expr: i64, ret_expr: i64, trail_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, t_nodes: i64, t_cursor: i64, t_vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    // Emit the OP_IF into a SCRATCH state first to learn dst (the trailing base-1).
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_mic3_if_stmt_instr(es_new(), cond_expr, ret_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    // Trailing expr: its non-param vids start at dst + 1 (the next free vid after
    // the OP_IF). Resolve its root vid (= FN_DEF ret) and node count.
    let trail_root: i64 = flatten_branch(trail_expr, src, params_addr, n_params, t_nodes, t_cursor, t_vidbuf, dst + 1);
    if trail_root < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_n: i64 = __mind_load_i64(t_cursor);
    let trail_nonparam: i64 = count_nonparam_nodes(trail_expr, src, params_addr, n_params);
    // body_len = n PARAM instrs + 1 OP_IF + the trailing expr's non-param instrs.
    let body_len: i64 = n_params + 1 + trail_nonparam;
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, trail_root);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s8: EmitState = emit_mic3_if_stmt_instr(s7, cond_expr, ret_expr, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let s9: EmitState = emit_mic3_tree_body(s8, t_nodes, trail_n, t_vidbuf, 0, 0, 0, 0, 0);
    __mind_store_i64(ok_cell, 1);
    s9
}

// Recursively emit an OP_IF chain `if c1 { if c2 { ... if cN { return E } } }` — each
// else-less, then-block = a SINGLE stmt that is either the next nested if or the
// terminal `return E`. Subsumes the depth-1 (flat) + depth-2 cases at ARBITRARY depth.
// Byte-exact vs --emit-mic3 (vid layout verified vs the depth-3 decode, 115B ret_vid=17).
// base0 = starting vid; writes the OP_IF dst to okcell (-1 on a wall).
pub fn emit_if_chain_instr(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let inner: i64 = branch_single_expr(then_blk);
    if inner < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // base case: then-block is `return E`.
    if ast_kind(inner) == ast_return() {
        let ret_expr: i64 = ast_child0(inner);
        let then_root: i64 = flatten_branch(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
        if then_root < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let then_n: i64 = __mind_load_i64(cursor);
        let then_nonparam: i64 = count_nonparam_nodes(ret_expr, buf, params_addr, n_params);
        let s5: EmitState = emit_uleb128(s4, then_nonparam + 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0, 0, 0, 0, 0);
        let s8: EmitState = emit_mic3_return(s7, 1, then_root);
        let s9: EmitState = emit_uleb128(s8, then_root);
        let after_then: i64 = after_cond + 1 + then_nonparam;
        let else_synth: i64 = after_then;
        let s10: EmitState = emit_uleb128(s9, 1);
        let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
        let s12: EmitState = emit_uleb128(s11, else_synth);
        let dst: i64 = after_then + 1;
        let s13: EmitState = emit_uleb128(s12, dst);
        let s14: EmitState = emit_uleb128(s13, 0);
        let s15: EmitState = emit_uleb128(s14, 0);
        __mind_store_i64(okcell, dst);
        return s15;
    }
    // recursive case: then-block is the next nested if.
    if ast_kind(inner) == ast_if() {
        let s5: EmitState = emit_uleb128(s4, 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let inner_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_cell, 0 - 1);
        let s7: EmitState = emit_if_chain_instr(s6, inner, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, inner_cell);
        let inner_dst: i64 = __mind_load_i64(inner_cell);
        if inner_dst < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let s8: EmitState = emit_uleb128(s7, inner_dst);
        let else_synth: i64 = inner_dst + 1;
        let s9: EmitState = emit_uleb128(s8, 1);
        let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
        let s11: EmitState = emit_uleb128(s10, else_synth);
        let dst: i64 = inner_dst + 2;
        let s12: EmitState = emit_uleb128(s11, dst);
        let s13: EmitState = emit_uleb128(s12, 0);
        let s14: EmitState = emit_uleb128(s13, 0);
        __mind_store_i64(okcell, dst);
        return s14;
    }
    __mind_store_i64(okcell, 0 - 1);
    s
}

// Emit a SEQUENCE of if-segments (the then-block of a type-3 if), each an
// arbitrary-depth nested if-return chain, threading the running vid base. Returns
// the post-emit EmitState; writes the LAST segment's dst (the sequence's value vid)
// to `dst_cell`, or -1 on any wall. Each segment is one top-level OP_IF instr,
// emitted by emit_if_chain_instr (which self-flattens its cond/ret trees into the
// shared scratch via flatten_branch — cursor-resetting, so segments are isolated).
pub fn emit_if_seq_segments(s: EmitState, stmts_addr: i64, stmts_len: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, last_dst: i64, dst_cell: i64, i: i64) -> EmitState {
    if i >= stmts_len {
        __mind_store_i64(dst_cell, last_dst);
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    let seg_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seg_cell, 0 - 1);
    let s1: EmitState = emit_if_chain_instr(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, seg_cell);
    let seg_dst: i64 = __mind_load_i64(seg_cell);
    if seg_dst < 0 {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    emit_if_seq_segments(s1, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_dst + 1, seg_dst, dst_cell, i + 1)
}

// Emit the OP_IF body instruction for a type-3 if: an else-less `if COND { <SEQ of
// if-return / nested-if-chain statements, NO lets, NO trailing value> }`. The
// then-block is a sequence of if-segments emitted in order, each one top-level
// OP_IF; the then-result is the LAST segment's dst (the block falls through to the
// next outer statement). Mirrors emit_if_chain_instr's outer framing but with a
// multi-segment then-branch. Byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
pub fn emit_if_seq_then_instr(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    if stmts_len < 2 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0, 0, 0, 0, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // then_len = leading synth + 1 OP_IF per then-segment.
    let s5: EmitState = emit_uleb128(s4, stmts_len + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let s7: EmitState = emit_if_seq_segments(s6, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, after_cond, seq_cell, 0);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // then-result = last segment dst.
    let s8: EmitState = emit_uleb128(s7, last_dst);
    let else_synth: i64 = last_dst + 1;
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_uleb128(s10, else_synth);
    let dst: i64 = last_dst + 2;
    let s12: EmitState = emit_uleb128(s11, dst);
    let s13: EmitState = emit_uleb128(s12, 0);
    let s14: EmitState = emit_uleb128(s13, 0);
    __mind_store_i64(okcell, dst);
    s14
}

// ===========================================================================
// LET-VID-aware if-chain / if-seq emit (6c prep) — thread an lv-env
// ===========================================================================
//
// _lv mirrors of emit_if_chain_instr / emit_if_seq_segments / emit_if_seq_then_instr
// that thread an lv-environment (lvenv/nlv) down to the flatten + count helpers so a
// then-block let reference resolves to its value vid. With nlv == 0 the _lv variants
// are BYTE-FOR-BYTE equivalent to the non-lv ones (lvenv_lookup never matches), so
// routing the type-3 if-with-SEQ-then-block through them with an empty lv-env changes
// NO bytes (Bound by MIND-CONSTITUTION §I). 6c-2 populates the lv-env to deliver the
// lets-in-then capability.

// Emit ValueId(usize::MAX) — the SSA POISON / undef marker the Rust lowering uses
// for a merge's then_val when the then-branch RETURNS (does not fall through, so the
// variable has no then-edge value). u64::MAX as uleb128 = nine 0xFF bytes then 0x01.
pub fn emit_poison_vid(s: EmitState) -> EmitState {
    let a: EmitState = es_push(s, 255);
    let b: EmitState = es_push(a, 255);
    let c: EmitState = es_push(b, 255);
    let d: EmitState = es_push(c, 255);
    let e: EmitState = es_push(d, 255);
    let f: EmitState = es_push(e, 255);
    let g: EmitState = es_push(f, 255);
    let h: EmitState = es_push(g, 255);
    let i9: EmitState = es_push(h, 255);
    es_push(i9, 1)
}

// `binds` is an array of 32-byte escaping-binding records: [0]=name_lo, [8]=name_hi,
// [16]=this-level merge_id, [24]=then_val (the value on the then-edge, or -1 = poison
// when the then-branch returns). These three helpers fill + emit the OP_IF merge tail.

// CASE A fill: each leading then-block let escapes with then_val = POISON (-1) because
// the then-block ends in `return` (no then-edge). merge_id = else_synth+2+2*i.
pub fn fill_binds_caseA(binds: i64, then_sa: i64, nlets: i64, else_synth: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    let stmt: i64 = __mind_load_i64(then_sa + i * 8);
    let name: i64 = ast_child0(stmt);
    __mind_store_i64(binds + i * 32 + 0, ast_span_lo(name));
    __mind_store_i64(binds + i * 32 + 8, ast_span_hi(name));
    __mind_store_i64(binds + i * 32 + 16, else_synth + 2 + 2 * i);
    __mind_store_i64(binds + i * 32 + 24, 0 - 1);
    fill_binds_caseA(binds, then_sa, nlets, else_synth, i + 1)
}

// CASE B fill: the inner if's escaping bindings (24-byte name_lo/name_hi/merge_id
// triples) re-merge at THIS level with then_val = the inner merge_id (the value of the
// name after the inner if, which the then-block falls through to). merge_id = else_synth+2+2*i.
pub fn fill_binds_caseB(binds: i64, inner_bind: i64, n: i64, else_synth: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(binds + i * 32 + 0, __mind_load_i64(inner_bind + i * 24 + 0));
    __mind_store_i64(binds + i * 32 + 8, __mind_load_i64(inner_bind + i * 24 + 8));
    __mind_store_i64(binds + i * 32 + 16, else_synth + 2 + 2 * i);
    __mind_store_i64(binds + i * 32 + 24, __mind_load_i64(inner_bind + i * 24 + 16));
    fill_binds_caseB(binds, inner_bind, n, else_synth, i + 1)
}

// Emit the n_bindings list: (name_idx, merge_id) per escaping binding.
pub fn emit_chain_bindings(s: EmitState, binds: i64, n: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let lo: i64 = __mind_load_i64(binds + i * 32 + 0);
    let hi: i64 = __mind_load_i64(binds + i * 32 + 8);
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, lo, hi, 0);
    let mid: i64 = __mind_load_i64(binds + i * 32 + 16);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_chain_bindings(s2, binds, n, strbuf, offs, ncount, src, i + 1)
}

// Emit the n_merges list: (merge_id, then_val, else_val=placeholder) per binding.
// then_val == -1 emits the poison vid; placeholder_i = else_synth+1+2*i.
pub fn emit_chain_merges(s: EmitState, binds: i64, n: i64, else_synth: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let mid: i64 = __mind_load_i64(binds + i * 32 + 16);
    let tv: i64 = __mind_load_i64(binds + i * 32 + 24);
    let ph: i64 = else_synth + 1 + 2 * i;
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = if tv == 0 - 1 {
        emit_poison_vid(s1)
    } else {
        emit_uleb128(s1, tv)
    };
    let s3: EmitState = emit_uleb128(s2, ph);
    emit_chain_merges(s3, binds, n, else_synth, i + 1)
}

// MIXED returning then-block — GENERAL ordered walk. The then-block is an arbitrary
// sequence of `let NAME = INIT` (incl. if-expr inits) and else-less if-segments
// (each an if-return chain), terminating in `return E`. Every then-block let escapes
// as a branch_binding + merge, as does every segment's bubbled binding; because the
// block RETURNS (then_falls_through==false, lower.rs F2) ALL then_vals are POISON.
// Bindings are accumulated in SOURCE WRITE ORDER (a let when emitted, a segment's
// bindings at its position). bindout/nbind_cell expose this level's bindings upward.

// Validate the mixed shape: every stmt before the last is a let or an else-less if,
// the last is `return E`, with >=1 if-segment. Returns n_segs (>=1) or -1.
pub fn mixed_shape_segs(stmts_addr: i64, stmts_len: i64, i: i64, nseg: i64) -> i64 {
    if i >= stmts_len - 1 {
        let last: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
        if ast_kind(last) != ast_return() {
            return 0 - 1;
        }
        return nseg;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_let() {
        return mixed_shape_segs(stmts_addr, stmts_len, i + 1, nseg);
    }
    if k == ast_if() {
        if ast_child2(stmt) != 0 {
            return 0 - 1;
        }
        return mixed_shape_segs(stmts_addr, stmts_len, i + 1, nseg + 1);
    }
    // A bare expression-statement (a call/binop used for its side effect — e.g.
    // `__mind_store_i64(cell, v);`). It emits its instr tree but binds no name and
    // creates no merge. Accept it as a prefix statement (does not count as a segment).
    mixed_shape_segs(stmts_addr, stmts_len, i + 1, nseg)
}

// Measuring walk: top-level body-instr count of the prefix stmts[0..n) (a let = its
// init instr count, or 1 for an if-expr init; an if-segment = 1 OP_IF). Populates
// lvbuf NAMES (vid 0) so a later stmt referencing an earlier let resolves.
pub fn measure_mixed_instrs(stmts_addr: i64, n: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, lvbuf: i64, nlv_cell: i64) -> i64 {
    if idx >= n {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    if ast_kind(stmt) == ast_while() {
        // A statement while lowers to OP_WHILE + a trailing unit ConstI64 = 2 top-level
        // instrs. It rebinds (does not introduce) loop-carried names, so no lvbuf growth.
        return 2 + measure_mixed_instrs(stmts_addr, n, idx + 1, buf, params_addr, n_params, lvbuf, nlv_cell);
    }
    if ast_kind(stmt) == ast_if() {
        // An if-segment lowers to a single OP_IF instruction.
        return 1 + measure_mixed_instrs(stmts_addr, n, idx + 1, buf, params_addr, n_params, lvbuf, nlv_cell);
    }
    if ast_kind(stmt) != ast_let() {
        // A bare expression-statement contributes its FULL instr tree (not 1) and
        // binds no name (no lv-env entry).
        let be_nlv: i64 = __mind_load_i64(nlv_cell);
        let be_c: i64 = count_nonparam_nodes_lv(stmt, buf, params_addr, n_params, lvbuf, be_nlv);
        return be_c + measure_mixed_instrs(stmts_addr, n, idx + 1, buf, params_addr, n_params, lvbuf, nlv_cell);
    }
    let nlv: i64 = __mind_load_i64(nlv_cell);
    let init: i64 = ast_child2(stmt);
    let c: i64 = if is_any_value_if_expr(init) == 1 {
        1
    } else {
        count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv)
    };
    let name: i64 = ast_child0(stmt);
    __mind_store_i64(lvbuf + nlv * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + nlv * 24 + 8, ast_span_hi(name));
    __mind_store_i64(lvbuf + nlv * 24 + 16, 0);
    __mind_store_i64(nlv_cell, nlv + 1);
    c + measure_mixed_instrs(stmts_addr, n, idx + 1, buf, params_addr, n_params, lvbuf, nlv_cell)
}

// Emit walk: process prefix stmts[0..n) in order, threading the vid base (base_cell),
// the lv-env (lvbuf + nlv_cell), and the ordered escaping-binding NAME accumulator
// (acc 24B name records + acc_cell count). A let emits its init (if-expr or normal),
// binds NAME->its value vid, records NAME. A segment emits its OP_IF and appends its
// bubbled bindings. okcell <- 0 on any wall.
pub fn emit_mixed_walk(s: EmitState, stmts_addr: i64, n: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base_cell: i64, lvbuf: i64, nlv_cell: i64, acc: i64, acc_cell: i64, okcell: i64, strbuf: i64, offs: i64, ncount: i64, esc_to_lv: i64) -> EmitState {
    if idx >= n {
        return s;
    }
    if __mind_load_i64(okcell) == 0 {
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    let nlv: i64 = __mind_load_i64(nlv_cell);
    let cur_base: i64 = __mind_load_i64(base_cell);
    if ast_kind(stmt) == ast_while() {
        // WHILE statement inside a value-if branch / mixed block. Emit one OP_WHILE (via
        // emit_mic3_while_general) at the threaded base, then the trailing unit ConstI64.
        // REBIND each loop-carried var -> its exit_id in `lvbuf` so a later read AND the
        // branch trailing value resolve to the dominating exit id (lower.rs F2 exit-rebind).
        // The carried vars are pre-existing lvbuf bindings (an outer let or an earlier
        // branch-local let), so this is a pure overlay — no new acc/merge entry of its own.
        let w_merge: i64 = __mind_alloc(64 * 24);
        let w_nm: i64 = __mind_alloc(8);
        __mind_store_i64(w_nm, 0);
        let w_end: i64 = __mind_alloc(8);
        __mind_store_i64(w_end, 0 - 1);
        let w_ok: i64 = __mind_alloc(8);
        __mind_store_i64(w_ok, 1);
        let sw: EmitState = emit_mic3_while_general(s, stmt, buf, params_addr, n_params, cur_base, lvbuf, nlv, strbuf, offs, ncount, w_merge, w_nm, w_end, w_ok);
        if __mind_load_i64(w_ok) == 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        // trailing unit ConstI64 at endbase (= one past the exit_ids).
        let sw2: EmitState = emit_mic3_const_i64(sw, __mind_load_i64(w_end), 0);
        // Overlay each carried var name -> exit_id into lvbuf (innermost binding).
        let _ov: i64 = mixed_while_rebind(buf, lvbuf, nlv, w_merge, __mind_load_i64(w_nm), 0);
        // Mirror the rebind into acc (the binding's then-value for a poison/merge tail).
        let _ova: i64 = mixed_while_rebind_acc(buf, acc, __mind_load_i64(acc_cell), w_merge, __mind_load_i64(w_nm), 0);
        // base advances past OP_WHILE vids + the trailing unit (endbase + 1).
        __mind_store_i64(base_cell, __mind_load_i64(w_end) + 1);
        return emit_mixed_walk(sw2, stmts_addr, n, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv_cell, acc, acc_cell, okcell, strbuf, offs, ncount, esc_to_lv);
    }
    if ast_kind(stmt) == ast_if() {
        let seg_cell: i64 = __mind_alloc(8);
        __mind_store_i64(seg_cell, 0 - 1);
        let seg_bind: i64 = __mind_alloc(64 * 24);
        let seg_nb: i64 = __mind_alloc(8);
        // A two-sided `if C {..} else {..}` STATEMENT segment delegates to the two-sided
        // fall-through emitter (recursive); an else-less if stays on the chain emitter.
        let s1: EmitState = if ast_child2(stmt) != 0 {
            emit_if_else_fallthrough_lv(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, seg_cell, lvbuf, nlv, 0, strbuf, offs, ncount, seg_bind, seg_nb)
        } else {
            emit_if_chain_instr_lv(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, seg_cell, lvbuf, nlv, strbuf, offs, ncount, seg_bind, seg_nb)
        };
        let seg_dst: i64 = __mind_load_i64(seg_cell);
        if seg_dst < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        let _ap: i64 = bind_append(acc, acc_cell, seg_bind, __mind_load_i64(seg_nb), 0);
        // FALL-THROUGH walks (esc_to_lv==1): a segment's escaping bindings are LIVE for the
        // rest of the block, so a later statement that REDEFINES one of these names (a shadow)
        // sees the outer vid in the env and its own merge reuses it (bound, no placeholder).
        // VALUE-branch walks (esc_to_lv==0) keep nlv == direct lets (their merge tail + the
        // acc==nlets guard depend on it), so they do NOT grow the env here.
        if esc_to_lv == 1 {
            let _le: i64 = lvenv_append_escapes(lvbuf, nlv, seg_bind, __mind_load_i64(seg_nb), 0);
            __mind_store_i64(nlv_cell, nlv + __mind_load_i64(seg_nb))
        }
        __mind_store_i64(base_cell, seg_dst + 1);
        return emit_mixed_walk(s1, stmts_addr, n, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv_cell, acc, acc_cell, okcell, strbuf, offs, ncount, esc_to_lv);
    }
    if ast_kind(stmt) != ast_let() {
        // Bare expression-statement (call/binop used for its side effect). Emit its
        // instr tree, advance the vid base, but bind NO name and accumulate NO merge.
        let be_root: i64 = flatten_branch_lv(stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, lvbuf, nlv);
        if be_root < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        let be_n: i64 = __mind_load_i64(cursor);
        let be_nn: i64 = count_nonparam_nodes_lv(stmt, buf, params_addr, n_params, lvbuf, nlv);
        let be_s: EmitState = emit_mic3_tree_body(s, nodes, be_n, vidbuf, buf, strbuf, offs, ncount, 0);
        __mind_store_i64(base_cell, cur_base + be_nn);
        return emit_mixed_walk(be_s, stmts_addr, n, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv_cell, acc, acc_cell, okcell, strbuf, offs, ncount, esc_to_lv);
    }
    let name: i64 = ast_child0(stmt);
    let init: i64 = ast_child2(stmt);
    let s2: EmitState = if is_any_value_if_expr(init) == 1 {
        let q_cell: i64 = __mind_alloc(8);
        __mind_store_i64(q_cell, 0 - 1);
        let sq: EmitState = emit_if_expr_any_lv(s, init, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, q_cell, lvbuf, nlv, strbuf, offs, ncount, 0, 0);
        let qdst: i64 = __mind_load_i64(q_cell);
        if qdst < 0 {
            __mind_store_i64(okcell, 0);
            sq
        } else {
            __mind_store_i64(lvbuf + nlv * 24 + 16, qdst);
            __mind_store_i64(base_cell, qdst + 1);
            sq
        }
    } else {
        let root: i64 = flatten_branch_lv(init, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, lvbuf, nlv);
        if root < 0 {
            __mind_store_i64(okcell, 0);
            s
        } else {
            let init_n: i64 = __mind_load_i64(cursor);
            let nn: i64 = count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv);
            let se: EmitState = emit_mic3_tree_body(s, nodes, init_n, vidbuf, buf, strbuf, offs, ncount, 0);
            __mind_store_i64(lvbuf + nlv * 24 + 16, root);
            __mind_store_i64(base_cell, cur_base + nn);
            se
        }
    };
    if __mind_load_i64(okcell) == 0 {
        return s2;
    }
    __mind_store_i64(lvbuf + nlv * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + nlv * 24 + 8, ast_span_hi(name));
    __mind_store_i64(nlv_cell, nlv + 1);
    let at: i64 = __mind_load_i64(acc_cell);
    __mind_store_i64(acc + at * 24 + 0, ast_span_lo(name));
    __mind_store_i64(acc + at * 24 + 8, ast_span_hi(name));
    // acc[+16] = this binding's THEN-value: a direct let's own vid (here) OR, for an
    // if-segment's bubbled binding (bind_append), the inner merge_id. Uniform across both
    // so a fall-through merge tail can read then_val from acc. (POISON-tail callers ignore it.)
    __mind_store_i64(acc + at * 24 + 16, __mind_load_i64(lvbuf + nlv * 24 + 16));
    __mind_store_i64(acc_cell, at + 1);
    emit_mixed_walk(s2, stmts_addr, n, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv_cell, acc, acc_cell, okcell, strbuf, offs, ncount, esc_to_lv)
}

// Overlay each loop-carried var (name -> exit_id from `merge`) into the INNERMOST `lvbuf`
// binding of that name, so a post-while read/value resolves to the dominating exit id.
pub fn mixed_while_rebind(src: i64, lvbuf: i64, nlv: i64, merge: i64, nm: i64, i: i64) -> i64 {
    if i >= nm {
        return nm;
    }
    let lo: i64 = __mind_load_i64(merge + i * 24 + 0);
    let hi: i64 = __mind_load_i64(merge + i * 24 + 8);
    let exit_id: i64 = __mind_load_i64(merge + i * 24 + 16);
    let pos: i64 = lvenv_index_of(src, lo, hi, lvbuf, nlv);
    if pos >= 0 {
        __mind_store_i64(lvbuf + pos * 24 + 16, exit_id)
    }
    mixed_while_rebind(src, lvbuf, nlv, merge, nm, i + 1)
}

// Mirror the exit-id rebind into the acc accumulator's then-value slot (+16), so a
// fall-through poison/merge tail reads the carried var's post-loop value. No-op if the
// name is not in acc (a body-local-only carried var that never reached the merge set).
pub fn mixed_while_rebind_acc(src: i64, acc: i64, nacc: i64, merge: i64, nm: i64, i: i64) -> i64 {
    if i >= nm {
        return nm;
    }
    let lo: i64 = __mind_load_i64(merge + i * 24 + 0);
    let hi: i64 = __mind_load_i64(merge + i * 24 + 8);
    let exit_id: i64 = __mind_load_i64(merge + i * 24 + 16);
    let pos: i64 = lv_find(acc, nacc, src, lo, hi);
    if pos >= 0 {
        __mind_store_i64(acc + pos * 24 + 16, exit_id)
    }
    mixed_while_rebind_acc(src, acc, nacc, merge, nm, i + 1)
}

// Fill 32-byte bind records from the ordered NAME accumulator (acc), all POISON.
pub fn fill_binds_acc(binds: i64, acc: i64, n: i64, else_synth: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(binds + i * 32 + 0, __mind_load_i64(acc + i * 24 + 0));
    __mind_store_i64(binds + i * 32 + 8, __mind_load_i64(acc + i * 24 + 8));
    __mind_store_i64(binds + i * 32 + 16, else_synth + 2 + 2 * i);
    __mind_store_i64(binds + i * 32 + 24, 0 - 1);
    fill_binds_acc(binds, acc, n, else_synth, i + 1)
}

// FALL-THROUGH merge tail from the acc accumulator (direct lets AND bubbled if-segment
// bindings). Each binding i: name = acc[i] (interned), merge_id = else_synth+2+2*i,
// then_val = acc[i].+16 (the binding's own value), else_val = placeholder else_synth+1+2*i.
pub fn emit_merge_bindings_acc(s: EmitState, acc: i64, n: i64, else_synth: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, __mind_load_i64(acc + i * 24 + 0), __mind_load_i64(acc + i * 24 + 8), 0);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, else_synth + 2 + 2 * i);
    emit_merge_bindings_acc(s2, acc, n, else_synth, strbuf, offs, ncount, src, i + 1)
}
pub fn emit_merge_triples_acc(s: EmitState, acc: i64, n: i64, else_synth: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, else_synth + 2 + 2 * i);
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(acc + i * 24 + 16));
    let s3: EmitState = emit_uleb128(s2, else_synth + 1 + 2 * i);
    emit_merge_triples_acc(s3, acc, n, else_synth, i + 1)
}
pub fn acc_to_bindout(acc: i64, n: i64, else_synth: i64, bindout: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(acc + i * 24 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(acc + i * 24 + 8));
    __mind_store_i64(bindout + i * 24 + 16, else_synth + 2 + 2 * i);
    acc_to_bindout(acc, n, else_synth, bindout, i + 1)
}

pub fn emit_if_mixed_then_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_blk: i64 = ast_child1(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let n_segs: i64 = mixed_shape_segs(then_sa, then_sl, 0, 0);
    if n_segs < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let final_stmt: i64 = __mind_load_i64(then_sa + (then_sl - 1) * 8);
    let cond_expr: i64 = ast_child0(if_node);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let n_prefix: i64 = then_sl - 1;
    let nlets_total: i64 = then_sl - 1 - n_segs;
    let lvbuf: i64 = __mind_alloc((nlv + nlets_total + 2) * 24);
    let _cp: i64 = lvenv_copy(lvbuf, lvenv, nlv, 0);
    let m_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(m_nlv, nlv);
    let prefix_instrs: i64 = measure_mixed_instrs(then_sa, n_prefix, 0, buf, params_addr, n_params, lvbuf, m_nlv);
    let ret_expr: i64 = ast_child0(final_stmt);
    // Use the ACTUAL let count measure_mixed_instrs accumulated (bare expression-
    // statements in the prefix add instrs but NO lv-env entry), not n_prefix - n_segs.
    let nlv_total: i64 = __mind_load_i64(m_nlv);
    let ret_nonparam: i64 = count_nonparam_nodes_lv(ret_expr, buf, params_addr, n_params, lvbuf, nlv_total);
    if ret_nonparam < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_len: i64 = 1 + prefix_instrs + ret_nonparam + 1;
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let _cp2: i64 = lvenv_copy(lvbuf, lvenv, nlv, 0);
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, after_cond + 1);
    let e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(e_nlv, nlv);
    let acc: i64 = __mind_alloc(128 * 24);
    let acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(acc_cell, 0);
    let w_ok: i64 = __mind_alloc(8);
    __mind_store_i64(w_ok, 1);
    let s7: EmitState = emit_mixed_walk(s6, then_sa, n_prefix, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, e_nlv, acc, acc_cell, w_ok, strbuf, offs, ncount, 0);
    if __mind_load_i64(w_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let ret_base: i64 = __mind_load_i64(base_cell);
    let ret_root: i64 = flatten_branch_lv(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, ret_base, lvbuf, nlv_total);
    if ret_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let ret_n: i64 = __mind_load_i64(cursor);
    let s8: EmitState = emit_mic3_tree_body(s7, nodes, ret_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let s9: EmitState = emit_mic3_return(s8, 1, ret_root);
    let s10: EmitState = emit_uleb128(s9, ret_root);
    let nb: i64 = __mind_load_i64(acc_cell);
    let else_synth: i64 = ret_base + ret_nonparam;
    // Divergent (returns) -> POISON then_val for fresh bindings; a binding whose name is
    // already live in the outer env keeps that vid (then=else=outer, no placeholder).
    let lay: i64 = __mind_alloc((nb + 1) * 48);
    let dst: i64 = caseA_layout_acc(lay, acc, nb, buf, lvbuf, nlv, 0, else_synth + 1);
    let else_len: i64 = 1 + caseA_fresh_count(lay, nb, 0);
    let s11: EmitState = emit_uleb128(s10, else_len);
    let s12: EmitState = emit_mic3_const_i64(s11, else_synth, 0);
    let s13: EmitState = caseA_emit_placeholders(s12, lay, nb, 0);
    let s14: EmitState = emit_uleb128(s13, else_synth);
    let s15: EmitState = emit_uleb128(s14, dst);
    let s16: EmitState = emit_uleb128(s15, nb);
    let s17: EmitState = caseA_emit_bindings(s16, lay, nb, strbuf, offs, ncount, buf, 0);
    let s18: EmitState = emit_uleb128(s17, nb);
    let s19: EmitState = caseA_emit_merges(s18, lay, nb, 0);
    let _bo: i64 = caseA_lay_to_bindout(lay, bindout, nb, 0);
    __mind_store_i64(nbind_cell, nb);
    __mind_store_i64(okcell, dst);
    s19
}

// Copy the binds (32-byte records) into the caller's 24-byte bindout (name_lo,
// name_hi, this-level merge_id) so the enclosing if can re-merge them (bubble up).
pub fn binds_to_bindout(binds: i64, bindout: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(binds + i * 32 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(binds + i * 32 + 8));
    __mind_store_i64(bindout + i * 24 + 16, __mind_load_i64(binds + i * 32 + 16));
    binds_to_bindout(binds, bindout, n, i + 1)
}

// CASE-A merge layout that distinguishes FRESH vs already-BOUND lets. For each then-block
// let (in source order) look up its name in the OUTER lv-env [0,nlv): a HIT means the name
// was already live (a prior segment bound it, OR an outer let) -> the divergent block keeps
// that value, so merge then_val = else_val = the outer vid and NO placeholder const is
// emitted; a MISS means the name is fresh -> then_val = POISON, else_val = a fresh
// placeholder const (vid `running`) emitted in the else block. Running vid advances by 2 per
// fresh let (placeholder + merge_id) and 1 per bound let (merge_id only). Fills a 48-byte
// `lay` per let [name_lo,name_hi,merge_id,then_val,else_val,is_fresh] and returns the OP_IF
// dst (final running). For an all-fresh block this reproduces the old fixed 2-per-let layout
// byte-for-byte. Mirrors src/eval/lower.rs F2 phi construction over a diverging then-edge.
pub fn caseA_layout(lay: i64, then_sa: i64, nlets: i64, buf: i64, lvbuf: i64, nlv: i64, i: i64, running: i64) -> i64 {
    if i >= nlets {
        return running;
    }
    let stmt: i64 = __mind_load_i64(then_sa + i * 8);
    let name: i64 = ast_child0(stmt);
    let nlo: i64 = ast_span_lo(name);
    let nhi: i64 = ast_span_hi(name);
    let outer: i64 = lvenv_lookup(buf, nlo, nhi, lvbuf, nlv, 0);
    __mind_store_i64(lay + i * 48 + 0, nlo);
    __mind_store_i64(lay + i * 48 + 8, nhi);
    if outer >= 0 {
        __mind_store_i64(lay + i * 48 + 16, running);
        __mind_store_i64(lay + i * 48 + 24, outer);
        __mind_store_i64(lay + i * 48 + 32, outer);
        __mind_store_i64(lay + i * 48 + 40, 0);
        return caseA_layout(lay, then_sa, nlets, buf, lvbuf, nlv, i + 1, running + 1);
    }
    __mind_store_i64(lay + i * 48 + 16, running + 1);
    __mind_store_i64(lay + i * 48 + 24, 0 - 1);
    __mind_store_i64(lay + i * 48 + 32, running);
    __mind_store_i64(lay + i * 48 + 40, 1);
    caseA_layout(lay, then_sa, nlets, buf, lvbuf, nlv, i + 1, running + 2)
}
// ELSE-block placeholder count = number of FRESH lets (each adds one const 0).
pub fn caseA_fresh_count(lay: i64, nlets: i64, i: i64) -> i64 {
    if i >= nlets {
        return 0;
    }
    __mind_load_i64(lay + i * 48 + 40) + caseA_fresh_count(lay, nlets, i + 1)
}
// Emit one CONST 0 per FRESH let at its placeholder vid (else_val), in source order.
pub fn caseA_emit_placeholders(s: EmitState, lay: i64, nlets: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    if __mind_load_i64(lay + i * 48 + 40) == 1 {
        let s1: EmitState = emit_mic3_const_i64(s, __mind_load_i64(lay + i * 48 + 32), 0);
        return caseA_emit_placeholders(s1, lay, nlets, i + 1);
    }
    caseA_emit_placeholders(s, lay, nlets, i + 1)
}
// Emit (name_idx, merge_id) per let.
pub fn caseA_emit_bindings(s: EmitState, lay: i64, nlets: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, __mind_load_i64(lay + i * 48 + 0), __mind_load_i64(lay + i * 48 + 8), 0);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(lay + i * 48 + 16));
    caseA_emit_bindings(s2, lay, nlets, strbuf, offs, ncount, src, i + 1)
}
// Emit (merge_id, then_val|POISON, else_val) per let.
pub fn caseA_emit_merges(s: EmitState, lay: i64, nlets: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(lay + i * 48 + 16));
    let tv: i64 = __mind_load_i64(lay + i * 48 + 24);
    let s2: EmitState = if tv == 0 - 1 {
        emit_poison_vid(s1)
    } else {
        emit_uleb128(s1, tv)
    };
    let s3: EmitState = emit_uleb128(s2, __mind_load_i64(lay + i * 48 + 32));
    caseA_emit_merges(s3, lay, nlets, i + 1)
}
// Copy (name_lo, name_hi, merge_id) per let to bindout (24-byte) for outer bubble-up.
pub fn caseA_lay_to_bindout(lay: i64, bindout: i64, nlets: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(lay + i * 48 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(lay + i * 48 + 8));
    __mind_store_i64(bindout + i * 24 + 16, __mind_load_i64(lay + i * 48 + 16));
    caseA_lay_to_bindout(lay, bindout, nlets, i + 1)
}

// Same as caseA_lay_to_bindout but reads 56-byte two-sided `bl` (blk_layout) entries:
// [name_lo, name_hi, merge_id, then_val, else_val, is_fresh, is_then]. Copies (name_lo,
// name_hi, merge_id) into 24-byte bindout records so an enclosing if-expr can bubble the
// nested if-expr's merged bindings up into its own merge tail (else_val = merge_id = the
// value the binding holds after the nested if-expr).
pub fn blk_lay_to_bindout(bl: i64, bindout: i64, nlets: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(bl + i * 64 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(bl + i * 64 + 8));
    __mind_store_i64(bindout + i * 24 + 16, __mind_load_i64(bl + i * 64 + 16));
    blk_lay_to_bindout(bl, bindout, nlets, i + 1)
}

// CASE-B merge layout (nested if that FALLS THROUGH to an inner if): each inner escaping
// binding re-merges here with then_val = the inner merge_id (the value the then-branch
// produced). The same fresh/bound rule as CASE A applies to the ELSE side: a name already
// live in the OUTER env [0,nlv) keeps that vid (else_val = outer_vid, NO placeholder, 1 vid);
// a fresh name gets a placeholder const (else_val = placeholder, 2 vids). Shares the caseA_*
// emit helpers (then_val is stored per-let, never POISON in CASE B). Fills a 48-byte `lay`
// per binding and returns the OP_IF dst. All-fresh reproduces the old fixed layout exactly.
pub fn caseB_layout(lay: i64, inner_bind: i64, nb: i64, buf: i64, lvbuf: i64, nlv: i64, i: i64, running: i64) -> i64 {
    if i >= nb {
        return running;
    }
    let nlo: i64 = __mind_load_i64(inner_bind + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(inner_bind + i * 24 + 8);
    let inner_mid: i64 = __mind_load_i64(inner_bind + i * 24 + 16);
    let outer: i64 = lvenv_lookup(buf, nlo, nhi, lvbuf, nlv, 0);
    __mind_store_i64(lay + i * 48 + 0, nlo);
    __mind_store_i64(lay + i * 48 + 8, nhi);
    __mind_store_i64(lay + i * 48 + 24, inner_mid);
    if outer >= 0 {
        __mind_store_i64(lay + i * 48 + 16, running);
        __mind_store_i64(lay + i * 48 + 32, outer);
        __mind_store_i64(lay + i * 48 + 40, 0);
        return caseB_layout(lay, inner_bind, nb, buf, lvbuf, nlv, i + 1, running + 1);
    }
    __mind_store_i64(lay + i * 48 + 16, running + 1);
    __mind_store_i64(lay + i * 48 + 32, running);
    __mind_store_i64(lay + i * 48 + 40, 1);
    caseB_layout(lay, inner_bind, nb, buf, lvbuf, nlv, i + 1, running + 2)
}

// CASE-A merge layout but reading binding NAMES from the `acc` accumulator (name at +0/+8)
// instead of the let-statement list — for a DIVERGENT block (returns) whose escaping
// bindings (direct lets + bubbled if-segment bindings) come from a mixed walk. Same rule as
// caseA_layout: a name already live in the outer env keeps its vid (then=else=outer, no
// placeholder); a fresh name gets POISON then + a placeholder else. Used by the mixed
// returning-then-block emitter.
pub fn caseA_layout_acc(lay: i64, acc: i64, nb: i64, buf: i64, lvbuf: i64, nlv: i64, i: i64, running: i64) -> i64 {
    if i >= nb {
        return running;
    }
    let nlo: i64 = __mind_load_i64(acc + i * 24 + 0);
    let nhi: i64 = __mind_load_i64(acc + i * 24 + 8);
    let outer: i64 = lvenv_lookup(buf, nlo, nhi, lvbuf, nlv, 0);
    __mind_store_i64(lay + i * 48 + 0, nlo);
    __mind_store_i64(lay + i * 48 + 8, nhi);
    if outer >= 0 {
        __mind_store_i64(lay + i * 48 + 16, running);
        __mind_store_i64(lay + i * 48 + 24, outer);
        __mind_store_i64(lay + i * 48 + 32, outer);
        __mind_store_i64(lay + i * 48 + 40, 0);
        return caseA_layout_acc(lay, acc, nb, buf, lvbuf, nlv, i + 1, running + 1);
    }
    __mind_store_i64(lay + i * 48 + 16, running + 1);
    __mind_store_i64(lay + i * 48 + 24, 0 - 1);
    __mind_store_i64(lay + i * 48 + 32, running);
    __mind_store_i64(lay + i * 48 + 40, 1);
    caseA_layout_acc(lay, acc, nb, buf, lvbuf, nlv, i + 1, running + 2)
}

// Recursive nested-if-CHAIN segment emitter WITH SSA binding bubble-up. The then-block
// is `let* + (return E | single nested-if)`. Every then-block let escapes its OP_IF as a
// branch_binding + merge (mirrors src/eval/lower.rs F2): when the then-block returns,
// then_val = POISON (no then-edge); when it falls through to a nested if, the inner if's
// escaping bindings re-merge here with then_val = the inner merge_id (bubble up). The
// escaping bindings are written to `bindout` (24-byte name_lo/name_hi/merge_id records)
// and counted in `nbind_cell` so the enclosing level re-merges them. okcell <- dst (-1
// on a wall). When no lets / no bubbled bindings (N==0) the tail is `0,0` —
// BYTE-IDENTICAL to the pre-6f emitter (all existing if-chain callers unaffected).
pub fn emit_if_chain_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_blk: i64 = ast_child1(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let nlets_then: i64 = count_leading_lets(then_sa, then_sl, 0);
    // (type 4 inside a chain) leading lets + >=1 if-SEGMENT (fall-through) — e.g.
    // `if A { if B { let prev_ok=..; if prev_ok==1 {return} } }`. Delegate to the
    // type-4 emitter (it emits cond + then[lets+segments] + merge tail) and expose its
    // leading-let bindings via bindout so THIS level's caller re-merges them.
    if nlets_then >= 1 {
        let cn_segs: i64 = then_sl - nlets_then;
        // cn_segs == 0 is a FALL-THROUGH guard `if C { let* }` (lets-only, no return/
        // segment) — route to the same type-4 emitter (handles n_segs==0), exposing the
        // leading-let merge bindings via bindout for this level's caller to re-merge.
        if cn_segs >= 0 {
            if seq_then_all_ifs(then_sa + nlets_then * 8, cn_segs, 0) == 1 {
                let d_lvbuf: i64 = __mind_alloc((nlv + nlets_then + 512) * 24);
                let d_cell: i64 = __mind_alloc(8);
                __mind_store_i64(d_cell, 0 - 1);
                let sd: EmitState = emit_if_let_seq_then_instr_lv(s, if_node, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, d_cell, lvenv, nlv, d_lvbuf, strbuf, offs, ncount, bindout, nbind_cell);
                let d_dst: i64 = __mind_load_i64(d_cell);
                __mind_store_i64(okcell, d_dst);
                return sd;
            }
        }
    }
    // (fall-through inside a chain) `if C { lets + bare-calls + if-segments }` with no
    // top-level return — route to the side-effect fall-through emitter (which handles
    // interleaved if-segments + bubbled bindings), exposing the merge bindings via bindout
    // for this level's caller to re-merge. (mixed_prefix_ok, not fallthrough_all_sidefx,
    // so a then-block of only/interleaved if-segments like `if c { if a{ret} if b{ret} }`
    // is handled.) Placed after the type-4 delegate (leading-lets + all-if-segments) and
    // before the mixed-RETURNING delegation (which needs a terminal return).
    if mixed_prefix_ok(then_sa, then_sl, 0) == 1 {
        let ftc_lvbuf: i64 = __mind_alloc((nlv + then_sl + 512) * 24);
        let ftc_cell: i64 = __mind_alloc(8);
        __mind_store_i64(ftc_cell, 0 - 1);
        let sftc: EmitState = emit_if_fallthrough_lv(s, if_node, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, ftc_cell, lvenv, nlv, ftc_lvbuf, strbuf, offs, ncount, bindout, nbind_cell);
        let ftc_dst: i64 = __mind_load_i64(ftc_cell);
        __mind_store_i64(okcell, ftc_dst);
        return sftc;
    }
    // (nested MIXED returning then-block inside a chain) `(let | bare-call | if-segment)*
    // + return` whose prefix is NOT pure leading-lets (>=1 bare-call or if-segment) — a
    // recursively-mixed block. Delegate to the mixed emitter; its emit_mixed_walk recurses
    // into any if-segment which re-enters HERE, delegating again for arbitrarily-nested
    // mixed segments. Pure `let* + return` (nlets_then == then_sl-1) stays on CASE A below.
    if nlets_then < then_sl - 1 {
        if mixed_shape_segs(then_sa, then_sl, 0, 0) >= 0 {
            let mx_cell: i64 = __mind_alloc(8);
            __mind_store_i64(mx_cell, 0 - 1);
            let smx: EmitState = emit_if_mixed_then_instr_lv(s, if_node, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, mx_cell, lvenv, nlv, strbuf, offs, ncount, bindout, nbind_cell);
            let mx_dst: i64 = __mind_load_i64(mx_cell);
            __mind_store_i64(okcell, mx_dst);
            return smx;
        }
    }
    if then_sl - nlets_then != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let final_stmt: i64 = __mind_load_i64(then_sa + nlets_then * 8);
    let fk: i64 = ast_kind(final_stmt);
    let cond_expr: i64 = ast_child0(if_node);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // Local lv-env = the incoming lv-env (nlv) plus this then-block's leading lets.
    let lvbuf: i64 = __mind_alloc((nlv + nlets_then + 2) * 24);
    let _cp: i64 = lvenv_copy(lvbuf, lvenv, nlv, 0);
    if fk == ast_return() {
        // CASE A — `let* + return E`. Lets escape with POISON then_val.
        let let_instrs: i64 = sum_let_init_nonparam(then_sa, nlets_then, 0, buf, params_addr, n_params, lvbuf, nlv);
        let ret_expr: i64 = ast_child0(final_stmt);
        let nlv_total: i64 = nlv + nlets_then;
        let ret_nonparam: i64 = count_nonparam_nodes_lv(ret_expr, buf, params_addr, n_params, lvbuf, nlv_total);
        let then_len: i64 = 1 + let_instrs + ret_nonparam + 1;
        let s5: EmitState = emit_uleb128(s4, then_len);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let base_cell: i64 = __mind_alloc(8);
        __mind_store_i64(base_cell, after_cond + 1);
        let li_ok: i64 = __mind_alloc(8);
        __mind_store_i64(li_ok, 1);
        let s7: EmitState = emit_let_inits_lv(s6, then_sa, nlets_then, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv, li_ok, strbuf, offs, ncount);
        if __mind_load_i64(li_ok) == 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        // Post-lets vid base from the threaded base_cell (NOT let_instrs — an
        // if-expr init is 1 instr but consumes its OP_IF's full vid delta).
        let seg_base: i64 = __mind_load_i64(base_cell);
        let ret_root: i64 = flatten_branch_lv(ret_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_base, lvbuf, nlv_total);
        if ret_root < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let ret_n: i64 = __mind_load_i64(cursor);
        let s8: EmitState = emit_mic3_tree_body(s7, nodes, ret_n, vidbuf, buf, strbuf, offs, ncount, 0);
        let s9: EmitState = emit_mic3_return(s8, 1, ret_root);
        let s10: EmitState = emit_uleb128(s9, ret_root);
        let else_synth: i64 = seg_base + ret_nonparam;
        let nb: i64 = nlets_then;
        // Per-let merge layout: a let whose name is already live in the OUTER env (a prior
        // segment's escaped binding, or an enclosing let) keeps that value across the
        // diverging then-edge (then_val=else_val=outer_vid, no placeholder); a fresh name
        // gets POISON then + a placeholder-const else. For all-fresh lets this is byte-
        // identical to the old fixed layout.
        let lay: i64 = __mind_alloc((nb + 1) * 48);
        let dst: i64 = caseA_layout(lay, then_sa, nb, buf, lvbuf, nlv, 0, else_synth + 1);
        let else_len: i64 = 1 + caseA_fresh_count(lay, nb, 0);
        let s11: EmitState = emit_uleb128(s10, else_len);
        let s12: EmitState = emit_mic3_const_i64(s11, else_synth, 0);
        let s13: EmitState = caseA_emit_placeholders(s12, lay, nb, 0);
        let s14: EmitState = emit_uleb128(s13, else_synth);
        let s15: EmitState = emit_uleb128(s14, dst);
        let s16: EmitState = emit_uleb128(s15, nb);
        let s17: EmitState = caseA_emit_bindings(s16, lay, nb, strbuf, offs, ncount, buf, 0);
        let s18: EmitState = emit_uleb128(s17, nb);
        let s19: EmitState = caseA_emit_merges(s18, lay, nb, 0);
        let _bo: i64 = caseA_lay_to_bindout(lay, bindout, nb, 0);
        __mind_store_i64(nbind_cell, nb);
        __mind_store_i64(okcell, dst);
        return s19;
    }
    if fk == ast_if() {
        if nlets_then != 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        // CASE B — single nested if. Recurse; the inner's escaping bindings bubble up.
        let s5: EmitState = emit_uleb128(s4, 2);
        let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
        let inner_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_cell, 0 - 1);
        let inner_bind: i64 = __mind_alloc((then_sl + 8) * 24);
        let inner_nb_cell: i64 = __mind_alloc(8);
        __mind_store_i64(inner_nb_cell, 0);
        let s7: EmitState = emit_if_chain_instr_lv(s6, final_stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, inner_cell, lvenv, nlv, strbuf, offs, ncount, inner_bind, inner_nb_cell);
        let inner_dst: i64 = __mind_load_i64(inner_cell);
        if inner_dst < 0 {
            __mind_store_i64(okcell, 0 - 1);
            return s;
        }
        let inner_nb: i64 = __mind_load_i64(inner_nb_cell);
        let s8: EmitState = emit_uleb128(s7, inner_dst);
        let else_synth: i64 = inner_dst + 1;
        // Same fresh/bound rule as CASE A: a bubbled binding whose name is already live in
        // the outer env keeps that vid on the else side (no placeholder), then_val = inner mid.
        let lay: i64 = __mind_alloc((inner_nb + 1) * 48);
        let dst: i64 = caseB_layout(lay, inner_bind, inner_nb, buf, lvbuf, nlv, 0, else_synth + 1);
        let else_len: i64 = 1 + caseA_fresh_count(lay, inner_nb, 0);
        let s9: EmitState = emit_uleb128(s8, else_len);
        let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
        let s11: EmitState = caseA_emit_placeholders(s10, lay, inner_nb, 0);
        let s12: EmitState = emit_uleb128(s11, else_synth);
        let s13: EmitState = emit_uleb128(s12, dst);
        let s14: EmitState = emit_uleb128(s13, inner_nb);
        let s15: EmitState = caseA_emit_bindings(s14, lay, inner_nb, strbuf, offs, ncount, buf, 0);
        let s16: EmitState = emit_uleb128(s15, inner_nb);
        let s17: EmitState = caseA_emit_merges(s16, lay, inner_nb, 0);
        let _bo2: i64 = caseA_lay_to_bindout(lay, bindout, inner_nb, 0);
        __mind_store_i64(nbind_cell, inner_nb);
        __mind_store_i64(okcell, dst);
        return s17;
    }
    __mind_store_i64(okcell, 0 - 1);
    s
}

pub fn emit_if_seq_segments_lv(s: EmitState, stmts_addr: i64, stmts_len: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, last_dst: i64, dst_cell: i64, i: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, acc_bind: i64, acc_cell: i64) -> EmitState {
    if i >= stmts_len {
        __mind_store_i64(dst_cell, last_dst);
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    let seg_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seg_cell, 0 - 1);
    // Each segment's escaping bindings live in its OWN OP_IF tail (emitted there) AND
    // are appended to the caller's accumulator (acc_bind/acc_cell, 24B name/merge_id
    // records) so an enclosing OP_IF can re-merge them (lower.rs upward threading).
    let seg_bindout: i64 = __mind_alloc(256 * 24);
    let seg_nbind: i64 = __mind_alloc(8);
    let s1: EmitState = emit_if_chain_instr_lv(s, stmt, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, seg_cell, lvenv, nlv, strbuf, offs, ncount, seg_bindout, seg_nbind);
    let seg_dst: i64 = __mind_load_i64(seg_cell);
    if seg_dst < 0 {
        __mind_store_i64(dst_cell, 0 - 1);
        return s;
    }
    // DEDUPED merge accumulator: a later segment that redefines a name updates that
    // binding's value (the join binds it once, latest value).
    let _ap: i64 = bind_append_dedup(acc_bind, acc_cell, buf, seg_bindout, __mind_load_i64(seg_nbind), 0);
    // The segment's escaping bindings are LIVE for the rest of this segment-sequence: a
    // later segment that REDEFINES one (a shadow) must see the outer vid in the env so its
    // own merge reuses it (bound, no placeholder). Appended at `nlv`, looked up last-match.
    let snb: i64 = __mind_load_i64(seg_nbind);
    let _le: i64 = lvenv_append_escapes(lvenv, nlv, seg_bindout, snb, 0);
    emit_if_seq_segments_lv(s1, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_dst + 1, seg_dst, dst_cell, i + 1, lvenv, nlv + snb, strbuf, offs, ncount, acc_bind, acc_cell)
}

// Append `n` 24-byte (name_lo, name_hi, merge_id) records from src to the
// accumulator at index *acc_cell, advancing it. Returns the new count.
pub fn bind_append(acc_bind: i64, acc_cell: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return __mind_load_i64(acc_cell);
    }
    let at: i64 = __mind_load_i64(acc_cell);
    __mind_store_i64(acc_bind + at * 24 + 0, __mind_load_i64(src + i * 24 + 0));
    __mind_store_i64(acc_bind + at * 24 + 8, __mind_load_i64(src + i * 24 + 8));
    __mind_store_i64(acc_bind + at * 24 + 16, __mind_load_i64(src + i * 24 + 16));
    __mind_store_i64(acc_cell, at + 1);
    bind_append(acc_bind, acc_cell, src, n, i + 1)
}

// Find a 24-byte (name_lo, name_hi, *) record in `acc` [0,n) whose NAME (compared by
// content in `buf`) equals buf[lo..hi). Returns its index or -1.
pub fn binddup_find(acc: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    if span_bytes_equal(buf, lo, hi, __mind_load_i64(acc + i * 24 + 0), __mind_load_i64(acc + i * 24 + 8)) == 1 {
        return i;
    }
    binddup_find(acc, n, buf, lo, hi, i + 1)
}

// Like bind_append but DEDUPED by name: a binding whose name already appears in `acc`
// UPDATES that entry's merge_id (keeping its first-seen position); a new name appends.
// This is the SSA join for a sequence of if-segments that REDEFINE the same name across
// segments (the join binds the name ONCE, with the value the LAST segment produced).
pub fn bind_append_dedup(acc_bind: i64, acc_cell: i64, buf: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return __mind_load_i64(acc_cell);
    }
    let lo: i64 = __mind_load_i64(src + i * 24 + 0);
    let hi: i64 = __mind_load_i64(src + i * 24 + 8);
    let mid: i64 = __mind_load_i64(src + i * 24 + 16);
    let cur: i64 = __mind_load_i64(acc_cell);
    let found: i64 = binddup_find(acc_bind, cur, buf, lo, hi, 0);
    if found >= 0 {
        __mind_store_i64(acc_bind + found * 24 + 16, mid)
    } else {
        __mind_store_i64(acc_bind + cur * 24 + 0, lo);
        __mind_store_i64(acc_bind + cur * 24 + 8, hi);
        __mind_store_i64(acc_bind + cur * 24 + 16, mid);
        __mind_store_i64(acc_cell, cur + 1)
    }
    bind_append_dedup(acc_bind, acc_cell, buf, src, n, i + 1)
}

pub fn emit_if_seq_then_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    if stmts_len < 2 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let s5: EmitState = emit_uleb128(s4, stmts_len + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let t3_acc: i64 = __mind_alloc(256 * 24);
    let t3_acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(t3_acc_cell, 0);
    // Growable env COPY for the segment walk: a segment's escapes append here so a later
    // segment that redefines a name sees it (the original lvenv/nlv below drives THIS if's
    // own merge fresh/bound — a name not live before this if is fresh).
    let seg_lvbuf: i64 = __mind_alloc((nlv + stmts_len + 512) * 24);
    let _sc: i64 = lvenv_copy(seg_lvbuf, lvenv, nlv, 0);
    let s7: EmitState = emit_if_seq_segments_lv(s6, stmts_addr, stmts_len, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, after_cond, seq_cell, 0, seg_lvbuf, nlv, strbuf, offs, ncount, t3_acc, t3_acc_cell);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // then_result = the last segment's dst; ELSE block + merge tail re-merge every binding
    // the segments escaped (deduped in t3_acc), fresh/bound vs the ORIGINAL outer env.
    let s8: EmitState = emit_uleb128(s7, last_dst);
    let nb: i64 = __mind_load_i64(t3_acc_cell);
    let else_synth: i64 = last_dst + 1;
    let lay: i64 = __mind_alloc((nb + 1) * 48);
    let dst: i64 = caseB_layout(lay, t3_acc, nb, buf, lvenv, nlv, 0, else_synth + 1);
    let else_len: i64 = 1 + caseA_fresh_count(lay, nb, 0);
    let s9: EmitState = emit_uleb128(s8, else_len);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = caseA_emit_placeholders(s10, lay, nb, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, nb);
    let s15: EmitState = caseA_emit_bindings(s14, lay, nb, strbuf, offs, ncount, buf, 0);
    let s16: EmitState = emit_uleb128(s15, nb);
    let s17: EmitState = caseA_emit_merges(s16, lay, nb, 0);
    __mind_store_i64(okcell, dst);
    s17
}

// ===========================================================================
// 6c-2b — if-with-LET-then-block + MERGE TAIL. The outer if's then-block is a
// SEQUENCE of leading `let NAME = INIT` bindings followed by >=1 if-segment(s)
// (each an arbitrary-depth nested if-return). Decoded byte-for-byte from
// --emit-mic3 on `g(b){ if b>=5 { let x=b+1; if x>=9 {return x} } 9 }` (106B) and
// the 2-let variant (121B). The outer OP_IF carries a non-empty MERGE TAIL: each
// then-block let escapes as a `branch_binding` (name -> merge_id) plus a
// `merge` triple (merge_id, then_val=let's value vid, else_val=a placeholder
// ConstI64(0) emitted in the else block). VID layout after the inner segments'
// last dst: else_synth, then PER let (placeholder, merge_id) interleaved, then
// dst. else_len = 1 + nlets (synth + placeholders; merge_ids are named, NOT
// emitted as instrs). Mirrors src/ir/compact/v3/emit.rs Instr::If encoding
// (encode_named_vids branch_bindings then encode_vid_triples merges) and the
// strtab order (collect_instr_strings interns branch_binding names AFTER all
// cond/then/else strings — verified vs the oracle). Bound by MIND-CONSTITUTION §I:
// additive, fail-closed, canary untouched.
// ===========================================================================

// Number of leading `let` statements in stmts[0..stmts_len). Bounded recursion
// (i strictly increases to stmts_len) — returns the index of the first non-let.
pub fn count_leading_lets(stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return i;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_let() {
        return i;
    }
    count_leading_lets(stmts_addr, stmts_len, i + 1)
}

// Emit each leading let's INIT tree into the THEN block, recording NAME -> its
// value (root) vid in the lv-env (lvbuf at slot nlv0+idx). cur_base (in base_cell)
// threads the running vid base; each init consumes count_nonparam_nodes_lv vids.
// A let init may reference an EARLIER let (lvbuf already holds nlv0+idx entries).
// Writes 0 to okcell + returns the seed on any flatten wall (defensive; the probe
// already validated, so this should not trigger).
pub fn emit_let_inits_lv(s: EmitState, stmts_addr: i64, nlets: i64, idx: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base_cell: i64, lvbuf: i64, nlv0: i64, okcell: i64, strbuf: i64, offs: i64, ncount: i64) -> EmitState {
    if idx >= nlets {
        return s;
    }
    if __mind_load_i64(okcell) == 0 {
        return s;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + idx * 8);
    let name: i64 = ast_child0(stmt);
    let init: i64 = ast_child2(stmt);
    let cur_base: i64 = __mind_load_i64(base_cell);
    let nlv_now: i64 = nlv0 + idx;
    // if-EXPRESSION init: `let x = if C {A} else {B}` -> ONE OP_IF whose dst is the
    // let's value. Cond/branches resolve params + earlier lets via the lv-env prefix
    // (nlv_now). The vid base advances past the whole OP_IF (dst + 1) — its delta,
    // not the 1 instr it contributes to then_len.
    if is_any_value_if_expr(init) == 1 {
        let q_cell: i64 = __mind_alloc(8);
        __mind_store_i64(q_cell, 0 - 1);
        let sq: EmitState = emit_if_expr_any_lv(s, init, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, q_cell, lvbuf, nlv_now, strbuf, offs, ncount, 0, 0);
        let qdst: i64 = __mind_load_i64(q_cell);
        if qdst < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        __mind_store_i64(lvbuf + nlv_now * 24 + 0, ast_span_lo(name));
        __mind_store_i64(lvbuf + nlv_now * 24 + 8, ast_span_hi(name));
        __mind_store_i64(lvbuf + nlv_now * 24 + 16, qdst);
        __mind_store_i64(base_cell, qdst + 1);
        return emit_let_inits_lv(sq, stmts_addr, nlets, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv0, okcell, strbuf, offs, ncount);
    }
    let root: i64 = flatten_branch_lv(init, buf, params_addr, n_params, nodes, cursor, vidbuf, cur_base, lvbuf, nlv_now);
    if root < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let init_n: i64 = __mind_load_i64(cursor);
    let s1: EmitState = emit_mic3_tree_body(s, nodes, init_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let nn: i64 = count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv_now);
    __mind_store_i64(lvbuf + nlv_now * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + nlv_now * 24 + 8, ast_span_hi(name));
    __mind_store_i64(lvbuf + nlv_now * 24 + 16, root);
    __mind_store_i64(base_cell, cur_base + nn);
    emit_let_inits_lv(s1, stmts_addr, nlets, idx + 1, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv0, okcell, strbuf, offs, ncount)
}

// Emit the per-let MERGE PLACEHOLDER consts in the else block: ConstI64(0) at
// vid base+2*i for i in 0..nlets (base = else_synth+1; merge_ids interleave at
// base+1+2*i and are NOT emitted).
pub fn emit_merge_placeholders(s: EmitState, base: i64, nlets: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let s1: EmitState = emit_mic3_const_i64(s, base + 2 * i, 0);
    emit_merge_placeholders(s1, base, nlets, i + 1)
}

// Emit the branch_bindings list: per let (name_str_idx, merge_id). merge_id =
// else_synth+2+2*i. name_str_idx via intern_find over the strtab.
pub fn emit_merge_bindings(s: EmitState, lvbuf: i64, nlv0: i64, nlets: i64, else_synth: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let lo: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 0);
    let hi: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 8);
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, lo, hi, 0);
    let merge_id: i64 = else_synth + 2 + 2 * i;
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, merge_id);
    emit_merge_bindings(s2, lvbuf, nlv0, nlets, else_synth, strbuf, offs, ncount, src, i + 1)
}

// Emit the merges list: per let (merge_id, then_val=let value vid, else_val=
// placeholder). merge_id=else_synth+2+2*i, placeholder=else_synth+1+2*i.
pub fn emit_merge_triples(s: EmitState, lvbuf: i64, nlv0: i64, nlets: i64, else_synth: i64, i: i64) -> EmitState {
    if i >= nlets {
        return s;
    }
    let merge_id: i64 = else_synth + 2 + 2 * i;
    let val_vid: i64 = __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 16);
    let placeholder: i64 = else_synth + 1 + 2 * i;
    let s1: EmitState = emit_uleb128(s, merge_id);
    let s2: EmitState = emit_uleb128(s1, val_vid);
    let s3: EmitState = emit_uleb128(s2, placeholder);
    emit_merge_triples(s3, lvbuf, nlv0, nlets, else_synth, i + 1)
}

// Outer OP_IF whose then-block = leading lets + if-segments, WITH the merge tail.
// Generalises emit_if_seq_then_instr_lv (no-let) to lets-in-then. base0 = the vid
// base for the cond. okcell <- dst on success, -1 on any wall. lvbuf is a private
// scratch (>= (nlv0+nlets)*24 bytes); strbuf/offs/ncount resolve binding names.
// Expose the type-4 leading-let bindings (name_lo, name_hi, merge_id) into a 24-byte
// bindout so an enclosing chain if can re-merge them (bubble up). merge_id =
// else_synth+2+2*i (matches emit_merge_bindings).
pub fn t4_binds_to_bindout(lvbuf: i64, nlv0: i64, nlets: i64, else_synth: i64, bindout: i64, i: i64) -> i64 {
    if i >= nlets {
        return nlets;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(lvbuf + (nlv0 + i) * 24 + 8));
    __mind_store_i64(bindout + i * 24 + 16, else_synth + 2 + 2 * i);
    t4_binds_to_bindout(lvbuf, nlv0, nlets, else_synth, bindout, i + 1)
}

pub fn emit_if_let_seq_then_instr_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv0: i64, nlv0: i64, lvbuf: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    let nlets: i64 = count_leading_lets(stmts_addr, stmts_len, 0);
    let n_segs: i64 = stmts_len - nlets;
    // Require >=1 let (else the no-let path owns it) and >=1 trailing if-segment,
    // all of which must be if-statements.
    if nlets < 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // n_segs == 0 is a FALL-THROUGH guard if `if C { let* }` (side-effect lets, no
    // return/segment) — the lets merge with their values and the block falls through.
    // emit_if_seq_segments_lv with 0 segments returns last_dst = the last let's vid, so
    // the merge tail below is identical; no special-casing needed.
    if n_segs < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let segs_addr: i64 = stmts_addr + nlets * 8;
    if seq_then_all_ifs(segs_addr, n_segs, 0) != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // Seed the lv-env with the outer lets (nlv0 entries) so a let init can refer to
    // them; the leading lets append at slots nlv0..nlv0+nlets.
    let copy_ok: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    // OP_IF cond.
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvbuf, nlv0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvbuf, nlv0);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // THEN length = 1 (synth) + sum(let init nonparam) + n_segs (one OP_IF each).
    let let_instrs: i64 = sum_let_init_nonparam(stmts_addr, nlets, 0, buf, params_addr, n_params, lvbuf, nlv0);
    let s5: EmitState = emit_uleb128(s4, 1 + let_instrs + n_segs);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    // Emit the let init trees, building the lv-env (nlv0..nlv0+nlets).
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, after_cond + 1);
    let li_ok: i64 = __mind_alloc(8);
    __mind_store_i64(li_ok, 1);
    let s7: EmitState = emit_let_inits_lv(s6, stmts_addr, nlets, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, nlv0, li_ok, strbuf, offs, ncount);
    if __mind_load_i64(li_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let nlv_total: i64 = nlv0 + nlets;
    // Post-lets vid base from the threaded base_cell (NOT let_instrs — an if-expr
    // init is 1 instr but consumes its OP_IF's full vid delta).
    let seg_base: i64 = __mind_load_i64(base_cell);
    let seq_cell: i64 = __mind_alloc(8);
    __mind_store_i64(seq_cell, 0 - 1);
    let t4_acc: i64 = __mind_alloc(256 * 24);
    let t4_acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(t4_acc_cell, 0);
    let s8: EmitState = emit_if_seq_segments_lv(s7, segs_addr, n_segs, buf, params_addr, n_params, nodes, cursor, vidbuf, seg_base, seg_base - 1, seq_cell, 0, lvbuf, nlv_total, strbuf, offs, ncount, t4_acc, t4_acc_cell);
    let last_dst: i64 = __mind_load_i64(seq_cell);
    if last_dst < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // then_result = last segment's dst.
    let s9: EmitState = emit_uleb128(s8, last_dst);
    // MERGE TAIL — the leading lets (then_val = own vid) AND the if-segments' bubbled bindings
    // (then_val = inner merge_id, accumulated in t4_acc) BOTH escape; combine them into one acc
    // in source order and apply the fresh/bound rule (a name already live in the outer env
    // reuses that vid on the else side, no placeholder). Previously the bubbled bindings were
    // dropped, so an enclosing block lost the inner if-segment's escaping names.
    let t4_nb: i64 = __mind_load_i64(t4_acc_cell);
    let raw_nb: i64 = nlets + t4_nb;
    let raw: i64 = __mind_alloc((raw_nb + 1) * 24);
    let _c1: i64 = acc_copy_lvbuf(raw, lvbuf, nlv0, nlets, 0);
    let _c2: i64 = acc_copy_acc(raw, nlets, t4_acc, t4_nb, 0);
    // Dedup same-name escaping bindings (a leading let shadowed by a same-name bubbled
    // if-segment binding, e.g. `let x=..; if c { let x=.. }`) into ONE merge per name:
    // first-seen position, LAST value wins (SSA F2 — the name's value after the block is
    // its last write). Additive: a block with no duplicate escaping names re-appends every
    // entry unchanged, so the merge tail stays byte-identical.
    let cacc: i64 = __mind_alloc((raw_nb + 1) * 24);
    let cacc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(cacc_cell, 0);
    let _cd: i64 = bind_append_dedup(cacc, cacc_cell, buf, raw, raw_nb, 0);
    let nb: i64 = __mind_load_i64(cacc_cell);
    let else_synth: i64 = last_dst + 1;
    let lay: i64 = __mind_alloc((nb + 1) * 48);
    let dst: i64 = caseB_layout(lay, cacc, nb, buf, lvbuf, nlv0, 0, else_synth + 1);
    let s10: EmitState = emit_uleb128(s9, 1 + caseA_fresh_count(lay, nb, 0));
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = caseA_emit_placeholders(s11, lay, nb, 0);
    let s13: EmitState = emit_uleb128(s12, else_synth);
    let s14: EmitState = emit_uleb128(s13, dst);
    let s15: EmitState = emit_uleb128(s14, nb);
    let s16: EmitState = caseA_emit_bindings(s15, lay, nb, strbuf, offs, ncount, buf, 0);
    let s17: EmitState = emit_uleb128(s16, nb);
    let s18: EmitState = caseA_emit_merges(s17, lay, nb, 0);
    // Expose ALL escaping bindings (leading lets + bubbled) so an enclosing chain re-merges them.
    let _bo: i64 = caseA_lay_to_bindout(lay, bindout, nb, 0);
    __mind_store_i64(nbind_cell, nb);
    __mind_store_i64(okcell, dst);
    s18
}

// Copy `n` 24-byte lv-env entries from src to dst. Returns 1.
pub fn lvenv_copy(dst: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 1;
    }
    __mind_store_i64(dst + i * 24 + 0, __mind_load_i64(src + i * 24 + 0));
    __mind_store_i64(dst + i * 24 + 8, __mind_load_i64(src + i * 24 + 8));
    __mind_store_i64(dst + i * 24 + 16, __mind_load_i64(src + i * 24 + 16));
    lvenv_copy(dst, src, n, i + 1)
}

// Is the then-block a pure FALL-THROUGH side-effect block? Every statement is a
// `let` or a bare expression-statement (NO `if`, NO `return`) — the block runs its
// side effects and falls off the end. Returns 1 if so, else 0.
pub fn fallthrough_all_sidefx(stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let k: i64 = ast_kind(stmt);
    if k == ast_if() {
        return 0;
    }
    if k == ast_return() {
        return 0;
    }
    fallthrough_all_sidefx(stmts_addr, stmts_len, i + 1)
}

// Emit an else-less `if C { <lets + bare-call side-effects> }` whose then-block FALLS
// THROUGH (no return, no nested if-segment). Generalises the lets-only fall-through to
// allow bare expression-statements interleaved (via the mixed walk). The block's lets
// each escape as a branch_binding + merge (then_val = the let's vid, else_val = a
// POISON placeholder in the synthetic else); bare-calls bind nothing. then_result = the
// last emitted vid. Exposes the leading-let merge bindings via bindout for an enclosing
// chain to re-merge. okcell <- dst (-1 on a wall).
pub fn emit_if_fallthrough_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv0: i64, nlv0: i64, lvbuf: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    if ast_child2(if_node) != 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let stmts_addr: i64 = ast_child0(then_blk);
    let stmts_len: i64 = ast_aux(then_blk);
    if stmts_len < 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // Accept let / bare-call / if-segment statements; the block must FALL THROUGH (no
    // top-level return). An interior if-segment is emitted via the mixed walk; its
    // escaping bindings (if any) are caught by the bubbled guard after the walk.
    if mixed_prefix_ok(stmts_addr, stmts_len, 0) != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let copy_ok: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvbuf, nlv0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvbuf, nlv0);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // Measure the prefix instrs + accumulate let names (bare-calls add no lv-env entry).
    let m_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(m_nlv, nlv0);
    let prefix_instrs: i64 = measure_mixed_instrs(stmts_addr, stmts_len, 0, buf, params_addr, n_params, lvbuf, m_nlv);
    let nlets: i64 = __mind_load_i64(m_nlv) - nlv0;
    // THEN = 1 (synth) + prefix_instrs (no THEN-side placeholders in an else-less if).
    let s5: EmitState = emit_uleb128(s4, 1 + prefix_instrs);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let _cp2: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, after_cond + 1);
    let e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(e_nlv, nlv0);
    let acc: i64 = __mind_alloc(128 * 24);
    let acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(acc_cell, 0);
    let w_ok: i64 = __mind_alloc(8);
    __mind_store_i64(w_ok, 1);
    let s7: EmitState = emit_mixed_walk(s6, stmts_addr, stmts_len, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, e_nlv, acc, acc_cell, w_ok, strbuf, offs, ncount, 1);
    if __mind_load_i64(w_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // BUBBLED-binding guard: the merge tail below uses lvbuf (the DIRECT lets only). If an
    // interior if-segment escaped extra bindings (acc holds more than the direct lets),
    // they would be lost — fail closed (this shape is not yet supported).
    let then_end: i64 = __mind_load_i64(base_cell);
    let then_result: i64 = then_end - 1;
    let s8: EmitState = emit_uleb128(s7, then_result);
    // ELSE block: synth + one POISON placeholder per ESCAPING binding (acc: direct lets
    // AND if-segment-bubbled bindings — nb >= nlets). The merge then_val comes from
    // acc[+16] (the binding's own value), so a bubbled binding merges with the inner
    // segment's merge_id.
    let nb: i64 = __mind_load_i64(acc_cell);
    let else_synth: i64 = then_end;
    // Fresh/bound merge tail (acc[i] = name + then_val, same layout caseB_layout reads):
    // a binding whose name is already live in the outer env [0,nlv0) keeps that vid on the
    // else side (no placeholder, 1 vid); a fresh name gets a placeholder (2 vids).
    let lay: i64 = __mind_alloc((nb + 1) * 48);
    let dst: i64 = caseB_layout(lay, acc, nb, buf, lvbuf, nlv0, 0, else_synth + 1);
    let else_len: i64 = 1 + caseA_fresh_count(lay, nb, 0);
    let s9: EmitState = emit_uleb128(s8, else_len);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = caseA_emit_placeholders(s10, lay, nb, 0);
    let s12: EmitState = emit_uleb128(s11, else_synth);
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, nb);
    let s15: EmitState = caseA_emit_bindings(s14, lay, nb, strbuf, offs, ncount, buf, 0);
    let s16: EmitState = emit_uleb128(s15, nb);
    let s17: EmitState = caseA_emit_merges(s16, lay, nb, 0);
    let _bo: i64 = caseA_lay_to_bindout(lay, bindout, nb, 0);
    __mind_store_i64(nbind_cell, nb);
    __mind_store_i64(okcell, dst);
    s17
}

// Sum the nonparam (vid-consuming) node counts of the leading lets' inits. Each
// let i resolves against the lv-env built from the prior lets (nlv0+i entries),
// matching emit_let_inits_lv's per-let base advance. Populates each let's NAME
// into lvbuf (with a placeholder vid 0) BEFORE measuring the next, so a later
// let's init that references an earlier let resolves (the real vids are written
// by emit_let_inits_lv afterwards; only the name spans matter for counting).
pub fn sum_let_init_nonparam(stmts_addr: i64, nlets: i64, i: i64, buf: i64, params_addr: i64, n_params: i64, lvbuf: i64, nlv0: i64) -> i64 {
    if i >= nlets {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let init: i64 = ast_child2(stmt);
    // An if-EXPRESSION init (`let x = if C {A} else {B}`) lowers to ONE OP_IF
    // instruction (its cond/branch instrs live INSIDE the OP_IF, not at the
    // then-block top level) — so it contributes 1 to the instr count, while its
    // VID consumption (handled in emit_let_inits_lv) is the OP_IF's full delta.
    let nn: i64 = if is_any_value_if_expr(init) == 1 {
        1
    } else {
        count_nonparam_nodes_lv(init, buf, params_addr, n_params, lvbuf, nlv0 + i)
    };
    let name: i64 = ast_child0(stmt);
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 0, ast_span_lo(name));
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 8, ast_span_hi(name));
    __mind_store_i64(lvbuf + (nlv0 + i) * 24 + 16, 0);
    nn + sum_let_init_nonparam(stmts_addr, nlets, i + 1, buf, params_addr, n_params, lvbuf, nlv0)
}

// FN_DEF whose body is `{ <if-chain>; TRAIL }` — one arbitrary-depth nested if-return
// then a trailing value. Mirrors emit_mic3_module_fndef_nested_if but for the recursive
// chain (any depth >= 1). Supersedes the depth-2 dedicated case byte-identically.
pub fn emit_mic3_module_fndef_if_chain(s: EmitState, src: i64, fn_node: i64, nidx: i64, pstr: i64, n_params: i64, if_node: i64, trail_expr: i64, nodes: i64, cursor: i64, vidbuf: i64, t_nodes: i64, t_cursor: i64, t_vidbuf: i64, ok_cell: i64) -> EmitState {
    let params_addr: i64 = ast_child1(fn_node);
    let dst_cell: i64 = __mind_alloc(8);
    __mind_store_i64(dst_cell, 0 - 1);
    let probe: EmitState = emit_if_chain_instr(es_new(), if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let dst: i64 = __mind_load_i64(dst_cell);
    if dst < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_root: i64 = flatten_branch(trail_expr, src, params_addr, n_params, t_nodes, t_cursor, t_vidbuf, dst + 1);
    if trail_root < 0 {
        __mind_store_i64(ok_cell, 0);
        return s;
    }
    let trail_n: i64 = __mind_load_i64(t_cursor);
    let trail_nonparam: i64 = count_nonparam_nodes(trail_expr, src, params_addr, n_params);
    let body_len: i64 = n_params + 1 + trail_nonparam;
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, nidx);
    let s3: EmitState = emit_mic3_param_pairs_mod(s2, pstr, n_params);
    let s4: EmitState = emit_mic3_opt_vid(s3, 1, trail_root);
    let s5: EmitState = es_push(s4, 0);
    let s6: EmitState = emit_uleb128(s5, body_len);
    let s7: EmitState = emit_mic3_params_mod(s6, pstr, n_params, 0);
    let s8: EmitState = emit_if_chain_instr(s7, if_node, src, params_addr, n_params, nodes, cursor, vidbuf, n_params, dst_cell);
    let s9: EmitState = emit_mic3_tree_body(s8, t_nodes, trail_n, t_vidbuf, 0, 0, 0, 0, 0);
    __mind_store_i64(ok_cell, 1);
    s9
}

// ===========================================================================
// GENERAL statement sequencing — lets + if-early-returns in arbitrary order
// ===========================================================================
//
// Generalises cases (f) [let-chain] and (g) [single if-early-return then trail]
// into ONE recursive statement walker: a body is an arbitrary sequence of
//   `let NAME: TYPE = INIT`           (binds NAME -> its init's root descriptor slot)
//   `if COND { return E; }`           (else-less if; then-block ends in `return E`)
// then a trailing value expression (the FN_DEF result). Decoded byte-for-byte from
// --emit-mic3 on `fn foo(a,b){ let t=a+b; if t==0 {return 0;} let u=t*2; u }`:
//   PARAM%0 PARAM%1
//   BINOP%2 = %0 add %1                 (let t)
//   OP_IF{ cond: CONST%3=0, BINOP%4=%2 eq %3 ;
//          then: CONST%5=0(synth), CONST%6=0(ret literal), RETURN%6 ; then_res %6 ;
//          else: CONST%7=0(synth) ; else_res %7 ; dst %8 ; bindings0 merges0 }
//   CONST%9=2 BINOP%10=%2 mul %9        (let u)  -> ret_vid %10 (= trailing `u`)
// All let-inits, every if cond/ret expr, and the trailing flatten into ONE shared
// descriptor array carrying the let-env, so let-refs in a later cond / init / the
// trailing reuse the earlier slot's vid with no new node. Vids are assigned in
// SOURCE order per segment (a let segment, then the OP_IF block which injects the
// synth/dst vids, then the next segment), threading a running base — matching the
// Rust SSA numbering exactly. ISOLATED from the canary (flatten_ast still rejects
// ast_if/ast_let at expression level, so the fixed point stays byte-identical;
// Bound by MIND-CONSTITUTION §I — additive, canary untouched).

// Count the body-instr (non-structural) descriptor slots in nodes[lo..hi). Mirrors
// count_descriptor_nonparam but over a half-open sub-range, used to size per-segment
// vid blocks and the cond/ret OP_IF lengths.
pub fn count_descriptor_nonparam_range(nodes: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return 0;
    }
    let kind: i64 = __mind_load_i64(nodes + lo * 32);
    if kind == 0 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    if kind == 4 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    if kind == 5 {
        return count_descriptor_nonparam_range(nodes, lo + 1, hi);
    }
    1 + count_descriptor_nonparam_range(nodes, lo + 1, hi)
}

// Resolve vids for nodes[lo..hi) starting the non-param counter at `base`. Reuses
// tree_resolve_vids_base's logic but bounded to a sub-range (so a let segment, the
// trailing, or an OP_IF cond/ret tree each resolve against a private base while
// referring to already-resolved earlier slots). Returns the next free vid.
pub fn seq_resolve_range(nodes: i64, lo: i64, hi: i64, vidbuf: i64, base: i64) -> i64 {
    if lo >= hi {
        return base;
    }
    let kind: i64 = __mind_load_i64(nodes + lo * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + lo * 32 + 8);
        __mind_store_i64(vidbuf + lo * 8, pidx);
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    if kind == 4 {
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    if kind == 5 {
        return seq_resolve_range(nodes, lo + 1, hi, vidbuf, base);
    }
    __mind_store_i64(vidbuf + lo * 8, base);
    seq_resolve_range(nodes, lo + 1, hi, vidbuf, base + 1)
}

// Walk the statements [0..stmts_len-1) (everything before the trailing value),
// flattening each into the SHARED descriptor array and recording a plan entry
// (64-byte record) per statement. Plan record layout:
//   [0]=type (0=let, 1=if-return)
//   let:  [8]=slot_start, [16]=slot_end
//   if :  [8]=cond_start, [16]=cond_end, [24]=cond_root_slot,
//         [32]=ret_start,  [40]=ret_end,  [48]=ret_root_slot
// Returns 1 on success (plan/env/nodes filled), 0 on any wall (unsupported stmt or
// init/cond/ret the flatten rejects). `nplan_cell` accumulates the plan length;
// `nlets_cell` the let-env length. Threaded through recursion.
// True (1) iff every statement in stmts[0..len) is an if-statement — the precondition
// for a type-3 if-with-SEQ-then-block (each becomes one if-segment).
pub fn seq_then_all_ifs(stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if ast_kind(stmt) != ast_if() {
        return 0;
    }
    seq_then_all_ifs(stmts_addr, stmts_len, i + 1)
}

// lv-aware if-EXPRESSION emitter: `if C { A } else { B }` as a VALUE (the OP_IF dst).
// Mirrors emit_mic3_if_instr but resolves seq-level lets in the cond/branches via the
// lv-env, and resolves call name_idx via strbuf/offs/ncount. then_result = then-value,
// else_result = else-value, dst = the merged value; 0 bindings / 0 merges (an
// if-expression value, not a variable merge). okcell <- dst (-1 on a wall).
// Emit ONE if-EXPRESSION whose branches are BLOCKS (`let* VALUE`), with the F2
// two-sided merge: each branch-local let escapes as a branch_binding + merge. Vid
// layout (decoded): then(synth, then-lets, then-value), else(synth, else-lets,
// else-value), then PER merged name (placeholder, merge_id), then dst. A then-only
// name's placeholder goes in the ELSE block (and vice-versa); then_val/else_val use
// the let's value on its own side and the placeholder on the other. okcell <- dst.
pub fn emit_if_expr_block_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    let then_nlets: i64 = then_sl - 1;
    let else_nlets: i64 = else_sl - 1;
    let then_val_expr: i64 = __mind_load_i64(then_sa + then_nlets * 8);
    let else_val_expr: i64 = __mind_load_i64(else_sa + else_nlets * 8);
    // cond
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // then lv-env + measure then-let instrs.
    let then_lvbuf: i64 = __mind_alloc((nlv + then_nlets + 66) * 24);
    let _tc: i64 = lvenv_copy(then_lvbuf, lvenv, nlv, 0);
    let then_let_instrs: i64 = sum_let_init_nonparam(then_sa, then_nlets, 0, buf, params_addr, n_params, then_lvbuf, nlv);
    let then_val_base0: i64 = letchain_vid_base(then_sa, then_nlets, after_cond + 1, buf, params_addr, n_params, lvenv, nlv, strbuf, offs, ncount);
    // INSTR count = block length contribution (an if-expr value is ONE OP_IF); SPAN =
    // its vid delta (an if-expr value consumes its whole OP_IF's vids).
    let then_val_instrs: i64 = branch_val_instrs(then_val_expr, buf, params_addr, n_params, then_lvbuf, nlv + then_nlets);
    if then_val_instrs < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_val_span: i64 = branch_val_span(then_val_expr, buf, params_addr, n_params, then_val_base0, then_lvbuf, nlv + then_nlets, strbuf, offs, ncount);
    if then_val_span < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // else lv-env + measure else-let instrs.
    let else_lvbuf: i64 = __mind_alloc((nlv + else_nlets + 66) * 24);
    let _ec: i64 = lvenv_copy(else_lvbuf, lvenv, nlv, 0);
    let else_let_instrs: i64 = sum_let_init_nonparam(else_sa, else_nlets, 0, buf, params_addr, n_params, else_lvbuf, nlv);
    let else_val_instrs: i64 = branch_val_instrs(else_val_expr, buf, params_addr, n_params, else_lvbuf, nlv + else_nlets);
    if else_val_instrs < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // vid layout — the else value's base depends on then_val_end, so its span (which may
    // probe a nested if-expr) is computed here once the synth/let offsets are known.
    let then_val_end: i64 = then_val_base0 + then_val_span;
    let else_synth: i64 = then_val_end;
    let else_val_base0: i64 = letchain_vid_base(else_sa, else_nlets, else_synth + 1, buf, params_addr, n_params, lvenv, nlv, strbuf, offs, ncount);
    let else_val_span: i64 = branch_val_span(else_val_expr, buf, params_addr, n_params, else_val_base0, else_lvbuf, nlv + else_nlets, strbuf, offs, ncount);
    if else_val_span < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_val_end: i64 = else_val_base0 + else_val_span;
    let ph_start: i64 = else_val_end;
    // Fresh/bound layout (both lv-bufs already hold the branch-let NAMES via
    // sum_let_init_nonparam; own vids are filled post-emit by blk_fill_own). A branch let
    // already live in the outer env reuses that vid on the opposite side (no placeholder).
    // Merge set = UNION of names: a let bound by the SAME name on both branches is ONE phi.
    // A branch VALUE that is itself an escaping value if-expr bubbles its merge bindings up:
    // append them after the leading lets (names now; real merge_ids at the value emit) so
    // blk_layout re-merges them with the leading lets. no-escape -> eff==nlets, byte-identical.
    // A leading let whose INIT is an escaping value if-expr (`let x = if .. { let m=.. } ..`)
    // surfaces that inner merge binding (m) into the block scope; bubble it BEFORE the value
    // escapes so the union order is [lets, init-escapes, value-escapes] (matches the oracle's
    // vid-allocation order: the let inits emit before the trailing value).
    let then_init_ec: i64 = block_init_escape_probe(then_sa, then_nlets, after_cond + 1, buf, params_addr, n_params, then_lvbuf, nlv, strbuf, offs, ncount, then_lvbuf, nlv + then_nlets, 0, 0);
    let else_init_ec: i64 = block_init_escape_probe(else_sa, else_nlets, else_synth + 1, buf, params_addr, n_params, else_lvbuf, nlv, strbuf, offs, ncount, else_lvbuf, nlv + else_nlets, 0, 0);
    let then_ec: i64 = branch_escape_probe(then_val_expr, buf, params_addr, n_params, then_val_base0, then_lvbuf, nlv + then_nlets, strbuf, offs, ncount, then_lvbuf, nlv + then_nlets + then_init_ec);
    let else_ec: i64 = branch_escape_probe(else_val_expr, buf, params_addr, n_params, else_val_base0, else_lvbuf, nlv + else_nlets, strbuf, offs, ncount, else_lvbuf, nlv + else_nlets + else_init_ec);
    let then_nle: i64 = then_nlets + then_init_ec + then_ec;
    let else_nle: i64 = else_nlets + else_init_ec + else_ec;
    let blk_shared: i64 = blk_count_shared(then_lvbuf, nlv, then_nle, else_lvbuf, else_nle, buf, 0, 0);
    let n_merged: i64 = then_nle + else_nle - blk_shared;
    let eix: i64 = __mind_alloc((then_nle + else_nle + 1) * 8);
    let bl: i64 = __mind_alloc((n_merged + 1) * 64);
    let dst: i64 = blk_layout(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nle, else_nle, n_merged, buf, params_addr, n_params, lvenv, nlv, 0, ph_start);
    let then_len: i64 = 1 + then_let_instrs + then_val_instrs + blk_fresh_side(bl, n_merged, 0, 0);
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let t_base: i64 = __mind_alloc(8);
    __mind_store_i64(t_base, after_cond + 1);
    let t_ok: i64 = __mind_alloc(8);
    __mind_store_i64(t_ok, 1);
    let s7: EmitState = emit_let_inits_lv(s6, then_sa, then_nlets, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, t_base, then_lvbuf, nlv, t_ok, strbuf, offs, ncount);
    if __mind_load_i64(t_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_val_base: i64 = __mind_load_i64(t_base);
    let then_rcell: i64 = __mind_alloc(8);
    let then_vok: i64 = __mind_alloc(8);
    __mind_store_i64(then_vok, 1);
    let then_vb: i64 = __mind_alloc(64 * 24);
    let then_vnb: i64 = __mind_alloc(8);
    __mind_store_i64(then_vnb, 0);
    let s8: EmitState = emit_branch_value_lv(s7, then_val_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, then_val_base, then_lvbuf, nlv + then_nlets, strbuf, offs, ncount, then_rcell, then_vok, then_vb, then_vnb);
    if __mind_load_i64(then_vok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let _tae: i64 = lvenv_append_escapes(then_lvbuf, nlv + then_nlets + then_init_ec, then_vb, __mind_load_i64(then_vnb), 0);
    let then_root: i64 = __mind_load_i64(then_rcell);
    // then placeholders: FRESH else-block lets only (bound names reuse the outer vid).
    let s9: EmitState = blk_emit_ph(s8, bl, n_merged, 0, 0);
    let s10: EmitState = emit_uleb128(s9, then_root);
    let else_len: i64 = 1 + else_let_instrs + else_val_instrs + blk_fresh_side(bl, n_merged, 1, 0);
    let s11: EmitState = emit_uleb128(s10, else_len);
    let s12: EmitState = emit_mic3_const_i64(s11, else_synth, 0);
    let e_base: i64 = __mind_alloc(8);
    __mind_store_i64(e_base, else_synth + 1);
    let e_ok: i64 = __mind_alloc(8);
    __mind_store_i64(e_ok, 1);
    let s13: EmitState = emit_let_inits_lv(s12, else_sa, else_nlets, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, e_base, else_lvbuf, nlv, e_ok, strbuf, offs, ncount);
    if __mind_load_i64(e_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_val_base: i64 = __mind_load_i64(e_base);
    let else_rcell: i64 = __mind_alloc(8);
    let else_vok: i64 = __mind_alloc(8);
    __mind_store_i64(else_vok, 1);
    let else_vb: i64 = __mind_alloc(64 * 24);
    let else_vnb: i64 = __mind_alloc(8);
    __mind_store_i64(else_vnb, 0);
    let s14: EmitState = emit_branch_value_lv(s13, else_val_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, else_val_base, else_lvbuf, nlv + else_nlets, strbuf, offs, ncount, else_rcell, else_vok, else_vb, else_vnb);
    if __mind_load_i64(else_vok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let _eae: i64 = lvenv_append_escapes(else_lvbuf, nlv + else_nlets + else_init_ec, else_vb, __mind_load_i64(else_vnb), 0);
    let else_root: i64 = __mind_load_i64(else_rcell);
    // else placeholders: FRESH then-block lets only (bound names reuse the outer vid).
    let s15: EmitState = blk_emit_ph(s14, bl, n_merged, 1, 0);
    let s16: EmitState = emit_uleb128(s15, else_root);
    let s17: EmitState = emit_uleb128(s16, dst);
    // Fill each binding's own-side value from the now-emitted branch lv-bufs, then emit.
    let _fo: i64 = blk_fill_own(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, n_merged, 0);
    let s18: EmitState = emit_uleb128(s17, n_merged);
    let s19: EmitState = blk_emit_bindings(s18, bl, n_merged, strbuf, offs, ncount, buf, 0);
    let s20: EmitState = emit_uleb128(s19, n_merged);
    let s21: EmitState = blk_emit_merges(s20, bl, n_merged, 0);
    if bindout != 0 {
        let _bo: i64 = blk_lay_to_bindout(bl, bindout, n_merged, 0);
        __mind_store_i64(nbind_cell, n_merged)
    }
    __mind_store_i64(okcell, dst);
    s21
}

// Emit a two-sided STATEMENT-level `if C { <lets+bare-calls> } else { <lets+bare-calls> }`
// that FALLS THROUGH (no trailing value, no return on either side; the OP_IF dst is
// discarded). Structurally emit_if_expr_block_lv with each block's (lets + value)
// collapsed to all-side-effects via the mixed walk, and branch_result = the last
// side-effect vid. Branch-local lets escape via the two-sided F2 merge (a let defined on
// one side merges with a POISON/placeholder on the other), reusing emit_block_ph /
// fill_binds_block / emit_block_bindings / emit_block_merges verbatim. okcell <- dst.
pub fn emit_if_else_fallthrough_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv0: i64, nlv0: i64, lvbuf_unused: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    __mind_store_i64(nbind_cell, 0);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    // Both branches must FALL THROUGH (no top-level return); they may contain lets,
    // bare-calls, if-segments AND nested two-sided if-else statements (handled by the
    // mixed walk's recursion). Escaping bindings (direct lets + bubbled) flow via acc.
    if mixed_prefix_ok(then_sa, then_sl, 0) != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    if mixed_prefix_ok(else_sa, else_sl, 0) != 1 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // OP_IF cond.
    let cond_expr: i64 = ast_child0(if_node);
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv0, nlv0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv0, nlv0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let then_instrs: i64 = measure_mixed_instrs_probe(then_sa, then_sl, buf, params_addr, n_params, lvenv0, nlv0);
    let else_instrs: i64 = measure_mixed_instrs_probe(else_sa, else_sl, buf, params_addr, n_params, lvenv0, nlv0);
    // PROBE each branch (into throwaway scratch) to learn its VID SPAN (an if-segment /
    // nested if-else consumes more vids than its 1 instr) + ESCAPING-binding count.
    let then_nb_c: i64 = __mind_alloc(8);
    let then_end: i64 = probe_mixed_walk(then_sa, then_sl, after_cond + 1, buf, params_addr, n_params, lvenv0, nlv0, strbuf, offs, ncount, then_nb_c);
    if then_end < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_nb: i64 = __mind_load_i64(then_nb_c);
    let then_result: i64 = then_end - 1;
    let else_synth: i64 = then_end;
    let else_nb_c: i64 = __mind_alloc(8);
    let else_end: i64 = probe_mixed_walk(else_sa, else_sl, else_synth + 1, buf, params_addr, n_params, lvenv0, nlv0, strbuf, offs, ncount, else_nb_c);
    if else_end < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_nb: i64 = __mind_load_i64(else_nb_c);
    let else_result: i64 = else_end - 1;
    let ph_start: i64 = else_end;
    let n_merged: i64 = then_nb + else_nb;
    let dst: i64 = ph_start + 2 * n_merged;
    let then_len: i64 = 1 + then_instrs + else_nb;
    let else_len: i64 = 1 + else_instrs + then_nb;
    // EMIT for real.
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let then_lvbuf: i64 = __mind_alloc((nlv0 + then_sl + 512) * 24);
    let _tc: i64 = lvenv_copy(then_lvbuf, lvenv0, nlv0, 0);
    let then_base: i64 = __mind_alloc(8);
    __mind_store_i64(then_base, after_cond + 1);
    let then_e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(then_e_nlv, nlv0);
    let then_acc: i64 = __mind_alloc(128 * 24);
    let then_acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(then_acc_cell, 0);
    let then_ok: i64 = __mind_alloc(8);
    __mind_store_i64(then_ok, 1);
    let s7: EmitState = emit_mixed_walk(s6, then_sa, then_sl, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, then_base, then_lvbuf, then_e_nlv, then_acc, then_acc_cell, then_ok, strbuf, offs, ncount, 1);
    if __mind_load_i64(then_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // THEN-side placeholders cover the ELSE-only escaping names (merged idx >= then_nb).
    let s8: EmitState = emit_block_ph(s7, ph_start, then_nb, n_merged, then_nb);
    let s9: EmitState = emit_uleb128(s8, then_result);
    let s10: EmitState = emit_uleb128(s9, else_len);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let else_lvbuf: i64 = __mind_alloc((nlv0 + else_sl + 512) * 24);
    let _ec: i64 = lvenv_copy(else_lvbuf, lvenv0, nlv0, 0);
    let else_base: i64 = __mind_alloc(8);
    __mind_store_i64(else_base, else_synth + 1);
    let else_e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(else_e_nlv, nlv0);
    let else_acc: i64 = __mind_alloc(128 * 24);
    let else_acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(else_acc_cell, 0);
    let else_ok: i64 = __mind_alloc(8);
    __mind_store_i64(else_ok, 1);
    let s12: EmitState = emit_mixed_walk(s11, else_sa, else_sl, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, else_base, else_lvbuf, else_e_nlv, else_acc, else_acc_cell, else_ok, strbuf, offs, ncount, 1);
    if __mind_load_i64(else_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    // ELSE-side placeholders cover the THEN-only escaping names (merged idx < then_nb).
    let s13: EmitState = emit_block_ph(s12, ph_start, 0, then_nb, then_nb);
    let s14: EmitState = emit_uleb128(s13, else_result);
    let s15: EmitState = emit_uleb128(s14, dst);
    // bindings + merges from acc (then escaping then else escaping; direct lets AND bubbled).
    let bb: i64 = __mind_alloc((n_merged + 1) * 40);
    let _fb: i64 = fill_binds_block(bb, then_acc, else_acc, 0, then_nb, else_nb, ph_start, 0);
    let s16: EmitState = emit_uleb128(s15, n_merged);
    let s17: EmitState = emit_block_bindings(s16, bb, n_merged, strbuf, offs, ncount, buf, 0);
    let s18: EmitState = emit_uleb128(s17, n_merged);
    let s19: EmitState = emit_block_merges(s18, bb, n_merged, 0);
    // Expose this if's merge bindings so an enclosing fall-through walk (emit_mixed_walk) can
    // bubble them up when this if-else is itself a nested statement in a branch.
    if bindout != 0 {
        let bo: i64 = bb_to_bindout(bb, bindout, n_merged, 0);
        // bo < 0 => over-64-cap refusal (no copy): expose 0 bindings upward (fail-closed).
        if bo >= 0 {
            __mind_store_i64(nbind_cell, n_merged)
        } else {
            __mind_store_i64(nbind_cell, 0)
        }
    }
    __mind_store_i64(okcell, dst);
    s19
}

// Probe a mixed walk into THROWAWAY scratch: returns the end vid (base after the walk) +
// the escaping-binding count (acc) via nb_out. -1 on a wall. Used to learn a fall-through
// branch's vid span (which includes interior if-segment / nested if-else deltas) and its
// escaping-binding count BEFORE the real two-sided layout is committed.
pub fn probe_mixed_walk(sa: i64, sl: i64, base: i64, buf: i64, params_addr: i64, n_params: i64, lvenv0: i64, nlv0: i64, strbuf: i64, offs: i64, ncount: i64, nb_out: i64) -> i64 {
    let pn: i64 = __mind_alloc(256 * 32);
    let pc: i64 = __mind_alloc(8);
    let pv: i64 = __mind_alloc(256 * 8);
    let lvbuf: i64 = __mind_alloc((nlv0 + sl + 512) * 24);
    let _cp: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, base);
    let e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(e_nlv, nlv0);
    let acc: i64 = __mind_alloc(128 * 24);
    let acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(acc_cell, 0);
    let w_ok: i64 = __mind_alloc(8);
    __mind_store_i64(w_ok, 1);
    let _sw: EmitState = emit_mixed_walk(es_new(), sa, sl, 0, buf, params_addr, n_params, pn, pc, pv, base_cell, lvbuf, e_nlv, acc, acc_cell, w_ok, strbuf, offs, ncount, 1);
    if __mind_load_i64(w_ok) == 0 {
        return 0 - 1;
    }
    __mind_store_i64(nb_out, __mind_load_i64(acc_cell));
    __mind_load_i64(base_cell)
}

// Emit CONST(ph_start + 2*i) placeholders for merged indices i in [lo, hi).
pub fn emit_block_ph(s: EmitState, ph_start: i64, lo: i64, hi: i64, then_nlets: i64) -> EmitState {
    if lo >= hi {
        return s;
    }
    let s1: EmitState = emit_mic3_const_i64(s, ph_start + 2 * lo, 0);
    emit_block_ph(s1, ph_start, lo + 1, hi, then_nlets)
}

// Fill 40-byte records [name_lo, name_hi, merge_id, then_val, else_val] per merged
// name (then-lets then else-lets). merge_id = ph_start+2i+1; placeholder = ph_start+2i.
pub fn fill_binds_block(bb: i64, then_lvbuf: i64, else_lvbuf: i64, nlv: i64, then_nlets: i64, else_nlets: i64, ph_start: i64, i: i64) -> i64 {
    let total: i64 = then_nlets + else_nlets;
    if i >= total {
        return total;
    }
    let ph: i64 = ph_start + 2 * i;
    let mid: i64 = ph + 1;
    if i < then_nlets {
        __mind_store_i64(bb + i * 40 + 0, __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 0));
        __mind_store_i64(bb + i * 40 + 8, __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 8));
        __mind_store_i64(bb + i * 40 + 16, mid);
        __mind_store_i64(bb + i * 40 + 24, __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 16));
        __mind_store_i64(bb + i * 40 + 32, ph)
    } else {
        let j: i64 = i - then_nlets;
        __mind_store_i64(bb + i * 40 + 0, __mind_load_i64(else_lvbuf + (nlv + j) * 24 + 0));
        __mind_store_i64(bb + i * 40 + 8, __mind_load_i64(else_lvbuf + (nlv + j) * 24 + 8));
        __mind_store_i64(bb + i * 40 + 16, mid);
        __mind_store_i64(bb + i * 40 + 24, ph);
        __mind_store_i64(bb + i * 40 + 32, __mind_load_i64(else_lvbuf + (nlv + j) * 24 + 16))
    }
    fill_binds_block(bb, then_lvbuf, else_lvbuf, nlv, then_nlets, else_nlets, ph_start, i + 1)
}

pub fn emit_block_bindings(s: EmitState, bb: i64, n: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let lo: i64 = __mind_load_i64(bb + i * 40 + 0);
    let hi: i64 = __mind_load_i64(bb + i * 40 + 8);
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, lo, hi, 0);
    let mid: i64 = __mind_load_i64(bb + i * 40 + 16);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_block_bindings(s2, bb, n, strbuf, offs, ncount, src, i + 1)
}

pub fn emit_block_merges(s: EmitState, bb: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let mid: i64 = __mind_load_i64(bb + i * 40 + 16);
    let tv: i64 = __mind_load_i64(bb + i * 40 + 24);
    let ev: i64 = __mind_load_i64(bb + i * 40 + 32);
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = emit_uleb128(s1, tv);
    let s3: EmitState = emit_uleb128(s2, ev);
    emit_block_merges(s3, bb, n, i + 1)
}

// Expose a fall-through if's merge bindings (name_lo, name_hi, merge_id) from the 40-byte
// `bb` records into 24-byte `bindout` records, so an ENCLOSING fall-through if whose branch
// CONTAINS this nested if-else statement can re-merge its escaping bindings (the parent reads
// merge_id as the value the binding holds after this if — see bind_append / emit_mixed_walk).
pub fn bb_to_bindout(bb: i64, bindout: i64, n: i64, i: i64) -> i64 {
    // Cap-guard (mirror the 256-cap carry-table fail-closed at nb_while_carry): the
    // caller `bindout` buffer is a fixed __mind_alloc(64 * 24), so copying more than 64
    // records would store past its end and corrupt adjacent arena state. Refuse (-1)
    // before any copy. Theoretical — needs >64 lets escaping one branch; no current fn
    // hits it — the callers fold -1 into a 0-binding (no bindings exposed upward).
    if n > 64 {
        return 0 - 1;
    }
    if i >= n {
        return n;
    }
    __mind_store_i64(bindout + i * 24 + 0, __mind_load_i64(bb + i * 40 + 0));
    __mind_store_i64(bindout + i * 24 + 8, __mind_load_i64(bb + i * 40 + 8));
    __mind_store_i64(bindout + i * 24 + 16, __mind_load_i64(bb + i * 40 + 16));
    bb_to_bindout(bb, bindout, n, i + 1)
}

// Does a block's PREFIX (all-but-last statements) contain any non-let statement (a bare
// call or an if-segment)? If so the block is a MIXED value block, not a leading-lets one.
pub fn block_prefix_has_nonlet(blk: i64) -> i64 {
    let sa: i64 = ast_child0(blk);
    let sl: i64 = ast_aux(blk);
    block_prefix_has_nonlet_loop(sa, sl - 1, 0)
}
pub fn block_prefix_has_nonlet_loop(sa: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    if ast_kind(__mind_load_i64(sa + i * 8)) != ast_let() {
        return 1;
    }
    block_prefix_has_nonlet_loop(sa, n, i + 1)
}

// Is `blk` a MIXED value block: prefix = lets / bare-calls / if-segments, then a trailing
// VALUE expression (not a return, not a let; a trailing if-EXPR must itself be a value).
pub fn branch_is_mixed_value_block(blk: i64) -> i64 {
    let sa: i64 = ast_child0(blk);
    let sl: i64 = ast_aux(blk);
    if sl < 1 {
        return 0;
    }
    let last: i64 = __mind_load_i64(sa + (sl - 1) * 8);
    let lk: i64 = ast_kind(last);
    if lk == ast_return() {
        return 0;
    }
    if lk == ast_let() {
        return 0;
    }
    if lk == ast_if() {
        if is_value_if_expr(last) != 1 {
            if is_mixed_value_if_expr(last) != 1 {
                return 0;
            }
        }
    }
    // Prefix statements: let / bare-expr / if-segment (no bare return).
    mixed_prefix_ok(sa, sl - 1, 0)
}
pub fn mixed_prefix_ok(sa: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return 1;
    }
    if ast_kind(__mind_load_i64(sa + i * 8)) == ast_return() {
        return 0;
    }
    mixed_prefix_ok(sa, n, i + 1)
}

// A value if-EXPRESSION whose branches are mixed value blocks AND at least one branch is
// genuinely MIXED (a non-let prefix stmt) — so it is NOT handled by the leading-lets-only
// emit_if_expr_block_lv and routes to emit_if_expr_mixedblock_lv.
pub fn is_mixed_value_if_expr(node: i64) -> i64 {
    if ast_kind(node) != ast_if() {
        return 0;
    }
    let then_blk: i64 = ast_child1(node);
    let else_blk: i64 = ast_child2(node);
    if else_blk == 0 {
        return 0;
    }
    if block_prefix_has_nonlet(then_blk) == 0 {
        if block_prefix_has_nonlet(else_blk) == 0 {
            return 0;
        }
    }
    if branch_is_mixed_value_block(then_blk) != 1 {
        return 0;
    }
    if branch_is_mixed_value_block(else_blk) != 1 {
        return 0;
    }
    1
}

// Emit ONE if-expr branch that is a mixed value block: the prefix (sl-1 stmts) via the
// mixed walk, then the trailing VALUE via emit_branch_value_lv. Populates `lvbuf` with the
// direct lets (for the merge tail), and returns via cells: the let count, the value result
// vid, and the end vid (base after the value). Fails closed (ok_out=0) on a wall OR if any
// interior if-segment escapes a binding (acc_count != nlets — the bubbled case is unhandled).
pub fn emit_mixed_value_branch(s: EmitState, sa: i64, sl: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64, lvenv0: i64, nlv0: i64, lvbuf: i64, strbuf: i64, offs: i64, ncount: i64, nlets_out: i64, result_out: i64, end_out: i64, ok_out: i64) -> EmitState {
    let _cp: i64 = lvenv_copy(lvbuf, lvenv0, nlv0, 0);
    let base_cell: i64 = __mind_alloc(8);
    __mind_store_i64(base_cell, base);
    let e_nlv: i64 = __mind_alloc(8);
    __mind_store_i64(e_nlv, nlv0);
    let acc: i64 = __mind_alloc(128 * 24);
    let acc_cell: i64 = __mind_alloc(8);
    __mind_store_i64(acc_cell, 0);
    let w_ok: i64 = __mind_alloc(8);
    __mind_store_i64(w_ok, 1);
    let s1: EmitState = emit_mixed_walk(s, sa, sl - 1, 0, buf, params_addr, n_params, nodes, cursor, vidbuf, base_cell, lvbuf, e_nlv, acc, acc_cell, w_ok, strbuf, offs, ncount, 0);
    if __mind_load_i64(w_ok) == 0 {
        __mind_store_i64(ok_out, 0);
        return s;
    }
    let nlets: i64 = __mind_load_i64(e_nlv) - nlv0;
    if __mind_load_i64(acc_cell) != nlets {
        __mind_store_i64(ok_out, 0);
        return s;
    }
    let val_base: i64 = __mind_load_i64(base_cell);
    let val: i64 = __mind_load_i64(sa + (sl - 1) * 8);
    let nlv_now: i64 = __mind_load_i64(e_nlv);
    let vspan: i64 = branch_val_span(val, buf, params_addr, n_params, val_base, lvbuf, nlv_now, strbuf, offs, ncount);
    if vspan < 0 {
        __mind_store_i64(ok_out, 0);
        return s;
    }
    let rcell: i64 = __mind_alloc(8);
    let vok: i64 = __mind_alloc(8);
    __mind_store_i64(vok, 1);
    let vbind: i64 = __mind_alloc(64 * 24);
    let vnb: i64 = __mind_alloc(8);
    __mind_store_i64(vnb, 0);
    let s2: EmitState = emit_branch_value_lv(s1, val, buf, params_addr, n_params, nodes, cursor, vidbuf, val_base, lvbuf, nlv_now, strbuf, offs, ncount, rcell, vok, vbind, vnb);
    if __mind_load_i64(vok) == 0 {
        __mind_store_i64(ok_out, 0);
        return s;
    }
    // The branch value (if itself a value if-expr) escapes bindings that stay live past the
    // value position; append them after the leading lets so the block's merge tail re-merges
    // them (their then-value = the value if-expr's own merge_id).
    let v_n: i64 = __mind_load_i64(vnb);
    let _va: i64 = lvenv_append_escapes(lvbuf, nlv_now, vbind, v_n, 0);
    __mind_store_i64(nlets_out, nlets + v_n);
    __mind_store_i64(result_out, __mind_load_i64(rcell));
    __mind_store_i64(end_out, val_base + vspan);
    __mind_store_i64(ok_out, 1);
    s2
}

// Emit a value if-EXPRESSION whose branches are MIXED value blocks (`(let|bare-call|
// if-segment)* + trailing VALUE`). Mirrors emit_if_expr_block_lv but uses emit_mixed_value_branch
// for each branch (mixed walk + value); the branch SPANS (which include interior OP_IF vid
// deltas) are learned by probing each branch into throwaway scratch first, then the layout
// (else_synth / ph_start / dst) is computed and the branches are re-emitted for real. The
// branch-local lets escape via the two-sided F2 merge (emit_block_ph / fill_binds_block /
// emit_block_bindings / emit_block_merges). okcell <- dst (-1 on a wall).
// Two-sided value-if-expr merge layout with the fresh/bound rule. Each branch-local let
// merges across the join: a then-block let contributes its own vid as then_val and a
// placeholder (else side) unless its name is already live in the outer env, in which case
// the else side reuses that OUTER vid (no placeholder); symmetric for else-block lets. Fills
// a 56-byte `bl` per let [name_lo,name_hi,merge_id,then_val,else_val,is_fresh,is_then] and
// returns the OP_IF dst. A fresh let consumes 2 vids (placeholder + merge_id), a bound let 1.
// Find a let in `sb`'s [nlv, nlv+n) records whose NAME equals buf[lo..hi); index or -1.
pub fn blk_name_find(sb: i64, nlv: i64, n: i64, buf: i64, lo: i64, hi: i64, j: i64) -> i64 {
    if j >= n {
        return 0 - 1;
    }
    if span_bytes_equal(buf, lo, hi, __mind_load_i64(sb + (nlv + j) * 24 + 0), __mind_load_i64(sb + (nlv + j) * 24 + 8)) == 1 {
        return j;
    }
    blk_name_find(sb, nlv, n, buf, lo, hi, j + 1)
}
// Count then-block lets whose name ALSO appears in the else block. Each such name is bound on
// BOTH branches of the value if-expr and collapses to ONE F2 phi (so the merge set is the
// UNION of names, not the multiset then_nlets+else_nlets).
pub fn blk_count_shared(then_lvbuf: i64, nlv: i64, then_nlets: i64, else_lvbuf: i64, else_nlets: i64, buf: i64, i: i64, acc: i64) -> i64 {
    if i >= then_nlets {
        return acc;
    }
    let lo: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 0);
    let hi: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 8);
    let hit: i64 = if blk_name_find(else_lvbuf, nlv, else_nlets, buf, lo, hi, 0) >= 0 {
        1
    } else {
        0
    };
    blk_count_shared(then_lvbuf, nlv, then_nlets, else_lvbuf, else_nlets, buf, i + 1, acc + hit)
}
// The actual else-index of the k-th else-let NOT shared with any then-let (the else-only
// portion of the merge set, laid out AFTER the then-lets in then-source order).
pub fn blk_nth_nonshared_else(else_lvbuf: i64, nlv: i64, else_nlets: i64, then_lvbuf: i64, then_nlets: i64, buf: i64, k: i64, j: i64) -> i64 {
    if j >= else_nlets {
        return 0 - 1;
    }
    let lo: i64 = __mind_load_i64(else_lvbuf + (nlv + j) * 24 + 0);
    let hi: i64 = __mind_load_i64(else_lvbuf + (nlv + j) * 24 + 8);
    if blk_name_find(then_lvbuf, nlv, then_nlets, buf, lo, hi, 0) >= 0 {
        return blk_nth_nonshared_else(else_lvbuf, nlv, else_nlets, then_lvbuf, then_nlets, buf, k, j + 1);
    }
    if k == 0 {
        return j;
    }
    blk_nth_nonshared_else(else_lvbuf, nlv, else_nlets, then_lvbuf, then_nlets, buf, k - 1, j + 1)
}
// Two-sided value-if-expr merge planner over the UNION OF NAMES. Bindings: bl[0,then_nlets)
// are the then-block lets (in then order); bl[then_nlets,n_merged) are the else-only lets.
// A then-let whose name also appears in else is a PHI (is_then=2, no placeholder, both sides
// are the respective branch's own vid, filled post-emit; eix[i] = the matching else index).
// A then-only / else-only let keeps the fresh/bound rule vs the outer env. eix carries the
// else-source index for phi + else-only rows so blk_fill_own can resolve the post-emit vids.
pub fn blk_layout(bl: i64, eix: i64, then_lvbuf: i64, else_lvbuf: i64, nlv: i64, then_nlets: i64, else_nlets: i64, n_merged: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv_outer: i64, i: i64, running: i64) -> i64 {
    if i >= n_merged {
        return running;
    }
    if i < then_nlets {
        let nlo: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 0);
        let nhi: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 8);
        let eidx: i64 = blk_name_find(else_lvbuf, nlv, else_nlets, buf, nlo, nhi, 0);
        if eidx >= 0 {
            // own vids read from the lvbufs (correct for the mixedblock PROBE path, which has
            // no post-emit fill; the block path overwrites both via blk_fill_own).
            let town: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 16);
            let eown: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx) * 24 + 16);
            __mind_store_i64(bl + i * 64 + 0, nlo);
            __mind_store_i64(bl + i * 64 + 8, nhi);
            __mind_store_i64(bl + i * 64 + 16, running);
            __mind_store_i64(bl + i * 64 + 24, town);
            __mind_store_i64(bl + i * 64 + 32, eown);
            __mind_store_i64(bl + i * 64 + 40, 0);
            __mind_store_i64(bl + i * 64 + 48, 2);
            __mind_store_i64(eix + i * 8, eidx);
            return blk_layout(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, else_nlets, n_merged, buf, params_addr, n_params, lvenv, nlv_outer, i + 1, running + 1);
        }
        let own: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 16);
        let ol: i64 = lvenv_lookup(buf, nlo, nhi, lvenv, nlv_outer, 0);
        let outer: i64 = if ol >= 0 {
            ol
        } else {
            resolve_param(params_addr, n_params, buf, nlo, nhi)
        };
        let bound: i64 = if outer >= 0 {
            1
        } else {
            0
        };
        let opp: i64 = if bound == 1 {
            outer
        } else {
            running
        };
        let mid: i64 = if bound == 1 {
            running
        } else {
            running + 1
        };
        let isf: i64 = if bound == 1 {
            0
        } else {
            1
        };
        let nextr: i64 = if bound == 1 {
            running + 1
        } else {
            running + 2
        };
        __mind_store_i64(bl + i * 64 + 0, nlo);
        __mind_store_i64(bl + i * 64 + 8, nhi);
        __mind_store_i64(bl + i * 64 + 16, mid);
        __mind_store_i64(bl + i * 64 + 24, own);
        __mind_store_i64(bl + i * 64 + 32, opp);
        __mind_store_i64(bl + i * 64 + 40, isf);
        __mind_store_i64(bl + i * 64 + 48, 1);
        __mind_store_i64(eix + i * 8, 0 - 1);
        return blk_layout(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, else_nlets, n_merged, buf, params_addr, n_params, lvenv, nlv_outer, i + 1, nextr);
    }
    let k: i64 = i - then_nlets;
    let eidx2: i64 = blk_nth_nonshared_else(else_lvbuf, nlv, else_nlets, then_lvbuf, then_nlets, buf, k, 0);
    let nlo2: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx2) * 24 + 0);
    let nhi2: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx2) * 24 + 8);
    let own2: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx2) * 24 + 16);
    let ol2: i64 = lvenv_lookup(buf, nlo2, nhi2, lvenv, nlv_outer, 0);
    let outer2: i64 = if ol2 >= 0 {
        ol2
    } else {
        resolve_param(params_addr, n_params, buf, nlo2, nhi2)
    };
    let bound2: i64 = if outer2 >= 0 {
        1
    } else {
        0
    };
    let opp2: i64 = if bound2 == 1 {
        outer2
    } else {
        running
    };
    let mid2: i64 = if bound2 == 1 {
        running
    } else {
        running + 1
    };
    let isf2: i64 = if bound2 == 1 {
        0
    } else {
        1
    };
    let nextr2: i64 = if bound2 == 1 {
        running + 1
    } else {
        running + 2
    };
    __mind_store_i64(bl + i * 64 + 0, nlo2);
    __mind_store_i64(bl + i * 64 + 8, nhi2);
    __mind_store_i64(bl + i * 64 + 16, mid2);
    __mind_store_i64(bl + i * 64 + 24, opp2);
    __mind_store_i64(bl + i * 64 + 32, own2);
    __mind_store_i64(bl + i * 64 + 40, isf2);
    __mind_store_i64(bl + i * 64 + 48, 0);
    __mind_store_i64(eix + i * 8, eidx2);
    blk_layout(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, else_nlets, n_merged, buf, params_addr, n_params, lvenv, nlv_outer, i + 1, nextr2)
}
// Count FRESH lets whose is_then matches `want` (placeholders emitted in the OPPOSITE branch).
pub fn blk_fresh_side(bl: i64, n: i64, want: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let add: i64 = if __mind_load_i64(bl + i * 64 + 40) == 1 {
        if __mind_load_i64(bl + i * 64 + 48) == want {
            1
        } else {
            0
        }
    } else {
        0
    };
    add + blk_fresh_side(bl, n, want, i + 1)
}
// Emit a placeholder CONST 0 for each FRESH let whose is_then == want (in index order). A
// then-block let's placeholder is its else_val; an else-block let's placeholder is its then_val.
pub fn blk_emit_ph(s: EmitState, bl: i64, n: i64, want: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    if __mind_load_i64(bl + i * 64 + 40) == 1 {
        if __mind_load_i64(bl + i * 64 + 48) == want {
            let ph: i64 = if want == 1 {
                __mind_load_i64(bl + i * 64 + 32)
            } else {
                __mind_load_i64(bl + i * 64 + 24)
            };
            let s1: EmitState = emit_mic3_const_i64(s, ph, 0);
            return blk_emit_ph(s1, bl, n, want, i + 1);
        }
    }
    blk_emit_ph(s, bl, n, want, i + 1)
}
pub fn blk_emit_bindings(s: EmitState, bl: i64, n: i64, strbuf: i64, offs: i64, ncount: i64, src: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let nidx: i64 = intern_find(strbuf, offs, ncount, src, __mind_load_i64(bl + i * 64 + 0), __mind_load_i64(bl + i * 64 + 8), 0);
    let s1: EmitState = emit_uleb128(s, nidx);
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(bl + i * 64 + 16));
    blk_emit_bindings(s2, bl, n, strbuf, offs, ncount, src, i + 1)
}
pub fn blk_emit_merges(s: EmitState, bl: i64, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, __mind_load_i64(bl + i * 64 + 16));
    let s2: EmitState = emit_uleb128(s1, __mind_load_i64(bl + i * 64 + 24));
    let s3: EmitState = emit_uleb128(s2, __mind_load_i64(bl + i * 64 + 32));
    blk_emit_merges(s3, bl, n, i + 1)
}
// Copy `n` lv-env entries (name_lo/name_hi/vid, 24-byte) from lvbuf[base..] into a unified
// merge accumulator `cacc[0..)`. Used to prepend a fall-through block's leading lets (whose
// then-value is the let's own vid) ahead of the if-segments' bubbled bindings.
pub fn acc_copy_lvbuf(cacc: i64, lvbuf: i64, base: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(cacc + i * 24 + 0, __mind_load_i64(lvbuf + (base + i) * 24 + 0));
    __mind_store_i64(cacc + i * 24 + 8, __mind_load_i64(lvbuf + (base + i) * 24 + 8));
    __mind_store_i64(cacc + i * 24 + 16, __mind_load_i64(lvbuf + (base + i) * 24 + 16));
    acc_copy_lvbuf(cacc, lvbuf, base, n, i + 1)
}
// Append `n` 24-byte acc records from `src[0..)` into cacc[at..].
pub fn acc_copy_acc(cacc: i64, at: i64, src: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        return n;
    }
    __mind_store_i64(cacc + (at + i) * 24 + 0, __mind_load_i64(src + i * 24 + 0));
    __mind_store_i64(cacc + (at + i) * 24 + 8, __mind_load_i64(src + i * 24 + 8));
    __mind_store_i64(cacc + (at + i) * 24 + 16, __mind_load_i64(src + i * 24 + 16));
    acc_copy_acc(cacc, at, src, n, i + 1)
}
// The TRUE vid base AFTER a block's leading lets — probes emit_let_inits_lv into throwaway
// scratch. An if-expr let init counts as ONE instruction but consumes its whole OP_IF's vid
// delta, so the instruction count under-estimates the vid offset; the if-expr block emitter
// needs the real delta to place the value / else_synth / merge tail correctly.
pub fn letchain_vid_base(then_sa: i64, nlets: i64, base0: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> i64 {
    let pb_base: i64 = __mind_alloc(8);
    __mind_store_i64(pb_base, base0);
    let pb_lvbuf: i64 = __mind_alloc((nlv + nlets + 2) * 24);
    let _c: i64 = lvenv_copy(pb_lvbuf, lvenv, nlv, 0);
    let pb_ok: i64 = __mind_alloc(8);
    __mind_store_i64(pb_ok, 1);
    let pb_nodes: i64 = __mind_alloc(256 * 32);
    let pb_cursor: i64 = __mind_alloc(8);
    let pb_vidbuf: i64 = __mind_alloc(256 * 8);
    let _e: EmitState = emit_let_inits_lv(es_new(), then_sa, nlets, 0, buf, params_addr, n_params, pb_nodes, pb_cursor, pb_vidbuf, pb_base, pb_lvbuf, nlv, pb_ok, strbuf, offs, ncount);
    __mind_load_i64(pb_base)
}
// Fill each binding's OWN-side value from the now-emitted branch lv-buf (a then-block let's
// then_val, an else-block let's else_val). Run AFTER both branches emit (when emit_let_inits_lv
// has written the real vids). Used by the block if-expr emitter, which has no probe phase.
pub fn blk_fill_own(bl: i64, eix: i64, then_lvbuf: i64, else_lvbuf: i64, nlv: i64, then_nlets: i64, n_merged: i64, i: i64) -> i64 {
    if i >= n_merged {
        return n_merged;
    }
    let is_then: i64 = __mind_load_i64(bl + i * 64 + 48);
    if is_then == 2 {
        // PHI (same name both branches): fill BOTH then_val (then-let i's own) and else_val
        // (the matching else-let's own, eix[i]).
        let town: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 16);
        let eidx: i64 = __mind_load_i64(eix + i * 8);
        let eown: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx) * 24 + 16);
        __mind_store_i64(bl + i * 64 + 24, town);
        __mind_store_i64(bl + i * 64 + 32, eown);
        return blk_fill_own(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, n_merged, i + 1);
    }
    if is_then == 1 {
        let own: i64 = __mind_load_i64(then_lvbuf + (nlv + i) * 24 + 16);
        __mind_store_i64(bl + i * 64 + 24, own);
        return blk_fill_own(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, n_merged, i + 1);
    }
    let eidx2: i64 = __mind_load_i64(eix + i * 8);
    let own2: i64 = __mind_load_i64(else_lvbuf + (nlv + eidx2) * 24 + 16);
    __mind_store_i64(bl + i * 64 + 32, own2);
    blk_fill_own(bl, eix, then_lvbuf, else_lvbuf, nlv, then_nlets, n_merged, i + 1)
}
pub fn emit_if_expr_mixedblock_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    // OP_IF cond.
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    // PROBE both branches into throwaway scratch to learn their vid spans + let counts.
    let pn: i64 = __mind_alloc(256 * 32);
    let pc: i64 = __mind_alloc(8);
    let pv: i64 = __mind_alloc(256 * 8);
    let p_then_lvbuf: i64 = __mind_alloc((nlv + then_sl + 8) * 24);
    let then_nl_c: i64 = __mind_alloc(8);
    let then_rs_c: i64 = __mind_alloc(8);
    let then_end_c: i64 = __mind_alloc(8);
    let then_ok_c: i64 = __mind_alloc(8);
    __mind_store_i64(then_ok_c, 0);
    let _pt: EmitState = emit_mixed_value_branch(es_new(), then_sa, then_sl, buf, params_addr, n_params, pn, pc, pv, after_cond + 1, lvenv, nlv, p_then_lvbuf, strbuf, offs, ncount, then_nl_c, then_rs_c, then_end_c, then_ok_c);
    if __mind_load_i64(then_ok_c) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_nlets: i64 = __mind_load_i64(then_nl_c);
    let then_end: i64 = __mind_load_i64(then_end_c);
    let else_synth: i64 = then_end;
    let p_else_lvbuf: i64 = __mind_alloc((nlv + else_sl + 8) * 24);
    let else_nl_c: i64 = __mind_alloc(8);
    let else_rs_c: i64 = __mind_alloc(8);
    let else_end_c: i64 = __mind_alloc(8);
    let else_ok_c: i64 = __mind_alloc(8);
    __mind_store_i64(else_ok_c, 0);
    let _pe: EmitState = emit_mixed_value_branch(es_new(), else_sa, else_sl, buf, params_addr, n_params, pn, pc, pv, else_synth + 1, lvenv, nlv, p_else_lvbuf, strbuf, offs, ncount, else_nl_c, else_rs_c, else_end_c, else_ok_c);
    if __mind_load_i64(else_ok_c) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_nlets: i64 = __mind_load_i64(else_nl_c);
    let else_end: i64 = __mind_load_i64(else_end_c);
    // Merge set = UNION of names (a name bound on BOTH branches is one F2 phi).
    let blk_shared: i64 = blk_count_shared(p_then_lvbuf, nlv, then_nlets, p_else_lvbuf, else_nlets, buf, 0, 0);
    let n_merged: i64 = then_nlets + else_nlets - blk_shared;
    let eix: i64 = __mind_alloc((then_nlets + else_nlets + 1) * 8);
    let ph_start: i64 = else_end;
    // Fresh/bound layout: a branch let already live in the outer env reuses that OUTER vid on
    // the opposite side (no placeholder, 1 vid); a fresh let gets a placeholder (2 vids).
    let bl: i64 = __mind_alloc((n_merged + 1) * 64);
    let dst: i64 = blk_layout(bl, eix, p_then_lvbuf, p_else_lvbuf, nlv, then_nlets, else_nlets, n_merged, buf, params_addr, n_params, lvenv, nlv, 0, ph_start);
    // Block INSTR lengths. Placeholders emitted in a branch = the FRESH lets of the OPPOSITE
    // side (a then-block let's placeholder lives in the else branch, and vice versa).
    let then_pf_instrs: i64 = measure_mixed_instrs_probe(then_sa, then_sl - 1, buf, params_addr, n_params, lvenv, nlv);
    let then_v_instrs: i64 = branch_val_instrs(__mind_load_i64(then_sa + (then_sl - 1) * 8), buf, params_addr, n_params, p_then_lvbuf, nlv + then_nlets);
    let then_len: i64 = 1 + then_pf_instrs + then_v_instrs + blk_fresh_side(bl, n_merged, 0, 0);
    let else_pf_instrs: i64 = measure_mixed_instrs_probe(else_sa, else_sl - 1, buf, params_addr, n_params, lvenv, nlv);
    let else_v_instrs: i64 = branch_val_instrs(__mind_load_i64(else_sa + (else_sl - 1) * 8), buf, params_addr, n_params, p_else_lvbuf, nlv + else_nlets);
    let else_len: i64 = 1 + else_pf_instrs + else_v_instrs + blk_fresh_side(bl, n_merged, 1, 0);
    // EMIT for real.
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let then_lvbuf: i64 = __mind_alloc((nlv + then_sl + 8) * 24);
    let r_then_nl: i64 = __mind_alloc(8);
    let r_then_rs: i64 = __mind_alloc(8);
    let r_then_end: i64 = __mind_alloc(8);
    let r_then_ok: i64 = __mind_alloc(8);
    __mind_store_i64(r_then_ok, 0);
    let s7: EmitState = emit_mixed_value_branch(s6, then_sa, then_sl, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, lvenv, nlv, then_lvbuf, strbuf, offs, ncount, r_then_nl, r_then_rs, r_then_end, r_then_ok);
    if __mind_load_i64(r_then_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let s8: EmitState = blk_emit_ph(s7, bl, n_merged, 0, 0);
    let s9: EmitState = emit_uleb128(s8, __mind_load_i64(r_then_rs));
    let s10: EmitState = emit_uleb128(s9, else_len);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let else_lvbuf: i64 = __mind_alloc((nlv + else_sl + 8) * 24);
    let r_else_nl: i64 = __mind_alloc(8);
    let r_else_rs: i64 = __mind_alloc(8);
    let r_else_end: i64 = __mind_alloc(8);
    let r_else_ok: i64 = __mind_alloc(8);
    __mind_store_i64(r_else_ok, 0);
    let s12: EmitState = emit_mixed_value_branch(s11, else_sa, else_sl, buf, params_addr, n_params, nodes, cursor, vidbuf, else_synth + 1, lvenv, nlv, else_lvbuf, strbuf, offs, ncount, r_else_nl, r_else_rs, r_else_end, r_else_ok);
    if __mind_load_i64(r_else_ok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let s13: EmitState = blk_emit_ph(s12, bl, n_merged, 1, 0);
    let s14: EmitState = emit_uleb128(s13, __mind_load_i64(r_else_rs));
    let s15: EmitState = emit_uleb128(s14, dst);
    let s16: EmitState = emit_uleb128(s15, n_merged);
    let s17: EmitState = blk_emit_bindings(s16, bl, n_merged, strbuf, offs, ncount, buf, 0);
    let s18: EmitState = emit_uleb128(s17, n_merged);
    let s19: EmitState = blk_emit_merges(s18, bl, n_merged, 0);
    if bindout != 0 {
        let _bo: i64 = blk_lay_to_bindout(bl, bindout, n_merged, 0);
        __mind_store_i64(nbind_cell, n_merged)
    }
    __mind_store_i64(okcell, dst);
    s19
}

// measure_mixed_instrs over a fresh throwaway lvbuf/nlv-cell (for block-length sizing).
// The outer env NAMES must be copied in so a prefix bare-call/let that references an outer
// let (not just a param) resolves while measuring — otherwise count_nonparam_nodes_lv fails.
pub fn measure_mixed_instrs_probe(stmts_addr: i64, n: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv0: i64) -> i64 {
    let lvbuf: i64 = __mind_alloc((nlv0 + n + 8) * 24);
    let _c: i64 = lvenv_copy(lvbuf, lvenv, nlv0, 0);
    let m: i64 = __mind_alloc(8);
    __mind_store_i64(m, nlv0);
    measure_mixed_instrs(stmts_addr, n, 0, buf, params_addr, n_params, lvbuf, m)
}

// Dispatcher: route a value if-expr `init` to the single-expr emitter (both branches
// 0 lets, byte-identical to before) or the general block emitter.
// `bindout`/`nbind_cell` (may be 0 to skip): expose this value if-expr's two-sided merge
// bindings (name + merge_id) so an ENCLOSING if-expr whose branch VALUE is this if-expr can
// re-merge them — its branch-local lets stay live through the value position (SSA F2).
pub fn emit_if_expr_any_lv(s: EmitState, if_node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    if nbind_cell != 0 {
        __mind_store_i64(nbind_cell, 0)
    }
    if is_mixed_value_if_expr(if_node) == 1 {
        return emit_if_expr_mixedblock_lv(s, if_node, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, okcell, lvenv, nlv, strbuf, offs, ncount, bindout, nbind_cell);
    }
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    let tn: i64 = ast_aux(then_blk) - 1;
    let en: i64 = ast_aux(else_blk) - 1;
    if tn == 0 {
        if en == 0 {
            let c: i64 = ast_child0(if_node);
            let t: i64 = branch_single_expr(then_blk);
            let e: i64 = branch_single_expr(else_blk);
            return emit_if_expr_lv(s, c, t, e, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, okcell, lvenv, nlv, strbuf, offs, ncount, bindout, nbind_cell);
        }
    }
    emit_if_expr_block_lv(s, if_node, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, okcell, lvenv, nlv, strbuf, offs, ncount, bindout, nbind_cell)
}

// Emit one if-expr BRANCH VALUE at `base`, returning its result vid via rcell. A plain
// expression flattens + emits its tree (result = root vid); a NESTED if-EXPRESSION value
// (else-if chains) emits ONE recursive OP_IF (result = its dst). In both cases the value
// occupies vids [base .. result], so the caller's next vid is result+1. okcell<-0 wall.
// A value if-expression of EITHER form: leading-lets blocks (emit_if_expr_block_lv) OR
// mixed blocks (emit_if_expr_mixedblock_lv). Both lower to ONE OP_IF value via emit_if_expr_any_lv.
pub fn is_any_value_if_expr(node: i64) -> i64 {
    if is_value_if_expr(node) == 1 {
        return 1;
    }
    is_mixed_value_if_expr(node)
}

// A value-if with ONE DIVERGING branch (`if c { return X; } else { V }`, or the
// mirror). branch_is_value_block REJECTS a return-terminated block, so
// is_any_value_if_expr misses this shape and the native let-init/return/assign
// routing would send it to nb_expr — whose in-expression ast_if arm fail-closes to a
// single const-0 (1 id). The COUNT side (nb_count_stmt's generic ast_if arm) always
// counts the full if (cond+then+else+merge+dst, many ids), so that const-0 emit
// DESYNCS next_id and every downstream slot is wrong. nb_if_value produces the SAME
// id progression the count side expects and (with the divergence handling in
// nb_if_value_simple/merged) lowers the live branch's value to dst. Accept exactly the
// one-branch-diverges shape: the other branch must be a value block; both-diverge is
// unreachable-valued and not accepted. Native-ELF-only routing; main.mind never binds
// a diverging value-if, so this is inert during self-compile (byte-identical oracle).
pub fn is_diverging_value_if(node: i64) -> i64 {
    if ast_kind(node) != ast_if() {
        return 0;
    }
    let else_blk: i64 = ast_child2(node);
    if else_blk == 0 {
        return 0;
    }
    let then_blk: i64 = ast_child1(node);
    let then_sa: i64 = ast_child0(then_blk);
    let then_sl: i64 = ast_aux(then_blk);
    let else_sa: i64 = ast_child0(else_blk);
    let else_sl: i64 = ast_aux(else_blk);
    let then_div: i64 = nb_block_diverges(then_sa, then_sl);
    let else_div: i64 = nb_block_diverges(else_sa, else_sl);
    if then_div == 1 {
        if else_div == 1 {
            return 0;
        }
        return branch_is_value_block(else_blk);
    }
    if else_div == 1 {
        return branch_is_value_block(then_blk);
    }
    0
}

// True for any if-expr the native-ELF value path must route through nb_if_value: a
// plain value-if OR a one-diverging-branch value-if.
pub fn is_native_if_value(node: i64) -> i64 {
    if is_any_value_if_expr(node) == 1 {
        return 1;
    }
    is_diverging_value_if(node)
}

// `vbind`/`vnb` (may be 0): when the value is itself a value if-expr, expose ITS escaped
// merge bindings so the enclosing block's merge tail re-merges them (the value's branch lets
// stay live past the value). A plain expression value escapes nothing -> vnb := 0.
pub fn emit_branch_value_lv(s: EmitState, expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, rcell: i64, okcell: i64, vbind: i64, vnb: i64) -> EmitState {
    if vnb != 0 {
        __mind_store_i64(vnb, 0)
    }
    if is_any_value_if_expr(expr) == 1 {
        let ic: i64 = __mind_alloc(8);
        __mind_store_i64(ic, 0 - 1);
        let sx: EmitState = emit_if_expr_any_lv(s, expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base, ic, lvenv, nlv, strbuf, offs, ncount, vbind, vnb);
        let d: i64 = __mind_load_i64(ic);
        if d < 0 {
            __mind_store_i64(okcell, 0);
            return s;
        }
        __mind_store_i64(rcell, d);
        return sx;
    }
    let root: i64 = flatten_branch_lv(expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base, lvenv, nlv);
    if root < 0 {
        __mind_store_i64(okcell, 0);
        return s;
    }
    let n: i64 = __mind_load_i64(cursor);
    let se: EmitState = emit_mic3_tree_body(s, nodes, n, vidbuf, buf, strbuf, offs, ncount, 0);
    __mind_store_i64(rcell, root);
    se
}

// Instr count a branch value contributes to a block length: 1 for a nested if-expr
// (one OP_IF), else its non-param node count.
pub fn branch_val_instrs(expr: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64) -> i64 {
    if is_any_value_if_expr(expr) == 1 {
        return 1;
    }
    count_nonparam_nodes_lv(expr, buf, params_addr, n_params, lvenv, nlv)
}

// VID SPAN of a branch value placed at descriptor base `base`: a plain value occupies
// its nonparam node count; a nested if-EXPRESSION value occupies its whole OP_IF vid
// delta (dst - base + 1), learned by probing emit_if_expr_any_lv into throwaway scratch.
// Returns -1 on a wall.
pub fn branch_val_span(expr: i64, buf: i64, params_addr: i64, n_params: i64, base: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> i64 {
    if is_any_value_if_expr(expr) == 1 {
        let pn: i64 = __mind_alloc(256 * 32);
        let pc: i64 = __mind_alloc(8);
        let pv: i64 = __mind_alloc(256 * 8);
        let pcell: i64 = __mind_alloc(8);
        __mind_store_i64(pcell, 0 - 1);
        let _ps: EmitState = emit_if_expr_any_lv(es_new(), expr, buf, params_addr, n_params, pn, pc, pv, base, pcell, lvenv, nlv, strbuf, offs, ncount, 0, 0);
        let pdst: i64 = __mind_load_i64(pcell);
        if pdst < 0 {
            return 0 - 1;
        }
        return pdst - base + 1;
    }
    count_nonparam_nodes_lv(expr, buf, params_addr, n_params, lvenv, nlv)
}

// Number of bindings a branch VALUE escapes: a value if-expr whose own branches carry lets
// re-merges them, and those bindings must bubble into the ENCLOSING if-expr's merge. Probed
// into throwaway scratch (count is base-independent). A plain value escapes nothing -> 0.
pub fn branch_escape_count(expr: i64, buf: i64, params_addr: i64, n_params: i64, base: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64) -> i64 {
    if is_any_value_if_expr(expr) != 1 {
        return 0;
    }
    let pn: i64 = __mind_alloc(256 * 32);
    let pc: i64 = __mind_alloc(8);
    let pv: i64 = __mind_alloc(256 * 8);
    let pcell: i64 = __mind_alloc(8);
    __mind_store_i64(pcell, 0 - 1);
    let vb: i64 = __mind_alloc(64 * 24);
    let vnb: i64 = __mind_alloc(8);
    __mind_store_i64(vnb, 0);
    let _ps: EmitState = emit_if_expr_any_lv(es_new(), expr, buf, params_addr, n_params, pn, pc, pv, base, pcell, lvenv, nlv, strbuf, offs, ncount, vb, vnb);
    if __mind_load_i64(pcell) < 0 {
        return 0;
    }
    __mind_load_i64(vnb)
}

// Probe a branch VALUE's escaping bindings and APPEND their NAME spans to `dest` at index
// `dest_at` (the merge_id +16 is filled later by the real capture). Returns the count. Lets the
// leading-let block emitter (emit_if_expr_block_lv) treat branch-value escapes as extra branch
// lets so blk_layout/blk_fill_own re-merge them uniformly with the leading lets.
pub fn branch_escape_probe(expr: i64, buf: i64, params_addr: i64, n_params: i64, base: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, dest: i64, dest_at: i64) -> i64 {
    if is_any_value_if_expr(expr) != 1 {
        return 0;
    }
    let pn: i64 = __mind_alloc(256 * 32);
    let pc: i64 = __mind_alloc(8);
    let pv: i64 = __mind_alloc(256 * 8);
    let pcell: i64 = __mind_alloc(8);
    __mind_store_i64(pcell, 0 - 1);
    let vb: i64 = __mind_alloc(64 * 24);
    let vnb: i64 = __mind_alloc(8);
    __mind_store_i64(vnb, 0);
    let _ps: EmitState = emit_if_expr_any_lv(es_new(), expr, buf, params_addr, n_params, pn, pc, pv, base, pcell, lvenv, nlv, strbuf, offs, ncount, vb, vnb);
    if __mind_load_i64(pcell) < 0 {
        return 0;
    }
    let n: i64 = __mind_load_i64(vnb);
    let _ap: i64 = lvenv_append_escapes(dest, dest_at, vb, n, 0);
    n
}

// Probe the escaping bindings of a leading-let block's LET INITS (not its trailing value). A
// `let X = <value if-expr>` whose init is a same-name phi / escaping if-expr surfaces that
// inner merge binding into the enclosing scope (the Rust lowering keeps it live after the let),
// so it must bubble into the enclosing if's merge. For each leading let i with an if-expr init,
// probe it at the init's vid base (base after the i prior let inits) with the env [0..nlv+i),
// appending each escape's NAME+vid into `dest` starting at `dest_at + acc`. Returns the running
// count. A block with no if-expr-init lets returns 0 (eff == nlets, byte-identical).
pub fn block_init_escape_probe(stmts_addr: i64, nlets: i64, base0: i64, buf: i64, params_addr: i64, n_params: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, dest: i64, dest_at: i64, i: i64, acc: i64) -> i64 {
    if i >= nlets {
        return acc;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let init: i64 = ast_child2(stmt);
    if is_any_value_if_expr(init) != 1 {
        return block_init_escape_probe(stmts_addr, nlets, base0, buf, params_addr, n_params, lvenv, nlv, strbuf, offs, ncount, dest, dest_at, i + 1, acc);
    }
    let init_base: i64 = letchain_vid_base(stmts_addr, i, base0, buf, params_addr, n_params, lvenv, nlv, strbuf, offs, ncount);
    let ec: i64 = branch_escape_probe(init, buf, params_addr, n_params, init_base, lvenv, nlv + i, strbuf, offs, ncount, dest, dest_at + acc);
    block_init_escape_probe(stmts_addr, nlets, base0, buf, params_addr, n_params, lvenv, nlv, strbuf, offs, ncount, dest, dest_at, i + 1, acc + ec)
}

// emit_if_expr_lv for the case where a branch VALUE is itself a value if-expr that escapes
// bindings (else-if chains carrying lets). Mirrors emit_if_expr_lv but re-merges the bubbled
// branch-value escapes via the two-sided F2 block-merge tail (then-escape -> placeholder on the
// else side; else-escape -> placeholder on the then side), reusing fill_binds_block /
// emit_block_ph / emit_block_bindings / emit_block_merges (the fall-through merge helpers).
pub fn emit_if_expr_lv_bubble(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, then_en: i64, else_en: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let n_merged: i64 = then_en + else_en;
    // vid layout: spans place the else value, so ph_start (the merge vid base) is known before
    // either block is emitted (the placeholders live in the OPPOSITE block but use ph_start vids).
    let then_v_instrs: i64 = branch_val_instrs(then_expr, buf, params_addr, n_params, lvenv, nlv);
    let else_v_instrs: i64 = branch_val_instrs(else_expr, buf, params_addr, n_params, lvenv, nlv);
    let then_v_span: i64 = branch_val_span(then_expr, buf, params_addr, n_params, after_cond + 1, lvenv, nlv, strbuf, offs, ncount);
    if then_v_span < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_synth: i64 = after_cond + 1 + then_v_span;
    let else_v_span: i64 = branch_val_span(else_expr, buf, params_addr, n_params, else_synth + 1, lvenv, nlv, strbuf, offs, ncount);
    if else_v_span < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let ph_start: i64 = else_synth + 1 + else_v_span;
    let dst: i64 = ph_start + 2 * n_merged;
    // THEN block: synth + then value (capture its escapes) + placeholders for the ELSE escapes.
    let then_len: i64 = 1 + then_v_instrs + else_en;
    let s5: EmitState = emit_uleb128(s4, then_len);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let then_acc: i64 = __mind_alloc(64 * 24);
    let then_nb_c: i64 = __mind_alloc(8);
    __mind_store_i64(then_nb_c, 0);
    let trcell: i64 = __mind_alloc(8);
    let tvok: i64 = __mind_alloc(8);
    __mind_store_i64(tvok, 1);
    let s7: EmitState = emit_branch_value_lv(s6, then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, lvenv, nlv, strbuf, offs, ncount, trcell, tvok, then_acc, then_nb_c);
    if __mind_load_i64(tvok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_root: i64 = __mind_load_i64(trcell);
    let s8: EmitState = emit_block_ph(s7, ph_start, then_en, n_merged, then_en);
    let s9: EmitState = emit_uleb128(s8, then_root);
    // ELSE block: synth + else value (capture its escapes) + placeholders for the THEN escapes.
    let else_len: i64 = 1 + else_v_instrs + then_en;
    let s10: EmitState = emit_uleb128(s9, else_len);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let else_acc: i64 = __mind_alloc(64 * 24);
    let else_nb_c: i64 = __mind_alloc(8);
    __mind_store_i64(else_nb_c, 0);
    let ercell: i64 = __mind_alloc(8);
    let evok: i64 = __mind_alloc(8);
    __mind_store_i64(evok, 1);
    let s12: EmitState = emit_branch_value_lv(s11, else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, else_synth + 1, lvenv, nlv, strbuf, offs, ncount, ercell, evok, else_acc, else_nb_c);
    if __mind_load_i64(evok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_root: i64 = __mind_load_i64(ercell);
    let s13: EmitState = emit_block_ph(s12, ph_start, 0, then_en, then_en);
    let s14: EmitState = emit_uleb128(s13, else_root);
    let s15: EmitState = emit_uleb128(s14, dst);
    // merge tail from the captured branch-value escapes (then escapes then else escapes).
    let bb: i64 = __mind_alloc((n_merged + 1) * 40);
    let _fb: i64 = fill_binds_block(bb, then_acc, else_acc, 0, then_en, else_en, ph_start, 0);
    let s16: EmitState = emit_uleb128(s15, n_merged);
    let s17: EmitState = emit_block_bindings(s16, bb, n_merged, strbuf, offs, ncount, buf, 0);
    let s18: EmitState = emit_uleb128(s17, n_merged);
    let s19: EmitState = emit_block_merges(s18, bb, n_merged, 0);
    // Expose this level's escaping bindings upward so an ENCLOSING if-expr re-merges
    // them (lower.rs F2 branch-binding propagation through nested value-ifs). Without
    // this, a `let` buried in a doubly-nested branch (e.g. nb_count_carried_nested's
    // `_s`) is dropped at the outermost value-if and the merge set undercounts.
    if bindout != 0 {
        let bo: i64 = bb_to_bindout(bb, bindout, n_merged, 0);
        // bo < 0 => over-64-cap refusal (no copy): expose 0 bindings upward (fail-closed).
        if bo >= 0 {
            __mind_store_i64(nbind_cell, n_merged)
        } else {
            __mind_store_i64(nbind_cell, 0)
        }
    }
    __mind_store_i64(okcell, dst);
    s19
}

pub fn emit_if_expr_lv(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64, lvenv: i64, nlv: i64, strbuf: i64, offs: i64, ncount: i64, bindout: i64, nbind_cell: i64) -> EmitState {
    if nbind_cell != 0 {
        __mind_store_i64(nbind_cell, 0)
    }
    // If a branch VALUE is itself a value if-expr that escapes bindings, re-merge them via the
    // bubble path (which now ALSO bubbles those escapes upward via bindout). Otherwise (the
    // common case — a leaf both-single-expr if) the merge is empty, nbind stays 0, and the
    // original layout is byte-identical.
    let then_en: i64 = branch_escape_count(then_expr, buf, params_addr, n_params, base0 + 1, lvenv, nlv, strbuf, offs, ncount);
    let else_en: i64 = branch_escape_count(else_expr, buf, params_addr, n_params, base0 + 1, lvenv, nlv, strbuf, offs, ncount);
    if then_en + else_en > 0 {
        return emit_if_expr_lv_bubble(s, cond_expr, then_expr, else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, okcell, lvenv, nlv, strbuf, offs, ncount, then_en, else_en, bindout, nbind_cell);
    }
    let cond_id: i64 = flatten_branch_lv(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0, lvenv, nlv);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes_lv(cond_expr, buf, params_addr, n_params, lvenv, nlv);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, buf, strbuf, offs, ncount, 0);
    let after_cond: i64 = base0 + cond_nonparam;
    let then_synth: i64 = after_cond;
    let then_is_if: i64 = is_any_value_if_expr(then_expr);
    let then_instrs: i64 = if then_is_if == 1 {
        1
    } else {
        count_nonparam_nodes_lv(then_expr, buf, params_addr, n_params, lvenv, nlv)
    };
    let s5: EmitState = emit_uleb128(s4, then_instrs + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let trcell: i64 = __mind_alloc(8);
    let tvok: i64 = __mind_alloc(8);
    __mind_store_i64(tvok, 1);
    let s7: EmitState = emit_branch_value_lv(s6, then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1, lvenv, nlv, strbuf, offs, ncount, trcell, tvok, 0, 0);
    if __mind_load_i64(tvok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_root: i64 = __mind_load_i64(trcell);
    let s8: EmitState = emit_uleb128(s7, then_root);
    // after_branch = result+1 for an if-expr value (its dst is the last fresh vid);
    // base + nonparam for a plain value (a param/let-ref result has a LOW reused vid).
    let after_then: i64 = if then_is_if == 1 {
        then_root + 1
    } else {
        after_cond + 1 + then_instrs
    };
    let else_synth: i64 = after_then;
    let else_is_if: i64 = is_any_value_if_expr(else_expr);
    let else_instrs: i64 = if else_is_if == 1 {
        1
    } else {
        count_nonparam_nodes_lv(else_expr, buf, params_addr, n_params, lvenv, nlv)
    };
    let s9: EmitState = emit_uleb128(s8, else_instrs + 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let ercell: i64 = __mind_alloc(8);
    let evok: i64 = __mind_alloc(8);
    __mind_store_i64(evok, 1);
    let s11: EmitState = emit_branch_value_lv(s10, else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, else_synth + 1, lvenv, nlv, strbuf, offs, ncount, ercell, evok, 0, 0);
    if __mind_load_i64(evok) == 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_root: i64 = __mind_load_i64(ercell);
    let s12: EmitState = emit_uleb128(s11, else_root);
    let after_else: i64 = if else_is_if == 1 {
        else_root + 1
    } else {
        else_synth + 1 + else_instrs
    };
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// True iff `node` is an if-EXPRESSION usable as a value: an else-ful if whose then
// and else blocks are each a single value-expression (branch_single_expr).
// A branch usable as an if-EXPRESSION value: `let* VALUE` where VALUE is a plain
// value expression (not a return, not a bare if-statement). Single-expr branches
// (0 lets) are the common case; block branches carry leading lets that escape.
pub fn branch_is_value_block(blk: i64) -> i64 {
    let sa: i64 = ast_child0(blk);
    let sl: i64 = ast_aux(blk);
    if sl < 1 {
        return 0;
    }
    let nl: i64 = count_leading_lets(sa, sl, 0);
    if nl != sl - 1 {
        return 0;
    }
    let last: i64 = __mind_load_i64(sa + (sl - 1) * 8);
    let lk: i64 = ast_kind(last);
    if lk == ast_return() {
        return 0;
    }
    // A trailing if-EXPRESSION value is allowed (nested `else if` chains) — it must
    // itself be a value if-expr (recursively). A bare if-statement (no else) is not.
    if lk == ast_if() {
        return is_value_if_expr(last);
    }
    1
}

pub fn is_value_if_expr(node: i64) -> i64 {
    if ast_kind(node) != ast_if() {
        return 0;
    }
    if ast_child2(node) == 0 {
        return 0;
    }
    if branch_is_value_block(ast_child1(node)) == 0 {
        return 0;
    }
    if branch_is_value_block(ast_child2(node)) == 0 {
        return 0;
    }
    1
}

pub fn flatten_stmt_seq(src: i64, stmts_addr: i64, stmts_len: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, env: i64, nlets_cell: i64, plan: i64, nplan_cell: i64, i: i64) -> i64 {
    if i >= stmts_len - 1 {
        return 1;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let nlets: i64 = __mind_load_i64(nlets_cell);
    let p: i64 = __mind_load_i64(nplan_cell);
    if ast_kind(stmt) == ast_let() {
        let name: i64 = ast_child0(stmt);
        let init: i64 = ast_child2(stmt);
        // (type 7) let bound to an if-EXPRESSION value: `let X = if C {A} else {B}`.
        // Emit the OP_IF (then_result/else_result = the branch values, dst = the merged
        // value); bind X -> a synthetic dst-slot whose vid is set to the OP_IF dst in
        // Pass B, so later refs to X resolve to the merged value.
        if is_any_value_if_expr(init) == 1 {
            let q7_nodes: i64 = __mind_alloc(256 * 32);
            let q7_cursor: i64 = __mind_alloc(8);
            let q7_vidbuf: i64 = __mind_alloc(256 * 8);
            let q7_cell: i64 = __mind_alloc(8);
            __mind_store_i64(q7_cell, 0 - 1);
            let q7_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
            let _q7lv: i64 = seq_env_to_lvenv(env, nlets, 0, q7_lvenv, 0, 0);
            let q7: EmitState = emit_if_expr_any_lv(es_new(), init, src, params_addr, n_params, q7_nodes, q7_cursor, q7_vidbuf, 0, q7_cell, q7_lvenv, nlets, 0, 0, 0, 0, 0);
            let q7_dst: i64 = __mind_load_i64(q7_cell);
            if q7_dst >= 0 {
                let dst_slot: i64 = __mind_load_i64(cursor);
                __mind_store_i64(nodes + dst_slot * 32 + 0, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 8, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 16, 0);
                __mind_store_i64(nodes + dst_slot * 32 + 24, 0);
                __mind_store_i64(cursor, dst_slot + 1);
                __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
                __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
                __mind_store_i64(env + nlets * 24 + 16, dst_slot);
                __mind_store_i64(nlets_cell, nlets + 1);
                __mind_store_i64(plan + p * 64 + 0, 7);
                __mind_store_i64(plan + p * 64 + 8, init);
                __mind_store_i64(plan + p * 64 + 16, q7_dst + 1);
                __mind_store_i64(plan + p * 64 + 24, params_addr);
                __mind_store_i64(plan + p * 64 + 32, n_params);
                __mind_store_i64(plan + p * 64 + 40, dst_slot);
                __mind_store_i64(nplan_cell, p + 1);
                return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
            }
        }
        let start: i64 = __mind_load_i64(cursor);
        let root_slot: i64 = flatten_expr_env(init, src, params_addr, n_params, nodes, cursor, env, nlets);
        if root_slot < 0 {
            return 0;
        }
        let end: i64 = __mind_load_i64(cursor);
        __mind_store_i64(env + nlets * 24 + 0, ast_span_lo(name));
        __mind_store_i64(env + nlets * 24 + 8, ast_span_hi(name));
        __mind_store_i64(env + nlets * 24 + 16, root_slot);
        __mind_store_i64(nlets_cell, nlets + 1);
        __mind_store_i64(plan + p * 64 + 0, 0);
        __mind_store_i64(plan + p * 64 + 8, start);
        __mind_store_i64(plan + p * 64 + 16, end);
        __mind_store_i64(nplan_cell, p + 1);
        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
    }
    if ast_kind(stmt) == ast_if() {
        // (type 9) two-sided FALL-THROUGH if-else statement: `if C { lets+bare-calls }
        // else { lets+bare-calls } TRAIL` — both branches pure side-effects (no return,
        // no nested if), branch lets escape via the two-sided F2 merge. Probed BEFORE the
        // else-less guard below; on a miss any other two-sided if still fails closed.
        if ast_child2(stmt) != 0 {
            let te_blk: i64 = ast_child1(stmt);
            let ee_blk: i64 = ast_child2(stmt);
            if mixed_prefix_ok(ast_child0(te_blk), ast_aux(te_blk), 0) == 1 {
                if mixed_prefix_ok(ast_child0(ee_blk), ast_aux(ee_blk), 0) == 1 {
                    let i9_nodes: i64 = __mind_alloc(256 * 32);
                    let i9_cursor: i64 = __mind_alloc(8);
                    let i9_vidbuf: i64 = __mind_alloc(256 * 8);
                    let i9_cell: i64 = __mind_alloc(8);
                    __mind_store_i64(i9_cell, 0 - 1);
                    let i9_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                    let _i9lv: i64 = seq_env_to_lvenv(env, nlets, 0, i9_lvenv, 0, 0);
                    let i9_bo: i64 = __mind_alloc(64 * 24);
                    let i9_nb: i64 = __mind_alloc(8);
                    let i9p: EmitState = emit_if_else_fallthrough_lv(es_new(), stmt, src, params_addr, n_params, i9_nodes, i9_cursor, i9_vidbuf, 0, i9_cell, i9_lvenv, nlets, 0, 0, 0, 0, i9_bo, i9_nb);
                    let i9_dst: i64 = __mind_load_i64(i9_cell);
                    if i9_dst >= 0 {
                        __mind_store_i64(plan + p * 64 + 0, 9);
                        __mind_store_i64(plan + p * 64 + 8, stmt);
                        __mind_store_i64(plan + p * 64 + 16, i9_dst + 1);
                        __mind_store_i64(plan + p * 64 + 24, params_addr);
                        __mind_store_i64(plan + p * 64 + 32, n_params);
                        __mind_store_i64(nplan_cell, p + 1);
                        return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                    }
                }
            }
        }
        // else-less if whose then-block's single statement is `return E`.
        if ast_child2(stmt) != 0 {
            return 0;
        }
        let then_blk: i64 = ast_child1(stmt);
        // (type 3) if-with-SEQ-then-block: the then-block is a SEQUENCE (>=2 stmts)
        // of if-segments (each an arbitrary-depth nested if-return chain), no lets,
        // no trailing value. The outer OP_IF's then-branch emits those segments in
        // order; the then-result is the last segment's dst. Probe the self-contained
        // emitter once (base0=0) to learn the vid delta, store it + the stmt node.
        let then_sa: i64 = ast_child0(then_blk);
        let then_sl: i64 = ast_aux(then_blk);
        // (type 4, n_segs==0) FALL-THROUGH guard if `if C { let* }` — the then-block is
        // ALL lets (side-effect, no return/segment); the block falls through and the
        // lets merge with their values. Covers single-let `if c { let re = call(); }`
        // (then_sl==1) which the >=2 type-4 path below skips. Routed through the same
        // type-4 emitter (plan type 4) which now handles n_segs==0.
        if then_sl >= 1 {
            let g_nlets: i64 = count_leading_lets(then_sa, then_sl, 0);
            if g_nlets == then_sl {
                let g_nodes: i64 = __mind_alloc(256 * 32);
                let g_cursor: i64 = __mind_alloc(8);
                let g_vidbuf: i64 = __mind_alloc(256 * 8);
                let g_cell: i64 = __mind_alloc(8);
                __mind_store_i64(g_cell, 0 - 1);
                let g_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _glv: i64 = seq_env_to_lvenv(env, nlets, 0, g_lvenv, 0, 0);
                let g_lvbuf: i64 = __mind_alloc((nlets + g_nlets + 8) * 24);
                let g_bo: i64 = __mind_alloc(64 * 24);
                let g_nb: i64 = __mind_alloc(8);
                let gp: EmitState = emit_if_let_seq_then_instr_lv(es_new(), stmt, src, params_addr, n_params, g_nodes, g_cursor, g_vidbuf, 0, g_cell, g_lvenv, nlets, g_lvbuf, 0, 0, 0, g_bo, g_nb);
                let g_dst: i64 = __mind_load_i64(g_cell);
                if g_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 4);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, g_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
            }
        }
        // (type 8) FALL-THROUGH side-effect block `if C { lets + bare-calls }` (no return,
        // no if-segment) — covers bare-call-only `if c { __mind_store_i64(p, v); }` and
        // let/call mixes the pure-lets guard above doesn't. Probe emit_if_fallthrough_lv.
        if then_sl >= 1 {
            if fallthrough_all_sidefx(then_sa, then_sl, 0) == 1 {
                let ft_nodes: i64 = __mind_alloc(256 * 32);
                let ft_cursor: i64 = __mind_alloc(8);
                let ft_vidbuf: i64 = __mind_alloc(256 * 8);
                let ft_cell: i64 = __mind_alloc(8);
                __mind_store_i64(ft_cell, 0 - 1);
                let ft_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _ftlv: i64 = seq_env_to_lvenv(env, nlets, 0, ft_lvenv, 0, 0);
                let ft_lvbuf: i64 = __mind_alloc((nlets + then_sl + 512) * 24);
                let ft_bo: i64 = __mind_alloc(64 * 24);
                let ft_nb: i64 = __mind_alloc(8);
                let ftp: EmitState = emit_if_fallthrough_lv(es_new(), stmt, src, params_addr, n_params, ft_nodes, ft_cursor, ft_vidbuf, 0, ft_cell, ft_lvenv, nlets, ft_lvbuf, 0, 0, 0, ft_bo, ft_nb);
                let ft_dst: i64 = __mind_load_i64(ft_cell);
                if ft_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 8);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, ft_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
            }
        }
        // (type 4) if-with-LET-then-block: the then-block is leading `let` bindings
        // then >=1 if-segment(s), carrying a merge tail. Probe the let-aware emitter
        // (base0=0, empty outer lv-env) to learn the vid delta. Takes priority over
        // type 3 when leading lets are present (type 3 requires 0 lets).
        if then_sl >= 2 {
            let t4_nlets: i64 = count_leading_lets(then_sa, then_sl, 0);
            if t4_nlets >= 1 {
                let t4_segs: i64 = then_sl - t4_nlets;
                if t4_segs >= 1 {
                    if seq_then_all_ifs(then_sa + t4_nlets * 8, t4_segs, 0) == 1 {
                        let p4_nodes: i64 = __mind_alloc(256 * 32);
                        let p4_cursor: i64 = __mind_alloc(8);
                        let p4_vidbuf: i64 = __mind_alloc(256 * 8);
                        let p4_cell: i64 = __mind_alloc(8);
                        __mind_store_i64(p4_cell, 0 - 1);
                        // Name-only seq lv-env (vids unresolved at probe time) so the
                        // cond / then-lets can reference sequence-level lets.
                        let p4_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                        let _p4lv: i64 = seq_env_to_lvenv(env, nlets, 0, p4_lvenv, 0, 0);
                        let p4_lvbuf: i64 = __mind_alloc((nlets + t4_nlets + 8) * 24);
                        let p4_bo: i64 = __mind_alloc(64 * 24);
                        let p4_nb: i64 = __mind_alloc(8);
                        let p4: EmitState = emit_if_let_seq_then_instr_lv(es_new(), stmt, src, params_addr, n_params, p4_nodes, p4_cursor, p4_vidbuf, 0, p4_cell, p4_lvenv, nlets, p4_lvbuf, 0, 0, 0, p4_bo, p4_nb);
                        let p4_dst: i64 = __mind_load_i64(p4_cell);
                        if p4_dst >= 0 {
                            __mind_store_i64(plan + p * 64 + 0, 4);
                            __mind_store_i64(plan + p * 64 + 8, stmt);
                            __mind_store_i64(plan + p * 64 + 16, p4_dst + 1);
                            __mind_store_i64(plan + p * 64 + 24, params_addr);
                            __mind_store_i64(plan + p * 64 + 32, n_params);
                            __mind_store_i64(nplan_cell, p + 1);
                            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                        }
                    }
                }
                // (type 5, case A in a sequence) leading lets + a single final `return E`
                // (the block DIVERGES, so the lets merge with POISON). type-4 above only
                // takes lets + if-SEGMENTS (fall-through); this takes lets + return. e.g.
                // scan's `if is_alpha(b) { let hi=..; let kind=..; let nt=..; return scan(..) }`.
                if then_sl - t4_nlets == 1 {
                    let t5a_fin: i64 = __mind_load_i64(then_sa + t4_nlets * 8);
                    if ast_kind(t5a_fin) == ast_return() {
                        let q5_nodes: i64 = __mind_alloc(256 * 32);
                        let q5_cursor: i64 = __mind_alloc(8);
                        let q5_vidbuf: i64 = __mind_alloc(256 * 8);
                        let q5_cell: i64 = __mind_alloc(8);
                        __mind_store_i64(q5_cell, 0 - 1);
                        let q5_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                        let _q5lv: i64 = seq_env_to_lvenv(env, nlets, 0, q5_lvenv, 0, 0);
                        let q5_bindout: i64 = __mind_alloc(64 * 24);
                        let q5_nbind: i64 = __mind_alloc(8);
                        let q5: EmitState = emit_if_chain_instr_lv(es_new(), stmt, src, params_addr, n_params, q5_nodes, q5_cursor, q5_vidbuf, 0, q5_cell, q5_lvenv, nlets, 0, 0, 0, q5_bindout, q5_nbind);
                        let q5_dst: i64 = __mind_load_i64(q5_cell);
                        if q5_dst >= 0 {
                            __mind_store_i64(plan + p * 64 + 0, 5);
                            __mind_store_i64(plan + p * 64 + 8, stmt);
                            __mind_store_i64(plan + p * 64 + 16, q5_dst + 1);
                            __mind_store_i64(plan + p * 64 + 24, params_addr);
                            __mind_store_i64(plan + p * 64 + 32, n_params);
                            __mind_store_i64(nplan_cell, p + 1);
                            return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                        }
                    }
                }
            }
            if seq_then_all_ifs(then_sa, then_sl, 0) == 1 {
                let pr_nodes: i64 = __mind_alloc(256 * 32);
                let pr_cursor: i64 = __mind_alloc(8);
                let pr_vidbuf: i64 = __mind_alloc(256 * 8);
                let pr_cell: i64 = __mind_alloc(8);
                __mind_store_i64(pr_cell, 0 - 1);
                let pr_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _prlv: i64 = seq_env_to_lvenv(env, nlets, 0, pr_lvenv, 0, 0);
                let pr: EmitState = emit_if_seq_then_instr_lv(es_new(), stmt, src, params_addr, n_params, pr_nodes, pr_cursor, pr_vidbuf, 0, pr_cell, pr_lvenv, nlets, 0, 0, 0);
                let pr_dst: i64 = __mind_load_i64(pr_cell);
                if pr_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 3);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, pr_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
            }
        }
        // (type 6) MIXED returning then-block: any `{let | if-segment}* return E` with
        // >=1 if-segment (parse_primary_ns's tk_ident block, type_of_expr's binop arm
        // `let op; if{ret} if{ret} let lhs; return ..`). General ordered walk.
        if then_sl >= 2 {
            if mixed_shape_segs(then_sa, then_sl, 0, 0) >= 0 {
                let p6_nodes: i64 = __mind_alloc(256 * 32);
                let p6_cursor: i64 = __mind_alloc(8);
                let p6_vidbuf: i64 = __mind_alloc(256 * 8);
                let p6_cell: i64 = __mind_alloc(8);
                __mind_store_i64(p6_cell, 0 - 1);
                let p6_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
                let _p6lv: i64 = seq_env_to_lvenv(env, nlets, 0, p6_lvenv, 0, 0);
                let p6_bindout: i64 = __mind_alloc(64 * 24);
                let p6_nbind: i64 = __mind_alloc(8);
                let p6: EmitState = emit_if_mixed_then_instr_lv(es_new(), stmt, src, params_addr, n_params, p6_nodes, p6_cursor, p6_vidbuf, 0, p6_cell, p6_lvenv, nlets, 0, 0, 0, p6_bindout, p6_nbind);
                let p6_dst: i64 = __mind_load_i64(p6_cell);
                if p6_dst >= 0 {
                    __mind_store_i64(plan + p * 64 + 0, 6);
                    __mind_store_i64(plan + p * 64 + 8, stmt);
                    __mind_store_i64(plan + p * 64 + 16, p6_dst + 1);
                    __mind_store_i64(plan + p * 64 + 24, params_addr);
                    __mind_store_i64(plan + p * 64 + 32, n_params);
                    __mind_store_i64(nplan_cell, p + 1);
                    return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
                }
                return 0;
            }
        }
        // (type 8, with if-segments) FALL-THROUGH block whose prefix interleaves lets,
        // bare-calls AND if-segments (no top-level return) — the pure-side-effect type-8
        // above (fallthrough_all_sidefx) rejected it for the if-segments. emit_if_fallthrough_lv
        // (mixed walk) handles them; it fails closed if any if-segment escapes a binding.
        if mixed_prefix_ok(then_sa, then_sl, 0) == 1 {
            let fs_nodes: i64 = __mind_alloc(256 * 32);
            let fs_cursor: i64 = __mind_alloc(8);
            let fs_vidbuf: i64 = __mind_alloc(256 * 8);
            let fs_cell: i64 = __mind_alloc(8);
            __mind_store_i64(fs_cell, 0 - 1);
            let fs_lvenv: i64 = __mind_alloc((nlets + 1) * 24);
            let _fslv: i64 = seq_env_to_lvenv(env, nlets, 0, fs_lvenv, 0, 0);
            let fs_lvbuf: i64 = __mind_alloc((nlets + then_sl + 512) * 24);
            let fs_bo: i64 = __mind_alloc(64 * 24);
            let fs_nb: i64 = __mind_alloc(8);
            let fsp: EmitState = emit_if_fallthrough_lv(es_new(), stmt, src, params_addr, n_params, fs_nodes, fs_cursor, fs_vidbuf, 0, fs_cell, fs_lvenv, nlets, fs_lvbuf, 0, 0, 0, fs_bo, fs_nb);
            let fs_dst: i64 = __mind_load_i64(fs_cell);
            if fs_dst >= 0 {
                __mind_store_i64(plan + p * 64 + 0, 8);
                __mind_store_i64(plan + p * 64 + 8, stmt);
                __mind_store_i64(plan + p * 64 + 16, fs_dst + 1);
                __mind_store_i64(plan + p * 64 + 24, params_addr);
                __mind_store_i64(plan + p * 64 + 32, n_params);
                __mind_store_i64(nplan_cell, p + 1);
                return flatten_stmt_seq(src, stmts_addr, stmts_len, params_addr, n_params, nodes, cursor, env, nlets_cell, plan, nplan_cell, i + 1);
            }
        }
        let ret_stmt: i64 = branch_single_expr(then_blk);
        if ret_stmt < 0 {
            return 0;
        }
        // (type 2) NESTED if-return segment: the outer then-block's single stmt is
        // ITSELF an else-less if whose then-block is `return E`. Flatten the 3 trees
        // (outer cond, inner cond, inner ret) CONSECUTIVELY into the shared array and
        // store the contiguous range + 2 split points + 3 roots (fits the 64B entry).
        if ast_kind(ret_stmt) == ast_if() {
            if ast_child2(ret_stmt) != 0 {
                return 0;
            }
            let inner_then: i64 = ast_child1(ret_stmt);
            let inner_ret: i64 = branch_single_expr(inner_then);
