pub fn op_add() -> i64 {
    1
}
pub fn op_sub() -> i64 {
    2
}
pub fn op_mul() -> i64 {
    3
}
pub fn op_div() -> i64 {
    4
}
pub fn op_lt() -> i64 {
    5
}
pub fn op_gt() -> i64 {
    6
}
pub fn op_eq() -> i64 {
    7
}
pub fn op_le() -> i64 {
    8
}
pub fn op_ge() -> i64 {
    9
}
pub fn op_ne() -> i64 {
    10
}
pub fn op_bitand() -> i64 {
    11
}
pub fn op_bitor() -> i64 {
    12
}
pub fn op_bitxor() -> i64 {
    13
}
pub fn op_shl() -> i64 {
    14
}
pub fn op_shr() -> i64 {
    15
