// examples/mindc_mind/main.mind — Phase 6.5 Stage 5 APEX driver.
//
// Combined pure-MIND mindc front-end: lexer + parser + type-checker +
// MLIR-text emitter wired into a single cdylib.  Every function from
// the four preceding stages (Phase 6.1–6.4) is inlined here verbatim
// (duplicate helper names are deduplicated to their first canonical
// definition); the only net-new code is the `mindc_compile` entry
// at the bottom.
//
// Why a single file rather than `use examples.lexer.main` etc.:
// mindc v0.5.x's `use` resolver covers `std.*` only; user-space
// .mind files that are binary entry-point files (they define `main`)
// are not exposed as importable modules.  The single-file merge is
// therefore the only path that compiles through the current surface
// grammar.  A follow-on RFC will introduce a `mod` keyword for
// user-space module composition.
//
// Build:
//   cargo run --features "mlir-build std-surface cross-module-imports" \
//       --bin mindc -- \
//       examples/mindc_mind/main.mind \
//       --emit-shared examples/mindc_mind/libmindc_mind.so
//
// Smoke gate (Phase 6.5 Stage 5 contract):
//   mindc_compile(buf_addr, buf_len) on fixture.mind produces an
//   EmitState whose .buf is byte-identical to the 148-byte MLIR text
//   documented in examples/mindc_mind/EXPECTED.md and to the output
//   of `mindc --emit-ir` on the same fixture.  Verification is done
//   by examples/mindc_mind/bootstrap_smoke.py.

import std.vec;
import std.map;
import std.string;
import std.io;

// ===========================================================================
// SECTION 1 — LEXER (Phase 6.1)
// examples/lexer/main.mind, verbatim.
// Provides: lex(buf, buf_len) -> Vec
// ===========================================================================

// ===== Token kinds (i64 tags) =====

pub fn tk_eof() -> i64 {
    0
}
pub fn tk_ident() -> i64 {
    1
}
pub fn tk_int() -> i64 {
    2
}
pub fn tk_lparen() -> i64 {
    3
}
pub fn tk_rparen() -> i64 {
    4
}
pub fn tk_lbrace() -> i64 {
    5
}
pub fn tk_rbrace() -> i64 {
    6
}
pub fn tk_comma() -> i64 {
    7
}
pub fn tk_semi() -> i64 {
    8
}
pub fn tk_colon() -> i64 {
    9
}
pub fn tk_arrow() -> i64 {
    10
}
pub fn tk_eq() -> i64 {
    11
}
pub fn tk_plus() -> i64 {
    12
}
pub fn tk_minus() -> i64 {
    13
}
pub fn tk_star() -> i64 {
    14
}
pub fn tk_slash() -> i64 {
    15
}
pub fn tk_lt() -> i64 {
    16
}
pub fn tk_gt() -> i64 {
    17
}
pub fn tk_kw_fn() -> i64 {
    18
}
pub fn tk_kw_let() -> i64 {
    19
}
pub fn tk_kw_use() -> i64 {
    20
}
pub fn tk_kw_pub() -> i64 {
    21
}
pub fn tk_dot() -> i64 {
    22
}
pub fn tk_eqeq() -> i64 {
    23
}
pub fn tk_le() -> i64 {
    24
}
pub fn tk_ge() -> i64 {
    25
}
pub fn tk_ne() -> i64 {
    26
}
pub fn tk_bang() -> i64 {
    27
}
pub fn tk_kw_if() -> i64 {
    28
}
pub fn tk_kw_else() -> i64 {
    29
}
pub fn tk_amp() -> i64 {
    30
}
pub fn tk_pipe() -> i64 {
    31
}
pub fn tk_caret() -> i64 {
    32
}
pub fn tk_shl() -> i64 {
    33
}
pub fn tk_shr() -> i64 {
    34
}
pub fn tk_percent() -> i64 {
    35
}
pub fn tk_float() -> i64 {
    36
}
// `&&` / `||` logical operators. Two-char tokens (like tk_shl/tk_shr), lexed
// before the single-char `&` (tk_amp) / `|` (tk_pipe) so `a && b` is ONE token,
// not two tk_amp. They carry NO tk_to_op mapping: the Pratt parser desugars them
// at parse time to a short-circuit value-if (desugar_andand / desugar_oror).
pub fn tk_andand() -> i64 {
    37
}
pub fn tk_oror() -> i64 {
    38
}

// ===== Byte loads =====

pub fn load_byte(buf: i64, i: i64) -> i64 {
    __mind_load_i64(buf + i) & 255
}

// ===== Classification primitives =====

pub fn is_space(b: i64) -> i64 {
    if b == 32 {
        return 1;
    }
    if b == 9 {
        return 1;
    }
    if b == 10 {
        return 1;
    }
    if b == 13 {
        return 1;
    }
    0
}

pub fn is_digit(b: i64) -> i64 {
    if b >= 48 {
        if b <= 57 {
            return 1;
        }
    }
    0
}

pub fn is_alpha(b: i64) -> i64 {
    if b >= 65 {
        if b <= 90 {
            return 1;
        }
    }
    if b >= 97 {
        if b <= 122 {
            return 1;
        }
    }
    if b == 95 {
        return 1;
    }
    0
}

pub fn is_alnum(b: i64) -> i64 {
    if is_alpha(b) == 1 {
        return 1;
    }
    is_digit(b)
}

// ===== Token-stream packing =====

pub fn push_token(toks: Vec, kind: i64, lo: i64, hi: i64) -> Vec {
    let t1: Vec = vec_push(toks, kind);
    let t2: Vec = vec_push(t1, lo);
    vec_push(t2, hi)
}

// ===== Keyword detection =====

pub fn classify_ident(buf: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = hi - lo;
    if n == 2 {
        if load_byte(buf, lo) == 102 {
            if load_byte(buf, lo + 1) == 110 {
                return tk_kw_fn();
            }
        }
        // `if` (105,102): keyword token for control-flow parsing.
        if load_byte(buf, lo) == 105 {
            if load_byte(buf, lo + 1) == 102 {
                return tk_kw_if();
            }
        }
    }
    if n == 4 {
        // `else` (101,108,115,101): keyword token for control-flow parsing.
        if load_byte(buf, lo + 0) == 101 {
            if load_byte(buf, lo + 1) == 108 {
                if load_byte(buf, lo + 2) == 115 {
                    if load_byte(buf, lo + 3) == 101 {
                        return tk_kw_else();
                    }
                }
            }
        }
    }
    if n == 3 {
        let c0: i64 = load_byte(buf, lo);
        let c1: i64 = load_byte(buf, lo + 1);
        let c2: i64 = load_byte(buf, lo + 2);
        if c0 == 108 {
            if c1 == 101 {
                if c2 == 116 {
                    return tk_kw_let();
                }
            }
        }
        if c0 == 117 {
            if c1 == 115 {
                if c2 == 101 {
                    return tk_kw_use();
                }
            }
        }
        if c0 == 112 {
            if c1 == 117 {
                if c2 == 98 {
                    return tk_kw_pub();
                }
            }
        }
    }
    if n == 6 {
        // `import` (105,109,112,111,114,116) lowers like `use`: one placeholder
        // stub per item, matching mindc-Rust lower_to_ir's Import arm. The token
        // shape `import std . vec ;` is identical to `use std . vec ;`, so the
        // existing parse_use offsets apply unchanged.
        if load_byte(buf, lo + 0) == 105 {
            if load_byte(buf, lo + 1) == 109 {
                if load_byte(buf, lo + 2) == 112 {
                    if load_byte(buf, lo + 3) == 111 {
                        if load_byte(buf, lo + 4) == 114 {
                            if load_byte(buf, lo + 5) == 116 {
                                return tk_kw_use();
                            }
                        }
                    }
                }
            }
        }
    }
    tk_ident()
}

// Returns 1 if the bytes buf[lo..hi] spell "struct" (6 bytes).
pub fn is_struct_kw(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo + 0) == 115 {
            if load_byte(buf, lo + 1) == 116 {
                if load_byte(buf, lo + 2) == 114 {
                    if load_byte(buf, lo + 3) == 117 {
                        if load_byte(buf, lo + 4) == 99 {
                            if load_byte(buf, lo + 5) == 116 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// `const` is lexed as a plain identifier (no dedicated keyword token), so the
// top-level item parser detects it by byte content, exactly like is_struct_kw.
// A top-level `const NAME: TYPE = EXPR` declaration lowers (in mindc-Rust) to a
// single `const.i64 0` / `output` placeholder — the value is inlined at each use
// site, so the declaration itself is a unit no-op (parallels StructDef/EnumDef).
// Detecting it here lets the parser consume the whole declaration as ONE stub
// item instead of mis-splitting it into per-token leaves.
pub fn is_const_kw(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 5 {
        if load_byte(buf, lo + 0) == 99 {
            if load_byte(buf, lo + 1) == 111 {
                if load_byte(buf, lo + 2) == 110 {
                    if load_byte(buf, lo + 3) == 115 {
                        if load_byte(buf, lo + 4) == 116 {
                            return 1;
                        }
                    }
                }
            }
        }
    }
    0
}

// `enum` is lexed as a plain identifier; detect it by byte content like
// is_struct_kw. A top-level `enum Name { Variant, .. }` lowers (in mindc-Rust) to
// a single `const.i64 0` / `output` stub item (parallels StructDef). It reuses
// parse_struct_def (skip-to-rbrace, one ast_struct_def stub leaf). NOTE: enum
// bodies here are flat variant lists (no nested `{}`), matching skip_to_rbrace's
// naive first-`}` scan, same as struct.
pub fn is_enum_kw(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 4 {
        if load_byte(buf, lo + 0) == 101 {
            if load_byte(buf, lo + 1) == 110 {
                if load_byte(buf, lo + 2) == 117 {
                    if load_byte(buf, lo + 3) == 109 {
                        return 1;
                    }
                }
            }
        }
    }
    0
}

// `extern` is lexed as a plain identifier; detect it by byte content. A top-level
// `extern "C" { unsafe fn a(..); unsafe fn b(..); }` block lowers (in mindc-Rust)
// to a SINGLE stub item for the WHOLE block (one `const.i64 0` / `output`, no
// `// fn` comment — verified: std/net.mind's 15-fn block emits exactly one
// comment-less stub). The block holds only body-less `fn NAME(..);` declarations
// (no nested braces), so skip_to_rbrace finds the block's closing `}` directly.
pub fn is_extern_kw(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo + 0) == 101 {
            if load_byte(buf, lo + 1) == 120 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 101 {
                        if load_byte(buf, lo + 4) == 114 {
                            if load_byte(buf, lo + 5) == 110 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// `module` is lexed as a plain identifier; detect it by byte content. A top-level
// `module NAME { ... }` block lowers (in mindc-Rust) to a SINGLE stub item for the
// whole block (verified on phase_10_5_module: `module governance { const .. }` →
// one `const.i64 0` / `output`). It reuses parse_extern_block (skip-to-rbrace, one
// stub leaf). The module body here has no nested `{}`, matching skip_to_rbrace.
pub fn is_module_kw(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo + 0) == 109 {
            if load_byte(buf, lo + 1) == 111 {
                if load_byte(buf, lo + 2) == 100 {
                    if load_byte(buf, lo + 3) == 117 {
                        if load_byte(buf, lo + 4) == 108 {
                            if load_byte(buf, lo + 5) == 101 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// Advance past all tokens until (and including) the closing `}` of a struct body.
pub fn skip_to_rbrace(toks: Vec, pos: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return pos;
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        return pos + 1;
    }
    skip_to_rbrace(toks, pos + 1)
}

// Parse a struct definition: consume `struct Name { ... }` and return a single
// ast_struct_def leaf node so the emitter can emit exactly one stub for it.
pub fn parse_struct_def(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let after: i64 = skip_to_rbrace(toks, pos + 2);
    let hi: i64 = tok_hi(toks, after - 1);
    let n: i64 = ast_new_leaf(ast_struct_def(), lo, hi);
    pr_new(after, n)
}

// True iff `pos` is the first token of a new top-level item: an item begins
// with `use` / `pub` / `fn`, or an identifier whose bytes are `struct` / `const`
// (which the lexer emits as plain idents). A top-level `const`'s value
// expression never contains these item-leading tokens, so this is a safe
// terminator for skip_const_decl. (Source-text type names like `i32`/`u32` are
// idents but are neither `struct` nor `const`, so they do not stop the scan.)
pub fn tok_is_item_start(toks: Vec, pos: i64, buf: i64) -> i64 {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_use() {
        return 1;
    }
    if k == tk_kw_pub() {
        return 1;
    }
    if k == tk_kw_fn() {
        return 1;
    }
    if k == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_struct_kw(buf, lo, hi) == 1 {
            return 1;
        }
        if is_enum_kw(buf, lo, hi) == 1 {
            return 1;
        }
        if is_extern_kw(buf, lo, hi) == 1 {
            return 1;
        }
        if is_module_kw(buf, lo, hi) == 1 {
            return 1;
        }
        if is_const_kw(buf, lo, hi) == 1 {
            return 1;
        }
    }
    0
}

// Advance past the value tokens of a `const NAME: TYPE = EXPR` declaration: from
// `pos` (the first token AFTER `const`) skip forward until the next top-level
// item start or EOF. Mirrors skip_to_rbrace's "consume to boundary" shape.
pub fn skip_const_decl(toks: Vec, pos: i64, buf: i64) -> i64 {
    if at_eof(toks, pos) == 1 {
        return pos;
    }
    if tok_is_item_start(toks, pos, buf) == 1 {
        return pos;
    }
    skip_const_decl(toks, pos + 1, buf)
}

// Parse a top-level `const NAME: TYPE = EXPR` as a single declaration item.
// It lowers to one `const.i64 0` / `output` placeholder (emit_item_stub), exactly
// as mindc-Rust lowers a scalar/string const declaration (the value is inlined at
// each use site, so the declaration is a unit no-op). Reuses ast_struct_def as the
// stub-leaf kind so emit_program_items emits exactly one stub for it.
pub fn parse_const_decl(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let after: i64 = skip_const_decl(toks, pos + 1, buf);
    let hi: i64 = tok_hi(toks, after - 1);
    let n: i64 = ast_new_leaf(ast_struct_def(), lo, hi);
    pr_new(after, n)
}

// Parse `extern "C" { ... }` as ONE stub item. Scan from the `extern` token to the
// block's closing `}` (the inner fn declarations are body-less, no nested braces),
// and emit a single ast_struct_def leaf so emit_program_items emits exactly one
// stub — matching mindc-Rust, which lowers a whole extern block to one placeholder.
pub fn parse_extern_block(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let after: i64 = skip_to_rbrace(toks, pos);
    let hi: i64 = tok_hi(toks, after - 1);
    let n: i64 = ast_new_leaf(ast_struct_def(), lo, hi);
    pr_new(after, n)
}

// ===== Sub-scans (tail-recursive) =====

pub fn scan_ident_end(buf: i64, i: i64, buf_len: i64) -> i64 {
    if i >= buf_len {
        return i;
    }
    if is_alnum(load_byte(buf, i)) == 1 {
        return scan_ident_end(buf, i + 1, buf_len);
    }
    i
}

pub fn scan_int_end(buf: i64, i: i64, buf_len: i64) -> i64 {
    if i >= buf_len {
        return i;
    }
    if is_digit(load_byte(buf, i)) == 1 {
        return scan_int_end(buf, i + 1, buf_len);
    }
    i
}

pub fn scan_comment_end(buf: i64, i: i64, buf_len: i64) -> i64 {
    if i >= buf_len {
        return i;
    }
    if load_byte(buf, i) == 10 {
        return i + 1;
    }
    scan_comment_end(buf, i + 1, buf_len)
}

pub fn match_punct(b: i64) -> i64 {
    if b == 40 {
        return tk_lparen();
    }
    if b == 41 {
        return tk_rparen();
    }
    if b == 123 {
        return tk_lbrace();
    }
    if b == 125 {
        return tk_rbrace();
    }
    if b == 44 {
        return tk_comma();
    }
    if b == 59 {
        return tk_semi();
    }
    if b == 58 {
        return tk_colon();
    }
    if b == 61 {
        return tk_eq();
    }
    if b == 43 {
        return tk_plus();
    }
    if b == 45 {
        return tk_minus();
    }
    if b == 42 {
        return tk_star();
    }
    if b == 47 {
        return tk_slash();
    }
    if b == 46 {
        return tk_dot();
    }
    if b == 60 {
        return tk_lt();
    }
    if b == 62 {
        return tk_gt();
    }
    if b == 33 {
        return tk_bang();
    }
    if b == 38 {
        return tk_amp();
    }
    if b == 124 {
        return tk_pipe();
    }
    if b == 94 {
        return tk_caret();
    }
    if b == 37 {
        return tk_percent();
    }
    tk_ident()
}

// ===== Main scan loop (tail-recursive) =====

pub fn scan(buf: i64, i: i64, buf_len: i64, toks: Vec) -> Vec {
    if i >= buf_len {
        return push_token(toks, tk_eof(), buf_len, buf_len);
    }
    let b: i64 = load_byte(buf, i);
    if is_space(b) == 1 {
        return scan(buf, i + 1, buf_len, toks);
    }
    if b == 47 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 47 {
                let after: i64 = scan_comment_end(buf, i + 2, buf_len);
                return scan(buf, after, buf_len, toks);
            }
        }
    }
    if is_alpha(b) == 1 {
        let hi: i64 = scan_ident_end(buf, i + 1, buf_len);
        let kind: i64 = classify_ident(buf, i, hi);
        let next_toks: Vec = push_token(toks, kind, i, hi);
        return scan(buf, hi, buf_len, next_toks);
    }
    if is_digit(b) == 1 {
        let hi: i64 = scan_int_end(buf, i + 1, buf_len);
        // Float literal: <digits> '.' <digits>. Fire only when a '.' (46) is
        // immediately followed by a digit, so `x.0` (ident-dot-int), `0..n`
        // (range) and a trailing `.` stay int-DOT paths. `hi + 1 < buf_len`
        // guarantees both `hi` and `hi + 1` are valid indices.
        // deferred: exponent form `<digits>.<digits>(e|E)[+|-]<digits>` — the
        // parser float-lit AST kind + dtype threading are separate follow-up
        // constructs; upgrade path: add a scan_float_exp tail after the frac scan.
        if hi + 1 < buf_len {
            if load_byte(buf, hi) == 46 {
                if is_digit(load_byte(buf, hi + 1)) == 1 {
                    let fhi: i64 = scan_int_end(buf, hi + 1, buf_len);
                    let ftoks: Vec = push_token(toks, tk_float(), i, fhi);
                    return scan(buf, fhi, buf_len, ftoks);
                }
            }
        }
        let next_toks: Vec = push_token(toks, tk_int(), i, hi);
        return scan(buf, hi, buf_len, next_toks);
    }
    if b == 45 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 62 {
                let next_toks: Vec = push_token(toks, tk_arrow(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    if b == 61 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 61 {
                let next_toks: Vec = push_token(toks, tk_eqeq(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    if b == 60 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 61 {
                let next_toks: Vec = push_token(toks, tk_le(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    if b == 62 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 61 {
                let next_toks: Vec = push_token(toks, tk_ge(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    if b == 33 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 61 {
                let next_toks: Vec = push_token(toks, tk_ne(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    // `<<` (60,60): left-shift two-char token. Checked before the `<` / `<=`
    // single-char paths so `a << b` lexes as one tk_shl, not two tk_lt.
    if b == 60 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 60 {
                let next_toks: Vec = push_token(toks, tk_shl(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    // `>>` (62,62): right-shift two-char token (same precedence as `<<`).
    if b == 62 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 62 {
                let next_toks: Vec = push_token(toks, tk_shr(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    // `&&` (38,38): logical-and two-char token. Checked before the single-char
    // `&` (tk_amp) path so `a && b` lexes as one tk_andand, not two tk_amp.
    if b == 38 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 38 {
                let next_toks: Vec = push_token(toks, tk_andand(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    // `||` (124,124): logical-or two-char token. Checked before the single-char
    // `|` (tk_pipe) path so `a || b` lexes as one tk_oror, not two tk_pipe.
    if b == 124 {
        if i + 1 < buf_len {
            if load_byte(buf, i + 1) == 124 {
                let next_toks: Vec = push_token(toks, tk_oror(), i, i + 2);
                return scan(buf, i + 2, buf_len, next_toks);
            }
        }
    }
    let kind: i64 = match_punct(b);
    let next_toks: Vec = push_token(toks, kind, i, i + 1);
    scan(buf, i + 1, buf_len, next_toks)
}

// ===== Public entry: lex =====

pub fn lex(buf: i64, buf_len: i64) -> Vec {
    let empty: Vec = vec_new();
    scan(buf, 0, buf_len, empty)
}

// ===========================================================================
// SECTION 2 — PARSER (Phase 6.2)
// examples/parser/main.mind, with deduplication:
//   removed: tk_* constants, load_byte  (already defined above)
// Provides: parse(toks: Vec, buf: i64) -> i64
// ===========================================================================

// ===== AST kind tags =====

pub fn ast_int_lit() -> i64 {
    1
}
pub fn ast_ident() -> i64 {
    2
}
pub fn ast_binop() -> i64 {
    3
}
pub fn ast_call() -> i64 {
    4
}
pub fn ast_fn_def() -> i64 {
    5
}
pub fn ast_let() -> i64 {
    6
}
pub fn ast_use() -> i64 {
    7
}
pub fn ast_return() -> i64 {
    8
}
pub fn ast_param() -> i64 {
    9
}
pub fn ast_block() -> i64 {
    10
}
pub fn ast_program() -> i64 {
    11
}
pub fn ast_paren() -> i64 {
    12
}
pub fn ast_struct_def() -> i64 {
    13
}
pub fn ast_neg() -> i64 {
    14
}
pub fn ast_not() -> i64 {
    15
}
pub fn ast_if() -> i64 {
    16
}
pub fn ast_field() -> i64 {
    17
}
pub fn ast_method() -> i64 {
    18
}
// `Ident { f: e, ... }` struct-literal CONSTRUCTION expression. PARSE-ONLY for
// now: the parser builds this node, but flatten_ast / flatten_ast_le reject it
// (fail-closed, no byte emit yet — the desugar/lowering half lands separately).
// Mirrors the Rust front-end's ast::Node::StructLit { name, fields }.
pub fn ast_struct_lit() -> i64 {
    19
}
// `while COND { BODY }` loop statement. child0 = cond expr, child1 = body block,
// child2 = 0 (no else). Mirrors the Rust front-end's ast::Node::While.
pub fn ast_while() -> i64 {
    20
}
// `NAME = VALUE` assignment statement (loop-carried mutation). child0 = name
// leaf (ast_ident), child2 = value expr. Mirrors ast::Node::Assign.
pub fn ast_assign() -> i64 {
    21
}
// `break;` / `continue;` loop-control statements (bare leaves). Mirror
// ast::Node::Break / ast::Node::Continue.
pub fn ast_break() -> i64 {
    22
}
pub fn ast_continue() -> i64 {
    23
}
// `<digits>.<digits>` float literal (the tk_float token, kind 36). PARSE-ONLY
// for now: the parser builds this leaf and its [lo, hi) span captures the raw
// float-literal source text (the bits are re-derived from that span at lower
// time). flatten_ast / the emitters do not yet lower it — dtype threading
// through nb_expr -> the SSE2 encoders is a separate follow-up construct.
// Mirrors the Rust front-end's ast::Node::FloatLit.
pub fn ast_float_lit() -> i64 {
    24
}
// `EXPR as i8/i16/i32` NARROWING cast expression. child0 = operand expr, aux =
// target bit width (8/16/32). A WIDENING `as i64` cast stays a value passthrough
// (no node — parse_postfix_rest returns the operand unchanged); only a narrowing
// target needs a real two's-complement truncation, emitted natively as a movsx
// (nb_expr's ast_cast arm -> nb_movsx_rax_al/ax / nb_movsxd_rax_eax, the same
// reg-to-reg wrap the __mind_wrap_iN intrinsics use). main.mind's OWN source uses
// no cast in code (every `as iN` occurrence is inside a comment the lexer strips),
// so this node is NEVER produced during self-compile — additive, the integer
// native-ELF oracle and the mic@3/mic@1 canary paths stay byte-identical.
pub fn ast_cast() -> i64 {
    25
}

