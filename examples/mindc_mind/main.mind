// examples/mindc_mind/main.mind — Phase 6.5 Stage 5 APEX driver.
//
// Combined pure-MIND mindc front-end: lexer + parser + type-checker +
// MLIR-text emitter wired into a single cdylib.  Every function from
// the four preceding stages (Phase 6.1–6.4) is inlined here verbatim
// (duplicate helper names are deduplicated to their first canonical
// definition); the only net-new code is the `mindc_compile` entry
// at the bottom.
//
// Why a single file rather than `use examples.lexer.main` etc.:
// mindc v0.5.x's `use` resolver covers `std.*` only; user-space
// .mind files that are binary entry-point files (they define `main`)
// are not exposed as importable modules.  The single-file merge is
// therefore the only path that compiles through the current surface
// grammar.  A follow-on RFC will introduce a `mod` keyword for
// user-space module composition.
//
// Build:
//   cargo run --features "mlir-build std-surface cross-module-imports" \
//       --bin mindc -- \
//       examples/mindc_mind/main.mind \
//       --emit-shared examples/mindc_mind/libmindc_mind.so
//
// Smoke gate (Phase 6.5 Stage 5 contract):
//   mindc_compile(buf_addr, buf_len) on fixture.mind produces an
//   EmitState whose .buf is byte-identical to the 148-byte MLIR text
//   documented in examples/mindc_mind/EXPECTED.md and to the output
//   of `mindc --emit-ir` on the same fixture.  Verification is done
//   by examples/mindc_mind/bootstrap_smoke.py.

import std.vec;
import std.map;
import std.string;
import std.io;

// ===========================================================================
// SECTION 1 — LEXER (Phase 6.1)
// examples/lexer/main.mind, verbatim.
// Provides: lex(buf, buf_len) -> Vec
// ===========================================================================

// ===== Token kinds (i64 tags) =====

pub fn tk_eof() -> i64 {
    0
}
pub fn tk_ident() -> i64 {
    1
}
pub fn tk_int() -> i64 {
    2
}
pub fn tk_lparen() -> i64 {
    3
}
pub fn tk_rparen() -> i64 {
    4
}
pub fn tk_lbrace() -> i64 {
    5
}
pub fn tk_rbrace() -> i64 {
    6
}
pub fn tk_comma() -> i64 {
    7
}
pub fn tk_semi() -> i64 {
    8
}
pub fn tk_colon() -> i64 {
    9
}
pub fn tk_arrow() -> i64 {
    10
}
pub fn tk_eq() -> i64 {
    11
}
pub fn tk_plus() -> i64 {
    12
}
pub fn tk_minus() -> i64 {
    13
}
pub fn tk_star() -> i64 {
    14
}
pub fn tk_slash() -> i64 {
    15
}
pub fn tk_lt() -> i64 {
    16
}
pub fn tk_gt() -> i64 {
    17
}
pub fn tk_kw_fn() -> i64 {
    18
}
pub fn tk_kw_let() -> i64 {
    19
}
pub fn tk_kw_use() -> i64 {
    20
}
pub fn tk_kw_pub() -> i64 {
    21
}
pub fn tk_dot() -> i64 {
    22
}
pub fn tk_eqeq() -> i64 {
    23
}
pub fn tk_le() -> i64 {
    24
}
pub fn tk_ge() -> i64 {
    25
