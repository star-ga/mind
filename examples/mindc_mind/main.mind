// H0..H7 — FIPS 180-4 §5.3.3 square-root constants (Rust SHA256_H0, decimal).
pub fn nb_h_init(i: i64) -> i64 {
    if i == 0 {
        return 1779033703;
    }
    if i == 1 {
        return 3144134277;
    }
    if i == 2 {
        return 1013904242;
    }
    if i == 3 {
        return 2773480762;
    }
