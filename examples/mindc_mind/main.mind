// `receiver.field`: child0=receiver expr, child1/child2 (offsets 32/40) carry
// the field-name span (lo/hi) into the source buffer.  Mirrors the Rust
// front-end's ast::Node::FieldAccess { receiver, field, span }.  The emitter
// (emit_expr_env ast_field arm) lowers it to a single `const.i64 0` — the
// byte-identical match to lower.rs's FieldAccess `None` arm, taken whenever the
// receiver's struct type is unresolvable (the bootstrap parser tracks no
// struct field-name order, so every field access lands on that arm).
pub fn ast_new_field(span_lo: i64, span_hi: i64, receiver: i64, field_lo: i64, field_hi: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_field());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, receiver);
    __mind_store_i64(n + 32, field_lo);
    __mind_store_i64(n + 40, field_hi);
    __mind_store_i64(n + 48, 0);
    n
}

// `if cond { then } else { else }`: child0=cond expr, child1=then-block,
// child2=else-block (0 when no else clause).  Matches the Rust front-end's
// ast::Node::If (cond / then_branch / else_branch).
pub fn ast_new_if(span_lo: i64, span_hi: i64, cond: i64, then_blk: i64, else_blk: i64) -> i64 {
    let n: i64 = ast_alloc();
    __mind_store_i64(n + 0, ast_if());
    __mind_store_i64(n + 8, span_lo);
    __mind_store_i64(n + 16, span_hi);
    __mind_store_i64(n + 24, cond);
    __mind_store_i64(n + 32, then_blk);
    __mind_store_i64(n + 40, else_blk);
    __mind_store_i64(n + 48, 0);
    n
}

// ===== AST accessors =====

pub fn ast_kind(node: i64) -> i64 {
    __mind_load_i64(node + 0)
}
pub fn ast_span_lo(node: i64) -> i64 {
    __mind_load_i64(node + 8)
}
pub fn ast_span_hi(node: i64) -> i64 {
    __mind_load_i64(node + 16)
}
pub fn ast_child0(node: i64) -> i64 {
    __mind_load_i64(node + 24)
}
pub fn ast_child1(node: i64) -> i64 {
    __mind_load_i64(node + 32)
}
pub fn ast_child2(node: i64) -> i64 {
    __mind_load_i64(node + 40)
}
pub fn ast_aux(node: i64) -> i64 {
    __mind_load_i64(node + 48)
}

// ===== ParseResult =====

struct ParseResult {
    next_pos: i64,
    node: i64,
}

pub fn pr_new(next_pos: i64, node: i64) -> ParseResult {
    ParseResult { next_pos: next_pos, node: node }
}

pub fn pr_pos(r: ParseResult) -> i64 {
    r.next_pos
}
pub fn pr_node(r: ParseResult) -> i64 {
    r.node
}

// ===== Return-keyword detector =====

pub fn is_ident_return(buf: i64, lo: i64, hi: i64) -> i64 {
    if hi - lo == 6 {
        if load_byte(buf, lo) == 114 {
            if load_byte(buf, lo + 1) == 101 {
                if load_byte(buf, lo + 2) == 116 {
                    if load_byte(buf, lo + 3) == 117 {
                        if load_byte(buf, lo + 4) == 114 {
                            if load_byte(buf, lo + 5) == 110 {
                                return 1;
                            }
                        }
                    }
                }
            }
        }
    }
    0
}

// ===== Pratt precedence table =====

pub fn infix_prec(kind: i64) -> i64 {
    if kind == tk_eq() {
        return 1;
    }
    if kind == tk_lt() {
        return 2;
    }
    if kind == tk_gt() {
        return 2;
    }
    if kind == tk_eqeq() {
        return 2;
    }
    if kind == tk_le() {
        return 2;
    }
    if kind == tk_ge() {
        return 2;
    }
    if kind == tk_ne() {
        return 2;
    }
    if kind == tk_plus() {
        return 3;
    }
    if kind == tk_minus() {
        return 3;
    }
    if kind == tk_star() {
        return 4;
    }
    if kind == tk_slash() {
        return 4;
    }
    0
}

pub fn tk_to_op(kind: i64) -> i64 {
    if kind == tk_plus() {
        return op_add();
    }
    if kind == tk_minus() {
        return op_sub();
    }
    if kind == tk_star() {
        return op_mul();
    }
    if kind == tk_slash() {
        return op_div();
    }
    if kind == tk_lt() {
        return op_lt();
    }
    if kind == tk_gt() {
        return op_gt();
    }
    if kind == tk_eq() {
        return op_eq();
    }
    if kind == tk_eqeq() {
        return op_eq();
    }
    if kind == tk_le() {
        return op_le();
    }
    if kind == tk_ge() {
        return op_ge();
    }
    if kind == tk_ne() {
        return op_ne();
    }
    0
}

// ===== Primary / prefix parser =====

pub fn parse_primary(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);

    if k == tk_kw_if() {
        return parse_if(toks, pos, buf);
    }

    if k == tk_minus() {
        let operand: ParseResult = parse_primary(toks, pos + 1, buf);
        let opnode: i64 = pr_node(operand);
        let neg: i64 = ast_new_neg(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), neg);
    }

    if k == tk_bang() {
        let operand: ParseResult = parse_primary(toks, pos + 1, buf);
        let opnode: i64 = pr_node(operand);
        let notn: i64 = ast_new_not(lo, ast_span_hi(opnode), opnode);
        return pr_new(pr_pos(operand), notn);
    }

    if k == tk_int() {
        let n: i64 = ast_new_leaf(ast_int_lit(), lo, hi);
        return pr_new(pos + 1, n);
    }

    if k == tk_lparen() {
        let inner: ParseResult = parse_expr(toks, pos + 1, buf);
        let after_inner: i64 = pr_pos(inner);
        let close_hi: i64 = tok_hi(toks, after_inner);
        let after_close: i64 = if tok_kind(toks, after_inner) == tk_rparen() {
            after_inner + 1
        } else {
            after_inner
        };
        let paren: i64 = ast_new_paren(lo, close_hi, pr_node(inner));
        return pr_new(after_close, paren);
    }

    if k == tk_ident() {
        if at_eof(toks, pos + 1) == 0 {
            if tok_kind(toks, pos + 1) == tk_lparen() {
                return parse_call(toks, pos, buf);
            }
        }
        let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
        return pr_new(pos + 1, n);
    }

    let fallback: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, fallback)
}

// ===== Call parser =====

pub fn parse_call(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let lo: i64 = tok_lo(toks, pos);
    let name_hi: i64 = tok_hi(toks, pos);
    let callee: i64 = ast_new_leaf(ast_ident(), lo, name_hi);

    let empty_args: Vec = vec_new();
    let after_open: i64 = pos + 2;

    if tok_kind(toks, after_open) == tk_rparen() {
        let close_hi: i64 = tok_hi(toks, after_open);
        let call_node: i64 = ast_new_call(lo, close_hi, callee, vec_addr(empty_args), 0);
        return pr_new(after_open + 1, call_node);
    }

    let args_res: ParseResult = parse_args_rest(toks, after_open, buf, empty_args);
    let after_args: i64 = pr_pos(args_res);
    let args_node: i64 = pr_node(args_res);
    let args_addr: i64 = ast_child0(args_node);
    let args_len: i64 = ast_aux(args_node);

    let close_hi: i64 = tok_hi(toks, after_args);
    let after_close: i64 = if tok_kind(toks, after_args) == tk_rparen() {
        after_args + 1
    } else {
        after_args
    };

    let call_node: i64 = ast_new_call(lo, close_hi, callee, args_addr, args_len);
    pr_new(after_close, call_node)
}

pub fn parse_args_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    let one: ParseResult = parse_expr(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    let after_one: i64 = pr_pos(one);
    if tok_kind(toks, after_one) == tk_comma() {
        return parse_args_rest(toks, after_one + 1, buf, new_acc);
    }
    let sentinel: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_one, sentinel)
}

// ===== Pratt expression parser =====

pub fn parse_expr(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let prim: ParseResult = parse_postfix(toks, pos, buf);
    parse_pratt(toks, pr_pos(prim), buf, pr_node(prim), 1)
}

// Postfix wrapper around parse_primary: after a primary is parsed, greedily
// consume trailing `.field` accesses so `a.b.c` chains left-associatively into
// nested ast_field nodes.  Field access binds tighter than any infix operator
// (it is applied before parse_pratt), matching the Rust front-end where
// FieldAccess is built in primary position.  Each `.field` requires the dot to
// be followed by an identifier; a bare trailing dot is left for the primary
// fallback (it simply stops the loop).
pub fn parse_postfix(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let prim: ParseResult = parse_primary(toks, pos, buf);
    parse_postfix_rest(toks, pr_pos(prim), buf, pr_node(prim))
}

pub fn parse_postfix_rest(toks: Vec, pos: i64, buf: i64, recv: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, recv);
    }
    if tok_kind(toks, pos) != tk_dot() {
        return pr_new(pos, recv);
    }
    if tok_kind(toks, pos + 1) != tk_ident() {
        return pr_new(pos, recv);
    }
    let field_lo: i64 = tok_lo(toks, pos + 1);
    let field_hi: i64 = tok_hi(toks, pos + 1);
    let recv_lo: i64 = ast_span_lo(recv);
    let fa: i64 = ast_new_field(recv_lo, field_hi, recv, field_lo, field_hi);
    parse_postfix_rest(toks, pos + 2, buf, fa)
}

pub fn parse_pratt(toks: Vec, pos: i64, buf: i64, lhs: i64, min_prec: i64) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        return pr_new(pos, lhs);
    }
    let k: i64 = tok_kind(toks, pos);
    let prec: i64 = infix_prec(k);
    if prec == 0 {
        return pr_new(pos, lhs);
    }
    if prec < min_prec {
        return pr_new(pos, lhs);
    }

    let op_tag: i64 = tk_to_op(k);
    let rhs_prim: ParseResult = parse_postfix(toks, pos + 1, buf);
    let rhs_full: ParseResult = parse_pratt(toks, pr_pos(rhs_prim), buf, pr_node(rhs_prim), prec + 1);

    let lhs_lo: i64 = ast_span_lo(lhs);
    let rhs_hi: i64 = ast_span_hi(pr_node(rhs_full));
    let combined: i64 = ast_new_binop(lhs_lo, rhs_hi, lhs, pr_node(rhs_full), op_tag);

    parse_pratt(toks, pr_pos(rhs_full), buf, combined, min_prec)
}

// ===== Statements =====

pub fn parse_stmt(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_let() {
        return parse_let(toks, pos, buf);
    }
    if k == tk_ident() {
        let lo: i64 = tok_lo(toks, pos);
        let hi: i64 = tok_hi(toks, pos);
        if is_ident_return(buf, lo, hi) == 1 {
            return parse_return(toks, pos, buf);
        }
    }
    let e: ParseResult = parse_expr(toks, pos, buf);
    let after_e: i64 = pr_pos(e);
    if tok_kind(toks, after_e) == tk_semi() {
        return pr_new(after_e + 1, pr_node(e));
    }
    e
}

pub fn parse_let(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let name_lo: i64 = tok_lo(toks, pos + 1);
    let name_hi: i64 = tok_hi(toks, pos + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);
    let ty_lo: i64 = tok_lo(toks, pos + 3);
    let ty_hi: i64 = tok_hi(toks, pos + 3);
    let ty: i64 = ast_new_leaf(ast_ident(), ty_lo, ty_hi);
    let init: ParseResult = parse_expr(toks, pos + 5, buf);
    let after_init: i64 = pr_pos(init);
    let after_semi: i64 = if tok_kind(toks, after_init) == tk_semi() {
        after_init + 1
    } else {
        after_init
    };
    let init_hi: i64 = ast_span_hi(pr_node(init));
    let let_node: i64 = ast_new_let(kw_lo, init_hi, name, ty, pr_node(init));
    pr_new(after_semi, let_node)
}

pub fn parse_return(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let value: ParseResult = parse_expr(toks, pos + 1, buf);
    let after_v: i64 = pr_pos(value);
    let after_semi: i64 = if tok_kind(toks, after_v) == tk_semi() {
        after_v + 1
    } else {
        after_v
    };
    let v_hi: i64 = ast_span_hi(pr_node(value));
    let r: i64 = ast_new_return(kw_lo, v_hi, pr_node(value));
    pr_new(after_semi, r)
}

// ===== Blocks =====

pub fn parse_block(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let open_lo: i64 = tok_lo(toks, pos);
    let acc: Vec = vec_new();
    let body: ParseResult = parse_block_stmts(toks, pos + 1, buf, acc);
    let after_body: i64 = pr_pos(body);
    let stmts_node: i64 = pr_node(body);
    let stmts_addr: i64 = ast_child0(stmts_node);
    let stmts_len: i64 = ast_aux(stmts_node);

    let close_hi: i64 = tok_hi(toks, after_body);
    let after_close: i64 = if tok_kind(toks, after_body) == tk_rbrace() {
        after_body + 1
    } else {
        after_body
    };
    let blk: i64 = ast_new_block(open_lo, close_hi, stmts_addr, stmts_len);
    pr_new(after_close, blk)
}

pub fn parse_block_stmts(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    if tok_kind(toks, pos) == tk_rbrace() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_stmt(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_block_stmts(toks, pr_pos(one), buf, new_acc)
}

// ===== If-expressions =====
//
// `if COND { THEN } else { ELSE }` — COND is a full expression (parse_expr
// stops at the `{` because `{` has no infix precedence), THEN/ELSE reuse the
// function-body block parser.  The else clause is optional; when absent,
// child2 is left 0.  Mirrors the Rust front-end's ast::Node::If.
pub fn parse_if(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let kw_lo: i64 = tok_lo(toks, pos);
    let cond: ParseResult = parse_expr(toks, pos + 1, buf);
    let after_cond: i64 = pr_pos(cond);

    let then_res: ParseResult = parse_block(toks, after_cond, buf);
    let after_then: i64 = pr_pos(then_res);
    let then_blk: i64 = pr_node(then_res);
    let then_hi: i64 = ast_span_hi(then_blk);

    if tok_kind(toks, after_then) == tk_kw_else() {
        let else_res: ParseResult = parse_block(toks, after_then + 1, buf);
        let after_else: i64 = pr_pos(else_res);
        let else_blk: i64 = pr_node(else_res);
        let else_hi: i64 = ast_span_hi(else_blk);
        let if_node: i64 = ast_new_if(kw_lo, else_hi, pr_node(cond), then_blk, else_blk);
        return pr_new(after_else, if_node);
    }

    let if_node: i64 = ast_new_if(kw_lo, then_hi, pr_node(cond), then_blk, 0);
    pr_new(after_then, if_node)
}

// ===== Function definitions =====

pub fn parse_fn_def(toks: Vec, pos: i64, buf: i64, is_pub: i64) -> ParseResult {
    let fn_lo: i64 = tok_lo(toks, pos);
    let name_lo: i64 = tok_lo(toks, pos + 1);
    let name_hi: i64 = tok_hi(toks, pos + 1);
    let name: i64 = ast_new_leaf(ast_ident(), name_lo, name_hi);

    let params_acc: Vec = vec_new();
    let params_res: ParseResult = parse_params_rest(toks, pos + 3, buf, params_acc);
    let after_params: i64 = pr_pos(params_res);
    let params_node: i64 = pr_node(params_res);
    let params_addr: i64 = ast_child0(params_node);
    let params_len: i64 = ast_aux(params_node);

    let after_rparen: i64 = if tok_kind(toks, after_params) == tk_rparen() {
        after_params + 1
    } else {
        after_params
    };
    let after_arrow: i64 = if tok_kind(toks, after_rparen) == tk_arrow() {
        after_rparen + 1
    } else {
        after_rparen
    };
    let after_ret: i64 = after_arrow + 1;

    let body_res: ParseResult = parse_block(toks, after_ret, buf);
    let body_hi: i64 = ast_span_hi(pr_node(body_res));

    let fn_node: i64 = ast_new_fn_def(fn_lo, body_hi, name, params_addr, pr_node(body_res), params_len, is_pub);
    pr_new(pr_pos(body_res), fn_node)
}

pub fn parse_params_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if tok_kind(toks, pos) == tk_rparen() {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let n_lo: i64 = tok_lo(toks, pos);
    let n_hi: i64 = tok_hi(toks, pos);
    let n_name: i64 = ast_new_leaf(ast_ident(), n_lo, n_hi);
    let t_lo: i64 = tok_lo(toks, pos + 2);
    let t_hi: i64 = tok_hi(toks, pos + 2);
    let n_ty: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let p: i64 = ast_new_param(n_lo, t_hi, n_name, n_ty);
    let new_acc: Vec = vec_push(acc, p);
    let after_param: i64 = pos + 3;
    if tok_kind(toks, after_param) == tk_comma() {
        return parse_params_rest(toks, after_param + 1, buf, new_acc);
    }
    let s: i64 = ast_new_block(0, 0, vec_addr(new_acc), vec_len(new_acc));
    pr_new(after_param, s)
}

// ===== Use statements =====

pub fn parse_use(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let use_lo: i64 = tok_lo(toks, pos);
    let h_lo: i64 = tok_lo(toks, pos + 1);
    let h_hi: i64 = tok_hi(toks, pos + 1);
    let head: i64 = ast_new_leaf(ast_ident(), h_lo, h_hi);
    let t_lo: i64 = tok_lo(toks, pos + 3);
    let t_hi: i64 = tok_hi(toks, pos + 3);
    let tail: i64 = ast_new_leaf(ast_ident(), t_lo, t_hi);
    let after_semi: i64 = if tok_kind(toks, pos + 4) == tk_semi() {
        pos + 5
    } else {
        pos + 4
    };
    let node: i64 = ast_new_use(use_lo, t_hi, head, tail);
    pr_new(after_semi, node)
}

// ===== Top-level item / program =====

pub fn parse_item(toks: Vec, pos: i64, buf: i64) -> ParseResult {
    let k: i64 = tok_kind(toks, pos);
    if k == tk_kw_use() {
        return parse_use(toks, pos, buf);
    }
    if k == tk_kw_pub() {
        return parse_fn_def(toks, pos + 1, buf, 1);
    }
    if k == tk_kw_fn() {
        return parse_fn_def(toks, pos, buf, 0);
    }
    let lo: i64 = tok_lo(toks, pos);
    let hi: i64 = tok_hi(toks, pos);
    if k == tk_ident() {
        if is_struct_kw(buf, lo, hi) == 1 {
            return parse_struct_def(toks, pos, buf);
        }
    }
    let n: i64 = ast_new_leaf(ast_ident(), lo, hi);
    pr_new(pos + 1, n)
}

pub fn parse_items_rest(toks: Vec, pos: i64, buf: i64, acc: Vec) -> ParseResult {
    if at_eof(toks, pos) == 1 {
        let s: i64 = ast_new_block(0, 0, vec_addr(acc), vec_len(acc));
        return pr_new(pos, s);
    }
    let one: ParseResult = parse_item(toks, pos, buf);
    let new_acc: Vec = vec_push(acc, pr_node(one));
    parse_items_rest(toks, pr_pos(one), buf, new_acc)
}

// ===== Public entry: parse =====

pub fn parse(toks: Vec, buf: i64) -> i64 {
    let acc: Vec = vec_new();
    let res: ParseResult = parse_items_rest(toks, 0, buf, acc);
    let s: i64 = pr_node(res);
    let items_addr: i64 = ast_child0(s);
    let items_len: i64 = ast_aux(s);
    ast_new_program(0, 0, items_addr, items_len)
}

// ===========================================================================
// SECTION 3 — TYPE CHECKER (Phase 6.3)
// examples/typecheck/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: typecheck(ast_root: i64, buf: i64) -> String
// ===========================================================================

// ===== Type tags =====

pub fn ty_unknown() -> i64 {
    0
}
pub fn ty_i64() -> i64 {
    1
}
pub fn ty_f64() -> i64 {
    2
}
pub fn ty_bool() -> i64 {
    3
}
pub fn ty_vec() -> i64 {
    4
}
pub fn ty_string() -> i64 {
    5
}
pub fn ty_unit() -> i64 {
    6
}

// ===== Fn-def aux unpacking =====

pub fn fn_def_params_len(node: i64) -> i64 {
    ast_aux(node) / 2
}
pub fn fn_def_is_pub(node: i64) -> i64 {
    ast_aux(node) - (ast_aux(node) / 2) * 2
}

// ===== Byte-range equality =====

pub fn bytes_eq(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64, chi: i64) -> i64 {
    if hi - lo == chi - clo {
        return bytes_eq_rest(buf, lo, hi, cmp_buf, clo);
    }
    0
}

pub fn bytes_eq_rest(buf: i64, lo: i64, hi: i64, cmp_buf: i64, clo: i64) -> i64 {
    if lo >= hi {
        return 1;
    }
    if load_byte(buf, lo) == load_byte(cmp_buf, clo) {
        return bytes_eq_rest(buf, lo + 1, hi, cmp_buf, clo + 1);
    }
    0
}

// ===== Type-name byte tables =====

pub fn make_byte_buf_3(b0: i64, b1: i64, b2: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    h
}

pub fn make_byte_buf_4(b0: i64, b1: i64, b2: i64, b3: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    h
}

pub fn make_byte_buf_6(b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64) -> i64 {
    let h: i64 = __mind_alloc(16);
    __mind_store_i64(h + 0, b0);
    __mind_store_i64(h + 1, b1);
    __mind_store_i64(h + 2, b2);
    __mind_store_i64(h + 3, b3);
    __mind_store_i64(h + 4, b4);
    __mind_store_i64(h + 5, b5);
    h
}

pub fn name_buf_i64() -> i64 {
    make_byte_buf_3(105, 54, 52)
}
pub fn name_buf_f64() -> i64 {
    make_byte_buf_3(102, 54, 52)
}
pub fn name_buf_bool() -> i64 {
    make_byte_buf_4(98, 111, 111, 108)
}
pub fn name_buf_vec() -> i64 {
    make_byte_buf_3(86, 101, 99)
}
pub fn name_buf_string() -> i64 {
    make_byte_buf_6(83, 116, 114, 105, 110, 103)
}

pub fn resolve_type_ident(buf: i64, lo: i64, hi: i64) -> i64 {
    let i64_buf: i64 = name_buf_i64();
    if bytes_eq(buf, lo, hi, i64_buf, 0, 3) == 1 {
        return ty_i64();
    }
    let f64_buf: i64 = name_buf_f64();
    if bytes_eq(buf, lo, hi, f64_buf, 0, 3) == 1 {
        return ty_f64();
    }
    let bool_buf: i64 = name_buf_bool();
    if bytes_eq(buf, lo, hi, bool_buf, 0, 4) == 1 {
        return ty_bool();
    }
    let vec_buf: i64 = name_buf_vec();
    if bytes_eq(buf, lo, hi, vec_buf, 0, 3) == 1 {
        return ty_vec();
    }
    let str_buf: i64 = name_buf_string();
    if bytes_eq(buf, lo, hi, str_buf, 0, 6) == 1 {
        return ty_string();
    }
    ty_unknown()
}

// ===== Name hashing (DJB2) =====

pub fn djb2_seed() -> i64 {
    5381
}
pub fn djb2_prime() -> i64 {
    33
}

pub fn name_hash(buf: i64, lo: i64, hi: i64) -> i64 {
    name_hash_rest(buf, lo, hi, djb2_seed())
}

pub fn name_hash_rest(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    let mixed: i64 = (acc * djb2_prime()) + b;
    name_hash_rest(buf, lo + 1, hi, mixed)
}

// ===== Env helpers =====

pub fn env_new() -> Map {
    map_new()
}

pub fn env_bind(env: Map, buf: i64, lo: i64, hi: i64, ty: i64) -> Map {
    let key: i64 = name_hash(buf, lo, hi);
    map_insert(env, key, ty)
}

pub fn env_lookup(env: Map, buf: i64, lo: i64, hi: i64) -> i64 {
    let key: i64 = name_hash(buf, lo, hi);
    env_lookup_rest(env, key, 0, ty_unknown())
}

pub fn env_lookup_rest(env: Map, key: i64, i: i64, best: i64) -> i64 {
    if i >= map_len(env) {
        return best;
    }
    let new_best: i64 = if map_key_at(env, i) == key {
        map_value_at(env, i)
    } else {
        best
    };
    env_lookup_rest(env, key, i + 1, new_best)
}

// ===== String-building helpers (for type-check report) =====

pub fn push_ascii(s: String, b: i64) -> String {
    string_push_byte(s, b)
}
pub fn push_newline(s: String) -> String {
    string_push_byte(s, 10)
}
pub fn push_space(s: String) -> String {
    string_push_byte(s, 32)
}

pub fn push_bytes(s: String, buf: i64, lo: i64, hi: i64) -> String {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let next: String = string_push_byte(s, b);
    push_bytes(next, buf, lo + 1, hi)
}

pub fn push_type_name(s: String, ty: i64) -> String {
    if ty == ty_i64() {
        let s1: String = string_push_byte(s, 105);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_f64() {
        let s1: String = string_push_byte(s, 102);
        let s2: String = string_push_byte(s1, 54);
        return string_push_byte(s2, 52);
    }
    if ty == ty_bool() {
        let s1: String = string_push_byte(s, 98);
        let s2: String = string_push_byte(s1, 111);
        let s3: String = string_push_byte(s2, 111);
        return string_push_byte(s3, 108);
    }
    if ty == ty_vec() {
        let s1: String = string_push_byte(s, 86);
        let s2: String = string_push_byte(s1, 101);
        return string_push_byte(s2, 99);
    }
    if ty == ty_string() {
        let s1: String = string_push_byte(s, 83);
        let s2: String = string_push_byte(s1, 116);
        let s3: String = string_push_byte(s2, 114);
        let s4: String = string_push_byte(s3, 105);
        let s5: String = string_push_byte(s4, 110);
        return string_push_byte(s5, 103);
    }
    if ty == ty_unit() {
        let s1: String = string_push_byte(s, 40);
        return string_push_byte(s1, 41);
    }
    string_push_byte(s, 63)
}

pub fn push_kw_let(s: String) -> String {
    let s1: String = string_push_byte(s, 108);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    string_push_byte(s3, 32)
}

pub fn push_kw_fn(s: String) -> String {
    let s1: String = string_push_byte(s, 102);
    let s2: String = string_push_byte(s1, 110);
    string_push_byte(s2, 32)
}

pub fn push_colon(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 58);
    string_push_byte(s2, 32)
}

pub fn push_arrow(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 45);
    let s3: String = string_push_byte(s2, 62);
    string_push_byte(s3, 32)
}

pub fn push_lparen(s: String) -> String {
    string_push_byte(s, 40)
}
pub fn push_rparen(s: String) -> String {
    string_push_byte(s, 41)
}

pub fn push_comma(s: String) -> String {
    let s1: String = string_push_byte(s, 44);
    string_push_byte(s1, 32)
}

pub fn push_kw_error(s: String) -> String {
    let s1: String = string_push_byte(s, 69);
    let s2: String = string_push_byte(s1, 82);
    let s3: String = string_push_byte(s2, 82);
    let s4: String = string_push_byte(s3, 79);
    let s5: String = string_push_byte(s4, 82);
    let s6: String = string_push_byte(s5, 58);
    string_push_byte(s6, 32)
}

pub fn push_at_span(s: String) -> String {
    let s1: String = string_push_byte(s, 32);
    let s2: String = string_push_byte(s1, 97);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 32);
    let s5: String = string_push_byte(s4, 115);
    let s6: String = string_push_byte(s5, 112);
    let s7: String = string_push_byte(s6, 97);
    let s8: String = string_push_byte(s7, 110);
    let s9: String = string_push_byte(s8, 32);
    string_push_byte(s9, 91)
}

pub fn push_i64(s: String, n: i64) -> String {
    if n < 10 {
        return string_push_byte(s, 48 + n);
    }
    let high: String = push_i64(s, n / 10);
    string_push_byte(high, 48 + (n - (n / 10) * 10))
}

pub fn push_err_return_mismatch(s: String) -> String {
    let s1: String = string_push_byte(s, 114);
    let s2: String = string_push_byte(s1, 101);
    let s3: String = string_push_byte(s2, 116);
    let s4: String = string_push_byte(s3, 117);
    let s5: String = string_push_byte(s4, 114);
    let s6: String = string_push_byte(s5, 110);
    let s7: String = string_push_byte(s6, 32);
    let s8: String = string_push_byte(s7, 116);
    let s9: String = string_push_byte(s8, 121);
    let s10: String = string_push_byte(s9, 112);
    let s11: String = string_push_byte(s10, 101);
    let s12: String = string_push_byte(s11, 32);
    let s13: String = string_push_byte(s12, 109);
    let s14: String = string_push_byte(s13, 105);
    let s15: String = string_push_byte(s14, 115);
    let s16: String = string_push_byte(s15, 109);
    let s17: String = string_push_byte(s16, 97);
    let s18: String = string_push_byte(s17, 116);
    let s19: String = string_push_byte(s18, 99);
    string_push_byte(s19, 104)
}

// ===== TcResult =====

struct TcResult {
    env: Map,
    report: String,
}

pub fn tc_new(env: Map, report: String) -> TcResult {
    TcResult { env: env, report: report }
}

pub fn tc_env(r: TcResult) -> Map {
    r.env
}
pub fn tc_report(r: TcResult) -> String {
    r.report
}

// ===== Expression type resolution =====

pub fn type_of_expr(node: i64, env: Map, buf: i64) -> i64 {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        return ty_i64();
    }

    if k == ast_ident() {
        let lo: i64 = ast_span_lo(node);
        let hi: i64 = ast_span_hi(node);
        return env_lookup(env, buf, lo, hi);
    }

    if k == ast_binop() {
        let op: i64 = ast_aux(node);
        if op == op_lt() {
            return ty_bool();
        }
        if op == op_gt() {
            return ty_bool();
        }
        if op == op_eq() {
            return ty_bool();
        }
        let lhs: i64 = ast_child0(node);
        return type_of_expr(lhs, env, buf);
    }

    if k == ast_paren() {
        let inner: i64 = ast_child0(node);
        return type_of_expr(inner, env, buf);
    }

    if k == ast_call() {
        return ty_unknown();
    }

    ty_unknown()
}

// ===== Statement / item walkers =====

pub fn tc_let(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let ty_node: i64 = ast_child1(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);
    let t_lo: i64 = ast_span_lo(ty_node);
    let t_hi: i64 = ast_span_hi(ty_node);

    let ty: i64 = resolve_type_ident(buf, t_lo, t_hi);
    let new_env: Map = env_bind(env, buf, n_lo, n_hi, ty);

    let s1: String = push_kw_let(report);
    let s2: String = push_bytes(s1, buf, n_lo, n_hi);
    let s3: String = push_colon(s2);
    let s4: String = push_type_name(s3, ty);
    let s5: String = push_newline(s4);

    tc_new(new_env, s5)
}

pub fn tc_return(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let value: i64 = ast_child0(node);
    let actual: i64 = type_of_expr(value, env, buf);

    if actual == expected_ret {
        return tc_new(env, report);
    }
    let lo: i64 = ast_span_lo(node);
    let hi: i64 = ast_span_hi(node);
    let s1: String = push_kw_error(report);
    let s2: String = push_err_return_mismatch(s1);
    let s3: String = push_at_span(s2);
    let s4: String = push_i64(s3, lo);
    let s5: String = push_comma(s4);
    let s6: String = push_i64(s5, hi);
    let s7: String = string_push_byte(s6, 41);
    let s8: String = push_newline(s7);
    tc_new(env, s8)
}

pub fn tc_stmt(node: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return tc_let(node, env, buf, report);
    }
    if k == ast_return() {
        return tc_return(node, env, buf, report, expected_ret);
    }
    let _: i64 = type_of_expr(node, env, buf);
    tc_new(env, report)
}

pub fn tc_block(block: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    let stmts_addr: i64 = ast_child0(block);
    let stmts_len: i64 = ast_aux(block);
    tc_block_stmts_rest(stmts_addr, stmts_len, 0, env, buf, report, expected_ret)
}

pub fn tc_block_stmts_rest(stmts_addr: i64, stmts_len: i64, i: i64, env: Map, buf: i64, report: String, expected_ret: i64) -> TcResult {
    if i >= stmts_len {
        return tc_new(env, report);
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let after: TcResult = tc_stmt(stmt, env, buf, report, expected_ret);
    tc_block_stmts_rest(stmts_addr, stmts_len, i + 1, tc_env(after), buf, tc_report(after), expected_ret)
}

pub fn fn_default_ret() -> i64 {
    ty_i64()
}

pub fn tc_fn_def(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let name_node: i64 = ast_child0(node);
    let params_addr: i64 = ast_child1(node);
    let body: i64 = ast_child2(node);
    let params_len: i64 = fn_def_params_len(node);

    let n_lo: i64 = ast_span_lo(name_node);
    let n_hi: i64 = ast_span_hi(name_node);

    let fn_env: Map = env_new();
    let after_params: TcResult = tc_params_rest(params_addr, params_len, 0, fn_env, buf, report, n_lo, n_hi, 1);

    let header1: String = push_arrow(tc_report(after_params));
    let header2: String = push_type_name(header1, fn_default_ret());
    let header3: String = push_newline(header2);

    let after_body: TcResult = tc_block(body, tc_env(after_params), buf, header3, fn_default_ret());

    tc_new(env, tc_report(after_body))
}

pub fn tc_params_rest(params_addr: i64, params_len: i64, i: i64, env: Map, buf: i64, report: String, name_lo: i64, name_hi: i64, is_first: i64) -> TcResult {
    if i >= params_len {
        if is_first == 1 {
            let s1: String = push_kw_fn(report);
            let s2: String = push_bytes(s1, buf, name_lo, name_hi);
            let s3: String = push_colon(s2);
            let s4: String = push_lparen(s3);
            let s5: String = push_rparen(s4);
            return tc_new(env, s5);
        }
        let close: String = push_rparen(report);
        return tc_new(env, close);
    }

    let p: i64 = __mind_load_i64(params_addr + i * 8);
    let p_name: i64 = ast_child0(p);
    let p_type: i64 = ast_child1(p);
    let pn_lo: i64 = ast_span_lo(p_name);
    let pn_hi: i64 = ast_span_hi(p_name);
    let pt_lo: i64 = ast_span_lo(p_type);
    let pt_hi: i64 = ast_span_hi(p_type);

    let pt: i64 = resolve_type_ident(buf, pt_lo, pt_hi);
    let new_env: Map = env_bind(env, buf, pn_lo, pn_hi, pt);

    let prefix: String = if is_first == 1 {
        let s1: String = push_kw_fn(report);
        let s2: String = push_bytes(s1, buf, name_lo, name_hi);
        let s3: String = push_colon(s2);
        push_lparen(s3)
    } else {
        push_comma(report)
    };
    let with_type: String = push_type_name(prefix, pt);

    tc_params_rest(params_addr, params_len, i + 1, new_env, buf, with_type, name_lo, name_hi, 0)
}

pub fn tc_item(node: i64, env: Map, buf: i64, report: String) -> TcResult {
    let k: i64 = ast_kind(node);
    if k == ast_fn_def() {
        return tc_fn_def(node, env, buf, report);
    }
    tc_new(env, report)
}

pub fn tc_items_rest(items_addr: i64, items_len: i64, i: i64, env: Map, buf: i64, report: String) -> TcResult {
    if i >= items_len {
        return tc_new(env, report);
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let after: TcResult = tc_item(item, env, buf, report);
    tc_items_rest(items_addr, items_len, i + 1, tc_env(after), buf, tc_report(after))
}

// ===== Public entry: typecheck =====

pub fn typecheck(ast_root: i64, buf: i64) -> String {
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    let env: Map = env_new();
    let report: String = string_new();
    let result: TcResult = tc_items_rest(items_addr, items_len, 0, env, buf, report);
    tc_report(result)
}

// ===========================================================================
// SECTION 4 — MLIR-TEXT EMITTER (Phase 6.4)
// examples/emit_ir/main.mind, with deduplication:
//   removed: ast_* constants, op_* constants, ast_* accessors, load_byte
//            (all already defined above)
// Provides: lower_program(ast_addr: i64, buf: i64) -> EmitState
// ===========================================================================

// ===== EmitState =====

struct EmitState {
    buf: String,
    next_id: i64,
    last_id: i64,
    lets: Map,
}

pub fn es_new() -> EmitState {
    EmitState { buf: string_new(), next_id: 0, last_id: 0 - 1, lets: env_new() }
}

pub fn es_buf(s: EmitState) -> String {
    s.buf
}
pub fn es_next_id(s: EmitState) -> i64 {
    s.next_id
}
pub fn es_last_id(s: EmitState) -> i64 {
    s.last_id
}

pub fn es_push(s: EmitState, b: i64) -> EmitState {
    EmitState { buf: string_push_byte(s.buf, b), next_id: s.next_id, last_id: s.last_id, lets: s.lets }
}

// ===== ASCII byte constants =====

pub fn ch_space() -> i64 {
    32
}
pub fn ch_newline() -> i64 {
    10
}
pub fn ch_percent() -> i64 {
    37
}
pub fn ch_eq_sign() -> i64 {
    61
}
pub fn ch_comma() -> i64 {
    44
}
pub fn ch_dot() -> i64 {
    46
}
pub fn ch_slash() -> i64 {
    47
}
pub fn ch_lbrace() -> i64 {
    123
}
pub fn ch_rbrace() -> i64 {
    125
}

// ===== Decimal i64 writer =====

pub fn emit_digits_collect(n: i64, acc: Vec) -> Vec {
    if n == 0 {
        return acc;
    }
    let d: i64 = n - (n / 10) * 10;
    let new_acc: Vec = vec_push(acc, 48 + d);
    emit_digits_collect(n / 10, new_acc)
}

pub fn emit_digits_flush(s: EmitState, digits: Vec, i: i64) -> EmitState {
    if i < 0 {
        return s;
    }
    let b: i64 = vec_get(digits, i);
    let s2: EmitState = es_push(s, b);
    emit_digits_flush(s2, digits, i - 1)
}

pub fn emit_i64(s: EmitState, n: i64) -> EmitState {
    if n == 0 {
        return es_push(s, 48);
    }
    let collected: Vec = emit_digits_collect(n, vec_new());
    emit_digits_flush(s, collected, vec_len(collected) - 1)
}

// ===== Byte-range writer =====

pub fn emit_byte_range(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    if lo >= hi {
        return s;
    }
    let b: i64 = load_byte(buf, lo);
    let s2: EmitState = es_push(s, b);
    emit_byte_range(s2, buf, lo + 1, hi)
}

// ===== mic@3 encoding primitives (self-host mic@3 convergence, Phase 1) =====
//
// ULEB128 + zigzag varints — the foundation of the mic@3 wire format (mirrors
// src/ir/compact/v3/emit.rs uleb128_write / zigzag_encode). The bootstrap
// language has `&` and `/` but no `>>` / `while`, so this is arithmetic +
// recursion: the low 7 bits are `n & 127`, the shift is `n / 128`, and the
// continuation bit is `+ 128` (the kept byte is < 128, so `+` equals `|`). Pure:
// identical n yields identical bytes on every substrate (the wedge invariant).
// Verified against the Rust oracle: uleb128(300) = [172, 2] = [0xAC, 0x02].
//
// Additive + isolated from the canary mic@1 emit path (these are not yet wired
// into the keystone fixed-point; they are exercised by selftest_mic3_uleb below
// until Phase 2 builds the mic@3 section emitter on top of them).
pub fn emit_uleb128(s: EmitState, n: i64) -> EmitState {
    let low: i64 = n & 127;
    let rest: i64 = n / 128;
    if rest == 0 {
        return es_push(s, low);
    }
    let s2: EmitState = es_push(s, low + 128);
    emit_uleb128(s2, rest)
}

// zigzag: signed -> unsigned so small-magnitude values stay short.
//   zigzag(n) = n >= 0 ? 2n : -2n - 1   (== (n<<1) ^ (n>>63) for i64)
pub fn zigzag_encode(n: i64) -> i64 {
    if n < 0 {
        return (0 - n) * 2 - 1;
    }
    n * 2
}

pub fn emit_sleb_zigzag(s: EmitState, n: i64) -> EmitState {
    emit_uleb128(s, zigzag_encode(n))
}

// Selftest export (cdylib pub-fn symbol, like selftest_emit_fn_body): emit the
// ULEB128 of `n` into a fresh EmitState so the Python gate can read the bytes
// back and check them against the Rust encoder. Keeps the primitives live + gated.
pub fn selftest_mic3_uleb(n: i64) -> EmitState {
    emit_uleb128(es_new(), n)
}

// ===== mic@3 header + string-table entry (self-host mic@3 convergence, Phase 2) =====
//
// The MIC3 header: the 4-byte "MIC3" magic + the version byte (mic@3 = 2). This
// is exactly what src/ir/compact/v3/emit.rs emit_mic3 writes first (MIC3_MAGIC
// then MIC3_VERSION). Bytes: M=77 I=73 C=67 '3'=51, version=2.
pub fn emit_mic3_header(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 77);
    let s2: EmitState = es_push(s1, 73);
    let s3: EmitState = es_push(s2, 67);
    let s4: EmitState = es_push(s3, 51);
    es_push(s4, 2)
}

// One mic@3 string-table entry: uleb128(len) || the `len` raw bytes of buf[lo..hi].
// This is the per-string framing emit_mic3 uses (uleb128_write(len) then the
// bytes), and the string-table is just `uleb128(count)` followed by `count` of
// these. Composes the Phase 1 uleb128 with the existing byte-range writer.
pub fn emit_mic3_lp_bytes(s: EmitState, buf: i64, lo: i64, hi: i64) -> EmitState {
    let len: i64 = hi - lo;
    let s1: EmitState = emit_uleb128(s, len);
    emit_byte_range(s1, buf, lo, hi)
}

pub fn selftest_mic3_header() -> EmitState {
    emit_mic3_header(es_new())
}

pub fn selftest_mic3_lp_bytes(src_addr: i64, src_len: i64) -> EmitState {
    emit_mic3_lp_bytes(es_new(), src_addr, 0, src_len)
}

// ===== mic@3 instruction emitters (self-host mic@3 convergence, Phase 3) =====
//
// The per-opcode encoding of src/ir/compact/v3/emit.rs emit_instr. Operand
// encodings (emit.rs §Low-level helpers): write_vid(id) = uleb128(id);
// write_i64(v) = uleb128(zigzag(v)) — i.e. emit_sleb_zigzag above. These two
// opcodes are the foundation the other 42 reuse (every dst is a vid, every
// integer operand is a write_i64); the full set + the IRModule that feeds it is
// Phase 3b/4. Tested as mechanisms (operands -> bytes) — keystone-isolated.

// Instr::ConstI64(dst, v): OP_CONST_I64(0x01) || vid(dst) || i64(v)
pub fn emit_mic3_const_i64(s: EmitState, dst: i64, v: i64) -> EmitState {
    let s1: EmitState = es_push(s, 1);
    let s2: EmitState = emit_uleb128(s1, dst);
    emit_sleb_zigzag(s2, v)
}

// Instr::BinOp { dst, op, lhs, rhs }:
//   OP_BINOP(0x04) || vid(dst) || binop_to_byte(op) || vid(lhs) || vid(rhs)
// `op_byte` is binop_to_byte(op) — supplied by the (future) lowering; here it is
// a parameter so the framing is tested independently of the op-code mapping.
pub fn emit_mic3_binop(s: EmitState, dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    let s1: EmitState = es_push(s, 4);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = es_push(s2, op_byte);
    let s4: EmitState = emit_uleb128(s3, lhs);
    emit_uleb128(s4, rhs)
}

pub fn selftest_mic3_const_i64(dst: i64, v: i64) -> EmitState {
    emit_mic3_const_i64(es_new(), dst, v)
}

pub fn selftest_mic3_binop(dst: i64, op_byte: i64, lhs: i64, rhs: i64) -> EmitState {
    emit_mic3_binop(es_new(), dst, op_byte, lhs, rhs)
}

// Instr::Output(id): OP_OUTPUT(0x13) || vid(id). The function-result terminator.
pub fn emit_mic3_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 19);
    emit_uleb128(s1, id)
}

// encode_opt_vid: None -> [0]; Some(v) -> [1] || uleb(v). `has` = 0/1. Shared by
// Return and FnDef's ret_id.
pub fn emit_mic3_opt_vid(s: EmitState, has: i64, vid: i64) -> EmitState {
    if has == 0 {
        return es_push(s, 0);
    }
    let s1: EmitState = es_push(s, 1);
    emit_uleb128(s1, vid)
}

// Instr::Return { value: Option<vid> }: OP_RETURN(0x17) || encode_opt_vid(value).
pub fn emit_mic3_return(s: EmitState, has_value: i64, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, 23);
    emit_mic3_opt_vid(s1, has_value, id)
}

// Instr::FnDef header (OP_FN_DEF 0x15) for a no-parameter function:
//   0x15 || uleb(name_idx) || uleb(0 params) || opt_vid(ret) || opt_f64(None) ||
//   uleb(body_len). The `body_len` body instructions follow (caller-emitted).
// Mirrors the emit_instr Instr::FnDef arm (encode_string_idx, encode_named_vids,
// encode_opt_vid, encode_opt_f64(reap_threshold=None), uleb(body.len)). For
// `fn f() -> i64 {...}` (name_idx=0, ret=%0, body_len=1) this reproduces the
// oracle FN_DEF header bytes 15 00 00 01 00 00 01 exactly.
pub fn emit_mic3_fn_def_header(s: EmitState, name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    let s1: EmitState = es_push(s, 21);
    let s2: EmitState = emit_uleb128(s1, name_idx);
    let s3: EmitState = emit_uleb128(s2, 0);
    let s4: EmitState = emit_mic3_opt_vid(s3, has_ret, ret_vid);
    let s5: EmitState = es_push(s4, 0);
    emit_uleb128(s5, body_len)
}

pub fn selftest_mic3_fn_def_header(name_idx: i64, has_ret: i64, ret_vid: i64, body_len: i64) -> EmitState {
    emit_mic3_fn_def_header(es_new(), name_idx, has_ret, ret_vid, body_len)
}

// Instr::Param { dst, name, index }: OP_PARAM(0x18) || vid(dst) || string_idx(name)
//   || uleb(index). The parameter-binding instruction in a function body. For
// `fn id(a)` the body holds PARAM(%0, "a"=idx1, index 0) = 18 00 01 00.
pub fn emit_mic3_param(s: EmitState, dst: i64, name_idx: i64, index: i64) -> EmitState {
    let s1: EmitState = es_push(s, 24);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    emit_uleb128(s3, index)
}

// encode_named_vids (the FN_DEF parameter list): uleb(count) || (string_idx, vid)
// per pair. `pairs` is a heap array of 2*count i64s: pairs[2i] = string_idx,
// pairs[2i+1] = vid. emit_mic3_fn_def's param list uses this.
pub fn emit_mic3_named_vids(s: EmitState, pairs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_named_vids_loop(s1, pairs, count, 0)
}

pub fn emit_mic3_named_vids_loop(s: EmitState, pairs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let sidx: i64 = __mind_load_i64(pairs + i * 16);
    let vid: i64 = __mind_load_i64(pairs + i * 16 + 8);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, vid);
    emit_mic3_named_vids_loop(s2, pairs, count, i + 1)
}

pub fn selftest_mic3_param(dst: i64, name_idx: i64, index: i64) -> EmitState {
    emit_mic3_param(es_new(), dst, name_idx, index)
}

pub fn selftest_mic3_named_vids(pairs: i64, count: i64) -> EmitState {
    emit_mic3_named_vids(es_new(), pairs, count)
}

pub fn selftest_mic3_output(id: i64) -> EmitState {
    emit_mic3_output(es_new(), id)
}

pub fn selftest_mic3_return(has_value: i64, id: i64) -> EmitState {
    emit_mic3_return(es_new(), has_value, id)
}

// ===== mic@3 string-table SECTION assembler (self-host convergence, Phase 3c) =====
//
// The complete mic@3 string table: uleb128(count) followed by `count`
// length-prefixed entries (each via emit_mic3_lp_bytes). `offs` is a heap array
// of (count+1) i64 byte-offsets into `buf`: string i is buf[offs[i] .. offs[i+1]].
// This is the same section src/ir/compact/v3/emit.rs writes after the header
// (uleb128(entries.len()) then each uleb128(len)||bytes), so a matching offsets
// array reproduces the oracle string table byte-for-byte. The offsets are what
// the (future) collect_strings pass will populate; here they are an input so the
// section assembler is tested independently of string collection.
pub fn emit_mic3_strtab(s: EmitState, buf: i64, offs: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_strtab_entries(s1, buf, offs, count, 0)
}

pub fn emit_mic3_strtab_entries(s: EmitState, buf: i64, offs: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let lo: i64 = __mind_load_i64(offs + i * 8);
    let hi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    let s1: EmitState = emit_mic3_lp_bytes(s, buf, lo, hi);
    emit_mic3_strtab_entries(s1, buf, offs, count, i + 1)
}

pub fn selftest_mic3_strtab(buf_addr: i64, offs_addr: i64, count: i64) -> EmitState {
    emit_mic3_strtab(es_new(), buf_addr, offs_addr, count)
}

// ===== mic@3 exports + registries + module assembler (Phase 3d) =====
//
// Exports section: uleb128(count) || count uleb128 string-table indices. emit_mic3
// sorts the export names then writes st.get(name) for each; here `idx` is a heap
// array of (already-sorted) i64 indices (the sort belongs to collection).
pub fn emit_mic3_exports(s: EmitState, idx: i64, count: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, count);
    emit_mic3_exports_loop(s1, idx, count, 0)
}

pub fn emit_mic3_exports_loop(s: EmitState, idx: i64, count: i64, i: i64) -> EmitState {
    if i >= count {
        return s;
    }
    let v: i64 = __mind_load_i64(idx + i * 8);
    let s1: EmitState = emit_uleb128(s, v);
    emit_mic3_exports_loop(s1, idx, count, i + 1)
}

// The 3 std-surface registries (struct_defs, const_array_defs, repr_c_structs)
// are each uleb128(count) || entries; for a program with none they are three
// uleb128(0). emit_mic3 writes them last.
pub fn emit_mic3_empty_registries(s: EmitState) -> EmitState {
    let s1: EmitState = emit_uleb128(s, 0);
    let s2: EmitState = emit_uleb128(s1, 0);
    emit_uleb128(s2, 0)
}

// Assemble a COMPLETE mic@3 module for the no-instruction case, in the exact
// section order emit_mic3 uses: header || strtab || uleb(next_id) || exports ||
// uleb(0 instrs) || empty registries. The instruction stream (the Phase 4
// real-body lowering) plugs in between exports and the registries.
pub fn emit_mic3_module_noinstr(s: EmitState, buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, str_count);
    let s3: EmitState = emit_uleb128(s2, next_id);
    let s4: EmitState = emit_mic3_exports(s3, idx, exp_count);
    let s5: EmitState = emit_uleb128(s4, 0);
    emit_mic3_empty_registries(s5)
}

pub fn selftest_mic3_exports(idx_addr: i64, count: i64) -> EmitState {
    emit_mic3_exports(es_new(), idx_addr, count)
}

pub fn selftest_mic3_empty_registries() -> EmitState {
    emit_mic3_empty_registries(es_new())
}

pub fn selftest_mic3_module_noinstr(buf: i64, offs: i64, str_count: i64, next_id: i64, idx: i64, exp_count: i64) -> EmitState {
    emit_mic3_module_noinstr(es_new(), buf, offs, str_count, next_id, idx, exp_count)
}

// ===== mic@3 COMPLETE with-body module — the const-return function family (Phase 4a) =====
//
// Assembles the full mic@3 of `pub fn <name>() -> i64 { <const_val> }`, byte-exact
// vs the Rust oracle. This is the FIRST complete WITH-BODY emit in pure-MIND. The
// section order + the exact 3-instruction module shape are what emit_mic3 + the
// lowering produce for a const-return function:
//   header || strtab(1:name) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name, ret=%0, body=[ConstI64(%0, const_val)]} ||
//     ConstI64(%0, 0) || Output(%0) ||
//   3 empty registries.
// Verified across const values (42 -> 0x54, 100 -> 0xc8 0x01), so it is a genuine
// (narrow) lowering, not a hardcoded byte blob. Generalizing to arbitrary bodies
// (the AST walk that emits these calls) is the remaining Phase 4 work; this proves
// the emit layer composes into a complete, oracle-identical module.
pub fn emit_mic3_const_fn_module(s: EmitState, buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = emit_mic3_fn_def_header(s5, name_idx, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, const_val);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    emit_mic3_empty_registries(s9)
}

pub fn selftest_mic3_const_fn(buf: i64, offs: i64, name_idx: i64, const_val: i64) -> EmitState {
    emit_mic3_const_fn_module(es_new(), buf, offs, name_idx, const_val)
}

// ===== mic@3 COMPLETE MULTI-FUNCTION module — two const-return fns (Phase 5a) =====
//
// The first pure-MIND emit of a module with MORE THAN ONE function. Assembles the
// full mic@3 of `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>() -> i64 { <v1> }`
// (no export{} block -> empty exports table), byte-exact vs the Rust --emit-mic3
// oracle. The four multi-function deltas vs the single-fn const family (Phase 4a):
//   (1) ONE string table deduped in FIRST-SEEN TRAVERSAL order (n0 then n1) — the
//       offsets array carries 3 i64s (2 strings); name indices are 0 and 1.
//   (2) ONE FLAT next_id threaded across both fns + their scaffolds: the two
//       scaffold ConstI64s take %0 (fn0) and %1 (fn1), so next_id = 2.
//   (3) ONE flat top-level instruction list with a SINGLE uleb count (= 6) covering
//       both FN_DEFs and both scaffold ConstI64/Output pairs.
//   (4) exports sorted (empty here — the export-free fixture).
// The FN_DEF body vids reset to %0 per function (each body is its own vid space),
// while the module-level scaffold const/output threads the flat counter (%0, %1).
// Verified across const values (one=1->zz 0x02, two=2->zz 0x04) so it is a genuine
// narrow multi-fn lowering, not a hardcoded blob.
pub fn emit_mic3_const_fn2_module(s: EmitState, buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = emit_mic3_fn_def_header(s9, 1, 1, 0, 1);
    let s11: EmitState = emit_mic3_const_i64(s10, 0, v1);
    let s12: EmitState = emit_mic3_const_i64(s11, 1, 0);
    let s13: EmitState = emit_mic3_output(s12, 1);
    emit_mic3_empty_registries(s13)
}

pub fn selftest_mic3_module_2fn(buf: i64, offs: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_const_fn2_module(es_new(), buf, offs, v0, v1)
}

// ===== mic@3 MULTI-FUNCTION module — const-return fn0 + arith fn1 (Phase 5b) =====
//
// `pub fn <n0>() -> i64 { <v0> }  pub fn <n1>(<pa>,<pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust --emit-mic3 oracle. Combines a Phase 4a const-return body
// with a Phase 4c PARAM/PARAM/BINOP body under ONE module header, exercising the
// multi-function deltas where the two functions have DIFFERENT body shapes:
//   strtab[4] in FIRST-SEEN order: n0, n1, pa, pb (name indices 0,1,2,3).
//   next_id = 2 (flat scaffold consts %0, %1 — the FN_DEF bodies keep their own vid
//   spaces: fn0 body %0, fn1 body %0,%1,%2).
//   instr_count = 6: FN_DEF n0{ConstI64 %0=v0} || ConstI64 %0=0 || Output %0 ||
//     FN_DEF n1{PARAM %0, PARAM %1, BINOP %2=%0 op %1} || ConstI64 %1=0 || Output %1.
// For `one(){1}` + `add(a,b){a+b}` (op_byte 0) this reproduces the 68-byte oracle
// byte-for-byte; verified vs live --emit-mic3 in mic3_primitives_smoke.py.
pub fn emit_mic3_const_arith_module(s: EmitState, buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    let s6: EmitState = emit_mic3_fn_def_header(s5, 0, 1, 0, 1);
    let s7: EmitState = emit_mic3_const_i64(s6, 0, v0);
    let s8: EmitState = emit_mic3_const_i64(s7, 0, 0);
    let s9: EmitState = emit_mic3_output(s8, 0);
    let s10: EmitState = es_push(s9, 21);
    let s11: EmitState = emit_uleb128(s10, 1);
    let s12: EmitState = emit_uleb128(s11, 2);
    let s13: EmitState = emit_uleb128(s12, 2);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_uleb128(s15, 1);
    let s17: EmitState = emit_mic3_opt_vid(s16, 1, 2);
    let s18: EmitState = es_push(s17, 0);
    let s19: EmitState = emit_uleb128(s18, 3);
    let s20: EmitState = emit_mic3_param(s19, 0, 2, 0);
    let s21: EmitState = emit_mic3_param(s20, 1, 3, 1);
    let s22: EmitState = emit_mic3_binop(s21, 2, op_byte, 0, 1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_const_arith(buf: i64, offs: i64, v0: i64, op_byte: i64) -> EmitState {
    emit_mic3_const_arith_module(es_new(), buf, offs, v0, op_byte)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const fn1 (Strategy A, let cover) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }  pub fn <n1>() -> i64 { <v1> }`,
// byte-exact vs the Rust --emit-mic3 oracle. This is the arith-FIRST ordering (the
// const-arith module is const-first); it is the module shape a 2-param fn written
// with a LET body lowers to (`f(a,b){let t=a+b; t}` == `f(a,b){a+b}` — the let-bound
// value reuses the binop vid, emitting no distinct opcode or string). strtab[4] in
// first-seen order: n0, pa, pb, n1 (indices 0,1,2,3). next_id = 2 (flat scaffold
// consts %0 fn0, %1 fn1). instr_count = 6.
//   FN_DEF n0{PARAM %0=str1, PARAM %1=str2, BINOP %2=%0 op %1} ret %2 ||
//     ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v1} ret %0 || ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_const_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: const (name idx 3).
    let s21: EmitState = emit_mic3_fn_def_header(s20, 3, 1, 0, 1);
    let s22: EmitState = emit_mic3_const_i64(s21, 0, v1);
    let s23: EmitState = emit_mic3_const_i64(s22, 1, 0);
    let s24: EmitState = emit_mic3_output(s23, 1);
    emit_mic3_empty_registries(s24)
}

pub fn selftest_mic3_module_arith_const(buf: i64, offs: i64, op_byte: i64, v1: i64) -> EmitState {
    emit_mic3_arith_const_module(es_new(), buf, offs, op_byte, v1)
}

// ===== mic@3 MULTI-FUNCTION module — arith fn0 + const-args CALL fn1 (Strategy A) =====
//
// `pub fn <n0>(<pa>,<pb>) -> i64 { <pa> OP <pb> }
//  pub fn <n1>() -> i64 { <n0>(<v0>, <v1>) }`, byte-exact vs --emit-mic3. fn1's
// body is a CALL to fn0 with two int-literal args: each arg lowers to a ConstI64
// taking the next body vid (%0, %1), then OP_CALL(0x16) %2 = name#callee(%0,%1)
// (encode_string_idx(callee) || encode_vid_vec([%0,%1])). The FN_DEF ret is %2,
// body_len 3. The callee string DEDUPS to fn0's name index (interned first during
// fn0's FnDef; the call name interns idempotently during body traversal — handled
// by collect_body_strings, so strtab[4] = n0, pa, pb, n1 in first-seen order with
// the call referencing index 0). next_id = 2 (scaffold consts %0 fn0, %1 fn1).
//   FN_DEF n0{PARAM,PARAM,BINOP} ret %2 || ConstI64 %0=0 || Output %0 ||
//   FN_DEF n1{ConstI64 %0=v0, ConstI64 %1=v1, CALL %2=callee(%0,%1)} ret %2 ||
//     ConstI64 %1=0 || Output %1.
pub fn emit_mic3_arith_call_module(s: EmitState, buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 4);
    let s3: EmitState = emit_uleb128(s2, 2);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 6);
    // fn0: arith (name idx 0, params str 1/2).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    // fn1: call body (name idx 3), ret %2, body_len 3.
    let s21: EmitState = es_push(s20, 21);
    let s22: EmitState = emit_uleb128(s21, 3);
    let s23: EmitState = emit_uleb128(s22, 0);
    let s24: EmitState = emit_mic3_opt_vid(s23, 1, 2);
    let s25: EmitState = es_push(s24, 0);
    let s26: EmitState = emit_uleb128(s25, 3);
    let s27: EmitState = emit_mic3_const_i64(s26, 0, v0);
    let s28: EmitState = emit_mic3_const_i64(s27, 1, v1);
    let s29: EmitState = emit_mic3_call2(s28, 2, callee_idx, 0, 1);
    let s30: EmitState = emit_mic3_const_i64(s29, 1, 0);
    let s31: EmitState = emit_mic3_output(s30, 1);
    emit_mic3_empty_registries(s31)
}

// Instr::Call { dst, name, args=[a0,a1] }:
//   OP_CALL(0x16) || vid(dst) || string_idx(name) || uleb(2) || vid(a0) || vid(a1).
pub fn emit_mic3_call2(s: EmitState, dst: i64, name_idx: i64, a0: i64, a1: i64) -> EmitState {
    let s1: EmitState = es_push(s, 22);
    let s2: EmitState = emit_uleb128(s1, dst);
    let s3: EmitState = emit_uleb128(s2, name_idx);
    let s4: EmitState = emit_uleb128(s3, 2);
    let s5: EmitState = emit_uleb128(s4, a0);
    emit_uleb128(s5, a1)
}

pub fn selftest_mic3_module_arith_call(buf: i64, offs: i64, op_byte: i64, callee_idx: i64, v0: i64, v1: i64) -> EmitState {
    emit_mic3_arith_call_module(es_new(), buf, offs, op_byte, callee_idx, v0, v1)
}

// ===========================================================================
// Phase 5c — AST-DRIVEN full-module COLLECTION PASS (the hand-feeding removal)
// ===========================================================================
//
// Phases 5a/5b proved the two multi-function module assemblers
// (emit_mic3_const_fn2_module / emit_mic3_const_arith_module) reproduce the
// 50-byte and 68-byte Rust --emit-mic3 oracles byte-for-byte — but with the
// string table / offsets / const-values / op-byte HAND-FED by the test harness.
// Phase 5c removes the hand-feeding: a pure-MIND COLLECTION PASS that, given
// only the parsed multi-function AST, automatically (a) builds the deduped
// FIRST-SEEN-traversal contiguous string table + offsets array, and (b)
// extracts the const-body values / arith op-byte from the live AST node
// descriptors, then drives the proven assemblers. The result: a whole small
// `.mind` source lowers to a complete mic@3 module with ZERO hand-fed offsets,
// byte-identical to the Rust oracle (Bound by MIND-CONSTITUTION §I).
//
// The string collection mirrors Rust collect_strings / collect_instr_strings
// (src/ir/compact/v3/emit.rs ~492-586) EXACTLY: for each top-level FnDef in
// sequence, intern fn name -> each param name -> recurse body strings (for the
// const / param-arith body shapes here the body carries no strings — int
// literals and binops intern nothing; param idents are resolved positionally,
// not by name interning). StringTable::intern is idempotent (first-seen dedup),
// mirrored by intern_span's span-equality scan over already-interned entries.
//
// ADDITIVE / canary-isolated: exported only via selftest_mic3_module_from_ast;
// the canary mindc_compile / emit_fn_def mic@1 path is untouched, so the
// fixed point stays byte-identical. The actual cutover (routing mindc_compile
// through this pass) is a SEPARATE, deliberately-reviewed step.
//
// SCOPE: the two proven module shapes — (1) two zero-arg const-return fns, and
// (2) a zero-arg const-return fn0 + a 2-param single-binop arith fn1. Any other
// shape returns the seed state unchanged (fail-closed, no partial bytes).

// Append the source span src[lo..hi) to the contiguous string buffer `strbuf`,
// deduping against the strings already interned (first-seen, idempotent — mirrors
// Rust StringTable::intern). `offs` is the offset array (offs[k] = start of
// string k; offs[count] = current write cursor / end of last string). `ccell`
// is a 1-i64 cell holding the live interned-string count. Returns the string
// index (existing on a dedup hit, or the freshly allocated index). Single bytes
// are written with __mind_store_i8 so the buffer is byte-contiguous, exactly as
// emit_mic3_strtab/emit_mic3_lp_bytes expect.
pub fn intern_span(strbuf: i64, offs: i64, ccell: i64, src: i64, lo: i64, hi: i64) -> i64 {
    let n: i64 = __mind_load_i64(ccell);
    let hit: i64 = intern_find(strbuf, offs, n, src, lo, hi, 0);
    if hit >= 0 {
        return hit;
    }
    let start: i64 = __mind_load_i64(offs + n * 8);
    let end: i64 = intern_copy(strbuf, start, src, lo, hi);
    __mind_store_i64(offs + (n + 1) * 8, end);
    __mind_store_i64(ccell, n + 1);
    n
}

// Scan the n already-interned strings for one whose bytes equal src[lo..hi);
// return its index or -1. Mirrors StringTable dedup (span_bytes_equal compares
// raw bytes — no hashing, so no collision risk).
pub fn intern_find(strbuf: i64, offs: i64, n: i64, src: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(offs + i * 8);
    let ehi: i64 = __mind_load_i64(offs + (i + 1) * 8);
    if span_bytes_equal2(src, lo, hi, strbuf, elo, ehi) == 1 {
        return i;
    }
    intern_find(strbuf, offs, n, src, lo, hi, i + 1)
}

// Copy src[lo..hi) into strbuf starting at `dst`; return the new write cursor.
pub fn intern_copy(strbuf: i64, dst: i64, src: i64, lo: i64, hi: i64) -> i64 {
    if lo >= hi {
        return dst;
    }
    __mind_store_i8(strbuf + dst, load_byte(src, lo));
    intern_copy(strbuf, dst + 1, src, lo + 1, hi)
}

// Intern one fn_def's strings in Rust collect_strings order: fn name first,
// then each param name. Body strings (int literals, binops, param-ident leaves)
// intern nothing for the const / param-arith shapes, mirroring the oracle.
pub fn collect_fn_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, fn_node: i64) -> i64 {
    let name_leaf: i64 = ast_child0(fn_node);
    let n0: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let rp: i64 = collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, 0);
    // Recurse the body in statement order, interning any CALL callee names — the
    // Rust collect_instr_strings(Instr::Call) interns the call name during the
    // body traversal (verified: a forward call interns the callee BEFORE the
    // callee fn's own params). Const/int/binop/param/ident bodies intern nothing.
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, 0)
}

// Intern call-callee names appearing in a fn body, in statement+expression order,
// mirroring Rust collect_strings -> collect_instr_strings recursion. Only the
// constructs the AST-driven path emits are walked (let-init, call); other leaves
// intern nothing. Idempotent via intern_span's first-seen dedup.
pub fn collect_body_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> i64 {
    if i >= stmts_len {
        return 0;
    }
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, stmt);
    collect_body_strings(strbuf, offs, ccell, src, stmts_addr, stmts_len, i + 1)
}

pub fn collect_expr_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child2(node));
    }
    if k == ast_call() {
        // Intern the callee name (call lowers to Instr::Call whose name interns).
        let callee: i64 = ast_child0(node);
        let nm: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(callee), ast_span_hi(callee));
        // Then recurse args left-to-right (their own const lowerings precede the
        // Call instr; int-literal args intern nothing, matching the oracle).
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        return collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, 0);
    }
    if k == ast_binop() {
        let rl: i64 = collect_expr_strings(strbuf, offs, ccell, src, ast_child0(node));
        return collect_expr_strings(strbuf, offs, ccell, src, ast_child1(node));
    }
    0
}

pub fn collect_args_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, args_addr: i64, args_len: i64, i: i64) -> i64 {
    if i >= args_len {
        return 0;
    }
    let arg: i64 = __mind_load_i64(args_addr + i * 8);
    let r: i64 = collect_expr_strings(strbuf, offs, ccell, src, arg);
    collect_args_strings(strbuf, offs, ccell, src, args_addr, args_len, i + 1)
}

pub fn collect_param_strings(strbuf: i64, offs: i64, ccell: i64, src: i64, params_addr: i64, n_params: i64, i: i64) -> i64 {
    if i >= n_params {
        return 0;
    }
    let pnode: i64 = __mind_load_i64(params_addr + i * 8);
    let name_leaf: i64 = ast_child0(pnode);
    let idx: i64 = intern_span(strbuf, offs, ccell, src, ast_span_lo(name_leaf), ast_span_hi(name_leaf));
    collect_param_strings(strbuf, offs, ccell, src, params_addr, n_params, i + 1)
}

// Walk the top-level item list and collect every fn_def's strings in sequence —
// the module-wide first-seen traversal order Rust collect_strings produces.
pub fn build_module_strtab(strbuf: i64, offs: i64, ccell: i64, src: i64, items_addr: i64, items_len: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        let r: i64 = collect_fn_strings(strbuf, offs, ccell, src, item);
        return build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1);
    }
    build_module_strtab(strbuf, offs, ccell, src, items_addr, items_len, i + 1)
}

// Extract the i64 value a zero-arg const-return fn returns: its body's trailing
// statement must be an int literal. Returns the literal, or -1 if the body is
// not a single int-literal return (fail-closed shape guard).
pub fn const_fn_value(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    if ast_kind(expr) != ast_int_lit() {
        return 0 - 1;
    }
    parse_int_span(src, ast_span_lo(expr), ast_span_hi(expr), 0)
}

// Extract the mic@3 op-byte of a 2-param single-binop arith fn (body = one
// `pa OP pb` binop whose leaves are the two params, in order). Returns the
// op-byte, or -1 if the shape does not match (fail-closed).
pub fn arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0 - 1;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(expr);
    let r: i64 = ast_child1(expr);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(expr))
}

// Extract the mic@3 op-byte of a 2-param arith fn whose body is written as a
// LET binding then a use of it: `{ let t: i64 = pa OP pb; t }`. The Rust lowering
// produces a body BYTE-IDENTICAL to the direct `{ pa OP pb }` form — the let-bound
// value simply takes the binop's vid (%2) and the trailing `t` resolves to it, so
// no distinct opcode and no extra string is emitted (verified vs --emit-mic3 on
// `f(a,b){let t=a+b; t}` == `f(a,b){a+b}`). Returns the op-byte, or -1 on shape
// mismatch (fail-closed). Two body stmts required: a let with a 2-ident binop init,
// then a trailing ident referencing the let name.
pub fn let_arith_fn_opbyte(src: i64, fn_node: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 2 {
        return 0 - 1;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 2 {
        return 0 - 1;
    }
    let s0: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(s0) != ast_let() {
        return 0 - 1;
    }
    let s1: i64 = __mind_load_i64(stmts_addr + 8);
    if ast_kind(s1) != ast_ident() {
        return 0 - 1;
    }
    // The trailing use must name the let-bound variable.
    let let_name: i64 = ast_child0(s0);
    if span_bytes_equal2(src, ast_span_lo(s1), ast_span_hi(s1), src, ast_span_lo(let_name), ast_span_hi(let_name)) != 1 {
        return 0 - 1;
    }
    let init: i64 = ast_child2(s0);
    if ast_kind(init) != ast_binop() {
        return 0 - 1;
    }
    let l: i64 = ast_child0(init);
    let r: i64 = ast_child1(init);
    if ast_kind(l) != ast_ident() {
        return 0 - 1;
    }
    if ast_kind(r) != ast_ident() {
        return 0 - 1;
    }
    binop_to_byte(ast_aux(init))
}

// Extract the two int-literal argument values of a zero-arg fn whose body is a
// single call with exactly two int-literal arguments: `{ callee(<v0>, <v1>) }`.
// Writes v0 -> out[0], v1 -> out[1] and returns 1 on a match, 0 otherwise
// (fail-closed). The callee name is resolved separately to its string index.
pub fn call_fn_args2(src: i64, fn_node: i64, out: i64) -> i64 {
    if ast_aux(fn_node) / 2 != 0 {
        return 0;
    }
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    if stmts_len != 1 {
        return 0;
    }
    let expr: i64 = __mind_load_i64(stmts_addr);
    if ast_kind(expr) != ast_call() {
        return 0;
    }
    if ast_aux(expr) != 2 {
        return 0;
    }
    let args_addr: i64 = ast_child1(expr);
    let a0: i64 = __mind_load_i64(args_addr);
    let a1: i64 = __mind_load_i64(args_addr + 8);
    if ast_kind(a0) != ast_int_lit() {
        return 0;
    }
    if ast_kind(a1) != ast_int_lit() {
        return 0;
    }
    let v0: i64 = parse_int_span(src, ast_span_lo(a0), ast_span_hi(a0), 0);
    let v1: i64 = parse_int_span(src, ast_span_lo(a1), ast_span_hi(a1), 0);
    __mind_store_i64(out + 0, v0);
    __mind_store_i64(out + 8, v1);
    1
}

// Resolve the string index of a zero-arg call-fn's callee name within the already
// built string table (offs/n hold the interned strings). Returns the index, or -1.
pub fn call_fn_callee_idx(src: i64, fn_node: i64, strbuf: i64, offs: i64, n_strings: i64) -> i64 {
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let expr: i64 = __mind_load_i64(stmts_addr);
    let callee: i64 = ast_child0(expr);
    intern_find(strbuf, offs, n_strings, src, ast_span_lo(callee), ast_span_hi(callee), 0)
}

// AST-DRIVEN full-module driver: lex+parse `src`, build the deduped first-seen
// string table into caller-supplied scratch (strbuf/offs/ccell), detect which of
// the two proven module shapes the source is, extract its const values / op-byte
// from the live AST, and emit the complete mic@3 module byte-exact vs the Rust
// --emit-mic3 oracle — with ZERO hand-fed offsets. Fails closed (returns es_new()
// unchanged, empty buf) on any other shape, so the harness can detect non-emission.
//
//   strbuf : contiguous byte buffer for the string table (>= total name bytes + 8)
//   offs   : offset array ((n_strings + 1) i64s; offs[0] must be pre-zeroed)
//   ccell  : 1-i64 interned-count cell (pre-zeroed)
pub fn selftest_mic3_module_from_ast(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, ccell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let items_addr: i64 = ast_child0(ast_root);
    let items_len: i64 = ast_aux(ast_root);
    // Build the string table from the live AST (the hand-feeding removal).
    __mind_store_i64(ccell, 0);
    __mind_store_i64(offs + 0, 0);
    let r: i64 = build_module_strtab(strbuf, offs, ccell, src_addr, items_addr, items_len, 0);
    // Require exactly two top-level fn_defs.
    let f0: i64 = nth_fn_def(items_addr, items_len, 0);
    let f1: i64 = nth_fn_def(items_addr, items_len, 1);
    let f2: i64 = nth_fn_def(items_addr, items_len, 2);
    if f0 == 0 {
        return es_new();
    }
    if f1 == 0 {
        return es_new();
    }
    if f2 != 0 {
        return es_new();
    }
    // Shape (1): two zero-arg const-return fns.
    let v0: i64 = const_fn_value(src_addr, f0);
    if v0 >= 0 {
        let v1: i64 = const_fn_value(src_addr, f1);
        if v1 >= 0 {
            return emit_mic3_const_fn2_module(es_new(), strbuf, offs, v0, v1);
        }
        // Shape (2): const-return fn0 + 2-param arith fn1.
        let ob: i64 = arith_fn_opbyte(src_addr, f1);
        if ob >= 0 {
            return emit_mic3_const_arith_module(es_new(), strbuf, offs, v0, ob);
        }
    }
    // fn0 = a 2-param arith fn (direct `pa OP pb`, or `let t=pa OP pb; t`).
    let ob0_direct: i64 = arith_fn_opbyte(src_addr, f0);
    let ob0_let: i64 = let_arith_fn_opbyte(src_addr, f0);
    let ob0: i64 = if ob0_direct >= 0 {
        ob0_direct
    } else {
        ob0_let
    };
    if ob0 >= 0 {
        // Shape (3): arith fn0 + const fn1 (the LET-body ordering — arith first).
        let cv1: i64 = const_fn_value(src_addr, f1);
        if cv1 >= 0 {
            return emit_mic3_arith_const_module(es_new(), strbuf, offs, ob0, cv1);
        }
        // Shape (4): arith fn0 + const-args CALL fn1.
        let scratch: i64 = __mind_alloc(16);
        let ok: i64 = call_fn_args2(src_addr, f1, scratch);
        if ok == 1 {
            let ncount: i64 = __mind_load_i64(ccell);
            let cidx: i64 = call_fn_callee_idx(src_addr, f1, strbuf, offs, ncount);
            if cidx >= 0 {
                let cva: i64 = __mind_load_i64(scratch + 0);
                let cvb: i64 = __mind_load_i64(scratch + 8);
                return emit_mic3_arith_call_module(es_new(), strbuf, offs, ob0, cidx, cva, cvb);
            }
        }
    }
    es_new()
}

// Return the j-th top-level fn_def node (0-based), or 0 if fewer than j+1 exist.
pub fn nth_fn_def(items_addr: i64, items_len: i64, j: i64) -> i64 {
    nth_fn_def_loop(items_addr, items_len, j, 0, 0)
}
pub fn nth_fn_def_loop(items_addr: i64, items_len: i64, j: i64, seen: i64, i: i64) -> i64 {
    if i >= items_len {
        return 0;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    if ast_kind(item) == ast_fn_def() {
        if seen == j {
            return item;
        }
        return nth_fn_def_loop(items_addr, items_len, j, seen + 1, i + 1);
    }
    nth_fn_def_loop(items_addr, items_len, j, seen, i + 1)
}

// ===== mic@3 COMPLETE with-body module — the 2-param arithmetic function family (Phase 4c) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>, <pb>) -> i64 { <pa> OP <pb> }`,
// byte-exact vs the Rust oracle. Extends Phase 4a (const-return) to functions with
// PARAMETERS and a real BINOP body. `buf`/`offs` carry 3 strings (name, pa, pb);
// `op_byte` is binop_to_byte(op) (0 = Add, as `a + b`). The exact shape emit_mic3 +
// the lowering produce (decoded from the oracle):
//   header || strtab(3:name,pa,pb) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0),(2,%1)], ret=%2, body=[PARAM %0, PARAM %1,
//            BINOP %2 = %0 op %1]} || ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// For add(a,b){a+b} (op_byte=0) this reproduces the 49-byte oracle byte-for-byte.
pub fn emit_mic3_arith_fn_module(s: EmitState, buf: i64, offs: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 3);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 2);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_uleb128(s10, 2);
    let s12: EmitState = emit_uleb128(s11, 1);
    let s13: EmitState = emit_mic3_opt_vid(s12, 1, 2);
    let s14: EmitState = es_push(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 3);
    let s16: EmitState = emit_mic3_param(s15, 0, 1, 0);
    let s17: EmitState = emit_mic3_param(s16, 1, 2, 1);
    let s18: EmitState = emit_mic3_binop(s17, 2, op_byte, 0, 1);
    let s19: EmitState = emit_mic3_const_i64(s18, 0, 0);
    let s20: EmitState = emit_mic3_output(s19, 0);
    emit_mic3_empty_registries(s20)
}

pub fn selftest_mic3_arith_fn(buf: i64, offs: i64, op_byte: i64) -> EmitState {
    emit_mic3_arith_fn_module(es_new(), buf, offs, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the single-param identity family (Phase 4d) =====
//
// Assembles the full mic@3 of `pub fn <name>(<pa>) -> i64 { <pa> }`, byte-exact vs
// the Rust oracle. This is the FIRST function whose RETURN is a PARAMETER directly:
// the FN_DEF ret_vid is the param's own vid (%0) and the body is a single PARAM
// instruction — no BINOP, no body ConstI64 (distinct from Phase 4a const-return,
// where the body is a ConstI64, and Phase 4c arith, where the body is PARAM,PARAM,
// BINOP). `buf`/`offs` carry 2 strings (name, pa). The exact shape emit_mic3 + the
// lowering produce (decoded from the oracle for `ident(a){a}`, 38 bytes):
//   header || strtab(2:name,pa) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)], ret=%0, body=[PARAM %0]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_ident_fn_module(s: EmitState, buf: i64, offs: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, 2);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_uleb128(s7, 1);
    let s9: EmitState = emit_uleb128(s8, 1);
    let s10: EmitState = emit_uleb128(s9, 0);
    let s11: EmitState = emit_mic3_opt_vid(s10, 1, 0);
    let s12: EmitState = es_push(s11, 0);
    let s13: EmitState = emit_uleb128(s12, 1);
    let s14: EmitState = emit_mic3_param(s13, 0, 1, 0);
    let s15: EmitState = emit_mic3_const_i64(s14, 0, 0);
    let s16: EmitState = emit_mic3_output(s15, 0);
    emit_mic3_empty_registries(s16)
}

pub fn selftest_mic3_ident_fn(buf: i64, offs: i64) -> EmitState {
    emit_mic3_ident_fn_module(es_new(), buf, offs)
}

// ===== mic@3 COMPLETE with-body module — the N-param chained-binop family (Phase 4e) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { p0 OP p1 OP .. }`,
// byte-exact vs the Rust oracle, for N >= 2 left-associated binops of one op. This is
// the FIRST body that emits MORE THAN ONE BINOP where each consumes the previous
// binop's result: params take %0..%(n-1), then %n = %0 op %1, %(n+1) = %n op %2,
// %(n+2) = %(n+1) op %3, ... — the second operand of binop k (k>=1) is param %(k+1)
// and the first operand is the running accumulator %(n+k-1). The FN_DEF ret_vid is
// the FINAL binop's vid (2n-2) and body_len = n PARAMs + (n-1) BINOPs = 2n-1.
// `buf`/`offs` carry (n+1) strings (name then the n params, str_idx i+1 -> vid i);
// `op_byte` is binop_to_byte(op) (0 = Add). Decoded from the oracle for
// chain(a,b,c){a+b+c} (n=3, 64 bytes: ret %4, body_len 5) and
// chain4(a,b,c,d){a+b+c+d} (n=4, 78 bytes: ret %6, body_len 7). Generalizes the
// Phase 4c 2-param arith module (n=2 collapses to a single binop, identical shape).
//   header || strtab(n+1) || next_id(1) || exports(0) || uleb(3 instrs) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%(2n-2),
//            body=[PARAM %0..PARAM %(n-1), BINOP %n=%0 op %1,
//                  BINOP %(n+1)=%n op %2, ..]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
pub fn emit_mic3_chain_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header (inline: name_idx=0, then encode_named_vids param list).
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    // ret = Some %(2n-2) (final binop vid); reap None; body_len = 2n-1.
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, n + n - 2);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + n - 1);
    // Body: n PARAM instrs (%i, str i+1, index i), then the binop chain.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_chain_binops(s12, n, op_byte, 1);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// FN_DEF param list (encode_named_vids): uleb(n) then n pairs (str_idx i+1, vid i).
pub fn emit_mic3_chain_param_pairs(s: EmitState, n: i64) -> EmitState {
    let s1: EmitState = emit_uleb128(s, n);
    emit_mic3_chain_param_pairs_loop(s1, n, 0)
}

pub fn emit_mic3_chain_param_pairs_loop(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_uleb128(s, i + 1);
    let s2: EmitState = emit_uleb128(s1, i);
    emit_mic3_chain_param_pairs_loop(s2, n, i + 1)
}

// Body PARAM instrs: PARAM(%i, name=i+1, index=i) for i in 0..n.
pub fn emit_mic3_chain_params(s: EmitState, n: i64, i: i64) -> EmitState {
    if i >= n {
        return s;
    }
    let s1: EmitState = emit_mic3_param(s, i, i + 1, i);
    emit_mic3_chain_params(s1, n, i + 1)
}

// Body BINOP chain: for k in 1..n emit BINOP(dst=%(n+k-1), op, lhs, rhs):
//   k == 1: lhs=%0, rhs=%1 (the first add of the two leading params);
//   k  > 1: lhs=%(n+k-2) (running accumulator), rhs=%k (next param).
// Caller passes k starting at 1; there are n-1 binops.
pub fn emit_mic3_chain_binops(s: EmitState, n: i64, op_byte: i64, k: i64) -> EmitState {
    if k >= n {
        return s;
    }
    let dst: i64 = n + k - 1;
    if k == 1 {
        let s1: EmitState = emit_mic3_binop(s, dst, op_byte, 0, 1);
        return emit_mic3_chain_binops(s1, n, op_byte, k + 1);
    }
    let s2: EmitState = emit_mic3_binop(s, dst, op_byte, n + k - 2, k);
    emit_mic3_chain_binops(s2, n, op_byte, k + 1)
}

pub fn selftest_mic3_chain_fn(buf: i64, offs: i64, n: i64, op_byte: i64) -> EmitState {
    emit_mic3_chain_fn_module(es_new(), buf, offs, n, op_byte)
}

// ===== mic@3 COMPLETE with-body module — the mixed-operator expression-tree family (Phase 4f) =====
//
// Assembles the full mic@3 of `pub fn <name>(p0, .., p(n-1)) -> i64 { <expr-tree> }`,
// byte-exact vs the Rust oracle, for an ARBITRARY binary-expression tree of MIXED
// operators — the first body that is NOT a left-spine accumulator. Examples:
//   mixed(a,b,c,d){a*b+c*d}  (tree +(*(a,b),*(c,d)), 77-byte oracle)
//   f(a,b,c){(a+b)*c}        (tree *(+(a,b),c),       60-byte oracle)
//
// The tree is supplied as a flat POST-ORDER node array (the standard flattening of
// a recursive post-order walk — the lowering emits each subtree, allocates a fresh
// vid, then references the two child vids). `nodes` is a heap array of `n_nodes`
// 4-i64 records (32 bytes each):
//   record[0] = kind: 0 = LEAF (param), 1 = BINOP.
//   LEAF :  record[1] = param index (its vid IS the index, since param i -> vid i).
//   BINOP:  record[1] = op_byte, record[2] = left child slot, record[3] = right slot.
// Nodes are in post-order, so a binop's child slots always precede it. The vid of a
// LEAF slot is its param index; the vid of a BINOP slot is allocated n, n+1, .. in
// post-order array order (== emission order). The FN_DEF ret_vid is the LAST node's
// vid (the tree root). body_len = n PARAMs + (#BINOP nodes). Decoded from the oracle:
//   header || strtab(n+1: name,p0..p(n-1)) || next_id(1) || exports(0) || uleb(3) ||
//     FN_DEF{name=0, params=[(1,%0)..(n,%(n-1))], ret=%root,
//            body=[PARAM %0..%(n-1), then BINOP per binop-node in post-order with
//                  the two child slot vids]} ||
//     ConstI64(%0,0) || Output(%0) ||
//   3 empty registries.
// Generalizes Phase 4e (the left-spine chain is the special case where every binop's
// left child is the previous binop and right child is the next leaf).
//
// `vidbuf` is a caller-supplied heap scratch array of `n_nodes` i64s used to record
// each slot's resolved vid (a binop references children by slot, so the slot->vid map
// must be materialized before the binops emit). It is filled by the first pass below.
pub fn emit_mic3_tree_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    // Pass 1: resolve every slot's vid into vidbuf (post-order, binops from %n).
    let root: i64 = tree_resolve_vids(nodes, n_nodes, n, vidbuf, 0, n);
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, encode_named_vids param list, ret Some %root, reap
    // None, body_len = n PARAMs + nbinops.
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, root);
    let s10: EmitState = es_push(s9, 0);
    // body_len = one instr per node: n PARAMs + every non-param node (binops and
    // const leaves). Since params are slots 0..(some) and ALL n_nodes nodes emit
    // exactly one body instr, body_len == n_nodes. For a param-only tree this is
    // identical to the former `n + nbinops` (every leaf is a param) — byte-exact.
    let s11: EmitState = emit_uleb128(s10, n_nodes);
    // Body: n PARAM instrs (reuse the chain param-body writer), then every
    // non-param node in post-order — binops with resolved child vids, const leaves
    // as their own ConstI64 at the interleaved slot.
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    let s13: EmitState = emit_mic3_tree_body(s12, nodes, n_nodes, vidbuf, 0);
    // Module-level ConstI64(%0,0), Output(%0), 3 empty registries.
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Pass 1: walk slots 0..n_nodes in order and record each slot's vid in vidbuf.
//   kind 0 (PARAM leaf): vid = param index (params own vids 0..n-1).
//   kind 1 (BINOP) and kind 2 (CONST leaf): vid = the running counter `nxt`
//     (starts at n). Const leaves and binops SHARE the post-order vid counter —
//     the Rust --emit-mic3 oracle interleaves them (e.g. h(a){a*2+1} resolves
//     PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4). Since both non-param
//     kinds fall through to the same `nxt++` branch, the post-order slot order
//     IS the oracle's interleaved vid order. Returns the LAST slot's vid (root).
// `i` is the current slot, `nxt` the next free non-param vid.
pub fn tree_resolve_vids(nodes: i64, n_nodes: i64, n: i64, vidbuf: i64, i: i64, nxt: i64) -> i64 {
    if i >= n_nodes {
        return __mind_load_i64(vidbuf + (n_nodes - 1) * 8);
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt);
    }
    __mind_store_i64(vidbuf + i * 8, nxt);
    tree_resolve_vids(nodes, n_nodes, n, vidbuf, i + 1, nxt + 1)
}

// Pass 2: emit one body instr per NON-PARAM slot, in post-order array order.
//   kind 0 (PARAM leaf): emit nothing (its PARAM was written in the param pass).
//   kind 1 (BINOP): dst = vidbuf[slot]; lhs/rhs = vidbuf[left]/vidbuf[right].
//   kind 2 (CONST leaf): record[1] holds the RAW literal value; emit a ConstI64
//     at vidbuf[slot] (emit_mic3_const_i64 zigzag-encodes it, so lit 2 -> the
//     oracle's CONST 4). Const slots are interleaved with binops by post-order.
// For a param-only tree no kind-2 slot exists, so this is byte-identical to the
// former emit_mic3_tree_binops (Bound by MIND-CONSTITUTION §I — param-only path
// unchanged).
pub fn emit_mic3_tree_body(s: EmitState, nodes: i64, n_nodes: i64, vidbuf: i64, i: i64) -> EmitState {
    if i >= n_nodes {
        return s;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        return emit_mic3_tree_body(s, nodes, n_nodes, vidbuf, i + 1);
    }
    let dst: i64 = __mind_load_i64(vidbuf + i * 8);
    if kind == 2 {
        let lit: i64 = __mind_load_i64(nodes + i * 32 + 8);
        let sc: EmitState = emit_mic3_const_i64(s, dst, lit);
        return emit_mic3_tree_body(sc, nodes, n_nodes, vidbuf, i + 1);
    }
    let op_byte: i64 = __mind_load_i64(nodes + i * 32 + 8);
    let lslot: i64 = __mind_load_i64(nodes + i * 32 + 16);
    let rslot: i64 = __mind_load_i64(nodes + i * 32 + 24);
    let lvid: i64 = __mind_load_i64(vidbuf + lslot * 8);
    let rvid: i64 = __mind_load_i64(vidbuf + rslot * 8);
    let s1: EmitState = emit_mic3_binop(s, dst, op_byte, lvid, rvid);
    emit_mic3_tree_body(s1, nodes, n_nodes, vidbuf, i + 1)
}

pub fn selftest_mic3_tree_fn(buf: i64, offs: i64, n: i64, nodes: i64, n_nodes: i64, vidbuf: i64) -> EmitState {
    emit_mic3_tree_fn_module(es_new(), buf, offs, n, nodes, n_nodes, vidbuf)
}

// ===========================================================================
// Phase 4g/4h — AST-DRIVEN mic@3 expression emission (the bootstrap-parser bridge)
// ===========================================================================
//
// Phase 4f drove emit_mic3_tree_fn_module from a SYNTHETIC hand-built 4-i64 node
// descriptor. Phase 4g closed the gap to self-compilation: it walks the LIVE
// bootstrap-parser AST (real 56-byte ast_binop / ast_ident nodes — see
// ast_new_binop at line ~621, ast_child0=lhs+24, ast_child1=rhs+32, ast_aux=op+48)
// and FLATTENS it into the same post-order descriptor the proven 4f emitter
// consumes. The byte-exact emitter is reused, so the param-only path is byte-exact-
// by-construction with the Phase 4f path AND the Rust oracle.
//
// Phase 4h adds CONST LEAVES (ast_int_lit). The descriptor gains a third record
// kind (kind 2 = const, record[1] = raw literal). A const leaf gets its own
// post-order slot whose vid is allocated INTERLEAVED with the binops (the oracle
// does NOT batch consts with params): e.g. h(a){a*2+1} resolves
//   PARAM %0, CONST %1, BINOP %2, CONST %3, BINOP %4
// and the const value is zigzag-encoded at emit (lit 2 -> CONST 4, lit 3 -> CONST
// 6) by the existing emit_mic3_const_i64. Pass 1 (tree_resolve_vids) already routes
// every non-param node through the shared `nxt++` counter, and Pass 2
// (emit_mic3_tree_body) emits a ConstI64 at a const slot — so param-only trees keep
// the exact former bytes (no kind-2 slot fires) while const leaves now lower
// byte-exact vs --emit-mic3 (Bound by MIND-CONSTITUTION §I).
//
// SCOPE: ast_binop trees whose leaves are ast_ident PARAM references and/or
// ast_int_lit CONST literals. field access / calls / if / let are later-phase
// walls (flatten_ast returns -1, the driver fails closed — no partial bytes).

// AST binop op-tag (op_add()=1, op_sub()=2, op_mul()=3, op_div()=4 ..) -> the
// mic@3 op_byte the oracle stores (add=0, sub=1, mul=2, div=3 ..). The mapping is
// op_byte = op_tag - 1 across the arithmetic ops (verified vs --emit-mic3).
pub fn binop_to_byte(op_tag: i64) -> i64 {
    op_tag - 1
}

// Recursive post-order flatten of a param-only binary-expression AST sub-tree into
// the 4-i64 descriptor array `nodes` (kind,a,b,c per record, 32 bytes). `cursor` is
// a 1-i64 heap cell holding the next free slot. Returns the slot index of `node`'s
// emitted record, or -1 if the sub-tree contains an unsupported construct (a
// const/int leaf, or anything that is not ast_ident / ast_binop). On -1 the caller
// MUST abort (the descriptor is then partial/invalid) — fail-closed, never a
// byte-mismatched emit (Bound by MIND-CONSTITUTION §I).
pub fn flatten_ast(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        // Parentheses are purely structural — the mic@3 oracle carries no paren
        // node (verified vs --emit-mic3 on (a+b)*c). Recurse transparently.
        return flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 0);
        __mind_store_i64(nodes + slot * 32 + 8, idx);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_int_lit() {
        // Phase 4h: const leaf. The int-literal node carries no stored value, only
        // its source span [lo,hi) — parse the decimal digits to the raw literal.
        // Descriptor kind=2, record[1]=raw literal (emit_mic3_const_i64 zigzag-
        // encodes it at emission, matching the oracle's CONST lit*2). A const leaf
        // gets its own post-order slot (vid allocated interleaved with binops).
        let lit: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let lslot: i64 = flatten_ast(ast_child0(node), buf, params_addr, n_params, nodes, cursor);
        if lslot < 0 {
            return 0 - 1;
        }
        let rslot: i64 = flatten_ast(ast_child1(node), buf, params_addr, n_params, nodes, cursor);
        if rslot < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, lslot);
        __mind_store_i64(nodes + slot * 32 + 24, rslot);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    // Every other kind (field access, call, if, ...) = a later-phase wall — reject.
    0 - 1
}

// Count the slots a param-only AST sub-tree flattens to (= total nodes in the tree),
// so the caller can size the descriptor / vidbuf scratch. Returns -1 on an
// unsupported construct (mirrors flatten_ast's rejection set exactly).
pub fn count_ast_nodes(node: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_ast_nodes(ast_child0(node));
    }
    if k == ast_ident() {
        return 1;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_ast_nodes(ast_child0(node));
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_ast_nodes(ast_child1(node));
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    0 - 1
}

// AST-driven driver: flatten a real param-only binary-expression AST `expr` into the
// 4f descriptor, then emit byte-exact via the proven emit_mic3_tree_fn_module. Two
// buffers: `src` (source bytes, holds the scattered param-name spans used by
// flatten_ast for param-index resolution) and `strbuf`/`offs` (a CONTIGUOUS name
// buffer + offset array — string i spans strbuf[offs[i]..offs[i+1]] — for the mic@3
// string table; emit_mic3_strtab requires contiguous packing, the source spans are
// not). `n` is the param count, `params_addr`/`n_params` the parsed param block.
// `nodes`/`cursor`/`vidbuf` are caller-supplied heap scratch (nodes: n_nodes*32
// bytes; cursor: 1 i64; vidbuf: n_nodes i64). On an unsupported body (const leaf /
// non-arith) it returns the unmodified seed state `s` so the caller can detect
// non-emission — fail-closed, no partial bytes (Bound by MIND-CONSTITUTION §I.4).
pub fn emit_mic3_ast_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, expr: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    let root: i64 = flatten_ast(expr, src, params_addr, n_params, nodes, cursor);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4g): lex+parse `src`, find the first fn_def, take its
// trailing body expression, flatten the REAL AST, and emit mic@3 — byte-exact vs
// the Rust --emit-mic3 oracle for param-only bodies (e.g. mixed(a,b,c,d){a*b+c*d}).
// `strbuf`/`offs` are the caller-supplied CONTIGUOUS string-table name buffer +
// offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf` are caller-supplied heap
// scratch sized to the body's node count. Returns the EmitState (Python harness
// decodes EmitState.buf); for a const-leaf body it returns es_new() unchanged (empty
// buf) — the Phase 4h deferral, detectable by the harness.
pub fn selftest_mic3_ast_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    let expr: i64 = __mind_load_i64(stmts_addr + (stmts_len - 1) * 8);
    emit_mic3_ast_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, expr, nodes, cursor, vidbuf)
}

// ===========================================================================
// Phase 4i — LET-BOUND LOCALS / multi-statement bodies (the let-env bridge)
// ===========================================================================
//
// Phase 4g/4h emitted a SINGLE trailing-expression body. Phase 4i extends the
// AST walk to a STATEMENT SEQUENCE: zero or more `let name: ty = init;` bindings
// feeding a final expression. The oracle (--emit-mic3) rule, decoded byte-for-byte
// from f(a,b){let t=a*b; t+1}, g(a){let x=a+1; let y=x*2; y}, h(a,b){let s=a+b; s*s}:
//
//   * Each `let name = init` flattens `init` post-order into the SAME descriptor
//     array; the resulting ROOT slot's vid is bound to `name`. No instruction and
//     no string-table entry is emitted for the let-name — it is a pure vid ALIAS
//     (strtab carries only the fn name + params; t/x/y/s are absent).
//   * A later ast_ident referencing a let-name returns that bound SLOT (an alias,
//     emits no new node) — exactly as a param ident returns its param slot. So
//     `t+1` -> BINOP whose lhs is the let-init's slot; `s*s` reuses ONE slot twice.
//   * The trailing expression flattens normally; its root slot vid = the FN_DEF
//     ret_vid. body_len = total descriptor nodes (PARAMs + every CONST/BINOP);
//     let-name aliases contribute nothing (Bound by MIND-CONSTITUTION §I —
//     verified byte-exact: letf 55B / letg 50B / leth 52B).
//
// The single-expression path (selftest_mic3_ast_fn) is UNTOUCHED below this point;
// flatten_ast / emit_mic3_ast_fn_module stay byte-identical for param/const bodies.
//
// SCOPE: bodies whose statements are `let` bindings (param/const/binop inits, the
// 4g/4h expr grammar) plus a trailing expression. A let whose init contains a
// non-arith construct, or any statement that is not a let / final expr, is a
// later-phase wall (flatten returns -1, the driver fails closed — no partial bytes).

// Let-env: parallel heap array. Entry j at `lenv + j*24` = [name_lo, name_hi, slot].
// `lcount` is a 1-i64 cell holding the live entry count. Look up the ident span
// buf[lo..hi): return the bound descriptor slot, or -1 if not a let-name. Span
// comparison (span_bytes_equal) mirrors resolve_param exactly — no hashing, so no
// collision risk on fresh let names.
pub fn resolve_let(lenv: i64, lcount: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_let_loop(lenv, __mind_load_i64(lcount), buf, lo, hi, 0)
}
pub fn resolve_let_loop(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    resolve_let_loop(lenv, n, buf, lo, hi, i + 1)
}

// Let-env-aware post-order flatten. Identical to flatten_ast (Phase 4g/4h) except
// the ast_ident branch first tries params, THEN let-names (alias to the bound slot,
// no new node). Threads lenv/lcount through paren/binop recursion. Returns the
// node's slot index, or -1 on an unsupported construct (fail-closed).
pub fn flatten_ast_le(node: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            let slot: i64 = __mind_load_i64(cursor);
            __mind_store_i64(nodes + slot * 32 + 0, 0);
            __mind_store_i64(nodes + slot * 32 + 8, idx);
            __mind_store_i64(nodes + slot * 32 + 16, 0);
            __mind_store_i64(nodes + slot * 32 + 24, 0);
            __mind_store_i64(cursor, slot + 1);
            return slot;
        }
        // Not a param: a let-bound local resolves to its init's already-emitted
        // slot (an alias — emit no new node, return the bound slot directly).
        let lslot: i64 = resolve_let(lenv, lcount, buf, ast_span_lo(node), ast_span_hi(node));
        if lslot >= 0 {
            return lslot;
        }
        return 0 - 1;
    }
    if k == ast_int_lit() {
        let lit: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 2);
        __mind_store_i64(nodes + slot * 32 + 8, lit);
        __mind_store_i64(nodes + slot * 32 + 16, 0);
        __mind_store_i64(nodes + slot * 32 + 24, 0);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    if k == ast_binop() {
        let ls: i64 = flatten_ast_le(ast_child0(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if ls < 0 {
            return 0 - 1;
        }
        let rs: i64 = flatten_ast_le(ast_child1(node), buf, params_addr, n_params, nodes, cursor, lenv, lcount);
        if rs < 0 {
            return 0 - 1;
        }
        let slot: i64 = __mind_load_i64(cursor);
        __mind_store_i64(nodes + slot * 32 + 0, 1);
        __mind_store_i64(nodes + slot * 32 + 8, binop_to_byte(ast_aux(node)));
        __mind_store_i64(nodes + slot * 32 + 16, ls);
        __mind_store_i64(nodes + slot * 32 + 24, rs);
        __mind_store_i64(cursor, slot + 1);
        return slot;
    }
    0 - 1
}

// Walk a block's statement list: each `let` flattens its init and binds the
// let-name span -> the init's root slot in the let-env; the FINAL statement is the
// trailing expression, flattened and its root slot returned (the fn ret slot).
// Returns the trailing expr's root slot, or -1 on any wall (a non-let / non-final
// statement, a let-init that doesn't flatten, or an unsupported trailing expr).
pub fn flatten_stmts(stmts_addr: i64, stmts_len: i64, i: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, lenv: i64, lcount: i64) -> i64 {
    let stmt: i64 = __mind_load_i64(stmts_addr + i * 8);
    if i + 1 >= stmts_len {
        // Final statement = the trailing value expression.
        return flatten_ast_le(stmt, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    }
    // Non-final statements must be `let` bindings.
    if ast_kind(stmt) != ast_let() {
        return 0 - 1;
    }
    let init: i64 = ast_child2(stmt);
    let slot: i64 = flatten_ast_le(init, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if slot < 0 {
        return 0 - 1;
    }
    let name_leaf: i64 = ast_child0(stmt);
    let j: i64 = __mind_load_i64(lcount);
    __mind_store_i64(lenv + j * 24 + 0, ast_span_lo(name_leaf));
    __mind_store_i64(lenv + j * 24 + 8, ast_span_hi(name_leaf));
    __mind_store_i64(lenv + j * 24 + 16, slot);
    __mind_store_i64(lcount, j + 1);
    flatten_stmts(stmts_addr, stmts_len, i + 1, buf, params_addr, n_params, nodes, cursor, lenv, lcount)
}

// AST-driven driver for multi-statement (let-bound) bodies: flatten the whole
// statement sequence into the 4f descriptor, then emit byte-exact via the proven
// emit_mic3_tree_fn_module. Fails closed (returns the seed state `s`) on any wall.
pub fn emit_mic3_let_fn_module(s: EmitState, src: i64, strbuf: i64, offs: i64, n: i64, params_addr: i64, n_params: i64, stmts_addr: i64, stmts_len: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let root: i64 = flatten_stmts(stmts_addr, stmts_len, 0, src, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root < 0 {
        return s;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    emit_mic3_tree_fn_module(s, strbuf, offs, n, nodes, n_nodes, vidbuf)
}

// Self-test entry (Phase 4i): lex+parse `src`, find the first fn_def, walk its full
// body statement list (let bindings + trailing expr), and emit mic@3 — byte-exact
// vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied CONTIGUOUS
// string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/`cursor`/`vidbuf`
// are heap scratch sized to the body node count; `lenv`/`lcount` are the let-env
// scratch (lenv: n_lets*24 bytes; lcount: 1 i64).
pub fn selftest_mic3_let_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let stmts_addr: i64 = ast_child0(body);
    let stmts_len: i64 = ast_aux(body);
    emit_mic3_let_fn_module(es_new(), src_addr, strbuf, offs, n_params, params_addr, n_params, stmts_addr, stmts_len, nodes, cursor, vidbuf, lenv, lcount)
}

// ===========================================================================
// Phase 4j — IF-EXPRESSION as a value (the control-flow frontier)
// ===========================================================================
//
// `if cond { then } else { else }` used as a value lowers to ONE top-level body
// instruction: OP_IF (0x1C). Decoded byte-for-byte from the Rust --emit-mic3
// oracle (src/ir/compact/v3/emit.rs Instr::If arm + src/eval/lower.rs):
//
//   OP_IF(0x1C)
//     vid(cond_id)
//     uleb(cond_instrs.len) || cond_instrs...
//     uleb(then_instrs.len) || then_instrs...
//     vid(then_result)
//     uleb(else_instrs.len) || else_instrs...
//     vid(else_result)
//     vid(dst)
//     encode_named_vids(branch_bindings)   // uleb(count) || (str,vid)*
//     encode_vid_triples(merges)           // uleb(count) || (vid,vid,vid)*
//
// VID THREADING (decoded; params own vids 0..n-1, the counter starts at n):
//   * cond: its NON-param nodes take vids n, n+1, ... (params re-use their own
//     vid, emit NO sub-instr). cond_id = cond's root vid. No synth const.
//   * then: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1406),
//     then the then-expr's non-param nodes. then_result = then-expr's root vid.
//   * else: a SYNTHESISED ConstI64(synth, 0) is pushed FIRST (lower.rs:1476),
//     then the else-expr's non-param nodes. else_result = else-expr's root vid.
//   * dst = the next free vid after both branches (the if's value / ret_vid).
//
// SCOPE (the SMALLEST canary-safe increment): cond / then-expr / else-expr are
// each a param/const/binop tree (the same construct flatten_ast already lowers),
// the else clause is PRESENT, and neither branch writes an outer var or binds a
// branch-local let — so branch_bindings and merges are BOTH empty (count 0).
// Let-in-branch, no-else, and nested if are later 4j sub-steps. This path is
// ISOLATED from the canary (exported only via selftest_mic3_if_fn); the
// AST-driven body emitter still rejects ast_if (flatten_ast/flatten_ast_le
// return -1), so the fixed point stays byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Count the non-param nodes a param/const/binop tree flattens to (= CONST leaves
// + BINOP nodes). Params contribute 0 (they re-use their own vid, no sub-instr).
// Returns -1 on any unsupported construct (mirrors flatten_ast's rejection set).
pub fn count_nonparam_nodes(node: i64, buf: i64, params_addr: i64, n_params: i64) -> i64 {
    let k: i64 = ast_kind(node);
    if k == ast_paren() {
        return count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx < 0 {
            return 0 - 1;
        }
        return 0;
    }
    if k == ast_int_lit() {
        return 1;
    }
    if k == ast_binop() {
        let l: i64 = count_nonparam_nodes(ast_child0(node), buf, params_addr, n_params);
        if l < 0 {
            return 0 - 1;
        }
        let r: i64 = count_nonparam_nodes(ast_child1(node), buf, params_addr, n_params);
        if r < 0 {
            return 0 - 1;
        }
        return 1 + l + r;
    }
    0 - 1
}

// Pass-1 vid resolution with an arbitrary non-param base. Identical to
// tree_resolve_vids except the non-param counter starts at `base` (instead of n):
// param leaf -> param index; CONST/BINOP -> base, base+1, .. in post-order.
// Returns the next free vid after this tree (so the caller can thread it onward).
pub fn tree_resolve_vids_base(nodes: i64, n_nodes: i64, vidbuf: i64, i: i64, base: i64) -> i64 {
    if i >= n_nodes {
        return base;
    }
    let kind: i64 = __mind_load_i64(nodes + i * 32);
    if kind == 0 {
        let pidx: i64 = __mind_load_i64(nodes + i * 32 + 8);
        __mind_store_i64(vidbuf + i * 8, pidx);
        return tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base);
    }
    __mind_store_i64(vidbuf + i * 8, base);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, i + 1, base + 1)
}

// Flatten ONE branch/cond expression tree into a fresh descriptor (resets cursor),
// resolve its slot vids from `base`, and return the root slot's resolved vid (or
// -1 on a wall). On success `cursor` holds n_nodes and `vidbuf` is filled — the
// caller emits the branch's non-param instrs via emit_mic3_tree_body.
pub fn flatten_branch(expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    let root_slot: i64 = flatten_ast(expr, buf, params_addr, n_params, nodes, cursor);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Extract a block's single trailing expression. The minimal 4j branch is a block
// whose only statement is the value expression (stmts_len == 1). Returns the
// expr node, or -1 if the block has != 1 statement (a later 4j sub-step).
pub fn branch_single_expr(blk: i64) -> i64 {
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len != 1 {
        return 0 - 1;
    }
    __mind_load_i64(stmts_addr + 0)
}

// Emit the OP_IF body instruction (0x1C) for the simplest if-expression: cond /
// then-expr / else-expr are each a param/const/binop tree, else present, no
// branch writes (branch_bindings + merges both empty). Threads the vid counter
// through cond -> then(synth + tree) -> else(synth + tree) -> dst, byte-exact vs
// the oracle. Returns the post-OP_IF EmitState; the if's result vid is `dst`
// (the caller uses it as the FN_DEF ret_vid). On a wall returns the seed `s`
// unchanged and writes -1 to `okcell` so the caller fails closed.
pub fn emit_mic3_if_instr(s: EmitState, cond_expr: i64, then_expr: i64, else_expr: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, base0: i64, okcell: i64) -> EmitState {
    // --- cond ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(cursor);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, nodes, cond_n, vidbuf, 0);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then: synth ConstI64(after_cond, 0) FIRST, then the then-expr tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch(then_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(cursor);
    let then_nonparam: i64 = count_nonparam_nodes(then_expr, buf, params_addr, n_params);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, nodes, then_n, vidbuf, 0);
    let s8: EmitState = emit_uleb128(s7, then_root);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else: synth ConstI64(after_then, 0) FIRST, then the else-expr tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch(else_expr, buf, params_addr, n_params, nodes, cursor, vidbuf, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(cursor);
    let else_nonparam: i64 = count_nonparam_nodes(else_expr, buf, params_addr, n_params);
    let s9: EmitState = emit_uleb128(s8, else_nonparam + 1);
    let s10: EmitState = emit_mic3_const_i64(s9, else_synth, 0);
    let s11: EmitState = emit_mic3_tree_body(s10, nodes, else_n, vidbuf, 0);
    let s12: EmitState = emit_uleb128(s11, else_root);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- dst (the if's value) + empty branch_bindings + empty merges ---
    let dst: i64 = after_else;
    let s13: EmitState = emit_uleb128(s12, dst);
    let s14: EmitState = emit_uleb128(s13, 0);
    let s15: EmitState = emit_uleb128(s14, 0);
    __mind_store_i64(okcell, dst);
    s15
}

// Assemble the full mic@3 module of
//   pub fn <name>(p0,..,p(n-1)) -> i64 { if cond { then } else { else } }
// byte-exact vs the Rust --emit-mic3 oracle. The body is n PARAM instrs then the
// single OP_IF instr (body_len = n + 1); ret_vid = the if's dst. Mirrors
// emit_mic3_tree_fn_module's framing (header/strtab/next_id/exports/FN_DEF/tail).
// Fails closed (returns the seed `s`) on any wall.
pub fn emit_mic3_if_fn_module(s: EmitState, buf: i64, offs: i64, n: i64, cond_expr: i64, then_expr: i64, else_expr: i64, src: i64, params_addr: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, n + 1);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // FN_DEF header: name_idx=0, param-pair list, ret Some %dst, reap None, body_len.
    // The ret_vid (dst) is only known after the OP_IF is emitted, so emit the body
    // into a SCRATCH EmitState first to learn dst + body bytes, then frame it.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_instr(es_new(), cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_instr(s12, cond_expr, then_expr, else_expr, src, params_addr, n, nodes, cursor, vidbuf, n, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j): lex+parse `src`, find the first fn_def whose body is
// a single `if cond { then } else { else }` expression, and emit its mic@3 module
// byte-exact vs the Rust --emit-mic3 oracle. `strbuf`/`offs` are the caller-supplied
// CONTIGUOUS string-table name buffer + offsets (name then p0..p(n-1)); `nodes`/
// `cursor`/`vidbuf` are heap scratch sized to the LARGEST single branch's node
// count; `okcell` is a 1-i64 cell (holds dst on success, -1 on a wall).
pub fn selftest_mic3_if_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, nodes: i64, cursor: i64, vidbuf: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    // The fn body block's single trailing statement must be the if-expression.
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    let then_expr: i64 = branch_single_expr(then_blk);
    let else_expr: i64 = branch_single_expr(else_blk);
    if then_expr < 0 {
        return es_new();
    }
    if else_expr < 0 {
        return es_new();
    }
    emit_mic3_if_fn_module(es_new(), strbuf, offs, n_params, cond_expr, then_expr, else_expr, src_addr, params_addr, nodes, cursor, vidbuf, okcell)
}

// ===========================================================================
// Phase 4j+ — IF with MULTI-STATEMENT branch blocks + NON-EMPTY merges
// ===========================================================================
//
// The 4j path above handles `if cond { expr } else { expr }` where each branch is a
// SINGLE value expression — no branch writes, so branch_bindings and merges are
// empty. This step extends a branch to a STATEMENT SEQUENCE `{ let n: ty = init; ..;
// trailing }` (the same grammar Phase 4i already lowers for fn bodies). A branch-local
// `let` is a WRITE of that name, which the Rust oracle (src/eval/lower.rs ~1399-1611)
// turns into a NON-EMPTY merge phi set. Decoded byte-for-byte from --emit-mic3:
//
//   * Each branch flattens its statement list (lets + trailing) into its OWN
//     post-order descriptor with its OWN let-env (reusing flatten_stmts/flatten_ast_le).
//     The branch's non-param vids resolve from its per-branch base; a `let` records the
//     name -> its init's resolved vid (the merge "value" for that branch).
//   * VID THREADING: params 0..n-1; cond non-param from n; then = synth ConstI64(0)
//     then then-tree; else = synth ConstI64(0) then else-tree. AFTER both branches,
//     for each merged name (then-writes then else-writes, deduped first-seen): if a
//     branch does NOT define the name, a placeholder ConstI64(fresh, 0) is appended to
//     THAT branch's body (its vid allocated from the running parent counter), in the
//     order then-placeholder, else-placeholder, then merge_id. dst is the final fresh.
//   * branch_bindings = (name_strtab_idx, merge_id) per merged name; merges =
//     (merge_id, then_val, else_val) per merged name. The strtab carries the let-names
//     (after name+params, in encounter order). Verified byte-exact vs --emit-mic3:
//     f(a,b){if a{let t=a*b; t+1}else{b}}=81B, both-let=75B, else-let=73B, two-name=88B.
//
// ISOLATED from the canary (exported only via selftest_mic3_if_let_fn); the AST-driven
// body emitter still rejects ast_if, so the fixed point is byte-identical (Bound by
// MIND-CONSTITUTION §I — additive, canary untouched).

// Flatten ONE branch block (a statement list) into a fresh per-branch descriptor with
// its own let-env, resolve its non-param vids from `base`, and return the trailing
// expression's resolved vid (or -1 on a wall). On success: `cursor` holds n_nodes,
// `vidbuf` is filled, and the let-env (`lenv`/`lcount`) holds each let-name's span +
// its RESOLVED vid (slot rewritten to vid). The caller reads writes from the let-env.
pub fn flatten_branch_block(blk: i64, buf: i64, params_addr: i64, n_params: i64, nodes: i64, cursor: i64, vidbuf: i64, lenv: i64, lcount: i64, base: i64) -> i64 {
    __mind_store_i64(cursor, 0);
    __mind_store_i64(lcount, 0);
    let stmts_addr: i64 = ast_child0(blk);
    let stmts_len: i64 = ast_aux(blk);
    if stmts_len < 1 {
        return 0 - 1;
    }
    let root_slot: i64 = flatten_stmts(stmts_addr, stmts_len, 0, buf, params_addr, n_params, nodes, cursor, lenv, lcount);
    if root_slot < 0 {
        return 0 - 1;
    }
    let n_nodes: i64 = __mind_load_i64(cursor);
    tree_resolve_vids_base(nodes, n_nodes, vidbuf, 0, base);
    // Rewrite each let-env entry's stored SLOT to its resolved VID so the merge pass
    // can read a branch's per-name value directly.
    lenv_slots_to_vids(lenv, __mind_load_i64(lcount), vidbuf, 0);
    __mind_load_i64(vidbuf + root_slot * 8)
}

// Rewrite let-env entry slots (offset +16) in place from descriptor slot -> resolved
// vid (vidbuf[slot]). Called once after tree_resolve_vids_base fills vidbuf.
pub fn lenv_slots_to_vids(lenv: i64, n: i64, vidbuf: i64, i: i64) -> i64 {
    if i >= n {
        return 0;
    }
    let slot: i64 = __mind_load_i64(lenv + i * 24 + 16);
    __mind_store_i64(lenv + i * 24 + 16, __mind_load_i64(vidbuf + slot * 8));
    lenv_slots_to_vids(lenv, n, vidbuf, i + 1)
}

// Look up a name span in a branch's let-env: return its resolved vid (entry +16) or -1.
pub fn lenv_lookup_vid(lenv: i64, n: i64, buf: i64, lo: i64, hi: i64, i: i64) -> i64 {
    if i >= n {
        return 0 - 1;
    }
    let elo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let ehi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return __mind_load_i64(lenv + i * 24 + 16);
    }
    lenv_lookup_vid(lenv, n, buf, lo, hi, i + 1)
}

// Find a name span's string-table index. The contiguous name buffer `strbuf`/`offs`
// holds [name, p0..p(n-1), let-names..]; entry j spans buf[offs[j]..offs[j+1]).
// Returns the matching index, or -1. (Used to fill branch_bindings' name_strtab_idx.)
pub fn strtab_index_of(strbuf: i64, offs: i64, count: i64, buf: i64, lo: i64, hi: i64, j: i64) -> i64 {
    if j >= count {
        return 0 - 1;
    }
    let slo: i64 = __mind_load_i64(offs + j * 8);
    let shi: i64 = __mind_load_i64(offs + (j + 1) * 8);
    if span_bytes_equal2(strbuf, slo, shi, buf, lo, hi) == 1 {
        return j;
    }
    strtab_index_of(strbuf, offs, count, buf, lo, hi, j + 1)
}

// Span-equality across TWO distinct buffers (span_bytes_equal compares within one buf).
pub fn span_bytes_equal2(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, bhi: i64) -> i64 {
    if ahi - alo != bhi - blo {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, 0)
}
pub fn span_bytes_equal2_loop(a: i64, alo: i64, ahi: i64, b: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        return 1;
    }
    if load_byte(a, alo + k) != load_byte(b, blo + k) {
        return 0;
    }
    span_bytes_equal2_loop(a, alo, ahi, b, blo, k + 1)
}

// Build the merged-name list as spans into `buf`: then-lenv entries first, then
// else-lenv entries not already present (first-seen dedup). `outspans` is a heap array
// of (lo,hi) i64 pairs; returns the merged count. Each branch's lenv holds name spans.
pub fn build_merged_names(t_lenv: i64, t_n: i64, e_lenv: i64, e_n: i64, buf: i64, outspans: i64) -> i64 {
    let c1: i64 = copy_lenv_spans(t_lenv, t_n, buf, outspans, 0, 0);
    merge_else_spans(e_lenv, e_n, buf, outspans, c1, 0)
}
pub fn copy_lenv_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return copy_lenv_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    copy_lenv_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn merge_else_spans(lenv: i64, n: i64, buf: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= n {
        return oc;
    }
    let lo: i64 = __mind_load_i64(lenv + i * 24 + 0);
    let hi: i64 = __mind_load_i64(lenv + i * 24 + 8);
    if span_in_list(buf, lo, hi, outspans, oc, 0) == 1 {
        return merge_else_spans(lenv, n, buf, outspans, oc, i + 1);
    }
    __mind_store_i64(outspans + oc * 16 + 0, lo);
    __mind_store_i64(outspans + oc * 16 + 8, hi);
    merge_else_spans(lenv, n, buf, outspans, oc + 1, i + 1)
}
pub fn span_in_list(buf: i64, lo: i64, hi: i64, outspans: i64, oc: i64, i: i64) -> i64 {
    if i >= oc {
        return 0;
    }
    let elo: i64 = __mind_load_i64(outspans + i * 16 + 0);
    let ehi: i64 = __mind_load_i64(outspans + i * 16 + 8);
    if span_bytes_equal(buf, lo, hi, elo, ehi) == 1 {
        return 1;
    }
    span_in_list(buf, lo, hi, outspans, oc, i + 1)
}

// Emit the OP_IF body instruction with NON-EMPTY merges. Threads cond -> then(synth
// +block) -> else(synth+block) -> [per-name then/else placeholders + merge_ids] -> dst,
// byte-exact vs the oracle. The two branch blocks carry their own let-envs (already
// resolved to vids). `mspans`/`mcount` are filled with the merged-name spans. Writes
// dst to `okcell` on success; -1 on a wall (caller fails closed). `extra` is a heap
// scratch of i64s: per merged name we store (then_extra_vid, else_extra_vid, merge_id)
// = 3 i64 at extra + k*24, with -1 where a branch already defines the name.
pub fn emit_mic3_if_block_instr(s: EmitState, cond_expr: i64, then_blk: i64, else_blk: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, params_addr: i64, n_params: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let base0: i64 = n_params;
    // --- cond (single value expr; reuse flatten_branch into the cond descriptor) ---
    let cond_id: i64 = flatten_branch(cond_expr, buf, params_addr, n_params, c_nodes, c_cur, c_vid, base0);
    if cond_id < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let cond_n: i64 = __mind_load_i64(c_cur);
    let cond_nonparam: i64 = count_nonparam_nodes(cond_expr, buf, params_addr, n_params);
    let after_cond: i64 = base0 + cond_nonparam;

    // --- then block: synth ConstI64(after_cond, 0), then the block tree ---
    let then_synth: i64 = after_cond;
    let then_root: i64 = flatten_branch_block(then_blk, buf, params_addr, n_params, t_nodes, t_cur, t_vid, t_lenv, t_lc, after_cond + 1);
    if then_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let then_n: i64 = __mind_load_i64(t_cur);
    let then_nonparam: i64 = nonparam_count_desc(t_nodes, then_n, 0);
    let after_then: i64 = after_cond + 1 + then_nonparam;

    // --- else block: synth ConstI64(after_then, 0), then the block tree ---
    let else_synth: i64 = after_then;
    let else_root: i64 = flatten_branch_block(else_blk, buf, params_addr, n_params, e_nodes, e_cur, e_vid, e_lenv, e_lc, after_then + 1);
    if else_root < 0 {
        __mind_store_i64(okcell, 0 - 1);
        return s;
    }
    let else_n: i64 = __mind_load_i64(e_cur);
    let else_nonparam: i64 = nonparam_count_desc(e_nodes, else_n, 0);
    let after_else: i64 = after_then + 1 + else_nonparam;

    // --- merge pass: merged names, per-name placeholders + merge_ids from after_else ---
    let t_lcount: i64 = __mind_load_i64(t_lc);
    let e_lcount: i64 = __mind_load_i64(e_lc);
    let mn: i64 = build_merged_names(t_lenv, t_lcount, e_lenv, e_lcount, buf, mspans);
    __mind_store_i64(mcount, mn);
    let final_ctr: i64 = assign_merge_vids(mspans, mn, buf, t_lenv, t_lcount, e_lenv, e_lcount, extra, after_else, 0);
    let dst: i64 = final_ctr;

    // --- emit OP_IF ---
    let s1: EmitState = es_push(s, 28);
    let s2: EmitState = emit_uleb128(s1, cond_id);
    let s3: EmitState = emit_uleb128(s2, cond_nonparam);
    let s4: EmitState = emit_mic3_tree_body(s3, c_nodes, cond_n, c_vid, 0);
    // then: synth + tree + then-edge placeholders.
    let then_extra_count: i64 = count_then_extras(extra, mn, 0);
    let s5: EmitState = emit_uleb128(s4, then_nonparam + 1 + then_extra_count);
    let s6: EmitState = emit_mic3_const_i64(s5, then_synth, 0);
    let s7: EmitState = emit_mic3_tree_body(s6, t_nodes, then_n, t_vid, 0);
    let s8: EmitState = emit_extra_consts(s7, extra, mn, 0, 0);
    let s9: EmitState = emit_uleb128(s8, then_root);
    // else: synth + tree + else-edge placeholders.
    let else_extra_count: i64 = count_else_extras(extra, mn, 0);
    let s10: EmitState = emit_uleb128(s9, else_nonparam + 1 + else_extra_count);
    let s11: EmitState = emit_mic3_const_i64(s10, else_synth, 0);
    let s12: EmitState = emit_mic3_tree_body(s11, e_nodes, else_n, e_vid, 0);
    let s13: EmitState = emit_extra_consts(s12, extra, mn, 1, 0);
    let s14: EmitState = emit_uleb128(s13, else_root);
    // dst, branch_bindings, merges.
    let s15: EmitState = emit_uleb128(s14, dst);
    let s16: EmitState = emit_uleb128(s15, mn);
    let s17: EmitState = emit_branch_bindings(s16, mspans, mn, buf, strbuf, offs, strcount, extra, 0);
    let s18: EmitState = emit_uleb128(s17, mn);
    let s19: EmitState = emit_merges(s18, extra, mn, 0);
    __mind_store_i64(okcell, dst);
    s19
}

// Count non-param nodes in an already-flattened descriptor (kind != 0).
pub fn nonparam_count_desc(nodes: i64, n_nodes: i64, i: i64) -> i64 {
    if i >= n_nodes {
        return 0;
    }
    let k: i64 = __mind_load_i64(nodes + i * 32);
    if k == 0 {
        return nonparam_count_desc(nodes, n_nodes, i + 1);
    }
    1 + nonparam_count_desc(nodes, n_nodes, i + 1)
}

// For each merged name allocate (then_extra, else_extra, merge_id) from the running
// counter `ctr`. A branch that DEFINES the name contributes -1 for its extra slot (no
// placeholder); otherwise a fresh vid is allocated (the per-branch placeholder). Order
// per name: then_extra, else_extra, merge_id. Returns the next free vid (= dst).
pub fn assign_merge_vids(mspans: i64, mn: i64, buf: i64, t_lenv: i64, t_lc: i64, e_lenv: i64, e_lc: i64, extra: i64, ctr: i64, k: i64) -> i64 {
    if k >= mn {
        return ctr;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let in_then: i64 = lenv_lookup_vid(t_lenv, t_lc, buf, lo, hi, 0);
    let in_else: i64 = lenv_lookup_vid(e_lenv, e_lc, buf, lo, hi, 0);
    // then_extra (placeholder vid, or -1 if the then-branch defines the name)
    let c1: i64 = ctr;
    if in_then >= 0 {
        __mind_store_i64(extra + k * 40 + 0, 0 - 1);
    }
    if in_then < 0 {
        __mind_store_i64(extra + k * 40 + 0, c1);
    }
    let c2: i64 = next_ctr(c1, in_then);
    // else_extra
    if in_else >= 0 {
        __mind_store_i64(extra + k * 40 + 8, 0 - 1);
    }
    if in_else < 0 {
        __mind_store_i64(extra + k * 40 + 8, c2);
    }
    let c3: i64 = next_ctr(c2, in_else);
    // merge_id (always fresh)
    __mind_store_i64(extra + k * 40 + 16, c3);
    // +24/+32 = the DEFINED-branch let-vid (used by emit_merges when extra slot is -1).
    __mind_store_i64(extra + k * 40 + 24, in_then);
    __mind_store_i64(extra + k * 40 + 32, in_else);
    assign_merge_vids(mspans, mn, buf, t_lenv, t_lc, e_lenv, e_lc, extra, c3 + 1, k + 1)
}
// ctr advances by 1 only when the branch did NOT define the name (in_branch < 0).
pub fn next_ctr(ctr: i64, in_branch: i64) -> i64 {
    if in_branch < 0 {
        return ctr + 1;
    }
    ctr
}

// Count then-edge / else-edge placeholders (extra slots != -1).
pub fn count_then_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 0);
    if v < 0 {
        return count_then_extras(extra, mn, k + 1);
    }
    1 + count_then_extras(extra, mn, k + 1)
}
pub fn count_else_extras(extra: i64, mn: i64, k: i64) -> i64 {
    if k >= mn {
        return 0;
    }
    let v: i64 = __mind_load_i64(extra + k * 40 + 8);
    if v < 0 {
        return count_else_extras(extra, mn, k + 1);
    }
    1 + count_else_extras(extra, mn, k + 1)
}

// Emit the placeholder ConstI64(vid, 0) for each merged name on the given edge
// (edge 0 = then-extra at +0, edge 1 = else-extra at +8), in merged-name order.
pub fn emit_extra_consts(s: EmitState, extra: i64, mn: i64, edge: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let off: i64 = edge * 8;
    let v: i64 = __mind_load_i64(extra + k * 40 + off);
    if v < 0 {
        return emit_extra_consts(s, extra, mn, edge, k + 1);
    }
    let s1: EmitState = emit_mic3_const_i64(s, v, 0);
    emit_extra_consts(s1, extra, mn, edge, k + 1)
}

// branch_bindings: per merged name (string_idx, merge_id). The name span is looked up
// in the contiguous strtab buffer to find its index.
pub fn emit_branch_bindings(s: EmitState, mspans: i64, mn: i64, buf: i64, strbuf: i64, offs: i64, strcount: i64, extra: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let lo: i64 = __mind_load_i64(mspans + k * 16 + 0);
    let hi: i64 = __mind_load_i64(mspans + k * 16 + 8);
    let sidx: i64 = strtab_index_of(strbuf, offs, strcount, buf, lo, hi, 0);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    let s1: EmitState = emit_uleb128(s, sidx);
    let s2: EmitState = emit_uleb128(s1, mid);
    emit_branch_bindings(s2, mspans, mn, buf, strbuf, offs, strcount, extra, k + 1)
}

// merges: per merged name (merge_id, then_val, else_val). then_val = the then-branch's
// value (its let-vid if defined, else the then-placeholder); symmetric for else_val.
pub fn emit_merges(s: EmitState, extra: i64, mn: i64, k: i64) -> EmitState {
    if k >= mn {
        return s;
    }
    let then_extra: i64 = __mind_load_i64(extra + k * 40 + 0);
    let else_extra: i64 = __mind_load_i64(extra + k * 40 + 8);
    let mid: i64 = __mind_load_i64(extra + k * 40 + 16);
    // then_val: placeholder vid if extra set, else the resolved let-vid (stored at +24).
    let then_val: i64 = merge_val(then_extra, extra, k, 24);
    let else_val: i64 = merge_val(else_extra, extra, k, 32);
    let s1: EmitState = emit_uleb128(s, mid);
    let s2: EmitState = emit_uleb128(s1, then_val);
    let s3: EmitState = emit_uleb128(s2, else_val);
    emit_merges(s3, extra, mn, k + 1)
}
pub fn merge_val(extra_vid: i64, extra: i64, k: i64, off: i64) -> i64 {
    if extra_vid >= 0 {
        return extra_vid;
    }
    __mind_load_i64(extra + k * 40 + off)
}

// Assemble the full mic@3 module for
//   pub fn <name>(p0,..) -> i64 { if cond { <block> } else { <block> } }
// with non-empty merges, byte-exact vs --emit-mic3. `strcount` = n+1+n_letnames (the
// full string-table count: name, params, then branch-local let-names in encounter
// order). The body is n PARAM instrs then ONE OP_IF (body_len = n + 1).
pub fn emit_mic3_if_block_fn_module(s: EmitState, buf: i64, offs: i64, strcount: i64, n: i64, cond_expr: i64, then_blk: i64, else_blk: i64, src: i64, params_addr: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let s1: EmitState = emit_mic3_header(s);
    let s2: EmitState = emit_mic3_strtab(s1, buf, offs, strcount);
    let s3: EmitState = emit_uleb128(s2, 1);
    let s4: EmitState = emit_uleb128(s3, 0);
    let s5: EmitState = emit_uleb128(s4, 3);
    // Scratch pass to learn dst (the FN_DEF ret_vid) before framing.
    __mind_store_i64(okcell, 0 - 1);
    let body: EmitState = emit_mic3_if_block_instr(es_new(), cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let dst: i64 = __mind_load_i64(okcell);
    if dst < 0 {
        return s;
    }
    let s6: EmitState = es_push(s5, 21);
    let s7: EmitState = emit_uleb128(s6, 0);
    let s8: EmitState = emit_mic3_chain_param_pairs(s7, n);
    let s9: EmitState = emit_mic3_opt_vid(s8, 1, dst);
    let s10: EmitState = es_push(s9, 0);
    let s11: EmitState = emit_uleb128(s10, n + 1);
    let s12: EmitState = emit_mic3_chain_params(s11, n, 0);
    // Re-emit the OP_IF directly into the framed stream (deterministic — same input).
    let s13: EmitState = emit_mic3_if_block_instr(s12, cond_expr, then_blk, else_blk, src, buf, offs, strcount, params_addr, n, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell);
    let s14: EmitState = emit_mic3_const_i64(s13, 0, 0);
    let s15: EmitState = emit_mic3_output(s14, 0);
    emit_mic3_empty_registries(s15)
}

// Self-test entry (Phase 4j+): lex+parse `src`, find the first fn whose body is a
// single `if cond { block } else { block }` where a branch may be a multi-statement
// (let-bound) block, and emit its mic@3 module byte-exact vs --emit-mic3. `strbuf`/
// `offs`/`strcount` are the caller-supplied CONTIGUOUS string table (name, params,
// branch let-names in encounter order). All `*_nodes`/`*_cur`/`*_vid`/`*_lenv`/`*_lc`
// are per-branch heap scratch; `mspans` (merged-name spans), `mcount`, `extra`
// (per-name vid triples + values), `okcell` are merge scratch.
pub fn selftest_mic3_if_block_fn(src_addr: i64, src_len: i64, strbuf: i64, offs: i64, strcount: i64, t_nodes: i64, t_cur: i64, t_vid: i64, t_lenv: i64, t_lc: i64, e_nodes: i64, e_cur: i64, e_vid: i64, e_lenv: i64, e_lc: i64, c_nodes: i64, c_cur: i64, c_vid: i64, mspans: i64, mcount: i64, extra: i64, okcell: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    let params_addr: i64 = ast_child1(fn_node);
    let n_params: i64 = ast_aux(fn_node) / 2;
    let body: i64 = ast_child2(fn_node);
    let if_node: i64 = branch_single_expr(body);
    if if_node < 0 {
        return es_new();
    }
    if ast_kind(if_node) != ast_if() {
        return es_new();
    }
    let cond_expr: i64 = ast_child0(if_node);
    let then_blk: i64 = ast_child1(if_node);
    let else_blk: i64 = ast_child2(if_node);
    if else_blk == 0 {
        return es_new();
    }
    // Record the merge name-values into extra +24/+32 from the resolved let-envs: we
    // need a branch's per-name value (its let-vid). emit_mic3_if_block_instr fills
    // extra +0/+8/+16; the +24/+32 (then_val/else_val for defined names) are filled
    // by the binding pass via the let-envs. To keep merge_val simple, stash them here
    // after the scratch emit re-runs the merge — done inside the module emitter.
    emit_mic3_if_block_fn_module(es_new(), strbuf, offs, strcount, n_params, cond_expr, then_blk, else_blk, src_addr, params_addr, t_nodes, t_cur, t_vid, t_lenv, t_lc, e_nodes, e_cur, e_vid, e_lenv, e_lc, c_nodes, c_cur, c_vid, mspans, mcount, extra, okcell)
}

// ===== Fixed-literal writers =====

pub fn emit_lit_module_open(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 109);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 100);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 108);
    let s6: EmitState = es_push(s5, 101);
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, ch_lbrace());
    es_push(s8, ch_newline())
}

pub fn emit_lit_fn_comment_head(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_slash());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, 102);
    let s7: EmitState = es_push(s6, 110);
    es_push(s7, ch_space())
}

pub fn emit_lit_const_i64_head(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_percent());
    let s4: EmitState = emit_i64(s3, id);
    let s5: EmitState = es_push(s4, ch_space());
    let s6: EmitState = es_push(s5, ch_eq_sign());
    let s7: EmitState = es_push(s6, ch_space());
    let s8: EmitState = es_push(s7, 99);
    let s9: EmitState = es_push(s8, 111);
    let s10: EmitState = es_push(s9, 110);
    let s11: EmitState = es_push(s10, 115);
    let s12: EmitState = es_push(s11, 116);
    let s13: EmitState = es_push(s12, ch_dot());
    let s14: EmitState = es_push(s13, 105);
    let s15: EmitState = es_push(s14, 54);
    let s16: EmitState = es_push(s15, 52);
    es_push(s16, ch_space())
}

pub fn emit_lit_output(s: EmitState, id: i64) -> EmitState {
    let s1: EmitState = es_push(s, ch_space());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, 111);
    let s4: EmitState = es_push(s3, 117);
    let s5: EmitState = es_push(s4, 116);
    let s6: EmitState = es_push(s5, 112);
    let s7: EmitState = es_push(s6, 117);
    let s8: EmitState = es_push(s7, 116);
    let s9: EmitState = es_push(s8, ch_space());
    let s10: EmitState = es_push(s9, ch_percent());
    let s11: EmitState = emit_i64(s10, id);
    es_push(s11, ch_newline())
}

// If-line literal fragments — the mic@1 text spelling of the flat If op
// `%dst = if cond=%c then=%t else=%e` (matches src/ir/print.rs).
pub fn emit_if_kw(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 105);
    es_push(s1, 102)
}
pub fn emit_cond_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 99);
    let s2: EmitState = es_push(s1, 111);
    let s3: EmitState = es_push(s2, 110);
    let s4: EmitState = es_push(s3, 100);
    es_push(s4, ch_eq_sign())
}
pub fn emit_then_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 116);
    let s2: EmitState = es_push(s1, 104);
    let s3: EmitState = es_push(s2, 101);
    let s4: EmitState = es_push(s3, 110);
    es_push(s4, ch_eq_sign())
}
pub fn emit_else_eq(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, 101);
    let s2: EmitState = es_push(s1, 108);
    let s3: EmitState = es_push(s2, 115);
    let s4: EmitState = es_push(s3, 101);
    es_push(s4, ch_eq_sign())
}

pub fn emit_lit_module_close(s: EmitState) -> EmitState {
    let s1: EmitState = es_push(s, ch_rbrace());
    let s2: EmitState = es_push(s1, ch_space());
    let s3: EmitState = es_push(s2, ch_space());
    let s4: EmitState = es_push(s3, ch_slash());
    let s5: EmitState = es_push(s4, ch_slash());
    let s6: EmitState = es_push(s5, ch_space());
    let s7: EmitState = es_push(s6, 110);
    let s8: EmitState = es_push(s7, 101);
    let s9: EmitState = es_push(s8, 120);
    let s10: EmitState = es_push(s9, 116);
    let s11: EmitState = es_push(s10, 95);
    let s12: EmitState = es_push(s11, 105);
    let s13: EmitState = es_push(s12, 100);
    let s14: EmitState = es_push(s13, ch_space());
    let s15: EmitState = es_push(s14, ch_eq_sign());
    let s16: EmitState = es_push(s15, ch_space());
    let s17: EmitState = emit_i64(s16, s.next_id);
    es_push(s17, ch_newline())
}

pub fn emit_op_mnemonic(s: EmitState, op: i64) -> EmitState {
    if op == op_add() {
        let s1: EmitState = es_push(s, 97);
        let s2: EmitState = es_push(s1, 100);
        return es_push(s2, 100);
    }
    if op == op_sub() {
        let s1: EmitState = es_push(s, 115);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 98);
    }
    if op == op_mul() {
        let s1: EmitState = es_push(s, 109);
        let s2: EmitState = es_push(s1, 117);
        return es_push(s2, 108);
    }
    if op == op_div() {
        let s1: EmitState = es_push(s, 100);
        let s2: EmitState = es_push(s1, 105);
        return es_push(s2, 118);
    }
    if op == op_lt() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 116);
    }
    if op == op_gt() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 116);
    }
    if op == op_eq() {
        let s1: EmitState = es_push(s, 101);
        return es_push(s1, 113);
    }
    if op == op_le() {
        let s1: EmitState = es_push(s, 108);
        return es_push(s1, 101);
    }
    if op == op_ge() {
        let s1: EmitState = es_push(s, 103);
        return es_push(s1, 101);
    }
    if op == op_ne() {
        let s1: EmitState = es_push(s, 110);
        return es_push(s1, 101);
    }
    let s1: EmitState = es_push(s, 63);
    es_push(s1, 63)
}

// ===== Integer-literal value parsing =====

pub fn parse_int_span(buf: i64, lo: i64, hi: i64, acc: i64) -> i64 {
    if lo >= hi {
        return acc;
    }
    let b: i64 = load_byte(buf, lo);
    parse_int_span(buf, lo + 1, hi, acc * 10 + (b - 48))
}

// ===== Expression lowering =====

pub fn emit_expr(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);

    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_ident() {
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    if k == ast_binop() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr(s1, buf, ast_child1(node));
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }

    if k == ast_paren() {
        return emit_expr(s, buf, ast_child0(node));
    }

    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args(s, buf, args_addr, args_len, 0);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }

    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

pub fn emit_call_args(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr(s, buf, arg_node);
    emit_call_args(s1, buf, args_addr, args_len, i + 1)
}

// ===== Statement lowering =====

pub fn emit_stmt(s: EmitState, buf: i64, node: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        return emit_expr(s, buf, ast_child2(node));
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr(s, buf, ast_child0(node));
        let s2: EmitState = emit_lit_output(s1, s1.last_id);
        return s2;
    }
    emit_expr(s, buf, node)
}

pub fn emit_block_stmts(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt(s, buf, stmt_node);
    emit_block_stmts(s1, buf, stmts_addr, stmts_len, i + 1)
}

// ===== Function definition lowering =====

pub fn emit_fn_def(s: EmitState, buf: i64, node: i64) -> EmitState {
    let name_node: i64 = ast_child0(node);
    let name_lo: i64 = ast_span_lo(name_node);
    let name_hi: i64 = ast_span_hi(name_node);
    let s1: EmitState = emit_lit_fn_comment_head(s);
    let s2: EmitState = emit_byte_range(s1, buf, name_lo, name_hi);
    let s3: EmitState = es_push(s2, ch_newline());

    let id: i64 = s3.next_id;
    let s4: EmitState = emit_lit_const_i64_head(s3, id);
    let s5: EmitState = es_push(s4, 48);
    let s6: EmitState = es_push(s5, ch_newline());
    let s7: EmitState = EmitState { buf: s6.buf, next_id: id + 1, last_id: id, lets: s6.lets };
    emit_lit_output(s7, id)
}

// ===== Real-body lowering (param-resolving) — additive, isolated from the
//       canary path (mindc_compile->lower_program->emit_fn_def stays stubbed).
//       Resolves a parameter NAME to its SSA id (param i == %i), so function
//       bodies emit real ops (`%2 = add %0, %1` / `output %2`) instead of a
//       const.i64-0 placeholder. =====

// 1 if buf[alo..ahi] equals buf[blo..bhi] byte-for-byte, else 0.
pub fn span_bytes_equal(buf: i64, alo: i64, ahi: i64, blo: i64, bhi: i64) -> i64 {
    if (ahi - alo) == (bhi - blo) {
        span_bytes_equal_loop(buf, alo, ahi, blo, 0)
    } else {
        0
    }
}
pub fn span_bytes_equal_loop(buf: i64, alo: i64, ahi: i64, blo: i64, k: i64) -> i64 {
    if alo + k >= ahi {
        1
    } else {
        if load_byte(buf, alo + k) == load_byte(buf, blo + k) {
            span_bytes_equal_loop(buf, alo, ahi, blo, k + 1)
        } else {
            0
        }
    }
}

// Return the SSA id (== param index) for the identifier buf[lo..hi] if it names
// a parameter of `params` (a block of ast_param nodes), else -1.
pub fn resolve_param(params_addr: i64, n_params: i64, buf: i64, lo: i64, hi: i64) -> i64 {
    resolve_param_loop(buf, lo, hi, params_addr, n_params, 0)
}
pub fn resolve_param_loop(buf: i64, lo: i64, hi: i64, addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0 - 1
    } else {
        let pnode: i64 = __mind_load_i64(addr + i * 8);
        let name_leaf: i64 = ast_child0(pnode);
        if span_bytes_equal(buf, lo, hi, ast_span_lo(name_leaf), ast_span_hi(name_leaf)) == 1 {
            i
        } else {
            resolve_param_loop(buf, lo, hi, addr, n, i + 1)
        }
    }
}

// Expression lowering with a parameter environment. Identical to emit_expr
// except the ident branch resolves a param to its %SSA id (no instruction).
// Lower an if's else-branch into a scratch EmitState seeded at `else_seed`
// (the seed const id, consumed by Rust's else_ir.fresh()).  When there is no
// else clause (`else_blk == 0`) the seed const IS the else result, so we just
// return a scratch state whose last_id is the seed.  Otherwise we lower the
// else-block statements and return their trailing-value state.  The scratch
// buffer is discarded by the caller (the sub-stream ops are not printed in
// mic@1 text — see src/ir/print.rs Instr::If).
pub fn emit_if_else_branch(else_blk: i64, buf: i64, else_seed: i64, params_addr: i64, n_params: i64, lets: Map) -> EmitState {
    let sc: EmitState = EmitState { buf: string_new(), next_id: else_seed + 1, last_id: else_seed, lets: lets };
    if else_blk == 0 {
        return sc;
    }
    emit_block_stmts_env(sc, buf, ast_child0(else_blk), ast_aux(else_blk), 0, params_addr, n_params)
}

pub fn emit_expr_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_int_lit() {
        let val: i64 = parse_int_span(buf, ast_span_lo(node), ast_span_hi(node), 0);
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = emit_i64(s1, val);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_ident() {
        let idx: i64 = resolve_param(params_addr, n_params, buf, ast_span_lo(node), ast_span_hi(node));
        if idx >= 0 {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: idx, lets: s.lets };
        }
        let lid: i64 = env_lookup(s.lets, buf, ast_span_lo(node), ast_span_hi(node));
        if lid != ty_unknown() {
            return EmitState { buf: s.buf, next_id: s.next_id, last_id: lid - 1, lets: s.lets };
        }
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_binop() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let lhs_id: i64 = s1.last_id;
        let s2: EmitState = emit_expr_env(s1, buf, ast_child1(node), params_addr, n_params);
        let rhs_id: i64 = s2.last_id;
        let id: i64 = s2.next_id;
        let s3: EmitState = es_push(s2, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, ast_aux(node));
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, lhs_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, rhs_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_paren() {
        return emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
    }
    if k == ast_neg() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_sub());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, c0);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, operand_id);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_not() {
        let so: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        let operand_id: i64 = so.last_id;
        let c0: i64 = so.next_id;
        let sc1: EmitState = emit_lit_const_i64_head(so, c0);
        let sc2: EmitState = es_push(sc1, 48);
        let sc3: EmitState = es_push(sc2, ch_newline());
        let id: i64 = c0 + 1;
        let s3: EmitState = es_push(sc3, ch_space());
        let s4: EmitState = es_push(s3, ch_space());
        let s5: EmitState = es_push(s4, ch_percent());
        let s6: EmitState = emit_i64(s5, id);
        let s7: EmitState = es_push(s6, ch_space());
        let s8: EmitState = es_push(s7, ch_eq_sign());
        let s9: EmitState = es_push(s8, ch_space());
        let s10: EmitState = emit_op_mnemonic(s9, op_eq());
        let s11: EmitState = es_push(s10, ch_space());
        let s12: EmitState = es_push(s11, ch_percent());
        let s13: EmitState = emit_i64(s12, operand_id);
        let s14: EmitState = es_push(s13, ch_comma());
        let s15: EmitState = es_push(s14, ch_space());
        let s16: EmitState = es_push(s15, ch_percent());
        let s17: EmitState = emit_i64(s16, c0);
        let s18: EmitState = es_push(s17, ch_newline());
        return EmitState { buf: s18.buf, next_id: id + 1, last_id: id, lets: s18.lets };
    }
    if k == ast_if() {
        // mic@1 If lowering — matches the Rust front-end (src/eval/lower.rs
        // ast::Node::If) and its print.rs text form: the condition, then-branch
        // and else-branch each lower into a hidden sub-stream, so the only
        // VISIBLE instruction in mic@1 text is the flat
        //   %dst = if cond=%c then=%t else=%e
        // line.  The sub-streams still consume SSA ids (each branch begins with
        // a `const.i64 0` seed via ir.fresh()), so we thread next_id through
        // scratch EmitStates to keep the dst id byte-identical to Rust, but we
        // discard their buffers (the sub-stream ops are not printed).
        let cond_node: i64 = ast_child0(node);
        let then_blk: i64 = ast_child1(node);
        let else_blk: i64 = ast_child2(node);

        // 1. Condition: lower into a scratch buffer seeded at the current id.
        let sc_cond: EmitState = EmitState { buf: string_new(), next_id: s.next_id, last_id: 0 - 1, lets: s.lets };
        let r_cond: EmitState = emit_expr_env(sc_cond, buf, cond_node, params_addr, n_params);
        let cond_id: i64 = r_cond.last_id;

        // 2. Then-branch: ir.fresh() seed const (consumed, not printed), then
        //    lower the block; then_result is the trailing value.
        let then_seed: i64 = r_cond.next_id;
        let sc_then: EmitState = EmitState { buf: string_new(), next_id: then_seed + 1, last_id: then_seed, lets: s.lets };
        let r_then: EmitState = emit_block_stmts_env(sc_then, buf, ast_child0(then_blk), ast_aux(then_blk), 0, params_addr, n_params);
        let then_id: i64 = r_then.last_id;

        // 3. Else-branch: ir.fresh() seed const, then lower the block (or, when
        //    there is no else clause, the seed const IS the else result).
        let else_seed: i64 = r_then.next_id;
        let r_else: EmitState = emit_if_else_branch(else_blk, buf, else_seed, params_addr, n_params, s.lets);
        let else_id: i64 = r_else.last_id;

        // 4. dst = ir.fresh().
        let dst: i64 = r_else.next_id;

        // 5. Emit the single visible flat If line into the real buffer.
        let e1: EmitState = es_push(s, ch_space());
        let e2: EmitState = es_push(e1, ch_space());
        let e3: EmitState = es_push(e2, ch_percent());
        let e4: EmitState = emit_i64(e3, dst);
        let e5: EmitState = es_push(e4, ch_space());
        let e6: EmitState = es_push(e5, ch_eq_sign());
        let e7: EmitState = es_push(e6, ch_space());
        let e8: EmitState = emit_if_kw(e7);
        let e9: EmitState = es_push(e8, ch_space());
        let e10: EmitState = emit_cond_eq(e9);
        let e11: EmitState = es_push(e10, ch_percent());
        let e12: EmitState = emit_i64(e11, cond_id);
        let e13: EmitState = es_push(e12, ch_space());
        let e14: EmitState = emit_then_eq(e13);
        let e15: EmitState = es_push(e14, ch_percent());
        let e16: EmitState = emit_i64(e15, then_id);
        let e17: EmitState = es_push(e16, ch_space());
        let e18: EmitState = emit_else_eq(e17);
        let e19: EmitState = es_push(e18, ch_percent());
        let e20: EmitState = emit_i64(e19, else_id);
        let e21: EmitState = es_push(e20, ch_newline());
        return EmitState { buf: e21.buf, next_id: dst + 1, last_id: dst, lets: e21.lets };
    }
    if k == ast_field() {
        // mic@1 FieldAccess lowering — matches the Rust front-end
        // (src/eval/lower.rs ast::Node::FieldAccess) `None` arm: when the
        // receiver's struct type is unresolvable, the whole access lowers to a
        // single `const.i64 0` (the receiver is NOT re-lowered on that arm).
        // The bootstrap parser tracks no struct field-name order, so every
        // field access lands on the `None` arm and lowers to exactly one const.
        let id: i64 = s.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    if k == ast_call() {
        let args_addr: i64 = ast_child1(node);
        let args_len: i64 = ast_aux(node);
        let s_args: EmitState = emit_call_args_env(s, buf, args_addr, args_len, 0, params_addr, n_params);
        let id: i64 = s_args.next_id;
        let s1: EmitState = emit_lit_const_i64_head(s_args, id);
        let s2: EmitState = es_push(s1, 48);
        let s3: EmitState = es_push(s2, ch_newline());
        return EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    }
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets }
}

// Env-aware call-argument lowering: like emit_call_args but threads the
// parameter environment so an argument that names a parameter resolves to
// its %SSA id (and nested binops/consts lower to real ops). The call result
// itself stays a const.i64-0 placeholder (the canary/oracle does not surface
// a real call op in mic@1 text — only the arguments gain real lowering).
pub fn emit_call_args_env(s: EmitState, buf: i64, args_addr: i64, args_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= args_len {
        return s;
    }
    let arg_node: i64 = __mind_load_i64(args_addr + i * 8);
    let s1: EmitState = emit_expr_env(s, buf, arg_node, params_addr, n_params);
    emit_call_args_env(s1, buf, args_addr, args_len, i + 1, params_addr, n_params)
}

pub fn emit_stmt_env(s: EmitState, buf: i64, node: i64, params_addr: i64, n_params: i64) -> EmitState {
    let k: i64 = ast_kind(node);
    if k == ast_let() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child2(node), params_addr, n_params);
        let name_leaf: i64 = ast_child0(node);
        let new_lets: Map = env_bind(s1.lets, buf, ast_span_lo(name_leaf), ast_span_hi(name_leaf), s1.last_id + 1);
        return EmitState { buf: s1.buf, next_id: s1.next_id, last_id: s1.last_id, lets: new_lets };
    }
    if k == ast_return() {
        let s1: EmitState = emit_expr_env(s, buf, ast_child0(node), params_addr, n_params);
        return emit_lit_output(s1, s1.last_id);
    }
    emit_expr_env(s, buf, node, params_addr, n_params)
}

pub fn emit_block_stmts_env(s: EmitState, buf: i64, stmts_addr: i64, stmts_len: i64, i: i64, params_addr: i64, n_params: i64) -> EmitState {
    if i >= stmts_len {
        return s;
    }
    let stmt_node: i64 = __mind_load_i64(stmts_addr + i * 8);
    let s1: EmitState = emit_stmt_env(s, buf, stmt_node, params_addr, n_params);
    emit_block_stmts_env(s1, buf, stmts_addr, stmts_len, i + 1, params_addr, n_params)
}

// Real-body function lowering: params occupy SSA ids 0..n-1; the body emits
// real ops starting at %n, then the trailing value is `output`-ed.
pub fn emit_fn_def_with_body(s: EmitState, buf: i64, node: i64) -> EmitState {
    let params_addr: i64 = ast_child1(node);
    let n_params: i64 = ast_aux(node) / 2;
    let body: i64 = ast_child2(node);
    let s0: EmitState = EmitState { buf: s.buf, next_id: n_params, last_id: 0, lets: s.lets };
    let s1: EmitState = emit_block_stmts_env(s0, buf, ast_child0(body), ast_aux(body), 0, params_addr, n_params);
    emit_lit_output(s1, s1.last_id)
}

// Self-test entry: lex+parse `src`, find the first fn_def, lower its body with
// param resolution, return the EmitState (Python harness decodes EmitState.buf).
pub fn selftest_emit_fn_body(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let fn_node: i64 = find_first_fn(ast_child0(ast_root), ast_aux(ast_root), 0);
    emit_fn_def_with_body(es_new(), src_addr, fn_node)
}
pub fn find_first_fn(addr: i64, n: i64, i: i64) -> i64 {
    if i >= n {
        0
    } else {
        let item: i64 = __mind_load_i64(addr + i * 8);
        if ast_kind(item) == ast_fn_def() {
            item
        } else {
            find_first_fn(addr, n, i + 1)
        }
    }
}

// ===== Program-level lowering =====

// Emit a single const.i64 0 / output stub for items that lower to a placeholder
// (UseDecl and StructDef — matches mindc-Rust lower_to_ir behaviour).
pub fn emit_item_stub(s: EmitState) -> EmitState {
    let id: i64 = s.next_id;
    let s1: EmitState = emit_lit_const_i64_head(s, id);
    let s2: EmitState = es_push(s1, 48);
    let s3: EmitState = es_push(s2, ch_newline());
    let s4: EmitState = EmitState { buf: s3.buf, next_id: id + 1, last_id: id, lets: s3.lets };
    emit_lit_output(s4, id)
}

pub fn emit_program_items(s: EmitState, buf: i64, items_addr: i64, items_len: i64, i: i64) -> EmitState {
    if i >= items_len {
        return s;
    }
    let item: i64 = __mind_load_i64(items_addr + i * 8);
    let k: i64 = ast_kind(item);
    let s1: EmitState = if k == ast_fn_def() {
        emit_fn_def(s, buf, item)
    } else {
        if k == ast_use() {
            emit_item_stub(s)
        } else {
            if k == ast_struct_def() {
                emit_item_stub(s)
            } else {
                s
            }
        }
    };
    emit_program_items(s1, buf, items_addr, items_len, i + 1)
}

// ===== Public entry: lower_program =====

pub fn lower_program(ast_addr: i64, buf: i64) -> EmitState {
    let items_addr: i64 = ast_child0(ast_addr);
    let items_len: i64 = ast_aux(ast_addr);
    let s0: EmitState = es_new();
    let s1: EmitState = emit_lit_module_open(s0);
    let s2: EmitState = emit_program_items(s1, buf, items_addr, items_len, 0);
    emit_lit_module_close(s2)
}

pub fn flush_to_stdout(s: EmitState) -> i64 {
    print_bytes(string_addr(s.buf), string_len(s.buf))
}

// ===========================================================================
// SECTION 5 — COMBINED DRIVER (Phase 6.5 Stage 5 APEX)
// ===========================================================================

// mindc_compile(src_addr, src_len) -> i64
//
// Runs the full compilation pipeline:
//   1. lex(src_addr, src_len)         -> Vec (token stream)
//   2. parse(tokens, src_addr)         -> i64 (AST root / ast_program)
//   3. typecheck(ast_root, src_addr)   -> String (type-check report, unused)
//   4. lower_program(ast_root, src_addr) -> EmitState (MLIR text accumulator)
//
// Returns the i64 heap-record address of the EmitState.  The caller
// reads EmitState fields at the returned address:
//   offset  0 : buf     (String handle — addr/len/cap)
//   offset  8 : next_id (SSA value counter)
//   offset 16 : last_id (most-recently allocated SSA id)
//
// The Python harness (bootstrap_smoke.py) reads the EmitState via
// ctypes and compares the decoded String bytes to EXPECTED.md.

// mindc_compile returns EmitState (heap-record address in Option-C ABI).
// The Python harness calls it with c_int64 restype and reads the
// EmitState fields at the returned address:
//   offset  0 : buf     (String handle)
//   offset  8 : next_id (SSA counter)
//   offset 16 : last_id (last allocated SSA id)
pub fn mindc_compile(src_addr: i64, src_len: i64) -> EmitState {
    let tokens: Vec = lex(src_addr, src_len);
    let ast_root: i64 = parse(tokens, src_addr);
    let _tc: String = typecheck(ast_root, src_addr);
    lower_program(ast_root, src_addr)
}
