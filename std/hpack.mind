    __mind_store_i64(dst + 264, (1852793645 << 32) | 1936942435); // b'cess-con'
    __mind_store_i64(dst + 272, (1819042093 << 32) | 1819243124); // b'trol-all'
    __mind_store_i64(dst + 280, (1768384882 << 32) | 1865250671); // b'ow-origi'
