    __mind_store_i64(dst + 408, (1869360500 << 32) | 1852142702); // b'ntent-lo'
    __mind_store_i64(dst + 416, (880239 << 32) | 1769234787); // b'cation\r\x00'
    __mind_store_i64(dst + 424, (762605157 << 32) | 1953394531); // b'content-'
    __mind_store_i64(dst + 432, (1660947557 << 32) | 1735287154); // b'range\x0c\x00c'
    __mind_store_i64(dst + 440, (1949135982 << 32) | 1702129263); // b'ontent-t'
    __mind_store_i64(dst + 448, (1869570816 << 32) | 107311225); // b'ype\x06\x00coo'
    __mind_store_i64(dst + 456, (1952539648 << 32) | 73754987); // b'kie\x04\x00dat'
    __mind_store_i64(dst + 464, (107438452 << 32) | 1694499941); // b'e\x04\x00etag\x06'
