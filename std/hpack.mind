    __mind_store_i64(dst + 376, (1735287148 << 32) | 762605157); // b'ent-lang'
    __mind_store_i64(dst + 384, (1868759054 << 32) | 1701273973); // b'uage\x0e\x00co'
    __mind_store_i64(dst + 392, (1701588340 << 32) | 1852142702); // b'ntent-le'
