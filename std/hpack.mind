}

// ---------------------------------------------------------------------------
// §5.1 — integer representation with an N-bit prefix.
// ---------------------------------------------------------------------------

// hpack_int_decode — decode one §5.1 integer starting at buf+pos, where the
// first byte contributes its low prefix_bits bits.  out2[0] = value,
// out2[8] = position after the integer.  Returns 0 ok / 1 error (truncated
// input or a continuation that would overflow i64 — fail closed).
pub fn hpack_int_decode(
    buf: i64,
    len: i64,
    pos: i64,
    prefix_bits: i64,
    out2: i64,
) -> i64 {
    if pos >= len {
        return 1;
    }
    let mask: i64 = (1 << prefix_bits) - 1;
    let mut value: i64 = __mind_load_i8(buf + pos) & mask;
    let mut p: i64 = pos + 1;
    if value < mask {
        __mind_store_i64(out2, value);
        __mind_store_i64(out2 + 8, p);
        return 0;
    }
    // Prefix saturated: value = mask + sum of 7-bit continuation groups.
    let mut m: i64 = 0;
    let mut cont: i64 = 1;
    let mut err: i64 = 0;
    while cont == 1 {
        if p >= len {
            err = 1;
            cont = 0;
        } else {
            let b: i64 = __mind_load_i8(buf + p);
            p = p + 1;
            value = value + ((b & 127) << m);
            m = m + 7;
            if m > 56 {
                // More than 8 continuation bytes cannot fit in i64.
                err = 1;
                cont = 0;
            }
            if (b & 128) == 0 {
                cont = 0;
            }
        }
    }
    if err == 1 {
        return 1;
    }
    __mind_store_i64(out2, value);
    __mind_store_i64(out2 + 8, p);
    0
}

// ---------------------------------------------------------------------------
// §5.2 + Appendix B — Huffman-coded string literals.
// ---------------------------------------------------------------------------

// hpack_huff_decode — decode src_len Huffman-coded bytes into dst (raw
// octets).  Canonical decode: accumulate bits into (code, clen); at each
// length L a hit is code in [bc[L], bc[L]+ct[L]) and the symbol is
// sym[bi[L] + code - bc[L]].  Canonicity of the Appendix B code (verified
// at table-generation time) guarantees a code below bc[L] can never match
// at any greater length, so invalid streams fail closed.
// A trailing partial code must be at most 7 bits of all ones (the most
// significant bits of EOS) — anything else, including a full 30-bit EOS,
// is a decoding error (§5.2).  Returns decoded length or -1.
pub fn hpack_huff_decode(src: i64, src_len: i64, dst: i64, dst_cap: i64) -> i64 {
    let sym: i64 = __mind_alloc(256);
    let bc: i64 = __mind_alloc(248);
    let bi: i64 = __mind_alloc(248);
    let ct: i64 = __mind_alloc(248);
    hpack_fill_huff(sym, bc, bi, ct);
    let nbits: i64 = src_len * 8;
    let mut code: i64 = 0;
    let mut clen: i64 = 0;
    let mut outn: i64 = 0;
    let mut err: i64 = 0;
    let mut i: i64 = 0;
    while i < nbits {
        let byte: i64 = __mind_load_i8(src + (i >> 3));
        code = (code << 1) | ((byte >> (7 - (i & 7))) & 1);
        clen = clen + 1;
        if clen > 30 {
            // No HPACK code is longer than 30 bits — invalid stream.
            err = 1;
            i = nbits;
        } else {
            let c: i64 = __mind_load_i64(ct + clen * 8);
            let b0: i64 = __mind_load_i64(bc + clen * 8);
            if c > 0 {
                if code >= b0 {
                    if code < b0 + c {
                        let s: i64 =
                            __mind_load_i8(sym + __mind_load_i64(bi + clen * 8) + (code - b0));
                        if outn >= dst_cap {
                            err = 1;
                            i = nbits;
                        } else {
                            __mind_store_i8(dst + outn, s);
                            outn = outn + 1;
                            code = 0;
                            clen = 0;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    // §5.2 padding: at most 7 bits, all ones (EOS most-significant bits).
    let mut ret: i64 = outn;
    if err == 1 {
        ret = 0 - 1;
    }
    if clen > 7 {
        ret = 0 - 1;
    }
    if clen > 0 {
        if code != (1 << clen) - 1 {
            ret = 0 - 1;
        }
    }
    __mind_free(sym);
    __mind_free(bc);
    __mind_free(bi);
    __mind_free(ct);
    ret
}

// hpack_str_decode — §5.2 string literal at buf+pos: a 7-bit-prefix length
// whose high flag bit selects Huffman coding, then that many octets.
// Decoded string is written to dst (max dst_cap); out2[0] = decoded length,
// out2[8] = position after the string.  Returns 0 ok / 1 error.
fn hpack_str_decode(
    buf: i64,
    len: i64,
    pos: i64,
    dst: i64,
    dst_cap: i64,
    out2: i64,
) -> i64 {
    if pos >= len {
        return 1;
    }
    if dst_cap < 0 {
        return 1;
    }
    let hflag: i64 = __mind_load_i8(buf + pos) & 128;
    let rc: i64 = hpack_int_decode(buf, len, pos, 7, out2);
    if rc != 0 {
        return 1;
    }
    let slen: i64 = __mind_load_i64(out2);
    let p: i64 = __mind_load_i64(out2 + 8);
    if p + slen > len {
        return 1;
    }
    if hflag != 0 {
        let n: i64 = hpack_huff_decode(buf + p, slen, dst, dst_cap);
        if n < 0 {
            return 1;
        }
        __mind_store_i64(out2, n);
        __mind_store_i64(out2 + 8, p + slen);
        return 0;
    }
    if slen > dst_cap {
        return 1;
    }
    hpack_memcopy(dst, buf + p, slen);
    __mind_store_i64(out2, slen);
    __mind_store_i64(out2 + 8, p + slen);
    0
}

// ---------------------------------------------------------------------------
// Index space (§2.3.3): static 1..61, dynamic 62.. (newest first).
// out4 layout for every table lookup:
//   out4[0]=name_addr, out4[8]=name_len, out4[16]=value_addr, out4[24]=value_len
// ---------------------------------------------------------------------------

// hpack_static_get — Appendix A entry idx (1..61) from the packed blob.
fn hpack_static_get(blob: i64, idx: i64, out4: i64) -> i64 {
    let mut p: i64 = 0;
    let mut i: i64 = 1;
    while i < idx {
        p = p + 2 + __mind_load_i8(blob + p) + __mind_load_i8(blob + p + 1);
        i = i + 1;
    }
    let nl: i64 = __mind_load_i8(blob + p);
    __mind_store_i64(out4, blob + p + 2);
    __mind_store_i64(out4 + 8, nl);
    __mind_store_i64(out4 + 16, blob + p + 2 + nl);
    __mind_store_i64(out4 + 24, __mind_load_i8(blob + p + 1));
    0
}

// ---------------------------------------------------------------------------
// §2.3.2 / §4 — the dynamic table (layout documented in the file header).
// ---------------------------------------------------------------------------

// hpack_dyn_init — initialize a dynamic-table state buffer (caller allocates
// >= 32 + max_size bytes).  Returns 0.
pub fn hpack_dyn_init(dyn_table_state_addr: i64, max_size: i64) -> i64 {
    __mind_store_i64(dyn_table_state_addr, max_size);
    __mind_store_i64(dyn_table_state_addr + 8, 0);
    __mind_store_i64(dyn_table_state_addr + 16, 0);
    __mind_store_i64(dyn_table_state_addr + 24, 0);
    0
}

// hpack_dyn_evict_one — drop the OLDEST entry (§4.3): the record at the
// front of the arena.  Remaining records shift down (forward overlapping
// copy is safe: dst < src).
fn hpack_dyn_evict_one(state: i64) -> i64 {
    let arena: i64 = state + 32;
    let nl: i64 = hpack_u16_load(arena);
    let vl: i64 = hpack_u16_load(arena + 2);
    let rec: i64 = 4 + nl + vl;
    let used: i64 = __mind_load_i64(state + 24);
    hpack_memcopy(arena, arena + rec, used - rec);
    __mind_store_i64(state + 24, used - rec);
    __mind_store_i64(state + 16, __mind_load_i64(state + 16) - 1);
    __mind_store_i64(state + 8, __mind_load_i64(state + 8) - (nl + vl + 32));
    0
}

// hpack_dyn_set_max — §6.3 dynamic table size update: adopt the new maximum
// and evict oldest-first until the table fits (§4.3).
fn hpack_dyn_set_max(state: i64, new_max: i64) -> i64 {
    __mind_store_i64(state, new_max);
    let mut sz: i64 = __mind_load_i64(state + 8);
    while sz > new_max {
        hpack_dyn_evict_one(state);
        sz = __mind_load_i64(state + 8);
    }
    0
}

// hpack_dyn_insert — §4.4: evict until the new entry (cost nl+vl+32, §4.1)
// fits, then append it as the newest record.  An entry larger than the
// whole table empties the table and is NOT added (per §4.4) — that is not
// an error.
fn hpack_dyn_insert(state: i64, name: i64, nl: i64, val: i64, vl: i64) -> i64 {
    let esz: i64 = nl + vl + 32;
    let maxs: i64 = __mind_load_i64(state);
    let mut go: i64 = 1;
    while go == 1 {
        let sz: i64 = __mind_load_i64(state + 8);
        if sz + esz > maxs {
            if __mind_load_i64(state + 16) > 0 {
                hpack_dyn_evict_one(state);
            } else {
                go = 0;
            }
        } else {
            go = 0;
        }
    }
    if esz > maxs {
        return 0;
    }
    let used: i64 = __mind_load_i64(state + 24);
    let arena: i64 = state + 32;
    hpack_u16_store(arena + used, nl);
    hpack_u16_store(arena + used + 2, vl);
    hpack_memcopy(arena + used + 4, name, nl);
    hpack_memcopy(arena + used + 4 + nl, val, vl);
    __mind_store_i64(state + 24, used + 4 + nl + vl);
    __mind_store_i64(state + 16, __mind_load_i64(state + 16) + 1);
    __mind_store_i64(state + 8, __mind_load_i64(state + 8) + esz);
    0
}

// hpack_dyn_get — dynamic entry d (0-based, NEWEST first, §2.3.3), i.e. the
// record at oldest-first arena position count-1-d.  Returns 0 ok / 1 if d
// is out of range (a reference to an evicted or never-inserted entry is a
// decode error).
fn hpack_dyn_get(state: i64, d: i64, out4: i64) -> i64 {
    let cnt: i64 = __mind_load_i64(state + 16);
    if d < 0 {
        return 1;
    }
    if d >= cnt {
        return 1;
    }
    let target: i64 = cnt - 1 - d;
    let arena: i64 = state + 32;
    let mut p: i64 = 0;
    let mut i: i64 = 0;
    while i < target {
        p = p + 4 + hpack_u16_load(arena + p) + hpack_u16_load(arena + p + 2);
        i = i + 1;
    }
    let nl: i64 = hpack_u16_load(arena + p);
    __mind_store_i64(out4, arena + p + 4);
    __mind_store_i64(out4 + 8, nl);
    __mind_store_i64(out4 + 16, arena + p + 4 + nl);
    __mind_store_i64(out4 + 24, hpack_u16_load(arena + p + 2));
    0
}

// hpack_table_get — unified index space (§2.3.3): 1..61 static, 62.. dynamic.
// Index 0 is reserved and always an error (§6.1).
fn hpack_table_get(blob: i64, state: i64, idx: i64, out4: i64) -> i64 {
    if idx <= 0 {
        return 1;
    }
    if idx <= 61 {
        let rc: i64 = hpack_static_get(blob, idx, out4);
        return rc;
    }
    let rc2: i64 = hpack_dyn_get(state, idx - 62, out4);
    rc2
}

// ---------------------------------------------------------------------------
// §6 — header-field representation decoding.
//
// Decode context (ctx, 64 bytes, i64 slots):
//   ctx+0  block addr     ctx+8  block len     ctx+16 cursor position
//   ctx+24 out addr       ctx+32 out cap       ctx+40 out bytes used
//   ctx+48 static blob    ctx+56 dyn state
// Each hpack_do_* helper consumes one representation, advances ctx+16, and
// returns the number of pairs it emitted (0 or 1), or 2 on error.
// ---------------------------------------------------------------------------

// hpack_emit — append one output record (name_len u16 LE, name, value_len
// u16 LE, value) at the output cursor.  Returns 0 ok / 1 on overflow.
fn hpack_emit(ctx: i64, name: i64, nl: i64, val: i64, vl: i64) -> i64 {
    let out: i64 = __mind_load_i64(ctx + 24);
    let cap: i64 = __mind_load_i64(ctx + 32);
    let u: i64 = __mind_load_i64(ctx + 40);
    if u + 4 + nl + vl > cap {
        return 1;
    }
    hpack_u16_store(out + u, nl);
    hpack_memcopy(out + u + 2, name, nl);
    hpack_u16_store(out + u + 2 + nl, vl);
    hpack_memcopy(out + u + 4 + nl, val, vl);
    __mind_store_i64(ctx + 40, u + 4 + nl + vl);
    0
}

// hpack_do_indexed — §6.1 indexed header field (1xxxxxxx): a 7-bit-prefix
// index into the unified table; index 0 is a decode error.
fn hpack_do_indexed(ctx: i64) -> i64 {
    let out2: i64 = __mind_alloc(16);
    let out4: i64 = __mind_alloc(32);
    let rc: i64 = hpack_int_decode(
        __mind_load_i64(ctx),
        __mind_load_i64(ctx + 8),
        __mind_load_i64(ctx + 16),
        7,
        out2,
    );
    if rc != 0 {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let idx: i64 = __mind_load_i64(out2);
    if idx == 0 {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let rc2: i64 = hpack_table_get(
        __mind_load_i64(ctx + 48),
        __mind_load_i64(ctx + 56),
        idx,
        out4,
    );
    if rc2 != 0 {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let rc3: i64 = hpack_emit(
        ctx,
        __mind_load_i64(out4),
        __mind_load_i64(out4 + 8),
        __mind_load_i64(out4 + 16),
        __mind_load_i64(out4 + 24),
    );
    __mind_store_i64(ctx + 16, __mind_load_i64(out2 + 8));
    __mind_free(out2);
    __mind_free(out4);
    if rc3 != 0 {
        return 2;
    }
    1
}

// hpack_do_literal — literal header field:
//   §6.2.1 incremental indexing (01xxxxxx): prefix_bits=6, add=1
//   §6.2.2 without indexing      (0000xxxx): prefix_bits=4, add=0
//   §6.2.3 never indexed         (0001xxxx): prefix_bits=4, add=0
// The name is either a table reference (prefix index > 0) or a literal
// string; the value is always a literal string.  Both are materialized
// directly into the output record; when add=1 the entry is inserted into
// the dynamic table FROM THE OUTPUT COPY, so a name that referenced a
// dynamic entry stays valid even if this insertion evicts its source.
fn hpack_do_literal(ctx: i64, prefix_bits: i64, add: i64) -> i64 {
    let block: i64 = __mind_load_i64(ctx);
    let blen: i64 = __mind_load_i64(ctx + 8);
    let out: i64 = __mind_load_i64(ctx + 24);
    let cap: i64 = __mind_load_i64(ctx + 32);
    let u: i64 = __mind_load_i64(ctx + 40);
    let out2: i64 = __mind_alloc(16);
    let out4: i64 = __mind_alloc(32);
    let rc: i64 = hpack_int_decode(
        block, blen, __mind_load_i64(ctx + 16), prefix_bits, out2,
    );
    if rc != 0 {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let idx: i64 = __mind_load_i64(out2);
    let mut pos: i64 = __mind_load_i64(out2 + 8);
    if u + 4 > cap {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let name_dst: i64 = out + u + 2;
    let mut nl: i64 = 0;
    if idx == 0 {
        // Literal name (cap budget reserves the two u16 length prefixes).
        let rc2: i64 = hpack_str_decode(block, blen, pos, name_dst, cap - u - 4, out2);
        if rc2 != 0 {
            __mind_free(out2);
            __mind_free(out4);
            return 2;
        }
        nl = __mind_load_i64(out2);
        pos = __mind_load_i64(out2 + 8);
    } else {
        // Name taken from the table (§6.2: N-bit-prefix name index).
        let rc3: i64 = hpack_table_get(
            __mind_load_i64(ctx + 48), __mind_load_i64(ctx + 56), idx, out4,
        );
        if rc3 != 0 {
            __mind_free(out2);
            __mind_free(out4);
            return 2;
        }
        nl = __mind_load_i64(out4 + 8);
        if u + 4 + nl > cap {
            __mind_free(out2);
            __mind_free(out4);
            return 2;
        }
        hpack_memcopy(name_dst, __mind_load_i64(out4), nl);
    }
    let val_dst: i64 = out + u + 4 + nl;
    let rc4: i64 = hpack_str_decode(block, blen, pos, val_dst, cap - u - 4 - nl, out2);
    if rc4 != 0 {
        __mind_free(out2);
        __mind_free(out4);
        return 2;
    }
    let vl: i64 = __mind_load_i64(out2);
    pos = __mind_load_i64(out2 + 8);
    hpack_u16_store(out + u, nl);
    hpack_u16_store(out + u + 2 + nl, vl);
    __mind_store_i64(ctx + 40, u + 4 + nl + vl);
    __mind_store_i64(ctx + 16, pos);
    if add == 1 {
        hpack_dyn_insert(__mind_load_i64(ctx + 56), name_dst, nl, val_dst, vl);
    }
    __mind_free(out2);
    __mind_free(out4);
    1
}

// hpack_do_szupd — §6.3 dynamic table size update (001xxxxx): a 5-bit-prefix
// new maximum size; emits no header field.
fn hpack_do_szupd(ctx: i64) -> i64 {
    let out2: i64 = __mind_alloc(16);
    let rc: i64 = hpack_int_decode(
        __mind_load_i64(ctx),
        __mind_load_i64(ctx + 8),
        __mind_load_i64(ctx + 16),
        5,
        out2,
    );
    if rc != 0 {
        __mind_free(out2);
        return 2;
    }
    let new_max: i64 = __mind_load_i64(out2);
    __mind_store_i64(ctx + 16, __mind_load_i64(out2 + 8));
    __mind_free(out2);
    hpack_dyn_set_max(__mind_load_i64(ctx + 56), new_max);
    0
}

// ---------------------------------------------------------------------------
// hpack_decode — decode one complete header block (see file header for the
// output record format and the persistent dynamic-table state contract).
// Returns the pair count, or -1 on any decode error (fail closed).
// ---------------------------------------------------------------------------
pub fn hpack_decode(
    block_addr: i64,
    block_len: i64,
    dyn_table_state_addr: i64,
    out_addr: i64,
    out_cap: i64,
) -> i64 {
    let blob: i64 = __mind_alloc(816);
    hpack_fill_static(blob);
    let ctx: i64 = __mind_alloc(64);
    __mind_store_i64(ctx, block_addr);
    __mind_store_i64(ctx + 8, block_len);
    __mind_store_i64(ctx + 16, 0);
    __mind_store_i64(ctx + 24, out_addr);
    __mind_store_i64(ctx + 32, out_cap);
    __mind_store_i64(ctx + 40, 0);
    __mind_store_i64(ctx + 48, blob);
    __mind_store_i64(ctx + 56, dyn_table_state_addr);
    let mut pairs: i64 = 0;
    let mut err: i64 = 0;
    let mut pos: i64 = 0;
    while pos < block_len {
        let b: i64 = __mind_load_i8(block_addr + pos);
        let mut rc: i64 = 0;
        if (b & 128) != 0 {
            rc = hpack_do_indexed(ctx); // §6.1   1xxxxxxx
        } else {
            if (b & 192) == 64 {
                rc = hpack_do_literal(ctx, 6, 1); // §6.2.1 01xxxxxx
            } else {
                if (b & 224) == 32 {
                    rc = hpack_do_szupd(ctx); // §6.3   001xxxxx
                } else {
                    // §6.2.2 0000xxxx / §6.2.3 0001xxxx — identical decode,
                    // neither inserts into the dynamic table.
                    rc = hpack_do_literal(ctx, 4, 0);
                }
            }
        }
        if rc == 2 {
            err = 1;
            pos = block_len;
        } else {
            pairs = pairs + rc;
            pos = __mind_load_i64(ctx + 16);
        }
    }
    __mind_free(ctx);
    __mind_free(blob);
    if err == 1 {
        return 0 - 1;
    }
    pairs
}
