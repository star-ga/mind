// std/hpack.mind — HPACK header-compression DECODING (RFC 7541) in pure MIND.
//
// Self-contained: no imports, only the __mind_* intrinsics (alloc/free +
// load/store i8/i64), matching std/aes_gcm.mind's byte-buffer discipline.
// Phase 2.1 of the HTTP-provable stack: HTTP/2 header decompression.
//
// Scope (RFC 7541):
//   - §5.1  N-bit-prefix variable-length integers
//   - §5.2  string literals (raw + Huffman) with the Appendix B canonical
//           Huffman table (256 symbols; EOS handled as padding/error only)
//   - Appendix A static table (61 entries)
//   - §2.3.2/§4  dynamic table: FIFO of (name,value) entries, entry cost
//           name_len + value_len + 32 octets (§4.1), oldest-first eviction
//           (§4.3), persistent across calls via a caller-owned state buffer
//   - §6.1/§6.2.1/§6.2.2/§6.2.3/§6.3  header-field representations
//   HPACK *encoding* is intentionally out of scope for this increment.
//
// Public API:
//   pub fn hpack_dyn_init(dyn_table_state_addr, max_size) -> i64
//     Initialize a dynamic-table state buffer.  The caller must allocate at
//     least 32 + max_size bytes at dyn_table_state_addr (the arena can never
//     hold more than max_size bytes because every entry costs 32 octets more
//     than the bytes it stores, §4.1).  Returns 0.
//   pub fn hpack_decode(block_addr, block_len, dyn_table_state_addr,
//                       out_addr, out_cap) -> i64
//     Decode one complete header block.  Emits, per header field, the record
//       name_len u16 LE, name bytes, value_len u16 LE, value bytes
//     packed back-to-back at out_addr.  Returns the number of (name,value)
//     pairs decoded, or -1 on malformed input / output overflow (fail
//     closed; out contents are unspecified on failure).  The dynamic-table
//     state persists across calls: pass the same dyn_table_state_addr for
//     every header block of a connection.
//   pub fn hpack_int_decode(buf, len, pos, prefix_bits, out2) -> i64
//     §5.1 integer decode (exposed for direct testing, RFC C.1 examples).
//     Writes out2[0] = value, out2[8] = new position; returns 0 ok / 1 err.
//   pub fn hpack_huff_decode(src, src_len, dst, dst_cap) -> i64
//     §5.2 + Appendix B Huffman decode (exposed for direct testing).
//     Returns the decoded byte count, or -1 on invalid padding, embedded
//     EOS, or output overflow.
//
// Dynamic-table state layout (all i64 fields in 8-byte little-endian slots):
//   state+0  : max_size — current maximum table size in octets (§4.2)
//   state+8  : size     — current table size per §4.1 (sum over entries of
//                         name_len + value_len + 32)
//   state+16 : count    — number of live dynamic entries
//   state+24 : used     — bytes used in the arena
//   state+32…: arena    — entry records OLDEST FIRST, newest appended at the
//                         end; each record is
//                           name_len u16 LE, value_len u16 LE, name, value
//                         Eviction (§4.3) drops the record at the front.
//   Dynamic index d = HPACK index − 62 (newest-first, §2.3.3) is the record
//   at oldest-first position count − 1 − d.
//
// §6.3 note: a dynamic-table size update is accepted as-is (evicting as
// needed).  Enforcing the SETTINGS_HEADER_TABLE_SIZE protocol bound is the
// HTTP/2 layer's job, not this codec's.
//
// Determinism: pure integer arithmetic, no floats, no clocks, no external
// calls.  Every error path fails closed with a nonzero / negative return.

// hpack_memcopy — copy len bytes from src to dst, one byte per offset.
// Forward copy, so overlapping moves with dst < src (eviction compaction)
// are safe.  Extracted per the std/hkdf.mind sibling-while-loop note.
fn hpack_memcopy(dst: i64, src: i64, len: i64) -> i64 {
    let mut i: i64 = 0;
    while i < len {
        __mind_store_i8(dst + i, __mind_load_i8(src + i));
        i = i + 1;
    }
    0
}

// hpack_u16_load / hpack_u16_store — 16-bit little-endian length fields
// used by both the dynamic-table arena records and the output records.
fn hpack_u16_load(a: i64) -> i64 {
    __mind_load_i8(a) | (__mind_load_i8(a + 1) << 8)
}

fn hpack_u16_store(a: i64, v: i64) -> i64 {
    __mind_store_i8(a, v & 255);
    __mind_store_i8(a + 1, (v >> 8) & 255);
    0
}

// hpack_fill_huff -- fill the canonical-Huffman decode tables
// (RFC 7541 Appendix B).  sym: 256 bytes, symbols ordered by
// (bit-length, code).  bc/bi/ct: 31 i64 slots each, indexed by
// bit-length L (1..30): first code of length L, index into sym
// of the first symbol of length L, and symbol count at length L.
// EOS (code 0x3FFFFFFF, 30 bits) is deliberately absent: an EOS
// inside a string is a decode error (RFC 7541 s5.2).
// Table bytes generated from the Appendix B table; packed 8 bytes
// per store as (hi32 << 32) | lo32 decimal (std/keccak.mind style).
fn hpack_fill_huff(sym: i64, bc: i64, bi: i64, ct: i64) -> i64 {
    let mut z: i64 = 0;
    while z < 31 {
        __mind_store_i64(bc + z * 8, 0);
        __mind_store_i64(bi + z * 8, 0);
        __mind_store_i64(ct + z * 8, 0);
        z = z + 1;
    }
    __mind_store_i64(sym + 0, (1869178211 << 32) | 1630679344);
    __mind_store_i64(sym + 8, (858730029 << 32) | 622883955);
    __mind_store_i64(sym + 16, (1094531384 << 32) | 926299444);
    __mind_store_i64(sym + 24, (1835821159 << 32) | 1717854815);
    __mind_store_i64(sym + 32, (1145258554 << 32) | 1970434158);
    __mind_store_i64(sym + 40, (1280002633 << 32) | 1212630597);
    __mind_store_i64(sym + 48, (1414746705 << 32) | 1347374669);
    __mind_store_i64(sym + 56, (1987144554 << 32) | 1498895957);
    __mind_store_i64(sym + 64, (992750118 << 32) | 2054781047);
    __mind_store_i64(sym + 72, (658450728 << 32) | 572611160);
    __mind_store_i64(sym + 80, (1530930176 << 32) | 1042512939);
    __mind_store_i64(sym + 88, (1551589436 << 32) | 2103344733);
    __mind_store_i64(sym + 96, (3266880131 << 32) | 2189480131);
    __mind_store_i64(sym + 104, (2981145767 << 32) | 2711216864);
    __mind_store_i64(sym + 112, (2179392995 << 32) | 3654865331);
    __mind_store_i64(sym + 120, (2694617746 << 32) | 2290517380);
    __mind_store_i64(sym + 128, (3115692717 << 32) | 2863244451);
    __mind_store_i64(sym + 136, (3907307204 << 32) | 3200105402);
    __mind_store_i64(sym + 144, (2374798218 << 32) | 2307326441);
    __mind_store_i64(sym + 152, (2644220055 << 32) | 2526385039);
    __mind_store_i64(sym + 160, (3065294766 << 32) | 2829493662);
    __mind_store_i64(sym + 168, (2383015911 << 32) | 3317677239);
    __mind_store_i64(sym + 176, (3789016747 << 32) | 2677313936);
    __mind_store_i64(sym + 184, (3250645994 << 32) | 3485986284);
    __mind_store_i64(sym + 192, (3688551890 << 32) | 3452619208);
    __mind_store_i64(sym + 200, (3553414143 << 32) | 4092784878);
    __mind_store_i64(sym + 208, (4126470623 << 32) | 3739080404);
    __mind_store_i64(sym + 216, (4278058235 << 32) | 4210620406);
    __mind_store_i64(sym + 224, (185075462 << 32) | 84148994);
    __mind_store_i64(sym + 232, (336794129 << 32) | 269422092);
    __mind_store_i64(sym + 240, (488381210 << 32) | 421009173);
    __mind_store_i64(sym + 248, (369953529 << 32) | 3699318558);
    __mind_store_i64(bc + 40, 0);   // len 5
    __mind_store_i64(bi + 40, 0);
    __mind_store_i64(ct + 40, 10);
    __mind_store_i64(bc + 48, 20);   // len 6
    __mind_store_i64(bi + 48, 10);
    __mind_store_i64(ct + 48, 26);
    __mind_store_i64(bc + 56, 92);   // len 7
    __mind_store_i64(bi + 56, 36);
    __mind_store_i64(ct + 56, 32);
    __mind_store_i64(bc + 64, 248);   // len 8
    __mind_store_i64(bi + 64, 68);
    __mind_store_i64(ct + 64, 6);
    __mind_store_i64(bc + 80, 1016);   // len 10
    __mind_store_i64(bi + 80, 74);
    __mind_store_i64(ct + 80, 5);
    __mind_store_i64(bc + 88, 2042);   // len 11
    __mind_store_i64(bi + 88, 79);
    __mind_store_i64(ct + 88, 3);
    __mind_store_i64(bc + 96, 4090);   // len 12
    __mind_store_i64(bi + 96, 82);
    __mind_store_i64(ct + 96, 2);
    __mind_store_i64(bc + 104, 8184);   // len 13
    __mind_store_i64(bi + 104, 84);
    __mind_store_i64(ct + 104, 6);
    __mind_store_i64(bc + 112, 16380);   // len 14
    __mind_store_i64(bi + 112, 90);
    __mind_store_i64(ct + 112, 2);
    __mind_store_i64(bc + 120, 32764);   // len 15
    __mind_store_i64(bi + 120, 92);
    __mind_store_i64(ct + 120, 3);
    __mind_store_i64(bc + 152, 524272);   // len 19
    __mind_store_i64(bi + 152, 95);
    __mind_store_i64(ct + 152, 3);
    __mind_store_i64(bc + 160, 1048550);   // len 20
    __mind_store_i64(bi + 160, 98);
    __mind_store_i64(ct + 160, 8);
    __mind_store_i64(bc + 168, 2097116);   // len 21
    __mind_store_i64(bi + 168, 106);
    __mind_store_i64(ct + 168, 13);
    __mind_store_i64(bc + 176, 4194258);   // len 22
    __mind_store_i64(bi + 176, 119);
    __mind_store_i64(ct + 176, 26);
    __mind_store_i64(bc + 184, 8388568);   // len 23
    __mind_store_i64(bi + 184, 145);
    __mind_store_i64(ct + 184, 29);
    __mind_store_i64(bc + 192, 16777194);   // len 24
    __mind_store_i64(bi + 192, 174);
    __mind_store_i64(ct + 192, 12);
    __mind_store_i64(bc + 200, 33554412);   // len 25
    __mind_store_i64(bi + 200, 186);
    __mind_store_i64(ct + 200, 4);
    __mind_store_i64(bc + 208, 67108832);   // len 26
    __mind_store_i64(bi + 208, 190);
    __mind_store_i64(ct + 208, 15);
    __mind_store_i64(bc + 216, 134217694);   // len 27
    __mind_store_i64(bi + 216, 205);
    __mind_store_i64(ct + 216, 19);
    __mind_store_i64(bc + 224, 268435426);   // len 28
    __mind_store_i64(bi + 224, 224);
    __mind_store_i64(ct + 224, 29);
    __mind_store_i64(bc + 240, 1073741820);   // len 30
    __mind_store_i64(bi + 240, 253);
    __mind_store_i64(ct + 240, 3);
    0
}

// hpack_fill_static -- fill the RFC 7541 Appendix A static table
// (61 entries) as a packed blob of records:
//   name_len u8, value_len u8, name bytes, value bytes
// Returns the blob length (806).  Caller allocates >= 808 bytes.
fn hpack_fill_static(dst: i64) -> i64 {
    __mind_store_i64(dst + 0, (1869116533 << 32) | 1631191050); // b'\n\x00:autho'
    __mind_store_i64(dst + 8, (1832518407 << 32) | 2037672306); // b'rity\x07\x03:m'
    __mind_store_i64(dst + 16, (1413826404 << 32) | 1869116517); // b'ethodGET'
    __mind_store_i64(dst + 24, (1869116517 << 32) | 1832518663); // b'\x07\x04:metho'
    __mind_store_i64(dst + 32, (973145428 << 32) | 1397706852); // b'dPOST\x05\x01:'
    __mind_store_i64(dst + 40, (973800751 << 32) | 1752457584); // b'path/\x05\x0b:'
    __mind_store_i64(dst + 48, (1684957487 << 32) | 1752457584); // b'path/ind'
    __mind_store_i64(dst + 56, (124546420 << 32) | 1747875941); // b'ex.html\x07'
    __mind_store_i64(dst + 64, (1701668200 << 32) | 1668495876); // b'\x04:scheme'
    __mind_store_i64(dst + 72, (1933182215 << 32) | 1886680168); // b'http\x07\x05:s'
    __mind_store_i64(dst + 80, (1953785957 << 32) | 1835362403); // b'chemehtt'
    __mind_store_i64(dst + 88, (1635021626 << 32) | 50819952); // b'ps\x07\x03:sta'
    __mind_store_i64(dst + 96, (50802736 << 32) | 846427508); // b'tus200\x07\x03'
    __mind_store_i64(dst + 104, (846427508 << 32) | 1635021626); // b':status2'
    __mind_store_i64(dst + 112, (1635021626 << 32) | 50803760); // b'04\x07\x03:sta'
    __mind_store_i64(dst + 120, (50804272 << 32) | 846427508); // b'tus206\x07\x03'
    __mind_store_i64(dst + 128, (863204724 << 32) | 1635021626); // b':status3'
    __mind_store_i64(dst + 136, (1635021626 << 32) | 50803760); // b'04\x07\x03:sta'
    __mind_store_i64(dst + 144, (50802736 << 32) | 879981940); // b'tus400\x07\x03'
    __mind_store_i64(dst + 152, (879981940 << 32) | 1635021626); // b':status4'
    __mind_store_i64(dst + 160, (1635021626 << 32) | 50803760); // b'04\x07\x03:sta'
    __mind_store_i64(dst + 168, (929840 << 32) | 896759156); // b'tus500\x0e\x00'
    __mind_store_i64(dst + 176, (1663923312 << 32) | 1701012321); // b'accept-c'
    __mind_store_i64(dst + 184, (219116645 << 32) | 1936875880); // b'harset\x0f\r'
    __mind_store_i64(dst + 192, (1697477744 << 32) | 1701012321); // b'accept-e'
    __mind_store_i64(dst + 200, (1734831721 << 32) | 1685021550); // b'ncodingg'
    __mind_store_i64(dst + 208, (1717920800 << 32) | 745564538); // b'zip, def'
    __mind_store_i64(dst + 216, (1667301391 << 32) | 1702125932); // b'late\x0f\x00ac'
    __mind_store_i64(dst + 224, (1851878445 << 32) | 1953523043); // b'cept-lan'
