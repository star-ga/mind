// std/sha512.mind — FIPS 180-4 SHA-512 and SHA-384 in pure MIND.
//
// Self-contained: no imports, only the `__mind_*` byte-buffer intrinsics,
// matching std/sha256.mind's discipline. Where SHA-256 emulates u32 on i64 with
// a `& 0xFFFFFFFF` mask, SHA-512 works in the full 64-bit word: i64 IS 64 bits,
// so wrapping add / xor / and are already mod 2^64 and need no mask. The one
// hazard is the RIGHT shift: `>>` is arithmetic (sign-extending) on i64, so any
// value with bit 63 set would smear ones. `shr64u` masks the sign-extended bits
// off, exactly like std/keccak.mind's keccak_rotl64 handles its logical part.
//
// 64-bit constants (K[0..79], the H init words) have bit 63 set for many
// entries and so do not fit a positive i64 literal; each is written as
// (hi32 << 32) | lo32 in decimal — the left shift lands hi32's top bit in the
// sign bit, giving the exact 64-bit pattern (the std/keccak.mind convention).
//
// Memory layout (like std/sha256.mind):
//   - message / digest byte buffers: one byte per offset.
//   - W schedule (80 words) and H state (8 words): stride-8 i64 slots.
//
// Public API:
//   pub fn sha512(in_addr, in_len, out_addr) -> i64   // 64-byte digest
//   pub fn sha384(in_addr, in_len, out_addr) -> i64   // 48-byte digest
//     Read in_len bytes at in_addr, write the big-endian digest to out_addr,
//     return 0.
//
// Determinism: pure integer arithmetic, no floats, no clocks, no external calls.

// ---------------------------------------------------------------------------
// u64-on-i64 primitives.
// ---------------------------------------------------------------------------

// shr64u — logical (zero-fill) right shift of a 64-bit value by n (1<=n<=63).
// (1 << (64 - n)) - 1 is the low-(64-n)-bit mask; for n=1 this is (1<<63)-1 =
// 0x7fff...f, which clears the arithmetic sign extension.
fn shr64u(x: i64, n: i64) -> i64 {
    (x >> n) & ((1 << (64 - n)) - 1)
}

// rotr64 — right-rotate a 64-bit word by n (1<=n<=63). The high part is the
// logical right shift; the low part `x << (64 - n)` wraps in i64 (drops the
// bits above bit 63), giving the rotated-in low bits.
fn rotr64(x: i64, n: i64) -> i64 {
    shr64u(x, n) | (x << (64 - n))
}

// FIPS 180-4 §4.1.3 boolean functions, written to avoid an explicit NOT.
// Ch(x,y,z) = (x&y) ^ (~x&z) = z ^ (x & (y ^ z)).
fn sha512_ch(x: i64, y: i64, z: i64) -> i64 {
    z ^ (x & (y ^ z))
}

// Maj(x,y,z) = (x&y) ^ (x&z) ^ (y&z) = (x&y) ^ (z & (x^y)).
fn sha512_maj(x: i64, y: i64, z: i64) -> i64 {
    (x & y) ^ (z & (x ^ y))
}

// Σ0(a) = ROTR28 ^ ROTR34 ^ ROTR39.
fn sha512_bsig0(x: i64) -> i64 {
    rotr64(x, 28) ^ rotr64(x, 34) ^ rotr64(x, 39)
}

// Σ1(e) = ROTR14 ^ ROTR18 ^ ROTR41.
fn sha512_bsig1(x: i64) -> i64 {
    rotr64(x, 14) ^ rotr64(x, 18) ^ rotr64(x, 41)
}

// σ0(w) = ROTR1 ^ ROTR8 ^ SHR7.
fn sha512_ssig0(x: i64) -> i64 {
    rotr64(x, 1) ^ rotr64(x, 8) ^ shr64u(x, 7)
}

// σ1(w) = ROTR19 ^ ROTR61 ^ SHR6.
fn sha512_ssig1(x: i64) -> i64 {
    rotr64(x, 19) ^ rotr64(x, 61) ^ shr64u(x, 6)
}

// ---------------------------------------------------------------------------
// Round constants K[0..79] — FIPS 180-4 §4.2.3 (first 64 bits of the fractional
// parts of the cube roots of the first 80 primes).
// ---------------------------------------------------------------------------

