// ---------------------------------------------------------------------------
// Initial hash values — FIPS 180-4 §5.3.4 (SHA-512) / §5.3.3 (SHA-384).
// is384 selects the SHA-384 IV (fractional parts of square roots of the 9th..
// 16th primes) instead of the SHA-512 IV.
// ---------------------------------------------------------------------------
fn sha512_hinit(i: i64, is384: i64) -> i64 {
    if is384 == 1 {
        if i == 0 {
            return (3418070365 << 32) | 3238371032;
        }
        // 0xcbbb9d5dc1059ed8
        if i == 1 {
            return (1654270250 << 32) | 914150663;
        }
        // 0x629a292a367cd507
        if i == 2 {
            return (2438529370 << 32) | 812702999;
        }
        // 0x9159015a3070dd17
        if i == 3 {
            return (355462360 << 32) | 4144912697;
        }
        // 0x152fecd8f70e5939
        if i == 4 {
            return (1731405415 << 32) | 4290775857;
        }
        // 0x67332667ffc00b31
        if i == 5 {
            return (2394180231 << 32) | 1750603025;
        }
        // 0x8eb44a8768581511
        if i == 6 {
            return (3675008525 << 32) | 1694076839;
        }
        // 0xdb0c2e0d64f98fa7
        return (1203062813 << 32) | 3204075428;
    }
    // 0x47b5481dbefa4fa4
    if i == 0 {
        return (1779033703 << 32) | 4089235720;
    }
    // 0x6a09e667f3bcc908
    if i == 1 {
        return (3144134277 << 32) | 2227873595;
    }
    // 0xbb67ae8584caa73b
    if i == 2 {
        return (1013904242 << 32) | 4271175723;
    }
    // 0x3c6ef372fe94f82b
    if i == 3 {
        return (2773480762 << 32) | 1595750129;
    }
    // 0xa54ff53a5f1d36f1
    if i == 4 {
        return (1359893119 << 32) | 2917565137;
    }
    // 0x510e527fade682d1
    if i == 5 {
        return (2600822924 << 32) | 725511199;
    }
    // 0x9b05688c2b3e6c1f
    if i == 6 {
        return (528734635 << 32) | 4215389547;
    }
    // 0x1f83d9abfb41bd6b
    (1541459225 << 32) | 327033209
    // 0x5be0cd19137e2179
}

// ---------------------------------------------------------------------------
// W-schedule accessors — 80 words stored stride-8.
// ---------------------------------------------------------------------------
fn w512_get(w_addr: i64, i: i64) -> i64 {
    __mind_load_i64(w_addr + i * 8)
}

fn w512_set(w_addr: i64, i: i64, v: i64) -> i64 {
    __mind_store_i64(w_addr + i * 8, v)
}

// ---------------------------------------------------------------------------
// compress_block512 — process one 128-byte block into the 8-word H state.
// ---------------------------------------------------------------------------
fn compress_block512(block_addr: i64, h_addr: i64) -> i64 {
    // W schedule: 80 words, stride-8 -> 640 bytes.
    let w_addr: i64 = __mind_alloc(640);

    // W[0..15]: pack eight consecutive message bytes (big-endian) per 64-bit word.
    let mut wi: i64 = 0;
    while wi < 16 {
        let base: i64 = wi * 8;
        let b0: i64 = __mind_load_i8(block_addr + base + 0);
        let b1: i64 = __mind_load_i8(block_addr + base + 1);
        let b2: i64 = __mind_load_i8(block_addr + base + 2);
        let b3: i64 = __mind_load_i8(block_addr + base + 3);
        let b4: i64 = __mind_load_i8(block_addr + base + 4);
        let b5: i64 = __mind_load_i8(block_addr + base + 5);
        let b6: i64 = __mind_load_i8(block_addr + base + 6);
        let b7: i64 = __mind_load_i8(block_addr + base + 7);
        let word: i64 = (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32) | (b4 << 24) | (b5 << 16) | (b6 << 8) | b7;
        w512_set(w_addr, wi, word);
        wi = wi + 1;
    }

    // W[16..79]: message schedule extension (wrapping add mod 2^64).
    let mut wj: i64 = 16;
    while wj < 80 {
        let s0: i64 = sha512_ssig0(w512_get(w_addr, wj - 15));
        let s1: i64 = sha512_ssig1(w512_get(w_addr, wj - 2));
        let val: i64 = w512_get(w_addr, wj - 16) + s0 + w512_get(w_addr, wj - 7) + s1;
        w512_set(w_addr, wj, val);
        wj = wj + 1;
    }

    // Working variables from H.
    let mut wa: i64 = __mind_load_i64(h_addr + 0 * 8);
    let mut wb: i64 = __mind_load_i64(h_addr + 1 * 8);
    let mut wc: i64 = __mind_load_i64(h_addr + 2 * 8);
    let mut wd: i64 = __mind_load_i64(h_addr + 3 * 8);
    let mut we: i64 = __mind_load_i64(h_addr + 4 * 8);
    let mut wf: i64 = __mind_load_i64(h_addr + 5 * 8);
    let mut wg: i64 = __mind_load_i64(h_addr + 6 * 8);
    let mut wh: i64 = __mind_load_i64(h_addr + 7 * 8);

    // 80-round compression loop (all additions wrap mod 2^64 in i64).
    let mut rnd: i64 = 0;
    while rnd < 80 {
        let t1: i64 = wh + sha512_bsig1(we) + sha512_ch(we, wf, wg) + sha512_k(rnd) + w512_get(w_addr, rnd);
        let t2: i64 = sha512_bsig0(wa) + sha512_maj(wa, wb, wc);
        wh = wg;
        wg = wf;
        wf = we;
        we = wd + t1;
        wd = wc;
        wc = wb;
        wb = wa;
        wa = t1 + t2;
        rnd = rnd + 1;
    }

    // Add the compressed chunk back into H.
    __mind_store_i64(h_addr + 0 * 8, __mind_load_i64(h_addr + 0 * 8) + wa);
    __mind_store_i64(h_addr + 1 * 8, __mind_load_i64(h_addr + 1 * 8) + wb);
    __mind_store_i64(h_addr + 2 * 8, __mind_load_i64(h_addr + 2 * 8) + wc);
    __mind_store_i64(h_addr + 3 * 8, __mind_load_i64(h_addr + 3 * 8) + wd);
    __mind_store_i64(h_addr + 4 * 8, __mind_load_i64(h_addr + 4 * 8) + we);
    __mind_store_i64(h_addr + 5 * 8, __mind_load_i64(h_addr + 5 * 8) + wf);
    __mind_store_i64(h_addr + 6 * 8, __mind_load_i64(h_addr + 6 * 8) + wg);
    __mind_store_i64(h_addr + 7 * 8, __mind_load_i64(h_addr + 7 * 8) + wh);
    0
}

// ---------------------------------------------------------------------------
// sha2_64_core — SHA-512 / SHA-384 shared driver. 128-byte blocks, 16-byte
// (128-bit) big-endian length field. out_words = 8 for SHA-512 (64 bytes) or 6
// for SHA-384 (48 bytes). is384 selects the IV.
//
// Padding (FIPS 180-4 §5.1.2): append 0x80, then zeros until the length is
// congruent to 112 (mod 128), then the 128-bit big-endian bit length. Messages
// here are < 2^61 bytes, so the top 64 bits of the length field are zero.
// ---------------------------------------------------------------------------
fn sha2_64_core(in_addr: i64, in_len: i64, out_addr: i64, out_words: i64, is384: i64) -> i64 {
    let tail: i64 = in_len % 128;
    let pad_zeros: i64 = if tail < 112 {
        111 - tail
    } else {
        239 - tail
    };
    let padded_len: i64 = in_len + 1 + pad_zeros + 16;

    let buf: i64 = __mind_alloc(padded_len);
    let mut ci: i64 = 0;
    while ci < in_len {
        __mind_store_i8(buf + ci, __mind_load_i8(in_addr + ci));
        ci = ci + 1;
    }

    // 0x80 terminator.
    __mind_store_i8(buf + in_len, 128);

    // Zero-fill padding (including the high 8 bytes of the 128-bit length).
    let mut zi: i64 = in_len + 1;
    while zi < padded_len - 8 {
        __mind_store_i8(buf + zi, 0);
        zi = zi + 1;
    }

    // Low 64 bits of the bit length, big-endian, in the final 8 bytes.
    let bit_len: i64 = in_len * 8;
    let len_off: i64 = padded_len - 8;
    __mind_store_i8(buf + len_off + 0, shr64u(bit_len, 56) & 255);
    __mind_store_i8(buf + len_off + 1, shr64u(bit_len, 48) & 255);
    __mind_store_i8(buf + len_off + 2, shr64u(bit_len, 40) & 255);
    __mind_store_i8(buf + len_off + 3, shr64u(bit_len, 32) & 255);
    __mind_store_i8(buf + len_off + 4, (bit_len >> 24) & 255);
    __mind_store_i8(buf + len_off + 5, (bit_len >> 16) & 255);
    __mind_store_i8(buf + len_off + 6, (bit_len >> 8) & 255);
    __mind_store_i8(buf + len_off + 7, bit_len & 255);

    // Initialise the 8-word H state.
    let h_addr: i64 = __mind_alloc(64);
    let mut hi: i64 = 0;
    while hi < 8 {
        __mind_store_i64(h_addr + hi * 8, sha512_hinit(hi, is384));
        hi = hi + 1;
    }

    // Process each 128-byte block.
    let num_blocks: i64 = padded_len / 128;
    let mut blk: i64 = 0;
    while blk < num_blocks {
        compress_block512(buf + blk * 128, h_addr);
        blk = blk + 1;
    }

    // Serialise out_words words, 8 bytes big-endian each.
    let mut di: i64 = 0;
    while di < out_words {
        let word: i64 = __mind_load_i64(h_addr + di * 8);
        __mind_store_i8(out_addr + di * 8 + 0, shr64u(word, 56) & 255);
        __mind_store_i8(out_addr + di * 8 + 1, shr64u(word, 48) & 255);
        __mind_store_i8(out_addr + di * 8 + 2, shr64u(word, 40) & 255);
        __mind_store_i8(out_addr + di * 8 + 3, shr64u(word, 32) & 255);
        __mind_store_i8(out_addr + di * 8 + 4, (word >> 24) & 255);
        __mind_store_i8(out_addr + di * 8 + 5, (word >> 16) & 255);
        __mind_store_i8(out_addr + di * 8 + 6, (word >> 8) & 255);
        __mind_store_i8(out_addr + di * 8 + 7, word & 255);
        di = di + 1;
    }
    0
}

// ---------------------------------------------------------------------------
// Public entry points.
// ---------------------------------------------------------------------------

// sha512 — 64-byte digest.
pub fn sha512(in_addr: i64, in_len: i64, out_addr: i64) -> i64 {
    sha2_64_core(in_addr, in_len, out_addr, 8, 0);
    0
}

// sha384 — 48-byte digest (SHA-512 core, SHA-384 IV, first 6 words emitted).
pub fn sha384(in_addr: i64, in_len: i64, out_addr: i64) -> i64 {
    sha2_64_core(in_addr, in_len, out_addr, 6, 1);
    0
}
